{
  "resources": {
    "includes": [
      {
        "pattern": "\\Qreference.conf\\E",
        "condition": {
          "typeReachable": "org.apache.pekko.actor.ActorSystem"
        }
      },
      {
        "pattern": "\\Qversion.conf\\E",
        "condition": {
          "typeReachable": "org.apache.pekko.actor.ActorSystem"
        }
      },
      {
        "pattern": "\\Qpekko-http-version.conf\\E",
        "condition": {
          "typeReachable": "org.apache.pekko.http.scaladsl.Http"
        }
      }
    ]
  },
  "bundles": [
  ]
}
