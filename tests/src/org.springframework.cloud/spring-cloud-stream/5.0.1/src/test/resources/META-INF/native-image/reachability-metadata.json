{
  "resources" : [
    {
      "condition" : {
        "typeReached" : "org.springframework.cloud.stream.config.BinderFactoryAutoConfiguration"
      },
      "glob" : "META-INF/spring.binders"
    },
    {
      "condition" : {
        "typeReached" : "org.springframework.cloud.stream.binder.DefaultBinderFactory"
      },
      "glob" : "META-INF/shared.beans"
    }
  ]
}
