{
  "resources": {
    "includes": [
      {
        "pattern": "\\Qorg_aspectj/aspectjweaver/util-class-loader-resource.txt\\E",
        "condition": {
          "typeReachable": "org.aspectj.util.UtilClassLoader"
        }
      },
      {
        "pattern": "\\Qorg_aspectj/aspectjweaver/pointcut-parser-lint.properties\\E",
        "condition": {
          "typeReachable": "org.aspectj.weaver.tools.PointcutParser"
        }
      },
      {
        "pattern": "\\Qorg/aspectj/apache/bcel/util/SyntheticRepository.class\\E",
        "condition": {
          "typeReachable": "org.aspectj.apache.bcel.util.SyntheticRepository"
        }
      },
      {
        "pattern": "\\Qorg_aspectj/aspectjweaver/Java15ReflectionBasedReferenceTypeDelegateTest$ParameterNameAspect.class\\E",
        "condition": {
          "typeReachable": "org.aspectj.weaver.reflect.Java15ReflectionBasedReferenceTypeDelegate"
        }
      }
    ]
  },
  "bundles": []
}
