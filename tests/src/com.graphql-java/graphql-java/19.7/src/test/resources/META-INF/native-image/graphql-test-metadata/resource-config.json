{
  "bundles": [
    {
      "name": "i18n.Execution"
    },
    {
      "name": "i18n.General"
    },
    {
      "name": "i18n.Validation"
    }
  ],
  "resources": {
    "includes": [
      {
        "pattern": "\\Qgraphql/greeting.graphqls\\E",
        "condition": {
          "typeReachable": "graphql.GraphQL"
        }
      },
      {
        "pattern": "\\Qgraphql/starwars.graphqls\\E",
        "condition": {
          "typeReachable": "graphql.GraphQL"
        }
      }
    ]
  }
}
