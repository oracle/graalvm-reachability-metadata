{
  "bundles": [],
  "resources": {
    "includes": [
      {
        "pattern": "\\Qgraphql/greeting.graphqls\\E",
        "condition": {
          "typeReachable": "graphql.GraphQL"
        }
      },
      {
        "pattern": "\\Qgraphql/starwars.graphqls\\E",
        "condition": {
          "typeReachable": "graphql.GraphQL"
        }
      },
      {
        "pattern": "\\QMETA-INF/services/javax.xml.stream.XMLOutputFactory\\E",
        "condition": {
          "typeReachable": "org.junit.platform.reporting.legacy.xml.XmlReportWriter"
        }
      },
      {
        "pattern": "\\QMETA-INF/services/java.net.spi.InetAddressResolverProvider\\E",
        "condition": {
          "typeReachable": "org.junit.platform.reporting.legacy.xml.XmlReportWriter"
        }
      }
    ]
  }
}
