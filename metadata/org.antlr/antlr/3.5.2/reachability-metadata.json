{
  "reflection" : [
    {
      "condition" : {
        "typeReached" : "org.antlr.tool.GrammarReport"
      },
      "type" : "org.antlr.tool.GrammarReport$ReportData",
      "allDeclaredFields" : true
    }
  ],
  "resources" : [
    {
      "condition" : {
        "typeReached" : "org.antlr.Tool"
      },
      "glob" : "org/antlr/antlr.properties"
    },
    {
      "condition" : {
        "typeReached" : "org.antlr.tool.ErrorManager"
      },
      "glob" : "org/antlr/tool/templates/messages/formats/antlr.stg"
    },
    {
      "condition" : {
        "typeReached" : "org.antlr.tool.ErrorManager"
      },
      "glob" : "org/antlr/tool/templates/messages/languages/en.stg"
    }
  ]
}
