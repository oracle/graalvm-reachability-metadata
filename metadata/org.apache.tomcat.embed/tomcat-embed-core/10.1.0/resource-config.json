{
  "resources": {
    "includes": [
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.net.Nio2Endpoint"
        },
        "pattern": "\\QMETA-INF/services/java.nio.channels.spi.AsynchronousChannelProvider\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.digester.Digester"
        },
        "pattern": "\\QMETA-INF/services/javax.xml.parsers.SAXParserFactory\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.compat.Jre16Compat"
        },
        "pattern": "\\QMETA-INF/services/org.apache.juli.logging.Log\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.net.AbstractEndpoint"
        },
        "pattern": "\\Qorg/apache/mbeans-descriptors.xml\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.net.AbstractEndpoint"
        },
        "pattern": "\\Qorg/apache/tomcat/mbeans-descriptors.xml\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.net.AbstractEndpoint"
        },
        "pattern": "\\Qorg/apache/tomcat/util/mbeans-descriptors.xml\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.modeler.modules.MbeansDescriptorsDigesterSource"
        },
        "pattern": "\\Qorg/apache/tomcat/util/modeler/mbeans-descriptors.dtd\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.net.AbstractEndpoint"
        },
        "pattern": "\\Qorg/apache/tomcat/util/net/mbeans-descriptors.xml\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.net.AbstractEndpoint"
        },
        "pattern": "\\Qorg/mbeans-descriptors.xml\\E"
      },
      {
        "condition": {
          "typeReachable": "org.apache.tomcat.util.modeler.Registry"
        },
        "pattern": "jdk.jfr:\\Qjdk/jfr/internal/query/view.ini\\E"
      }
    ]
  },
  "bundles": []
}
