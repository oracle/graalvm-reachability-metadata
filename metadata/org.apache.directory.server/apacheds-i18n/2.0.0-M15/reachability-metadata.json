{
  "resources": [
    {
      "condition": {
        "typeReached": "org.apache.directory.server.i18n.I18n"
      },
      "glob": "META-INF/services/java.util.spi.ResourceBundleControlProvider"
    },
    {
      "condition": {
        "typeReached": "org.apache.directory.server.i18n.I18n"
      },
      "glob": "org/apache/directory/server/i18n/errors.properties"
    },
    {
      "condition": {
        "typeReached": "org.apache.directory.server.i18n.I18n"
      },
      "glob": "org/apache/directory/server/i18n/errors_en.properties"
    },
    {
      "condition": {
        "typeReached": "org.apache.directory.server.i18n.I18n"
      },
      "glob": "org/apache/directory/server/i18n/errors_en_US.properties"
    },
    {
      "condition": {
        "typeReached": "org.apache.directory.server.i18n.I18n"
      },
      "glob": "org/apache/directory/server/i18n/messages.properties"
    },
    {
      "condition": {
        "typeReached": "org.apache.directory.server.i18n.I18n"
      },
      "glob": "org/apache/directory/server/i18n/messages_en.properties"
    },
    {
      "condition": {
        "typeReached": "org.apache.directory.server.i18n.I18n"
      },
      "glob": "org/apache/directory/server/i18n/messages_en_US.properties"
    },
    {
      "bundle": "org.apache.directory.server.i18n.errors"
    },
    {
      "bundle": "org/apache/directory/server/i18n/messages"
    }
  ]
