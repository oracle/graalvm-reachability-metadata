{
  "reflection" : [
    {
      "condition" : {
        "typeReached" : "org.springframework.boot.web.server.WebServerSslBundle"
      },
      "type" : "org.springframework.boot.io.Base64ProtocolResolver",
      "methods" : [
        {
          "name" : "<init>",
          "parameterTypes" : []
        }
      ]
    }
  ],
  "resources" : [
    {
      "glob" : "org/springframework/boot/web/server/mime-mappings.properties"
    },
    {
      "condition" : {
        "typeReached" : "org.springframework.boot.web.server.servlet.CookieSameSiteSupplier"
      },
      "bundle" : "jakarta.servlet.http.LocalStrings"
    }
  ]
}
