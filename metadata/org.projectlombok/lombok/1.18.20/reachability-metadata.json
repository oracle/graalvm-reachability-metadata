{
  "resources" : [
    {
      "condition" : {
        "typeReached" : "lombok.launch.ShadowClassLoader"
      },
      "glob" : "META-INF/services/javax.annotation.processing.Processor"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.ShadowClassLoader"
      },
      "glob" : "META-INF/services/lombok.*"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.ShadowClassLoader"
      },
      "glob" : "lombok/core/*.SCL.lombok"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.ShadowClassLoader"
      },
      "glob" : "lombok/core/**/*.SCL.lombok"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.ShadowClassLoader"
      },
      "glob" : "lombok/eclipse/agent/*.SCL.lombok"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.PatchFixesHider$Util"
      },
      "glob" : "lombok/eclipse/agent/PatchFixesShadowLoaded.SCL.lombok"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.PatchFixesHider$Util"
      },
      "glob" : "META-INF/services/lombok.core.PostCompilerTransformation"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.PatchFixesHider$Util"
      },
      "glob" : "lombok/core/*.SCL.lombok"
    },
    {
      "condition" : {
        "typeReached" : "lombok.launch.PatchFixesHider$Util"
      },
      "glob" : "lombok/core/**/*.SCL.lombok"
    }
  ]
}
