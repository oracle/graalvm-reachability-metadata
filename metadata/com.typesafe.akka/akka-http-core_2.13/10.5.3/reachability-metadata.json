{
  "reflection" : [
    {
      "condition" : {
        "typeReached" : "akka.http.impl.engine.http2.Http2AlpnSupport$"
      },
      "type" : "javax.net.ssl.SSLEngine",
      "methods" : [
        {
          "name" : "setHandshakeApplicationProtocolSelector",
          "parameterTypes" : [
            "java.util.function.BiFunction"
          ]
        }
      ]
    },
    {
      "condition" : {
        "typeReached" : "akka.http.impl.engine.client.PoolMasterActor$"
      },
      "type" : "akka.http.impl.engine.client.PoolMasterActor",
      "allDeclaredConstructors" : true
    }
  ],
  "resources" : [
    {
      "glob" : "akka-http-version.conf"
    },
    {
      "glob" : "akka-http-version.json"
    },
    {
      "glob" : "akka-http-version.properties"
    }
  ]
}
