{
  "reflection" : [
    {
      "condition" : {
        "typeReached" : "akka.actor.ActorSystem$"
      },
      "type" : "akka.http.impl.engine.client.PoolMasterActor",
      "allDeclaredConstructors" : true
    }
  ],
  "resources" : [
    {
      "condition" : {
        "typeReached" : "akka.actor.ActorSystem$"
      },
      "glob" : "akka-http-version.conf"
    },
    {
      "condition" : {
        "typeReached" : "akka.actor.ActorSystem$"
      },
      "glob" : "akka-http-version.json"
    },
    {
      "condition" : {
        "typeReached" : "akka.actor.ActorSystem$"
      },
      "glob" : "akka-http-version.properties"
    }
  ]
}
