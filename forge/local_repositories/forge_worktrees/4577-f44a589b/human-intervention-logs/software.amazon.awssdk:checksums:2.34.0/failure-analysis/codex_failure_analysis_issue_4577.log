CChecksum.create();\\n+        expected.update(PREFIX);\\n+        expected.update(REPLACEMENT_SUFFIX);\\n+        assertThat(checksum.getValue()).isEqualTo(expected.getValue());\\n+        assertThat(checksum.getChecksumBytes()).hasSize(Integer.BYTES);\\n+    }\\n+}\\n\\nFrom 3d30fe44cc81c1131200b099a9b84ff60595f9c4 Mon Sep 17 00:00:00 2001\\nFrom: Vojin Jovanovic <vojin.jovanovic@oracle.com>\\nDate: Mon, 4 May 2026 08:52:04 +0200\\nSubject: [PATCH 4/5] Update generated library support for\\n software.amazon.awssdk:checksums:2.34.0\\n\\n---\\n .../2.34.0/reachability-metadata.json         | 52 +++++++++++++++++++\\n .../checksums/2.34.0/stats.json               | 37 +++++++++++++\\n .../checksums/2.34.0/user-code-filter.json    |  9 ++--\\n 3 files changed, 95 insertions(+), 3 deletions(-)\\n create mode 100644 metadata/software.amazon.awssdk/checksums/2.34.0/reachability-metadata.json\\n create mode 100644 stats/software.amazon.awssdk/checksums/2.34.0/stats.json\\n\\ndiff --git a/metadata/software.amazon.awssdk/checksums/2.34.0/reachability-metadata.json b/metadata/software.amazon.awssdk/checksums/2.34.0/reachability-metadata.json\\nnew file mode 100644\\nindex 0000000000..75af66479e\\n--- /dev/null\\n+++ b/metadata/software.amazon.awssdk/checksums/2.34.0/reachability-metadata.json\\n@@ -0,0 +1,52 @@\\n+{\\n+  \\\"reflection\\\": [\\n+    {\\n+      \\\"condition\\\": {\\n+        \\\"typeReached\\\": \\\"software.amazon.awssdk.checksums.internal.ConstructorCache\\\"\\n+      },\\n+      \\\"type\\\": \\\"java.util.zip.CRC32C\\\"\\n+    },\\n+    {\\n+      \\\"condition\\\": {\\n+        \\\"typeReached\\\": \\\"software.amazon.awssdk.checksums.internal.CrcChecksumProvider\\\"\\n+      },\\n+      \\\"type\\\": \\\"java.util.zip.CRC32C\\\",\\n+      \\\"methods\\\": [\\n+        {\\n+          \\\"name\\\": \\\"<init>\\\",\\n+          \\\"parameterTypes\\\": []\\n+        }\\n+      ]\\n+    },\\n+    {\\n+      \\\"condition\\\": {\\n+        \\\"typeReached\\\