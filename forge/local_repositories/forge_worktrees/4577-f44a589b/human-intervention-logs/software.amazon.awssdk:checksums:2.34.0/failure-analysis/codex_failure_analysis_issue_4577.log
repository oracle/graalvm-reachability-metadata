static final byte[] PAYLOAD = \\\"The quick brown fox jumps over the lazy dog\\\".getBytes(StandardCharsets.UTF_8);\\n+\\n+    @Test\\n+    void crc32cImplementationUsesJavaCrc32cConstructor() {\\n+        SdkChecksum checksum = CrcChecksumProvider.crc32cImplementation();\\n+        CRC32C expected = new CRC32C();\\n+\\n+        checksum.update(PAYLOAD);\\n+        expected.update(PAYLOAD, 0, PAYLOAD.length);\\n+\\n+        assertThat(checksum.getValue()).isEqualTo(expected.getValue());\\n+        assertThat(checksum.getChecksumBytes()).hasSize(Integer.BYTES);\\n+    }\\n+\\n+    @Test\\n+    void crc64NvmeAlgorithmUsesCrtConstructor() {\\n+        SdkChecksum checksum = SdkChecksum.forAlgorithm(DefaultChecksumAlgorithm.CRC64NVME);\\n+\\n+        checksum.update(PAYLOAD);\\n+\\n+        assertThat(checksum.getValue()).isNotZero();\\n+        assertThat(checksum.getChecksumBytes()).hasSize(Long.BYTES);\\n+    }\\n+}\\n\\nFrom 9cc9459acb077bdb6318dc3753604a1b93f47c72 Mon Sep 17 00:00:00 2001\\nFrom: Vojin Jovanovic <vojin.jovanovic@oracle.com>\\nDate: Mon, 4 May 2026 08:34:30 +0200\\nSubject: [PATCH 3/5] Dynamic-access coverage for\\n software.amazon.awssdk.checksums.internal.CrcCloneOnMarkChecksum (5/6)\\n\\n---\\n .../checksums/CrcChecksumProviderTest.java    | 11 ++++-\\n .../checksums/CrcCloneOnMarkChecksumTest.java | 42 +++++++++++++++++++\\n 2 files changed, 52 insertions(+), 1 deletion(-)\\n create mode 100644 tests/src/software.amazon.awssdk/checksums/2.34.0/src/test/java/software_amazon_awssdk/checksums/CrcCloneOnMarkChecksumTest.java\\n\\ndiff --git a/tests/src/software.amazon.awssdk/checksums/2.34.0/src/test/java/software_amazon_awssdk/checksums/CrcChecksumProviderTest.java b/tests/src/software.amazon.awssdk/checksums/2.34.0/src/test/java/software_amazon_awssdk/checksums/CrcChecksumProviderTest.java\\nindex 6322f6c00c..08302df1a4 100644\\n--- a/tests/src/software.amazon.awssdk/checksums/2.34.0/src/test/java/software_amazon_awssdk/checksums/CrcChecksumProviderTest.java\\n+++ b/tests/src/software.amazon.awssdk/checksums/2.34.0/src/test/java/software_amazon_awssdk/checksums/CrcChecksumProviderTest.java\\n@@ -10,15 +10,22 @@\\n \\n import java.nio.charset.StandardCharsets;\\n import java.util.zip.CRC32C;\\n+import org.junit.jupiter.api.MethodOrderer;\\n+import org.junit.jupiter.api.Order;\\n import org.junit.jupiter.api.Test;\\n+import org.junit.jupiter.api.TestMethodOrder;\\n import software.amazon.awssdk.checksums.DefaultChecksumAlgorithm;\\n import software.amazon.awssdk.checksums.SdkChecksum;\\n import software.amazon.awssdk.checksums.internal.CrcChecksumProvider;\\n \\n+@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\\n public class CrcChecksumProviderTest {\\n-    private static final byte[] PAYLOAD = \\\"The quick brown fox jumps over the lazy dog\\\".getBytes(StandardCharsets.UTF_8);\\n+    private static final byte[] PAYLOAD =\\n+        \\\"The quick brown fox jumps over the lazy dog\\\".getBytes(StandardCharsets.UTF_8);\\n+    private static final String JAVA_CRC32C_PROVIDER_TYPE = \\\"CrcCombineOnMarkChecksum\\\";\\n \\n     @Test\\n+    @Order(1)\\n     void crc32cImplementationUsesJavaCrc32cConstructor() {\\n         SdkChecksum checksum = CrcChecksumProvider.crc32cImplementation();\\n         CRC32C expected = new CRC32C();\\n@@ -26,11 +33,13 @@ void crc32cImplementationUsesJavaCrc32cConstructor() {\\n         checksum.update(PAYLOAD);\\n         expected.update(PAYLOAD, 0, PAYLOAD.length);\\n \\n+        assertThat(checksum.getClass().getSimpleName()).isEqualTo(JAVA_CRC32C_PROVIDER_TYPE);\\n         assertThat(checksum.getValue()).isEqualTo(expected.getValue());\\n         assertThat(checksum.getChecksumBytes()).hasSize(Integer.BYTES);\\n     }\\n \\n     @Test\\n+    @Order(2)\\n     void crc64NvmeAlgorithmUsesCrtConstructor() {\\n         SdkChecksum checksum = SdkChecksum.forAlgorithm(DefaultChecksumAlgorithm.CRC64NVME);\\n \\ndiff --git a/tests/src/software.amazon.awssdk/checksums/2.34.0/src/test