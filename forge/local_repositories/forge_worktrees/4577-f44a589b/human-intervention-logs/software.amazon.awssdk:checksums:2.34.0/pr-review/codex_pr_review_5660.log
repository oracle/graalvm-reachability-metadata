m.forAlgorithm(DefaultChecksumAlgorithm.CRC64NVME);\n\n        checksum.update(PAYLOAD);\n\n        assertThat(checksum.getValue()).isNotZero();\n        assertThat(checksum.getChecksumBytes()).hasSize(Long.BYTES);\n    }\n}\n","exit_code":0,"status":"completed"}}
