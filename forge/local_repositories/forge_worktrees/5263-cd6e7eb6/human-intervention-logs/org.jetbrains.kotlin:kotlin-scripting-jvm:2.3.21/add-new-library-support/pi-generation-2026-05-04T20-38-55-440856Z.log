  package org_jetbrains_kotlin.kotlin_scripting_jvm
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  import kotlin.script.experimental.api.ScriptCompilationConfiguration
  import kotlin.script.experimental.jvm.impl.KJvmCompiledScript
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class KJvmCompiledScriptDataTest {
      @Test
      fun serializesAndDeserializesCompiledScriptData(): Unit {
          val script = KJvmCompiledScript(
              sourceLocationId = "memory://covered.kts",
              compilationConfiguration = ScriptCompilationConfiguration(),
              scriptClassFQName = "example.CoveredScript",
              resultField = null,
              otherScripts = ArrayList(),
              compiledModule = null,
          )
  
          val restoredScript: KJvmCompiledScript = roundTrip(script)
  
          assertThat(restoredScript.sourceLocationId).isEqualTo("memory://covered.kts")
          assertThat(restoredScript.compilationConfiguration.isEmpty()).isTrue()
          assertThat(restoredScript.scriptClassFQName).isEqualTo("example.CoveredScript")
          assertThat(restoredScript.resultField).isNull()
          assertThat(restoredScript.otherScripts).isEmpty()
          assertThat(restoredScript.getCompiledModule()).isNull()
      }
  
      private fun roundTrip(script: KJvmCompiledScript): KJvmCompiledScript {
          val serialized: ByteArray = ByteArrayOutputStream().use { byteStream ->
              ObjectOutputStream(byteStream).use { objectStream ->
                  objectStream.writeObject(script)
              }
              byteStream.toByteArray()
          }
  
          return ObjectInputStream(ByteArrayInputStream(serialized)).use { objectStream ->
              objectStream.readObject() as KJvmCompiledScript
          }
      }
  }
