{"type":"item.completed","item":{"id":"item_50","type":"command_execution","command":"/bin/bash -lc \"git -C /home/jovan/Work/graalvm-reachability-metadata show 'ai/jormundur00/add-lib-support-org.jetbrains.kotlin-kotlin-scripting-jvm-2.3.21:tests/src/org.jetbrains.kotlin/kotlin-scripting-jvm/2.3.21/src/test/kotlin/org_jetbrains_kotlin/kotlin_scripting_jvm/KJvmCompiledScriptDataTest.kt'\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jetbrains_kotlin.kotlin_scripting_jvm\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport kotlin.script.experimental.api.ScriptCompilationConfiguration\nimport kotlin.script.experimental.jvm.impl.KJvmCompiledScript\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class KJvmCompiledScriptDataTest {\n    @Test\n    fun serializesAndDeserializesCompiledScriptData(): Unit {\n        val script = KJvmCompiledScript(\n            sourceLocationId = \"memory://covered.kts\",\n            compilationConfiguration = ScriptCompilationConfiguration(),\n            scriptClassFQName = \"example.CoveredScript\",\n            resultField = null,\n            otherScripts = ArrayList(),\n            compiledModule = null,\n        )\n\n        val restoredScript: KJvmCompiledScript = roundTrip(script)\n\n        assertThat(restoredScript.sourceLocationId).isEqualTo(\"memory://covered.kts\")\n        assertThat(restoredScript.compilationConfiguration.isEmpty()).isTrue()\n        assertThat(restoredScript.scriptClassFQName).isEqualTo(\"example.CoveredScript\")\n        assertThat(restoredScript.resultField).isNull()\n        assertThat(restoredScript.otherScripts).isEmpty()\n        assertThat(restoredScript.getCompiledModule()).isNull()\n    }\n\n    private fun roundTrip(script: KJvmCompiledScript): KJvmCompiledScript {\n        val serialized: ByteArray = ByteArrayOutputStream().use { byteStream ->\n            ObjectOutputStream(byteStream).use { objectStream ->\n                objectStream.writeObject(script)\n            }\n            byteStream.toByteArray()\n        }\n\n        return ObjectInputStream(ByteArrayInputStream(serialized)).use { objectStream ->\n            objectStream.readObject() as KJvmCompiledScript\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
