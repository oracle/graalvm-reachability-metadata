/zero/1.0/>.\n */\npackage com_github_jnr.jffi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.catchThrowableOfType;\n\nimport com.kenai.jffi.Library;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.junit.jupiter.api.Test;\n\npublic class InitTest {\n    private static final String BOOT_LIBRARY_PATH_PROPERTY = \"jffi.boot.library.path\";\n    private static final String EXTRACT_DIR_PROPERTY = \"jffi.extract.dir\";\n    private static final String JAVA_LIBRARY_PATH_PROPERTY = \"java.library.path\";\n\n    @Test\n    void loadUsesStubLoaderFailureCauseWhenNativeStubCannotBeExtracted() throws IOException {\n        Path emptyLibraryPath = Files.createTempDirectory(\"jffi-empty-library-path\");\n        Path unusableExtractDirectory = Files.createTempFile(\"jffi-extract-target\", \".tmp\");\n\n        String previousBootLibraryPath = System.getProperty(BOOT_LIBRARY_PATH_PROPERTY);\n        String previousExtractDirectory = System.getProperty(EXTRACT_DIR_PROPERTY);\n        String previousJavaLibraryPath = System.getProperty(JAVA_LIBRARY_PATH_PROPERTY);\n        try {\n            System.setProperty(BOOT_LIBRARY_PATH_PROPERTY, emptyLibraryPath.toString());\n            System.setProperty(JAVA_LIBRARY_PATH_PROPERTY, emptyLibraryPath.toString());\n            System.setProperty(EXTRACT_DIR_PROPERTY, unusableExtractDirectory.toString());\n\n            UnsatisfiedLinkError error = catchThrowableOfType(\n                    () -> Library.openLibrary(null, 0), UnsatisfiedLinkError.class);\n\n            assertThat(error).isNotNull();\n            assertThat(error).hasMessageContaining(\"could not load jffi library from\");\n            assertThat(error).hasCauseInstanceOf(UnsatisfiedLinkError.class);\n        } finally {\n            restoreProperty(BOOT_LIBRARY_PATH_PROPERTY, previousBootLibraryPath);\n            restoreProperty(EXTRACT_DIR_PROPERTY, previousExtractDirectory);\n            restoreProperty(JAVA_LIBRARY_PATH_PROPERTY, previousJavaLibraryPath);\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.github.jnr/jffi/1.3.9/src/test/java/com_github_jnr/jffi/InitTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_github_jnr.jffi;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.catchThrowableOfType;\\n\\nimport com.kenai.jffi.Library;\\n\\nimport java.io.IOException;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\n\\nimport org.junit.jupiter.api.Test;\\n\\npublic class InitTest {\\n    private static final String BOOT_LIBRARY_PATH_PROPERTY = \\\"jffi.boot.library.path\\\";\\n    private static final String EXTRACT_DIR_PROPERTY = \\\"jffi.extract.dir\\\";\\n    private static final String JAVA_LIBRARY_PATH_PROPERTY = \\\"java.library.path\\\";\\n\\n    @Test\\n    void loadUsesStubLoaderFailureCauseWhenNativeStubCannotBeExtracted() throws IOException {\\n        Path emptyLibraryPath = Files.createTempDirectory(\\\"jffi-empty-library-path\\\");\\n        Path unusableExtractDirectory = Files.createTempFile(\\\"jffi-extract-target\\\", \\\".tmp\\\");\\n\\n        String previousBootLibraryPath = System.getProperty(BOOT_LIBRARY_PATH_PROPERTY);\\n        String previousExtractDirectory = System.getProperty(EXTRACT_DIR_PROPERTY);\\n        String previousJavaLibraryPath = System.getProperty(JAVA_LIBRARY_PATH_PROPERTY);\\n        try {\\n            System.setProperty(BOOT_LIBRARY_PATH_PROPERTY, emptyLibraryPath.to