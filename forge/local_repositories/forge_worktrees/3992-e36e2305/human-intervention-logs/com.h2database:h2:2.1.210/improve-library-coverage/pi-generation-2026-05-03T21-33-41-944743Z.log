 should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.CredentialsValidator;\nimport org.h2.api.UserToRolesMapper;\nimport org.h2.security.auth.AuthenticationInfo;\nimport org.h2.security.auth.ConfigProperties;\nimport org.h2.security.auth.DefaultAuthenticator;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultAuthenticatorTest implements CredentialsValidator, UserToRolesMapper {\n    @Test\n    void authenticatorConfigurationInstantiatesValidatorAndRoleMapperClasses() throws Exception {\n        Path config = Files.createTempFile(\"h2-auth\", \".xml\");\n        Files.writeString(config, \"\"\"\n                <h2Auth allowUserRegistration=\"true\" createMissingRoles=\"true\">\n                  <realm name=\"test\" validatorClass=\"h2.DefaultAuthenticatorTest\"/>\n                  <userToRolesMapper className=\"h2.DefaultAuthenticatorTest\"/>\n                </h2Auth>\n                \"\"\");\n        try {\n            DefaultAuthenticator authenticator = new DefaultAuthenticator();\n\n            authenticator.configureFromUrl(config.toUri().toURL());\n\n            assertThat(authenticator.getRealms()).containsOnlyKeys(\"TEST\");\n            assertThat(authenticator.getUserToRolesMappers()).hasSize(1);\n        } finally {\n            Files.deleteIfExists(config);\n        }\n    }\n\n    @Override\n    public boolean validateCredentials(AuthenticationInfo authenticationInfo) {\n        return true;\n    }\n\n    @Override\n    public Collection<String> mapUserToRoles(AuthenticationInfo authenticationInfo) {\n        return List.of(\"TEST_ROLE\");\n    }\n\n    @Override\n    public void configure(ConfigProperties configProperties) {\n    }\n}\n"}}], "a