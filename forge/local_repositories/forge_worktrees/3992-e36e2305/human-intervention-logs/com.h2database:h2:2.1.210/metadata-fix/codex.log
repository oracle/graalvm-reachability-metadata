{"type":"item.completed","item":{"id":"item_39","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,260p' tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DatabaseTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.DatabaseEventListener;\nimport org.h2.api.JavaObjectSerializer;\nimport org.h2.api.TableEngine;\nimport org.h2.command.ddl.CreateTableData;\nimport org.h2.mvstore.db.MVTable;\nimport org.h2.table.Table;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.charset.StandardCharsets;\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.PreparedStatement;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.Types;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DatabaseTest implements DatabaseEventListener, JavaObjectSerializer, TableEngine {\n    private static final AtomicInteger EVENT_LISTENER_INITS = new AtomicInteger();\n    private static final AtomicInteger SERIALIZE_CALLS = new AtomicInteger();\n    private static final AtomicInteger DESERIALIZE_CALLS = new AtomicInteger();\n    private static final AtomicInteger TABLE_ENGINE_CALLS = new AtomicInteger();\n\n    @Test\n    void databaseInstantiatesConfiguredEventListenerAndJavaObjectSerializer() throws Exception {\n        EVENT_LISTENER_INITS.set(0);\n        SERIALIZE_CALLS.set(0);\n        DESERIALIZE_CALLS.set(0);\n        String className = getClass().getName();\n        String url = \"jdbc:h2:mem:databaseDynamicAccess;DATABASE_EVENT_LISTENER='\" + className\n                + \"';JAVA_OBJECT_SERIALIZER='\" + className + \"'\";\n\n        try (Connection connection = DriverManager.getConnection(url)) {\n            connection.createStatement().execute(\"CREATE TABLE objects(id INT PRIMARY KEY, payload JAVA_OBJECT)\");\n            try (PreparedStatement statement = connection.prepareStatement(\"INSERT INTO objects VALUES (?, ?)\")) {\n                statement.setInt(1, 1);\n                statement.setObject(2, \"serialized-value\", Types.JAVA_OBJECT);\n                assertThat(statement.executeUpdate()).isEqualTo(1);\n            }\n            try (ResultSet resultSet = connection.createStatement().executeQuery(\"SELECT payload FROM objects\")) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getObject(1)).isEqualTo(\"serialized-value\");\n            }\n        }\n\n        assertThat(EVENT_LISTENER_INITS.get()).isEqualTo(1);\n        assertThat(SERIALIZE_CALLS.get()).isPositive();\n        assertThat(DESERIALIZE_CALLS.get()).isPositive();\n    }\n\n    @Test\n    void databaseInstantiatesConfiguredTableEngine() throws Exception {\n        TABLE_ENGINE_CALLS.set(0);\n\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:databaseTableEngine\")) {\n            connection.createStatement().execute(\"CREATE TABLE engine_items(id INT PRIMARY KEY, name VARCHAR) ENGINE \\\"\"\n                    + getClass().getName() + \"\\\"\");\n            connection.createStatement().execute(\"INSERT INTO engine_items VALUES (1, 'alpha')\");\n            try (ResultSet resultSet = connection.createStatement()\n                    .executeQuery(\"SELECT name FROM engine_items WHERE id = 1\")) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getString(1)).isEqualTo(\"alpha\");\n            }\n        }\n\n        assertThat(TABLE_ENGINE_CALLS.get()).isEqualTo(1);\n    }\n\n    @Override\n    public void init(String url) {\n        EVENT_LISTENER_INITS.incrementAndGet();\n    }\n\n    @Override\n    public byte[] serialize(Object obj) {\n        SERIALIZE_CALLS.incrementAndGet();\n        return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);\n    }\n\n    @Override\n    public Object deserialize(byte[] bytes) {\n        DESERIALIZE_CALLS.incrementAndGet();\n        return new String(bytes, StandardCharsets.UTF_8);\n    }\n\n    @Override\n    public void exceptionThrown(SQLException e, String sql) {\n        throw new AssertionError(sql, e);\n    }\n\n    @Override\n    public Table createTable(CreateTableData data) {\n        TABLE_ENGINE_CALLS.incrementAndGet();\n        return new MVTable(data, data.session.getDatabase().getStore());\n    }\n}\n","exit_code":0,"status":"completed"}}
