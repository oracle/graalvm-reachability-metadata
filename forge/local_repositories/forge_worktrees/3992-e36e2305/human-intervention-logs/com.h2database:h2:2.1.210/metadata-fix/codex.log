{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,260p' tests/src/com.h2database/h2/2.1.210/src/test/java/h2/TriggerObjectTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.h2.api.Trigger;\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.ResultSet;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TriggerObjectTest implements Trigger {\n    private static final AtomicInteger FIRED = new AtomicInteger();\n\n    @Test\n    void triggerClassIsLoadedAndConstructedReflectively() throws Exception {\n        FIRED.set(0);\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:triggerObject\")) {\n            connection.createStatement().execute(\"CREATE TABLE items(id INT PRIMARY KEY, name VARCHAR)\");\n            connection.createStatement().execute(\"CREATE TRIGGER item_trigger BEFORE INSERT ON items FOR EACH ROW CALL '\"\n                    + getClass().getName() + \"'\");\n            connection.createStatement().execute(\"INSERT INTO items VALUES (1, 'alpha')\");\n        }\n\n        assertThat(FIRED.get()).isEqualTo(1);\n    }\n\n    @Test\n    void triggerSourceIsCompiledAndInvokedReflectively() throws Exception {\n        try {\n            try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:triggerObjectSource\")) {\n                connection.createStatement().execute(\"CREATE TABLE source_items(id INT PRIMARY KEY)\");\n                connection.createStatement().execute(\"\"\"\n                        CREATE TRIGGER source_item_trigger BEFORE INSERT ON source_items FOR EACH ROW AS\n                        'org.h2.api.Trigger create() { return (conn, oldRow, newRow) -> { newRow[0] = 42; }; }'\n                        \"\"\");\n                connection.createStatement().execute(\"INSERT INTO source_items VALUES (1)\");\n\n                try (ResultSet resultSet = connection.createStatement()\n                        .executeQuery(\"SELECT id FROM source_items\")) {\n                    assertThat(resultSet.next()).isTrue();\n                    assertThat(resultSet.getInt(1)).isEqualTo(42);\n                }\n            }\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n        }\n    }\n\n    @Override\n    public void fire(Connection conn, Object[] oldRow, Object[] newRow) {\n        FIRED.incrementAndGet();\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
