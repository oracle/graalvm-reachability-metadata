{"type":"item.completed","item":{"id":"item_38","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,220p' tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DefaultAuthenticatorTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.CredentialsValidator;\nimport org.h2.api.UserToRolesMapper;\nimport org.h2.security.auth.AuthenticationInfo;\nimport org.h2.security.auth.ConfigProperties;\nimport org.h2.security.auth.DefaultAuthenticator;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultAuthenticatorTest implements CredentialsValidator, UserToRolesMapper {\n    @Test\n    void authenticatorConfigurationInstantiatesValidatorAndRoleMapperClasses() throws Exception {\n        Path config = Files.createTempFile(\"h2-auth\", \".xml\");\n        Files.writeString(config, \"\"\"\n                <h2Auth allowUserRegistration=\"true\" createMissingRoles=\"true\">\n                  <realm name=\"test\" validatorClass=\"h2.DefaultAuthenticatorTest\"/>\n                  <userToRolesMapper className=\"h2.DefaultAuthenticatorTest\"/>\n                </h2Auth>\n                \"\"\");\n        try {\n            DefaultAuthenticator authenticator = new DefaultAuthenticator();\n\n            authenticator.configureFromUrl(config.toUri().toURL());\n\n            assertThat(authenticator.isAllowUserRegistration()).isTrue();\n            assertThat(authenticator.isCreateMissingRoles()).isTrue();\n            assertThat(authenticator.getUserToRolesMappers()).hasSize(1);\n        } finally {\n            Files.deleteIfExists(config);\n        }\n    }\n\n    @Override\n    public boolean validateCredentials(AuthenticationInfo authenticationInfo) {\n        return true;\n    }\n\n    @Override\n    public Collection<String> mapUserToRoles(AuthenticationInfo authenticationInfo) {\n        return List.of(\"TEST_ROLE\");\n    }\n\n    @Override\n    public void configure(ConfigProperties configProperties) {\n        // No configuration is needed for this test implementation.\n    }\n}\n","exit_code":0,"status":"completed"}}
