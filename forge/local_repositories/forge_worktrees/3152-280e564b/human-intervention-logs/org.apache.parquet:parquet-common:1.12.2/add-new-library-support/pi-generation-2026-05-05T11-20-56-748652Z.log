  package org_apache_parquet.parquet_common;
  
  import org.apache.parquet.util.DynConstructors;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DynConstructorsInnerBuilderTest {
      @Test
      void implLoadsPublicConstructorByName() throws Exception {
          DynConstructors.Ctor<PublicGreeting> constructor = new DynConstructors.Builder(Greeting.class)
                  .impl(PublicGreeting.class.getName(), String.class)
                  .buildChecked();
  
          PublicGreeting greeting = constructor.newInstanceChecked("parquet");
  
          assertThat(constructor.getConstructedClass()).isEqualTo(PublicGreeting.class);
          assertThat(greeting.message()).isEqualTo("hello parquet");
      }
  
      @Test
      void hiddenImplLoadsPrivateConstructorByName() throws Exception {
          DynConstructors.Ctor<PrivateGreeting> constructor = new DynConstructors.Builder(Greeting.class)
                  .hiddenImpl(PrivateGreeting.class.getName(), String.class)
                  .buildChecked();
  
          PrivateGreeting greeting = constructor.newInstanceChecked("parquet");
  
          assertThat(constructor.getConstructedClass()).isEqualTo(PrivateGreeting.class);
          assertThat(greeting.message()).isEqualTo("hidden parquet");
      }
  
      private interface Greeting {
          String message();
      }
  
      public static final class PublicGreeting implements Greeting {
          private final String name;
  
          public PublicGreeting(String name) {
              this.name = name;
          }
  
          @Override
          public String message() {
              return "hello " + name;
          }
      }
  
      private static final class PrivateGreeting implements Greeting {
          private final String name;
  
          private PrivateGreeting(String name) {
              this.name = name;
          }
  
          @Override
          public String message() {
              return "hidden " + name;
          }
      }
  }
