  package org_apache_parquet.parquet_common;
  
  import org.apache.parquet.util.DynMethods;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DynMethodsInnerBuilderTest {
      @Test
      void implLoadsPublicMethodByClassName() throws Exception {
          DynMethods.UnboundMethod method = new DynMethods.Builder("greeting")
                  .impl(PublicMethods.class.getName(), String.class)
                  .buildChecked();
  
          String greeting = method.invoke(null, "parquet");
  
          assertThat(method.isStatic()).isTrue();
          assertThat(greeting).isEqualTo("hello parquet");
      }
  
      @Test
      void hiddenImplLoadsPrivateMethodByClassName() throws Exception {
          DynMethods.UnboundMethod method = new DynMethods.Builder("hiddenGreeting")
                  .hiddenImpl(HiddenMethods.class.getName(), String.class)
                  .buildChecked();
  
          String greeting = method.invoke(null, "parquet");
  
          assertThat(method.isStatic()).isTrue();
          assertThat(greeting).isEqualTo("hidden parquet");
      }
  
      public static final class PublicMethods {
          private PublicMethods() {
          }
  
          public static String greeting(String name) {
              return "hello " + name;
          }
      }
  
      private static final class HiddenMethods {
          private HiddenMethods() {
          }
  
          private static String hiddenGreeting(String name) {
              return "hidden " + name;
          }
