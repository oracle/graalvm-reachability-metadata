[tool-call] delta {"path":"tests/src/org.apache.parquet/parquet-common/1.12.2/src/test/java/org_apache_parquet/parquet_common/DynConstructorsInnerBuilderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_parquet.parquet_common;\n\nimport org.apache.parquet.util.DynConstructors;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DynConstructorsInnerBuilderTest {\n    @Test\n    void implLoadsPublicConstructorByName() throws Exception {\n        DynConstructors.Ctor<PublicGreeting> constructor = new DynConstructors.Builder(Greeting.class)\n                .impl(PublicGreeting.class.getName(), String.class)\n                .buildChecked();\n\n        PublicGreeting greeting = constructor.newInstanceChecked(\"parquet\");\n\n        assertThat(constructor.getConstructedClass()).isEqualTo(PublicGreeting.class);\n        assertThat(greeting.message()).isEqualTo(\"hello parquet\");\n    }\n\n    @Test\n    void hiddenImplLoadsPrivateConstructorByName() throws Exception {\n        DynConstructors.Ctor<PrivateGreeting> constructor = new DynConstructors.Builder(Greeting.class)\n                .hiddenImpl(PrivateGreeting.class.getName(), String.class)\n                .buildChecked();\n\n        PrivateGreeting greeting = constructor.newInstanceChecked(\"parquet\");\n\n        assertThat(constructor.getConstructedClass()).isEqualTo(PrivateGreeting.class);\n        assertThat(greeting.message()).isEqualTo(\"hidden parquet\");\n    }\n\n    private interface Greeting {\n        String message();\n    }\n\n    public static final class PublicGreeting implements Greeting {\n        private final String name;\n\n        public PublicGreeting(String name) {\n            this.name = name;\n        }\n\n        @Override\n        public String message() {\n            return \"hello \" + name;\n        }\n    }\n\n    private static final class PrivateGreeting implements Greeting {\n        private final String name;\n\n        private PrivateGreeting(String name) {\n            this.name = name;\n        }\n\n        @Override\n        public String message() {\n            return \"hidden \" + name;\n        }\n    }\n}\n"}
