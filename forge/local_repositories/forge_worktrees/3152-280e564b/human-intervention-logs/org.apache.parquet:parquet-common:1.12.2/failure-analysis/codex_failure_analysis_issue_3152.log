ash -lc \\\"find . -path '*org.apache.parquet:parquet-common:1.12.2*' | sed -n '1,240p'\\\"\",\"aggregated_output\":\"./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/native-test-verify\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/native-test-verify/cycle-0-test-2026-05-05T11-26-45-457712Z.log\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/native-test-verify/cycle-0-generateMetadata-2026-05-05T11-12-07-382109Z.log\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/native-test-verify/cycle-0-generateMetadata-2026-05-05T11-41-46-441694Z.log\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/native-test-verify/cycle-0-generateMetadata-2026-05-05T11-25-59-646480Z.log\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/native-test-verify/cycle-0-test-2026-05-05T11-13-32-931084Z.log\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/native-test-verify/cycle-0-test-2026-05-05T11-42-37-095035Z.log\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/gradle-test\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/gradle-test/gradle-test-2026-05-05T11-31-42-115528Z.log\\n./forge/local_repositories/forge_worktrees/3152-280e564b/human-intervention-logs/org.apache.parquet:parquet-common:1.12.2/gradle-test/g