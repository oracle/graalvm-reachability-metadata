ic List<Capability> resolveTimeContractCapabilities(Resource resource) {\", \"newText\": \"    private static List<Capability> contractCapabilitiesNamedInFilter(Resource resource, Requirement requirement) {\\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\\n        return resource.getCapabilities(requirement.getNamespace()).stream()\\n                .filter(capability -> filter.contains(\\\"(\\\" + ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + contractName(capability) + \\\")\\\"))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<String> packagesUsedBy(Capability capability) {\\n        String usesDirective = capability.getDirectives().get(Namespace.CAPABILITY_USES_DIRECTIVE);\\n        assertThat(usesDirective).isNotBlank();\\n        return Arrays.stream(usesDirective.split(\\\",\\\"))\\n                .map(String::trim)\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Capability> contractCapabilitiesUsingPackage(Resource resource, String packageName) {\\n        return resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE).stream()\\n                .filter(capability -> packagesUsedBy(capability).contains(packageName))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Capability> resolveTimeContractCapabilities(Resource resource) {\"}]}, \"partialJson\": \"{\\\"path\\\":\\\"tests/src/org.osgi/org.osgi.namespace.contract/1.0.0/src/test/java/org_osgi/org_osgi_namespace_contract/Org_osgi_namespace_contractTest.java\\\",\\\"edits\\\":[{\\\"oldText\\\":\\\"import java.util.ArrayList;\\\\nimport java.util.LinkedHashMap;\\\",\\\"newText\\\":\\\"import java.util.ArrayList;\\\\nimport java.util.Arrays;\\\\nimport java.util.LinkedHashMap;\\\"},{\\\"oldText\\\":\\\"    @Test\\\\n    void contractRequirementUsesNamespaceNameAndVersionRangeFilter() {\\\",\\\"newText\\\":\\\"    @Test\\\\n    void usesDi