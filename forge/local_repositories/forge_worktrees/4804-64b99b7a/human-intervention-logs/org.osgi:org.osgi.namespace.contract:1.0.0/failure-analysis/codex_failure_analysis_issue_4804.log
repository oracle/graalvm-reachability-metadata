{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,220p' tests/src/org.osgi/org.osgi.namespace.contract/1.0.0/src/test/java/org_osgi/org_osgi_namespace_contract/Org_osgi_namespace_contractTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_osgi.org_osgi_namespace_contract;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Objects;\nimport java.util.stream.Collectors;\nimport org.junit.jupiter.api.Test;\nimport org.osgi.framework.Version;\nimport org.osgi.namespace.contract.ContractNamespace;\nimport org.osgi.resource.Capability;\nimport org.osgi.resource.Namespace;\nimport org.osgi.resource.Requirement;\nimport org.osgi.resource.Resource;\n\npublic class Org_osgi_namespace_contractTest {\n    private static final String SERVLET_CONTRACT = \"JavaServlet\";\n    private static final String TRANSACTION_CONTRACT = \"JavaTransaction\";\n    private static final String JAX_RS_CONTRACT = \"JavaJAXRS\";\n    private static final String CONTRACT_SPECIFICATION_ATTRIBUTE = \"specification\";\n    private static final String CONTRACT_VENDOR_ATTRIBUTE = \"vendor\";\n\n    @Test\n    void constantsExposeContractNamespaceContract() {\n        assertThat(ContractNamespace.class).isNotNull();\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).isEqualTo(\"osgi.contract\");\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).startsWith(\"osgi.\").doesNotContain(\" \");\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isEqualTo(\"version\");\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isNotEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n    }\n\n    @Test\n    void contractCapabilityUsesNamespaceAttributeAndVersionAttribute() {\n        SyntheticResource resource = new SyntheticResource();\n        Version servletVersion = new Version(3, 1, 0);\n        Capability capability = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, \"javax.servlet,javax.servlet.http\"),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, servletVersion));\n\n        assertThat(capability.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(capability.getResource()).isSameAs(resource);\n        assertThat(capability.getDirectives()).containsEntry(Namespace.CAPABILITY_USES_DIRECTIVE, \"javax.servlet,javax.servlet.http\");\n        assertThat(capability.getAttributes())\n                .containsEntry(ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT)\n                .containsEntry(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, servletVersion);\n        assertThatThrownBy(() -> capability.getAttributes().put(\"extra\", \"value\"))\n                .isInstanceOf(UnsupportedOperationException.class);\n    }\n\n    @Test\n    void contractRequirementUsesFilterResolutionAndEffectiveDirectives() {\n        SyntheticResource resource = new SyntheticResource();\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractVersionFilter(SERVLET_CONTRACT, \"3.1.0\"),\n                        Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_OPTIONAL,\n                        Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_ACTIVE),\n                Map.of(\"consumer\", \"web.application\"));\n\n        assertThat(requirement.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(requirement.getResource()).isSameAs(resource);\n        assertThat(requirement.getDirectives())\n                .containsEntry(Namespace.REQUIREMENT_FILTER_DIRECTIVE, \"(&(osgi.contract=JavaServlet)(version>=3.1.0))\")\n                .containsEntry(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_OPTIONAL)\n                .containsEntry(Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_ACTIVE);\n        assertThat(requirement.getAttributes()).containsEntry(\"consumer\", \"web.application\");\n    }\n\n    @Test\n    void resourceFilteringSeparatesContractCapabilitiesAndRequirementsFromOtherNamespaces() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability servletCapability = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(3, 1, 0)));\n        Capability transactionCapability = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, TRANSACTION_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(1, 2, 0)));\n        resource.addCapability(\"osgi.identity\", Map.of(), Map.of(\"osgi.identity\", \"sample.bundle\"));\n\n        Requirement contractRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractVersionFilter(SERVLET_CONTRACT, \"3.1.0\")),\n                Map.of());\n        resource.addRequirement(\"osgi.wiring.package\", Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, \"(osgi.wiring.package=javax.servlet)\"), Map.of());\n\n        assertThat(resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(servletCapability, transactionCapability);\n        assertThat(resource.getCapabilities(null)).hasSize(3);\n        assertThat(resource.getCapabilities(\"osgi.identity\")).extracting(Capability::getNamespace).containsExactly(\"osgi.identity\");\n        assertThat(resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(contractRequirement);\n        assertThat(resource.getRequirements(\"osgi.wiring.package\")).hasSize(1);\n    }\n\n    @Test\n    void contractNameAttributeSupportsSelectingAllCapabilitiesForTheSameContract() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability servlet31 = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(3, 1, 0)));\n        Capability servlet40 = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(4, 0, 0)));\n        resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, TRANSACTION_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(1, 2, 0)));\n\n        List<Capability> servletContracts = contractCapabilitiesNamed(resource, SERVLET_CONTRACT);\n        List<Capability> transactionContracts = contractCapabilitiesNamed(resource, TRANSACTION_CONTRACT);\n        List<Capability> missingContracts = contractCapabilitiesNamed(resource, JAX_RS_CONTRACT);\n\n        assertThat(servletContracts).containsExactly(servlet31, servlet40);\n        assertThat(transactionContracts).hasSize(1);\n        assertThat(missingContracts).isEmpty();\n    }\n\n    @Test\n    void versionAttributeSupportsMinimumVersionRequirementMatching() {\n        SyntheticResource resource = new SyntheticResource();\n        resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(3, 0, 0)));\n        Capability servlet31 = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(3, 1, 0)));\n        Capability servlet40 = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(4, 0, 0)));\n        resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, TRANSACTION_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(1, 2, 0)));\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractVersionFilter(SERVLET_CONTRACT, \"3.1.0\")),\n                Map.of());\n\n        List<Capability> matchingCapabilities = contractCapabilitiesAtLeast(resource, requirement, SERVLET_CONTRACT, new Version(3, 1, 0));\n\n        assertThat(matchingCapabilities).containsExactly(servlet31, servlet40);\n    }\n\n    @Test\n    void arbitraryContractAttributesParticipateInMatchingAlongsideContractNameAndVersion() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability jakartaServlet = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(5, 0, 0),\n                        CONTRACT_SPECIFICATION_ATTRIBUTE, \"Jakarta Servlet\",\n                        CONTRACT_VENDOR_ATTRIBUTE, \"Eclipse Foundation\"));\n        resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, new Version(4, 0, 0),\n                        CONTRACT_SPECIFICATION_ATTRIBUTE, \"Java Servlet\",\n                        CONTRACT_VENDOR_ATTRIBUTE, \"Oracle\"));\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(&(osgi.contract=JavaServlet)(version>=5.0.0)(specification=Jakarta Servlet)(vendor=Eclipse Foundation))\"),\n                Map.of());\n\n        List<Capability> matchingCapabilities = contractCapabilitiesWithAttributes(\n                resource,\n                requirement,\n                SERVLET_CONTRACT,\n                new Version(5, 0, 0),\n                \"Jakarta Servlet\",\n                \"Eclipse Foundation\");\n\n        assertThat(matchingCapabilities).containsExactly(jakartaServlet);\n        assertThat(jakartaServlet.getAttributes())\n                .containsEntry(CONTRACT_SPECIFICATION_ATTRIBUTE, \"Jakarta Servlet\")\n                .containsEntry(CONTRACT_VENDOR_ATTRIBUTE, \"Eclipse Foundation\");\n    }\n\n    private static String contractVersionFilter(String contractName, String minimumVersion) {\n        return \"(&(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName + \")(\"\n","exit_code":0,"status":"completed"}}
