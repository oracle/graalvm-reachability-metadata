c String contractRangeFilter(String contractName, String floorVersion, String ceilingVersion) {\n", "newText": "    @Test\n    void requirementFilterCanSelectAlternativeContracts() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        resource.addContractCapability(JSON_P_CONTRACT, \"1.0.0\");\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(|(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + SERVLET_CONTRACT + \")(\" +\n                                ContractNamespace.CONTRACT_NAMESPACE + \"=\" + JAX_RS_CONTRACT + \"))\"),\n                Map.of());\n\n        assertThat(contractCapabilitiesNamedInFilter(resource, requirement)).containsExactly(servlet, jaxRs);\n    }\n\n    @Test\n    void listValuedContractAttributeCanAdvertiseAliasesForSameCapability() {\n        SyntheticResource resource = new SyntheticResource();\n        List<String> servletContractNames = List.of(SERVLET_CONTRACT, \"JavaServlet31\");\n        Capability servletCapability = resource.addCapability(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, \"javax.servlet,javax.servlet.http\"),\n                Map.of(\n                        ContractNamespace.CONTRACT_NAMESPACE, servletContractNames,\n                        ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, SemanticVersion.parse(\"3.1.0\"),\n                        IMPLEMENTATION_ATTRIBUTE, \"web-container\"));\n        resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        Requirement canonicalNameRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + SERVLET_CONTRACT + \")\"),\n                Map.of());\n        Requirement aliasRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=JavaServlet31)\"),\n                Map.of());\n\n        assertThat(contractNames(servletCapability)).containsExactly(SERVLET_CONTRACT, \"JavaServlet31\");\n        assertThat(contractCapabilitiesMatchingContractName(resource, canonicalNameRequirement, SERVLET_CONTRACT))\n                .containsExactly(servletCapability);\n        assertThat(contractCapabilitiesMatchingContractName(resource, aliasRequirement, \"JavaServlet31\"))\n                .containsExactly(servletCapability);\n        assertThat(contractCapabilitiesMatchingContractName(resource, aliasRequirement, JAX_RS_CONTRACT)).isEmpty();\n    }\n\n    private static String contractRangeFilter(String contractName, String floorVersion, String ceilingVersion) {\n"}, {"oldText": "    private static List<Capability> contractCapabilitiesNamedInFilter(Resource resource, Requirement requirement) {\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> filter.contains(\"(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName(capability) + \")\"))\n                .collect(Collectors.toList());\n    }\n\n    private static List<String> packagesUsedBy(Capability capability) {\n", "newText": "    private static List<Capability> contractCapabilitiesNamedInFilter(Resource resource, Requirement requirement) {\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> filter.contains(\"(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName(capability) + \")\"))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> contractCapabilitiesMatchingContractName(\n            Resource resource,\n            Requirement requirement,\n            String contractName) {\n        assertThat(requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE))\n                .contains(\"(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName + \")\");\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> contractNames(capability).contains(contractName))\n                .collect(Collectors.toList());\n    }\n\n    private static List<String> packagesUsedBy(Capability capability) {\n"}, {"oldText": "    private static String contractName(Capability capability) {\n        Object value = capability.getAttributes().get(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(value).isInstanceOf(String.class);\n        return value.toString();\n    }\n\n    private static SemanticVersion contractVersion(Capability capability) {\n", "newText": "    private static String contractName(Capability capability) {\n        Object value = capability.getAttributes().get(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(value).isInstanceOf(String.class);\n        return value.toString();\n    }\n\n    private static List<String> contractNames(Capability capability) {\n        Object value = capability.getAttributes().get(ContractNamespace.CONTRACT_NAMESPACE);\n        if (value instanceof String) {\n            return List.of(value.toString());\n        }\n        assertThat(value).isInstanceOf(List.class);\n        List<?> values = (List<?>) value;\n        assertThat(values).allSatisfy(contractName -> assertThat(contractName).isInstanceOf(String.class));\n        return values.stream()\n                .map(Object::toString)\n                .collect(Collectors.toList());\n    }\n\n    private static SemanticVersion contractVersion(Capability capability) {\n"}]}, "partialJson": "{\"path\":\"tests/src/org.osgi/org.osgi.namespace.contract/1.0.0/src/test/java/org_osgi/org_osgi_namespace_contract/Org_osgi_namespace_contractTest.java\",\"edits\":[{\"oldText\":\"    @Test\\n    void requirementFilterCanSelectAlternativeContracts() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \\\"3.1.0\\\");\\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \\\"2.0.0\\\");\\n        resource.addContractCapability(JSON_P_CONTRACT, \\\"1.0.0\\\");\\n        Requirement requirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\\n                        \\\"(|(\\\" + ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + SERVLET_CONTRACT + \\\")(\\\" +\\n                                ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + JAX_RS_CONTRACT + \\\"))\\\"),\\n                Map.of());\\n\\n        assertThat(contractCapabilitiesNamedInFilter(resource, requirement)).containsExactly(servlet, jaxRs);\\n    }\\n\\n    private static String contractRangeFilter(String contractName, String floorVersion, String ceilingVersion) {\\n\",\"newText\":\"    @Test\\n    void requirementFilterCanSelectAlternativeContracts() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \\\"3.1.0\\\");\\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \\\"2.0.0\\\");\\n        resource.addContractCapability(JSON_P_CONTRACT, \\\"1.0.0\\\");\\n        Requirement requirement = re