      void constantsExposeContractNamespaceContract() {
          assertThat(ContractNamespace.CONTRACT_NAMESPACE).isEqualTo("osgi.contract");
          assertThat(ContractNamespace.CONTRACT_NAMESPACE).startsWith("osgi.").doesNotContain(" ");
          assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isEqualTo("version");
          assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isNotEqualTo(ContractNamespace.CONTRACT_NAMESPACE);
      }
  
      @Test
      void contractCapabilityUsesNamespaceAsContractNameAndVersionAttribute() {
          SyntheticResource resource = new SyntheticResource();
          SemanticVersion servletVersion = SemanticVersion.parse("3.1.0");
          Capability capability = resource.addContractCapability(
                  SERVLET_CONTRACT,
                  servletVersion,
                  Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, "javax.servlet,javax.servlet.http"),
                  Map.of(
                          IMPLEMENTATION_ATTRIBUTE, "sample-web-container",
                          SPECIFICATION_ATTRIBUTE, "JSR-340"));
  
          assertThat(capability.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);
          assertThat(capability.getResource()).isSameAs(resource);
          assertThat(capability.getDirectives())
                  .containsEntry(Namespace.CAPABILITY_USES_DIRECTIVE, "javax.servlet,javax.servlet.http");
          assertThat(capability.getAttributes())
                  .containsEntry(ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT)
                  .containsEntry(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, servletVersion)
                  .containsEntry(IMPLEMENTATION_ATTRIBUTE, "sample-web-container")
                  .containsEntry(SPECIFICATION_ATTRIBUTE, "JSR-340");
          assertThat(contractName(capability)).isEqualTo(SERVLET_CONTRACT);
          assertThat(contractVersion(capability)).isEqualTo(SemanticVersion.parse("3.1.0"));
          assertThatThrownBy(() -> capability.getAttributes().put("extra", "value"))
                  .isInstanceOf(UnsupportedOperationException.class);
      }
  
      @Test
      void usesDirectiveIdentifiesPackagesDefinedByContract() {
          SyntheticResource resource = new SyntheticResource();
          Capability servletContract = resource.addContractCapability(
                  SERVLET_CONTRACT,
                  SemanticVersion.parse("3.1.0"),
                  Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, "javax.servlet, javax.servlet.http, javax.servlet.annotation"),
                  Map.of());
          Capability jsonContract = resource.addContractCapability(
                  JSON_P_CONTRACT,
                  SemanticVersion.parse("1.0.0"),
                  Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, "javax.json, javax.json.stream"),
                  Map.of());
  
          assertThat(packagesUsedBy(servletContract))
                  .containsExactly("javax.servlet", "javax.servlet.http", "javax.servlet.annotation");
          assertThat(contractCapabilitiesUsingPackage(resource, "javax.servlet.http")).containsExactly(servletContract);
          assertThat(contractCapabilitiesUsingPackage(resource, "javax.json.stream")).containsExactly(jsonContract);
          assertThat(contractCapabilitiesUsingPackage(resource, "javax.websocket")).isEmpty();
      }
  
