ed a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_osgi.org_osgi_namespace_contract;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Objects;\nimport java.util.stream.Collectors;\nimport org.junit.jupiter.api.Test;\nimport org.osgi.namespace.contract.ContractNamespace;\nimport org.osgi.resource.Capability;\nimport org.osgi.resource.Namespace;\nimport org.osgi.resource.Requirement;\nimport org.osgi.resource.Resource;\n\npublic class Org_osgi_namespace_contractTest {\n    private static final String SERVLET_CONTRACT = \"JavaServlet\";\n    private static final String JAX_RS_CONTRACT = \"JavaJAXRS\";\n    private static final String JSON_P_CONTRACT = \"JavaJSONP\";\n    private static final String IMPLEMENTATION_ATTRIBUTE = \"implementation\";\n    private static final String SPECIFICATION_ATTRIBUTE = \"specification\";\n    private static final String ORIGIN_ATTRIBUTE = \"origin\";\n\n    @Test\n    void constantsExposeContractNamespaceContract() {\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).isEqualTo(\"osgi.contract\");\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).startsWith(\"osgi.\").doesNotContain(\" \");\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isEqualTo(\"version\");\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isNotEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n    }\n\n    @Test\n    void contractCapabilityUsesNamespaceAsContractNameAndVersionAttribute() {\n        SyntheticResource resource = new SyntheticResource();\n        SemanticVersion servletVersion = SemanticVersion.parse(\"3.1.0\");\n        Capability capability = resource.addContractCapability(\n                SERVLET_CONTRACT,\n                servletVersion,\n                Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, \"javax.servlet,javax.servlet.http\"),\n                Map.of(\n                        IMPLEMENTATION_ATTRIBUTE, \"sample-web-container\",\n                        SPECIFICATION_ATTRIBUTE, \"JSR-340\"));\n\n        assertThat(capability.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(capability.getResource()).isSameAs(resource);\n        assertThat(capability.getDirectives())\n                .containsEntry(Namespace.CAPABILITY_USES_DIRECTIVE, \"javax.servlet,javax.servlet.http\");\n        assertThat(capability.getAttributes())\n                .containsEntry(ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT)\n                .containsEntry(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, servletVersion)\n                .containsEntry(IMPLEMENTATION_ATTRIBUTE, \"sample-web-container\")\n                .containsEntry(SPECIFICATION_ATTRIBUTE, \"JSR-340\");\n        assertThat(contractName(capability)).isEqualTo(SERVLET_CONTRACT);\n        assertThat(contractVersion(capability)).isEqualTo(SemanticVersion.parse(\"3.1.0\"));\n        assertThatThrownBy(() -> capability.getAttributes().put(\"extra\", \"value\"))\n                .isInstanceOf(UnsupportedOperationException.class);\n    }\n\n    @Test\n    void contractRequirementUsesNamespaceNameAndVersionRangeFilter() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability firstCompatible = resource.addContractCapability(SERVLET_CONTRACT, \"3.0.0\");\n        Capability preferredCompatible = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        resource.addContractCapability(SERVLET_CONTRACT, \"4.0.0\");\n        resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        contractRangeFilter(SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\"),\n                        Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE,\n                        Namespace.RESOLUTION_MANDATORY),\n                Map.of(\"consumer\", \"web.application\"));\n\n        assertThat(requirement.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(requirement.getDirectives())\n                .containsEntry(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(&(osgi.contract=JavaServlet)(version>=3.0.0)(!(version>=4.0.0)))\")\n                .containsEntry(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_MANDATORY);\n        assertThat(requirement.getAttributes()).containsEntry(\"consumer\", \"web.application\");\n        assertThat(contractCapabilitiesSatisfying(resource, requirement, SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\"))\n                .containsExactly(firstCompatible, preferredCompatible);\n    }\n\n    @Test\n    void optionalMultipleRequirementIsKeptSeparateFromMandatoryResolveRequirement() {\n        SyntheticResource resource = new SyntheticResource();\n        Requirement mandatoryRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\")),\n                Map.of());\n        Requirement optionalRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        contractRangeFilter(JAX_RS_CONTRACT, \"2.0.0\", \"3.0.0\"),\n                        Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE,\n                        Namespace.RESOLUTION_OPTIONAL,\n                        Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE,\n                        Namespace.CARDINALITY_MULTIPLE),\n                Map.of(ORIGIN_ATTRIBUTE, \"Require-Capability\"));\n\n        assertThat(requirementResolutionDirective(mandatoryRequirement)).isEqualTo(Namespace.RESOLUTION_MANDATORY);\n        assertThat(requirementCardinalityDirective(mandatoryRequirement)).isEqualTo(Namespace.CARDINALITY_SINGLE);\n        assertThat(optionalContractRequirements(resource)).containsExactly(optionalRequirement);\n        assertThat(optionalRequirement.getDirectives())\n                .containsEntry(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_OPTIONAL)\n                .containsEntry(Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE, Namespace.CARDINALITY_MULTIPLE);\n        assertThat(optionalRequirement.getAttributes()).containsEntry(ORIGIN_ATTRIBUTE, \"Require-Capability\");\n    }\n\n    @Test\n    void activeContractCapabilityAndRequirementAreDistinguishedFromResolveTimeEntries() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability resolveCapability = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        Capability activeCapability = resource.addContractCapability(\n                JAX_RS_CONTRACT,\n                SemanticVersion.parse(\"2.1.0\"),\n                Map.of(Namespace.CAPABILITY_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_ACTIVE),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"runtime-extension\"));\n        Requirement resolveRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \"3.1.0\", \"4.0.0\")),\n                Map.of());\n        Requirement activeRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        contractRangeFilter(JAX_RS_CONTRACT, \"2.1.0\", \"3.0.0\"),\n                        Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE,\n                        Namespace.EFFECTIVE_ACTIVE),\n                Map.of());\n\n        assertThat(resolveTimeContractCapabilities(resource)).containsExactly(resolveCapability);\n        assertThat(activeContractCapabilities(resource)).containsExactly(activeCapability);\n        assertThat(requirementEffectiveDirective(resolveRequirement)).isEqualTo(Namespace.EFFECTIVE_RESOLVE);\n        assertThat(activeContractRequirements(resource)).containsExactly(activeRequirement);\n    }\n\n    @Test\n    void resourceLookupsAreScopedToContractNamespace() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        resource.addCapability(\"osgi.identity\", Map.of(), Map.of(\"osgi.identity\", \"sample.bundle\"));\n        Requirement contractRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\")),\n                Map.of());\n        resource.addRequirement(\n                \"osgi.wiring.package\",\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, \"(osgi.wiring.package=javax.servlet)\"),\n                Map.of());\n\n        assertThat(resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(servlet, jaxRs);\n        assertThat(resource.getCapabilities(null)).hasSize(3);\n        assertThat(resource.getCapabilities(\"osgi.identity\"))\n                .extracting(Capability::getNamespace)\n                .containsExactly(\"osgi.identity\");\n        assertThat(resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(contractRequirement);\n        assertThat(resource.getRequirements(\"osgi.wiring.package\")).hasSize(1);\n    }\n\n    @Test\n    void arbitraryStringAttributesCanRefineContractSelection() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability supportedCapability = resource.addContractCapability(\n                SERVLET_CONTRACT,\n                SemanticVersion.parse(\"3.1.0\"),\n                Map.of(),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"web-container\", SPECIFICATION_ATTRIBUTE, \"JSR-340\"));\n        resource.addContractCapability(\n                SERVLET_CONTRACT,\n                SemanticVersion.parse(\"3.1.0\"),\n                Map.of(),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"legacy-container\", SPECIFICATION_ATTRIBUTE, \"JSR-315\"));\n        resource.addContractCapability(\n                JSON_P_CONTRACT,\n                SemanticVersion.parse(\"1.0.0\"),\n                Map.of(),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"json-provider\", SPECIFICATION_ATTRIBUTE, \"JSR-353\"));\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(&(osgi.contract=JavaServlet)(version>=3.1.0)(implementation=web-container)(specification=JSR-340))\"),\n                Map.of());\n\n        assertThat(contractCapabilitiesWithAttributes(resource, requirement, Map.of(\n                ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                IMPLEMENTATION_ATTRIBUTE, \"web-container\",\n                SPECIFICATION_ATTRIBUTE, \"JSR-340\"))).containsExactly(supportedCapability);\n    }\n\n    @Test\n    void requirementFilterCanSelectAlternativeContracts() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        resource.addContractCapability(JSON_P_CONTRACT, \"1.0.0\");\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(|(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + SERVLET_CONTRACT + \")(\" +\n                                ContractNamespace.CONTRACT_NAMESPACE + \"=\" + JAX_RS_CONTRACT + \"))\"),\n                Map.of());\n\n        assertThat(contractCapabilitiesNamedInFilter(resource, requirement)).containsExactly(servlet, jaxRs);\n    }\n\n    private static String contractRangeFilter(String contractName, String floorVersion, String ceilingVersion) {\n        return \"(&(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName + \")(\" +\n                ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + floorVersion + \")(!(\" +\n                ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + ceilingVersion + \")))\";\n    }\n\n    private static List<Capability> contractCapabilitiesSatisfying(\n            Resource resource,\n            Requirement requirement,\n            String contractName,\n            String floorVersion,\n            String ceilingVersion) {\n        assertThat(requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE))\n                .contains(ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName)\n                .contains(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + floorVersion)\n                .contains(\"!(\" + ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + ceilingVersion + \")\");\n        SemanticVersion floor = SemanticVersion.parse(floorVersion);\n        SemanticVersion ceiling = SemanticVersion.parse(ceilingVersion);\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> Objects.equals(contractName(capability), contractName))\n                .filter(capability -> versionInRange(contractVersion(capability), floor, ceiling))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> contractCapabilitiesWithAttributes(\n            Resource resource,\n            Requirement requirement,\n            Map<String, String> expectedAttributes) {\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\n        expectedAttributes.forEach((attributeName, expectedValue) -> assertThat(filter).contains(attributeName + \"=\" + expectedValue));\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> expectedAttributes.entrySet().stream()\n                        .allMatch(entry -> Objects.equals(capability.getAttributes().get(entry.getKey()), entry.getValue())))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> contractCapabilitiesNamedInFilter(Resource resource, Requirement requirement) {\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> filter.contains(\"(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName(capability) + \")\"))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> resolveTimeContractCapabilities(Resource resource) {\n        return resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(capability -> Namespace.EFFECTIVE_RESOLVE.equals(capabilityEffectiveDirective(capability)))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> activeContractCapabilities(Resource resource) {\n        return resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(capability -> Namespace.EFFECTIVE_ACTIVE.equals(capabilityEffectiveDirective(capability)))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Requirement> optionalContractRequirements(Resource resource) {\n        return resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(requirement -> Namespace.RESOLUTION_OPTIONAL.equals(requirementResolutionDirective(requirement)))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Requirement> activeContractRequirements(Resource resource) {\n        return resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(requirement -> Namespace.EFFECTIVE_ACTIVE.equals(requirementEffectiveDirective(requirement)))\n                .collect(Collectors.toList());\n    }\n\n    private static String capabilityEffectiveDirective(Capability capability) {\n        return capability.getDirectives().getOrDefault(Namespace.CAPABILITY_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_RESOLVE);\n    }\n\n    private static String requirementResolutionDirective(Requirement requirement) {\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_MANDATORY);\n    }\n\n    private static String requirementEffectiveDirective(Requirement requirement) {\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_RESOLVE);\n    }\n\n    private static String requirementCardinalityDirective(Requirement requirement) {\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE, Namespace.CARDINALITY_SINGLE);\n    }\n\n    private static boolean versionInRange(SemanticVersion version, SemanticVersion floor, SemanticVersion ceiling) {\n        return version.compareTo(floor) >= 0 && version.compareTo(ceiling) < 0;\n    }\n\n    private static String contractName(Capability capability) {\n        Object value = capability.getAttributes().get(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(value).isInstanceOf(String.class);\n        return value.toString();\n    }\n\n    private static SemanticVersion contractVersion(Capability capability) {\n        Object value = capability.getAttributes().get(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE);\n        assertThat(value).isInstanceOf(SemanticVersion.class);\n        return (SemanticVersion) value;\n    }\n\n    private static final class SyntheticResource implements Resource {\n        private final List<Capability> capabilities = new ArrayList<>();\n        private final List<Requirement> requirements = new ArrayList<>();\n\n        Capability addContractCapability(String contractName, String version) {\n            return addContractCapability(contractName, SemanticVersion.parse(version), Map.of(), Map.of());\n        }\n\n        Capability addContractCapability(\n                String contractName,\n                SemanticVersion version,\n                Map<String, String> directives,\n                Map<String, Object> extraAttributes) {\n            Map<String, Object> attributes = new java.util.LinkedHashMap<>();\n            attributes.put(ContractNamespace.CONTRACT_NAMESPACE, contractName);\n            attributes.put(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, version);\n            attributes.putAll(extraAttributes);\n            return addCapability(ContractNamespace.CONTRACT_NAMESPACE, directives, attributes);\n        }\n\n        Capability addCapability(String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            Capability capability = new SyntheticCapability(this, namespace, directives, attributes);\n            capabilities.add(capability);\n            return capability;\n        }\n\n        Requirement addRequirement(String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            Requirement requirement = new SyntheticRequirement(this, namespace, directives, attributes);\n            requirements.add(requirement);\n            return requirement;\n        }\n\n        @Override\n        public List<Capability> getCapabilities(String namespace) {\n            return capabilities.stream()\n                    .filter(capability -> namespace == null || Objects.equals(namespace, capability.getNamespace()))\n                    .collect(Collectors.toUnmodifiableList());\n        }\n\n        @Override\n        public List<Requirement> getRequirements(String namespace) {\n            return requirements.stream()\n                    .filter(requirement -> namespace == null || Objects.equals(namespace, requirement.getNamespace()))\n                    .collect(Collectors.toUnmodifiableList());\n        }\n    }\n\n    private static final class SyntheticCapability implements Capability {\n        private final Resource resource;\n        private final String namespace;\n        private final Map<String, String> directives;\n        private final Map<String, Object> attributes;\n\n        private SyntheticCapability(Resource resource, String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            this.resource = resource;\n            this.namespace = namespace;\n            this.directives = Map.copyOf(directives);\n            this.attributes = Map.copyOf(attributes);\n        }\n\n        @Override\n        public String getNamespace() {\n            return namespace;\n        }\n\n        @Override\n        public Map<String, String> getDirectives() {\n            return directives;\n        }\n\n        @Override\n        public Map<String, Object> getAttributes() {\n            return attributes;\n        }\n\n        @Override\n        public Resource getResource() {\n            return resource;\n        }\n    }\n\n    private static final class SyntheticRequirement implements Requirement {\n        private final Resource resource;\n        private final String namespace;\n        private final Map<String, String> directives;\n        private final Map<String, Object> attributes;\n\n        private SyntheticRequirement(Resource resource, String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            this.resource = resource;\n            this.namespace = namespace;\n            this.directives = Map.copyOf(directives);\n            this.attributes = Map.copyOf(attributes);\n        }\n\n        @Override\n        public String getNamespace() {\n            return namespace;\n        }\n\n        @Override\n        public Map<String, String> getDirectives() {\n            return directives;\n        }\n\n        @Override\n        public Map<String, Object> getAttributes() {\n            return attributes;\n        }\n\n        @Override\n        public Resource getResource() {\n            return resource;\n        }\n    }\n\n    private static final class SemanticVersion implements Comparable<SemanticVersion> {\n        private final int major;\n        private final int minor;\n        private final int micro;\n\n        private SemanticVersion(int major, int minor, int micro) {\n            this.major = major;\n            this.minor = minor;\n            this.micro = micro;\n        }\n\n        static SemanticVersion parse(String value) {\n            String[] segments = value.split(\"\\\\.\");\n            assertThat(segments).hasSize(3);\n            return new SemanticVersion(\n                    Integer.parseInt(segments[0]),\n                    Integer.parseInt(segments[1]),\n                    Integer.parseInt(segments[2]));\n        }\n\n        @Override\n        public int compareTo(SemanticVersion other) {\n            int majorComparison = Integer.compare(major, other.major);\n            if (majorComparison != 0) {\n                return majorComparison;\n            }\n            int minorComparison = Integer.compare(minor, other.minor);\n            if (minorComparison != 0) {\n                return minorComparison;\n            }\n            return Integer.compare(micro, other.micro);\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof SemanticVersion)) {\n                return false;\n            }\n            SemanticVersion that = (SemanticVersion) other;\n            return major == that.major && minor == that.minor && micro == that.micro;\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(major, minor, micro);\n        }\n\n        @Override\n        public String toString() {\n            return major + \".\" + minor + \".\" + micro;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.osgi/org.osgi.namespace.contract/1.0.0/src/test/java/org_osgi/org_osgi_namespace_contract/Org_osgi_namespace_contractTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_osgi.org_osgi_namespace_contract;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\nimport java.util.ArrayList;\\nimport java.util.List;\\nimport java.util.Map;\\nimport java.util.Objects;\\nimport java.util.stream.Collectors;\\nimport org.junit.jupiter.api.Test;\\nimport org.osgi.namespace.contract.ContractNamespace;\\nimport org.osgi.resource.Capability;\\nimport org.osgi.resource.Namespace;\\nimport org.osgi.resource.Requirement;\\nimport org.osgi.resource.Resource;\\n\\npublic class Org_osgi_namespace_contractTest {\\n    private static final String SERVLET_CONTRACT = \\\"JavaServlet\\\";\\n    private static final String JAX_RS_CONTRACT = \\\"JavaJAXRS\\\";\\n    private static final String JSON_P_CONTRACT = \\\"JavaJSONP\\\";\\n    private static final String IMPLEMENTATION_ATTRIBUTE = \\\"implementation\\\";\\n    private static final String SPECIFICATION_ATTRIBUTE = \\\"specification\\\";\\n    private static final String ORIGIN_ATTRIBUTE = \\\"origin\\\";\\n\\n    @Test\\n    void constantsExposeContractNamespaceContract() {\\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).isEqualTo(\\\"osgi.contract\\\");\\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).startsWith(\\\"osgi.\\\").doesNotContain(\\\" \\\");\\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isEqualTo(\\\"version\\\");\\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isNotEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\\n    }\\n\\n    @Test\\n    void contractCapabilityUsesNamespaceAsContractNameAndVersionAttribute() {\\n        SyntheticResource resource = new SyntheticResource();\\n        SemanticVersion servletVersion = SemanticVersion.parse(\\\"3.1.0\\\");\\n        Capability capability = resource.addContractCapability(\\n                SERVLET_CONTRACT,\\n                servletVersion,\\n                Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, \\\"javax.servlet,javax.servlet.http\\\"),\\n                Map.of(\\n                        IMPLEMENTATION_ATTRIBUTE, \\\"sample-web-container\\\",\\n                        SPECIFICATION_ATTRIBUTE, \\\"JSR-340\\\"));\\n\\n        assertThat(capability.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\\n        assertThat(capability.getResource()).isSameAs(resource);\\n        assertThat(capability.getDirectives())\\n                .containsEntry(Namespace.CAPABILITY_USES_DIRECTIVE, \\\"javax.servlet,javax.servlet.http\\\");\\n        assertThat(capability.getAttributes())\\n                .containsEntry(ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT)\\n                .containsEntry(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, servletVersion)\\n                .containsEntry(IMPLEMENTATION_ATTRIBUTE, \\\"sample-web-container\\\")\\n                .containsEntry(SPECIFICATION_ATTRIBUTE, \\\"JSR-340\\\");\\n        assertThat(contractName(capability)).isEqualTo(SERVLET_CONTRACT);\\n        assertThat(contractVersion(capability)).isEqualTo(SemanticVersion.parse(\\\"3.1.0\\\"));\\n        assertThatThrownBy(() -> capability.getAttributes().put(\\\"extra\\\", \\\"value\\\"))\\n                .isInstanceOf(UnsupportedOperationException.class);\\n    }\\n\\n    @Test\\n    void contractRequirementUsesNamespaceNameAndVersionRangeFilter() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Capability firstCompatible = resource.addContractCapability(SERVLET_CONTRACT, \\\"3.0.0\\\");\\n        Capability preferredCompatible = resource.addContractCapability(SERVLET_CONTRACT, \\\"3.1.0\\\");\\n        resource.addContractCapability(SERVLET_CONTRACT, \\\"4.0.0\\\");\\n        resource.addContractCapability(JAX_RS_CONTRACT, \\\"2.0.0\\\");\\n        Requirement requirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(\\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\\n                        contractRangeFilter(SERVLET_CONTRACT, \\\"3.0.0\\\", \\\"4.0.0\\\"),\\n                        Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE,\\n                        Namespace.RESOLUTION_MANDATORY),\\n                Map.of(\\\"consumer\\\", \\\"web.application\\\"));\\n\\n        assertThat(requirement.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\\n        assertThat(requirement.getDirectives())\\n                .containsEntry(\\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\\n                        \\\"(&(osgi.contract=JavaServlet)(version>=3.0.0)(!(version>=4.0.0)))\\\")\\n                .containsEntry(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_MANDATORY);\\n        assertThat(requirement.getAttributes()).containsEntry(\\\"consumer\\\", \\\"web.application\\\");\\n        assertThat(contractCapabilitiesSatisfying(resource, requirement, SERVLET_CONTRACT, \\\"3.0.0\\\", \\\"4.0.0\\\"))\\n                .containsExactly(firstCompatible, preferredCompatible);\\n    }\\n\\n    @Test\\n    void optionalMultipleRequirementIsKeptSeparateFromMandatoryResolveRequirement() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Requirement mandatoryRequirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \\\"3.0.0\\\", \\\"4.0.0\\\")),\\n                Map.of());\\n        Requirement optionalRequirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(\\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\\n                        contractRangeFilter(JAX_RS_CONTRACT, \\\"2.0.0\\\", \\\"3.0.0\\\"),\\n                        Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE,\\n                        Namespace.RESOLUTION_OPTIONAL,\\n                        Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE,\\n                        Namespace.CARDINALITY_MULTIPLE),\\n                Map.of(ORIGIN_ATTRIBUTE, \\\"Require-Capability\\\"));\\n\\n        assertThat(requirementResolutionDirective(mandatoryRequirement)).isEqualTo(Namespace.RESOLUTION_MANDATORY);\\n        assertThat(requirementCardinalityDirective(mandatoryRequirement)).isEqualTo(Namespace.CARDINALITY_SINGLE);\\n        assertThat(optionalContractRequirements(resource)).containsExactly(optionalRequirement);\\n        assertThat(optionalRequirement.getDirectives())\\n                .containsEntry(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_OPTIONAL)\\n                .containsEntry(Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE, Namespace.CARDINALITY_MULTIPLE);\\n        assertThat(optionalRequirement.getAttributes()).containsEntry(ORIGIN_ATTRIBUTE, \\\"Require-Capability\\\");\\n    }\\n\\n    @Test\\n    void activeContractCapabilityAndRequirementAreDistinguishedFromResolveTimeEntries() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Capability resolveCapability = resource.addContractCapability(SERVLET_CONTRACT, \\\"3.1.0\\\");\\n        Capability activeCapability = resource.addContractCapability(\\n                JAX_RS_CONTRACT,\\n                SemanticVersion.parse(\\\"2.1.0\\\"),\\n                Map.of(Namespace.CAPABILITY_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_ACTIVE),\\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \\\"runtime-extension\\\"));\\n        Requirement resolveRequirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \\\"3.1.0\\\", \\\"4.0.0\\\")),\\n                Map.of());\\n        Requirement activeRequirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(\\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\\n                        contractRangeFilter(JAX_RS_CONTRACT, \\\"2.1.0\\\", \\\"3.0.0\\\"),\\n                        Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE,\\n                        Namespace.EFFECTIVE_ACTIVE),\\n                Map.of());\\n\\n        assertThat(resolveTimeContractCapabilities(resource)).containsExactly(resolveCapability);\\n        assertThat(activeContractCapabilities(resource)).containsExactly(activeCapability);\\n        assertThat(requirementEffectiveDirective(resolveRequirement)).isEqualTo(Namespace.EFFECTIVE_RESOLVE);\\n        assertThat(activeContractRequirements(resource)).containsExactly(activeRequirement);\\n    }\\n\\n    @Test\\n    void resourceLookupsAreScopedToContractNamespace() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \\\"3.1.0\\\");\\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \\\"2.0.0\\\");\\n        resource.addCapability(\\\"osgi.identity\\\", Map.of(), Map.of(\\\"osgi.identity\\\", \\\"sample.bundle\\\"));\\n        Requirement contractRequirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \\\"3.0.0\\\", \\\"4.0.0\\\")),\\n                Map.of());\\n        resource.addRequirement(\\n                \\\"osgi.wiring.package\\\",\\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, \\\"(osgi.wiring.package=javax.servlet)\\\"),\\n                Map.of());\\n\\n        assertThat(resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(servlet, jaxRs);\\n        assertThat(resource.getCapabilities(null)).hasSize(3);\\n        assertThat(resource.getCapabilities(\\\"osgi.identity\\\"))\\n                .extracting(Capability::getNamespace)\\n                .containsExactly(\\\"osgi.identity\\\");\\n        assertThat(resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(contractRequirement);\\n        assertThat(resource.getRequirements(\\\"osgi.wiring.package\\\")).hasSize(1);\\n    }\\n\\n    @Test\\n    void arbitraryStringAttributesCanRefineContractSelection() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Capability supportedCapability = resource.addContractCapability(\\n                SERVLET_CONTRACT,\\n                SemanticVersion.parse(\\\"3.1.0\\\"),\\n                Map.of(),\\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \\\"web-container\\\", SPECIFICATION_ATTRIBUTE, \\\"JSR-340\\\"));\\n        resource.addContractCapability(\\n                SERVLET_CONTRACT,\\n                SemanticVersion.parse(\\\"3.1.0\\\"),\\n                Map.of(),\\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \\\"legacy-container\\\", SPECIFICATION_ATTRIBUTE, \\\"JSR-315\\\"));\\n        resource.addContractCapability(\\n                JSON_P_CONTRACT,\\n                SemanticVersion.parse(\\\"1.0.0\\\"),\\n                Map.of(),\\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \\\"json-provider\\\", SPECIFICATION_ATTRIBUTE, \\\"JSR-353\\\"));\\n        Requirement requirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\\n                        \\\"(&(osgi.contract=JavaServlet)(version>=3.1.0)(implementation=web-container)(specification=JSR-340))\\\"),\\n                Map.of());\\n\\n        assertThat(contractCapabilitiesWithAttributes(resource, requirement, Map.of(\\n                ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\\n                IMPLEMENTATION_ATTRIBUTE, \\\"web-container\\\",\\n                SPECIFICATION_ATTRIBUTE, \\\"JSR-340\\\"))).containsExactly(supportedCapability);\\n    }\\n\\n    @Test\\n    void requirementFilterCanSelectAlternativeContracts() {\\n        SyntheticResource resource = new SyntheticResource();\\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \\\"3.1.0\\\");\\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \\\"2.0.0\\\");\\n        resource.addContractCapability(JSON_P_CONTRACT, \\\"1.0.0\\\");\\n        Requirement requirement = resource.addRequirement(\\n                ContractNamespace.CONTRACT_NAMESPACE,\\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\\n                        \\\"(|(\\\" + ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + SERVLET_CONTRACT + \\\")(\\\" +\\n                                ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + JAX_RS_CONTRACT + \\\"))\\\"),\\n                Map.of());\\n\\n        assertThat(contractCapabilitiesNamedInFilter(resource, requirement)).containsExactly(servlet, jaxRs);\\n    }\\n\\n    private static String contractRangeFilter(String contractName, String floorVersion, String ceilingVersion) {\\n        return \\\"(&(\\\" + ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + contractName + \\\")(\\\" +\\n                ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \\\">=\\\" + floorVersion + \\\")(!(\\\" +\\n                ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \\\">=\\\" + ceilingVersion + \\\")))\\\";\\n    }\\n\\n    private static List<Capability> contractCapabilitiesSatisfying(\\n            Resource resource,\\n            Requirement requirement,\\n            String contractName,\\n            String floorVersion,\\n            String ceilingVersion) {\\n        assertThat(requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE))\\n                .contains(ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + contractName)\\n                .contains(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \\\">=\\\" + floorVersion)\\n                .contains(\\\"!(\\\" + ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \\\">=\\\" + ceilingVersion + \\\")\\\");\\n        SemanticVersion floor = SemanticVersion.parse(floorVersion);\\n        SemanticVersion ceiling = SemanticVersion.parse(ceilingVersion);\\n        return resource.getCapabilities(requirement.getNamespace()).stream()\\n                .filter(capability -> Objects.equals(contractName(capability), contractName))\\n                .filter(capability -> versionInRange(contractVersion(capability), floor, ceiling))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Capability> contractCapabilitiesWithAttributes(\\n            Resource resource,\\n            Requirement requirement,\\n            Map<String, String> expectedAttributes) {\\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\\n        expectedAttributes.forEach((attributeName, expectedValue) -> assertThat(filter).contains(attributeName + \\\"=\\\" + expectedValue));\\n        return resource.getCapabilities(requirement.getNamespace()).stream()\\n                .filter(capability -> expectedAttributes.entrySet().stream()\\n                        .allMatch(entry -> Objects.equals(capability.getAttributes().get(entry.getKey()), entry.getValue())))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Capability> contractCapabilitiesNamedInFilter(Resource resource, Requirement requirement) {\\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\\n        return resource.getCapabilities(requirement.getNamespace()).stream()\\n                .filter(capability -> filter.contains(\\\"(\\\" + ContractNamespace.CONTRACT_NAMESPACE + \\\"=\\\" + contractName(capability) + \\\")\\\"))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Capability> resolveTimeContractCapabilities(Resource resource) {\\n        return resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE).stream()\\n                .filter(capability -> Namespace.EFFECTIVE_RESOLVE.equals(capabilityEffectiveDirective(capability)))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Capability> activeContractCapabilities(Resource resource) {\\n        return resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE).stream()\\n                .filter(capability -> Namespace.EFFECTIVE_ACTIVE.equals(capabilityEffectiveDirective(capability)))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Requirement> optionalContractRequirements(Resource resource) {\\n        return resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE).stream()\\n                .filter(requirement -> Namespace.RESOLUTION_OPTIONAL.equals(requirementResolutionDirective(requirement)))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static List<Requirement> activeContractRequirements(Resource resource) {\\n        return resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE).stream()\\n                .filter(requirement -> Namespace.EFFECTIVE_ACTIVE.equals(requirementEffectiveDirective(requirement)))\\n                .collect(Collectors.toList());\\n    }\\n\\n    private static String capabilityEffectiveDirective(Capability capability) {\\n        return capability.getDirectives().getOrDefault(Namespace.CAPABILITY_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_RESOLVE);\\n    }\\n\\n    private static String requirementResolutionDirective(Requirement requirement) {\\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_MANDATORY);\\n    }\\n\\n    private static String requirementEffectiveDirective(Requirement requirement) {\\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_RESOLVE);\\n    }\\n\\n    private static String requirementCardinalityDirective(Requirement requirement) {\\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE, Namespace.CARDINALITY_SINGLE);\\n    }\\n\\n    private static boolean versionInRange(SemanticVersion version, SemanticVersion floor, SemanticVersion ceiling) {\\n        return version.compareTo(floor) >= 0 && version.compareTo(ceiling) < 0;\\n    }\\n\\n    private static String contractName(Capability capability) {\\n        Object value = capability.getAttributes().get(ContractNamespace.CONTRACT_NAMESPACE);\\n        assertThat(value).isInstanceOf(String.class);\\n        return value.toString();\\n    }\\n\\n    private static SemanticVersion contractVersion(Capability capability) {\\n        Object value = capability.getAttributes().get(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE);\\n        assertThat(value).isInstanceOf(SemanticVersion.class);\\n        return (SemanticVersion) value;\\n    }\\n\\n    private static final class SyntheticResource implements Resource {\\n        private final List<Capability> capabilities = new ArrayList<>();\\n        private final List<Requirement> requirements = new ArrayList<>();\\n\\n        Capability addContractCapability(String contractName, String version) {\\n            return addContractCapability(contractName, SemanticVersion.parse(version), Map.of(), Map.of());\\n        }\\n\\n        Capability addContractCapability(\\n                String contractName,\\n                SemanticVersion version,\\n                Map<String, String> directives,\\n                Map<String, Object> extraAttributes) {\\n            Map<String, Object> attributes = new java.util.LinkedHashMap<>();\\n            attributes.put(ContractNamespace.CONTRACT_NAMESPACE, contractName);\\n            attributes.put(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, version);\\n            attributes.putAll(extraAttributes);\\n            return addCapability(ContractNamespace.CONTRACT_NAMESPACE, directives, attributes);\\n        }\\n\\n        Capability addCapability(String namespace, Map<String, String> directives, Map<String, Object> attributes) {\\n            Capability capability = new SyntheticCapability(this, namespace, directives, attributes);\\n            capabilities.add(capability);\\n            return capability;\\n        }\\n\\n        Requirement addRequirement(String namespace, Map<String, String> directives, Map<String, Object> attributes) {\\n            Requirement requirement = new SyntheticRequirement(this, namespace, directives, attributes);\\n            requirements.add(requirement);\\n            return requirement;\\n        }\\n\\n        @Override\\n        public List<Capability> getCapabilities(String namespace) {\\n            return capabilities.stream()\\n                    .filter(capability -> namespace == null || Objects.equals(namespace, capability.getNamespace()))\\n                    .collect(Collectors.toUnmodifiableList());\\n        }\\n\\n        @Override\\n        public List<Requirement> getRequirements(String namespace) {\\n            return requirements.stream()\\n                    .filter(requirement -> namespace == null || Objects.equals(namespace, requirement.getNamespace()))\\n                    .collect(Collectors.toUnmodifiableList());\\n        }\\n    }\\n\\n    private static final class SyntheticCapability implements Capability {\\n        private final Resource resource;\\n        private final String namespace;\\n        private final Map<String, String> directives;\\n        private final Map<String, Object> attributes;\\n\\n        private SyntheticCapability(Resource resource, String namespace, Map<String, String> directives, Map<String, Object> attributes) {\\n            this.resource = resource;\\n            this.namespace = namespace;\\n            this.directives = Map.copyOf(directives);\\n            this.attributes = Map.copyOf(attributes);\\n        }\\n\\n        @Override\\n        public String getNamespace() {\\n            return namespace;\\n        }\\n\\n        @Override\\n        public Map<String, String> getDirectives() {\\n            return directives;\\n        }\\n\\n        @Override\\n        public Map<String, Object> getAttributes() {\\n            return attributes;\\n        }\\n\\n        @Override\\n        public Resource getResource() {\\n            return resource;\\n        }\\n    }\\n\\n    private static final class SyntheticRequirement implements Requirement {\\n        private final Resource resource;\\n        private final String namespace;\\n        private final Map<String, String> directives;\\n        private final Map<String, Object> attributes;\\n\\n        private SyntheticRequirement(Resource resource, String namespace, Map<String, String> directives, Map<String, Object> attributes) {\\n            this.resource = resource;\\n            this.namespace = namespace;\\n            this.directives = Map.copyOf(directives);\\n            this.attributes = Map.copyOf(attributes);\\n        }\\n\\n        @Override\\n        public String getNamespace() {\\n            return namespace;\\n        }\\n\\n        @Override\\n        public Map<String, String> getDirectives() {\\n            return directives;\\n        }\\n\\n        @Override\\n        public Map<String, Object> getAttributes() {\\n            return attributes;\\n        }\\n\\n        @Override\\n        public Resource getResource() {\\n            return resource;\\n        }\\n    }\\n\\n    private static final class SemanticVersion implements Comparable<SemanticVersion> {\\n        private final int major;\\n        private final int minor;\\n        private final int micro;\\n\\n        private SemanticVersion(int major, int minor, int micro) {\\n            this.major = major;\\n            this.minor = minor;\\n            this.micro = micro;\\n        }\\n\\n        static SemanticVersion parse(String value) {\\n            String[] segments = value.split(\\\"\\\\\\\\.\\\");\\n            assertThat(segments).hasSize(3);\\n            return new SemanticVersion(\\n                    Integer.parseInt(segments[0]),\\n                    Integer.parseInt(segments[1]),\\n                    Integer.parseInt(segments[2]));\\n        }\\n\\n        @Override\\n        public int compareTo(SemanticVersion other) {\\n            int majorComparison = Integer.compare(major, other.major);\\n            if (majorComparison != 0) {\\n                return majorComparison;\\n            }\\n            int minorComparison = Integer.compare(minor, other.minor);\\n            if (minorComparison != 0) {\\n                return minorComparison;\\n            }\\n            return Integer.compare(micro, other.micro);\\n        }\\n\\n        @Override\\n        public boolean equals(Object other) {\\n            if (this == other) {\\n                return true;\\n            }\\n            if (!(other instanceof SemanticVersion)) {\\n                return false;\\n            }\\n            SemanticVersion that = (SemanticVersion) other;\\n            return major == that.major && minor == that.minor && micro == that.micro;\\n        }\\n\\n        @Override\\n        public int hashCode() {\\n            return Objects.hash(major, minor, micro);\\n        }\\n\\n        @Override\\n        public String toString() {\\n            return major + \\\".\\\" + minor + \\\".\\\" + micro;\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3072, "output": 5538, "cacheRead": 20992, "cacheWrite": 0, "totalTokens": 29602, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777967114263, "responseId": "resp_0232e546208d8fe20169f9a00af398819eb8c47b12485baad8"}}
[tool-exec] start id=call_kag2HFYj212RKFJufrhiO33X|fc_0232e546208d8fe20169f9a011d73c819ea41f15666b604352 name=write args={"path": "tests/src/org.osgi/org.osgi.namespace.contract/1.0.0/src/test/java/org_osgi/org_osgi_namespace_contract/Org_osgi_namespace_contractTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_osgi.org_osgi_namespace_contract;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Objects;\nimport java.util.stream.Collectors;\nimport org.junit.jupiter.api.Test;\nimport org.osgi.namespace.contract.ContractNamespace;\nimport org.osgi.resource.Capability;\nimport org.osgi.resource.Namespace;\nimport org.osgi.resource.Requirement;\nimport org.osgi.resource.Resource;\n\npublic class Org_osgi_namespace_contractTest {\n    private static final String SERVLET_CONTRACT = \"JavaServlet\";\n    private static final String JAX_RS_CONTRACT = \"JavaJAXRS\";\n    private static final String JSON_P_CONTRACT = \"JavaJSONP\";\n    private static final String IMPLEMENTATION_ATTRIBUTE = \"implementation\";\n    private static final String SPECIFICATION_ATTRIBUTE = \"specification\";\n    private static final String ORIGIN_ATTRIBUTE = \"origin\";\n\n    @Test\n    void constantsExposeContractNamespaceContract() {\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).isEqualTo(\"osgi.contract\");\n        assertThat(ContractNamespace.CONTRACT_NAMESPACE).startsWith(\"osgi.\").doesNotContain(\" \");\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isEqualTo(\"version\");\n        assertThat(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE).isNotEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n    }\n\n    @Test\n    void contractCapabilityUsesNamespaceAsContractNameAndVersionAttribute() {\n        SyntheticResource resource = new SyntheticResource();\n        SemanticVersion servletVersion = SemanticVersion.parse(\"3.1.0\");\n        Capability capability = resource.addContractCapability(\n                SERVLET_CONTRACT,\n                servletVersion,\n                Map.of(Namespace.CAPABILITY_USES_DIRECTIVE, \"javax.servlet,javax.servlet.http\"),\n                Map.of(\n                        IMPLEMENTATION_ATTRIBUTE, \"sample-web-container\",\n                        SPECIFICATION_ATTRIBUTE, \"JSR-340\"));\n\n        assertThat(capability.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(capability.getResource()).isSameAs(resource);\n        assertThat(capability.getDirectives())\n                .containsEntry(Namespace.CAPABILITY_USES_DIRECTIVE, \"javax.servlet,javax.servlet.http\");\n        assertThat(capability.getAttributes())\n                .containsEntry(ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT)\n                .containsEntry(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, servletVersion)\n                .containsEntry(IMPLEMENTATION_ATTRIBUTE, \"sample-web-container\")\n                .containsEntry(SPECIFICATION_ATTRIBUTE, \"JSR-340\");\n        assertThat(contractName(capability)).isEqualTo(SERVLET_CONTRACT);\n        assertThat(contractVersion(capability)).isEqualTo(SemanticVersion.parse(\"3.1.0\"));\n        assertThatThrownBy(() -> capability.getAttributes().put(\"extra\", \"value\"))\n                .isInstanceOf(UnsupportedOperationException.class);\n    }\n\n    @Test\n    void contractRequirementUsesNamespaceNameAndVersionRangeFilter() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability firstCompatible = resource.addContractCapability(SERVLET_CONTRACT, \"3.0.0\");\n        Capability preferredCompatible = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        resource.addContractCapability(SERVLET_CONTRACT, \"4.0.0\");\n        resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        contractRangeFilter(SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\"),\n                        Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE,\n                        Namespace.RESOLUTION_MANDATORY),\n                Map.of(\"consumer\", \"web.application\"));\n\n        assertThat(requirement.getNamespace()).isEqualTo(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(requirement.getDirectives())\n                .containsEntry(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(&(osgi.contract=JavaServlet)(version>=3.0.0)(!(version>=4.0.0)))\")\n                .containsEntry(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_MANDATORY);\n        assertThat(requirement.getAttributes()).containsEntry(\"consumer\", \"web.application\");\n        assertThat(contractCapabilitiesSatisfying(resource, requirement, SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\"))\n                .containsExactly(firstCompatible, preferredCompatible);\n    }\n\n    @Test\n    void optionalMultipleRequirementIsKeptSeparateFromMandatoryResolveRequirement() {\n        SyntheticResource resource = new SyntheticResource();\n        Requirement mandatoryRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\")),\n                Map.of());\n        Requirement optionalRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        contractRangeFilter(JAX_RS_CONTRACT, \"2.0.0\", \"3.0.0\"),\n                        Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE,\n                        Namespace.RESOLUTION_OPTIONAL,\n                        Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE,\n                        Namespace.CARDINALITY_MULTIPLE),\n                Map.of(ORIGIN_ATTRIBUTE, \"Require-Capability\"));\n\n        assertThat(requirementResolutionDirective(mandatoryRequirement)).isEqualTo(Namespace.RESOLUTION_MANDATORY);\n        assertThat(requirementCardinalityDirective(mandatoryRequirement)).isEqualTo(Namespace.CARDINALITY_SINGLE);\n        assertThat(optionalContractRequirements(resource)).containsExactly(optionalRequirement);\n        assertThat(optionalRequirement.getDirectives())\n                .containsEntry(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_OPTIONAL)\n                .containsEntry(Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE, Namespace.CARDINALITY_MULTIPLE);\n        assertThat(optionalRequirement.getAttributes()).containsEntry(ORIGIN_ATTRIBUTE, \"Require-Capability\");\n    }\n\n    @Test\n    void activeContractCapabilityAndRequirementAreDistinguishedFromResolveTimeEntries() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability resolveCapability = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        Capability activeCapability = resource.addContractCapability(\n                JAX_RS_CONTRACT,\n                SemanticVersion.parse(\"2.1.0\"),\n                Map.of(Namespace.CAPABILITY_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_ACTIVE),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"runtime-extension\"));\n        Requirement resolveRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \"3.1.0\", \"4.0.0\")),\n                Map.of());\n        Requirement activeRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(\n                        Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        contractRangeFilter(JAX_RS_CONTRACT, \"2.1.0\", \"3.0.0\"),\n                        Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE,\n                        Namespace.EFFECTIVE_ACTIVE),\n                Map.of());\n\n        assertThat(resolveTimeContractCapabilities(resource)).containsExactly(resolveCapability);\n        assertThat(activeContractCapabilities(resource)).containsExactly(activeCapability);\n        assertThat(requirementEffectiveDirective(resolveRequirement)).isEqualTo(Namespace.EFFECTIVE_RESOLVE);\n        assertThat(activeContractRequirements(resource)).containsExactly(activeRequirement);\n    }\n\n    @Test\n    void resourceLookupsAreScopedToContractNamespace() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        resource.addCapability(\"osgi.identity\", Map.of(), Map.of(\"osgi.identity\", \"sample.bundle\"));\n        Requirement contractRequirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, contractRangeFilter(SERVLET_CONTRACT, \"3.0.0\", \"4.0.0\")),\n                Map.of());\n        resource.addRequirement(\n                \"osgi.wiring.package\",\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE, \"(osgi.wiring.package=javax.servlet)\"),\n                Map.of());\n\n        assertThat(resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(servlet, jaxRs);\n        assertThat(resource.getCapabilities(null)).hasSize(3);\n        assertThat(resource.getCapabilities(\"osgi.identity\"))\n                .extracting(Capability::getNamespace)\n                .containsExactly(\"osgi.identity\");\n        assertThat(resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE)).containsExactly(contractRequirement);\n        assertThat(resource.getRequirements(\"osgi.wiring.package\")).hasSize(1);\n    }\n\n    @Test\n    void arbitraryStringAttributesCanRefineContractSelection() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability supportedCapability = resource.addContractCapability(\n                SERVLET_CONTRACT,\n                SemanticVersion.parse(\"3.1.0\"),\n                Map.of(),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"web-container\", SPECIFICATION_ATTRIBUTE, \"JSR-340\"));\n        resource.addContractCapability(\n                SERVLET_CONTRACT,\n                SemanticVersion.parse(\"3.1.0\"),\n                Map.of(),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"legacy-container\", SPECIFICATION_ATTRIBUTE, \"JSR-315\"));\n        resource.addContractCapability(\n                JSON_P_CONTRACT,\n                SemanticVersion.parse(\"1.0.0\"),\n                Map.of(),\n                Map.of(IMPLEMENTATION_ATTRIBUTE, \"json-provider\", SPECIFICATION_ATTRIBUTE, \"JSR-353\"));\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(&(osgi.contract=JavaServlet)(version>=3.1.0)(implementation=web-container)(specification=JSR-340))\"),\n                Map.of());\n\n        assertThat(contractCapabilitiesWithAttributes(resource, requirement, Map.of(\n                ContractNamespace.CONTRACT_NAMESPACE, SERVLET_CONTRACT,\n                IMPLEMENTATION_ATTRIBUTE, \"web-container\",\n                SPECIFICATION_ATTRIBUTE, \"JSR-340\"))).containsExactly(supportedCapability);\n    }\n\n    @Test\n    void requirementFilterCanSelectAlternativeContracts() {\n        SyntheticResource resource = new SyntheticResource();\n        Capability servlet = resource.addContractCapability(SERVLET_CONTRACT, \"3.1.0\");\n        Capability jaxRs = resource.addContractCapability(JAX_RS_CONTRACT, \"2.0.0\");\n        resource.addContractCapability(JSON_P_CONTRACT, \"1.0.0\");\n        Requirement requirement = resource.addRequirement(\n                ContractNamespace.CONTRACT_NAMESPACE,\n                Map.of(Namespace.REQUIREMENT_FILTER_DIRECTIVE,\n                        \"(|(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + SERVLET_CONTRACT + \")(\" +\n                                ContractNamespace.CONTRACT_NAMESPACE + \"=\" + JAX_RS_CONTRACT + \"))\"),\n                Map.of());\n\n        assertThat(contractCapabilitiesNamedInFilter(resource, requirement)).containsExactly(servlet, jaxRs);\n    }\n\n    private static String contractRangeFilter(String contractName, String floorVersion, String ceilingVersion) {\n        return \"(&(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName + \")(\" +\n                ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + floorVersion + \")(!(\" +\n                ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + ceilingVersion + \")))\";\n    }\n\n    private static List<Capability> contractCapabilitiesSatisfying(\n            Resource resource,\n            Requirement requirement,\n            String contractName,\n            String floorVersion,\n            String ceilingVersion) {\n        assertThat(requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE))\n                .contains(ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName)\n                .contains(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + floorVersion)\n                .contains(\"!(\" + ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE + \">=\" + ceilingVersion + \")\");\n        SemanticVersion floor = SemanticVersion.parse(floorVersion);\n        SemanticVersion ceiling = SemanticVersion.parse(ceilingVersion);\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> Objects.equals(contractName(capability), contractName))\n                .filter(capability -> versionInRange(contractVersion(capability), floor, ceiling))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> contractCapabilitiesWithAttributes(\n            Resource resource,\n            Requirement requirement,\n            Map<String, String> expectedAttributes) {\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\n        expectedAttributes.forEach((attributeName, expectedValue) -> assertThat(filter).contains(attributeName + \"=\" + expectedValue));\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> expectedAttributes.entrySet().stream()\n                        .allMatch(entry -> Objects.equals(capability.getAttributes().get(entry.getKey()), entry.getValue())))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> contractCapabilitiesNamedInFilter(Resource resource, Requirement requirement) {\n        String filter = requirement.getDirectives().get(Namespace.REQUIREMENT_FILTER_DIRECTIVE);\n        return resource.getCapabilities(requirement.getNamespace()).stream()\n                .filter(capability -> filter.contains(\"(\" + ContractNamespace.CONTRACT_NAMESPACE + \"=\" + contractName(capability) + \")\"))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> resolveTimeContractCapabilities(Resource resource) {\n        return resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(capability -> Namespace.EFFECTIVE_RESOLVE.equals(capabilityEffectiveDirective(capability)))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Capability> activeContractCapabilities(Resource resource) {\n        return resource.getCapabilities(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(capability -> Namespace.EFFECTIVE_ACTIVE.equals(capabilityEffectiveDirective(capability)))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Requirement> optionalContractRequirements(Resource resource) {\n        return resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(requirement -> Namespace.RESOLUTION_OPTIONAL.equals(requirementResolutionDirective(requirement)))\n                .collect(Collectors.toList());\n    }\n\n    private static List<Requirement> activeContractRequirements(Resource resource) {\n        return resource.getRequirements(ContractNamespace.CONTRACT_NAMESPACE).stream()\n                .filter(requirement -> Namespace.EFFECTIVE_ACTIVE.equals(requirementEffectiveDirective(requirement)))\n                .collect(Collectors.toList());\n    }\n\n    private static String capabilityEffectiveDirective(Capability capability) {\n        return capability.getDirectives().getOrDefault(Namespace.CAPABILITY_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_RESOLVE);\n    }\n\n    private static String requirementResolutionDirective(Requirement requirement) {\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_RESOLUTION_DIRECTIVE, Namespace.RESOLUTION_MANDATORY);\n    }\n\n    private static String requirementEffectiveDirective(Requirement requirement) {\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_EFFECTIVE_DIRECTIVE, Namespace.EFFECTIVE_RESOLVE);\n    }\n\n    private static String requirementCardinalityDirective(Requirement requirement) {\n        return requirement.getDirectives().getOrDefault(Namespace.REQUIREMENT_CARDINALITY_DIRECTIVE, Namespace.CARDINALITY_SINGLE);\n    }\n\n    private static boolean versionInRange(SemanticVersion version, SemanticVersion floor, SemanticVersion ceiling) {\n        return version.compareTo(floor) >= 0 && version.compareTo(ceiling) < 0;\n    }\n\n    private static String contractName(Capability capability) {\n        Object value = capability.getAttributes().get(ContractNamespace.CONTRACT_NAMESPACE);\n        assertThat(value).isInstanceOf(String.class);\n        return value.toString();\n    }\n\n    private static SemanticVersion contractVersion(Capability capability) {\n        Object value = capability.getAttributes().get(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE);\n        assertThat(value).isInstanceOf(SemanticVersion.class);\n        return (SemanticVersion) value;\n    }\n\n    private static final class SyntheticResource implements Resource {\n        private final List<Capability> capabilities = new ArrayList<>();\n        private final List<Requirement> requirements = new ArrayList<>();\n\n        Capability addContractCapability(String contractName, String version) {\n            return addContractCapability(contractName, SemanticVersion.parse(version), Map.of(), Map.of());\n        }\n\n        Capability addContractCapability(\n                String contractName,\n                SemanticVersion version,\n                Map<String, String> directives,\n                Map<String, Object> extraAttributes) {\n            Map<String, Object> attributes = new java.util.LinkedHashMap<>();\n            attributes.put(ContractNamespace.CONTRACT_NAMESPACE, contractName);\n            attributes.put(ContractNamespace.CAPABILITY_VERSION_ATTRIBUTE, version);\n            attributes.putAll(extraAttributes);\n            return addCapability(ContractNamespace.CONTRACT_NAMESPACE, directives, attributes);\n        }\n\n        Capability addCapability(String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            Capability capability = new SyntheticCapability(this, namespace, directives, attributes);\n            capabilities.add(capability);\n            return capability;\n        }\n\n        Requirement addRequirement(String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            Requirement requirement = new SyntheticRequirement(this, namespace, directives, attributes);\n            requirements.add(requirement);\n            return requirement;\n        }\n\n        @Override\n        public List<Capability> getCapabilities(String namespace) {\n            return capabilities.stream()\n                    .filter(capability -> namespace == null || Objects.equals(namespace, capability.getNamespace()))\n                    .collect(Collectors.toUnmodifiableList());\n        }\n\n        @Override\n        public List<Requirement> getRequirements(String namespace) {\n            return requirements.stream()\n                    .filter(requirement -> namespace == null || Objects.equals(namespace, requirement.getNamespace()))\n                    .collect(Collectors.toUnmodifiableList());\n        }\n    }\n\n    private static final class SyntheticCapability implements Capability {\n        private final Resource resource;\n        private final String namespace;\n        private final Map<String, String> directives;\n        private final Map<String, Object> attributes;\n\n        private SyntheticCapability(Resource resource, String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            this.resource = resource;\n            this.namespace = namespace;\n            this.directives = Map.copyOf(directives);\n            this.attributes = Map.copyOf(attributes);\n        }\n\n        @Override\n        public String getNamespace() {\n            return namespace;\n        }\n\n        @Override\n        public Map<String, String> getDirectives() {\n            return directives;\n        }\n\n        @Override\n        public Map<String, Object> getAttributes() {\n            return attributes;\n        }\n\n        @Override\n        public Resource getResource() {\n            return resource;\n        }\n    }\n\n    private static final class SyntheticRequirement implements Requirement {\n        private final Resource resource;\n        private final String namespace;\n        private final Map<String, String> directives;\n        private final Map<String, Object> attributes;\n\n        private SyntheticRequirement(Resource resource, String namespace, Map<String, String> directives, Map<String, Object> attributes) {\n            this.resource = resource;\n            this.namespace = namespace;\n            this.directives = Map.copyOf(directives);\n            this.attributes = Map.copyOf(attributes);\n        }\n\n        @Override\n        public String getNamespace() {\n            return namespace;\n        }\n\n        @Override\n        public Map<String, String> getDirectives() {\n            return directives;\n        }\n\n        @Override\n        public Map<String, Object> getAttributes() {\n            return attributes;\n        }\n\n        @Override\n        public Resource getResource() {\n            return resource;\n        }\n    }\n\n    private static final class SemanticVersion implements Comparable<SemanticVersion> {\n        private final int major;\n        private final int minor;\n        private final int micro;\n\n        private SemanticVersion(int major, int minor, int micro) {\n            this.major = major;\n            this.minor = minor;\n            this.micro = micro;\n        }\n\n        static SemanticVersion parse(String value) {\n            String[] segments = value.split(\"\\\\.\");\n            assertThat(segments).hasSize(3);\n            return new SemanticVersion(\n                    Integer.parseInt(segments[0]),\n                    Integer.parseInt(segments[1]),\n                    Integer.parseInt(segments[2]));\n        }\n\n        @Override\n        public int compareTo(SemanticVersion other) {\n            int majorComparison = Integer.compare(major, other.major);\n            if (majorComparison != 0) {\n                return majorComparison;\n            }\n            int minorComparison = Integer.compare(minor, other.minor);\n            if (minorComparison != 0) {\n                return minorComparison;\n            }\n            return Integer.compare(micro, other.micro);\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof SemanticVersion)) {\n                return false;\n            }\n            SemanticVersion that = (SemanticVersion) other;\n            return major == that.major && minor == that.minor && micro == that.micro;\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(major, minor, micro);\n        }\n\n        @Override\n        public String toString() {\n            return major + \".\" + minor + \".\" + micro;\n        }\n    }\n}\n"}
