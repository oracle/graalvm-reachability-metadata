  	 * specification of the contract. The value of this attribute must be of
  	 * type {@code Version}.
  	 */
  	public final static String	CAPABILITY_VERSION_ATTRIBUTE	= "version";
  
  	private ContractNamespace() {
  		// empty
  	}
  }
