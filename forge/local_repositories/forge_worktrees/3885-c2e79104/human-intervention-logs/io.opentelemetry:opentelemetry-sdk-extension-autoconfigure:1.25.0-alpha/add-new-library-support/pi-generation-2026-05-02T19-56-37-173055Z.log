va.util.concurrent.atomic.AtomicBoolean;\nimport org.junit.jupiter.api.Test;\n\npublic class Opentelemetry_sdk_extension_autoconfigureTest {\n    private static final AttributeKey<String> SERVICE_NAME = AttributeKey.stringKey(\"service.name\");\n    private static final AttributeKey<String> DEPLOYMENT_ENVIRONMENT = AttributeKey.stringKey(\"deployment.environment\");\n    private static final AttributeKey<String> CUSTOM_RESOURCE_ATTRIBUTE =\n            AttributeKey.stringKey(\"test.resource.customized\");\n    private static final AttributeKey<String> COMPONENT = AttributeKey.stringKey(\"component\");\n    private static final AttributeKey<String> LOG_ATTRIBUTE = AttributeKey.stringKey(\"log.attribute\");\n    private static final TextMapSetter<Map<String, String>> MAP_SETTER =\n            (carrier, key, value) -> carrier.put(key, value);\n\n    @Test\n    void appliesPropertiesAndResourceCustomizers() {\n        AtomicBoolean propertiesCustomizerCalled = new AtomicBoolean(false);\n        AtomicBoolean resourceCustomizerCalled = new AtomicBoolean(false);\n\n        AutoConfiguredOpenTelemetrySdk configured = AutoConfiguredOpenTelemetrySdk.builder()\n                .setResultAsGlobal(false)\n                .registerShutdownHook(false)\n                .addPropertiesSupplier(() -> properties(\n                        \"otel.traces.exporter\", \"none\",\n                        \"otel.metrics.exporter\", \"none\",\n                        \"otel.logs.exporter\", \"none\",\n                        \"otel.service.name\", \"supplier-service\",\n                        \"otel.resource.attributes\", \"deployment.environment=integration,service.namespace=reachability\",\n                        \"otel.traces.sampler\", \"traceidratio\",\n                        \"otel.traces.sampler.arg\", \"0.25\",\n                        \"custom.boolean\", \"true\",\n                        \"custom.duration\", \"42ms\",\n                        \"custom.list\", \"alpha,beta\"))\n                .addPropertiesCustomizer(config -> {\n                    propertiesCustomizerCalled.set(true);\n                    assertThat(config.getString(\"otel.service.name\")).isEqualTo(\"supplier-service\");\n                    return properties(\"otel.service.name\", \"customized-service\", \"custom.long\", \"123\");\n                })\n                .addResourceCustomizer((resource, config) -> {\n                    resourceCustomizerCalled.set(true);\n                    assertThat(config.getLong(\"custom.long\")).isEqualTo(123L);\n                    return resource.merge(Resource.create(Attributes.of(CUSTOM_RESOURCE_ATTRIBUTE, \"from-customizer\")));\n                })\n                .build();\n\n        try {\n            Resource resource = configured.getResource();\n\n            assertThat(propertiesCustomizerCalled).isTrue();\n            assertThat(resourceCustomizerCalled).isTrue();\n            assertThat(resource.getAttribute(SERVICE_NAME)).isEqualTo(\"customized-service\");\n            assertThat(resource.getAttribute(DEPLOYMENT_ENVIRONMENT)).isEqualTo(\"integration\");\n            assertThat(resource.getAttribute(CUSTOM_RESOURCE_ATTRIBUTE)).isEqualTo(\"from-customizer\");\n            assertThat(configured.getConfig().getBoolean(\"custom.boolean\")).isTrue();\n            assertThat(configured.getConfig().getDuration(\"custom.duration\")).isEqualTo(Duration.ofMillis(42));\n            assertThat(configured.getConfig().getList(\"custom.list\")).containsExactly(\"alpha\", \"beta\");\n        } finally {\n            configured.getOpenTelemetrySdk().close();\n        }\n    }\n\n    @Test\n    void exportsEndedSpansThroughCustomizedTracePipeline() {\n        RecordingSpanExporter exporter = new RecordingSpanExporter();\n        AtomicBoolean samplerCustomizerCalled = new AtomicBoolean(false);\n        AtomicBoolean exporterCustomizerCalled = new AtomicBoolean(false);\n\n        AutoConfiguredOpenTelemetrySdk configured = AutoConfiguredOpenTelemetrySdk.builder()\n                .setResultAsGlobal(false)\n                .registerShutdownHook(false)\n                .addPropertiesSupplier(() -> properties(\n                        \"otel.traces.exporter\", \"none\",\n                        \"otel.metrics.exporter\", \"none\",\n                        \"otel.logs.exporter\", \"none\",\n                        \"otel.traces.sampler\", \"always_on\",\n                        \"otel.bsp.schedule.delay\", \"10ms\",\n                        \"otel.bsp.export.timeout\", \"1s\",\n                        \"otel.bsp.max.queue.size\", \"8\",\n                        \"otel.bsp.max.export.batch.size\", \"4\"))\n                .addSamplerCustomizer((sampler, config) -> {\n                    samplerCustomizerCalled.set(true);\n                    assertThat(config.getString(\"otel.traces.sampler\")).isEqualTo(\"always_on\");\n                    return sampler;\n                })\n                .addSpanExporterCustomizer((spanExporter, config) -> {\n                    exporterCustomizerCalled.set(true);\n                    assertThat(config.getString(\"otel.traces.exporter\")).isEqualTo(\"none\");\n                    return exporter;\n                })\n                .build();\n\n        try {\n            OpenTelemetrySdk sdk = configured.getOpenTelemetrySdk();\n            Span span = sdk.getTracer(\"reachability-test\")\n                    .spanBuilder(\"autoconfigured-span\")\n                    .setAttribute(COMPONENT, \"autoconfigure\")\n                    .startSpan();\n            assertThat(span.isRecording()).isTrue();\n\n            span.addEvent(\"span-event\");\n            span.end();\n\n            assertThat(sdk.getSdkTracerProvider().forceFlush().join(5, TimeUnit.SECONDS).isSuccess()).isTrue();\n\n            assertThat(samplerCustomizerCalled).isTrue();\n            assertThat(exporterCustomizerCalled).isTrue();\n            assertThat(exporter.exportedSpans())\n                    .hasSize(1)\n                    .first()\n                    .satisfies(spanData -> {\n                        assertThat(spanData.getName()).isEqualTo(\"autoconfigured-span\");\n                        assertThat(spanData.getAttributes().get(COMPONENT)).isEqualTo(\"autoconfigure\");\n                        assertThat(spanData.getEvents()).hasSize(1);\n                        assertThat(spanData.getResource().getAttribute(SERVICE_NAME)).isNotBlank();\n                    });\n        } finally {\n            configured.getOpenTelemetrySdk().close();\n        }\n    }\n\n    @Test\n    void configuresPropagatorsAndProviderCustomizers() {\n        AtomicBoolean propagatorCustomizerCalled = new AtomicBoolean(false);\n        AtomicBoolean tracerProviderCustomizerCalled = new AtomicBoolean(false);\n        AtomicBoolean meterProviderCustomizerCalled = new AtomicBoolean(false);\n        AtomicBoolean loggerProviderCustomizerCalled = new AtomicBoolean(false);\n\n        AutoConfiguredOpenTelemetrySdk configured = AutoConfiguredOpenTelemetrySdk.builder()\n                .setResultAsGlobal(false)\n                .registerShutdownHook(false)\n                .addPropertiesSupplier(() -> properties(\n                        \"otel.traces.exporter\", \"none\",\n                        \"otel.metrics.exporter\", \"none\",\n                        \"otel.logs.exporter\", \"none\",\n                        \"otel.propagators\", \"tracecontext,baggage\",\n                        \"otel.traces.sampler\", \"always_on\",\n                        \"custom.propagation.header\", \"x-autoconfigure-test\"))\n                .addPropagatorCustomizer((propagator, config) -> {\n                    propagatorCustomizerCalled.set(true);\n                    return TextMapPropagator.composite(\n                            propagator, new TestHeaderPropagator(config.getString(\"custom.propagation.header\")));\n                })\n                .addTracerProviderCustomizer((builder, config) -> {\n                    tracerProviderCustomizerCalled.set(true);\n                    return builder;\n                })\n                .addMeterProviderCustomizer((builder, config) -> {\n                    meterProviderCustomizerCalled.set(true);\n                    return builder;\n                })\n                .addLoggerProviderCustomizer((builder, config) -> {\n                    loggerProviderCustomizerCalled.set(true);\n                    return builder;\n                })\n                .build();\n\n        try {\n            OpenTelemetrySdk sdk = configured.getOpenTelemetrySdk();\n            Span span = sdk.getTracer(\"propagation-test\").spanBuilder(\"carrier-span\").startSpan();\n            Map<String, String> carrier = new HashMap<>();\n\n            sdk.getPropagators()\n                    .getTextMapPropagator()\n                    .inject(span.storeInContext(Context.root()), carrier, MAP_SETTER);\n            span.end();\n\n            LongCounter counter = sdk.getMeter(\"metrics-test\")\n                    .counterBuilder(\"autoconfigure.counter\")\n                    .setDescription(\"Exercises the auto-configured meter provider\")\n                    .setUnit(\"1\")\n                    .build();\n            counter.add(1L, Attributes.of(COMPONENT, \"metrics\"));\n\n            sdk.getSdkLoggerProvider()\n                    .get(\"logs-test\")\n                    .logRecordBuilder()\n                    .setSeverity(Severity.INFO)\n                    .setBody(\"autoconfigure log\")\n                    .setAttribute(LOG_ATTRIBUTE, \"logs\")\n                    .emit();\n\n            assertThat(propagatorCustomizerCalled).isTrue();\n            assertThat(tracerProviderCustomizerCalled).isTrue();\n            assertThat(meterProviderCustomizerCalled).isTrue();\n            assertThat(loggerProviderCustomizerCalled).isTrue();\n            assertThat(carrier).containsKey(\"traceparent\");\n            assertThat(carrier).containsEntry(\"x-autoconfigure-test\", \"custom-propagated\");\n        } finally {\n            configured.getOpenTelemetrySdk().close();\n        }\n    }\n\n    @Test\n    void leavesMetricAndLogExportersDisabledWhenExporterIsNone() {\n        RecordingMetricExporter metricExporter = new RecordingMetricExporter();\n        RecordingLogRecordExporter logRecordExporter = new RecordingLogRecordExporter();\n        AtomicBoolean metricCustomizerCalled = new AtomicBoolean(false);\n        AtomicBoolean logCustomizerCalled = new AtomicBoolean(false);\n\n        AutoConfiguredOpenTelemetrySdk configured = AutoConfiguredOpenTelemetrySdk.builder()\n                .setResultAsGlobal(false)\n                .registerShutdownHook(false)\n                .addPropertiesSupplier(() -> properties(\n                        \"otel.traces.exporter\", \"none\",\n                        \"otel.metrics.exporter\", \"none\",\n                        \"otel.logs.exporter\", \"none\"))\n                .addMetricExporterCustomizer((exporter, config) -> {\n                    metricCustomizerCalled.set(true);\n                    return metricExporter;\n                })\n                .addLogRecordExporterCustomizer((exporter, config) -> {\n                    logCustomizerCalled.set(true);\n                    return logRecordExporter;\n                })\n                .build();\n\n        try {\n            configured.getOpenTelemetrySdk().getMeter(\"customizer-test\")\n                    .counterBuilder(\"customizer.counter\")\n                    .build()\n                    .add(1L);\n            configured.getOpenTelemetrySdk().getSdkLoggerProvider().get(\"customizer-test\")\n                    .logRecordBuilder()\n                    .setBody(\"customizer log\")\n                    .emit();\n\n            assertThat(metricCustomizerCalled).isFalse();\n            assertThat(logCustomizerCalled).isFalse();\n            assertThat(metricExporter.exportedMetrics()).isEmpty();\n            assertThat(logRecordExporter.exportedLogs()).isEmpty();\n        } finally {\n            configured.getOpenTelemetrySdk().close();\n        }\n    }\n\n    private static Map<String, String> properties(String... entries) {\n        Map<String, String> properties = new HashMap<>();\n        for (int index = 0; index < entries.length; index += 2) {\n            properties.put(entries[index], entries[index + 1]);\n        }\n        return properties;\n    }\n\n    private static final class TestHeaderPropagator implements TextMapPropagator {\n        private final String headerName;\n\n        private TestHeaderPropagator(String headerName) {\n            this.headerName = headerName;\n        }\n\n        @Override\n        public Collection<String> fields() {\n            return Collections.singleton(headerName);\n        }\n\n        @Override\n        public <C> void inject(Context context, C carrier, TextMapSetter<C> setter) {\n            setter.set(carrier, headerName, \"custom-propagated\");\n        }\n\n        @Override\n        public <C> Context extract(Context context, C carrier, TextMapGetter<C> getter) {\n            return context;\n        }\n    }\n\n    private static final class RecordingSpanExporter implements SpanExporter {\n        private final List<SpanData> spans = new CopyOnWriteArrayList<>();\n\n        @Override\n        public CompletableResultCode export(Collection<SpanData> spans) {\n            this.spans.addAll(spans);\n            return CompletableResultCode.ofSuccess();\n        }\n\n        @Override\n        public CompletableResultCode flush() {\n            return CompletableResultCode.ofSuccess();\n        }\n\n        @Override\n        public CompletableResultCode shutdown() {\n            return CompletableResultCode.ofSuccess();\n        }\n\n        private List<SpanData> exportedSpans() {\n            return new ArrayList<>(spans);\n        }\n    }\n\n    private static final class RecordingMetricExporter implements MetricExporter {\n        private final List<MetricData> metrics = new CopyOnWriteArrayList<>();\n\n        @Override\n        public AggregationTemporality getAggregationTemporality(InstrumentType instrumentType) {\n            return AggregationTemporality.CUMULATIVE;\n        }\n\n        @Override\n        public CompletableResultCode export(Collection<MetricData> metrics) {\n            this.metrics.addAll(metrics);\n            return CompletableResultCode.ofSuccess();\n        }\n\n        @Override\n        public CompletableResultCode flush() {\n            return CompletableResultCode.ofSuccess();\n        }\n\n        @Override\n        public CompletableResultCode shutdown() {\n            return CompletableResultCode.ofSuccess();\n        }\n\n        private List<MetricData> exportedMetrics() {\n            return new ArrayList<>(metrics);\n        }\n    }\n\n    private static final class RecordingLogRecordExporter implements LogRecordExporter {\n        private final List<LogRecordData> logRecords = new CopyOnWriteArrayList<>();\n\n        @Override\n        public CompletableResultCode export(Collection<LogRecordData> logs) {\n            logRecords.addAll(logs);\n            return CompletableResultCode.ofSuccess();\n        }\n\n        @Override\n        public CompletableResultCode flush() {\n            return CompletableResultCode.ofSuccess();\n        }\n\n        @Override\n        public CompletableResultCode shutdown() {\n            return CompletableResultCode.ofSuccess();\n        }\n\n        private List<LogRecordData> exportedLogs() {\n            return new ArrayList<>(logRecords);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777751617568}}
