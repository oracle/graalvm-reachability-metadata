[tool-call] delta {"path":"tests/src/io.opentelemetry/opentelemetry-sdk-extension-autoconfigure/1.25.0-alpha/src/test/java/io_opentelemetry/opentelemetry_sdk_extension_autoconfigure/Opentelemetry_sdk_extension_autoconfigureTest.java","edits":[{"oldText":"    @Test\n    void exportsEndedSpansThroughCustomizedTracePipeline() {\n","newText":"    @Test\n    void readsSystemPropertiesWhenBuildingConfiguration() {\n        Map<String, String> previousProperties = replaceSystemProperties(properties(\n                \"otel.traces.exporter\", \"none\",\n                \"otel.metrics.exporter\", \"none\",\n                \"otel.logs.exporter\", \"none\",\n                \"otel.traces.sampler\", \"always_off\"));\n\n        AutoConfiguredOpenTelemetrySdk configured = AutoConfiguredOpenTelemetrySdk.builder()\n                .setResultAsGlobal(false)\n                .registerShutdownHook(false)\n                .build();\n\n        try {\n            Span span = configured.getOpenTelemetrySdk()\n                    .getTracer(\"system-properties-test\")\n                    .spanBuilder(\"unsampled-system-property-span\")\n                    .startSpan();\n\n            try {\n                assertThat(configured.getConfig().getString(\"otel.traces.sampler\")).isEqualTo(\"always_off\");\n                assertThat(span.isRecording()).isFalse();\n            } finally {\n                span.end();\n            }\n        } finally {\n            configured.getOpenTelemetrySdk().close();\n            restoreSystemProperties(previousProperties);\n        }\n    }\n\n    @Test\n    void exportsEndedSpansThroughCustomizedTracePipeline() {\n"},{"oldText":"    private static Map<String, String> properties(String... entries) {\n        Map<String, String> properties = new HashMap<>();\n        for (int index = 0; index < entries.length; index += 2) {\n            properties.put(entries[index], entries[index + 1]);\n        }\n        return properties;\n    }\n\n    private static final class TestHeaderPropagator implements TextMapPropagator {\n","newText":"    private static Map<String, String> properties(String... entries) {\n        Map<String, String> properties = new HashMap<>();\n        for (int index = 0; index < entries.length; index += 2) {\n            properties.put(entries[index], entries[index + 1]);\n        }\n        return properties;\n    }\n\n    private static Map<String, String> replaceSystemProperties(Map<String, String> properties) {\n        Map<String, String> previousProperties = new HashMap<>();\n        for (Map.Entry<String, String> property : properties.entrySet()) {\n            previousProperties.put(property.getKey(), System.getProperty(property.getKey()));\n            System.setProperty(property.getKey(), property.getValue());\n        }\n        return previousProperties;\n    }\n\n    private static void restoreSystemProperties(Map<String, String> previousProperties) {\n        for (Map.Entry<String, String> property : previousProperties.entrySet()) {\n            if (property.getValue() == null) {\n                System.clearProperty(property.getKey());\n            } else {\n                System.setProperty(property.getKey(), property.getValue());\n            }\n        }\n    }\n\n    private static final class TestHeaderPropagator implements TextMapPropagator {\n"}]}
