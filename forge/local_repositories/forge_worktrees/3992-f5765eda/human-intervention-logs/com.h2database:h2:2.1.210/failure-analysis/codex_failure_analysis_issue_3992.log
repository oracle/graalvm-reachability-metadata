t\\n    void triggerClassIsLoadedAndConstructedReflectively() throws Exception {\\n        FIRED.set(0);\\n        try (Connection connection = DriverManager.getConnection(\\\"jdbc:h2:mem:triggerObject\\\")) {\\n            connection.createStatement().execute(\\\"CREATE TABLE items(id INT PRIMARY KEY, name VARCHAR)\\\");\\n            connection.createStatement().execute(\\\"CREATE TRIGGER item_trigger BEFORE INSERT ON items FOR EACH ROW CALL '\\\"\\n                    + getClass().getName() + \\\"'\\\");\\n            connection.createStatement().execute(\\\"INSERT INTO items VALUES (1, 'alpha')\\\");\\n        }\\n\\n        assertThat(FIRED.get()).isEqualTo(1);\\n    }\\n\\n    @Test\\n    void triggerSourceIsCompiledAndInvokedReflectively() throws Exception {\\n        try {\\n            try (Connection connection = DriverManager.getConnection(\\\"jdbc:h2:mem:triggerObjectSource\\\")) {\\n                connection.createStatement().execute(\\\"CREATE TABLE source_items(id INT PRIMARY KEY)\\\");\\n                connection.createStatement().execute(\\\"\\\"\\\"\\n                        CREATE TRIGGER source_item_trigger BEFORE INSERT ON source_items FOR EACH ROW AS\\n                        'org.h2.api.Trigger create() { return (conn, oldRow, newRow) -> { newRow[0] = 42; }; }'\\n                        \\\"\\\"\\\");\\n                connection.createStatement().execute(\\\"INSERT INTO source_items VALUES (1)\\\");\\n\\n                try (ResultSet resultSet = connection.createStatement()\\n                        .executeQuery(\\\"SELECT id FROM source_items\\\")) {\\n                    assertThat(resultSet.next()).isTrue();\\n                    assertThat(resultSet.getInt(1)).isEqualTo(42);\\n                }\\n            }\\n        } catch (Error error) {\\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\\n        }\\n    }\\n\\n    @Override\\n    public void fire(Connection conn, Object[] oldRow, Object[] newRow) {\\n       