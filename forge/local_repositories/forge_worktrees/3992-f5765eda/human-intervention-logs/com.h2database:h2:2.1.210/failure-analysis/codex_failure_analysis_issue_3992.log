\\n                  <realm name=\\\"test\\\" validatorClass=\\\"h2.DefaultAuthenticatorTest\\\"/>\\n                  <userToRolesMapper className=\\\"h2.DefaultAuthenticatorTest\\\"/>\\n                </h2Auth>\\n                \\\"\\\"\\\");\\n        try {\\n            DefaultAuthenticator authenticator = new DefaultAuthenticator();\\n\\n            authenticator.configureFromUrl(config.toUri().toURL());\\n\\n            assertThat(authenticator.isAllowUserRegistration()).isTrue();\\n            assertThat(authenticator.isCreateMissingRoles()).isTrue();\\n            assertThat(authenticator.getUserToRolesMappers()).hasSize(1);\\n        } finally {\\n            Files.deleteIfExists(config);\\n        }\\n    }\\n\\n    @Override\\n    public boolean validateCredentials(AuthenticationInfo authenticationInfo) {\\n        return true;\\n    }\\n\\n    @Override\\n    public Collection<String> mapUserToRoles(AuthenticationInfo authenticationInfo) {\\n        return List.of(\\\"TEST_ROLE\\\");\\n    }\\n\\n    @Override\\n    public void configure(ConfigProperties configProperties) {\\n        // No configuration is needed for this test implementation.\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\r\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_39\",\"type\":\"command_execution\",\"command\":\"/usr/bin/zsh -lc \\\"sed -n '1,260p' tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DatabaseTest.java\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\r\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_39\",\"type\":\"command_execution\",\"command\":\"/usr/bin/zsh -lc \\\"sed -n '1,260p' tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DatabaseTest.java\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage h2;\\n\\nimport org.h2.api.DatabaseEventListener;\\nimport org.h2.api.JavaObjectSerializer;\\nimport org.h2.api.TableEngine;\\nimport org.h2.command.ddl.CreateTableData;\\nimport org.h2.mvstore.db.MVTable;\\nimport org.h2.table.Table;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.nio.charset.StandardCharsets;\\nimport java.sql.Connection;\\nimport java.sql.DriverManager;\\nimport java.sql.PreparedStatement;\\nimport java.sql.ResultSet;\\nimport java.sql.SQLException;\\nimport java.sql.Types;\\nimport java.util.concurrent.atomic.AtomicInteger;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class DatabaseTest implements DatabaseEventListener, JavaObjectSerializer, TableEngine {\\n    private static final AtomicInteger EVENT_LISTENER_INITS = new AtomicInteger();\\n    private static final AtomicInteger SERIALIZE_CALLS = new AtomicInteger();\\n    private static final AtomicInteger DESERIALIZE_CALLS = new AtomicInteger();\\n    private static final AtomicInteger TABLE_ENGINE_CALLS = new AtomicInteger();\\n\\n    @Test\\n    void databaseInstantiatesConfiguredEventListenerAndJavaObjectSerializer() throws Exception {\\n        EVENT_LISTENER_INITS.set(0);\\n        SERIALIZE_CALLS.set(0);\\n        DESERIALIZE_CALLS.set(0);\\n        String className = getClass().getName();\\n        String url = \\\"jdbc:h2:mem:databaseDynamicAccess;DATABASE_EVENT_LISTENER='\\\" + className\\n                + \\\"';JAVA_OBJECT_SERIALIZER='\\\" + className + \\\"'\\\";\\n\\n        try (Connection connection = DriverManager.getConnection(url)) {\\n            connection.createStatement().execute(\\\"CREATE TABLE objects(id INT PRIMARY KEY, payload JAVA_OBJECT)\\\");\\n            try (PreparedStatement statement = connection.prepareStatement(\\\"INSERT INTO objects VALUES (?, ?)\\\")) {\\n                statement.setInt(1, 1);\\n                statement.setObject(2, \\\"serialized-value\\\", Types.JAVA_OBJECT);\\n                assertThat(statement.executeUpdate()).isEqualTo(1);\\n            }\\n            try (ResultSet resultSet = connection.createStatement().executeQuery(\\\"SELECT payload FROM objects\\\")) {\\n                assertThat(resultSet.next()).isTrue();\\n                assertThat(resultSet.getObject(1)).isEqualTo(\\\"serialized-value\\\");\\n            }\\n        }\\n\\n        assertThat(EVENT_LISTENER_INITS.get()).isEqualTo(1);\\n        assertThat(SERIALIZE_CALLS.get()).isPositive();\\n        assertThat(DESERIALIZE_CALLS.get()).isPositive();\\n    }\\n\\n    @Test\\n    void databaseInstantiatesConfiguredTableEngine() throws Exception {\\n        TABLE_ENGINE_CALLS.set(0);\\n\\n        try (Connection connection = DriverManager.getConnection(\\\"jdbc:h2:mem:databaseTableEngine\\\")) {\\n            connection.createStatement().execute(\\\"CREATE TABLE engine_items(id INT PRIMARY KEY, name VARCHAR) ENGINE \\\\\\\"\\\"\\n                    + getClass().getName() + \\\"\\\\\\\"\\\");\\n            connection.createStatement().execute(\\\"INSERT INTO engine_items VALUES (1, 'alpha')\\\");\\n            try (ResultSet resultSet = connection.createStatement()\\n                    .executeQuery(\\\"SELECT name FROM engine_items WHERE id = 1\\\")) {\\n                assertThat(resultSet.next()).isTrue();\\n                assertThat(resultSet.getString(1)).isEqualTo(\\\"alpha\\\");\\n            }\\n        }\\n\\n        assertThat(TABLE_ENGINE_CALLS.get()).isEqualTo(1);\\n    }\\n\\n    @Override\\n    public void init(String url) {\\n        EVENT_LISTENER_INITS.incrementAndGet();\\n    }\\n\\n    @Override\\n    public byte[] serialize(Object obj) {\\n        SERIALIZE_CALLS.incrementAndGet();\\n        return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);\\n    }\\n\\n    @Override\\n    public Object deserialize(byte[] bytes) {\\n        DESERIALIZE_CALLS.incrementAndGet();\\n        return new String(bytes, StandardCharsets.UTF_8);\\n    }\\n\\n    @Override\\n    public void exceptionThrown(SQLException e, String sql) {\\n        throw new AssertionError(sql, e);\\n    }\\n\\n    @Override\\n    public Table createTable(CreateTableData data) {\\n        TABLE_ENGINE_CALLS.incrementAndGet();\\n        return new MVTable(data, data.session.getDatabase().getStore());\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\r\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_40\",\"type\":\"command_execution\",\"command\":\"/usr/bin/zsh -lc 'git diff -- metadata/com.h2database/h2/2.1.210/reachability-metadata.json'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\r\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_40\",\"type\":\"command_execution\",\"command\":\"/usr/bin/zsh -lc 'git diff -- metadata/com.h2database/h2/2.1.210/reachability-metadata.json'\",\"aggregated_output\":\"diff --git a/metadata/com.h2database/h2/2.1.210/reachability-metadata.json b/metadata/com.h2database/h2/2.1.210/reachability-metadata.json\\nindex 877d04004..ccc5050a0 100644\\n--- a/metadata/com.h2database/h2/2.1.210/reachability-metadata.json\\n+++ b/metadata/com.h2database/h2/2.1.210/reachability-metadata.json\\n@@ -199,6 +199,31 @@\\n         }\\n       ]\\n     },\\n+    {\\n+      \\\"condition\\\": {\\n+        \\\"typeReached\\\": \\\"org.h2.api.DatabaseEventListener\\\"\\n+      },\\n+      \\\"type\\\": \\\"java.util.EventListener\\\"\\n+    },\\n+    {\\n+      \\\"condition\\\": {\\n+        \\\"typeReached\\\": \\\"org.h2.util.JdbcUtils\\\"\\n+      },\\n+      \\\"type\\\": \\\"java.sql.Driver\\\"\\n+    },\\n+    {\\n+      \\\"condition\\\": {\\n+        \\\"typeReached\\\": \\\"org.h2.util.JdbcUtils\\\"\\n+      },\\n+      \\\"type\\\": \\\"java.sql.DatabaseMetaData\\\",\\n+      \\\"allPublicMethods\\\": true\\n+    },\\n+    {\\n+      \\\"condition\\\": {\\n+        \\\"typeReached\\\": \\\"org.h2.util.JdbcUtils\\\"\\n+      },\\n+      \\\"type\\\": \\\"org.h2.server.TcpServer\\\"\\n+    },\\n     {\\n       \\