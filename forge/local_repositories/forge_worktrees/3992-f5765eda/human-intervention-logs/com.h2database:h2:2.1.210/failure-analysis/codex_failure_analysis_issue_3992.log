n    67\\t        try (Connection connection = DriverManager.getConnection(\\\"jdbc:h2:mem:jdbcUtilsInfo\\\");\\n    68\\t                ResultSet resultSet = JdbcUtils.getMetaResultSet(connection, \\\"@info\\\")) {\\n    69\\t            Set<String> keys = new HashSet<>();\\n    70\\t            while (resultSet.next()) {\\n    71\\t                keys.add(resultSet.getString(\\\"KEY\\\"));\\n    72\\t            }\\n    73\\t\\n    74\\t            assertThat(keys)\\n    75\\t                    .contains(\\\"conn.getCatalog\\\")\\n    76\\t                    .contains(\\\"meta.getDatabaseProductName\\\")\\n    77\\t                    .contains(\\\"meta.supportsTransactions\\\");\\n    78\\t        }\\n    79\\t    }\\n    80\\t\\n    81\\t    public static final class Serializer implements JavaObjectSerializer {\\n    82\\t        @Override\\n    83\\t        public byte[] serialize(Object obj) throws Exception {\\n    84\\t            ByteArrayOutputStream out = new ByteArrayOutputStream();\\n    85\\t            try (ObjectOutputStream objectOut = new ObjectOutputStream(out)) {\\n    86\\t                objectOut.writeObject(obj);\\n    87\\t            }\\n    88\\t            return out.toByteArray();\\n    89\\t        }\\n    90\\t\\n    91\\t        @Override\\n    92\\t        public Object deserialize(byte[] bytes) throws Exception {\\n    93\\t            try (ObjectInputStream objectIn = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\\n    94\\t                return objectIn.readObject();\\n    95\\t            }\\n    96\\t        }\\n    97\\t    }\\n    98\\t}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\r\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_21\",\"type\":\"agent_message\",\"text\":\"I have the review conclusion. I’m submitting a change request now because the apparent coverage gain depends on test-only reflection/runtime-init config that is not present in the shipped H2 metadata, so the PR overstates real suppo