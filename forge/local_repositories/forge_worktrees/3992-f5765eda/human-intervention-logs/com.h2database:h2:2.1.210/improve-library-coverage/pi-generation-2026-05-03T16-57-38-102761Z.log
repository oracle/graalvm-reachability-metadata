[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/ObjectDataTypeInnerObjectArrayTypeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.mvstore.MVMap;\nimport org.h2.mvstore.MVStore;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.net.URI;\nimport java.nio.file.Path;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectDataTypeInnerObjectArrayTypeTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void readsObjectArraysWithNonCommonComponentType() throws Exception {\n        Path storePath = tempDir.resolve(\"arrays.mv.db\");\n        URI[] values = {new URI(\"https://h2database.com\"), new URI(\"urn:h2:test\")};\n        try (MVStore store = new MVStore.Builder().fileName(storePath.toString()).open()) {\n            MVMap<Integer, URI[]> map = store.openMap(\"arrays\");\n            map.put(1, values);\n            store.commit();\n        }\n\n        try (MVStore store = new MVStore.Builder().fileName(storePath.toString()).readOnly().open()) {\n            MVMap<Integer, URI[]> map = store.openMap(\"arrays\");\n            assertThat(map.get(1)).containsExactly(values);\n        }\n    }\n}\n"}
