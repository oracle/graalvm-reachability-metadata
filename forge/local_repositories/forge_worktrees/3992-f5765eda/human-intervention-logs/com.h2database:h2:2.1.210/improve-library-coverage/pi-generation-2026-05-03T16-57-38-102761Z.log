[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/UserAggregateTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.AggregateFunction;\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.Types;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UserAggregateTest {\n    @Test\n    void createsAggregateFunctionInstances() throws Exception {\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:userAggregate;DB_CLOSE_DELAY=-1\")) {\n            connection.createStatement().execute(\"CREATE AGGREGATE SUM_PLUS_ONE FOR 'h2.UserAggregateTest$SumPlusOne'\");\n            connection.createStatement().execute(\"CREATE TABLE NUMBERS(V INT)\");\n            connection.createStatement().execute(\"INSERT INTO NUMBERS VALUES (1), (2), (3)\");\n            try (ResultSet resultSet = connection.createStatement().executeQuery(\"SELECT SUM_PLUS_ONE(V) FROM NUMBERS\")) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getInt(1)).isEqualTo(7);\n            }\n        }\n    }\n\n    public static class SumPlusOne implements AggregateFunction {\n        private int sum;\n\n        @Override\n        public int getType(int[] inputTypes) {\n            return Types.INTEGER;\n        }\n\n        @Override\n        public void add(Object value) {\n            if (value instanceof Number number) {\n                sum += number.intValue();\n            }\n        }\n\n        @Override\n        public Object getResult() throws SQLException {\n            return sum + 1;\n        }\n    }\n}\n"}
