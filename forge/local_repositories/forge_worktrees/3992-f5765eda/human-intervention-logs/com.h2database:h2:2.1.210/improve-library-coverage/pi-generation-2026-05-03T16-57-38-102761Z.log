e);\n        URL configUrl = config.toUri().toURL();\n        authenticator.configureFromUrl(configUrl);\n\n        assertThat(authenticator.getRealms()).containsKey(\"TEST\");\n        assertThat(authenticator.getUserToRolesMappers()).hasSize(1);\n        assertThat(VALIDATOR_CONFIG_COUNT).hasValue(1);\n        assertThat(MAPPER_CONFIG_COUNT).hasValue(1);\n    }\n\n    public static class AllowValidator implements CredentialsValidator {\n        @Override\n        public void configure(ConfigProperties configProperties) {\n            VALIDATOR_CONFIG_COUNT.incrementAndGet();\n        }\n\n        @Override\n        public boolean validateCredentials(AuthenticationInfo authenticationInfo) {\n            return true;\n        }\n    }\n\n    public static class StaticRoleMapper implements UserToRolesMapper {\n        @Override\n        public void configure(ConfigProperties configProperties) {\n            MAPPER_CONFIG_COUNT.incrementAndGet();\n        }\n\n        @Override\n        public Collection<String> mapUserToRoles(AuthenticationInfo authenticationInfo) throws AuthenticationException {\n            return List.of(\"TEST_ROLE\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1127, "output": 677, "cacheRead": 70656, "cacheWrite": 0, "totalTokens": 72460, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777827192391, "responseId": "resp_008d204f541439390169f77d7961f881959dfd9b969615e017"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_dcYhGLtSK0ygWXAgrOU5JHtb|fc_008d204f541439390169f77d7a3548819591c6355cd5aa085c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2756 bytes to tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DefaultAuthenticatorTest.java"}], "isError": false, "timestamp": 1777827198407}]}
