).execute(\"CREATE TABLE TEST(ID INT)\"));\n            assertThat(thrown).isInstanceOf(SQLException.class);\n        }\n\n        assertThat(TABLE_ENGINE_COUNT).hasValue(1);\n    }\n\n    public static class RecordingListener implements DatabaseEventListener {\n        @Override\n        public void init(String url) {\n            LISTENER_INIT_COUNT.incrementAndGet();\n        }\n    }\n\n    public static class StringSerializer implements JavaObjectSerializer {\n        public StringSerializer() {\n            SERIALIZER_COUNT.incrementAndGet();\n        }\n\n        @Override\n        public byte[] serialize(Object obj) {\n            return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);\n        }\n\n        @Override\n        public Object deserialize(byte[] bytes) {\n            return new String(bytes, StandardCharsets.UTF_8);\n        }\n    }\n\n    public static class FailingTableEngine implements TableEngine {\n        public FailingTableEngine() {\n            TABLE_ENGINE_COUNT.incrementAndGet();\n        }\n\n        @Override\n        public Table createTable(CreateTableData data) {\n            throw new IllegalStateException(\"table engine was invoked\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1757, "output": 866, "cacheRead": 69120, "cacheWrite": 0, "totalTokens": 71743, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777827184582, "responseId": "resp_008d204f541439390169f77d718a2081958e0b1971aea38111"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_3Kzlv7kG4OMLnzXUBtjPHgog|fc_008d204f541439390169f77d736a708195a9fcf6d62c6c7238", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3378 bytes to tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DatabaseTest.java"}], "isError": false, "timestamp": 1777827192384}]}
