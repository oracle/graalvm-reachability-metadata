       assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).contains(\"h2 classpath resource\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777845372196}, {"role": "toolResult", "toolCallId": "call_vfjYpf1lkFngcZs7IUyjMa7B|fc_098fddbd388d97700169f7c47bce0081a288f3ac573a88934c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.DatabaseEventListener;\nimport org.h2.api.JavaObjectSerializer;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.charset.StandardCharsets;\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.PreparedStatement;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.Types;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DatabaseTest implements DatabaseEventListener, JavaObjectSerializer {\n    private static final AtomicInteger EVENT_LISTENER_INITS = new AtomicInteger();\n    private static final AtomicInteger SERIALIZE_CALLS = new AtomicInteger();\n    private static final AtomicInteger DESERIALIZE_CALLS = new AtomicInteger();\n\n    @Test\n    void databaseInstantiatesConfiguredEventListenerAndJavaObjectSerializer() throws Exception {\n        EVENT_LISTENER_INITS.set(0);\n        SERIALIZE_CALLS.set(0);\n        DESERIALIZE_CALLS.set(0);\n        String className = getClass().getName();\n        String url = \"jdbc:h2:mem:databaseDynamicAccess;DATABASE_EVENT_LISTENER='\" + className\n                + \"';JAVA_OBJECT_SERIALIZER='\" + className + \"'\";\n\n        try (Connection connection = DriverManager.getConnection(url)) {\n            connection.createStatement().execute(\"CREATE TABLE objects(id INT PRIMARY KEY, payload JAVA_OBJECT)\");\n            try (PreparedStatement statement = connection.prepareStatement(\"INSERT INTO objects VALUES (?, ?)\")) {\n                statement.setInt(1, 1);\n                statement.setObject(2, \"serialized-value\", Types.JAVA_OBJECT);\n                assertThat(statement.executeUpdate()).isEqualTo(1);\n            }\n            try (ResultSet resultSet = connection.createStatement().executeQuery(\"SELECT payload FROM objects\")) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getObject(1)).isEqualTo(\"serialized-value\");\n            }\n        }\n\n        assertThat(EVENT_LISTENER_INITS.get()).isEqualTo(1);\n        assertThat(SERIALIZE_CALLS.get()).isPositive();\n        assertThat(DESERIALIZE_CALLS.get()).isPositive();\n    }\n\n    @Override\n    public void init(String url) {\n        EVENT_LISTENER_INITS.incrementAndGet();\n    }\n\n    @Override\n    public byte[] serialize(Object obj) {\n        SERIALIZE_CALLS.incrementAndGet();\n        return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);\n    }\n\n    @Override\n    public Object deserialize(byte[] bytes) {\n        DESERIALIZE_CALLS.incrementAndGet();\n        return new String(bytes, StandardCharsets.UTF_8);\n    }\n\n    @Override\n    public void exceptionThrown(SQLException e, String sql) {\n        throw new AssertionError(sql, e);\n    }\n}\n"}], "isError": false, "timestamp": 1777845372197}, {"role": "toolResult", "toolCallId": "call_rMq8NrIEbw0c8jCAvjdp0qGY|fc_098fddbd388d97700169f7c47bce0c81a28976e2f4e97fd122", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.util.Utils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UtilsTest {\n    @Test\n    void utilityReflectionHelpersInvokePublicMembers() throws Exception {\n        Helper helper = new Helper(\"h2\");\n\n        assertThat(Utils.callStaticMethod(\"h2.UtilsTest.staticEcho\", \"H2\")).isEqualTo(\"H2\");\n        assertThat(Utils.callMethod(helper, \"upper\")).isEqualTo(\"H2\");\n        assertThat(Utils.newInstance(\"h2.UtilsTest$Helper\", \"H2\").toString()).isEqualTo(\"H2\");\n    }\n\n    @Test\n    void resourceLoaderReadsBundledWebResourceFromDataZip() throws Exception {\n        byte[] bytes = Utils.getResource(\"/org/h2/server/web/res/helpTranslate.jsp\");\n\n        assertThat(bytes).isNotEmpty();\n    }\n\n    public static String staticEcho(String value) {\n        return value;\n    }\n\n    public static final class Helper {\n        private final String value;\n\n        public Helper(String value) {\n            this.value = value;\n        }\n\n        public String upper() {\n            return value.toUpperCase();\n        }\n\n        @Override\n        public String toString() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777845372197}, {"role": "toolResult", "toolCallId": "call_HvmkOU8Lt3HcvsglZKDXyYxn|fc_098fddbd388d97700169f7c47bce1481a289d6b96876d1d49c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.ResultSet;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FunctionAliasTest {\n    @Test\n    void aliasLoaderScansPublicStaticMethods() throws Exception {\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:functionAlias\")) {\n            connection.createStatement().execute(\"CREATE ALIAS DOUBLE_VALUE FOR '\" + getClass().getName() + \".doubleValue'\");\n            try (ResultSet resultSet = connection.createStatement().executeQuery(\"SELECT DOUBLE_VALUE(21)\")) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getInt(1)).isEqualTo(42);\n            }\n        }\n    }\n\n    public static int doubleValue(int value) {\n        return value * 2;\n    }\n}\n"}], "isError": false, "timestamp": 1777845372197}, {"role": "toolResult", "toolCallId": "call_CNDgNHyoCefFSDwVAQqF84AB|fc_098fddbd388d97700169f7c47bce1c81a291be0ac94166d5d0", "toolName": "read", "content": [{"type": "text", "text": "[\n  {\n    \"name\": \"h2.DatabaseTest\",\n    \"queryAllPublicMethods\": true,\n    \"methods\": [\n      { \"name\": \"<init>\", \"parameterTypes\": [] }\n    ]\n  },\n  {\n    \"name\": \"h2.DefaultAuthenticatorTest\",\n    \"methods\": [\n      { \"name\": \"<init>\", \"parameterTypes\": [] }\n    ]\n  },\n  {\n    \"name\": \"h2.FunctionAliasInnerJavaMethodTest\",\n    \"queryAllPublicMethods\": true,\n    \"methods\": [\n      { \"name\": \"joinWords\", \"parameterTypes\": [\"java.lang.String[]\"] }\n    ]\n  },\n  {\n    \"name\": \"h2.FunctionAliasTest\",\n    \"queryAllPublicMethods\": true,\n    \"methods\": [\n      { \"name\": \"doubleValue\", \"parameterTypes\": [\"int\"] }\n    ]\n  },\n  {\n    \"name\": \"h2.JdbcUtilsTest\",\n    \"methods\": [\n      { \"name\": \"<init>\", \"parameterTypes\": [] }\n    ]\n  },\n  {\n    \"name\": \"h2.UtilsTest\",\n    \"queryAllPublicMethods\": true,\n    \"methods\": [\n      { \"name\": \"staticEcho\", \"parameterTypes\": [\"java.lang.String\"] }\n    ]\n  },\n  {\n    \"name\": \"h2.UtilsTest$Helper\",\n    \"queryAllPublicConstructors\": true,\n    \"queryAllPublicMethods\": true,\n    \"methods\": [\n      { \"name\": \"<init>\", \"parameterTypes\": [\"java.lang.String\"] },\n      { \"name\": \"upper\", \"parameterTypes\": [] }\n