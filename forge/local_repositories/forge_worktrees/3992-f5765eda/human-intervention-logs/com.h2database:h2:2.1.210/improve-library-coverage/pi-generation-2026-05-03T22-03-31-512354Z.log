  package h2;
  
  import org.h2.api.Trigger;
  import org.junit.jupiter.api.Test;
  
  import java.sql.Connection;
  import java.sql.DriverManager;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TriggerObjectTest implements Trigger {
      private static final AtomicInteger FIRED = new AtomicInteger();
  
      @Test
      void triggerClassIsLoadedAndConstructedReflectively() throws Exception {
          FIRED.set(0);
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:triggerObject")) {
              connection.createStatement().execute("CREATE TABLE items(id INT PRIMARY KEY, name VARCHAR)");
              connection.createStatement().execute("CREATE TRIGGER item_trigger BEFORE INSERT ON items FOR EACH ROW CALL '"
                      + getClass().getName() + "'");
              connection.createStatement().execute("INSERT INTO items VALUES (1, 'alpha')");
          }
  
          assertThat(FIRED.get()).isEqualTo(1);
      }
  
      @Override
      public void fire(Connection conn, Object[] oldRow, Object[] newRow) {
          FIRED.incrementAndGet();
      }
  }
