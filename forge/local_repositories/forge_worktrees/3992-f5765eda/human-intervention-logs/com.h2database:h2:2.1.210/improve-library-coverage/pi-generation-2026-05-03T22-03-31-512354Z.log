[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/CompareModeIcu4JTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.value.CompareMode;\nimport org.junit.jupiter.api.Test;\n\nimport java.text.Collator;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CompareModeIcu4JTest {\n    @Test\n    void icu4jCompareModeReflectivelyUsesOptionalCollatorApi() {\n        CompareMode languageOnly = CompareMode.getInstance(CompareMode.ICU4J + \"en\", Collator.TERTIARY);\n        CompareMode languageAndCountry = CompareMode.getInstance(CompareMode.ICU4J + \"en_US\", Collator.TERTIARY);\n        CompareMode discoveredLocale = CompareMode.getInstance(CompareMode.ICU4J + \"ENGLISH_UNITED_STATES\",\n                Collator.TERTIARY);\n\n        assertThat(languageOnly.compareString(\"alpha\", \"beta\", false)).isNegative();\n        assertThat(languageAndCountry.compareString(\"alpha\", \"ALPHA\", true)).isZero();\n        assertThat(discoveredLocale.equalsChars(\"H2\", 0, \"h2\", 0, true)).isTrue();\n    }\n}\n"}
