  package h2;
  
  import org.h2.message.TraceSystem;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThatCode;
  
  public class TraceSystemTest {
      @Test
      void adapterTraceLevelAttemptsToConstructTraceWriterAdapter() {
          TraceSystem traceSystem = new TraceSystem(null);
  
          assertThatCode(() -> traceSystem.setLevelFile(TraceSystem.ADAPTER)).doesNotThrowAnyException();
          traceSystem.close();
      }
  }
