  package h2;
  
  import org.h2.store.fs.FilePath;
  import org.junit.jupiter.api.Test;
  
  import java.io.InputStream;
  import java.io.ByteArrayInputStream;
  import java.nio.charset.StandardCharsets;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FilePathDiskTest {
      @Test
      void diskPathReadsClasspathResources() throws Exception {
          FilePath path = FilePath.get("classpath:h2-resource.txt");
  
          assertThat(path.size()).isGreaterThanOrEqualTo(0);
          try (InputStream inputStream = path.newInputStream()) {
              assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).contains("h2 classpath resource");
          }
      }
  
      @Test
      void diskPathFallsBackToContextClassLoaderForClasspathResources() throws Exception {
          ClassLoader previous = Thread.currentThread().getContextClassLoader();
          byte[] resourceBytes = "h2 context class loader resource".getBytes(StandardCharsets.UTF_8);
          ClassLoader classLoader = new ClassLoader(null) {
              @Override
              public InputStream getResourceAsStream(String name) {
                  if ("context-loader-resource.txt".equals(name)) {
                      return new ByteArrayInputStream(resourceBytes);
                  }
                  return null;
              }
          };
  
          try {
