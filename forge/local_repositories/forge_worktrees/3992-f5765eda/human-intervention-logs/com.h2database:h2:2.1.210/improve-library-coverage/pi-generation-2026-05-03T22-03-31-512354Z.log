/H2Test.java:101:            statement.setLong(12, Long.MAX_VALUE); // BIGINT\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:102:            statement.setBigDecimal(13, new BigDecimal(\"12345\")); // NUMERIC\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:103:            statement.setFloat(14, 23.42f); // REAL\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:104:            statement.setDouble(15, 42.23); // DOUBLE PRECISION\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:105:            statement.setBigDecimal(16, new BigDecimal(\"12345\")); // DECFLOAT\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:106:            statement.setObject(17, LocalDate.of(2020, 1, 2)); // DATE\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:107:            statement.setObject(18, LocalTime.of(23, 1, 2)); // TIME\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:108:            statement.setObject(19, OffsetTime.of(23, 1, 2, 3, ZoneOffset.ofHours(3))); // TIME WITH TIME ZONE\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:109:            statement.setObject(20, LocalDateTime.of(2020, 1, 2, 3, 4, 5, 6)); // TIMESTAMP\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:110:            statement.setObject(21, OffsetDateTime.of(2020, 1, 2, 3, 4, 5, 6, ZoneOffset.ofHours(3))); // TIMESTAMP WITH TIME ZONE\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:111:            statement.setObject(22, Interval.ofYears(23)); // INTERVAL YEAR\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:112:            statement.setObject(23, \"serialize this string\", Types.JAVA_OBJECT); // JAVA_OBJECT\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:113:            statement.setString(24, \"value2\"); // ENUM\ntests/src/com.h2database/h2/2.1.210/src/test/java/h2/H2Test.java:114:            statement.setString(