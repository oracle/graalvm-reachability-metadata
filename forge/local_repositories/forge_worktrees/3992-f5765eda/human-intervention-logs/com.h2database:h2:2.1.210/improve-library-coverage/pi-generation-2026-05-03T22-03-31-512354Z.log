  package h2;
  
  import org.h2.api.DatabaseEventListener;
  import org.h2.api.JavaObjectSerializer;
  import org.h2.api.TableEngine;
  import org.h2.command.ddl.CreateTableData;
  import org.h2.mvstore.db.MVTable;
  import org.h2.table.Table;
  import org.junit.jupiter.api.Test;
  
  import java.nio.charset.StandardCharsets;
  import java.sql.Connection;
  import java.sql.DriverManager;
  import java.sql.PreparedStatement;
  import java.sql.ResultSet;
  import java.sql.SQLException;
  import java.sql.Types;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DatabaseTest implements DatabaseEventListener, JavaObjectSerializer, TableEngine {
      private static final AtomicInteger EVENT_LISTENER_INITS = new AtomicInteger();
      private static final AtomicInteger SERIALIZE_CALLS = new AtomicInteger();
      private static final AtomicInteger DESERIALIZE_CALLS = new AtomicInteger();
      private static final AtomicInteger TABLE_ENGINE_CALLS = new AtomicInteger();
  
      @Test
      void databaseInstantiatesConfiguredEventListenerAndJavaObjectSerializer() throws Exception {
          EVENT_LISTENER_INITS.set(0);
          SERIALIZE_CALLS.set(0);
          DESERIALIZE_CALLS.set(0);
          String className = getClass().getName();
          String url = "jdbc:h2:mem:databaseDynamicAccess;DATABASE_EVENT_LISTENER='" + className
                  + "';JAVA_OBJECT_SERIALIZER='" + className + "'";
  
          try (Connection connection = DriverManager.getConnection(url)) {
              connection.createStatement().execute("CREATE TABLE objects(id INT PRIMARY KEY, payload JAVA_OBJECT)");
              try (PreparedStatement statement = connection.prepareStatement("INSERT INTO objects VALUES (?, ?)")) {
                  statement.setInt(1, 1);
                  statement.setObject(2, "serialized-value", Types.JAVA_OBJECT);
                  assertThat(statement.executeUpdate()).isEqualTo(1);
              }
              try (ResultSet resultSet = connection.createStatement().executeQuery("SELECT payload FROM objects")) {
                  assertThat(resultSet.next()).isTrue();
                  assertThat(resultSet.getObject(1)).isEqualTo("serialized-value");
              }
          }
  
          assertThat(EVENT_LISTENER_INITS.get()).isEqualTo(1);
          assertThat(SERIALIZE_CALLS.get()).isPositive();
          assertThat(DESERIALIZE_CALLS.get()).isPositive();
      }
  
      @Test
      void databaseInstantiatesConfiguredTableEngine() throws Exception {
          TABLE_ENGINE_CALLS.set(0);
  
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:databaseTableEngine")) {
              connection.createStatement().execute("CREATE TABLE engine_items(id INT PRIMARY KEY, name VARCHAR) ENGINE \""
                      + getClass().getName() + "\"");
              connection.createStatement().execute("INSERT INTO engine_items VALUES (1, 'alpha')");
              try (ResultSet resultSet = connection.createStatement().executeQuery("SELECT name FROM engine_items WHERE id = 1")) {
                  assertThat(resultSet.next()).isTrue();
                  assertThat(resultSet.getString(1)).isEqualTo("alpha");
              }
          }
  
          assertThat(TABLE_ENGINE_CALLS.get()).isEqualTo(1);
      }
  
      @Override
      public void init(String url) {
          EVENT_LISTENER_INITS.incrementAndGet();
      }
  
      @Override
      public byte[] serialize(Object obj) {
          SERIALIZE_CALLS.incrementAndGet();
          return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);
      }
  
      @Override
      public Object deserialize(byte[] bytes) {
          DESERIALIZE_CALLS.incrementAndGet();
          return new String(bytes, StandardCharsets.UTF_8);
      }
  
      @Override
      public void exceptionThrown(SQLException e, String sql) {
          throw new AssertionError(sql, e);
      }
  
      @Override
      public Table createTable(CreateTableData data) {
          TABLE_ENGINE_CALLS.incrementAndGet();
          return new MVTable(data, data.session.getDatabase().getStore());
      }
  }
