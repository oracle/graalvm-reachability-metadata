  package h2;
  
  import org.h2.util.Utils;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UtilsTest {
      @Test
      void invokesUtilityReflectionAndResourceLoadingPaths() throws Exception {
          UtilityTarget target = new UtilityTarget("dynamic");
  
          assertThat(Utils.callStaticMethod(UtilityTarget.class.getName() + ".staticValue", "42")).isEqualTo(42);
          assertThat(Utils.callMethod(target, "suffix", 3)).isEqualTo("amic");
          assertThat(Utils.newInstance(UtilityTarget.class.getName(), "h2").toString()).isEqualTo("h2");
          assertThat(Utils.getResource("/org/h2/util/data.zip")).isNotEmpty();
          assertThat(Utils.scaleForAvailableMemory(1)).isGreaterThanOrEqualTo(0);
      }
  
      public static final class UtilityTarget {
          private final String value;
  
          public UtilityTarget(String value) {
              this.value = value;
          }
  
          public static Integer staticValue(String value) {
              return Integer.valueOf(value);
          }
  
          public String suffix(Integer beginIndex) {
              return value.substring(beginIndex);
          }
  
          @Override
          public String toString() {
              return value;
          }
      }
  }
