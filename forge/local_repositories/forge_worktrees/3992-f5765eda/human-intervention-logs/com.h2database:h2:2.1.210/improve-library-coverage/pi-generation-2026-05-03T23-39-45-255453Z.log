  package h2;
  
  import org.h2.api.DatabaseEventListener;
  import org.h2.api.JavaObjectSerializer;
  import org.h2.api.TableEngine;
  import org.h2.command.ddl.CreateTableData;
  import org.h2.table.Table;
  import org.junit.jupiter.api.Test;
  
  import java.nio.charset.StandardCharsets;
  import java.sql.Connection;
  import java.sql.DriverManager;
  import java.sql.PreparedStatement;
  import java.sql.ResultSet;
  import java.sql.SQLException;
  import java.sql.Statement;
  import java.sql.Types;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class DatabaseTest {
      @Test
      void instantiatesConfiguredDatabaseExtensions() throws SQLException {
          RecordingDatabaseEventListener.initialized = false;
          RecordingJavaObjectSerializer.serialized = false;
          RecordingJavaObjectSerializer.deserialized = false;
  
          String url = "jdbc:h2:mem:database-extensions;DB_CLOSE_DELAY=-1"
                  + ";DATABASE_EVENT_LISTENER='" + RecordingDatabaseEventListener.class.getName() + "'"
                  + ";JAVA_OBJECT_SERIALIZER='" + RecordingJavaObjectSerializer.class.getName() + "'";
          try (Connection connection = DriverManager.getConnection(url)) {
              assertThat(RecordingDatabaseEventListener.initialized).isTrue();
  
              try (PreparedStatement statement = connection.prepareStatement("SELECT CAST(? AS JAVA_OBJECT)")) {
                  statement.setObject(1, "custom", Types.JAVA_OBJECT);
                  try (ResultSet resultSet = statement.executeQuery()) {
                      assertThat(resultSet.next()).isTrue();
                      assertThat(resultSet.getObject(1)).isEqualTo("custom");
                  }
              }
          }
  
          assertThat(RecordingJavaObjectSerializer.serialized).isTrue();
          assertThat(RecordingJavaObjectSerializer.deserialized).isTrue();
      }
  
      @Test
      void instantiatesConfiguredTableEngine() throws SQLException {
          RecordingTableEngine.constructed = false;
  
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:database-table-engine")) {
              try (Statement statement = connection.createStatement()) {
                  assertThatThrownBy(() -> statement.execute(
                          "CREATE TABLE engine_target(id INT) ENGINE \""
                                  + RecordingTableEngine.class.getName() + "\""))
                          .isInstanceOf(SQLException.class);
              }
          }
  
          assertThat(RecordingTableEngine.constructed).isTrue();
      }
  
      public static final class RecordingDatabaseEventListener implements DatabaseEventListener {
          static boolean initialized;
  
          @Override
          public void init(String url) {
              initialized = true;
          }
      }
  
      public static final class RecordingJavaObjectSerializer implements JavaObjectSerializer {
          static boolean serialized;
          static boolean deserialized;
  
          @Override
          public byte[] serialize(Object obj) {
              serialized = true;
              return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);
          }
  
          @Override
          public Object deserialize(byte[] bytes) {
              deserialized = true;
              return new String(bytes, StandardCharsets.UTF_8);
          }
      }
  
      public static final class RecordingTableEngine implements TableEngine {
          static boolean constructed;
  
          public RecordingTableEngine() {
              constructed = true;
          }
  
          @Override
          public Table createTable(CreateTableData data) {
              throw new UnsupportedOperationException("recording table engine only covers instantiation");
          }
      }
