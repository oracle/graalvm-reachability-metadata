[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/FunctionAliasTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.Statement;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FunctionAliasTest {\n    @Test\n    void loadsAliasClassAndInvokesSelectedMethod() throws SQLException {\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:function-alias\")) {\n            try (Statement statement = connection.createStatement()) {\n                statement.execute(\"CREATE ALIAS ALIAS_PLUS FOR '\" + AliasMethods.class.getName() + \".plus'\");\n                try (ResultSet resultSet = statement.executeQuery(\"SELECT ALIAS_PLUS(20, 22)\")) {\n                    assertThat(resultSet.next()).isTrue();\n                    assertThat(resultSet.getInt(1)).isEqualTo(42);\n                }\n            }\n        }\n    }\n\n    public static final class AliasMethods {\n        public static int plus(int left, int right) {\n            return left + right;\n        }\n    }\n}\n"}
