(cd "$jar_dir" && unzip -q "$tmp/artifact.jar")
git clone --filter=blob:none --no-checkout https://github.com/google/closure-library.git "$git_dir" >/dev/null 2>&1
cd "$git_dir"
commits=$(git log --all --since='"'2011-11-08' --until='2011-11-12 23:59:59' --format='%H')
find \""'$jar_dir/goog" -type f | sed "s#''^$jar_dir/##" | sort > "$tmp/jar-files.txt"
for c in $commits; do
  git ls-tree -r --name-only "$c" third_party/closure/goog 2>/dev/null | sed '"'s#"'^third_party/closure/##'"' | sort > \""'$tmp/git-files.txt"
  common=$(comm -12 "$tmp/jar-files.txt" "$tmp/git-files.txt" | wc -l)
  total=$(wc -l < "$tmp/jar-files.txt")
