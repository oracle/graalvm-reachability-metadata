ts/src/org.codehaus.janino/commons-compiler/3.0.16/src/test/java/org_codehaus_janino/commons_compiler/MethodsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_janino.commons_compiler;\n\nimport org.codehaus.commons.compiler.util.reflect.Classes;\nimport org.codehaus.commons.compiler.util.reflect.Methods;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MethodsTest {\n    @Test\n    void invokesReflectedMethodAndReturnsTypedValue() {\n        InvocationTarget target = new InvocationTarget();\n        Method method = Classes.getDeclaredMethod(InvocationTarget.class, \"formatMessage\", String.class, int.class);\n\n        String result = Methods.invoke(method, target, \"value-\", 42);\n\n        assertThat(result).isEqualTo(\"value-42\");\n        assertThat(target.invocationCount()).isEqualTo(1);\n    }\n\n    public static final class InvocationTarget {\n        private int invocationCount;\n\n        public String formatMessage(String prefix, int value) {\n            this.invocationCount++;\n            return prefix + value;\n        }\n\n        int invocationCount() {\n            return this.invocationCount;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.codehaus.janino/commons-compiler/3.0.16/src/test/java/org_codehaus_janino/commons_compiler/MethodsTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_codehaus_janino.commons_compiler;\\n\\nimport org.codehaus.commons.compiler.util.reflect.Classes;\\nimport org.codehaus.commons.compiler.util.reflect.Methods;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.lang.reflect.Method;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class MethodsTest {\\n    @Test\\n    void invokesReflectedMethodAndReturnsTypedValue() {\\n        InvocationTarget target = new InvocationTarget();\\n        Method method = Classes.getDeclaredMethod(InvocationTarget.class, \\\"formatMessage\\\", String.class, int.class);\\n\\n        String result = Methods.invoke(method, target, \\\"value-\\\", 42);\\n\\n        assertThat(result).isEqualTo(\\\"value-42\\\");\\n        assertThat(target.invocationCount()).isEqualTo(1);\\n    }\\n\\n    public static final class InvocationTarget {\\n        private int invocationCount;\\n\\n        public String formatMessage(String prefix, int value) {\\n            this.invocationCount++;\\n            return prefix + value;\\n        }\\n\\n        int invocationCount() {\\n            return this.invocationCount;\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 735, "output": 768, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25055, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777514708937, "responseId": "resp_037fd05d7d97a4f50169f2b8d5b428819da671ee3f4e8f9ad5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_nz4WguaRgtaQxwwwIkvjBQMU|fc_037fd05d7d97a4f50169f2b8dc7a04819dacad8b9c2c4c12db", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1277 bytes to tests/src/org.codehaus.janino/commons-compiler/3.0.16/src/test/java/org_codehaus_janino/commons_compiler/MethodsTest.java"}], "isError": false, "timestamp": 1777514719189}]}
