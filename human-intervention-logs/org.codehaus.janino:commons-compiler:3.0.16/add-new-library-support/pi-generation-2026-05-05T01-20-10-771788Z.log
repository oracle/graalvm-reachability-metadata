[tool-call] delta {"path":"tests/src/org.codehaus.janino/commons-compiler/3.0.16/src/test/java/org_codehaus_janino/commons_compiler/ProxiesTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_janino.commons_compiler;\n\nimport java.lang.reflect.Method;\n\nimport org.codehaus.commons.compiler.util.reflect.Proxies;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProxiesTest {\n    @Test\n    void createsInterfaceProxyThatDelegatesToConfiguredMethod() throws Exception {\n        GreetingDelegate delegate = new GreetingDelegate(\"Hello\");\n        Method greetingMethod = GreetingService.class.getMethod(\"greeting\", String.class);\n        Method delegateMethod = GreetingDelegate.class.getDeclaredMethod(\"format\", String.class);\n\n        GreetingService proxy = Proxies.newInstance(delegate, greetingMethod, delegateMethod);\n\n        assertThat(proxy.greeting(\"Janino\")).isEqualTo(\"Hello, Janino\");\n    }\n}\n\ninterface GreetingService {\n    String greeting(String name);\n}\n\nfinal class GreetingDelegate {\n    private final String prefix;\n\n    GreetingDelegate(String prefix) {\n        this.prefix = prefix;\n    }\n\n    String format(String name) {\n        return this.prefix + \", \" + name;\n    }\n}\n"}
