  package org_codehaus_janino.commons_compiler;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.codehaus.commons.compiler.samples.DemoBase;
  import org.junit.jupiter.api.Test;
  
  public class DemoBaseTest {
      @Test
      void createsObjectsFromDefaultAndStringConstructors() throws Exception {
          Object emptyBuilder = DemoBase.createObject(StringBuilder.class, "");
          Object initializedBuilder = DemoBase.createObject(StringBuilder.class, "janino");
  
          assertThat(emptyBuilder).isInstanceOf(StringBuilder.class).hasToString("");
          assertThat(initializedBuilder).isInstanceOf(StringBuilder.class).hasToString("janino");
      }
  
      @Test
      void convertsClassNamesToTypes() {
          assertThat(DemoBase.stringToType("java.lang.String")).isSameAs(String.class);
          assertThat(DemoBase.stringToType("int[]")).isSameAs(int[].class);
          assertThat(DemoBase.stringToTypes("java.lang.String,boolean[]"))
              .containsExactly(String.class, boolean[].class);
      }
  }
