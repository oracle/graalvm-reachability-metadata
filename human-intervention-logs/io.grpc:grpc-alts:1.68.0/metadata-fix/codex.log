   \"items\": {\n                  \"type\": \"string\",\n                  \"title\": \"Memory layout definition (allows canonical layouts; see `java.lang.foreign.Linker`)\"\n                },\n                \"type\": \"array\",\n                \"title\": \"List of the function descriptor's parameter types\"\n","exit_code":0,"status":"completed"}}
