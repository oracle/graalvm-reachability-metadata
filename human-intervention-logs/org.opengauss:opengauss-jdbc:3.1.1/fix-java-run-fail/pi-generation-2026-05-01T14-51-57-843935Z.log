                          c2 character varying,
                          d1 date,
                          d2 double precision,
                          i1 integer,
                          j1 json,
                          j2 jsonb,
                          r1 real,
                          s1 smallint,
                          t1 text,
                          t2 time,
                          t3 time with time zone,
                          t4 timestamp,
                          t5 timestamp with time zone,
                          u1 uuid,
                          x1 text,
                          n1 integer
                      )
                      """).execute();
              PreparedStatement statement = connection.prepareStatement("""
                      INSERT INTO simple_datatypes
                      VALUES (?, CAST(? AS bit), ?, ?, ?, ?, ?, ?, ?, CAST(? AS json), CAST(? AS jsonb), ?, ?, ?, ?, ?, ?, ?, ?,
                              CAST(? AS text), ?)
