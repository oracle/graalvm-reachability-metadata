s = new Properties();\n        properties.setProperty(\"xmlFactoryFactory\", Object.class.getName());\n\n        try (Connection connection = openConnection(properties)) {\n            BaseConnection pgConnection = connection.unwrap(BaseConnection.class);\n\n            assertThatThrownBy(pgConnection::getXmlFactoryFactory).isInstanceOf(SQLException.class);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777341653735}}
