   props.setProperty(\"prepareThreshold\", \"-1\");\n        return DriverManager.getConnection(JDBC_URL, props);\n    }\n\n    @BeforeAll\n    static void beforeAll() throws IOException {\n        System.out.println(\"Starting OpenGauss for PgArray tests ...\");\n        process = new ProcessBuilder(\n                \"docker\", \"run\", \"--rm\", \"-p\", \"15433:5432\", \"-e\", \"GS_USERNAME=\" + USERNAME,\n                \"-e\", \"GS_PASSWORD=\" + PASSWORD, \"opengauss/opengauss:5.0.0\")\n                .redirectOutput(new File(\"opengauss-pg-array-stdout.txt\"))\n                .redirectError(new File(\"opengauss-pg-array-stderr.txt\")).start();\n        Awaitility.await().atMost(Duration.ofMinutes(1)).ignoreExceptions().until(() -> {\n            openConnection().close();\n            return true;\n        });\n        System.out.println(\"OpenGauss for PgArray tests started\");\n    }\n\n    @AfterAll\n    static void tearDown() {\n        if (process != null && process.isAlive()) {\n            System.out.println(\"Shutting down OpenGauss for PgArray tests\");\n            process.destroy();\n        }\n    }\n\n    @Test\n    void convertsTextArraysForScalarElementTypes() throws Exception {\n        try (Connection connection = openConnection()) {\n            assertThat((Object[][]) connection.createArrayOf(\"bool\", new Object[][]{{true, false}, {false, true}}).getArray())\n                    .isDeepEqualTo(new Boolean[][]{{true, false}, {false, true}});\n            assertThat((Object[][]) connection.createArrayOf(\"int2\", new Object[][]{{(short) 1, (short) 2}, {(short) 3, null}})\n                    .getArray()).isDeepEqualTo(new Short[][]{{1, 2}, {3, null}});\n            assertThat((Object[][]) connection.createArrayOf(\"int4\", new Object[][]{{1, 2}, {3, 4}}).getArray())\n                    .isDeepEqualTo(new Integer[][]{{1, 2}, {3, 4}});\n            assertThat((Object[][]) connection.createArrayOf(\"int8\", new Object[][]{{1L, 2L}, {3L, 4L}}).getArray())\n                    .isDeepEqualTo(new Long[][]{{1L, 2L}, {3L, 4L}});\n            assertThat((Object[][]) connection.createArrayOf(\"numeric\", new Object[][]{\n                    {new BigDecimal(\"1.25\"), new BigDecimal(\"2.50\")},\n                    {new BigDecimal(\"3.75\"), null}\n            }).getArray()).isDeepEqualTo(new BigDecimal[][]{\n                    {new BigDecimal(\"1.25\"), new BigDecimal(\"2.50\")},\n                    {new BigDecimal(\"3.75\"), null}\n            });\n            assertThat((Object[][]) connection.createArrayOf(\"float4\", new Object[][]{{1.25F, 2.5F}, {3.75F, 4.5F}})\n                    .getArray()).isDeepEqualTo(new Float[][]{{1.25F, 2.5F}, {3.75F, 4.5F}});\n            assertThat((Object[][]) connection.createArrayOf(\"float8\", new Object[][]{{1.25D, 2.5D}, {3.75D, 4.5D}})\n                    .getArray()).isDeepEqualTo(new Double[][]{{1.25D, 2.5D}, {3.75D, 4.5D}});\n            assertThat((Object[][]) connection.createArrayOf(\"text\", new Object[][]{{\"one\", \"two\"}, {\"three\", null}}).getArray())\n                    .isDeepEqualTo(new String[][]{{\"one\", \"two\"}, {\"three\", null}});\n        }\n    }\n\n    @Test\n    void convertsTextArraysForTemporalAndAssistantElementTypes() throws Exception {\n        UUID firstUuid = UUID.fromString(\"00000000-0000-0000-0000-000000000001\");\n        UUID secondUuid = UUID.fromString(\"00000000-0000-0000-0000-000000000002\");\n        UUID thirdUuid = UUID.fromString(\"00000000-0000-0000-0000-000000000003\");\n\n        try (Connection connection = openConnection()) {\n            assertThat((Object[][]) connection.createArrayOf(\"date\", new Object[][]{\n                    {Date.valueOf(\"2024-01-02\"), Date.valueOf(\"2024-01-03\")},\n                    {Date.valueOf(\"2024-01-04\"), null}\n            }).getArray()).isDeepEqualTo(new Date[][]{\n                    {Date.valueOf(\"2024-01-02\"), Date.valueOf(\"2024-01-03\")},\n                    {Date.valueOf(\"2024-01-04\"), null}\n            });\n            assertThat((Object[][]) connection.createArrayOf(\"time\", new Object[][]{\n                    {Time.valueOf(\"01:02:03\"), Time.valueOf(\"04:05:06\")},\n                    {Time.valueOf(\"07:08:09\"), null}\n            }).getArray()).isDeepEqualTo(new Time[][]{\n                    {Time.valueOf(\"01:02:03\"), Time.valueOf(\"04:05:06\")},\n                    {Time.valueOf(\"07:08:09\"), null}\n            });\n            assertThat((Object[][]) connection.createArrayOf(\"timestamp\", new Object[][]{\n                    {Timestamp.valueOf(\"2024-01-02 03:04:05\"), Timestamp.valueOf(\"2024-01-03 04:05:06\")},\n                    {Timestamp.valueOf(\"2024-01-04 05:06:07\"), null}\n            }).getArray()).isDeepEqualTo(new Timestamp[][]{\n                    {Timestamp.valueOf(\"2024-01-02 03:04:05\"), Timestamp.valueOf(\"2024-01-03 04:05:06\")},\n                    {Timestamp.valueOf(\"2024-01-04 05:06:07\"), null}\n            });\n            assertThat((Object[][]) connection.createArrayOf(\"uuid\", new Object[][]{\n                    {firstUuid, secondUuid}, {thirdUuid, null}\n            }).getArray()).isDeepEqualTo(new UUID[][]{{firstUuid, secondUuid}, {thirdUuid, null}});\n            assertThat((Object[]) connection.createArrayOf(\"uuid\", new Object[]{firstUuid, secondUuid}).getArray())\n                    .containsExactly(firstUuid, secondUuid);\n        }\n    }\n\n    @Test\n    void readsBinaryArraysFromServerResults() throws Exception {\n        try (Connection connection = openBinaryConnection();\n                PreparedStatement statement = connection.prepareStatement(\n                        \"SELECT ARRAY[]::int4[] AS empty_values, ARRAY[11, 22, 33]::int4[] AS int_values\");\n                ResultSet resultSet = statement.executeQuery()) {\n            assertThat(resultSet.next()).isTrue();\n            assertThat((Object[]) resultSet.getArray(\"empty_values\").getArray()).isEmpty();\n            assertThat((Object[]) resultSet.getArray(\"int_values\").getArray()).containsExactly(11, 22, 33);\n            assertThat(resultSet.next()).isFalse();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777341373674}}
