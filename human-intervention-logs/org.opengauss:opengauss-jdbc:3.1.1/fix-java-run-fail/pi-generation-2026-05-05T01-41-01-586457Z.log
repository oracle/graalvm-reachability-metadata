              int localPort = serverSocket.getLocalPort();
              assertThat(localPort).isGreaterThan(0);
              return localPort;
          }
      }
  
      private static String readProcessError() throws IOException {
          return Files.exists(STDERR) ? Files.readString(STDERR) : "";
      }
  
