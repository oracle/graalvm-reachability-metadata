[tool-call] delta {"path":"tests/src/org.opengauss/opengauss-jdbc/3.1.1/src/test/java/org_opengauss/opengauss_jdbc/TimestampUtilsDynamicAccessTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_opengauss.opengauss_jdbc;\n\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.Test;\nimport org.postgresql.jdbc.TimestampUtils;\n\nimport java.sql.Date;\nimport java.time.LocalDate;\nimport java.util.TimeZone;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TimestampUtilsDynamicAccessTest {\n    private static final String ORIGINAL_JAVA_VERSION = System.getProperty(\"java.version\");\n    private static final TimeZone ORIGINAL_TIME_ZONE = TimeZone.getDefault();\n    private static final TimeZone UTC = TimeZone.getTimeZone(\"UTC\");\n\n    static {\n        System.setProperty(\"java.version\", \"1.8.0\");\n        TimeZone.setDefault(UTC);\n    }\n\n    @AfterAll\n    static void restoreSystemProperties() {\n        System.setProperty(\"java.version\", ORIGINAL_JAVA_VERSION);\n        TimeZone.setDefault(ORIGINAL_TIME_ZONE);\n    }\n\n    @Test\n    void readsDefaultTimeZoneThroughTimestampUtilsFastPath() throws Exception {\n        TimestampUtils timestampUtils = new TimestampUtils(false, TimeZone::getDefault);\n\n        assertThat(timestampUtils.hasFastDefaultTimeZone()).isTrue();\n\n        Date epochDate = timestampUtils.toDateBin(null, new byte[] {0, 0, 0, 0});\n        Date followingDate = timestampUtils.toDateBin(null, new byte[] {0, 0, 0, 1});\n\n        assertThat(epochDate.toLocalDate()).isEqualTo(LocalDate.of(2000, 1, 1));\n        assertThat(followingDate.toLocalDate()).isEqualTo(LocalDate.of(2000, 1, 2));\n    }\n}\n"}
