  package org_opengauss.opengauss_jdbc;
  
  import org.junit.jupiter.api.Test;
  import org.postgresql.ssl.SingleCertValidatingFactory;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SingleCertValidatingFactoryTest {
      private static final String CERTIFICATE_RESOURCE = "org_opengauss/opengauss_jdbc/"
              + "single-cert-validating-factory.crt";
  
      @Test
      void loadsPinnedServerCertificateFromClasspathResource() throws Exception {
          SingleCertValidatingFactory factory = new SingleCertValidatingFactory("classpath:" + CERTIFICATE_RESOURCE);
  
          assertThat(factory.getDefaultCipherSuites()).isNotEmpty();
          assertThat(factory.getSupportedCipherSuites()).contains(factory.getDefaultCipherSuites());
      }
  }
