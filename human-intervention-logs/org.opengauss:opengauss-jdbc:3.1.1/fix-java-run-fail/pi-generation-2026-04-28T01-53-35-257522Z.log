[tool-call] delta {"path":"tests/src/org.opengauss/opengauss-jdbc/3.1.1/src/test/java/org_opengauss/opengauss_jdbc/ObjectFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_opengauss.opengauss_jdbc;\n\nimport org.junit.jupiter.api.Test;\nimport org.postgresql.ssl.DefaultJavaSSLFactory;\nimport org.postgresql.ssl.NonValidatingFactory;\nimport org.postgresql.util.ObjectFactory;\nimport org.postgresql.util.PGobject;\n\nimport java.util.Properties;\n\nimport javax.net.ssl.SSLSocketFactory;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectFactoryTest {\n    @Test\n    void instantiatesClassUsingPropertiesConstructor() throws Exception {\n        SSLSocketFactory factory = ObjectFactory.instantiate(SSLSocketFactory.class,\n                DefaultJavaSSLFactory.class.getName(), new Properties(), true, \"ignored\");\n\n        assertThat(factory).isInstanceOf(DefaultJavaSSLFactory.class);\n        assertThat(factory.getDefaultCipherSuites()).isNotEmpty();\n    }\n\n    @Test\n    void fallsBackToStringConstructorWhenPropertiesConstructorIsUnavailable() throws Exception {\n        SSLSocketFactory factory = ObjectFactory.instantiate(SSLSocketFactory.class,\n                NonValidatingFactory.class.getName(), new Properties(), true, \"unused SSL factory argument\");\n\n        assertThat(factory).isInstanceOf(NonValidatingFactory.class);\n        assertThat(factory.getSupportedCipherSuites()).isNotEmpty();\n    }\n\n    @Test\n    void fallsBackToNoArgumentConstructorWhenStringConstructorIsNotRequested() throws Exception {\n        PGobject pgObject = ObjectFactory.instantiate(PGobject.class,\n                PGobject.class.getName(), new Properties(), false, \"ignored\");\n\n        assertThat(pgObject.getType()).isNull();\n        assertThat(pgObject.getValue()).isNull();\n    }\n}\n"}
