  package org_opengauss.opengauss_jdbc;
  
  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.postgresql.jdbc.TimestampUtils;
  
  import java.sql.Date;
  import java.time.LocalDate;
  import java.util.TimeZone;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @Order(1)
  public class TimestampUtilsDynamicAccessTest {
      private static final TimeZone UTC = TimeZone.getTimeZone("UTC");
  
      static {
          System.setProperty("java.version", "1.8.0");
          TimeZone.setDefault(UTC);
      }
  
      @Test
      void readsDefaultTimeZoneThroughTimestampUtilsFastPath() throws Exception {
          TimestampUtils timestampUtils = new TimestampUtils(false, TimeZone::getDefault);
  
          assertThat(timestampUtils.hasFastDefaultTimeZone()).isTrue();
  
          Date epochDate = timestampUtils.toDateBin(null, new byte[] {0, 0, 0, 0});
          Date followingDate = timestampUtils.toDateBin(null, new byte[] {0, 0, 0, 1});
  
          assertThat(epochDate.toLocalDate()).isEqualTo(LocalDate.of(2000, 1, 1));
          assertThat(followingDate.toLocalDate()).isEqualTo(LocalDate.of(2000, 1, 2));
      }
  }
