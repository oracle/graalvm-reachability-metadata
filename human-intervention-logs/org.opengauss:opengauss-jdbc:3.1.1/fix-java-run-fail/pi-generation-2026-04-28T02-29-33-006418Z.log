  package org_opengauss.opengauss_jdbc;
  
  import org.junit.jupiter.api.Test;
  import org.postgresql.core.Parser;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ParserTest {
      @Test
      void replacesKnownJdbcEscapeFunction() throws Exception {
          String rewrittenSql = Parser.replaceProcessing("select {fn lcase('OPEN')}", true, true);
  
          assertThat(rewrittenSql).isEqualTo("select lower('OPEN')");
      }
  }
