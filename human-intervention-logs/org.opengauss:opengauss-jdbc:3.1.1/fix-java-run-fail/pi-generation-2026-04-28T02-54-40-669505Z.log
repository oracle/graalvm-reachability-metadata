      @Test
      void readsBinaryArraysFromServerResults() throws Exception {
          try (Connection connection = openBinaryConnection();
                  PreparedStatement statement = connection.prepareStatement(
                          "SELECT ARRAY[]::int4[] AS empty_values, ARRAY[11, 22, 33]::int4[] AS int_values");
                  ResultSet resultSet = statement.executeQuery()) {
              assertThat(resultSet.next()).isTrue();
              assertThat((Object[]) resultSet.getArray("empty_values").getArray()).isEmpty();
