  +package org_opengauss.opengauss_jdbc;
  +
  +import org.junit.jupiter.api.Test;
  +import org.postgresql.jdbc.EscapedFunctions;
  +
  +import java.util.List;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +@SuppressWarnings("deprecation")
  +public class EscapedFunctionsTest {
  +    @Test
  +    void findsEscapedFunctionImplementationsByJdbcFunctionName() {
  +        assertThat(EscapedFunctions.getFunction("lcase")).isNotNull();
  +        assertThat(EscapedFunctions.getFunction("POWER")).isNotNull();
  +        assertThat(EscapedFunctions.getFunction("not_a_function")).isNull();
  +    }
  +
  +    @Test
  +    void translatesEscapedFunctions() throws Exception {
  +        assertThat(EscapedFunctions.sqllcase(List.of("'OPEN'"))).isEqualTo("lower('OPEN')");
  +        assertThat(EscapedFunctions.sqlpower(List.of("base", "exponent"))).isEqualTo("pow(base,exponent)");
  +    }
  +}
