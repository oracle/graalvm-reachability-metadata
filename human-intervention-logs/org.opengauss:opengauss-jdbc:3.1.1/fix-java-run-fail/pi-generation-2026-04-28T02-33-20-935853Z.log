  package org_opengauss.opengauss_jdbc;
  
  import org.junit.jupiter.api.Test;
  import org.postgresql.jdbc.EscapedFunctions;
  
  import java.lang.reflect.Method;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @SuppressWarnings("deprecation")
  public class EscapedFunctionsTest {
      @Test
      void findsEscapedFunctionImplementationsByJdbcFunctionName() {
          Method lcaseFunction = EscapedFunctions.getFunction("lcase");
          Method powerFunction = EscapedFunctions.getFunction("POWER");
  
          assertThat(lcaseFunction).isNotNull();
          assertThat(lcaseFunction.getName()).isEqualTo("sqllcase");
          assertThat(powerFunction).isNotNull();
          assertThat(powerFunction.getName()).isEqualTo("sqlpower");
      }
  
      @Test
      void translatesEscapedFunctions() throws Exception {
          assertThat(EscapedFunctions.sqllcase(List.of("'OPEN'"))).isEqualTo("lower('OPEN')");
          assertThat(EscapedFunctions.sqlpower(List.of("base", "exponent"))).isEqualTo("pow(base,exponent)");
      }
  }
