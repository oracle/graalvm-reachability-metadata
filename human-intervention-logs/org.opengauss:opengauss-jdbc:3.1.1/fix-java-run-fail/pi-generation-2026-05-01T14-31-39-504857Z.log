rg.postgresql.core.types.PGBlob;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PGBlobOutputStreamTest {\n    @Test\n    void writesThroughPrimitiveByteBufferCreatedByConstructor() throws Exception {\n        PGBlob blob = new PGBlob();\n        PGBlobOutputStream output = new PGBlobOutputStream(blob, 2);\n\n        output.write(1);\n        output.write(2);\n\n        assertThat(blob.length()).isZero();\n\n        output.write(3);\n\n        assertThat(blob.length()).isEqualTo(2L);\n        assertThat(blob.getBytes(1, 2)).containsExactly((byte) 1, (byte) 2);\n\n        output.write(new byte[]{4, 5, 6, 7}, 0, 4);\n\n        assertThat(blob.length()).isEqualTo(7L);\n        assertThat(blob.getBytes(1, 7)).containsExactly(\n                (byte) 1, (byte) 2, (byte) 3, (byte) 4, (byte) 5, (byte) 6, (byte) 7);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 424, "output": 1125, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 17421, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777645880690, "responseId": "resp_0cef2a55163b6def0169f4b9391a84819ca84d47564fd75474"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YaXKZH1yxuFq3lPms4X1LsmO|fc_0cef2a55163b6def0169f4b943bf60819cb1211e847c12769a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1160 bytes to tests/src/org.opengauss/opengauss-jdbc/3.1.1/src/test/java/org_opengauss/opengauss_jdbc/PGBlobOutputStreamTest.java"}], "isError": false, "timestamp": 1777645893875}]}
