eyPairGenerator;\nimport java.security.PrivateKey;\nimport java.security.SecureRandom;\nimport java.security.interfaces.RSAPrivateCrtKey;\n\nimport javax.security.auth.callback.PasswordCallback;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BouncyCastlePrivateKeyFactoryTest {\n    @Test\n    void decryptsEncryptedPkcs8PrivateKeyWithBouncyCastle() throws Exception {\n        char[] password = \"bouncy-castle-password\".toCharArray();\n        KeyPair keyPair = generateRsaKeyPair();\n        byte[] encryptedPrivateKey = encryptPrivateKey(keyPair.getPrivate(), password);\n\n        PasswordCallback passwordCallback = new PasswordCallback(\"private key password\", false);\n        passwordCallback.setPassword(password);\n\n        PrivateKey decryptedPrivateKey = new BouncyCastlePrivateKeyFactory()\n                .getPrivateKeyFromEncryptedKey(encryptedPrivateKey, passwordCallback);\n\n        assertThat(decryptedPrivateKey).isInstanceOf(RSAPrivateCrtKey.class);\n        RSAPrivateCrtKey originalRsaKey = (RSAPrivateCrtKey) keyPair.getPrivate();\n        RSAPrivateCrtKey decryptedRsaKey = (RSAPrivateCrtKey) decryptedPrivateKey;\n        assertThat(decryptedRsaKey.getModulus()).isEqualTo(originalRsaKey.getModulus());\n        assertThat(decryptedRsaKey.getPrivateExponent()).isEqualTo(originalRsaKey.getPrivateExponent());\n    }\n\n    private static KeyPair generateRsaKeyPair() throws Exception {\n        KeyPairGenerator generator = KeyPairGenerator.getInstance(\"RSA\");\n        generator.initialize(2048);\n        return generator.generateKeyPair();\n    }\n\n    private static byte[] encryptPrivateKey(PrivateKey privateKey, char[] password) throws Exception {\n        OutputEncryptor encryptor = new JceOpenSSLPKCS8EncryptorBuilder(PKCS8Generator.AES_256_CBC)\n                .setRandom(new SecureRandom())\n                .setPassword(password)\n                .build();\n        PemObject pemObject = new JcaPKCS8Generator(privateKey, 