r = new RecordingStatementHandler();\n        Connection physicalConnection = newPhysicalConnection(statementHandler);\n        PGPooledConnection pooledConnection = new PGPooledConnection(physicalConnection, true);\n        Method notifyMethod = Object.class.getMethod(\"notify\");\n\n        try (Connection connection = pooledConnection.getConnection(); Statement statement = connection.createStatement()) {\n            InvocationHandler proxyHandler = Proxy.getInvocationHandler(statement);\n\n            assertThatThrownBy(() -> proxyHandler.invoke(statement, notifyMethod, null))\n                    .isInstanceOf(InvocationTargetException.class)\n                    .hasCauseInstanceOf(IllegalMonitorStateException.class);\n        }\n    }\n\n    private static Connection newPhysicalConnection(RecordingStatementHandler statementHandler) {\n        ConnectionHandler connectionHandler = new ConnectionHandler(newPhysicalStatement(statementHandler));\n        return (Connection) Proxy.newProxyInstance(\n                PGPooledConnectionInnerStatementHandlerTest.class.getClassLoader(),\n                new Class<?>[]{Connection.class}, connectionHandler);\n    }\n\n    private static Statement newPhysicalStatement(RecordingStatementHandler statementHandler) {\n        return (Statement) Proxy.newProxyInstance(\n                PGPooledConnectionInnerStatementHandlerTest.class.getClassLoader(),\n                new Class<?>[]{Statement.class}, statementHandler);\n    }\n\n    private static final class ConnectionHandler implements InvocationHandler {\n        private final Statement statement;\n        private boolean closed;\n        private boolean autoCommit;\n\n        private ConnectionHandler(Statement statement) {\n            this.statement = statement;\n        }\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) {\n            String methodName = method.getName();\n            if (method.getDeclaringClass() == Objec