48, "cacheRead": 7680, "cacheWrite": 0, "totalTokens": 34930, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777946109105, "responseId": "resp_0aab0eaf7a8557890169f94dfe0bcc81909a227cd153472c1c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FQ7rx6kYNRghoAWDU4UlgPw9|fc_0aab0eaf7a8557890169f94e041a488190baa9a1e9449d661c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_opengauss.opengauss_jdbc;\n\nimport org.awaitility.Awaitility;\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\nimport org.postgresql.core.BaseConnection;\nimport org.postgresql.core.Oid;\nimport org.postgresql.jdbc.PgArray;\n\nimport java.io.IOException;\nimport java.math.BigDecimal;\nimport java.net.ServerSocket;\nimport java.nio.ByteBuffer;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.SQLException;\nimport java.sql.Time;\nimport java.sql.Timestamp;\nimport java.time.Duration;\nimport java.util.Properties;\nimport java.util.UUID;\nimport java.util.concurrent.TimeUnit;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PgArrayTest {\n    private static final String USERNAME = \"fred\";\n    private static final String PASSWORD = \"Secretpassword@123\";\n    private static final String DATABASE = \"postgres\";\n    private static final Path STDOUT = Path.of(\"pg-array-opengauss-stdout.txt\");\n    private static final Path STDERR = Path.of(\"pg-array-opengauss-stderr.txt\");\n\n    private static int port;\n    private static Process process;\n\n    @BeforeAll\n    static void beforeAll() throws IOException {\n        port = findAvailablePort();\n        process = new ProcessBuilder(\n                \"docker\", \"run\", \"--rm\", \"-p\", \"127.0.0.1:\" + port + \":5432\", \"-e\", \"GS_USERNAME=\" + USERNAME,\n                \"-e\", \"GS_PASSWORD=\" + PASSWORD, \"opengauss/opengauss:5.0.0\")\n                .redirectOutput(STDOUT.toFile()).redirectError(STDERR.toFile()).start();\n        Awaitility.await().atMost(Duration.ofSeconds(45)).pollInterval(Duration.ofSeconds(1)).until(() -> {\n            if (!process.isAlive()) {\n                throw new IllegalStateException(\"OpenGauss container exited early:\\n\" + readProcessError());\n            }\n            try (Connection ignored = openConnection()) {\n                return true;\n            } catch (SQLException e) {\n                return false;\n            }\n        });\n    }\n\n    @AfterAll\n    static void tearDown() {\n        if (process != null && process.isAlive()) {\n            process.destroy();\n            try {\n                if (!process.waitFor(10, TimeUnit.SECONDS)) {\n                    process.destroyForcibly();\n                }\n            } catch (InterruptedException e) {\n                Thread.currentThread().interrupt();\n                process.destroyForcibly();\n            }\n        }\n    }\n\n    @Test\n    void getArrayBuildsMultiDimensionalArraysForSupportedTextTypes() throws Exception {\n        try (Connection connection = openConnection()) {\n            BaseConnection baseConnection = (BaseConnection) connection;\n\n            assertThat(decodeTextArray(baseConnection, Oid.BOOL_ARRAY, \"{{true,false},{true,NULL}}\"))\n                    .isDeepEqualTo(new Boolean[][] { { true, false }, { true, null } });\n            assertThat(decodeTextArray(baseConnection, Oid.INT2_ARRAY, \"{{1,2},{3,4}}\"))\n                    .isDeepEqualTo(new Short[][] { { (short) 1, (short) 2 }, { (short) 3, (short) 4 } });\n            assertThat(decodeTextArray(baseConnection, Oid.INT4_ARRAY, \"{{1,2},{3,4}}\"))\n                    .isDeepEqualTo(new Integer[][] { { 1, 2 }, { 3, 4 } });\n            assertThat(decodeTextArray(baseConnection, Oid.INT8_ARRAY, \"{{1,2},{3,4}}\"))\n                    .isDeepEqualTo(new Long[][] { { 1L, 2L }, { 3L, 4L } });\n            assertThat(decodeTextArray(baseConnection, Oid.NUMERIC_ARRAY, \"{{1.25,2.50},{3.75,4.00}}\"))\n                    .isDeepEqualTo(new BigDecimal[][] {\n                            { new BigDecimal(\"1.25\"), new BigDecimal(\"2.50\") },\n                            { new BigDecimal(\"3.75\"), new BigDecimal(\"4.00\") }\n                    });\n            assertThat(decodeTextArray(baseConnection, Oid.FLOAT4_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"))\n                    .isDeepEqualTo(new Float[][] { { 1.5F, 2.5F }, { 3.5F, 4.5F } });\n            assertThat(decodeTextArray(baseConnection, Oid.FLOAT8_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"))\n                    .isDeepEqualTo(new Double[][] { { 1.5D, 2.5D }, { 3.5D, 4.5D } });\n            assertThat(decodeTextArray(baseConnection, Oid.VARCHAR_ARRAY, \"{{alpha,beta},{gamma,delta}}\"))\n                    .isDeepEqualTo(new String[][] { { \"alpha\", \"beta\" }, { \"gamma\", \"delta\" } });\n            assertThat(decodeTextArray(baseConnection, Oid.DATE_ARRAY, \"{{2020-01-02,2020-01-03},{2020-01-04,2020-01-05}}\"))\n                    .isDeepEqualTo(new java.sql.Date[][] {\n                            { java.sql.Date.valueOf(\"2020-01-02\"), java.sql.Date.valueOf(\"2020-01-03\") },\n                            { java.sql.Date.valueOf(\"2020-01-04\"), java.sql.Date.valueOf(\"2020-01-05\") }\n                    });\n            assertThat(decodeTextArray(baseConnection, Oid.TIME_ARRAY, \"{{12:34:56,13:34:56},{14:34:56,15:34:56}}\"))\n                    .isDeepEqualTo(new Time[][] {\n                            { Time.valueOf(\"12:34:56\"), Time.valueOf(\"13:34:56\") },\n                            { Time.valueOf(\"14:34:56\"), Time.valueOf(\"15:34:56\") }\n                    });\n            assertThat(decodeTextArray(baseConnection, Oid.TIMESTAMP_ARRAY,\n                    \"{{\\\"2020-01-02 12:34:56\\\",\\\"2020-01-03 13:34:56\\\"},\"\n                            + \"{\\\"2020-01-04 14:34:56\\\",\\\"2020-01-05 15:34:56\\\"}}\"))\n                    .isDeepEqualTo(new Timestamp[][] {\n                            { Timestamp.valueOf(\"2020-01-02 12:34:56\"), Timestamp.valueOf(\"2020-01-03 13:34:56\") },\n                            { Timestamp.valueOf(\"2020-01-04 14:34:56\"), Timestamp.valueOf(\"2020-01-05 15:34:56\") }\n                    });\n        }\n    }\n\n    @Test\n    void getArrayBuildsUuidArraysWithArrayAssistant() throws Exception {\n        UUID first = UUID.fromString(\"00000000-0000-0000-0000-000000000001\");\n        UUID second = UUID.fromString(\"00000000-0000-0000-0000-000000000002\");\n        UUID third = UUID.fromString(\"00000000-0000-0000-0000-000000000003\");\n        UUID fourth = UUID.fromString(\"00000000-0000-0000-0000-000000000004\");\n\n        try (Connection connection = openConnection()) {\n            BaseConnection baseConnection = (BaseConnection) connection;\n\n            assertThat((UUID[]) decodeTextArray(baseConnection, Oid.UUID_ARRAY,\n                    \"{00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002}\"))\n                    .containsExactly(first, second);\n            assertThat((UUID[][]) decodeTextArray(baseConnection, Oid.UUID_ARRAY,\n                    \"{{00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002},\"\n                            + \"{00000000-0000-0000-0000-000000000003,00000000-0000-0000-0000-000000000004}}\"))\n                    .isDeepEqualTo(new UUID[][] { { first, second }, { third, fourth } });\n        }\n    }\n\n    @Test\n    void getArrayReadsBinaryArrays() throws Exception {\n        try (Connection connection = openConnection()) {\n            BaseConnection baseConnection = (BaseConnection) connection;\n\n            assertThat((Integer[]) decodeBinaryArray(baseConnection, Oid.INT4_ARRAY, binaryIntArray(new int[0])))\n                    .isEmpty();\n            assertThat((Integer[][]) decodeBinaryArray(baseConnection, Oid.INT4_ARRAY,\n                    binaryIntArray(new int[] { 2, 2 }, 1, 2, 3, 4)))\n                    .isDeepEqualTo(new Integer[][] { { 1, 2 }, { 3, 4 } });\n        }\n    }\n\n    private static Object decodeTextArray(BaseConnection connection, int oid, String value) throws SQLException {\n        PgArray array = new PgArray(connection, oid, value);\n        try {\n            return array.getArray();\n        } finally {\n            array.free();\n        }\n    }\n\n    private static Object decodeBinaryArray(BaseConnection connection, int oid, byte[] value) throws SQLException {\n        PgArray array = new PgArray(connection, oid, value);\n        try {\n            return array.getArray();\n        } finally {\n            array.free();\n        }\n    }\n\n    private static byte[] binaryIntArray(int[] dimensions, int... values) {\n        ByteBuffer buffer = ByteBuffer.allocate(12 + dimensions.length * 8 + values.length * 8);\n        buffer.putInt(dimensions.length);\n        buffer.putInt(0);\n        buffer.putInt(Oid.INT4);\n        for (int dimension : dimensions) {\n            buffer.putInt(dimension);\n            buffer.putInt(1);\n        }\n        for (int value : values) {\n            buffer.putInt(Integer.BYTES);\n            buffer.putInt(value);\n        }\n        return buffer.array();\n    }\n\n    private static Connection openConnection() throws SQLException {\n        Properties props = new Properties();\n        props.setProperty(\"user\", USERNAME);\n        props.setProperty(\"password\", PASSWORD);\n        props.setProperty(\"connectTimeout\", \"2\");\n        props.setProperty(\"socketTimeoutInConnecting\", \"2\");\n        return DriverManager.getConnection(\"jdbc:postgresql://localhost:\" + port + \"/\" + DATABASE, props);\n    }\n\n    private static int findAvailablePort() throws IOException {\n        try (ServerSocket serverSocket = new ServerSocket(0)) {\n            assertThat(serverSocket).isNotNull();\n            int localPort = serverSocket.getLocalPort();\n            assertThat(localPort).isGreaterThan(0);\n            return localPort;\n        }\n    }\n\n    private static String readProcessError() throws IOException {\n        return Files.exists(STDERR) ? Files.readString(STDERR) : \"\";\n    }\n}\n"}], "isError": false, "timestamp": 1777946116536}]}
