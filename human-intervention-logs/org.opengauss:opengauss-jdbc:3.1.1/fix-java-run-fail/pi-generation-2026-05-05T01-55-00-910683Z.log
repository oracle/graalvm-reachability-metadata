      @Test
      void getArrayBuildsMultiDimensionalArraysForSupportedTextTypes() throws Exception {
          try (Connection connection = openConnection()) {
              BaseConnection baseConnection = (BaseConnection) connection;
  
              assertDeepArrayEquals(new Boolean[][] { { true, false }, { true, null } },
                      decodeTextArray(baseConnection, Oid.BOOL_ARRAY, "{{true,false},{true,NULL}}"));
              assertDeepArrayEquals(new Short[][] { { (short) 1, (short) 2 }, { (short) 3, (short) 4 } },
                      decodeTextArray(baseConnection, Oid.INT2_ARRAY, "{{1,2},{3,4}}"));
              assertDeepArrayEquals(new Integer[][] { { 1, 2 }, { 3, 4 } },
                      decodeTextArray(baseConnection, Oid.INT4_ARRAY, "{{1,2},{3,4}}"));
              assertDeepArrayEquals(new Long[][] { { 1L, 2L }, { 3L, 4L } },
                      decodeTextArray(baseConnection, Oid.INT8_ARRAY, "{{1,2},{3,4}}"));
              assertDeepArrayEquals(new BigDecimal[][] {
                      { new BigDecimal("1.25"), new BigDecimal("2.50") },
                      { new BigDecimal("3.75"), new BigDecimal("4.00") }
              }, decodeTextArray(baseConnection, Oid.NUMERIC_ARRAY, "{{1.25,2.50},{3.75,4.00}}"));
              assertDeepArrayEquals(new Float[][] { { 1.5F, 2.5F }, { 3.5F, 4.5F } },
                      decodeTextArray(baseConnection, Oid.FLOAT4_ARRAY, "{{1.5,2.5},{3.5,4.5}}"));
