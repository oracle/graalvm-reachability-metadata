      @Test
      void decryptsOpenSslPkcs8PrivateKey() throws Exception {
          char[] password = PASSWORD.toCharArray();
          PasswordCallback passwordCallback = new PasswordCallback("SSL key password", false);
          passwordCallback.setPassword(password);
          try {
              BouncyCastlePrivateKeyFactory factory = new BouncyCastlePrivateKeyFactory();
              PrivateKey privateKey = factory.getPrivateKeyFromEncryptedKey(encryptedPrivateKey(), passwordCallback);
  
              assertThat(privateKey).isNotNull();
              assertThat(privateKey.getAlgorithm()).isEqualTo("RSA");
              assertThat(privateKey.getFormat()).isEqualTo("PKCS#8");
              assertThat(privateKey.getEncoded()).isNotEmpty();
          } finally {
              passwordCallback.clearPassword();
              Arrays.fill(password, '\0');
          }
      }
  
      private static byte[] encryptedPrivateKey() {
          return Base64.getMimeDecoder().decode(ENCRYPTED_PKCS8_PRIVATE_KEY);
