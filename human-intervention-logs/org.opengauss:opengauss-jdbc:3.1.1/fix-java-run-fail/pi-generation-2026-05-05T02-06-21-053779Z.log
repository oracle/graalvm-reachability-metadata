  public class Opengauss_jdbcTest {
      private static final String USERNAME = "fred";
      private static final String PASSWORD = "Secretpassword@123";
      private static final String DATABASE = "postgres";
      private static final Path STDOUT = Path.of("opengauss-stdout.txt");
      private static final Path STDERR = Path.of("opengauss-stderr.txt");
      private static int port;
      private static Process process;
  
      private static String jdbcUrl() {
          return "jdbc:postgresql://localhost:%d/%s".formatted(port, DATABASE);
      }
  
      private static Connection openConnection() throws SQLException {
          Properties props = new Properties();
          props.setProperty("user", USERNAME);
          props.setProperty("password", PASSWORD);
          props.setProperty("connectTimeout", "2");
          props.setProperty("socketTimeoutInConnecting", "2");
          return DriverManager.getConnection(jdbcUrl(), props);
      }
  
      @BeforeAll
      static void beforeAll() throws IOException {
          port = findAvailablePort();
          System.out.println("Starting OpenGauss on port " + port + " ...");
          process = new ProcessBuilder(
                  "docker", "run", "--rm", "-p", "127.0.0.1:" + port + ":5432", "-e", "GS_USERNAME=" + USERNAME,
                  "-e", "GS_PASSWORD=" + PASSWORD, "opengauss/opengauss:5.0.0")
                  .redirectOutput(STDOUT.toFile()).redirectError(STDERR.toFile()).start();
          Awaitility.await().atMost(Duration.ofSeconds(45)).pollInterval(Duration.ofSeconds(1)).until(() -> {
              if (!process.isAlive()) {
                  throw new IllegalStateException("OpenGauss container exited early:\n" + readProcessError());
              }
              try (Connection ignored = openConnection()) {
                  return true;
              } catch (SQLException e) {
                  return false;
              }
          });
          System.out.println("OpenGauss started");
      }
  
      private static int findAvailablePort() throws IOException {
          try (ServerSocket serverSocket = new ServerSocket(0)) {
              assertThat(serverSocket).isNotNull();
              int localPort = serverSocket.getLocalPort();
              assertThat(localPort).isGreaterThan(0);
              return localPort;
          }
      }
  
      private static String readProcessError() throws IOException {
          return Files.exists(STDERR) ? Files.readString(STDERR) : "";
      }
  
      @AfterAll
      static void tearDown() {
          if (process != null && process.isAlive()) {
              System.out.println("Shutting down OpenGauss");
              process.destroy();
              try {
                  if (!process.waitFor(10, TimeUnit.SECONDS)) {
                      process.destroyForcibly();
                  }
              } catch (InterruptedException e) {
                  Thread.currentThread().interrupt();
                  process.destroyForcibly();
              }
          }
      }
  
