  package org_opengauss.opengauss_jdbc;
  
  import org.junit.jupiter.api.Test;
  import org.postgresql.ssl.DefaultJavaSSLFactory;
  import org.postgresql.ssl.NonValidatingFactory;
  import org.postgresql.util.ObjectFactory;
  import org.postgresql.util.PGobject;
  
  import java.util.Properties;
  
  import javax.net.ssl.SSLSocketFactory;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ObjectFactoryTest {
      @Test
      void instantiatesClassUsingPropertiesConstructor() throws Exception {
          SSLSocketFactory factory = ObjectFactory.instantiate(SSLSocketFactory.class,
                  DefaultJavaSSLFactory.class.getName(), new Properties(), true, "ignored");
  
          assertThat(factory).isInstanceOf(DefaultJavaSSLFactory.class);
          assertThat(factory.getDefaultCipherSuites()).isNotEmpty();
      }
  
      @Test
      void fallsBackToStringConstructorWhenPropertiesConstructorIsUnavailable() throws Exception {
          SSLSocketFactory factory = ObjectFactory.instantiate(SSLSocketFactory.class,
                  NonValidatingFactory.class.getName(), new Properties(), true, "unused SSL factory argument");
  
          assertThat(factory).isInstanceOf(NonValidatingFactory.class);
          assertThat(factory.getSupportedCipherSuites()).isNotEmpty();
      }
  
      @Test
      void fallsBackToNoArgumentConstructorWhenStringConstructorIsNotRequested() throws Exception {
          PGobject pgObject = ObjectFactory.instantiate(PGobject.class,
                  PGobject.class.getName(), new Properties(), false, "ignored");
  
          assertThat(pgObject.getType()).isNull();
          assertThat(pgObject.getValue()).isNull();
      }
  }
