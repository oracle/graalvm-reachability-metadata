[tool-call] delta {"path":"tests/src/org.opengauss/opengauss-jdbc/3.1.1/src/test/java/org_opengauss/opengauss_jdbc/PgArrayTest.java","edits":[{"oldText":"import static org.assertj.core.api.Assertions.assertThat;","newText":"import static org.junit.jupiter.api.Assertions.assertArrayEquals;"},{"oldText":"        assertThat(textArray(Oid.BOOL_ARRAY, \"{{true,false},{NULL,true}}\"))\n                .isDeepEqualTo(new Boolean[][]{{true, false}, {null, true}});\n        assertThat(textArray(Oid.INT2_ARRAY, \"{{1,2},{3,4}}\"))\n                .isDeepEqualTo(new Short[][]{{1, 2}, {3, 4}});\n        assertThat(textArray(Oid.INT4_ARRAY, \"{{10,20},{30,40}}\"))\n                .isDeepEqualTo(new Integer[][]{{10, 20}, {30, 40}});\n        assertThat(textArray(Oid.INT8_ARRAY, \"{{100,200},{300,400}}\"))\n                .isDeepEqualTo(new Long[][]{{100L, 200L}, {300L, 400L}});\n        assertThat(textArray(Oid.NUMERIC_ARRAY, \"{{1.25,2.50},{3.75,4.00}}\"))\n                .isDeepEqualTo(new BigDecimal[][]{\n                        {new BigDecimal(\"1.25\"), new BigDecimal(\"2.50\")},\n                        {new BigDecimal(\"3.75\"), new BigDecimal(\"4.00\")}\n                });\n        assertThat(textArray(Oid.FLOAT4_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"))\n                .isDeepEqualTo(new Float[][]{{1.5f, 2.5f}, {3.5f, 4.5f}});\n        assertThat(textArray(Oid.FLOAT8_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"))\n                .isDeepEqualTo(new Double[][]{{1.5d, 2.5d}, {3.5d, 4.5d}});\n        assertThat(textArray(Oid.VARCHAR_ARRAY, \"{{alpha,beta},{gamma,delta}}\"))\n                .isDeepEqualTo(new String[][]{{\"alpha\", \"beta\"}, {\"gamma\", \"delta\"}});\n        assertThat(textArray(Oid.DATE_ARRAY, \"{{2020-01-02,2020-01-03},{2020-01-04,2020-01-05}}\"))\n                .isDeepEqualTo(new Date[][]{\n                        {Date.valueOf(\"2020-01-02\"), Date.valueOf(\"2020-01-03\")},\n                        {Date.valueOf(\"2020-01-04\"), Date.valueOf(\"2020-01-05\")}\n                });\n        assertThat(textArray(Oid.TIME_ARRAY, \"{{12:34:56,13:34:56},{14:34:56,15:34:56}}\"))\n                .isDeepEqualTo(new Time[][]{\n                        {Time.valueOf(\"12:34:56\"), Time.valueOf(\"13:34:56\")},\n                        {Time.valueOf(\"14:34:56\"), Time.valueOf(\"15:34:56\")}\n                });\n        assertThat(textArray(\n                Oid.TIMESTAMP_ARRAY,\n                \"{{\\\"2020-01-02 03:04:05\\\",\\\"2020-01-03 03:04:05\\\"},\"\n                        + \"{\\\"2020-01-04 03:04:05\\\",\\\"2020-01-05 03:04:05\\\"}}\"))\n                .isDeepEqualTo(new Timestamp[][]{\n                        {\n                                Timestamp.valueOf(\"2020-01-02 03:04:05\"),\n                                Timestamp.valueOf(\"2020-01-03 03:04:05\")\n                        },\n                        {\n                                Timestamp.valueOf(\"2020-01-04 03:04:05\"),\n                                Timestamp.valueOf(\"2020-01-05 03:04:05\")\n                        }\n                });","newText":"        assertArrayEquals(\n                new Boolean[][]{{true, false}, {null, true}},\n                (Object[]) textArray(Oid.BOOL_ARRAY, \"{{true,false},{NULL,true}}\"));\n        assertArrayEquals(\n                new Short[][]{{1, 2}, {3, 4}},\n                (Object[]) textArray(Oid.INT2_ARRAY, \"{{1,2},{3,4}}\"));\n        assertArrayEquals(\n                new Integer[][]{{10, 20}, {30, 40}},\n                (Object[]) textArray(Oid.INT4_ARRAY, \"{{10,20},{30,40}}\"));\n        assertArrayEquals(\n                new Long[][]{{100L, 200L}, {300L, 400L}},\n                (Object[]) textArray(Oid.INT8_ARRAY, \"{{100,200},{300,400}}\"));\n        assertArrayEquals(\n                new BigDecimal[][]{\n                        {new BigDecimal(\"1.25\"), new BigDecimal(\"2.50\")},\n                        {new BigDecimal(\"3.75\"), new BigDecimal(\"4.00\")}\n                },\n                (Object[]) textArray(Oid.NUMERIC_ARRAY, \"{{1.25,2.50},{3.75,4.00}}\"));\n        assertArrayEquals(\n                new Float[][]{{1.5f, 2.5f}, {3.5f, 4.5f}},\n                (Object[]) textArray(Oid.FLOAT4_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"));\n        assertArrayEquals(\n                new Double[][]{{1.5d, 2.5d}, {3.5d, 4.5d}},\n                (Object[]) textArray(Oid.FLOAT8_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"));\n        assertArrayEquals(\n                new String[][]{{\"alpha\", \"beta\"}, {\"gamma\", \"delta\"}},\n                (Object[]) textArray(Oid.VARCHAR_ARRAY, \"{{alpha,beta},{gamma,delta}}\"));\n        assertArrayEquals(\n                new Date[][]{\n                        {Date.valueOf(\"2020-01-02\"), Date.valueOf(\"2020-01-03\")},\n                        {Date.valueOf(\"2020-01-04\"), Date.valueOf(\"2020-01-05\")}\n                },\n                (Object[]) textArray(Oid.DATE_ARRAY, \"{{2020-01-02,2020-01-03},{2020-01-04,2020-01-05}}\"));\n        assertArrayEquals(\n                new Time[][]{\n                        {Time.valueOf(\"12:34:56\"), Time.valueOf(\"13:34:56\")},\n                        {Time.valueOf(\"14:34:56\"), Time.valueOf(\"15:34:56\")}\n                },\n                (Object[]) textArray(Oid.TIME_ARRAY, \"{{12:34:56,13:34:56},{14:34:56,15:34:56}}\"));\n        assertArrayEquals(\n                new Timestamp[][]{\n                        {\n                                Timestamp.valueOf(\"2020-01-02 03:04:05\"),\n                                Timestamp.valueOf(\"2020-01-03 03:04:05\")\n                        },\n                        {\n                                Timestamp.valueOf(\"2020-01-04 03:04:05\"),\n                                Timestamp.valueOf(\"2020-01-05 03:04:05\")\n                        }\n                },\n                (Object[]) textArray(\n                        Oid.TIMESTAMP_ARRAY,\n                        \"{{\\\"2020-01-02 03:04:05\\\",\\\"2020-01-03 03:04:05\\\"},\"\n                                + \"{\\\"2020-01-04 03:04:05\\\",\\\"2020-01-05 03:04:05\\\"}}\"));"},{"oldText":"        assertThat(textArray(Oid.UUID_ARRAY, \"{\" + first + \",\" + second + \"}\"))\n                .isDeepEqualTo(new UUID[]{first, second});\n        assertThat(textArray(\n                Oid.UUID_ARRAY,\n                \"{{\" + first + \",\" + second + \"},{\" + third + \",\" + fourth + \"}}\"))\n                .isDeepEqualTo(new UUID[][]{{first, second}, {third, fourth}});","newText":"        assertArrayEquals(\n                new UUID[]{first, second},\n                (Object[]) textArray(Oid.UUID_ARRAY, \"{\" + first + \",\" + second + \"}\"));\n        assertArrayEquals(\n                new UUID[][]{{first, second}, {third, fourth}},\n                (Object[]) textArray(\n                        Oid.UUID_ARRAY,\n                        \"{{\" + first + \",\" + second + \"},{\" + third + \",\" + fourth + \"}}\"));"},{"oldText":"        assertThat(new PgArray(baseConnection, Oid.INT4_ARRAY, emptyBinaryArray(Oid.INT4)).getArray())\n                .isDeepEqualTo(new Integer[0]);\n        assertThat(new PgArray(baseConnection, Oid.INT4_ARRAY, binaryInt4Array(11, 22, 33)).getArray())\n                .isDeepEqualTo(new Integer[]{11, 22, 33});","newText":"        assertArrayEquals(\n                new Integer[0],\n                (Object[]) new PgArray(baseConnection, Oid.INT4_ARRAY, emptyBinaryArray(Oid.INT4)).getArray());\n        assertArrayEquals(\n                new Integer[]{11, 22, 33},\n                (Object[]) new PgArray(baseConnection, Oid.INT4_ARRAY, binaryInt4Array(11, 22, 33)).getArray());"}]}
