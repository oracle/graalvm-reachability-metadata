throws Exception {\n        System.out.println(\"Starting OpenGauss for PgArray coverage ...\");\n        process = new ProcessBuilder(\n                \"docker\", \"run\", \"--rm\", \"-p\", \"15432:5432\", \"-e\", \"GS_USERNAME=\" + USERNAME,\n                \"-e\", \"GS_PASSWORD=\" + PASSWORD, \"opengauss/opengauss:5.0.0\")\n                .redirectOutput(new File(\"opengauss-stdout.txt\"))\n                .redirectError(new File(\"opengauss-stderr.txt\"))\n                .start();\n        Awaitility.await().atMost(Duration.ofMinutes(1)).ignoreExceptions().until(() -> {\n            openConnection().close();\n            return true;\n        });\n        connection = openConnection();\n        baseConnection = connection.unwrap(BaseConnection.class);\n        System.out.println(\"OpenGauss started for PgArray coverage\");\n    }\n\n    @AfterAll\n    static void tearDown() throws SQLException {\n        if (connection != null) {\n            connection.close();\n        }\n        if (process != null && process.isAlive()) {\n            System.out.println(\"Shutting down OpenGauss for PgArray coverage\");\n            process.destroy();\n        }\n    }\n\n    @Test\n    void textArraysCreateTypedMultidimensionalJavaArrays() throws Exception {\n        assertThat(textArray(Oid.BOOL_ARRAY, \"{{true,false},{NULL,true}}\"))\n                .isDeepEqualTo(new Boolean[][]{{true, false}, {null, true}});\n        assertThat(textArray(Oid.INT2_ARRAY, \"{{1,2},{3,4}}\"))\n                .isDeepEqualTo(new Short[][]{{1, 2}, {3, 4}});\n        assertThat(textArray(Oid.INT4_ARRAY, \"{{10,20},{30,40}}\"))\n                .isDeepEqualTo(new Integer[][]{{10, 20}, {30, 40}});\n        assertThat(textArray(Oid.INT8_ARRAY, \"{{100,200},{300,400}}\"))\n                .isDeepEqualTo(new Long[][]{{100L, 200L}, {300L, 400L}});\n        assertThat(textArray(Oid.NUMERIC_ARRAY, \"{{1.25,2.50},{3.75,4.00}}\"))\n                .isDeepEqualTo(new BigDecimal[][]{\n                        {new BigDecimal(\"1.25\"), new BigDecimal(\"2.50\")},\n                        {new BigDecimal(\"3.75\"), new BigDecimal(\"4.00\")}\n                });\n        assertThat(textArray(Oid.FLOAT4_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"))\n                .isDeepEqualTo(new Float[][]{{1.5f, 2.5f}, {3.5f, 4.5f}});\n        assertThat(textArray(Oid.FLOAT8_ARRAY, \"{{1.5,2.5},{3.5,4.5}}\"))\n                .isDeepEqualTo(new Double[][]{{1.5d, 2.5d}, {3.5d, 4.5d}});\n        assertThat(textArray(Oid.VARCHAR_ARRAY, \"{{alpha,beta},{gamma,delta}}\"))\n                .isDeepEqualTo(new String[][]{{\"alpha\", \"beta\"}, {\"gamma\", \"delta\"}});\n        assertThat(textArray(Oid.DATE_ARRAY, \"{{2020-01-02,2020-01-03},{2020-01-04,2020-01-05}}\"))\n                .isDeepEqualTo(new Date[][]{\n                        {Date.valueOf(\"2020-01-02\"), Date.valueOf(\"2020-01-03\")},\n                        {Date.valueOf(\"2020-01-04\"), Date.valueOf(\"2020-01-05\")}\n                });\n        assertThat(textArray(Oid.TIME_ARRAY, \"{{12:34:56,13:34:56},{14:34:56,15:34:56}}\"))\n                .isDeepEqualTo(new Time[][]{\n                        {Time.valueOf(\"12:34:56\"), Time.valueOf(\"13:34:56\")},\n                        {Time.valueOf(\"14:34:56\"), Time.valueOf(\"15:34:56\")}\n                });\n        assertThat(textArray(\n                Oid.TIMESTAMP_ARRAY,\n                \"{{\\\"2020-01-02 03:04:05\\\",\\\"2020-01-03 03:04:05\\\"},\"\n                        + \"{\\\"2020-01-04 03:04:05\\\",\\\"2020-01-05 03:04:05\\\"}}\"))\n                .isDeepEqualTo(new Timestamp[][]{\n                        {Timestamp.valueOf(\"2020-01-02 03:04:05\"), Timestamp.valueOf(\"2020-01-03 03:04:05\")},\n                        {Timestamp.valueOf(\"2020-01-04 03:04:05\"), Timestamp.valueOf(\"2020-01-05 03:04:05\")}\n                });\n    }\n\n    @Test\n    void uuidArraysUseArrayAssistantForOneAndTwoDimensionalArrays() throws Exception {\n        UUID first = UUID.fromString(\"00000000-0000-0000-0000-000000000001\");\n        UUID second = UUID.fromString(\"00000000-0000-0000-0000-000000000002\");\n        UUID third = UUID.fromString(\"00000000-0000-0000-0000-000000000003\");\n        UUID fourth = UUID.fromString(\"00000000-0000-0000-0000-000000000004\");\n\n        assertThat(textArray(Oid.UUID_ARRAY, \"{\" + first + \",\" + second + \"}\"))\n                .isEqualTo(new UUID[]{first, second});\n        assertThat(textArray(Oid.UUID_ARRAY, \"{{\" + first + \",\" + second + \"},{\" + third + \",\" + fourth + \"}}\"))\n                .isDeepEqualTo(new UUID[][]{{first, second}, {third, fourth}});\n    }\n\n    @Test\n    void binaryArraysCreateTypedJavaArrays() throws Exception {\n        assertThat(new PgArray(baseConnection, Oid.INT4_ARRAY, emptyBinaryArray(Oid.INT4)).getArray())\n                .isEqualTo(new Integer[0]);\n        assertThat(new PgArray(baseConnection, Oid.INT4_ARRAY, binaryInt4Array(11, 22, 33)).getArray())\n                .isEqualTo(new Integer[]{11, 22, 33});\n    }\n\n    private static Object textArray(int oid, String literal) throws SQLException {\n        return new PgArray(baseConnection, oid, literal).getArray();\n    }\n\n    private static byte[] emptyBinaryArray(int elementOid) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(bytes);\n        output.writeInt(0);\n        output.writeInt(0);\n        output.writeInt(elementOid);\n        return bytes.toByteArray();\n    }\n\n    private static byte[] binaryInt4Array(int... values) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(bytes);\n        output.writeInt(1);\n        output.writeInt(0);\n        output.writeInt(Oid.INT4);\n        output.writeInt(values.length);\n        output.writeInt(1);\n        for (int value : values) {\n            output.writeInt(Integer.BYTES);\n            output.writeInt(value);\n        }\n        return bytes.toByteArray();\n    }\n}\n"}
