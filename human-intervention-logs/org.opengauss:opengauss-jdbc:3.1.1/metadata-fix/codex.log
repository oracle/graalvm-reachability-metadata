{"type":"item.completed","item":{"id":"item_211","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' /home/vjovanov/c/g/master/ee/vm-enterprise/tests/native-image/security/bouncy-castle/src/main/java/bouncy/castle/test/BouncyCastleFeature.java && printf '\\\\n---TEST---\\\\n' && sed -n '1,220p' /home/vjovanov/c/g/master/ee/vm-enterprise/tests/native-image/security/bouncy-castle/src/main/java/bouncy/castle/test/BouncyCastleTest.java\"","aggregated_output":"package bouncy.castle.test;\n\nimport java.security.Security;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.graalvm.nativeimage.hosted.Feature;\nimport org.graalvm.nativeimage.hosted.RuntimeClassInitialization;\n\npublic class BouncyCastleFeature implements Feature {\n\n\t@Override\n\tpublic void afterRegistration(AfterRegistrationAccess access) {\n\t\t/* Initialize most of Bouncy Castle at build time. */\n\t\tRuntimeClassInitialization.initializeAtBuildTime(\"org.bouncycastle\");\n\t\t/* Initialize classes that use SecureRandom in their initializer at run time. */\n\t\tRuntimeClassInitialization.initializeAtRunTime(\"org.bouncycastle.jcajce.provider.drbg.DRBG$Default\");\n\t\tRuntimeClassInitialization.initializeAtRunTime(\"org.bouncycastle.jcajce.provider.drbg.DRBG$NonceAndIV\");\n\n\t\t/*\n\t\t * Register the BouncyCastleProvider eagerly. This is necessary to discover its\n\t\t * services and register them for dynamic allocation.\n\t\t */\n\t\tSecurity.addProvider(new BouncyCastleProvider());\n\t}\n}\n\n---TEST---\npackage bouncy.castle.test;\n\nimport java.io.ByteArrayInputStream;\nimport java.math.BigInteger;\nimport java.security.*;\nimport java.security.cert.X509Certificate;\nimport java.util.Collection;\nimport java.util.Collections;\nimport java.util.Date;\n\nimport org.bouncycastle.asn1.ASN1InputStream;\nimport org.bouncycastle.asn1.cms.ContentInfo;\nimport org.bouncycastle.asn1.x500.X500Name;\nimport org.bouncycastle.cert.X509CertificateHolder;\nimport org.bouncycastle.cert.X509v1CertificateBuilder;\nimport org.bouncycastle.cert.jcajce.JcaCertStore;\nimport org.bouncycastle.cert.jcajce.JcaX509CertificateConverter;\nimport org.bouncycastle.cert.jcajce.JcaX509v1CertificateBuilder;\nimport org.bouncycastle.cms.*;\nimport org.bouncycastle.cms.jcajce.*;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.operator.ContentSigner;\nimport org.bouncycastle.operator.DigestCalculatorProvider;\nimport org.bouncycastle.operator.OutputEncryptor;\nimport org.bouncycastle.operator.jcajce.JcaContentSignerBuilder;\nimport org.bouncycastle.operator.jcajce.JcaDigestCalculatorProviderBuilder;\nimport org.bouncycastle.util.Store;\n\n/**\n * Test basic functionality for Bouncy Castle provider:\n * <ul>\n * <li>generate an RSA key pair</li>\n * <li>generate a x509 certificate</li>\n * <li>encrypt some data using the certificate</li>\n * <li>decrypt the data using the private key and check the result</li>\n * <li>sign the data using the certificate</li>\n * <li>verify the signed data</li>\n * </ul>\n */\npublic class BouncyCastleTest {\n\n\tpublic static void main(String[] args) throws Exception {\n\t\tSecurity.addProvider(new BouncyCastleProvider());\n\n\t\tKeyPair keyPair = generateRSAKeyPair();\n\t\tX509Certificate certificate = generateX509v1Certificate(keyPair);\n\n\t\tString secretMessage = \"\\\"The quick brown fox jumps over the lazy dog\\\"\";\n\t\tSystem.out.println(\"Message to encode: \" + secretMessage);\n\n\t\tbyte[] dataToEncrypt = secretMessage.getBytes();\n\t\tbyte[] encryptedData = encryptData(dataToEncrypt, certificate);\n\t\tbyte[] decryptedData = decryptData(encryptedData, keyPair.getPrivate());\n\t\tString decryptedMessage = new String(decryptedData);\n\t\tassertTrue(\"Decrypted message \" + decryptedMessage + \" not equal \" + secretMessage,\n\t\t\t\tdecryptedMessage.equals(secretMessage));\n\n\t\tbyte[] signedData = signData(decryptedData, certificate, keyPair.getPrivate());\n\t\tboolean result = verifySignedData(signedData);\n\t\tassertTrue(\"Signed data verification failed\", result);\n\t}\n\n\tprivate static byte[] encryptData(final byte[] data, X509Certificate encryptionCertificate) throws Exception {\n\t\tCMSEnvelopedDataGenerator cmsEnvelopedDataGenerator = new CMSEnvelopedDataGenerator();\n\t\tJceKeyTransRecipientInfoGenerator jceKey = new JceKeyTransRecipientInfoGenerator(encryptionCertificate);\n\t\tcmsEnvelopedDataGenerator.addRecipientInfoGenerator(jceKey);\n\t\tCMSTypedData msg = new CMSProcessableByteArray(data);\n\t\tOutputEncryptor encryptor = new JceCMSContentEncryptorBuilder(CMSAlgorithm.AES128_CBC).setProvider(\"BC\")\n\t\t\t\t.build();\n\t\tCMSEnvelopedData cmsEnvelopedData = cmsEnvelopedDataGenerator.generate(msg, encryptor);\n\t\treturn cmsEnvelopedData.getEncoded();\n\t}\n\n\tprivate static byte[] decryptData(final byte[] encryptedData, final PrivateKey decryptionKey) throws CMSException {\n\t\tCMSEnvelopedData envelopedData = new CMSEnvelopedData(encryptedData);\n\t\tCollection<RecipientInformation> recip = envelopedData.getRecipientInfos().getRecipients();\n\t\tKeyTransRecipientInformation recipientInfo = (KeyTransRecipientInformation) recip.iterator().next();\n\t\tJceKeyTransRecipient recipient = new JceKeyTransEnvelopedRecipient(decryptionKey);\n\t\treturn recipientInfo.getContent(recipient);\n\t}\n\n\tprivate static byte[] signData(byte[] data, final X509Certificate signingCertificate, final PrivateKey signingKey)\n\t\t\tthrows Exception {\n\t\tContentSigner contentSigner = new JcaContentSignerBuilder(\"SHA256withRSA\").build(signingKey);\n\t\tCMSSignedDataGenerator cmsGenerator = new CMSSignedDataGenerator();\n\t\tDigestCalculatorProvider digestCalculatorProvider = new JcaDigestCalculatorProviderBuilder().setProvider(\"BC\")\n\t\t\t\t.build();\n\t\tSignerInfoGenerator signerInfoGenerator = new JcaSignerInfoGeneratorBuilder(digestCalculatorProvider)\n\t\t\t\t.build(contentSigner, signingCertificate);\n\t\tcmsGenerator.addSignerInfoGenerator(signerInfoGenerator);\n\t\tStore<?> certs = new JcaCertStore(Collections.singleton(signingCertificate));\n\t\tcmsGenerator.addCertificates(certs);\n\t\tCMSTypedData cmsData = new CMSProcessableByteArray(data);\n\t\tCMSSignedData cms = cmsGenerator.generate(cmsData, true);\n\t\treturn cms.getEncoded();\n\t}\n\n\tprivate static boolean verifySignedData(final byte[] signedData) throws Exception {\n\t\tCMSSignedData cmsSignedData;\n\t\ttry (ByteArrayInputStream byteInput = new ByteArrayInputStream(signedData)) {\n\t\t\ttry (ASN1InputStream asnInput = new ASN1InputStream(byteInput)) {\n\t\t\t\tcmsSignedData = new CMSSignedData(ContentInfo.getInstance(asnInput.readObject()));\n\t\t\t}\n\t\t}\n\t\tStore<X509CertificateHolder> certificates = cmsSignedData.getCertificates();\n\t\tSignerInformationStore signers = cmsSignedData.getSignerInfos();\n\t\tSignerInformation signer = signers.getSigners().iterator().next();\n\t\t@SuppressWarnings(\"unchecked\")\n\t\tCollection<X509CertificateHolder> signedCertificates = certificates.getMatches(signer.getSID());\n\t\tX509CertificateHolder certificateHolder = signedCertificates.iterator().next();\n\t\treturn signer.verify(new JcaSimpleSignerInfoVerifierBuilder().build(certificateHolder));\n\t}\n\n\tprivate static X509Certificate generateX509v1Certificate(KeyPair pair) throws Exception {\n\t\tX500Name issuer = new X500Name(\"CN=John Doe, OU=Labs, O=Oracle, L=Portland, ST=OR, C=US\");\n\t\tBigInteger serial = new BigInteger(64, new SecureRandom());\n\t\tDate start = new Date();\n\t\tint daysValid = 365;\n\t\tDate end = new Date(start.getTime() + daysValid * 86400000L);\n\t\tX500Name subject = new X500Name(\"CN=Test Certificate\");\n\n\t\tX509v1CertificateBuilder certificateBuilder = new JcaX509v1CertificateBuilder(issuer, serial, start, end,\n\t\t\t\tsubject, pair.getPublic());\n\t\tString algorithm = \"SHA256WithRSAEncryption\";\n\t\tContentSigner contentSigner = new JcaContentSignerBuilder(algorithm).setProvider(\"BC\").build(pair.getPrivate());\n\t\treturn new JcaX509CertificateConverter().setProvider(\"BC\")\n\t\t\t\t.getCertificate(certificateBuilder.build(contentSigner));\n\t}\n\n\t/**\n\t * Create a random 1024 bit RSA key pair.\n\t */\n\tprivate static KeyPair generateRSAKeyPair() throws Exception {\n\t\tKeyPairGenerator kpGen = KeyPairGenerator.getInstance(\"RSA\", \"BC\");\n\t\tkpGen.initialize(1024, new SecureRandom());\n\t\treturn kpGen.generateKeyPair();\n\t}\n\n\tprivate static void assertTrue(String message, boolean condition) {\n\t\tif (!condition) {\n\t\t\tthrow new AssertionError(message);\n\t\t}\n\t}\n}\n","exit_code":0,"status":"completed"}}
