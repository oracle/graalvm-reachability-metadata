            </dependency>
            <dependency>
                <groupId>org.eclipse.angus</groupId>
                <artifactId>smtp</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.eclipse.angus</groupId>
