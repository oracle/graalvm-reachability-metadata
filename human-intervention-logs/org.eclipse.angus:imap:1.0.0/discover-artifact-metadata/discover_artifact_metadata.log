        <spotbugs.plugin.version>4.5.0.0</spotbugs.plugin.version>

        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <javadoc.title>Angus Mail API documentation</javadoc.title>

        <mail.spec.version>2.1</mail.spec.version>
        <mail-api.version>2.1.0</mail-api.version>
        <activation-api.version>2.1.0</activation-api.version>
        <jsp-api.version>3.0.0</jsp-api.version>
        <servlet-api.version>5.0.0</servlet-api.version>
