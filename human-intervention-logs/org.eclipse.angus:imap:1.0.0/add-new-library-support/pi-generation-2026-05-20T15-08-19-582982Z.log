  	if (socket == null) {
  	    socket = createSocket(localaddr, localport,
  		    host, port, cto, to, props, prefix, null, useSSL);
  
  	} else {
  	    if (to >= 0) {
  		if (logger.isLoggable(Level.FINEST))
  		    logger.finest("set socket read timeout " + to);
  		socket.setSoTimeout(to);
  	    }
  	}
  
  	return socket;
