          output.writeShort(9);
          output.writeInt(30);
          output.writeShort(5);
          output.writeShort(2);
          output.writeInt(18);
          output.write(new byte[] {
              0x2A, 0x2B, (byte) 0xBB, 0, 10, 0x59, 0x12, 12,
