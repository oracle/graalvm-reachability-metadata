  import jakarta.mail.Message;
  import jakarta.mail.MessagingException;
  import jakarta.mail.MethodNotSupportedException;
  import com.sun.mail.iap.ProtocolException;
  import com.sun.mail.imap.protocol.IMAPProtocol;
