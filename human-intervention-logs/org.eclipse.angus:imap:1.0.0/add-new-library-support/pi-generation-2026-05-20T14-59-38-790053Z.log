  	    name = url.getProtocol();
  	this.name = name;
  	if (!isSSL)
  	    isSSL = PropUtil.getBooleanProperty(props,
  				"mail." + name + ".ssl.enable", false);
  	if (isSSL)
  	    this.defaultPort = 993;
  
