      protected IMAPFolder(ListInfo li, IMAPStore store) {
  	this(li.name, li.separator, store, null);
  
  	if (li.hasInferiors)
  	    type |= HOLDS_FOLDERS;
  	if (li.canOpen)
  	    type |= HOLDS_MESSAGES;
  	exists = true;
  	attributes = li.attrs;
      }
  	
