oncat(_ => List.empty[ByteString])\\n        .mapMaterializedValue(_ => Future.successful(Http.OutgoingConnection(localAddress, remoteAddress)))\\n    }\\n  }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 2240, \"output\": 852, \"cacheRead\": 52224, \"cacheWrite\": 0, \"totalTokens\": 55316, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1781129707362, \"responseId\": \"resp_09934c5d992f21e6016a29e1ebf03c81909405b5bea87a1837\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_vSbaoSYYfHnuiu3YcmAhz6QG|fc_09934c5d992f21e6016a29e1ed0e0c8190b20e3d907b01c73e\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 3206 bytes to tests/src/org.apache.pekko/pekko-http-core_3/1.3.0/src/test/scala/org_apache_pekko/pekko_http_core_3/Http2AlpnSupportTest.scala\"}], \"isError\": false, \"timestamp\": 1781129718305}]}\n3800:[tool-call] delta {\"path\":\"tests/src/org.apache.pekko/pekko-http-core_3/1.3.0/src/test/scala/org_apache_pekko/pekko_http_core_3/Http2AlpnSupportTest.scala\",\"edits\":[{\"oldText\":\"      implicit val implicitSystem: ActorSystem = system\\n      implicit val materializer: SystemMaterializer#SystemMaterializer = null\\n      val engineCreated: AtomicBoolean = new AtomicBoolean(false)\\n\",\"newText\":\"      implicit val implicitSystem: ActorSystem = system\\n      val engineCreated: AtomicBoolean = new AtomicBoolean(false)\\n\"}]}\n3801:[tool-call] end id=call_CmSHGGX1TW5Wr7fNsOnlypGo|fc_09934c5d992f21e6016a29e1f9daa08190bb4125b4e74c8b23 name=edit args={\"path\": \"tests/src/org.apache.pekko/pekko-http-core_3/1.3.0/src/test/scala/org_apache_pekko/pekko_http_core_3/Http2AlpnSupportTest.scala\", \"edits\": [{\"oldText\": \"      implicit val implicitSystem: ActorSystem = system\\n      implicit val materializer: SystemMaterializer#SystemMateri