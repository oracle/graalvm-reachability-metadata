oading pattern, but that seems irrelevant. I wonder if I should write a test referencing active class via generated bytecode instead. There's this idea of separating the test source set, but I’m not sure that would help either. I'll need to check the dynamic coverage report after a failure to learn more about what went wrong.\\\\\\\"}]}\\\"}, {\\\"type\\\": \\\"toolCall\\\", \\\"id\\\": \\\"call_sa5swZuKU4vJCKWeXD5Ax6fM|fc_0775c31a3e99d9ff0169fb3b8e75d0819590060776453e22fa\\\", \\\"name\\\": \\\"read\\\", \\\"arguments\\\": {\\\"path\\\": \\\"tests/src/org.apache.pekko/pekko-http-core_3/1.3.0/build/reports/dynamic-access/dynamic-access-coverage.json\\\", \\\"limit\\\": 100}}], \\\"api\\\": \\\"openai-responses\\\", \\\"provider\\\": \\\"OCA\\\", \\\"model\\\": \\\"gpt-5.5\\\", \\\"usage\\\": {\\\"input\\\": 12333, \\\"output\\\": 1245, \\\"cacheRead\\\": 53760, \\\"cacheWrite\\\": 0, \\\"totalTokens\\\": 67338, \\\"cost\\\": {\\\"input\\\": 0, \\\"output\\\": 0, \\\"cacheRead\\\": 0, \\\"cacheWrite\\\": 0, \\\"total\\\": 0}}, \\\"stopReason\\\": \\\"toolUse\\\", \\\"timestamp\\\": 1778072441497, \\\"responseId\\\": \\\"resp_0775c31a3e99d9ff0169fb3b7a0eb08195822bb06c4e000809\\\"}, \\\"toolResults\\\": [{\\\"role\\\": \\\"toolResult\\\", \\\"toolCallId\\\": \\\"call_sa5swZuKU4vJCKWeXD5Ax6fM|fc_0775c31a3e99d9ff0169fb3b8e75d0819590060776453e22fa\\\", \\\"toolName\\\": \\\"read\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"{\\\\n  \\\\\\\"classes\\\\\\\" : [ {\\\\n    \\\\\\\"callSites\\\\\\\" : [ {\\\\n      \\\\\\\"covered\\\\\\\" : false,\\\\n      \\\\\\\"frame\\\\\\\" : \\\\\\\"org.apache.pekko.http.impl.engine.http2.Http2AlpnSupport$.$anonfun$2(Http2AlpnSupport.scala:60)\\\\\\\",\\\\n      \\\\\\\"line\\\\\\\" : 60,\\\\n      \\\\\\\"metadataType\\\\\\\" : \\\\\\\"reflection\\\\\\\",\\\\n      \\\\\\\"trackedApi\\\\\\\" : \\\\\\\"java.lang.Class#getDeclaredMethods()\\\\\\\"\\\\n    } ],\\\\n    \\\\\\\"className\\\\\\\" : \\\\\\\"org.apache.