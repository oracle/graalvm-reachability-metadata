  plugins {
      id "org.graalvm.internal.tck"
      id "scala"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "org.apache.pekko:pekko-http-core_3:$libraryVersion"
      testImplementation 'org.apache.pekko:pekko-stream_3:1.1.5'
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testImplementation 'org.scala-lang:scala3-library_3:3.3.6'
      testImplementation 'org.scala-lang:scala3-compiler_3:3.3.6'
  }
  
  sourceSets {
      alpnPatch {
          java.srcDir 'src/alpnPatch/java'
      }
      test {
          compileClasspath += alpnPatch.output
          runtimeClasspath += alpnPatch.output
      }
  }
  
  tasks.withType(Test).configureEach {
      dependsOn tasks.named('compileAlpnPatchJava')
      jvmArgs += [
          '--patch-module', "java.base=${sourceSets.alpnPatch.output.classesDirs.asPath}"
      ]
  }
  
  java {
      toolchain {
          languageVersion = JavaLanguageVersion.of(21)
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
