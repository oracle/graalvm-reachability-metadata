,\\n      \\\"metadataType\\\" : \\\"resources\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.Class#getResourceAsStream(java.lang.String)\\\"\\n    } ],\\n    \\\"className\\\" : \\\"scala.tools.nsc.doc.html.HtmlFactory$$anon$1\\\",\\n    \\\"coveredCalls\\\" : 0,\\n    \\\"sourceFile\\\" : \\\"HtmlFactory.scala\\\",\\n    \\\"totalCalls\\\" : 1\\n  }, {\\n    \\\"callSites\\\" : [ {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"scala.tools.nsc.doc.html.HtmlFactory$$anon$2.<init>(HtmlFactory.scala:135)\\\",\\n      \\\"line\\\" : 135,\\n      \\\"metadataType\\\" : \\\"resources\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.Class#getResourceAsStream(java.lang.String)\\\"\\n    } ],\\n    \\\"className\\\" : \\\"scala.tools.nsc.doc.html.HtmlFactory$$anon$2\\\",\\n    \\\"coveredCalls\\\" : 0,\\n    \\\"sourceFile\\\" : \\\"HtmlFactory.scala\\\",\\n    \\\"totalCalls\\\" : 1\\n  }, {\\n    \\\"callSites\\\" : [ {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"scala.tools.nsc.interpreter.shell.JavapClass$ClassLoaderOps$.resourceable$extension(JavapClass.scala:146)\\\",\\n      \\\"line\\\" : 146,\\n      \\\"metadataType\\\" : \\\"resources\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.ClassLoader#getResource(java.lang.String)\\\"\\n    } ],\\n    \\\"className\\\" : \\\"scala.tools.nsc.interpreter.shell.JavapClass$ClassLoaderOps$\\\",\\n    \\\"coveredCalls\\\" : 0,\\n    \\\"sourceFile\\\" : \\\"JavapClass.scala\\\",\\n    \\\"totalCalls\\\" : 1\\n  }, {\\n    \\\"callSites\\\" : [ {\\n      \\\"covered\\\" : false,\\n      \\\"frame\\\" : \\\"scala.tools.nsc.interpreter.shell.JavapProvider.task(JavapClass.scala:425)\\\",\\n      \\\"line\\\" : 425,\\n      \\\"metadataType\\\" : \\\"reflection\\\",\\n      \\\"trackedApi\\\" : \\\"java.lang.reflect.Method#invoke(java.lang.Object, java.lang.Object[])\\\"\\n    } ],\\n    \\\"className\\\" : \\\"scala.tools.nsc.interpreter.shell.JavapProvider\\\",\\n    \\\"coveredCalls\\\" : 0,\\n   