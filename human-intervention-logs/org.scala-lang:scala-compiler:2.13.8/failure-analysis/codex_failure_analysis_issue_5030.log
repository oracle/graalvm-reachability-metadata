rpreter.IMain\\nimport scala.tools.nsc.interpreter.shell.ReplReporterImpl\\nimport scala.tools.nsc.plugins.Plugin\\nimport scala.tools.nsc.reporters.StoreReporter\\nimport scala.tools.nsc.{Global, Settings}\\n\\nobject ScalaCompilerTestSupport {\\n  def withTempDir(prefix: String)(body: Path => Unit): Unit = {\\n    val dir: Path = Files.createTempDirectory(prefix)\\n    try body(dir)\\n    finally deleteRecursively(dir)\\n  }\\n\\n  def compileScala(source: String, options: List[String] = Nil)(afterCompile: Path => Unit = _ => ()): Unit = {\\n    withTempDir(\\\"scala-compiler-test\\\") { dir =>\\n      val sourceFile: Path = dir.resolve(\\\"Sample.scala\\\")\\n      val outputDir: Path = dir.resolve(\\\"classes\\\")\\n      Files.createDirectories(outputDir)\\n      Files.writeString(sourceFile, source, StandardCharsets.UTF_8)\\n      val settings: Settings = compilerSettings(outputDir, options)\\n      val reporter: StoreReporter = new StoreReporter\\n      val global: Global = new Global(settings, reporter)\\n      new global.Run().compile(List(sourceFile.toString))\\n      assertThat(reporter.hasErrors).isFalse\\n      afterCompile(outputDir)\\n    }\\n  }\\n\\n  def compilerSettings(output: Path, options: List[String] = Nil): Settings = {\\n    val settings: Settings = new Settings(message => throw new IllegalArgumentException(message))\\n    settings.usejavacp.value = true\\n    settings.outputDirs.setSingleOutput(output.toString)\\n    val arguments: List[String] = options.filter(_.nonEmpty)\\n    if (arguments.nonEmpty) {\\n      val (ok, remaining) = settings.processArguments(arguments, processAll = true)\\n      assertThat(ok).isTrue\\n      assertThat(remaining.isEmpty).isTrue\\n    }\\n    settings\\n  }\\n\\n  def allowUnsupportedNativeImageFeature(body: => Unit): Unit = {\\n    try body\\n    catch {\\n      case error: Error if NativeImageSupport.isUnsupportedFeatureError(error) => ()\\n    }\\n  }\\n\\n  def writePluginDescriptor(dir: Path, classNam