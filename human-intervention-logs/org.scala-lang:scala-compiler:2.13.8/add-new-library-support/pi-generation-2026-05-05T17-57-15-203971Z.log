[tool-call] delta {"path":"tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/PluginsAnonymous1Test.scala","edits":[{"oldText":"ScalaCompilerTestSupport.withTempDir(\"scalac-plugin-compile\") { directory =>\n      ScalaCompilerTestSupport.writePluginDescriptor(directory, classOf[ReachabilityTestCompilerPlugin].getName)\n      val output = directory.resolve(\"classes\")\n      val source = directory.resolve(\"UsesPlugin.scala\")\n      Files.writeString(source, \"object UsesPlugin\", StandardCharsets.UTF_8)\n      val settings = ScalaCompilerTestSupport.compilerSettings(output, List(\"-Xplugin:\" + directory.toString))\n      val reporter = new scala.tools.nsc.reporters.StoreReporter\n      val global = new scala.tools.nsc.Global(settings, reporter)\n      new global.Run().compile(List(source.toString))\n      assertThat(reporter.hasErrors).isFalse\n    }","newText":"ScalaCompilerTestSupport.withTempDir(\"scalac-plugin-compile\") { directory =>\n      val pluginDirectory = directory.resolve(\"plugin\")\n      val pluginSource = directory.resolve(\"CompiledReachabilityPlugin.scala\")\n      Files.createDirectories(pluginDirectory)\n      Files.writeString(pluginSource,\n        \"\"\"import scala.tools.nsc.Global\n          |import scala.tools.nsc.plugins.{Plugin, PluginComponent}\n          |class CompiledReachabilityPlugin(val global: Global) extends Plugin {\n          |  override val name: String = \"compiled-reachability-plugin\"\n          |  override val description: String = \"compiled plugin\"\n          |  override val components: List[PluginComponent] = Nil\n          |}\n          |\"\"\".stripMargin,\n        StandardCharsets.UTF_8)\n      val pluginSettings = ScalaCompilerTestSupport.compilerSettings(pluginDirectory)\n      val pluginReporter = new scala.tools.nsc.reporters.StoreReporter\n      val pluginGlobal = new scala.tools.nsc.Global(pluginSettings, pluginReporter)\n      new pluginGlobal.Run().compile(List(pluginSource.toString))\n      assertThat(pluginReporter.hasErrors).isFalse\n      ScalaCompilerTestSupport.writePluginDescriptor(pluginDirectory, \"CompiledReachabilityPlugin\")\n\n      val output = directory.resolve(\"classes\")\n      val source = directory.resolve(\"UsesPlugin.scala\")\n      Files.writeString(source, \"object UsesPlugin\", StandardCharsets.UTF_8)\n      val settings = ScalaCompilerTestSupport.compilerSettings(output, List(\"-Xplugin:\" + pluginDirectory.toString))\n      val reporter = new scala.tools.nsc.reporters.StoreReporter\n      val global = new scala.tools.nsc.Global(settings, reporter)\n      new global.Run().compile(List(source.toString))\n      assertThat(reporter.hasErrors).isFalse\n    }"}]}
