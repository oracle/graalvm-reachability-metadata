  package org_scala_lang.scala_compiler
  
  import java.io.{PrintWriter, StringWriter}
  import scala.util.Success
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import scala.tools.nsc.Settings
  import scala.tools.nsc.interpreter.IMain
  import scala.tools.nsc.interpreter.shell.{JavapProvider, JavapTool}
  
  class JavapProviderAnonymous5Test {
    @Test
    def runsToolProviderBackedJavapTool(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {
      val settings = new Settings
      settings.usejavacp.value = true
      val imain = new IMain(settings, new PrintWriter(new StringWriter))
      try {
        val provider = new JavapProvider(imain)
        val tool = provider.task(provider.loader.toOption.get).toOption.get
        val result = tool(Seq("-public"), filter = false)(Seq(JavapTool.Input("java.lang.String", "java.lang.String", Success(Array.emptyByteArray))))
        assertThat(result.exists(!_.isError)).isTrue
      } finally imain.close()
    }
  }
