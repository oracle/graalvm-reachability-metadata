[tool-call] delta {"command":"TEST_DIR='tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler'\ncat > \"$TEST_DIR/ClassWriterTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.asm.{ClassWriter, Label, Opcodes}\n\nclass ClassWriterTest extends Opcodes {\n  @Test\n  def computesCommonSuperclassForStackMapFrames(): Unit = {\n    val bytes = AsmTestClasses.mergeFramesClassBytes()\n    assertThat(bytes.length).isGreaterThan(0)\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/SimpleVerifierTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.asm.ClassReader\nimport scala.tools.asm.tree.ClassNode\nimport scala.tools.asm.tree.analysis.{Analyzer, SimpleVerifier}\n\nclass SimpleVerifierTest {\n  @Test\n  def resolvesClassesDuringBytecodeAnalysis(): Unit = {\n    val reader = new ClassReader(AsmTestClasses.mergeFramesClassBytes())\n    val node = new ClassNode()\n    reader.accept(node, 0)\n    val method = node.methods.get(1)\n    val frames = new Analyzer(new SimpleVerifier()).analyze(node.name, method)\n    assertThat(frames.length).isGreaterThan(0)\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/ClassReaderTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.asm.ClassReader\n\nclass ClassReaderTest {\n  @Test\n  def readsClassBytesFromSystemResource(): Unit = {\n    val reader = new ClassReader(\"java.lang.String\")\n    assertThat(reader.getClassName).isEqualTo(\"java/lang/String\")\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/ConstantsTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.asm.{ClassVisitor, Opcodes}\n\nclass ConstantsTest {\n  @Test\n  def checksExperimentalAsmResource(): Unit = {\n    val visitor = new ClassVisitor(Opcodes.ASM10_EXPERIMENTAL) {}\n    assertThat(visitor).isNotNull\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/AsmTestClasses.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport scala.tools.asm.{ClassWriter, Label, MethodVisitor, Opcodes}\n\nobject AsmTestClasses extends Opcodes {\n  def mergeFramesClassBytes(): Array[Byte] = {\n    val classWriter = new ClassWriter(ClassWriter.COMPUTE_FRAMES)\n    classWriter.visit(V1_8, ACC_PUBLIC, \"MergeFrames\", null, \"java/lang/Object\", null)\n    writeConstructor(classWriter)\n    val method = classWriter.visitMethod(ACC_PUBLIC | ACC_STATIC, \"choose\", \"(Z)Ljava/lang/Object;\", null, null)\n    method.visitCode()\n    val elseLabel = new Label\n    val endLabel = new Label\n    method.visitVarInsn(ILOAD, 0)\n    method.visitJumpInsn(IFEQ, elseLabel)\n    method.visitTypeInsn(NEW, \"java/lang/StringBuilder\")\n    method.visitInsn(DUP)\n    method.visitMethodInsn(INVOKESPECIAL, \"java/lang/StringBuilder\", \"<init>\", \"()V\", false)\n    method.visitJumpInsn(GOTO, endLabel)\n    method.visitLabel(elseLabel)\n    method.visitLdcInsn(\"text\")\n    method.visitLabel(endLabel)\n    method.visitInsn(ARETURN)\n    method.visitMaxs(0, 0)\n    method.visitEnd()\n    classWriter.visitEnd()\n    classWriter.toByteArray\n  }\n\n  private def writeConstructor(classWriter: ClassWriter): Unit = {\n    val method: MethodVisitor = classWriter.visitMethod(ACC_PUBLIC, \"<init>\", \"()V\", null, null)\n    method.visitCode()\n    method.visitVarInsn(ALOAD, 0)\n    method.visitMethodInsn(INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\", false)\n    method.visitInsn(RETURN)\n    method.visitMaxs(0, 0)\n    method.visitEnd()\n  }\n}\nEOF\n"}
