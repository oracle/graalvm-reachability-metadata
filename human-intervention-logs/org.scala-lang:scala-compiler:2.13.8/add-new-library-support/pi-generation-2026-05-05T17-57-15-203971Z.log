directory =>\n      val className = classOf[ReachabilityTestCompilerPlugin].getName\n      ScalaCompilerTestSupport.writePluginDescriptor(directory, className)\n      val loader = ScalaCompilerTestSupport.newPluginClassLoader(directory)\n      try {\n        val loaded = Plugin.loadAllFrom(\n          List(List(scala.reflect.io.Path(directory.toString))),\n          Nil,\n          Nil,\n          _ => loader)\n        assertThat(loaded).hasSize(1)\n        val settings = ScalaCompilerTestSupport.compilerSettings(directory.resolve(\"classes\"))\n        val reporter = new scala.tools.nsc.reporters.StoreReporter\n        val global = new Global(settings, reporter)\n        assertThat(Plugin.instantiate(loaded.head.get, global).name).isEqualTo(\"reachability-test-plugin\")\n      } finally loader.close()\n    }\n  }\n}\n\nclass ReachabilityTestCompilerPlugin(val global: Global) extends Plugin {\n  override val name: String = \"reachability-test-plugin\"\n  override val description: String = \"Plugin used by reachability metadata tests\"\n  override val components: List[PluginComponent] = Nil\n}\nEOF\n\ncat > \"$TEST_DIR/PluginsAnonymous1Test.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass PluginsAnonymous1Test {\n  @Test\n  def compilerPluginClassLoaderFindsOnlyItsPluginDescriptor(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    ScalaCompilerTestSupport.withTempDir(\"scalac-plugin-compile\") { directory =>\n      ScalaCompilerTestSupport.writePluginDescriptor(directory, classOf[ReachabilityTestCompilerPlugin].getName)\n      val output = directory.resolve(\"classes\")\n      val source = directory.resolve(\"UsesPlugin.scala\")\n      Files.writeString(source, \"object UsesPlugin\", StandardCharsets.UTF_8)\n      val settings = ScalaCompilerTestSupport.compilerSettings(output, List(\"-Xplugin:\" + directory.toString))\n      val reporter = new scala.tools.nsc.reporters.StoreReporter\n      val global = new scala.tools.nsc.Global(settings, reporter)\n      new global.Run().compile(List(source.toString))\n      assertThat(reporter.hasErrors).isFalse\n    }\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/IMainInnerReadEvalPrintTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.io.{PrintWriter, StringWriter}\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.Settings\nimport scala.tools.nsc.interpreter.IMain\n\nclass IMainInnerReadEvalPrintTest {\n  @Test\n  def interpretsAndInvokesGeneratedReplCode(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    val settings = new Settings\n    settings.usejavacp.value = true\n    val out = new StringWriter\n    val imain = new IMain(settings, new PrintWriter(out))\n    try {\n      assertThat(imain.interpret(\"val replValue = 40 + 2\").toString).contains(\"Success\")\n      assertThat(imain.valueOfTerm(\"replValue\")).contains(42)\n    } finally imain.close()\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/JavapTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.io.{PrintWriter, StringWriter}\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.Settings\nimport scala.tools.nsc.interpreter.IMain\nimport scala.tools.nsc.interpreter.shell.Javap\n\nclass JavapTest {\n  @Test\n  def createsJavapToolForReplClass(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    val settings = new Settings\n    settings.usejavacp.value = true\n    val imain = new IMain(settings, new PrintWriter(new StringWriter))\n    try {\n      imain.interpret(\"class Disassembled { def answer: Int = 42 }\")\n      val result = Javap(imain)(\"Disassembled\").map(_.show()).mkString(\"\\n\")\n      assertThat(result).contains(\"Disassembled\")\n    } finally imain.close()\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/JavapProviderTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.io.{PrintWriter, StringWriter}\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.Settings\nimport scala.tools.nsc.interpreter.IMain\nimport scala.tools.nsc.interpreter.shell.JavapProvider\n\nclass JavapProviderTest {\n  @Test\n  def locatesJavapToolProviderReflectively(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    val settings = new Settings\n    settings.usejavacp.value = true\n    val imain = new IMain(settings, new PrintWriter(new StringWriter))\n    try {\n      val provider = new JavapProvider(imain)\n      assertThat(provider.task(provider.loader.toOption.get).isRight).isTrue\n    } finally imain.close()\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/JavapProviderAnonymous5Test.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.io.{PrintWriter, StringWriter}\nimport scala.util.Success\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.Settings\nimport scala.tools.nsc.interpreter.IMain\nimport scala.tools.nsc.interpreter.shell.{JavapProvider, JavapTool}\n\nclass JavapProviderAnonymous5Test {\n  @Test\n  def runsToolProviderBackedJavapTool(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    val settings = new Settings\n    settings.usejavacp.value = true\n    val imain = new IMain(settings, new PrintWriter(new StringWriter))\n    try {\n      val provider = new JavapProvider(imain)\n      val tool = provider.task(provider.loader.toOption.get).toOption.get\n      val result = tool(Seq(\"-public\"), filter = false)(Seq(JavapTool.Input(\"java.lang.String\", \"java.lang.String\", Success(Array.emptyByteArray))))\n      assertThat(result.map(_.show()).mkString(\"\\n\")).contains(\"java.lang.String\")\n    } finally imain.close()\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/JavapTaskTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.io.{PrintWriter, StringWriter}\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.Settings\nimport scala.tools.nsc.interpreter.IMain\nimport scala.tools.nsc.interpreter.shell.JavapTask\n\nclass JavapTaskTest {\n  @Test\n  def constructsJavapTaskUsingJdkToolInternals(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    val settings = new Settings\n    settings.usejavacp.value = true\n    val imain = new IMain(settings, new PrintWriter(new StringWriter))\n    try {\n      val task = new JavapTask(imain.classLoader, imain)\n      assertThat(task.written).isEmpty\n    } finally imain.close()\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/JavapClassInnerClassLoaderOpsTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.junit.jupiter.api.Test\n\nclass JavapClassInnerClassLoaderOpsTest {\n  @Test\n  def checksClassResourcesWhileResolvingJavapTargets(): Unit = new JavapTest().createsJavapToolForReplClass()\n}\nEOF\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 639, "output": 1940, "cacheRead": 45568, "cacheWrite": 0, "totalTokens": 48147, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778003509789, "responseId": "resp_0545b625b80fd5ab0169fa2e3661f881a382faf4b49b496c42"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_7DFZgd1DKPWCnqESCYtxliF8|fc_0545b625b80fd5ab0169fa2e37c55481a384b1ff676005ec61", "toolName": "bash", "content": [{"type": "text", "text": "(no output)"}], "isError": false, "timestamp": 1778003524196}]}
