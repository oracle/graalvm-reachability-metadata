  package org_scala_lang.scala_compiler
  
  import java.nio.charset.StandardCharsets
  import java.nio.file.Files
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import scala.tools.nsc.ScalaDoc
  
  class DocFactoryTest {
    @Test
    def generatesScaladocWithDefaultDoclet(): Unit = {
      ScalaCompilerTestSupport.withTempDir("scaladoc-test") { directory =>
        val source = directory.resolve("Documented.scala")
        val output = directory.resolve("api")
        Files.createDirectories(output)
        Files.writeString(source, "/** Uses [[java.lang.String]]. */ class Documented", StandardCharsets.UTF_8)
        assertThat(ScalaDoc.process(Array("-usejavacp", "-d", output.toString, source.toString))).isTrue
      }
    }
  }
