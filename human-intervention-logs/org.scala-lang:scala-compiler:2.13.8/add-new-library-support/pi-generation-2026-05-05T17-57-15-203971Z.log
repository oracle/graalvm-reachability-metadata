\")\n      Files.createDirectories(macroOutput)\n      Files.createDirectories(useOutput)\n      val macroSource: Path = directory.resolve(\"TestMacros.scala\")\n      Files.writeString(macroSource,\n        \"\"\"import scala.language.experimental.macros\n          |import scala.reflect.macros.blackbox\n          |object TestMacros {\n          |  def answer: Int = macro answerImpl\n          |  def answerImpl(c: blackbox.Context): c.Expr[Int] = {\n          |    import c.universe._\n          |    c.Expr[Int](q\"42\")\n          |  }\n          |}\n          |\"\"\".stripMargin, StandardCharsets.UTF_8)\n      val macroSettings = ScalaCompilerTestSupport.compilerSettings(macroOutput, List(\"-language:experimental.macros\"))\n      val macroReporter = new scala.tools.nsc.reporters.StoreReporter\n      val macroGlobal = new scala.tools.nsc.Global(macroSettings, macroReporter)\n      new macroGlobal.Run().compile(List(macroSource.toString))\n      assert(!macroReporter.hasErrors)\n\n      val useSource: Path = directory.resolve(\"UseMacro.scala\")\n      Files.writeString(useSource, \"object UseMacro { val value: Int = TestMacros.answer }\", StandardCharsets.UTF_8)\n      val useSettings = ScalaCompilerTestSupport.compilerSettings(useOutput, List(\"-cp\", macroOutput.toString, \"-language:experimental.macros\"))\n      val useReporter = new scala.tools.nsc.reporters.StoreReporter\n      val useGlobal = new scala.tools.nsc.Global(useSettings, useReporter)\n      new useGlobal.Run().compile(List(useSource.toString))\n      assert(!useReporter.hasErrors)\n    }\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/DocFactoryTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.ScalaDoc\n\nclass DocFactoryTest {\n  @Test\n  def generatesScaladocWithDefaultDoclet(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    ScalaCompilerTestSupport.withTempDir(\"scaladoc-test\") { directory =>\n      val source = directory.resolve(\"Documented.scala\")\n      val output = directory.resolve(\"api\")\n      Files.createDirectories(output)\n      Files.writeString(source, \"/** Uses [[java.lang.String]]. */ class Documented\", StandardCharsets.UTF_8)\n      assertThat(ScalaDoc.process(Array(\"-usejavacp\", \"-d\", output.toString, source.toString))).isTrue\n    }\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/MemberLookupTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.junit.jupiter.api.Test\n\nclass MemberLookupTest {\n  @Test\n  def linksScaladocMembers(): Unit = new DocFactoryTest().generatesScaladocWithDefaultDoclet()\n}\nEOF\n\ncat > \"$TEST_DIR/ToolBoxFactoryInnerToolBoxImplInnerToolBoxGlobalTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.reflect.runtime.currentMirror\nimport scala.tools.reflect.ToolBox\n\nclass ToolBoxFactoryInnerToolBoxImplInnerToolBoxGlobalTest {\n  @Test\n  def compilesAndInvokesAToolboxFunction(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    val toolbox = currentMirror.mkToolBox()\n    val compiled = toolbox.compile(toolbox.parse(\"() => 40 + 2\"))\n    assertThat(compiled().asInstanceOf[Function0[Int]].apply()).isEqualTo(42)\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/ReportingInnerWarningCategoryTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.Reporting.WarningCategory\n\nclass ReportingInnerWarningCategoryTest {\n  @Test\n  def enumeratesWarningCategoriesAndNames(): Unit = {\n    assertThat(WarningCategory.all).containsKey(\"deprecation\")\n    assertThat(WarningCategory.Deprecation.name).isEqualTo(\"deprecation\")\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/ReportingInnerPerRunReportingInnerQuickfixTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.junit.jupiter.api.Test\n\nclass ReportingInnerPerRunReportingInnerQuickfixTest {\n  @Test\n  def reportsCompilerDiagnosticsWithQuickfixSupportLoaded(): Unit = ScalaCompilerTestSupport.compileScala(\"object QuickfixSample { val x: String = 1 }\")()\n}\nEOF\n\ncat > \"$TEST_DIR/GlobalTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.junit.jupiter.api.Test\n\nclass GlobalTest {\n  @Test\n  def loadsConfiguredSourceReader(): Unit = {\n    ScalaCompilerTestSupport.compileScala(\"object UsesConfiguredReader\", List(\"-Yrangepos\", \"-sourcepath\", \".\"))()\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/ClassfileWritersInnerFileWriterTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass ClassfileWritersInnerFileWriterTest {\n  @Test\n  def writesClassfilesThroughJarWriter(): Unit = ScalaCompilerTestSupport.withTempDir(\"scala-jar-output\") { directory =>\n    val source = directory.resolve(\"JarOutput.scala\")\n    val jarFile = directory.resolve(\"out.jar\")\n    Files.writeString(source, \"object JarOutput { def answer = 42 }\", StandardCharsets.UTF_8)\n    val settings = ScalaCompilerTestSupport.compilerSettings(jarFile, Nil)\n    val reporter = new scala.tools.nsc.reporters.StoreReporter\n    val global = new scala.tools.nsc.Global(settings, reporter)\n    new global.Run().compile(List(source.toString))\n    assertThat(reporter.hasErrors).isFalse\n    assertThat(Files.size(jarFile)).isGreaterThan(0L)\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/PicklerTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.io.{StringReader, StringWriter}\nimport java.util.ArrayList\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.interactive.{Lexer, Pickler}\n\nclass PicklerTest {\n  @Test\n  def unpicklesJavaInstancesWithDefaultConstructor(): Unit = {\n    val pickler = Pickler.javaInstancePickler[ArrayList[_]]\n    val writer = new StringWriter\n    pickler.pickle(writer, new ArrayList[AnyRef]())\n    val unpickled = pickler.unpickle(new Lexer(new StringReader(writer.toString))).get\n    assertThat(unpickled).isInstanceOf(classOf[ArrayList[_]])\n  }\n}\nEOF\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3539, "output": 1976, "cacheRead": 40448, "cacheWrite": 0, "totalTokens": 45963, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778003487752, "responseId": "resp_0545b625b80fd5ab0169fa2e208a8081a39a02c9e368001fb6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wcQSpoVTuReiR0k5KZntOupV|fc_0545b625b80fd5ab0169fa2e23d47481a394c4be8d2c4599c5", "toolName": "bash", "content": [{"type": "text", "text": "(no output)"}], "isError": false, "timestamp": 1778003503201}]}
