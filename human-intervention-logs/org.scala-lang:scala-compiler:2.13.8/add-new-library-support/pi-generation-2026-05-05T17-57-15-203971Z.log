ackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.util.ClassPath\n\nclass ClassPathTest {\n  @Test\n  def enumeratesManifestResourcesFromContextClassLoader(): Unit = {\n    assertThat(ClassPath.manifests).isNotEmpty\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/VerifyClassTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.util.VerifyClass\n\nclass VerifyClassTest {\n  @Test\n  def loadsClassesFromCompiledDirectory(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    ScalaCompilerTestSupport.withTempDir(\"verify-class\") { directory =>\n      val source = directory.resolve(\"Verified.scala\")\n      val output = directory.resolve(\"classes\")\n      Files.writeString(source, \"class Verified\", StandardCharsets.UTF_8)\n      val settings = ScalaCompilerTestSupport.compilerSettings(output)\n      val reporter = new scala.tools.nsc.reporters.StoreReporter\n      val global = new scala.tools.nsc.Global(settings, reporter)\n      new global.Run().compile(List(source.toString))\n      assertThat(reporter.hasErrors).isFalse\n      val results = VerifyClass.run(Array(output.toString))\n      assertThat(results).containsKey(\"Verified\")\n    }\n  }\n}\nEOF\n\ncat > \"$TEST_DIR/MacroAnnotationNamersInnerMacroAnnotationNamerTest.scala\" <<'EOF'\npackage org_scala_lang.scala_compiler\n\nimport org.junit.jupiter.api.Test\n\nclass MacroAnnotationNamersInnerMacroAnnotationNamerTest {\n  @Test\n  def enablesMacroAnnotationPipelineDuringCompilation(): Unit = ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n    ScalaCompilerTestSupport.compileScala(\n      \"\"\"import scala.annotation.StaticAnnotation\n        |class marker extends StaticAnnotation\n        |@marker class A