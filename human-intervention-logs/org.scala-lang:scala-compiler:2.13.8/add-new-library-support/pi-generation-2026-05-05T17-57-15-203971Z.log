[tool-call] delta {"path":"tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/Scala_compilerTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.io.StringReader\nimport java.net.URLClassLoader\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.{Files, Path}\nimport java.util.Comparator\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.graalvm.internal.tck.NativeImageSupport\nimport scala.tools.nsc.{Global, Settings}\nimport scala.tools.nsc.reporters.StoreReporter\n\nobject ScalaCompilerTestSupport {\n  def withTempDir(prefix: String)(test: Path => Unit): Unit = {\n    val directory: Path = Files.createTempDirectory(prefix)\n    try test(directory)\n    finally deleteRecursively(directory)\n  }\n\n  def compileScala(source: String, options: List[String] = Nil)(test: Path => Unit = _ => ()): Unit = {\n    withTempDir(\"scala-compiler-test\") { directory =>\n      val sourceFile: Path = directory.resolve(\"Sample.scala\")\n      val outputDirectory: Path = directory.resolve(\"classes\")\n      Files.createDirectories(outputDirectory)\n      Files.writeString(sourceFile, source, StandardCharsets.UTF_8)\n      val settings: Settings = compilerSettings(outputDirectory, options)\n      val reporter: StoreReporter = new StoreReporter\n      val global: Global = new Global(settings, reporter)\n      new global.Run().compile(List(sourceFile.toString))\n      assertThat(reporter.infos.filter(_.severity == reporter.ERROR)).isEmpty\n      test(outputDirectory)\n    }\n  }\n\n  def compilerSettings(outputDirectory: Path, options: List[String] = Nil): Settings = {\n    val settings: Settings = new Settings(error => throw new IllegalArgumentException(error))\n    settings.usejavacp.value = true\n    settings.outputDirs.setSingleOutput(outputDirectory.toString)\n    val arguments: List[String] = options.filter(_.nonEmpty)\n    if (arguments.nonEmpty) {\n      val processed: (Boolean, List[String]) = settings.processArguments(arguments, processAll = true)\n      assertThat(processed._1).isTrue\n      assertThat(processed._2).isEmpty\n    }\n    settings\n  }\n\n  def allowUnsupportedNativeImageFeature(test: => Unit): Unit = {\n    try test\n    catch {\n      case error: Error if NativeImageSupport.isUnsupportedFeatureError(error) => ()\n    }\n  }\n\n  def writePluginDescriptor(directory: Path, className: String): Unit = {\n    val descriptor: String =\n      s\"\"\"<plugin>\n         |  <name>reachability-test-plugin</name>\n         |  <classname>$className</classname>\n         |</plugin>\n         |\"\"\".stripMargin\n    Files.writeString(directory.resolve(\"scalac-plugin.xml\"), descriptor, StandardCharsets.UTF_8)\n  }\n\n  def newPluginClassLoader(directory: Path): URLClassLoader =\n    new URLClassLoader(Array(directory.toUri.toURL), Thread.currentThread().getContextClassLoader)\n\n  def reader(text: String): StringReader = new StringReader(text)\n\n  private def deleteRecursively(directory: Path): Unit = {\n    if (Files.exists(directory)) {\n      Files.walk(directory)\n        .sorted(Comparator.reverseOrder())\n        .forEach(path => Files.deleteIfExists(path))\n    }\n  }\n}\n"}
