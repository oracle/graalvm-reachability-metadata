  package org_scala_lang.scala_compiler
  
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Test
  import scala.tools.nsc.Global
  import scala.tools.nsc.Settings
  import scala.tools.nsc.plugins.Plugin
  import scala.tools.nsc.reporters.StoreReporter
  
  class PluginInnerTest {
    @Test
    def pluginObjectLoadsAndInstantiatesPlugin(): Unit = {
      val reporter = new StoreReporter()
      val global = new Global(new Settings(reporter.error), reporter)
      val loaded = Plugin.load(classOf[PluginTestCompilerPlugin].getName, getClass.getClassLoader).get
      val plugin = Plugin.instantiate(loaded, global)
  
      assertEquals("reachability-test-plugin", plugin.name)
    }
  }
