  package org_scala_lang.scala_compiler
  
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Assertions.assertTrue
  import org.junit.jupiter.api.Test
  import scala.tools.nsc.Settings
  import scala.tools.nsc.interpreter.IMain
  import scala.tools.nsc.interpreter.shell.JavapProvider
  
  class JavapProviderTest {
    @Test
    def providerFindsJavapToolProvider(): Unit = {
      val interpreter = new IMain(new Settings())
      try {
        assertTrue(new JavapProvider(interpreter).task(getClass.getClassLoader).isRight)
      } catch {
        case error: Error if NativeImageSupport.isUnsupportedFeatureError(error) => ()
      } finally {
        interpreter.close()
      }
    }
  }
