a_compiler\n\nimport java.nio.file.Path\n\nimport org.junit.jupiter.api.Assertions.assertFalse\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.io.TempDir\nimport scala.reflect.internal.util.BatchSourceFile\nimport scala.tools.nsc.Global\nimport scala.tools.nsc.Settings\nimport scala.tools.nsc.reporters.StoreReporter\n\nclass GlobalTest {\n  @Test\n  def compilerLoadsConfiguredSourceReader(@TempDir tempDir: Path): Unit = {\n    val reporter = new StoreReporter()\n    val settings = new Settings(reporter.error)\n    settings.usejavacp.value = true\n    settings.outputDirs.setSingleOutput(tempDir.toFile.getAbsolutePath)\n    settings.sourceReader.value = classOf[GlobalTestSourceReader].getName\n\n    val global = new Global(settings, reporter)\n    new global.Run().compileSources(List(new BatchSourceFile(\"GlobalSourceReader.scala\", \"object GlobalSourceReaderSample\")))\n\n    assertFalse(reporter.hasErrors)\n  }\n}\nEOF\ncat > tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/ClassfileWritersInnerFileWriterTest.scala <<'EOF'\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.nio.file.Path\n\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.io.TempDir\nimport scala.reflect.internal.util.BatchSourceFile\nimport scala.tools.nsc.Global\nimport scala.tools.nsc.Settings\nimport scala.tools.nsc.reporters.StoreReporter\n\nclass ClassfileWritersInnerFileWriterTest {\n  @Test\n  def compilerWritesJarOutputWithDefaultJarFactory(@TempDir tempDir: Path): Unit = {\n    val jar = tempDir.resolve(\"compiled.jar\")\n    val reporter = new StoreReporter()\n    val settings = new Settings(reporter.error)\n    settings.usejavacp.value = true\n    settings.outputDirs.setSingleOutput(jar.toFile.getAbsolutePath)\n\n    val global = new Global(settings, reporter)\n    new global.Run().compileSources(List(new BatchSourceFile(\"JarOutput.scala\", \"class JarOutputSample\")))\n\n    assertTrue(jar.toFile.isFile)\n  }\n}\nEOF\ncat > tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/DocFactoryTest.scala <<'EOF'\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\n\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.io.TempDir\nimport scala.tools.nsc.ScalaDoc\n\nclass DocFactoryTest {\n  @Test\n  def scaladocLoadsDefaultDoclet(@TempDir tempDir: Path): Unit = {\n    val source = tempDir.resolve(\"Documented.scala\")\n    val output = tempDir.resolve(\"doc\")\n    Files.createDirectories(output)\n    Files.writeString(source, \"/** A documented type. */ final class Documented(val name: String)\\n\", StandardCharsets.UTF_8)\n\n    val processed = new ScalaDoc().process(Array(\"-usejavacp\", \"-d\", output.toString, source.toString))\n\n    assertTrue(processed)\n  }\n}\nEOF\ncat > tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/MemberLookupTest.scala <<'EOF'\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\n\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\nimp