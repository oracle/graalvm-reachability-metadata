[tool-call] delta {"path":"tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/ScalaCompilerTestSupport.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.io.{PrintWriter, StringWriter}\nimport java.net.URLClassLoader\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.{Files, Path}\nimport java.util.Comparator\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.graalvm.internal.tck.NativeImageSupport\nimport scala.jdk.CollectionConverters._\nimport scala.reflect.io.AbstractFile\nimport scala.tools.nsc.interpreter.IMain\nimport scala.tools.nsc.interpreter.shell.ReplReporterImpl\nimport scala.tools.nsc.plugins.Plugin\nimport scala.tools.nsc.reporters.StoreReporter\nimport scala.tools.nsc.{Global, Settings}\n\nobject ScalaCompilerTestSupport {\n  def withTempDir(prefix: String)(body: Path => Unit): Unit = {\n    val dir: Path = Files.createTempDirectory(prefix)\n    try body(dir)\n    finally deleteRecursively(dir)\n  }\n\n  def compileScala(source: String, options: List[String] = Nil)(afterCompile: Path => Unit = _ => ()): Unit = {\n    withTempDir(\"scala-compiler-test\") { dir =>\n      val sourceFile: Path = dir.resolve(\"Sample.scala\")\n      val outputDir: Path = dir.resolve(\"classes\")\n      Files.createDirectories(outputDir)\n      Files.writeString(sourceFile, source, StandardCharsets.UTF_8)\n      val settings: Settings = compilerSettings(outputDir, options)\n      val reporter: StoreReporter = new StoreReporter\n      val global: Global = new Global(settings, reporter)\n      new global.Run().compile(List(sourceFile.toString))\n      assertThat(reporter.hasErrors).isFalse\n      afterCompile(outputDir)\n    }\n  }\n\n  def compilerSettings(output: Path, options: List[String] = Nil): Settings = {\n    val settings: Settings = new Settings(message => throw new IllegalArgumentException(message))\n    settings.usejavacp.value = true\n    settings.outputDirs.setSingleOutput(output.toString)\n    val arguments: List[String] = options.filter(_.nonEmpty)\n    if (arguments.nonEmpty) {\n      val (ok, remaining) = settings.processArguments(arguments, processAll = true)\n      assertThat(ok).isTrue\n      assertThat(remaining.isEmpty).isTrue\n    }\n    settings\n  }\n\n  def allowUnsupportedNativeImageFeature(body: => Unit): Unit = {\n    try body\n    catch {\n      case error: Error if NativeImageSupport.isUnsupportedFeatureError(error) => ()\n    }\n  }\n\n  def writePluginDescriptor(dir: Path, className: String): Unit = {\n    val descriptor: String =\n      s\"\"\"\n         |<plugin>\n         |  <name>reachability-test-plugin</name>\n         |  <classname>$className</classname>\n         |</plugin>\n         |\"\"\".stripMargin\n    Files.writeString(dir.resolve(Plugin.PluginXML), descriptor, StandardCharsets.UTF_8)\n  }\n\n  def newPluginClassLoader(dir: Path): URLClassLoader = {\n    new URLClassLoader(Array(dir.toUri.toURL), Thread.currentThread().getContextClassLoader)\n  }\n\n  def newInterpreter(): IMain = {\n    val settings: Settings = new Settings\n    settings.usejavacp.value = true\n    val reporter: ReplReporterImpl = new ReplReporterImpl(settings, new PrintWriter(new StringWriter))\n    new IMain(settings, reporter)\n  }\n\n  def newInterpreter(outputDir: Path): IMain = {\n    Files.createDirectories(outputDir)\n    val settings: Settings = new Settings\n    settings.usejavacp.value = true\n    settings.Yreploutdir.value = outputDir.toString\n    val reporter: ReplReporterImpl = new ReplReporterImpl(settings, new PrintWriter(new StringWriter))\n    new IMain(settings, reporter)\n  }\n\n  def allowJavapModuleAccessFailure(body: => Unit): Unit = {\n    try body\n    catch {\n      case error: IllegalAccessException if error.getMessage.contains(\"jdk.jdeps\") => ()\n    }\n  }\n\n  private def deleteRecursively(path: Path): Unit = {\n    if (Files.exists(path)) {\n      val stream = Files.walk(path)\n      try stream.sorted(Comparator.reverseOrder()).iterator().asScala.foreach(Files.deleteIfExists)\n      finally stream.close()\n    }\n  }\n}\n\nclass ReachabilityTestCompilerPlugin(val global: Global) extends Plugin {\n  override val name: String = \"reachability-test-plugin\"\n  override val description: String = \"Test compiler plugin for reachability coverage\"\n  override val components: List[PluginComponent] = Nil\n}\n"}
