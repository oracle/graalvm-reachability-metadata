[tool-call] delta {"path":"tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/JavaReflectionRuntimesInnerJavaReflectionResolversTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.{Files, Path}\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.nsc.Global\nimport scala.tools.nsc.reporters.StoreReporter\n\nclass JavaReflectionRuntimesInnerJavaReflectionResolversTest {\n  @Test\n  def expandsAMacroLoadedThroughJavaReflection(): Unit = {\n    ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n      ScalaCompilerTestSupport.withTempDir(\"macro-runtime\") { dir =>\n        val macroOut: Path = dir.resolve(\"macro-classes\")\n        val useOut: Path = dir.resolve(\"use-classes\")\n        Files.createDirectories(macroOut)\n        Files.createDirectories(useOut)\n        val macroSource: Path = dir.resolve(\"ReachMacro.scala\")\n        Files.writeString(macroSource,\n          \"\"\"\n            |import scala.language.experimental.macros\n            |import scala.reflect.macros.blackbox\n            |object ReachMacro {\n            |  def answer: Int = macro answerImpl\n            |  def answerImpl(c: blackbox.Context): c.Expr[Int] = {\n            |    import c.universe._\n            |    c.Expr[Int](q\"42\")\n            |  }\n            |}\n            |\"\"\".stripMargin, StandardCharsets.UTF_8)\n        compile(macroSource, macroOut, Nil)\n        val useSource: Path = dir.resolve(\"UsesReachMacro.scala\")\n        Files.writeString(useSource, \"object UsesReachMacro { val value: Int = ReachMacro.answer }\", StandardCharsets.UTF_8)\n        compile(useSource, useOut, List(\"-classpath\", macroOut.toString))\n      }\n    }\n  }\n\n  private def compile(source: Path, output: Path, options: List[String]): Unit = {\n    val reporter: StoreReporter = new StoreReporter\n    val global: Global = new Global(ScalaCompilerTestSupport.compilerSettings(output, options), reporter)\n    new global.Run().compile(List(source.toString))\n    assertThat(reporter.hasErrors).isFalse\n  }\n}\n"}
