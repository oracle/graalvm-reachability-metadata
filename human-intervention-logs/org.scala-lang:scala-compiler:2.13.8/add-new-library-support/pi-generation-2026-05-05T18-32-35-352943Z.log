  package org_scala_lang.scala_compiler
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import scala.tools.nsc.interpreter.IMain
  import scala.tools.nsc.interpreter.shell.Javap
  
  class JavapTest {
    @Test
    def createsJavapToolForReplClass(): Unit = {
      ScalaCompilerTestSupport.withTempDir("javap-repl") { dir =>
        val intp: IMain = ScalaCompilerTestSupport.newInterpreter(dir)
        try {
          intp.interpret("class JavapSample")
          assertThat(Javap(intp)("JavapSample").nonEmpty).isTrue
        } finally intp.close()
      }
    }
  }
