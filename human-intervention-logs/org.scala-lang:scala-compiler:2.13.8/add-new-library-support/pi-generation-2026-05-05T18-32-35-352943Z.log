  import org.junit.jupiter.api.Test
  import scala.tools.nsc.interpreter.IMain
  import scala.tools.nsc.interpreter.shell.Javap
  
  class JavapClassInnerClassLoaderOpsTest {
    @Test
    def checksClassResourcesWhileResolvingJavapTargets(): Unit = {
      ScalaCompilerTestSupport.withTempDir("javap-resource") { dir =>
        val intp: IMain = ScalaCompilerTestSupport.newInterpreter(dir)
        try {
          intp.interpret("class ResourceSample")
          assertThat(Javap(intp)("ResourceSample.class").nonEmpty).isTrue
        } finally intp.close()
      }
    }
  }
