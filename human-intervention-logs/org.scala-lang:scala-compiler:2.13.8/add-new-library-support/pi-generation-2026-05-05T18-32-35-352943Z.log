[tool-call] delta {"path":"tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/SimpleVerifierTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.tools.asm.ClassReader\nimport scala.tools.asm.tree.{ClassNode, MethodNode}\nimport scala.tools.asm.tree.analysis.{Analyzer, Frame, SimpleVerifier}\n\nclass SimpleVerifierTest {\n  @Test\n  def resolvesClassesDuringBytecodeAnalysis(): Unit = {\n    val reader: ClassReader = new ClassReader(AsmTestClasses.mergeFramesClassBytes())\n    val node: ClassNode = new ClassNode\n    reader.accept(node, 0)\n    val method: MethodNode = node.methods.get(1).asInstanceOf[MethodNode]\n    val frames: Array[Frame[_]] = new Analyzer(new SimpleVerifier).analyze(node.name, method)\n    assertThat(frames.length).isGreaterThan(0)\n  }\n}\n"}
