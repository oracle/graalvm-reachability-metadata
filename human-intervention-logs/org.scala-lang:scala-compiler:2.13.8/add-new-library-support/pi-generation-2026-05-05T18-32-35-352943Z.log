  package org_scala_lang.scala_compiler
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import scala.tools.nsc.interpreter.IMain
  import scala.tools.nsc.interpreter.shell.{JavapProvider, JavapTool}
  
  class JavapProviderAnonymous5Test {
    @Test
    def runsToolProviderBackedJavapTool(): Unit = {
      val intp: IMain = ScalaCompilerTestSupport.newInterpreter()
      try {
        val provider: JavapProvider = new JavapProvider(intp)
        val tool: JavapTool = provider.task(getClass.getClassLoader).toOption.get
        val results = tool(Seq("-classpath", System.getProperty("java.class.path")), filter = false)(Seq(JavapTool.Input("java.lang.String", "java.lang.String", scala.util.Success(Array.emptyByteArray))))
        assertThat(results.nonEmpty).isTrue
      } finally intp.close()
    }
  }
