[tool-call] delta {"path":"tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/PluginTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.net.URLClassLoader\nimport java.nio.file.{Files, Path}\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.reflect.io.Path.string2path\nimport scala.tools.nsc.Global\nimport scala.tools.nsc.plugins.{Plugin, PluginLoadException}\nimport scala.tools.nsc.reporters.StoreReporter\n\nclass PluginTest {\n  @Test\n  def loadsPluginDescriptorAndInstantiatesPlugin(): Unit = {\n    ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n      ScalaCompilerTestSupport.withTempDir(\"scalac-plugin\") { dir =>\n        ScalaCompilerTestSupport.writePluginDescriptor(dir, classOf[ReachabilityTestCompilerPlugin].getName)\n        val loader: URLClassLoader = ScalaCompilerTestSupport.newPluginClassLoader(dir)\n        try {\n          val loaded = Plugin.loadAllFrom(List(List(string2path(dir.toString))), Nil, Nil, _ => loader)\n          assertThat(loaded.size).isEqualTo(1)\n          val classes: Path = dir.resolve(\"classes\")\n          Files.createDirectories(classes)\n          val global: Global = new Global(ScalaCompilerTestSupport.compilerSettings(classes), new StoreReporter)\n          assertThat(Plugin.instantiate(loaded.head.get, global).name).isEqualTo(\"reachability-test-plugin\")\n        } finally loader.close()\n      }\n    }\n  }\n}\n"}
