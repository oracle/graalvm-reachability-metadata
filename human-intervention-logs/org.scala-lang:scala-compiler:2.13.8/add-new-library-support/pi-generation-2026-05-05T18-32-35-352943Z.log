[tool-call] delta {"path":"tests/src/org.scala-lang/scala-compiler/2.13.8/src/test/scala/org_scala_lang/scala_compiler/PluginsAnonymous1Test.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_compiler\n\nimport java.net.URL\nimport java.nio.file.{Files, Path => NioPath}\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.jdk.CollectionConverters._\nimport scala.reflect.io.{Path => ReflectPath}\nimport scala.tools.nsc.{Global, Settings}\nimport scala.tools.nsc.plugins.Plugin\nimport scala.tools.nsc.reporters.StoreReporter\n\nclass PluginsAnonymous1Test {\n  @Test\n  def compilerPluginClassLoaderFindsOnlyItsPluginDescriptor(): Unit = {\n    ScalaCompilerTestSupport.allowUnsupportedNativeImageFeature {\n      ScalaCompilerTestSupport.withTempDir(\"plugin-loader\") { dir =>\n        ScalaCompilerTestSupport.writePluginDescriptor(dir, classOf[ReachabilityTestCompilerPlugin].getName)\n        val global: ExposedPluginGlobal = new ExposedPluginGlobal(new Settings, new StoreReporter)\n        val loader: ClassLoader = global.exposePluginClassLoader(Seq(ReflectPath(dir.toString)))\n        val resource: URL = loader.getResource(Plugin.PluginXML)\n        assertThat(resource).isNotNull\n        assertThat(loader.getResources(Plugin.PluginXML).asScala.toList).isNotEmpty\n      }\n    }\n  }\n\n  private class ExposedPluginGlobal(settings: Settings, reporter: StoreReporter) extends Global(settings, reporter) {\n    def exposePluginClassLoader(paths: Seq[ReflectPath]): ClassLoader = findPluginClassLoader(paths)\n  }\n}\n"}
