      // Instance Members -------------------------------------------------------------------||
      // -------------------------------------------------------------------------------------||
  
      /**
       * Configuration for all archives created from this factory
       */
      private final Configuration configuration;
  
      // -------------------------------------------------------------------------------------||
      // Constructor ------------------------------------------------------------------------||
      // -------------------------------------------------------------------------------------||
  
      /**
