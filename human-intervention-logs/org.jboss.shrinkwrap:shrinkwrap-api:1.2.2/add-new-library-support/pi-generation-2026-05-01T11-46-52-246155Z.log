[tool-call] delta {"path":"tests/src/org.jboss.shrinkwrap/shrinkwrap-api/1.2.2/src/test/java/org_jboss_shrinkwrap/shrinkwrap_api/SecurityActionsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_shrinkwrap.shrinkwrap_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SecurityActionsTest {\n    @Test\n    void createsInstanceFromClassNameWithConstructorArguments() throws Exception {\n        Method newInstance = Class.forName(\"org.jboss.shrinkwrap.api.SecurityActions\").getDeclaredMethod(\n            \"newInstance\",\n            String.class,\n            Class[].class,\n            Object[].class,\n            Class.class,\n            ClassLoader.class);\n        newInstance.setAccessible(true);\n\n        Object created = newInstance.invoke(\n            null,\n            Constructible.class.getName(),\n            new Class<?>[] { String.class, int.class },\n            new Object[] { \"shrinkwrap\", 42 },\n            Constructible.class,\n            Constructible.class.getClassLoader());\n\n        assertThat(created).isInstanceOf(Constructible.class);\n        Constructible constructible = (Constructible) created;\n        assertThat(constructible.getName()).isEqualTo(\"shrinkwrap\");\n        assertThat(constructible.getNumber()).isEqualTo(42);\n    }\n\n    public static final class Constructible {\n        private final String name;\n        private final int number;\n\n        public Constructible(String name, int number) {\n            this.name = name;\n            this.number = number;\n        }\n\n        String getName() {\n            return name;\n        }\n\n        int getNumber() {\n            return number;\n        }\n    }\n}\n"}
