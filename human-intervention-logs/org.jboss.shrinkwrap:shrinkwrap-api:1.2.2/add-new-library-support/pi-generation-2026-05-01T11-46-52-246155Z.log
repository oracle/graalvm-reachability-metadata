   */
  public final class ArchiveFactory {
      // -------------------------------------------------------------------------------------||
      // Class Members ----------------------------------------------------------------------||
      // -------------------------------------------------------------------------------------||
  
      /**
       * Implementation class name backing {@link Archive}s to be created
       */
      private static final String ARCHIVE_IMPL = "org.jboss.shrinkwrap.impl.base.MemoryMapArchiveImpl";
  
