        fa.imap(iso.to)(iso.from)
  
    extension [F[_], A <: Tuple](fa: F[A])
      inline def dropUnits(using Invariant[F]): F[DropUnits[A]] =
        fa.imap(DropUnits.drop(_))(DropUnits.insert(_))
