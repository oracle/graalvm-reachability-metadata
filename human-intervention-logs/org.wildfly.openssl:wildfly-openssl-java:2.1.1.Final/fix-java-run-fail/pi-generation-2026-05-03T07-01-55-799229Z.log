  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  repositories {
      exclusiveContent {
          forRepository {
              mavenCentral {
                  metadataSources {
                      artifact()
