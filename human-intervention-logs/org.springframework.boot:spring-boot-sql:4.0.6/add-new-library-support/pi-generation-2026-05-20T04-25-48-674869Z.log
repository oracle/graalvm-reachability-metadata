     184	    void conditionalOnSqlInitializationMatchesUnlessModeIsNever() {
     185	        TestDatabaseInitializationCondition condition = new TestDatabaseInitializationCondition();
     186	
     187	        assertThat(matchOutcome(condition, null).isMatch()).isTrue();
     188	        assertThat(matchOutcome(condition, "always").isMatch()).isTrue();
     189	        assertThat(matchOutcome(condition, "never").isMatch()).isFalse();
     190	        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode("always")) {
     191	            assertThat(context.containsBean("sqlInitializationAwareBean")).isTrue();
     192	        }
     193	    }
