         \"spring.sql.init.platform\", \"postgresql\",\n    61\t                \"spring.sql.init.continue-on-error\", \"true\",\n    62\t                \"spring.sql.init.separator\", \"@@\",\n    63\t                \"spring.sql.init.encoding\", \"UTF-8\",\n    64\t                \"spring.sql.init.mode\", \"always\",\n    65\t                \"spring.sql.init.username\", \"schema-owner\",\n    66\t                \"spring.sql.init.password\", \"secret\")));\n    67\t\n    68\t        SqlInitializationProperties properties = Binder.get(environment)\n    69\t                .bind(\"spring.sql.init\", SqlInitializationProperties.class)\n    70\t                .get();\n    71\t        DatabaseInitializationSettings settings = ApplicationScriptDatabaseInitializer.getSettings(properties);\n    72\t\n    73\t        assertThat(properties.getPlatform()).isEqualTo(\"postgresql\");\n    74\t        assertThat(properties.getUsername()).isEqualTo(\"schema-owner\");\n    75\t        assertThat(properties.getPassword()).isEqualTo(\"secret\");\n    76\t        assertThat(settings.getSchemaLocations()).containsExactly(\"optional:classpath*:schema-postgresql.sql\",\n    77\t                \"optional:classpath*:schema.sql\");\n    78\t        assertThat(settings.getDataLocations()).containsExactly(\"optional:classpath*:data-postgresql.sql\",\n    79\t                \"optional:classpath*:data.sql\");\n    80\t        assertThat(settings.isContinueOnError()).isTrue();\n   175\t        assertThat(nonEmbeddedInitializer.initializeDatabase()).isFalse();\n   176\t        assertThat(nonEmbeddedInitializer.batches()).isEmpty();\n   177\t        assertThat(embeddedInitializer.initializeDatabase()).isTrue();\n   178\t        assertThat(embeddedInitializer.batches()).singleElement()\n   179\t                .extracting(RecordedScripts::resourceNames)\n   180\t                .isEqualTo(List.of(schema.getFileName().toString()));\n   181\t    }\n   182\t\n   183\t    @Test\n   184\t    void conditionalOnSqlInitializationMatchesUnlessModeIsNever() {\n   185\t        TestDatabaseInitializationCondition condition = new TestDatabaseInitializationCondition();\n   186\t\n   187\t        assertThat(matchOutcome(condition, null).isMatch()).isTrue();\n   188\t        assertThat(matchOutcome(condition, \"always\").isMatch()).isTrue();\n   189\t        assertThat(matchOutcome(condition, \"never\").isMatch()).isFalse();\n   190\t        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode(\"always\")) {\n   191\t            assertThat(context.containsBean(\"sqlInitializationAwareBean\")).isTrue();\n   192\t        }\n   193\t    }\n   194\t\n   195\t    @Test\n   196\t    void publicDatabaseInitializationDetectorsFindBeansByType() {\n   197\t        try (AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext(\n   198\t                DetectorSampleConfiguration.class)) {\n   199\t            ConfigurableListableBeanFactory beanFactory = context.getBeanFactory();\n   200\t            DatabaseInitializerDetector initializerDetector = new SampleDatabaseInitializerDetector();\n   201\t            DependsOnDatabaseInitializationDetector dependencyDetector = new SampleDependsOnInitializationDetector();\n   202\t\n   203\t            assertThat(initializerDetector.detect(beanFactory)).containsExactly(\"sampleInitializer\");\n   204\t            assertThat(dependencyDetector.detect(beanFactory)).containsExactlyInAnyOrder(\"annotatedDependent\",\n   205\t                    \"sampleDependent\");\n   206\t            assertThat(beanFactory.findAnnotationOnBean(\"annotatedDependent\", DependsOnDatabaseInitialization.class))\n   207\t                    .isNotNull();\n   208\t            assertThat(beanFactory.findAnnotationOnBean(\"sampleDependent\", DependsOnDatabaseInitialization.class))\n   209\t                    .isNull();\n   210\t            assertThat(initializerDetector.getOrder()).isZero();\n   211\t        }\n   212\t    }\n   213\t\n   214\t    private static Path writeScript(Path directory, String name, String content) throws IOException {\n   215\t        Path script = directory.resolve(name);\n   216\t        Files.writeString(script, content, StandardCharsets.UTF_8);\n   217\t        return script;\n   218\t    }\n   219\t\n   220\t    private static String fileUri(Path path) {\n   221\t        URI uri = path.toUri();\n   222\t        return uri.toString();\n   223\t    }\n   224\t\n   225\t    private static ResourceLoader resourceLoader() {\n   226\t        return new DefaultResourceLoader(Spring_boot_sqlTest.class.getClassLoader());\n   227\t    }\n   228\t\n   229\t    private static AnnotationConfigApplicationContext contextWithSqlInitializationMode(String mode) {\n   230\t        AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext();\n   231\t        if (mode != null) {\n   232\t            context.getEnvironment()\n   233\t                    .getPropertySources()\n   234\t                    .addFirst(new MapPropertySource(\"test\", Map.of(\"spring.sql.init.mode\", mode)));\n   235\t        }\n   236\t        context.register(ConditionalSqlInitializationConfiguration.class);\n   237\t        context.refresh();\n   238\t        return context;\n   239\t    }\n   240\t\n   241\t    private static ConditionOutcome matchOutcome(TestDatabaseInitializationCondition condition, String mode) {\n   242\t        StandardEnvironment environment = new StandardEnvironment();\n   243\t        if (mode != null) {\n   244\t            environment.getPropertySources()\n   245\t                    .addFirst(new MapPropertySource(\"test\", Map.of(\"spring.sql.init.mode\", mode)));\n   246\t        }\n   247\t        return condition.getMatchOutcome(new TestConditionContext(environment), new EmptyAnnotatedTypeMetadata());\n   248\t    }\n   249\t\n   250\t    private record RecordedScripts(List<String> resourceNames, boolean continueOnError, String separator,\n   251\t            String encoding) {\n   252\t    }\n   253\t\n   254\t    private record TestConditionContext(Environment environment) implements ConditionContext {\n   255\t\n   256\t        @Override\n   257\t        public BeanDefinitionRegistry getRegistry() {\n   258\t            return null;\n   259\t        }\n   260\t\n   261\t        @Override\n   262\t        public ConfigurableListableBeanFactory getBeanFactory() {\n   263\t            return null;\n   264\t        }\n   265\t\n   266\t        @Override\n   267\t        public Environment getEnvironment() {\n   268\t            return this.environment;\n   269\t        }\n   270\t\n   271\t        @Override\n   272\t        public ResourceLoader getResourceLoader() {\n   273\t            return resourceLoader();\n   274\t        }\n   275\t\n   276\t        @Override\n   277\t        public ClassLoader getClassLoader() {\n   278\t            return Spring_boot_sqlTest.class.getClassLoader();\n   279\t        }\n   280\t\n"}], "isError": false, "timestamp": 1779251205702}]}
