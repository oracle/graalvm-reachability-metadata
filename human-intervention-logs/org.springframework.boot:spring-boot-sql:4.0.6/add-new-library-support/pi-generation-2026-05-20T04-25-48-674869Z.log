     197	        try (AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext(
     198	                DetectorSampleConfiguration.class)) {
     199	            ConfigurableListableBeanFactory beanFactory = context.getBeanFactory();
     200	            DatabaseInitializerDetector initializerDetector = new SampleDatabaseInitializerDetector();
     201	            DependsOnDatabaseInitializationDetector dependencyDetector = new SampleDependsOnInitializationDetector();
     202	
     203	            assertThat(initializerDetector.detect(beanFactory)).containsExactly("sampleInitializer");
