io.support.ResourcePatternResolver;\nimport org.springframework.core.io.support.SpringFactoriesLoader;\n"},{"oldText":"    @Test\n    void conditionalOnSqlInitializationMatchesWhenModeAllowsInitialization() {\n        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode(null)) {\n            assertThat(context.containsBean(\"sqlInitializationConditionalBean\")).isTrue();\n            assertThat(context.getBean(SqlInitializationConditionalBean.class)).isNotNull();\n        }\n        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode(\"always\")) {\n            assertThat(context.containsBean(\"sqlInitializationConditionalBean\")).isTrue();\n        }\n        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode(\"never\")) {\n            assertThat(context.containsBean(\"sqlInitializationConditionalBean\")).isFalse();\n            assertThat(context.getBeanNamesForType(SqlInitializationConditionalBean.class)).isEmpty();\n        }\n    }\n","newText":"    @Test\n    void springFactoriesDetectorFindsBeansAnnotatedWithDependsOnDatabaseInitialization() {\n        try (GenericApplicationContext context = new GenericApplicationContext()) {\n            context.registerBean(\"annotatedDependent\", AnnotatedDatabaseDependentBean.class);\n            context.registerBean(\"plainDependent\", PlainDatabaseDependentBean.class);\n\n            List<DependsOnDatabaseInitializationDetector> detectors = SpringFactoriesLoader\n                .forDefaultResourceLocation(context.getClassLoader())\n                .load(DependsOnDatabaseInitializationDetector.class);\n\n            assertThat(detectors).isNotEmpty();\n            assertThat(detectors).anySatisfy((detector) -> assertThat(detector.detect(context.getBeanFactory()))\n                .containsExactly(\"annotatedDependent\"));\n        }\n    }\n"},{"oldText":"    private static AnnotationConfigApplicationContext contextWithSqlInitializationMode(String mode) {\n        AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext();\n        if (mode != null) {\n            context.getEnvironment()\n                .getPropertySources()\n                .addFirst(new MapPropertySource(\"testProperties\", Map.of(\"spring.sql.init.mode\", mode)));\n        }\n        context.register(SqlInitializationConditionalConfiguration.class);\n        context.refresh();\n        return context;\n    }\n\n","newText":""},{"oldText":"    @Configuration(proxyBeanMethods = false)\n    public static class SqlInitializationConditionalConfiguration {\n\n        @Bean\n        @ConditionalOnSqlInitialization\n        public SqlInitializationConditionalBean sqlInitializationConditionalBean() {\n            return new SqlInitializationConditionalBean();\n        }\n\n    }\n\n    public static final class SqlInitializationConditionalBean {\n    }\n\n    private static final class TestDatabaseInitializer {\n","newText":"    @DependsOnDatabaseInitialization\n    private static final class AnnotatedDatabaseDependentBean {\n    }\n\n    private static final class PlainDatabaseDependentBean {\n    }\n\n    private static final class TestDatabaseInitializer {\n"}]}
