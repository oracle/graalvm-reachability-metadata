[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot-sql/4.0.6/src/test/java/org_springframework_boot/spring_boot_sql/Spring_boot_sqlTest.java","edits":[{"oldText":"import org.springframework.beans.factory.support.BeanDefinitionRegistry;\nimport org.springframework.boot.sql.autoconfigure.init.ApplicationScriptDatabaseInitializer;\nimport org.springframework.boot.sql.autoconfigure.init.SqlInitializationProperties;\n","newText":"import org.springframework.beans.factory.support.BeanDefinitionRegistry;\nimport org.springframework.boot.sql.autoconfigure.init.ApplicationScriptDatabaseInitializer;\nimport org.springframework.boot.sql.autoconfigure.init.ConditionalOnSqlInitialization;\nimport org.springframework.boot.sql.autoconfigure.init.SqlInitializationProperties;\n"},{"oldText":"import org.springframework.context.support.GenericApplicationContext;\nimport org.springframework.core.io.ByteArrayResource;\n","newText":"import org.springframework.context.annotation.AnnotationConfigApplicationContext;\nimport org.springframework.context.annotation.Bean;\nimport org.springframework.context.annotation.Configuration;\nimport org.springframework.context.support.GenericApplicationContext;\nimport org.springframework.core.env.MapPropertySource;\nimport org.springframework.core.io.ByteArrayResource;\n"},{"oldText":"    @Test\n    void dependencyConfigurerRegistersItsBeanFactoryPostProcessorOnlyOnce() {\n        try (GenericApplicationContext context = new GenericApplicationContext()) {\n            DatabaseInitializationDependencyConfigurer configurer = new DatabaseInitializationDependencyConfigurer();\n            BeanDefinitionRegistry registry = context;\n\n            configurer.registerBeanDefinitions(null, registry);\n            configurer.registerBeanDefinitions(null, registry);\n\n            assertThat(context.getBeanDefinitionNames())\n                .filteredOn((name) -> name.contains(\"DependsOnDatabaseInitializationPostProcessor\"))\n                .hasSize(1);\n        }\n    }\n\n    private static DatabaseInitializationSettings scriptSettings(DatabaseInitializationMode mode) {\n","newText":"    @Test\n    void dependencyConfigurerRegistersItsBeanFactoryPostProcessorOnlyOnce() {\n        try (GenericApplicationContext context = new GenericApplicationContext()) {\n            DatabaseInitializationDependencyConfigurer configurer = new DatabaseInitializationDependencyConfigurer();\n            BeanDefinitionRegistry registry = context;\n\n            configurer.registerBeanDefinitions(null, registry);\n            configurer.registerBeanDefinitions(null, registry);\n\n            assertThat(context.getBeanDefinitionNames())\n                .filteredOn((name) -> name.contains(\"DependsOnDatabaseInitializationPostProcessor\"))\n                .hasSize(1);\n        }\n    }\n\n    @Test\n    void conditionalOnSqlInitializationMatchesWhenModeAllowsInitialization() {\n        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode(null)) {\n            assertThat(context.containsBean(\"sqlInitializationConditionalBean\")).isTrue();\n            assertThat(context.getBean(SqlInitializationConditionalBean.class)).isNotNull();\n        }\n        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode(\"always\")) {\n            assertThat(context.containsBean(\"sqlInitializationConditionalBean\")).isTrue();\n        }\n        try (AnnotationConfigApplicationContext context = contextWithSqlInitializationMode(\"never\")) {\n            assertThat(context.containsBean(\"sqlInitializationConditionalBean\")).isFalse();\n            assertThat(context.getBeanNamesForType(SqlInitializationConditionalBean.class)).isEmpty();\n        }\n    }\n\n    private static DatabaseInitializationSettings scriptSettings(DatabaseInitializationMode mode) {\n"},{"oldText":"    private static Resource resource(String filename, String content, String url) {\n        return new ByteArrayResource(content.getBytes(StandardCharsets.UTF_8), filename) {\n","newText":"    private static AnnotationConfigApplicationContext contextWithSqlInitializationMode(String mode) {\n        AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext();\n        if (mode != null) {\n            context.getEnvironment()\n                .getPropertySources()\n                .addFirst(new MapPropertySource(\"testProperties\", Map.of(\"spring.sql.init.mode\", mode)));\n        }\n        context.register(SqlInitializationConditionalConfiguration.class);\n        context.refresh();\n        return context;\n    }\n\n    private static Resource resource(String filename, String content, String url) {\n        return new ByteArrayResource(content.getBytes(StandardCharsets.UTF_8), filename) {\n"},{"oldText":"    private static final class TestDatabaseInitializer {\n    }\n\n    private static final class ReportingService {\n    }\n\n}\n","newText":"    @Configuration(proxyBeanMethods = false)\n    private static class SqlInitializationConditionalConfiguration {\n\n        @Bean\n        @ConditionalOnSqlInitialization\n        SqlInitializationConditionalBean sqlInitializationConditionalBean() {\n            return new SqlInitializationConditionalBean();\n        }\n\n    }\n\n    private static final class SqlInitializationConditionalBean {\n    }\n\n    private static final class TestDatabaseInitializer {\n    }\n\n    private static final class ReportingService {\n    }\n\n}\n"}]}
