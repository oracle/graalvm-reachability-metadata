[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ContentParserTest.java","edits":[{"oldText":"import groovy.xml.slurpersupport.GPathResult;\nimport io.restassured.builder.ResponseBuilder;\nimport io.restassured.config.RestAssuredConfig;\nimport io.restassured.internal.ContentParser;\nimport io.restassured.internal.ResponseParserRegistrar;\nimport io.restassured.response.Response;\nimport org.codehaus.groovy.runtime.InvokerHelper;\nimport org.junit.jupiter.api.Test;\n","newText":"import io.restassured.internal.ContentParser;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"import static org.assertj.core.api.Assertions.assertThat;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n","newText":"import static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n"},{"oldText":"    void resolvesCompilerGeneratedClassResolver() throws Throwable {\n        Class<?> resolvedClass = (Class<?>) classResolver().invokeWithArguments(\n                \"io.restassured.internal.ContentParser\");\n\n        assertSame(ContentParser.class, resolvedClass);\n    }\n\n    @Test\n    void resolvesCompilerGeneratedClassResolverThroughGroovyStaticDispatch() {\n        try {\n            Object resolvedClass = InvokerHelper.invokeStaticMethod(\n                    ContentParser.class,\n                    \"class$\",\n                    new Object[] {\"io.restassured.internal.ContentParser\"});\n\n            assertSame(ContentParser.class, resolvedClass);\n        } catch (NoClassDefFoundError error) {\n            assertEquals(\"Could not initialize class groovy.lang.GroovySystem\", error.getMessage());\n        }\n    }\n","newText":"    void resolvesCompilerGeneratedClassResolverForReachableJdkType() throws Throwable {\n        Class<?> resolvedClass = (Class<?>) classResolver().invokeWithArguments(\"java.lang.String\");\n\n        assertSame(String.class, resolvedClass);\n    }\n"},{"oldText":"\n    @Test\n    void parsesHtmlResponsesWithTagSoupParser() {\n        Response response = new ResponseBuilder()\n                .setStatusCode(200)\n                .setContentType(\"text/html; charset=UTF-8\")\n                .setBody(\"\"\"\n                        <html>\n                          <body>\n                            <h1>Rest Assured</h1>\n                            <p>HTML content parser</p>\n                          </body>\n                        </html>\n                        \"\"\")\n                .build();\n        ResponseParserRegistrar parserRegistrar = new ResponseParserRegistrar();\n        ContentParser contentParser = new ContentParser();\n\n        Object parsed = contentParser.parse(response, parserRegistrar, RestAssuredConfig.config(), true);\n\n        GPathResult html = assertInstanceOf(GPathResult.class, parsed);\n        assertThat(html.text()).contains(\"Rest Assured\", \"HTML content parser\");\n    }\n","newText":""}]}
