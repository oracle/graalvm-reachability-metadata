        if (config == null) {
          cfg = new EncoderConfig()
        } else {
          cfg = config.getEncoderConfig()
        }
  
        if (cfg.hasDefaultCharsetForContentType(contentType)) {
          charset = cfg.defaultCharsetForContentType(contentType)
        } else {
          charset = cfg.defaultContentCharset()
        }
      }
      charset
    }
  
