.py:234:                self._print_dynamic_access_detail(\"agent: running dynamic-access prompt\", indent_level=2)\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:297:                        \"result: dynamic-access report unavailable after test run\",\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:370:                        f\"Partial dynamic-access coverage for {class_name} \"\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:556:        \"\"\"Regenerate the dynamic-access report after the gate to reflect new coverage.\"\"\"\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:576:        \"\"\"Start resumable chunking when the first dynamic-access report is too large.\"\"\"\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:598:            \"Large dynamic-access report detected; starting large-library series \"\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:856:                \"Coverage report loaded but contains no usable dynamic-access guidance:\",\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:932:        log_stage(\"dynamic-access\", message)\nforge/ai_workflows/workflow_strategies/dynamic_access_iterative_strategy.py:936:        log_stage(\"dynamic-access\", message, indent_level=indent_level)\nforge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:26:    \"\"\"Bulk dynamic-access coverage strategy that shows the full report to the agent.\"\"\"\nforge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:28:    REQUIRED_PROMPTS = [\"optimistic-dynamic-access-iteration\"]\nforge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:52:            \"dynamic-access\",\nforge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:53:            \"dynamic-access-coverage.json\",\nforge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:93:                \"optimistic-dynamic-access-iteration\",\nforge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:151:                self._print_detail(\"result: dynamic-access report unavailable after test run\")\nforge/ai_workflows/workflow_strategies/optimistic_dynamic_access_strategy.py:155:                \"Optimistic dynamic-access coverage ({covered}/{total})\".format(\nforge/ai_workflows/workflow_strategies/increase_dynamic_access_coverage_strategy.py:16:    \"\"\"Composite strategy that runs a primary workflow then improves dynamic-access coverage.\"\"\"\nforge/ai_workflows/workflow_strategies/increase_dynamic_access_coverage_strategy.py:39:            self._print_message(\"no primary workflow configured, skipping to dynamic-access coverage phase\")\nforge/ai_workflows/workflow_strategies/increase_dynamic_access_coverage_strategy.py:50:                self._print_message(\"skipping dynamic-access coverage phase because primary workflow did not succeed\")\nforge/ai_workflows/workflow_strategies/increase_dynamic_access_coverage_strategy.py:56:        self._print_message(\"starting dynamic-access coverage phase\")\nforge/ai_workflows/workflow_strategies/increase_dynamic_access_coverage_strategy.py:65:            \"dynamic-access coverage phase completed with phase_ok={phase_ok}, iterations_added={iterations}\".format(\nforge/ai_workflows/workflow_strategies/increase_dynamic_access_coverage_strategy.py:72:            self._print_message(\"keeping primary workflow result because dynamic-access coverage phase did not succeed\")\nforge/DEVELOPING.md:98:  [--keep-tests-without-dynamic-access] \\\nforge/DEVELOPING.md:123:- `--keep-tests-without-dynamic-access` keeps generated tests for dynamic-access workflows even if no dynamic-access call sites are covered.\nforge/DEVELOPING.md:383:coordinates, active dynamic-access classes, source-context paths, and Gradle\nforge/DEVELOPING.md:41