ass);\n    }\n\n    @Test\n    void reportsMissingRecordedResponseTime() {\n        ResponseTimeMatcher matcher = new ResponseTimeMatcher();\n        matcher.setMatcher(lessThan(1L));\n        matcher.setTimeUnit(TimeUnit.MILLISECONDS);\n        Response response = new ResponseBuilder()\n                .setStatusCode(200)\n                .setBody(\"ok\")\n                .build();\n\n        @SuppressWarnings(\"unchecked\")\n        Map<String, Object> validation = (Map<String, Object>) matcher.validate(response);\n\n        assertEquals(false, validation.get(\"success\"));\n        assertEquals(\n                \"No time was recorded, cannot perform response time validation.\",\n                validation.get(\"errorMessage\"));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2533, "output": 979, "cacheRead": 39936, "cacheWrite": 0, "totalTokens": 43448, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778414807857, "responseId": "resp_0e37602f17d8710d016a0074d893e881a2ad6a471ed8d94346"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wpfLDa9OKBPMnTeaPwxqzF8E|fc_0e37602f17d8710d016a0074df8f6081a2a644c768117b133e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1773 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseTimeMatcherTest.java"}], "isError": false, "timestamp": 1778414818245}]}
