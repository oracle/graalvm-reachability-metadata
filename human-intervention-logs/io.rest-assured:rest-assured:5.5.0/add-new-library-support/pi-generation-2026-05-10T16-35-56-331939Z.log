          this(urlEncodingEnabled, encoderConfig, decoderConfig, oAuthConfig, client);
          try {
              this.defaultURI = new URIBuilder(URIBuilder.convertToURI(defaultURI), this.urlEncodingEnabled, this.encoderConfig);
