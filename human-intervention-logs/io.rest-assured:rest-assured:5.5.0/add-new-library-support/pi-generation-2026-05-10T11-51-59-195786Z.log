          return this;
      }
  
      /**
       * Syntactic sugar.
       *
       * @return The same SSL config instance.
       */
      public SSLConfig with() {
          return this;
      }
  
      /**
       * Syntactic sugar.
       *
       * @return The same SSL config instance.
       */
      public SSLConfig using() {
          return this;
      }
  
