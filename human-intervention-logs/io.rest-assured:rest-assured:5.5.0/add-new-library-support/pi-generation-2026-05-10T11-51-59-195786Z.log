ted rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport io.restassured.config.SSLConfig;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.IOException;\n\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\npublic class SSLConfigTest {\n    private static final String PASSWORD = \"changeit\";\n\n    @Test\n    void relaxedHttpsValidationLoadsKeyStoreFromContextClassLoaderResource() {\n        SSLConfig sslConfig = new SSLConfig()\n                .keyStore(\"io/restassured/config/SSLConfig.class\", PASSWORD);\n\n        assertThrows(IOException.class, sslConfig::relaxedHTTPSValidation);\n    }\n\n    @Test\n    void relaxedHttpsValidationFallsBackToClassResourceWhenContextClassLoaderResourceIsMissing() {\n        SSLConfig sslConfig = new SSLConfig()\n                .keyStore(\"/io/restassured/config/SSLConfig.class\", PASSWORD);\n\n        assertThrows(IOException.class, sslConfig::relaxedHTTPSValidation);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 23797, "output": 1188, "cacheRead": 14336, "cacheWrite": 0, "totalTokens": 39321, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778413871400, "responseId": "resp_0c159a8a545a324f016a0071301730819e89408eb21a9c4df6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_GsnyAvWyTThpgI3ediiuclY7|fc_0c159a8a545a324f016a00713e2368819e84fdb4dbd7641613", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1110 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/SSLConfigTest.java"}], "isError": false, "timestamp": 1778413887192}]}
