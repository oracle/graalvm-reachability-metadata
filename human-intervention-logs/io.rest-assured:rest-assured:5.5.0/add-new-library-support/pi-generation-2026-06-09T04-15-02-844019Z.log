KoPwpA==\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_MVuCn57l80PZBTWEugA6TRji|fc_01d22c7984dca3b6016a27932ead708193a826803748b131bd", "name": "write", "arguments": {"path": "tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_sendRequest_closure15Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.response.Response;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RequestSpecificationImplInner_sendRequest_closure15Test {\n    @Test\n    void sendsConfiguredCookiesWithRequest() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/cookies\", RequestSpecificationImplInner_sendRequest_closure15Test::handleCookies);\n        server.setExecutor(executor);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Response response = given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .cookie(\"session\", \"native\")\n                    .when()\n                    .get(\"/cookies\");\n\n            assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_OK);\n            assertThat(response.asString()).isEqualTo(\"session=native\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void handleCookies(HttpExchange exchange) throws IOException {\n        try {\n            String cookieHeader = exchange.getRequestHeaders().getFirst(\"Cookie\");\n            byte[] responseBytes = cookieHeader.getBytes(StandardCharsets.UTF_8);\n\n            exchange.getResponseHeaders().set(\"Content-Type\", \"text/plain; charset=utf-8\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);\n            try (OutputStream outputStream = exchange.getResponseBody()) {\n                outputStream.write(responseBytes);\n            }\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 688, "output": 1077, "cacheRead": 27136, "cacheWrite": 0, "totalTokens": 28901, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780978466705, "responseId": "resp_01d22c7984dca3b6016a2793233a6c8193a3723ac27ae7eab2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_MVuCn57l80PZBTWEugA6TRji|fc_01d22c7984dca3b6016a27932ead708193a826803748b131bd", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2631 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_sendRequest_closure15Test.java"}], "isError": false, "timestamp": 1780978485254}]}
