          } catch (LinkageError error) {
              assertNativeGroovyInitializationFailure(error);
          } catch (Error error) {
              rethrowUnlessUnsupportedNativeImageError(error);
          }
      }
  
      @Test
      void requestWithTooFewUnnamedPathParametersReportsUndefinedPlaceholder() {
          try {
              RestAssured.given()
                      .baseUri("http://127.0.0.1")
                      .get("/orders/{orderId}/items/{itemId}", "A-1");
              throw new AssertionError("Undefined path parameters should be rejected before the request is sent");
          } catch (IllegalArgumentException exception) {
              assertTrue(exception.getMessage().contains("Invalid number of path parameters."));
              assertTrue(exception.getMessage().contains("Undefined path parameters are:"));
              assertTrue(exception.getMessage().contains("itemId"));
          } catch (LinkageError error) {
              assertNativeGroovyInitializationFailure(error);
          } finally {
