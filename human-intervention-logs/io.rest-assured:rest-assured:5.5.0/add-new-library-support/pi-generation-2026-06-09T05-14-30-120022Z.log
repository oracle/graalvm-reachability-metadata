\nUpdates:\n- Keeps the public Rest Assured failure-listener behavior path.\n- Moves the generated `class$` helper invocation into the configured `ResponseValidationFailureListener`, so it runs while `fireFailureListeners` is executing the active closure.\n- Verifies the listener ran and observed the actual response status.\n\nI did not run tests, per instruction.", "textSignature": "{\"v\":1,\"id\":\"msg_072dc9e8eca51d32016a27a2b4ddc88197a25f45b0a2323b09\",\"phase\":\"final_answer\"}"}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1313, "output": 985, "cacheRead": 51712, "cacheWrite": 0, "totalTokens": 54010, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "stop", "timestamp": 1780982424375, "responseId": "resp_072dc9e8eca51d32016a27a29919188197929f11fdf1990fcb"}}
