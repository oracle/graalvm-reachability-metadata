                      .log().ifValidationFails(LogDetail.ALL)
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .when()
                      .get("/status")
                      .then()
                      .log().ifValidationFails(LogDetail.ALL)
                      .statusCode(HttpURLConnection.HTTP_CREATED));
  
              logStream.flush();
              String log = logBytes.toString(StandardCharsets.UTF_8);
