  package io.restassured.specification;
  
  import java.util.Map;
  
  /**
   * Represents one multi-part
   */
  public interface MultiPartSpecification {
      /**
       * @return The content to be sent
       */
      Object getContent();
  
      /**
       * @return The control name, may be <code>null</code>.
       */
      String getControlName();
  
      /**
       * @return The mime-type, may be <code>null</code>.
       */
      String getMimeType();
  
      /**
       * @return Headers The headers associated with this multipart specification
       */
      Map<String, String> getHeaders();
  
      /**
       * @return The charset, may be <code>null</code>.
       */
      String getCharset();
  
      /**
       * @return The fileName of the multi-part, may be <code>null</code>.
       */
      String getFileName();
  
      /**
       * @return <code>true</code> if this multi-part specification contains a filename, <code>false</code> otherwise.
       */
      boolean hasFileName();
  }
