\"\n                    {\"message\":\"%s\",\"details\":{\"count\":%d}}\n                    \"\"\".formatted(message, count).getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780939878940}}
