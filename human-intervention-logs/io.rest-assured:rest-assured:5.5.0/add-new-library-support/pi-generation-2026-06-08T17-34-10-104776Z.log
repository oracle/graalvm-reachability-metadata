  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  import java.net.HttpURLConnection;
  import java.net.InetSocketAddress;
  import java.nio.charset.StandardCharsets;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.TimeUnit;
  
  import com.sun.net.httpserver.Headers;
  import com.sun.net.httpserver.HttpExchange;
  import com.sun.net.httpserver.HttpServer;
  import io.restassured.RestAssured;
  import io.restassured.parsing.Parser;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.hamcrest.Matchers.equalTo;
  
  public class StreamVerifierTest {
      private static final String CUSTOM_JSON_CONTENT_TYPE = "application/vnd.stream-verifier+json";
  
      @Test
      void validatesJsonPathBodyAssertionThroughResponseSpecification() throws Exception {
          ExecutorService executor = Executors.newSingleThreadExecutor();
          HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
          server.createContext("/message", this::sendJsonResponse);
          server.setExecutor(executor);
          server.start();
  
          try {
              given()
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .when()
                      .get("/message")
                      .then()
                      .statusCode(HttpURLConnection.HTTP_OK)
                      .body("message", equalTo("hello"))
                      .body("details.count", equalTo(2));
          } finally {
              server.stop(0);
              executor.shutdownNow();
              executor.awaitTermination(5, TimeUnit.SECONDS);
          }
      }
  
      @Test
      void validatesJsonPathBodyAssertionWithCustomParser() throws Exception {
          ExecutorService executor = Executors.newSingleThreadExecutor();
          HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
          server.createContext("/custom-message", this::sendCustomJsonResponse);
          server.setExecutor(executor);
          server.start();
          RestAssured.registerParser(CUSTOM_JSON_CONTENT_TYPE, Parser.JSON);
  
          try {
              given()
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .when()
                      .get("/custom-message")
                      .then()
                      .statusCode(HttpURLConnection.HTTP_OK)
                      .body("message", equalTo("custom"))
                      .body("details.count", equalTo(4));
          } finally {
              RestAssured.unregisterParser(CUSTOM_JSON_CONTENT_TYPE);
              server.stop(0);
              executor.shutdownNow();
              executor.awaitTermination(5, TimeUnit.SECONDS);
          }
      }
  
      private void sendJsonResponse(HttpExchange exchange) throws IOException {
          sendJsonResponse(exchange, "application/json; charset=UTF-8", "hello", 2);
      }
  
      private void sendCustomJsonResponse(HttpExchange exchange) throws IOException {
          sendJsonResponse(exchange, CUSTOM_JSON_CONTENT_TYPE, "custom", 4);
      }
  
      private void sendJsonResponse(HttpExchange exchange, String contentType, String message, int count) throws IOException {
          try {
              Headers headers = exchange.getResponseHeaders();
              headers.add("Content-Type", contentType);
              byte[] body = """
                      {"message":"%s","details":{"count":%d}}
                      """.formatted(message, count).getBytes(StandardCharsets.UTF_8);
              exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);
              exchange.getResponseBody().write(body);
          } finally {
              exchange.close();
          }
      }
  }
