seSpecBuilder()\n                    .expectStatusCode(HttpURLConnection.HTTP_OK)\n                    .expectContentType(ContentType.JSON)\n                    .expectBody(\"message\", equalTo(\"hello\"))\n                    .build();\n\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/message\")\n                    .then()\n                    .spec(responseSpecification);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", ContentType.JSON.toString());\n            byte[] body = \"{\\\"message\\\":\\\"hello\\\"}\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1028, "output": 1075, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 22071, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780938560289, "responseId": "resp_08660d871c8c576a016a26f740c394819597a5dd6d1b03b0b5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pX0O0Qdayn5R5K5Pj1M7HY2Z|fc_08660d871c8c576a016a26f74ce2f4819595ba48203a1d524d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2583 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecBuilderTest.java"}], "isError": false, "timestamp": 178093857