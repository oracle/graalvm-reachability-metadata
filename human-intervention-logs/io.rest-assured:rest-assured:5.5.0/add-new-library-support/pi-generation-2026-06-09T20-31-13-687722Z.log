[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ParameterUpdaterInner_updateCollectionParameter_closure2Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.util.AbstractList;\nimport java.util.Arrays;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\n\nimport groovy.lang.Closure;\nimport io.restassured.RestAssured;\nimport io.restassured.specification.QueryableRequestSpecification;\nimport io.restassured.specification.RequestSpecification;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ParameterUpdaterInner_updateCollectionParameter_closure2Test {\n    private static final String CLOSURE_CLASS_NAME = \"io.restassured.internal.support.ParameterUpdater\"\n            + \"$_updateCollectionParameter_closure2\";\n\n    @Test\n    void mapQueryParametersSerializeCollectionValues() throws Throwable {\n        RestAssured.reset();\n        CapturingParameterValues tags = new CapturingParameterValues(\"native\", \"image\");\n        Map<String, Object> parameters = new LinkedHashMap<>();\n        parameters.put(\"tag\", tags);\n\n        RequestSpecification specification = RestAssured.given().queryParams(parameters);\n\n        Map<String, ?> queryParameters = ((QueryableRequestSpecification) specification).getQueryParams();\n        assertThat(queryParameters.get(\"tag\")).isEqualTo(List.of(\"native\", \"image\"));\n        Closure<?> closure = tags.getClosure();\n        assertThat(closure.getClass().getName()).isEqualTo(CLOSURE_CLASS_NAME);\n        assertThat(invokeGeneratedClassLookup(closure.getClass(), CLOSURE_CLASS_NAME)).isEqualTo(closure.getClass());\n    }\n\n    private static Class<?> invokeGeneratedClassLookup(Class<?> closureClass, String className) throws Throwable {\n        MethodHandles.Lookup closureLookup = MethodHandles.privateLookupIn(closureClass, MethodHandles.lookup());\n        MethodHandle classHelper = closureLookup.findStatic(\n                closureClass,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n        return (Class<?>) classHelper.invoke(className);\n    }\n\n    private static final class CapturingParameterValues extends AbstractList<Object> {\n        private final List<Object> values;\n        private transient Closure<?> closure;\n\n        private CapturingParameterValues(Object... values) {\n            this.values = Arrays.asList(values);\n        }\n\n        public List<String> collect(Closure<?> candidate) {\n            closure = candidate;\n            return values.stream()\n                    .map(value -> (String) candidate.call(value))\n                    .toList();\n        }\n\n        private Closure<?> getClosure() {\n            return closure;\n        }\n\n        @Override\n        public Object get(int index) {\n            return values.get(index);\n        }\n\n        @Override\n        public int size() {\n            return values.size();\n        }\n    }\n}\n"}
