;\n\npublic class ResponseSpecificationImplInner_cookies_closure8_closure19_closure20Test {\n    @Test\n    void recordsListCookieExpectationsFromMap() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\n                \"/cookies\",\n                ResponseSpecificationImplInner_cookies_closure8_closure19_closure20Test::sendCookieResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            List<Object> sessionMatchers = new ArrayList<>();\n            sessionMatchers.add(equalTo(\"abc\"));\n            sessionMatchers.add(startsWith(\"a\"));\n\n            List<Object> themeMatchers = new ArrayList<>();\n            themeMatchers.add(\"light-blue\");\n            themeMatchers.add(endsWith(\"blue\"));\n\n            Map<String, Object> expectedCookies = new LinkedHashMap<>();\n            expectedCookies.put(\"session\", sessionMatchers);\n            expectedCookies.put(\"theme\", themeMatchers);\n\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/cookies\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .cookies(expectedCookies);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendCookieResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Set-Cookie\", \"session=abc; Path=/cookies; HttpOnly\");\n            headers.add(\"Set-Cookie\", \"theme=light-blue; Path=/cookies\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, -1);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1116, "output": 985, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 22069, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780993727571, "responseId": "resp_03a18629e8232be5016a27cec01c1c819797a1c9d430a7d7e6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_q50bP8PORydW0wU7AZqsf8WA|fc_03a18629e8232be5016a27cec9c950819785a0607b45aaa27f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2938 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecificationImplInner_cookies_closure8_closure19_closure20Test.java"}], "isError": false, "timestamp": 1780993744079}]}
