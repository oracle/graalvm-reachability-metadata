  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  import java.io.OutputStream;
  import java.net.HttpURLConnection;
  import java.net.InetSocketAddress;
  import java.nio.charset.StandardCharsets;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import com.sun.net.httpserver.HttpExchange;
  import com.sun.net.httpserver.HttpServer;
  import io.restassured.RestAssured;
  import io.restassured.filter.FilterContext;
  import io.restassured.filter.time.TimingFilter;
  import io.restassured.response.Response;
  import io.restassured.specification.FilterableRequestSpecification;
  import io.restassured.specification.FilterableResponseSpecification;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RequestSpecificationImplInner_applyPathParamsAndSendRequest_closure34Test {
      @Test
      void existingTimingFilterIsRecognizedWhenSendingPathParameterizedRequest() throws Throwable {
          ExecutorService executor = Executors.newSingleThreadExecutor();
          HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
          server.createContext("/timed", exchange -> handleTimed(exchange));
          server.setExecutor(executor);
          server.start();
          RestAssured.reset();
  
          AtomicInteger timingFilterInvocations = new AtomicInteger();
  
          try {
              Response response = given()
                      .filter(new RecordingTimingFilter(timingFilterInvocations))
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .when()
                      .get("/timed/{recordId}", "42");
  
              assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_OK);
              assertThat(response.asString()).isEqualTo("timed-42");
              assertThat(timingFilterInvocations).hasValue(1);
              assertThat(response.time()).isGreaterThanOrEqualTo(0L);
          } finally {
              RestAssured.reset();
              server.stop(0);
              executor.shutdownNow();
              executor.awaitTermination(5, TimeUnit.SECONDS);
          }
      }
  
      private static void handleTimed(HttpExchange exchange) throws IOException {
          try {
              String requestPath = exchange.getRequestURI().getPath();
              String recordId = requestPath.substring(requestPath.lastIndexOf('/') + 1);
              byte[] responseBytes = ("timed-" + recordId).getBytes(StandardCharsets.UTF_8);
              exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);
              try (OutputStream outputStream = exchange.getResponseBody()) {
                  outputStream.write(responseBytes);
              }
          } finally {
              exchange.close();
          }
      }
  
      private static final class RecordingTimingFilter extends TimingFilter {
          private final AtomicInteger invocations;
  
          private RecordingTimingFilter(AtomicInteger invocations) {
              this.invocations = invocations;
          }
  
          @Override
          public Response filter(
                  FilterableRequestSpecification requestSpec,
                  FilterableResponseSpecification responseSpec,
                  FilterContext ctx) {
              invocations.incrementAndGet();
              return super.filter(requestSpec, responseSpec, ctx);
          }
      }
  }
