redMethod(\n                \"class$\", String.class);\n        classHelper.setAccessible(true);\n        String responseOptionsClassName = String.join(\n                \".\", \"io\", \"restassured\", \"internal\", \"RestAssuredResponseOptionsGroovyImpl\");\n\n        Class<?> resolvedClass = (Class<?>) classHelper.invoke(null, responseOptionsClassName);\n\n        assertEquals(responseOptionsClassName, resolvedClass.getName());\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 830, "output": 1829, "cacheRead": 49152, "cacheWrite": 0, "totalTokens": 51811, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781001497371, "responseId": "resp_059c1ec05b040302016a27ed1a40588194aaf09a1bda1b00ba"}}
