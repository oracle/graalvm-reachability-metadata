      void resetRestAssuredBeforeTest() {
          RestAssured.reset();
      }
  
      @AfterEach
      void resetRestAssuredAfterTest() {
          RestAssured.reset();
      }
  
      @Test
      void configuredHeaderOverwriteRemovesEarlierHeadersWithSameName() throws Throwable {
          RestAssuredConfig config = RestAssured.config()
                  .headerConfig(headerConfig().overwriteHeadersWithName("X-Trace"));
  
          RequestSpecification specification = given()
