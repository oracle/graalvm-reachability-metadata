[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ObjectMappingTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.lang.reflect.Method;\nimport java.nio.charset.StandardCharsets;\n\nimport io.restassured.config.EncoderConfig;\nimport io.restassured.config.ObjectMapperConfig;\nimport io.restassured.http.ContentType;\nimport io.restassured.internal.mapping.ObjectMapping;\nimport io.restassured.mapper.ObjectMapperType;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectMappingTest {\n    @Test\n    void serializesObjectWithExplicitGsonMapper() throws Exception {\n        Message message = new Message(\"rest-assured\", 5);\n\n        String json = ObjectMapping.serialize(\n                message,\n                ContentType.JSON.toString(),\n                StandardCharsets.UTF_8.name(),\n                ObjectMapperType.GSON,\n                new ObjectMapperConfig(),\n                new EncoderConfig());\n\n        assertThat(json).contains(\"\\\"name\\\":\\\"rest-assured\\\"\");\n        assertThat(json).contains(\"\\\"priority\\\":5\");\n        assertThat(invokeGeneratedClassLookup(ObjectMapping.class.getName())).isEqualTo(ObjectMapping.class);\n    }\n\n    private static Class<?> invokeGeneratedClassLookup(String className) throws Exception {\n        Method classLookup = ObjectMapping.class.getDeclaredMethod(\"class$\", String.class);\n        classLookup.setAccessible(true);\n        return (Class<?>) classLookup.invoke(null, className);\n    }\n\n    public static final class Message {\n        private final String name;\n        private final int priority;\n\n        private Message(String name, int priority) {\n            this.name = name;\n            this.priority = priority;\n        }\n    }\n}\n"}
