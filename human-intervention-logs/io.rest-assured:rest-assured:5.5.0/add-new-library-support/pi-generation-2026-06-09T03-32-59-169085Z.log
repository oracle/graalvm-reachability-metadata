                .given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .config(config)\n                    .header(\"X-Trace\", \"alpha\")\n                    .header(\"x-trace\", \"bravo\")\n                    .when()\n                    .get(\"/headers\");\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString()).isEqualTo(\"bravo\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n\n    private static void echoTraceHeaders(HttpExchange exchange) throws IOException {\n        List<String> headers = exchange.getRequestHeaders().get(\"X-Trace\");\n        String response = headers == null ? \"\" : String.join(\",\", headers);\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n\n        exchange.sendResponseHeaders(200, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 965, "output": 1119, "cacheRead": 36352, "cacheWrite": 0, "totalTokens": 38436, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780975926448, "responseId": "resp_00a4ca1ec475ad35016a278936f05c81979f23f972f88158d2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Cz3OsRUyXjhmfx6Rn24qqCuZ|fc_00a4ca1ec475ad35016a27894616cc81978661ab5ed46c39f1", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2494 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_removeMergedHeadersIfNeeded_closure7Test.java"}], "isError": false, "timestamp": 1780975949958}]}
