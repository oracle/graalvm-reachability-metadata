          val = parameters[i + 1]
        } else {
          args = parameters[i + 1]
          val = parameters[i + 2]
          if (!isRestAssuredArguments(args)) {
            throw new IllegalArgumentException("Illegal argument '$args' passed to body expectation '$key', a list of ${Argument.class.name} is required.")
          }
        }
  
