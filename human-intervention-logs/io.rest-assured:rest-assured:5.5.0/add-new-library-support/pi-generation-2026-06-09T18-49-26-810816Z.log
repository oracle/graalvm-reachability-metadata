  package io_rest_assured.rest_assured;
  
  import java.lang.reflect.Method;
  
  import io.restassured.internal.matcher.xml.LoadFromClasspathSupport;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.matcher.RestAssuredMatchers.matchesXsdInClasspath;
  import static org.hamcrest.MatcherAssert.assertThat;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class LoadFromClasspathSupportTest {
      @Test
      void generatedGroovyClassHelperResolvesClassName() throws Exception {
          Method classHelper = LoadFromClasspathSupport.class.getDeclaredMethod("class$", String.class);
          classHelper.setAccessible(true);
          String xsdMatcherClassName = String.join(
                  ".", "io", "restassured", "internal", "matcher", "xml", "XmlXsdMatcher");
  
          Class<?> resolvedClass = (Class<?>) classHelper.invoke(null, xsdMatcherClassName);
  
          assertEquals(xsdMatcherClassName, resolvedClass.getName());
      }
  
      @Test
      void loadsClasspathResourceWithLeadingSlashWhenValidatingXmlAgainstXsd() {
          String xml = """
                  <greeting>
                      <text>Hello from REST Assured</text>
                  </greeting>
                  """;
  
          assertThat(xml, matchesXsdInClasspath("/load-from-classpath-support-test.xsd"));
      }
  }
