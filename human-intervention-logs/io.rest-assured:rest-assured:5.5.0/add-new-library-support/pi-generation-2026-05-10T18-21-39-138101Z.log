      def baseUriPath = ""
      if (!(baseUri == null || baseUri == "")) {
        def uri = new URI(baseUri)
        baseUriPath = uri.getPath()
      }
      return mergeAndRemoveDoubleSlash(mergeAndRemoveDoubleSlash(baseUriPath, basePath), path)
    }
  
