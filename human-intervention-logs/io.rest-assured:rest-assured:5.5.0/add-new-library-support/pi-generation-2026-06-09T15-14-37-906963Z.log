              assertThat(resolvedClass.getName()).isEqualTo(dynamicallyLoadedClassName);
          } finally {
              registry.setMetaClass(closureClass, originalMetaClass);
              server.stop(0);
              executor.shutdownNow();
              executor.awaitTermination(5, TimeUnit.SECONDS);
          }
      }
  
