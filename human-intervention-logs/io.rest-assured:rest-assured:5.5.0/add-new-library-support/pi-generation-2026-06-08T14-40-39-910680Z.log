nimport static io.restassured.RestAssured.given;\nimport static org.hamcrest.Matchers.lessThan;\n\npublic class ResponseTimeMatcherTest {\n    @Test\n    void validatesResponseTimeThroughResponseSpecification() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/timed\", this::sendResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/timed\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .time(lessThan(60L), TimeUnit.SECONDS);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendResponse(HttpExchange exchange) throws IOException {\n        try {\n            byte[] body = \"ok\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1081, "output": 1204, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 35053, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780929586850, "responseId": "resp_091e82434b4a6888016a26d43353848197877f16b837f11978"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_vLeajj9jPhTxtTG7W91qax2z|fc_091e82434b4a6888016a26d4456f008197b3b6d4d04b6850c8", "toolName": "write", "content": [{"type": "text", "te