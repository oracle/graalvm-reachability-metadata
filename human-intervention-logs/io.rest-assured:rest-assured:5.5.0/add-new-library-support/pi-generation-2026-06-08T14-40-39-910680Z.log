Assured.given;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class HeaderMatcherTest {\n    @Test\n    void validatesMappedResponseHeaderThroughResponseSpecification() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/headers\", this::sendHeaderResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/headers\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .header(\"X-Count\", Integer::parseInt, equalTo(3))\n                    .header(\"X-Mode\", equalTo(\"native\"));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendHeaderResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"X-Count\", \"3\");\n            headers.add(\"X-Mode\", \"native\");\n            byte[] body = \"ok\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780929551417}, {"role": "toolResult", "toolCallId": "call_1ArhCy6uhbFAOBmbk3GAHhij|fc_091e82434b4a6888016a26d40f34048197936e6135c9d678b4", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static io.restassured.matcher.RestAssuredMatchers.detailedCookie;\n\npublic class DetailedCookieAssertionTest {\n    @Test\n    void validatesDetailedCookieAttributesFromSetCookieHeader() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/cookies\", this::sendCookieResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/cookies\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .cookie(\"session\", detailedCookie()\n                            .value(\"abc\")\n                            .path(\"/cookies\")\n                            .httpOnly(true)\n                            .sameSite(\"Lax\")\n                            .secured(false));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendCookieResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Set-Cookie\", \"session=abc; Path=/cookies; HttpOnly; SameSite=Lax\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, -1);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780929551417}]}
