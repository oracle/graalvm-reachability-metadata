ecutors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/catalog\", this::sendJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n        AtomicReference<Closure<?>> generatedBodyMatcherClosure = new AtomicReference<>();\n        MetaClassRegistry registry = GroovySystem.getMetaClassRegistry();\n        MetaClass originalMapMetaClass = registry.getMetaClass(LinkedHashMap.class);\n        ProxyMetaClass proxyMetaClass = ProxyMetaClass.getInstance(LinkedHashMap.class);\n        proxyMetaClass.setInterceptor(new CapturingEachClosureInterceptor(generatedBodyMatcherClosure));\n        registry.setMetaClass(LinkedHashMap.class, proxyMetaClass);\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/catalog\")\n                    .then()\n                    .body(\n                            \"items[%d].name\", withArgs(0), equalTo(\"book\"),\n                            \"items[%d].name\", withArgs(1), equalTo(\"pen\"),\n                            \"items[%d].name\", withArgs(2), equalTo(\"bag\"));\n\n            Class<?> resolvedLookupClass = invokeGeneratedClassLookup(\n                    generatedBodyMatcherClosure.get(),\n                    BodyMatcher.class.getName());\n            assertEquals(BodyMatcher.class, resolvedLookupClass);\n        } finally {\n            registry.setMetaClass(LinkedHashMap.class, originalMapMetaClass);\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }","newText":"    @Test\n    void validatesDuplicateParameterizedAdditionalBodyExpectations() throws Throwable {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = 