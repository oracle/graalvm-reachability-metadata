: {"path": "tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecificationImplInner_body_closure11_closure21Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.http.ContentType;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static io.restassured.RestAssured.withArgs;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class ResponseSpecificationImplInner_body_closure11_closure21Test {\n    @Test\n    void validatesDuplicateParameterizedAdditionalBodyExpectations() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/catalog\", this::sendJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/catalog\")\n                    .then()\n                    .body(\n                            \"items[%d].name\", withArgs(0), equalTo(\"book\"),\n                            \"items[%d].name\", withArgs(1), equalTo(\"pen\"),\n                            \"items[%d].name\", withArgs(2), equalTo(\"bag\"));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", ContentType.JSON.toString());\n            byte[] body = \"\"\"\n                    {\"items\":[{\"name\":\"book\"},{\"name\":\"pen\"},{\"name\":\"bag\"}]}\n                    \"\"\".strip().getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 304, "output": 1091, "cacheRead": 39424, "cacheWrite": 0, "totalTokens": 40819, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780987689629, "responseId": "resp_010fa4169cdc469d016a27b72a11c08196ab20f1ca854a3a37"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pjT0yO7IXRcQaUUtAbEqQdFq|fc_010fa4169cdc469d016a27b736d908819681c07c2601a3292b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2561 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecificationImplInner_body_closure11_closure21Test.java"}], "isError": false, "timestamp": 1780987710836}]}
