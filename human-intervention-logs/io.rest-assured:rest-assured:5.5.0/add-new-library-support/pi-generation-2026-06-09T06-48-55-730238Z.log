g.junit.jupiter.api.Assertions.assertNotNull;"},{"oldText":"public class ResponseSpecificationImplInner_body_closure11_closure21Test {\n    @Test\n    void validatesDuplicateParameterizedAdditionalBodyExpectations() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/catalog\", this::sendJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/catalog\")\n                    .then()\n                    .body(\n                            \"items[%d].name\", withArgs(0), equalTo(\"book\"),\n                            \"items[%d].name\", withArgs(1), equalTo(\"pen\"),\n                            \"items[%d].name\", withArgs(2), equalTo(\"bag\"));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }","newText":"public class ResponseSpecificationImplInner_body_closure11_closure21Test {\n    private static final String CLOSURE_CLASS_NAME = \"io.restassured.internal.ResponseSpecificationImpl\"\n            + \"$_body_closure11_closure21\";\n\n    @Test\n    void validatesDuplicateParameterizedAdditionalBodyExpectations() throws Throwable {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/catalog\", this::sendJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n        AtomicReference<Closure<?>> generatedBodyMatcherClosure = new AtomicReference<>();\n        MetaClassRegistry registry = GroovySystem.