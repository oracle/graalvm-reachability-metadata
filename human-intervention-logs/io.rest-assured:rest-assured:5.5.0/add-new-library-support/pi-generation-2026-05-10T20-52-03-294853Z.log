          Map<String, LibraryStatsModels.DynamicAccessBreakdown> breakdown = new TreeMap<>();
          for (Map.Entry<String, Set<String>> entry : totalKeysByType.entrySet()) {
              String reportType = entry.getKey();
              long total = entry.getValue().size();
