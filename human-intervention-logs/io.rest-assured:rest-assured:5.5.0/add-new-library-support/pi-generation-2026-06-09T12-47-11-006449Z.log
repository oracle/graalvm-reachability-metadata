                      .keyStore(storePath.toFile(), KEY_STORE_PASSWORD)
                      .trustStore(storePath.toFile(), KEY_STORE_PASSWORD)
                      .keystoreType(KEY_STORE_TYPE)
                      .trustStoreType(KEY_STORE_TYPE)
                      .allowAllHostnames();
  
