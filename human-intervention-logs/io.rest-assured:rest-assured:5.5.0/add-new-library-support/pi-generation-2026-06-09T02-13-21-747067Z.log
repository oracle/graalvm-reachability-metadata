          server.createContext(
                  "/shops/tea/items/42",
                  RequestSpecificationImplInner_newFilterContext_closure13Test::sendObservedPath);
          server.start();
          RestAssured.reset();
  
          try {
              Response response = RestAssured
                      .given()
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
