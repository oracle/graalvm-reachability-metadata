[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecificationImplInner_header_closure6Test.java","edits":[{"oldText":"import java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\n","newText":"import java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\n"},{"oldText":"import io.restassured.http.ContentType;\n","newText":""},{"oldText":"import org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.hamcrest.Matchers.equalTo;\n","newText":"import io.restassured.assertion.HeaderMatcher;\nimport io.restassured.internal.ResponseSpecificationImpl;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.hamcrest.Matchers.equalTo;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n"},{"oldText":"public class ResponseSpecificationImplInner_header_closure6Test {\n    @Test\n    void validatesMappedHeaderExpectation() throws Exception {\n","newText":"public class ResponseSpecificationImplInner_header_closure6Test {\n    private static final String CLOSURE_CLASS_NAME = \"io.restassured.internal.ResponseSpecificationImpl\"\n            + \"$_header_closure6\";\n\n    @Test\n    void validatesMappedHeaderExpectation() throws Throwable {\n"},{"oldText":"                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .header(\"X-Item-Count\", Integer::parseInt, equalTo(7));\n","newText":"                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .header(\"X-Item-Count\", Integer::parseInt, equalTo(7));\n            assertSame(HeaderMatcher.class, invokeGeneratedClassLookup(HeaderMatcher.class.getName()));\n"},{"oldText":"    private static void sendHeaderResponse(HttpExchange exchange) throws IOException {\n","newText":"    private static Class<?> invokeGeneratedClassLookup(String className) throws Throwable {\n        MethodHandle classHelper = generatedClassLookup();\n        return (Class<?>) classHelper.invokeExact(className);\n    }\n\n    private static MethodHandle generatedClassLookup() throws NoSuchMethodException, IllegalAccessException {\n        Class<?> closureClass = generatedClosureClass();\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(closureClass, MethodHandles.lookup());\n        return lookup.findStatic(closureClass, \"class$\", MethodType.methodType(Class.class, String.class));\n    }\n\n    private static Class<?> generatedClosureClass() throws ClassNotFoundException {\n        for (Class<?> declaredClass : ResponseSpecificationImpl.class.getDeclaredClasses()) {\n            if (CLOSURE_CLASS_NAME.equals(declaredClass.getName())) {\n                return declaredClass;\n            }\n        }\n        throw new ClassNotFoundException(CLOSURE_CLASS_NAME);\n    }\n\n    private static void sendHeaderResponse(HttpExchange exchange) throws IOException {\n"}]}
