eger::parseInt, equalTo(7));\n            assertSame(HeaderMatcher.class, invokeGeneratedClassLookup(HeaderMatcher.class.getName()));\n"}, {"oldText": "    private static void sendHeaderResponse(HttpExchange exchange) throws IOException {\n", "newText": "    private static Class<?> invokeGeneratedClassLookup(String className) throws Throwable {\n        MethodHandle classHelper = generatedClassLookup();\n        return (Class<?>) classHelper.invokeExact(className);\n    }\n\n    private static MethodHandle generatedClassLookup() throws NoSuchMethodException, IllegalAccessException {\n        Class<?> closureClass = generatedClosureClass();\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(closureClass, MethodHandles.lookup());\n        return lookup.findStatic(closureClass, \"class$\", MethodType.methodType(Class.class, String.class));\n    }\n\n    private static Class<?> generatedClosureClass() throws ClassNotFoundException {\n        for (Class<?> declaredClass : ResponseSpecificationImpl.class.getDeclaredClasses()) {\n            if (CLOSURE_CLASS_NAME.equals(declaredClass.getName())) {\n                return declaredClass;\n            }\n        }\n        throw new ClassNotFoundException(CLOSURE_CLASS_NAME);\n    }\n\n    private static void sendHeaderResponse(HttpExchange exchange) throws IOException {\n"}]}
