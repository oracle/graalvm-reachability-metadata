                      .forEach(path -> parseDynamicAccessFile(path, libraryClasses, coveredLinesBySource, callSitesByKey));
          } catch (IOException e) {
              throw new GradleException("Failed to traverse dynamic access directory " + dynamicAccessDir, e);
          }
  
