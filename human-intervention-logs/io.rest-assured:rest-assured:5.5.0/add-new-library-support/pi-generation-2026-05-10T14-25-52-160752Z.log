       * </pre>
       * </p>
       *
       * @param expectedHeaders The Map of expected response headers
       * @return The builder
       */
      public ResponseSpecBuilder expectHeaders(Map<String, Object> expectedHeaders) {
          spec.headers(expectedHeaders);
          return this;
      }
  
