  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  
  import io.restassured.RestAssured;
  import io.restassured.authentication.AuthenticationScheme;
  import io.restassured.authentication.OAuth2Scheme;
  import io.restassured.authentication.OAuthSignature;
  import io.restassured.config.DecoderConfig;
  import io.restassured.config.EncoderConfig;
  import io.restassured.config.OAuthConfig;
  import io.restassured.internal.http.HTTPBuilder;
  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.apache.http.client.ClientProtocolException;
  import org.apache.http.impl.client.AbstractHttpClient;
  import org.apache.http.impl.client.DefaultHttpClient;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OAuth2SchemeTest {
      private static final String ACCESS_TOKEN = "oauth2-access-token";
  
      @Test
      void createsOAuth2AuthenticationSchemeWithConfiguredHeaderSignature() {
          AuthenticationScheme authenticationScheme = RestAssured.oauth2(
                  ACCESS_TOKEN, OAuthSignature.HEADER);
  
          assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);
          OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;
          assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.HEADER);
      }
  
      @Test
      void createsOAuth2AuthenticationSchemeWithConfiguredQuerySignature() {
          AuthenticationScheme authenticationScheme = RestAssured.oauth2(
                  ACCESS_TOKEN, OAuthSignature.QUERY_STRING);
  
          assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);
          OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;
          assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);
      }
  
      @Test
      void createsOAuth2AuthenticationSchemeFromRequestAuthenticationDsl() {
          RequestSpecification specification = given()
                  .auth()
                  .oauth2(ACCESS_TOKEN, OAuthSignature.QUERY_STRING);
  
          AuthenticationScheme authenticationScheme = SpecificationQuerier.query(specification)
                  .getAuthenticationScheme();
          assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);
          OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;
          assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);
      }
  
      @Test
      void authenticateRegistersOAuth2InterceptorWithQuerySignature() throws IOException {
          OAuth2Scheme oauth2Scheme = (OAuth2Scheme) RestAssured.oauth2(
                  ACCESS_TOKEN, OAuthSignature.QUERY_STRING);
  
          assertThatOAuth2InterceptorIsRegisteredBy(oauth2Scheme);
      }
  
      @Test
      void authenticateRegistersOAuth2InterceptorWhenSignatureIsUnset() throws IOException {
          OAuth2Scheme oauth2Scheme = new OAuth2Scheme();
          oauth2Scheme.setAccessToken(ACCESS_TOKEN);
  
          assertThat(oauth2Scheme.getSignature()).isNull();
          assertThatOAuth2InterceptorIsRegisteredBy(oauth2Scheme);
      }
  
      private static void assertThatOAuth2InterceptorIsRegisteredBy(
              OAuth2Scheme oauth2Scheme) throws IOException {
          DefaultHttpClient client = new DefaultHttpClient();
          try {
              TestHttpBuilder httpBuilder = new TestHttpBuilder(client);
              int originalInterceptorCount = client.getRequestInterceptorCount();
              oauth2Scheme.authenticate(httpBuilder);
  
              assertThat(client.getRequestInterceptorCount()).isEqualTo(originalInterceptorCount + 1);
          } finally {
              client.getConnectionManager().shutdown();
          }
      }
  
      private static final class TestHttpBuilder extends HTTPBuilder {
          private TestHttpBuilder(AbstractHttpClient client) {
              super(true, new EncoderConfig(), new DecoderConfig(), new OAuthConfig(), client);
          }
  
          @Override
          protected Object doRequest(
                  RequestConfigDelegate delegate) throws ClientProtocolException, IOException {
              return null;
          }
      }
  }
  
