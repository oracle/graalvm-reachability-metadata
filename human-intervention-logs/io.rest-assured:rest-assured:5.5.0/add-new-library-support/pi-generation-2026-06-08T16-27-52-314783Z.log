              this.builder.client.addRequestInterceptor(new OAuthSigner(
                      consumerKey, consumerSecret, accessToken, secretToken,
                      signature, raOAuthConfig.shouldAddEmptyAccessOAuthTokenToBaseString()));
          }
      }
  
  
