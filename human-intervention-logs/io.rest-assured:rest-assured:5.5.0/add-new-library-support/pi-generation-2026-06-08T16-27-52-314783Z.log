sured;\nimport io.restassured.authentication.AuthenticationScheme;\nimport io.restassured.authentication.OAuth2Scheme;\nimport io.restassured.authentication.OAuthSignature;\nimport io.restassured.config.DecoderConfig;\nimport io.restassured.config.EncoderConfig;\nimport io.restassured.config.OAuthConfig;\nimport io.restassured.internal.http.HTTPBuilder;\nimport io.restassured.specification.RequestSpecification;\nimport io.restassured.specification.SpecificationQuerier;\nimport org.apache.http.client.ClientProtocolException;\nimport org.apache.http.impl.client.AbstractHttpClient;\nimport org.apache.http.impl.client.DefaultHttpClient;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OAuth2SchemeTest {\n    private static final String ACCESS_TOKEN = \"oauth2-access-token\";\n\n    @Test\n    void createsOAuth2AuthenticationSchemeWithConfiguredHeaderSignature() {\n        AuthenticationScheme authenticationScheme = RestAssured.oauth2(\n                ACCESS_TOKEN, OAuthSignature.HEADER);\n\n        assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);\n        OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;\n        assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.HEADER);\n    }\n\n    @Test\n    void createsOAuth2AuthenticationSchemeWithConfiguredQuerySignature() {\n        AuthenticationScheme authenticationScheme = RestAssured.oauth2(\n                ACCESS_TOKEN, OAuthSignature.QUERY_STRING);\n\n        assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);\n        OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;\n        assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);\n    }\n\n    @Test\n    void createsOAuth2AuthenticationSchemeFromRequestAuthenticationDsl() {\n        RequestSpecification specification = given()\n                .auth()\n                .oauth2(ACCESS_TOKEN, OAuthSignature.QUERY_STRING);\n\n        AuthenticationScheme authenticationScheme = SpecificationQuerier.query(specification)\n                .getAuthenticationScheme();\n        assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);\n        OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;\n        assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);\n    }\n\n    @Test\n    void authenticateRegistersOAuth2InterceptorWithQuerySignature() throws IOException {\n        OAuth2Scheme oauth2Scheme = (OAuth2Scheme) RestAssured.oauth2(\n                ACCESS_TOKEN, OAuthSignature.QUERY_STRING);\n\n        assertThatOAuth2InterceptorIsRegisteredBy(oauth2Scheme);\n    }\n\n    @Test\n    void authenticateRegistersOAuth2InterceptorWhenSignatureIsUnset() throws IOException {\n        OAuth2Scheme oauth2Scheme = new OAuth2Scheme();\n        oauth2Scheme.setAccessToken(ACCESS_TOKEN);\n\n        assertThat(oauth2Scheme.getSignature()).isNull();\n        assertThatOAuth2InterceptorIsRegisteredBy(oauth2Scheme);\n    }\n\n    private static void assertThatOAuth2InterceptorIsRegisteredBy(\n            OAuth2Scheme oauth2Scheme) throws IOException {\n        DefaultHttpClient client = new DefaultHttpClient();\n        try {\n            TestHttpBuilder httpBuilder = new TestHttpBuilder(client);\n            int originalInterceptorCount = client.getRequestInterceptorCount();\n            oauth2Scheme.authenticate(httpBuilder);\n\n            assertThat(client.getRequestInterceptorCount()).isEqualTo(originalInterceptorCount + 1);\n        } finally {\n            client.getConnectionManager().shutdown();\n        }\n    }\n\n    private static final class TestHttpBuilder extends HTTPBuilder {\n        private TestHttpBuilder(AbstractHttpClient client) {\n            super(true, new EncoderConfig(), new DecoderConfig(), new OAuthConfig(), client);\n        }\n\n        @Override\n        protected Object doRequest(\n                RequestConfigDelegate delegate) throws ClientProtocolException, IOException {\n            return null;\n        }\n    }\n}\n\n"}], "isError": false, "timestamp": 1780935959677}, {"role": "toolResult", "toolCallId": "call_TGjcbM7ZU13svoXMB5bFbMWT|fc_0861e6ee1ff304f0016a26ed176f448197b0c11762f40764a3", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Base64;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicBoolean;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.authentication.AuthenticationScheme;\nimport io.restassured.authentication.BasicAuthScheme;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class BasicAuthSchemeTest {\n    private static final String USER_NAME = \"basic-user\";\n    private static final String PASSWORD = \"basic-password\";\n    private static final String AUTHORIZATION_HEADER = \"Basic \" + Base64.getEncoder()\n            .encodeToString((USER_NAME + \":\" + PASSWORD).getBytes(StandardCharsets.ISO_8859_1));\n\n    @Test\n    void createsBasicAuthenticationSchemeWithConfiguredCredentials() {\n        AuthenticationScheme authenticationScheme = RestAssured.basic(USER_NAME, PASSWORD);\n\n        assertThat(authenticationScheme).isInstanceOf(BasicAuthScheme.class);\n        BasicAuthScheme basicAuthScheme = (BasicAuthScheme) authenticationScheme;\n        assertThat(basicAuthScheme.getUserName()).isEqualTo(USER_NAME);\n        assertThat(basicAuthScheme.getPassword()).isEqualTo(PASSWORD);\n    }\n\n    @Test\n    void appliesBasicAuthenticationCredentialsAfterChallenge() throws Exception {\n        AtomicBoolean authorizedRequestSeen = new AtomicBoolean(false);\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/secured\", exchange -> sendSecuredResponse(exchange, authorizedRequestSeen));\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .auth()\n                    .basic(USER_NAME, PASSWORD)\n                    .when()\n                    .get(\"/secured\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .body(equalTo(\"authenticated\"));\n            assertThat(authorizedRequestSeen).isTrue();\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendSecuredResponse(HttpExchange exchange, AtomicBoolean authorizedRequestSeen) throws IOException {\n        try {\n            Headers requestHeaders = exchange.getRequestHeaders();\n            if (!AUTHORIZATION_HEADER.equals(requestHeaders.getFirst(\"Authorization\"))) {\n                Headers responseHeaders = exchange.getResponseHeaders();\n                responseHeaders.add(\"WWW-Authenticate\", \"Basic realm=\\\"rest-assured-test\\\"\");\n                exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);\n                return;\n            }\n\n            authorizedRequestSeen.set(true);\n            byte[] body = \"authenticated\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780935959677}, {"role": "toolResult", "toolCallId": "call_LMbOrY0FA3YIrUSiyaVB2Nf6|fc_0861e6ee1ff304f0016a26ed176f4c8197998780208ec6c202", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.rest-assured:rest-assured:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780935959677}, {"role": "toolResult", "toolCallId": "call_b6P4qxAIW0zCkh9QaoJukX8F|fc_0861e6ee1ff304f0016a26ed176f548197a9836e1249a21af7", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2624-42f8dc6a/local_repositories/source_context/io.rest-assured/rest-assured/5.5.0/main/extracted/io/restassured/authentication/OAuthScheme.groovy'"}], "details": {}, "isError": true, "timestamp": 1780935959677}]}
