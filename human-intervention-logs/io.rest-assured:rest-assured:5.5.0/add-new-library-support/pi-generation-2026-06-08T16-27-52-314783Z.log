ticationScheme authenticationScheme = RestAssured.oauth(\n                CONSUMER_KEY, CONSUMER_SECRET, ACCESS_TOKEN, SECRET_TOKEN);\n\n        assertThat(authenticationScheme).isInstanceOf(OAuthScheme.class);\n        OAuthScheme oauthScheme = (OAuthScheme) authenticationScheme;\n        assertThat(oauthScheme.getConsumerKey()).isEqualTo(CONSUMER_KEY);\n        assertThat(oauthScheme.getConsumerSecret()).isEqualTo(CONSUMER_SECRET);\n        assertThat(oauthScheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(oauthScheme.getSecretToken()).isEqualTo(SECRET_TOKEN);\n        assertThat(oauthScheme.getSignature()).isNull();\n    }\n\n    @Test\n    void createsOAuthAuthenticationSchemeWithConfiguredSignature() {\n        AuthenticationScheme authenticationScheme = RestAssured.oauth(\n                CONSUMER_KEY,\n                CONSUMER_SECRET,\n                ACCESS_TOKEN,\n                SECRET_TOKEN,\n                OAuthSignature.QUERY_STRING);\n\n        assertThat(authenticationScheme).isInstanceOf(OAuthScheme.class);\n        OAuthScheme oauthScheme = (OAuthScheme) authenticationScheme;\n        assertThat(oauthScheme.getConsumerKey()).isEqualTo(CONSUMER_KEY);\n        assertThat(oauthScheme.getConsumerSecret()).isEqualTo(CONSUMER_SECRET);\n        assertThat(oauthScheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(oauthScheme.getSecretToken()).isEqualTo(SECRET_TOKEN);\n        assertThat(oauthScheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);\n    }\n\n    @Test\n    void createsOAuthAuthenticationSchemeFromRequestAuthenticationDsl() {\n        RequestSpecification specification = given()\n                .auth()\n                .oauth(\n                        CONSUMER_KEY,\n                        CONSUMER_SECRET,\n                        ACCESS_TOKEN,\n                        SECRET_TOKEN,\n                        OAuthSignature.HEADER);\n\n        AuthenticationScheme authenticationScheme = SpecificationQuerier.query(specification)\n                .getAuthenticationScheme();\n        assertThat(authenticationScheme).isInstanceOf(OAuthScheme.class);\n        OAuthScheme oauthScheme = (OAuthScheme) authenticationScheme;\n        assertThat(oauthScheme.getConsumerKey()).isEqualTo(CONSUMER_KEY);\n        assertThat(oauthScheme.getConsumerSecret()).isEqualTo(CONSUMER_SECRET);\n        assertThat(oauthScheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(oauthScheme.getSecretToken()).isEqualTo(SECRET_TOKEN);\n        assertThat(oauthScheme.getSignature()).isEqualTo(OAuthSignature.HEADER);\n    }\n\n    @Test\n    void authenticateRegistersOAuthInterceptorWithConfiguredSignature() throws IOException {\n        OAuthScheme oauthScheme = (OAuthScheme) RestAssured.oauth(\n                CONSUMER_KEY,\n                CONSUMER_SECRET,\n                ACCESS_TOKEN,\n                SECRET_TOKEN,\n                OAuthSignature.QUERY_STRING);\n\n        assertThatOAuthInterceptorIsRegisteredBy(oauthScheme);\n    }\n\n    @Test\n    void authenticateRegistersOAuthInterceptorWhenSignatureIsUnset() throws IOException {\n        OAuthScheme oauthScheme = (OAuthScheme) RestAssured.oauth(\n                CONSUMER_KEY, CONSUMER_SECRET, ACCESS_TOKEN, SECRET_TOKEN);\n\n        assertThat(oauthScheme.getSignature()).isNull();\n        assertThatOAuthInterceptorIsRegisteredBy(oauthScheme);\n    }\n\n    @Test\n    void groovyMetaClassResolvesGeneratedClassHelper() {\n        OAuthScheme oauthScheme = (OAuthScheme) RestAssured.oauth(\n                CONSUMER_KEY, CONSUMER_SECRET, ACCESS_TOKEN, SECRET_TOKEN);\n        MetaClass metaClass = oauthScheme.getMetaClass();\n\n        Object resolvedClass = metaClass.invokeStaticMethod(\n                OAuthScheme.class,\n                \"class$\",\n                new Object[] {OAuthScheme.class.getName()});\n\n        assertThat(resolvedClass).isSameAs(OAuthScheme.class);\n    }\n\n    private static void assertThatOAuthInterceptorIsRegisteredBy(\n            OAuthScheme oauthScheme) throws IOException {\n        DefaultHttpClient client = new DefaultHttpClient();\n        try {\n            TestHttpBuilder httpBuilder = new TestHttpBuilder(client);\n            int originalInterceptorCount = client.getRequestInterceptorCount();\n            oauthScheme.authenticate(httpBuilder);\n\n            assertThat(client.getRequestInterceptorCount()).isEqualTo(originalInterceptorCount + 1);\n        } finally {\n            client.getConnectionManager().shutdown();\n        }\n    }\n\n    private static final class TestHttpBuilder extends HTTPBuilder {\n        private TestHttpBuilder(AbstractHttpClient client) {\n            super(true, new EncoderConfig(), new DecoderConfig(), new OAuthConfig(), client);\n        }\n\n        @Override\n        protected Object doRequest(\n                RequestConfigDelegate delegate) throws ClientProtocolException, IOException {\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 741, "output": 1757, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 32706, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780936033285, "responseId": "resp_0861e6ee1ff304f0016a26ed61d0e48197af9228729fd1ceda"}}
