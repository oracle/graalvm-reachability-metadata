  package io_rest_assured.rest_assured;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import io.restassured.internal.MapCreator;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class MapCreatorInnerArgsAndValueTest {
      @Test
      void generatedGroovyClassHelperResolvesUnloadedLibraryClassName() throws Throwable {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                  MapCreator.ArgsAndValue.class,
                  MethodHandles.lookup());
          MethodHandle classHelper = lookup.findStatic(
                  MapCreator.ArgsAndValue.class,
                  "class$",
                  MethodType.methodType(Class.class, String.class));
  
          String className = "io.restassured.builder.MultiPartSpecBuilder";
  
          Class<?> resolvedClass = (Class<?>) classHelper.invokeExact(className);
  
          assertEquals(className, resolvedClass.getName());
      }
  }
