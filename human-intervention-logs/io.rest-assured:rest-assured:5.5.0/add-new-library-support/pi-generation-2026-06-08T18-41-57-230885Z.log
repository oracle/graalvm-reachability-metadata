[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/MapCreatorInnerArgsAndValueTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport io.restassured.internal.MapCreator;\nimport io.restassured.specification.Argument;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\npublic class MapCreatorInnerArgsAndValueTest {\n    @Test\n    void generatedGroovyClassHelperResolvesArgumentClassName() throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(MapCreator.ArgsAndValue.class, MethodHandles.lookup());\n        MethodHandle classHelper = lookup.findStatic(\n                MapCreator.ArgsAndValue.class,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) classHelper.invokeExact(Argument.class.getName());\n\n        assertSame(Argument.class, resolvedClass);\n    }\n}\n"}
