eneratedHeadersClosure));\n        registry.setMetaClass(ResponseSpecificationImpl.class, proxyMetaClass);\n\n        try {\n            Map<String, Object> expectedHeaders = new LinkedHashMap<>();\n            expectedHeaders.put(\"X-Request-Id\", equalTo(\"request-1\"));\n            expectedHeaders.put(\"X-Trace-Id\", startsWith(\"trace-\"));\n\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/headers\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .headers(expectedHeaders);\n\n            Class<?> resolvedLookupClass = invokeGeneratedClassLookup(\n                    generatedHeadersClosure.get(),\n                    Map.class.getName());\n            assertEquals(Map.class, resolvedLookupClass);\n        } finally {\n            registry.setMetaClass(ResponseSpecificationImpl.class, originalMetaClass);\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1260, "output": 1412, "cacheRead": 50176, "cacheWrite": 0, "totalTokens": 52848, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780995850440, "responseId": "resp_0ad24c96caa873cb016a27d70aff4481958bcbceaa7f8d888c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2lmHtFYXziQIRcjmLztjonj9|fc_0ad24c96caa873cb016a27d7136f9881958c07e8ab90e5e20b", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 1 block(s) in tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecificationImplInner_headers_closure5Test.java."}], "details": {"diff": "    .