henticateWritesBearerAuthorizationHeaderToHttpBuilder() {\n        PreemptiveOAuth2HeaderScheme scheme = new PreemptiveOAuth2HeaderScheme();\n        scheme.setAccessToken(ACCESS_TOKEN);\n        HTTPBuilder httpBuilder = new HTTPBuilder(\n                true,\n                EncoderConfig.encoderConfig(),\n                DecoderConfig.decoderConfig(),\n                OAuthConfig.oauthConfig(),\n                null) {\n        };\n\n        scheme.authenticate(httpBuilder);\n\n        assertEquals(\"Bearer \" + ACCESS_TOKEN, httpBuilder.getHeaders().get(\"Authorization\"));\n    }\n\n    @Test\n    void sendsBearerAuthorizationHeaderWithoutServerChallenge() throws Exception {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3860, "output": 1621, "cacheRead": 55808, "cacheWrite": 0, "totalTokens": 61289, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778419696445, "responseId": "resp_0115c9c5bf1ea927016a0087f131e4819c892ae84860e01e06"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pOGFxEh2c01cX6laC4KBMN56|fc_0115c9c5bf1ea927016a008805cb68819cab66b0b8f4a98f90", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/PreemptiveOAuth2HeaderSchemeTest.java."}], "details": {"diff": "     ...\n  10 import com.sun.net.httpserver.HttpServer;\n  11 import io.restassured.RestAssured;\n  12 import io.restassured.authentication.AuthenticationScheme;\n  13 import io.restassured.authentication.PreemptiveOAuth2HeaderScheme;\n+ 14 import io.restassured.config.DecoderConfig;\n+ 15 import io.restassured.config.EncoderConfig;\n+ 16 import io.restassured.config.OAuthConfig;\n+ 17 import io.restassured.internal.http.HTTPBuilder;\n  14 import org.codehaus.groovy.runtime.InvokerHelper;\n  15 import org.graalvm.internal.tck.NativeImag