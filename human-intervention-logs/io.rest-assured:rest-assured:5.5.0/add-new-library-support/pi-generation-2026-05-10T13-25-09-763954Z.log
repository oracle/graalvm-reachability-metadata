authenticateWritesBearerAuthorizationHeaderToHttpBuilder() {\n        PreemptiveOAuth2HeaderScheme scheme = new PreemptiveOAuth2HeaderScheme();\n        scheme.setAccessToken(ACCESS_TOKEN);\n        HTTPBuilder httpBuilder = new HTTPBuilder(\n                true,\n                EncoderConfig.encoderConfig(),\n                DecoderConfig.decoderConfig(),\n                OAuthConfig.oauthConfig(),\n                null) {\n        };\n\n        scheme.authenticate(httpBuilder);\n\n        assertEquals(\"Bearer \" + ACCESS_TOKEN, httpBuilder.getHeaders().get(\"Authorization\"));\n    }\n\n    @Test\n    void sendsBearerAuthorizationHeaderWithoutServerChallenge() throws Exception {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3860, "output": 1621, "cacheRead": 55808, "cacheWrite": 0, "totalTokens": 61289, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778419696445, "responseId": "resp_0115c9c5bf1ea927016a0087f131e4819c892ae84860e01e06"}}
