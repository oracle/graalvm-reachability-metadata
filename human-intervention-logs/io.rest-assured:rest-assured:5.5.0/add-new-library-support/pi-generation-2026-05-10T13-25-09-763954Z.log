                      EncoderConfig.encoderConfig(),
                      DecoderConfig.decoderConfig(),
                      OAuthConfig.oauthConfig(),
                      new DefaultHttpClient());
          }
  
          @Override
          protected Object doRequest(RequestConfigDelegate delegate) {
