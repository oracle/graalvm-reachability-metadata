sured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/XmlDtdMatcherInnerExceptionThrowingErrorHandlerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport org.hamcrest.Matcher;\nimport org.junit.jupiter.api.Test;\nimport org.xml.sax.SAXParseException;\n\nimport static io.restassured.matcher.RestAssuredMatchers.matchesDtd;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\npublic class XmlDtdMatcherInnerExceptionThrowingErrorHandlerTest {\n    @Test\n    void throwsParserExceptionWhenXmlDoesNotMatchDtd() {\n        String dtd = \"\"\"\n                <!ELEMENT greeting (message)>\n                <!ELEMENT message (#PCDATA)>\n                \"\"\";\n        String xml = \"\"\"\n                <greeting>\n                    <unexpected>Hello from Rest Assured</unexpected>\n                </greeting>\n                \"\"\";\n        Matcher<String> matcher = matchesDtd(dtd);\n\n        SAXParseException exception = assertThrows(SAXParseException.class, () -> matcher.matches(xml));\n\n        assertNotNull(exception.getSystemId());\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1772, "output": 1274, "cacheRead": 56320, "cacheWrite": 0, "totalTokens": 59366, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781032311883, "responseId": "resp_031e604dab9e4707016a286578b4308197834eb5a900c20fe1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_3ERQShWQ7VcfoehxvZX0vgcG|fc_031e604dab9e4707016a286590c43081978d997e988b84966f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1193 bytes to tests