tp://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/validation-errors\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_CREATED)\n                    .contentType(ContentType.XML)\n                    .header(\"X-Validation\", equalTo(\"rejected\")));\n\n            assertTrue(error.getMessage().contains(\"3 expectations failed\"));\n            assertTrue(error.getMessage().contains(\"status code\"));\n            assertTrue(error.getMessage().contains(\"content-type\"));\n            assertTrue(error.getMessage().contains(\"X-Validation\"));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", ContentType.JSON.toString());\n            headers.add(\"X-Validation\", \"accepted\");\n            byte[] body = \"{\\\"status\\\":\\\"accepted\\\"}\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 814, "output": 1143, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 27557, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780985281706, "responseId": "resp_0175de0ce14905ad016a27adc243a08194be6dbb7f3cc6c16d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Nn0U2v6xFFhI09kwzphXaUyH|fc_0175de0ce14905ad016a27adcdf4388194945df666b573731d", "toolName": "write", "content": [{"type": "