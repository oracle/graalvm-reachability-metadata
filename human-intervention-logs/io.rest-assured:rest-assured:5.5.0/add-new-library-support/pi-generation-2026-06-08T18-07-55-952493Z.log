lidationFails(LogDetail.ALL));\n\n            assertThrows(AssertionError.class, () -> given()\n                    .config(config)\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/status\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_CREATED)\n                    .body(equalTo(\"ready\")));\n\n            logStream.flush();\n            String log = logBytes.toString(StandardCharsets.UTF_8);\n            assertTrue(log.contains(\"Request method:\"), log);\n            assertTrue(log.contains(\"GET\"), log);\n            assertTrue(log.contains(\"ready\"), log);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n            logStream.close();\n        }\n    }\n\n    private void sendTextResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", \"text/plain; charset=utf-8\");\n            byte[] body = \"ready\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 808, "output": 880, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 34456, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780941992627, "responseId": "resp_03aa5d49a4009a95016a2704a939ac8196b6128199576aaf51"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_gDAFm8Sxyr7Jk8B7K8nscjUk|fc_03aa5d49a4009a95016a2704ad43288196b66f4a38ede8169c", "toolName": "write", "content": [{"ty