set();\n    }\n\n    @Test\n    void createsExplicitNoAuthenticationSchemeFromRequestAuthenticationDsl() {\n        RequestSpecification specification = given().auth().none();\n\n        assertThat(SpecificationQuerier.query(specification).getAuthenticationScheme())\n                .isInstanceOf(ExplicitNoAuthScheme.class);\n    }\n\n    @Test\n    void groovyObjectDispatchResolvesClassesForExplicitNoAuthenticationScheme() {\n        ExplicitNoAuthScheme authenticationScheme = (ExplicitNoAuthScheme) SpecificationQuerier\n                .query(given().auth().none())\n                .getAuthenticationScheme();\n\n        Object resolvedClass = authenticationScheme.invokeMethod(\n                \"class$\", new Object[] {ExplicitNoAuthScheme.class.getName()});\n\n        assertThat(resolvedClass).isEqualTo(ExplicitNoAuthScheme.class);\n    }\n\n    @Test\n    void explicitNoAuthenticationOverridesDefaultAuthenticationScheme() throws Exception {\n        AtomicBoolean authorizationHeaderSeen = new AtomicBoolean(false);\n        AtomicInteger requestCount = new AtomicInteger(0);\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\n                \"/secured\", exchange -> sendSecuredResponse(exchange, authorizationHeaderSeen, requestCount));\n        server.setExecutor(executor);\n        server.start();\n\n        RestAssured.authentication = RestAssured.basic(USER_NAME, PASSWORD);\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .auth()\n                    .none()\n                    .when()\n                    .get(\"/secured\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_UNAUTHORIZED);\n\n            assertThat(authorizationHeaderSeen).isFalse();\n            assertThat(requestCount.get()).isEqualTo(1);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendSecuredResponse(\n            HttpExchange exchange,\n            AtomicBoolean authorizationHeaderSeen,\n            AtomicInteger requestCount) throws IOException {\n        try {\n            requestCount.incrementAndGet();\n            Headers requestHeaders = exchange.getRequestHeaders();\n            authorizationHeaderSeen.set(AUTHORIZATION_HEADER.equals(requestHeaders.getFirst(\"Authorization\")));\n            Headers responseHeaders = exchange.getResponseHeaders();\n            responseHeaders.add(\"WWW-Authenticate\", \"Basic realm=\\\"rest-assured-test\\\"\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780933604150}}
