equestSpecificationImpl$_removeCookie_closure2 extends Closure {\n    private final Reference cookieName;\n\n    RequestSpecificationImpl$_removeCookie_closure2(Object owner, Object thisObject, Reference cookieName) {\n        super(owner, thisObject);\n        this.cookieName = cookieName;\n    }\n\n    public Object doCall(Object cookie) {\n        return !((String) cookieName.get()).equalsIgnoreCase((String) cookie.getClass().getMethod(\"getName\").invoke(cookie));\n    }\n\n    static Class class$(String className) {\n        try {\n            return Class.forName(className);\n        } catch (ClassNotFoundException e) {\n            throw new NoClassDefFoundError(e.getMessage());\n        }\n    }\n}\nEOF\njavac --release 8 -cp /home/vjovanov/.gradle/wrapper/dists/gradle-9.1.0-bin/y1dln97n0cqd2nzudb56rp9n/gradle-9.1.0/lib/groovy-4.0.28.jar -d \"$tmp/classes\" \"$tmp/io/restassured/internal/RequestSpecificationImpl\\$_removeCookie_closure2.java\"\nbase64 -w0 \"$tmp/classes/io/restassured/internal/RequestSpecificationImpl\\$_removeCookie_closure2.class\"\nrm -rf \"$tmp\"", "timeout": 30}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 792, "output": 1430, "cacheRead": 73216, "cacheWrite": 0, "totalTokens": 75438, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778457037348, "responseId": "resp_0b7c467f9a487366016a0119ce55c48197b44910fc6ccb0b7e"}}
