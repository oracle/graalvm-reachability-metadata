  import java.util.Base64
  
  import org.gradle.api.Task
  import org.gradle.api.file.Directory
  import org.gradle.api.provider.Provider
  import org.gradle.api.tasks.TaskProvider
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "io.rest-assured:rest-assured:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  Provider<Directory> generatedDirectAccessClasses = layout.buildDirectory.dir("generated/direct-access-test-classes")
  Closure<Void> writeGeneratedDirectAccessClass = { String path, String content ->
      File outputFile = generatedDirectAccessClasses.get().file(path).asFile
      outputFile.parentFile.mkdirs()
      outputFile.bytes = Base64.decoder.decode(content)
      null
  }
  
