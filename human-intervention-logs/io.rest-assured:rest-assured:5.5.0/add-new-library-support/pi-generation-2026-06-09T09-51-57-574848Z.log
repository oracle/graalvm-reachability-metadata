keMethod(\n                \"class$\",\n                new Object[] {PreemptiveBasicAuthScheme.class.getName()});\n\n        assertThat(resolvedClass).isSameAs(PreemptiveBasicAuthScheme.class);\n    }\n\n    @Test\n    void appliesPreemptiveBasicAuthenticationWithoutChallenge() throws Exception {\n        AtomicInteger requestCount = new AtomicInteger();\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/secured\", exchange -> sendPreemptiveResponse(exchange, requestCount));\n        server.setExecutor(executor);\n        server.start();\n\n        AuthenticationScheme previousAuthentication = RestAssured.authentication;\n        RestAssured.authentication = RestAssured.preemptive().basic(USER_NAME, PASSWORD);\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/secured\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .body(equalTo(\"preemptive\"));\n            assertThat(requestCount.get()).isEqualTo(1);\n        } finally {\n            RestAssured.authentication = previousAuthentication;\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendPreemptiveResponse(HttpExchange exchange, AtomicInteger requestCount) throws IOException {\n        requestCount.incrementAndGet();\n        try {\n            Headers requestHeaders = exchange.getRequestHeaders();\n            if (!AUTHORIZATION_HEADER.equals(requestHeaders.getFirst(\"Authorization\"))) {\n                Headers responseHeaders = exchange.getResponseHeaders();\n                responseHeaders.add(\"WWW-Authenticate\", \"Basic realm