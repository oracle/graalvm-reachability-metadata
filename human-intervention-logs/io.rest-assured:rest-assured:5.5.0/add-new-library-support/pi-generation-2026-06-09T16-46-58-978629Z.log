sUsed\n    89\t                    ? \"{\\\"message\\\":\\\"accepted\\\",\\\"count\\\":8}\"\n    90\t                    : \"{\\\"message\\\":\\\"unexpected\\\",\\\"count\\\":0}\").getBytes(StandardCharsets.UTF_8);\n    91\t\n    92\t            exchange.getResponseHeaders().set(\"Content-Type\", \"application/json\");\n    93\t            exchange.sendResponseHeaders(\n    94\t                    gsonMapperWasUsed ? HttpURLConnection.HTTP_OK : HttpURLConnection.HTTP_BAD_REQUEST,\n    95\t                    responseBytes.length);\n"}], "isError": false, "timestamp": 1781023800934}]}
