          try {
              Filter firstFilter = (requestSpecification, responseSpecification, context) ->
                      context.next(requestSpecification, responseSpecification);
              Filter secondFilter = (requestSpecification, responseSpecification, context) ->
                      context.next(requestSpecification, responseSpecification);
  
