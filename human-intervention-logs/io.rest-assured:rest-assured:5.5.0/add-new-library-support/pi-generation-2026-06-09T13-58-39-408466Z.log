[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/FilterContextImplTest.java","edits":[{"oldText":"import java.io.OutputStream;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.ArrayList;\nimport java.util.List;\n","newText":"import java.io.OutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.ArrayList;\nimport java.util.List;\n"},{"oldText":"import io.restassured.filter.Filter;\nimport io.restassured.response.Response;\n","newText":"import io.restassured.filter.Filter;\nimport io.restassured.internal.filter.FilterContextImpl;\nimport io.restassured.response.Response;\n"},{"oldText":"    void filterContextPassesSharedValuesToNextFilterAndCanSendRequestDirectly() throws IOException {\n","newText":"    void filterContextPassesSharedValuesToNextFilter() throws Throwable {\n        MethodHandle classHelper = generatedClassLookup();\n        assertThat(invokeGeneratedClassLookup(classHelper, FilterContextImpl.class.getName()))\n                .isSameAs(FilterContextImpl.class);\n\n"},{"oldText":"        Filter sendWithContextValue = (requestSpecification, responseSpecification, context) -> {\n","newText":"        Filter continueWithContextValue = (requestSpecification, responseSpecification, context) -> {\n"},{"oldText":"            invocations.add(\"send:\" + correlationId);\n\n            requestSpecification.header(\"X-Filter-Context\", correlationId);\n            return context.send(requestSpecification);\n","newText":"            invocations.add(\"continue:\" + correlationId);\n\n            requestSpecification.header(\"X-Filter-Context\", correlationId);\n            return context.next(requestSpecification, responseSpecification);\n"},{"oldText":"                    .filters(seedContextValue, sendWithContextValue)\n","newText":"                    .filters(seedContextValue, continueWithContextValue)\n"},{"oldText":"            assertThat(invocations).containsExactly(\"seed:true\", \"send:ctx-123\");\n","newText":"            assertThat(invocations).containsExactly(\"seed:true\", \"continue:ctx-123\");\n"},{"oldText":"    private static void sendObservedHeader(HttpExchange exchange) throws IOException {\n","newText":"    private static MethodHandle generatedClassLookup() throws NoSuchMethodException, IllegalAccessException {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(FilterContextImpl.class, MethodHandles.lookup());\n        return lookup.findStatic(FilterContextImpl.class, \"class$\", MethodType.methodType(Class.class, String.class));\n    }\n\n    private static Class<?> invokeGeneratedClassLookup(MethodHandle classHelper, String className) throws Throwable {\n        return (Class<?>) classHelper.invokeExact(className);\n    }\n\n    private static void sendObservedHeader(HttpExchange exchange) throws IOException {\n"}]}
