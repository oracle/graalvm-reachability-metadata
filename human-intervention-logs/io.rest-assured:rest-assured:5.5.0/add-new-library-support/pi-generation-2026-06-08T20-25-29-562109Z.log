izer = ((GroovyObject) parameterUpdater).getProperty(\"serializer\");\n\n        Class<?> resolvedClass = invokeGeneratedClassLookup(serializer, String.class.getName());\n        assertThat(resolvedClass).isEqualTo(String.class);\n    }\n\n    private static Class<?> invokeGeneratedClassLookup(Object serializer, String className) throws Throwable {\n        Class<?> serializerClass = serializer.getClass();\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(serializerClass, MethodHandles.lookup());\n        MethodHandle classHelper = lookup.findStatic(\n                serializerClass,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n        return (Class<?>) classHelper.invoke(className);\n    }\n}\n"}
