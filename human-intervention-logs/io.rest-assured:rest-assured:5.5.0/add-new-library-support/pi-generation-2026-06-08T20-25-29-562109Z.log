          }
        } else {
          to.put(key, newValue)
        }
      } else {
        to.put(key, newValue)
      }
    }
  
    private static boolean isEmpty(Object[] objects) {
      return objects == null || objects.length == 0 || (objects.length == 1 && objects[0] instanceof NoParameterValue)
