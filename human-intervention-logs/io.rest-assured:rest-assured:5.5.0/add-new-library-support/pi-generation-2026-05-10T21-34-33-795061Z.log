              return false;
          }
          Throwable cause = initializerError.getException();
          return cause instanceof NullPointerException
                  && cause.getStackTrace().length > 0
                  && "groovy.lang.GroovySystem".equals(cause.getStackTrace()[0].getClassName());
      }
