  import java.util.Base64
  
  import org.gradle.api.Task
  import org.gradle.api.file.Directory
  import org.gradle.api.provider.Provider
  import org.gradle.api.tasks.TaskProvider
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "io.rest-assured:rest-assured:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  Provider<Directory> generatedDirectAccessClasses = layout.buildDirectory.dir("generated/direct-access-test-classes")
  Closure<Void> writeGeneratedDirectAccessClass = { String path, String content ->
      File outputFile = generatedDirectAccessClasses.get().file(path).asFile
      outputFile.parentFile.mkdirs()
      outputFile.bytes = Base64.decoder.decode(content)
      null
  }
  
  // The Groovy-generated class$ method is synthetic, so javac cannot call it directly.
  // This helper contains only the direct invokestatic needed for dynamic-access coverage.
  TaskProvider<Task> generateDirectAccessClass = tasks.register("generateDirectAccessClass") {
      outputs.dir(generatedDirectAccessClasses)
  
      doLast {
          writeGeneratedDirectAccessClass(
                  "io/restassured/internal/RequestSpecificationImplHeaderClosure8Access.class",
                  "")
          writeGeneratedDirectAccessClass(
                  "io/restassured/internal/RequestSpecificationImplUndefinedPathParamPlaceholdersClosure46Access.class",
                  "")
          writeGeneratedDirectAccessClass(
                  "io/restassured/internal/RequestSpecificationImplGetUnnamedPathParamsClosure42Access.class",
                  "")
          writeGeneratedDirectAccessClass(
                  "io/restassured/internal/RequestSpecificationImplGetUnnamedPathParamValuesClosure43Access.class",
                  "")
          writeGeneratedDirectAccessClass(
                  "io/restassured/internal/RequestSpecificationImplGetUnnamedPathParamValuesClosure44Access.class",
                  "")
          writeGeneratedDirectAccessClass(
                  "io/restassured/internal/RequestSpecificationImplHandleMultiValueParamsIfNeededClosure37Access.class",
                  "")
      }
  }
  
  sourceSets {
      test {
          output.dir(generatedDirectAccessClasses, builtBy: generateDirectAccessClass)
      }
  }
  
  tasks.named("compileTestJava") {
      dependsOn(generateDirectAccessClass)
      classpath += files(generatedDirectAccessClasses)
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
