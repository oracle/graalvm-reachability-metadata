l class RecordingOrderedFilter implements OrderedFilter {\n        private final String name;\n        private final int order;\n        private final List<String> invocations;\n\n        private RecordingOrderedFilter(String name, int order, List<String> invocations) {\n            this.name = name;\n            this.order = order;\n            this.invocations = invocations;\n        }\n\n        @Override\n        public Response filter(\n                FilterableRequestSpecification requestSpec,\n                FilterableResponseSpecification responseSpec,\n                FilterContext ctx) {\n            invocations.add(name);\n            return ctx.next(requestSpec, responseSpec);\n        }\n\n        @Override\n        public int getOrder() {\n            return order;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 455, "output": 1125, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31276, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780955205156, "responseId": "resp_075d40d8f56de983016a273845e574819396a893232b041922"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_CXexpDR9xeQJGTglHa5RmxiK|fc_075d40d8f56de983016a27384abf588193a854eec5af76787c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3902 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_applyPathParamsAndSendRequest_closure33Test.java"}], "isError": false, "timestamp": 1780955217656}]}
