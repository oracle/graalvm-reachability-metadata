aseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .basePath(\"/api\")\n                    .pathParam(\"orderId\", \"named-order\")\n                    .filter(capturePathParameters)\n                    .when()\n                    .get(\"/orders/{orderId}/items/{itemId}\", \"unnamed-item\");\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString()).isEqualTo(\"/api/orders/named-order/items/unnamed-item\");\n            assertThat(pathParameters.get()).containsExactly(\n                    AbstractMap.SimpleEntry.entry(\"orderId\", \"named-order\"),\n                    AbstractMap.SimpleEntry.entry(\"itemId\", \"unnamed-item\"));\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n\n    private static void sendObservedPath(HttpExchange exchange) throws IOException {\n        byte[] responseBytes = exchange.getRequestURI().getPath().getBytes(StandardCharsets.UTF_8);\n        exchange.sendResponseHeaders(200, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1221, "output": 1146, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 28991, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780963573925, "responseId": "resp_046f5d11b45dee1c016a2758f65f20819680e55ce5b9d71b85"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_liAzbIPUH4Tae9KEaSjKhQKx|fc_046f5d11b45dee1c016a2758ffc8b88196b844f53099775444", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2975 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_getPathParams_cl