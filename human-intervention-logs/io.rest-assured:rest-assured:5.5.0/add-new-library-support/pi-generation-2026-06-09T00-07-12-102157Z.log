  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RequestSpecificationImplInner_getDerivedPath_closure38Test {
      @Test
      void specificationQuerierReadsDerivedPathAfterNamedPathParametersAreApplied() {
          RestAssured.reset();
  
          try {
              RequestSpecification specification = RestAssured
                      .given()
                      .baseUri("http://example.com")
                      .basePath("/api")
                      .pathParam("orderId", "first");
              ((FilterableRequestSpecification) specification).path("/orders/{orderId}");
  
              String derivedPath = SpecificationQuerier.query(specification).getDerivedPath();
  
              assertThat(derivedPath).isEqualTo("/api/orders/first");
          } finally {
              RestAssured.reset();
          }
      }
  
      @Test
      void filterCanReadDerivedPathAfterUnnamedPathParametersAreApplied() throws IOException {
          AtomicReference<String> derivedPath = new AtomicReference<>();
