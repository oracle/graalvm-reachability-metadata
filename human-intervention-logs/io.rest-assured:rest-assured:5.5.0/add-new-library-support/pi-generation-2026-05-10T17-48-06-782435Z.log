forge_metadata.py:35:from dataclasses import dataclass\nforge/forge_metadata.py:2413:    \"\"\"Load dynamic-access coverage from the stored run metrics stats block.\"\"\"\nforge/forge_metadata.py:2429:    covered_calls = int(dynamic_access.get(\"coveredCalls\", 0) or 0)\nforge/forge_metadata.py:2443:    \"\"\"Resolve the dynamic-access coverage report path for a new-library issue.\"\"\"\nforge/forge_metadata.py:2449:        \"dynamic-access\",\nforge/forge_metadata.py:2450:        \"dynamic-access-coverage.json\",\nforge/forge_metadata.py:2455:    \"\"\"Load dynamic-access coverage directly from the generated report as a fallback.\"\"\"\nforge/forge_metadata.py:2585:        \"Analyze the generated tests, metadata, stats, and dynamic-access report in this repository. \"\nforge/forge_metadata.py:2589:        \"- Explain briefly why dynamic-access coverage is missing or still very low.\\n\"\nforge/forge_metadata.py:2608:        f\"Automation completed for `{claimed_issue.issue_coordinates}`, but dynamic-access coverage remains \"\nforge/forge_metadata.py:2610:        \"This suggests the generated tests are not exercising the required dynamic-access paths well enough.\\n\\n\"\nforge/forge_metadata.py:2612:        \"- Inspect the generated tests and compare them with the dynamic-access report to find uncovered call sites.\\n\"\nforge/forge_metadata.py:3379:            pipeline_argv.append(\"--keep-tests-without-dynamic-access\")\nforge/forge_metadata.py:5541:        \"--keep-tests-without-dynamic-access\",\nforge/forge_metadata.py:5544:            \"Forwarded to the new-library pipeline. Keeps generated tests for dynamic-access \"\nforge/forge_metadata.py:5545:            \"strategies even when no dynamic-access coverage is added.\"\nforge/utility_scripts/native_test_verification.py:63:@dataclass\nforge/utility_scripts/native_test_verification.py:72:@dataclass\nforge/utility_scripts/test_quality_checks.py:6:from dataclasses import dataclass\nforge/utility_scripts/metrics_writer.py:78:    \"\"\"Return True when the dynamic-access stats entry matches the expected object shape.\"\"\"\nforge/utility_scripts/metrics_writer.py:82:    required_keys = {\"coveredCalls\", \"totalCalls\", \"coverageRatio\", \"breakdown\"}\nforge/utility_scripts/native_image_artifact.py:8:from dataclasses import dataclass\nforge/utility_scripts/dynamic_access_report.py:8:from dataclasses import dataclass\nforge/utility_scripts/dynamic_access_report.py:107:                covered_calls=int(class_payload.get(\"coveredCalls\", 0)),\nforge/utility_scripts/dynamic_access_report.py:117:        covered_calls=int(totals.get(\"coveredCalls\", 0)),\nforge/utility_scripts/dynamic_access_report.py:160:        return \"All dynamic-access call sites are covered.\"\nforge/utility_scripts/gradle_test_runner.py:8:from dataclasses import dataclass\nforge/utility_scripts/local_ci_verification.py:39:@dataclass\nforge/utility_scripts/local_ci_verification.py:51:@dataclass\nforge/utility_scripts/local_ci_verification.py:62:@dataclass\nforge/utility_scripts/source_context.py:15:from dataclasses import dataclass\nforge/utility_scripts/native_metadata_exploration.py:54:@dataclass\nforge/utility_scripts/native_metadata_exploration.py:64:@dataclass\nforge/utility_scripts/large_library_progress.py:104:@dataclass\nforge/utility_scripts/large_library_progress.py:172:            covered_calls=int(payload.get(\"coveredCalls\", 0)),\nforge/utility_scripts/large_library_progress.py:206:            \"coveredCalls\": self.covered_calls,\nforge/utility_scripts/large_library_progress.py:246:        \"\"\"Record aggregate dynamic-access coverage.\"\"\"\nforge/benchmarks/benchmark_runner.py:67:        \"--keep-tests-without-dynamic-access\",\nforge/benchmarks/benchmark_runner.py:70:            \"Forwarded to add_new_library_support.py. Keeps generated tests for dynamic-access strategies \"\nforge/benchmarks/benchmark_runner.py:71:            \"even when no dynamic-access coverage is added.\"\nforge/