Builder;\nimport io.restassured.config.RestAssuredConfig;\nimport io.restassured.filter.Filter;\nimport io.restassured.filter.FilterContext;\nimport io.restassured.filter.log.LogDetail;\nimport io.restassured.response.Response;\nimport io.restassured.specification.FilterableRequestSpecification;\nimport io.restassured.specification.FilterableResponseSpecification;\nimport io.restassured.specification.ResponseSpecification;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.expect;\nimport static io.restassured.RestAssured.given;\nimport static io.restassured.config.LogConfig.logConfig;\nimport static org.assertj.core.api.Assertions.assertThat;\n"}, {"oldText": "    private static void handleEvents(HttpExchange exchange) throws IOException {\n        try {\n            byte[] responseBytes = \"event-42\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);\n            try (OutputStream outputStream = exchange.getResponseBody()) {\n                outputStream.write(responseBytes);\n            }\n        } finally {\n            exchange.close();\n        }\n    }\n}\n", "newText": "    @Test\n    void responseSpecificationLogDetailChecksExistingNonResponseLoggingFilters() throws Throwable {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/events\", exchange -> handleEvents(exchange));\n        server.setExecutor(executor);\n        server.start();\n        RestAssured.reset();\n\n        ByteArrayOutputStream logOutput = new ByteArrayOutputStream();\n        PrintStream logStream = new PrintStream(logOutput, true, StandardCharsets.UTF_8);\n        RestAssuredConfig config = RestAssuredConfig.config().logConfig(logConfig().defaultStream(logStream));\n        AtomicBoolean customFilterWasInvoked = new AtomicBoolean();\n        ResponseSpecification responseSpecification = new ResponseSpecBuilder()\n                .log(LogDetail.BODY)\n                .build();\n\n        try {\n            Response response = given()\n                    .config(config)\n                    .filter(new RecordingFilter(customFilterWasInvoked))\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .expect()\n                    .spec(responseSpecification)\n                    .when()\n                    .get(\"/events/{eventId}\", \"42\");\n\n            assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_OK);\n            assertThat(response.asString()).isEqualTo(\"event-42\");\n            assertThat(customFilterWasInvoked).isTrue();\n            assertThat(logOutput.toString(StandardCharsets.UTF_8)).contains(\"event-42\");\n        } finally {\n            logStream.close();\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void handleEvents(HttpExchange exchange) throws IOException {\n        try {\n            byte[] responseBytes = \"event-42\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);\n            try (OutputStream outputStream = exchange.getResponseBody()) {\n                outputStream.write(responseBytes);\n            }\n        } finally {\n            exchange.close();\n        }\n    }\n\n    private static final class RecordingFilter implements Filter {\n        private final AtomicBoolean invoked;\n\n        private RecordingFilter(AtomicBoolean invoked) {\n            this.invoked = invoked;\n        }\n\n        @Override\n        public Response filter(\n                FilterableRequestSpecification requestSpec,\n                FilterableResponseSpecification responseSpec,\n                FilterContext ctx) {\n            invoked.set(true);\n            return ctx.next(requestSpec, responseSpec);\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 907, "output": 2285, "cacheRead": 52224, "cacheWrite": 0, "totalTokens": 55416, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780954855589, "responseId": "resp_0a589b4568d13dbb016a2736e8813081908f1d61bd02c1425e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_a8YqpBEMJMD3jkunvlRTBCV9|fc_0a589b4568d13dbb016a2736ff9f24819082131ef9b5d9647d", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_applyPathParamsAndSendRequest_closure32Test.java."}], "details": {"diff": "     ...\n  15 import java.nio.charset.StandardCharsets;\n  16 import java.util.concurrent.ExecutorService;\n  17 import java.util.concurrent.Executors;\n  18 import java.util.concurrent.TimeUnit;\n+ 19 import java.util.concurrent.atomic.AtomicBoolean;\n  19 \n  20 import com.sun.net.httpserver.HttpExchange;\n  21 import com.sun.net.httpserver.HttpServer;\n  22 import io.restassured.RestAssured;\n+ 24 import io.restassured.builder.ResponseSpecBuilder;\n  23 import io.restassured.config.RestAssuredConfig;\n+ 26 import io.restassured.filter.Filter;\n+ 27 import io.restassured.filter.FilterContext;\n+ 28 import io.restassured.filter.log.LogDetail;\n  24 import io.restassured.response.Response;\n+ 30 import io.restassured.specification.FilterableRequestSpecification;\n+ 31 import io.restassured.specification.FilterableResponseSpecification;\n+ 32 import io.restassured.specification.ResponseSpecification;\n  25 import org.junit.jupiter.api.Test;\n  26 \n  27 import static io.restassured.RestAssured.expect;\n+ 