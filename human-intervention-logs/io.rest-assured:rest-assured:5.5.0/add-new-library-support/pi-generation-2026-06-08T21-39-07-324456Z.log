          builder.append(this.@port)
        } else if (!isFullyQualified(url.toString()) || hasAuthorityEqualToLocalhost(url)) {
          builder.append(":")
          builder.append(DEFAULT_HTTP_TEST_PORT)
        }
      }
      return builder.toString()
    }
  
