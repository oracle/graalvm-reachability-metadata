tal": 0}}, "stopReason": "toolUse", "timestamp": 1780997552963, "responseId": "resp_0d4ac7c4028baf9d016a27ddb1717c819588776b4cac0918f0"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_UshoXXMnqoLrUgVSk9Qv2xE9|fc_0d4ac7c4028baf9d016a27ddb8307881958d20e099d729e96a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.http.ContentType;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.hamcrest.Matchers.containsString;\nimport static org.hamcrest.Matchers.equalTo;\nimport static org.hamcrest.Matchers.lessThan;\n\npublic class ResponseSpecificationImplTest {\n    @Test\n    void validatesResponseExpectationsThroughPublicApi() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/response\", this::sendJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/response\")\n                    .then()\n                    .statusCode(equalTo(HttpURLConnection.HTTP_OK))\n                    .statusLine(containsString(\"200\"))\n                    .contentType(ContentType.JSON)\n                    .header(\"X-Request-Id\", equalTo(\"request-1\"))\n                    .header(\"X-Body-Bytes\", Integer::parseInt, equalTo(19))\n                    .cookie(\"session\", \"abc\")\n                    .body(\"message\", equalTo(\"hello\"))\n                    .time(lessThan(5L), TimeUnit.SECONDS);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", ContentType.JSON.toString());\n            headers.add(\"X-Request-Id\", \"request-1\");\n            headers.add(\"X-Body-Bytes\", \"19\");\n            headers.add(\"Set-Cookie\", \"session=abc; Path=/; HttpOnly\");\n            byte[] body = \"{\\\"message\\\":\\\"hello\\\"}\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780997560389}, {"role": "toolResult", "toolCallId": "call_75uw9Q3k5ynFK73vGHX1IB9Z|fc_0d4ac7c4028baf9d016a27ddb83088819586d7f89527249085", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class ResponseSpecificationImplInner_header_closure6Test {\n    @Test\n    void validatesMappedHeaderExpectation() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/headers\", ResponseSpecificationImplInner_header_closure6Test::sendHeaderResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/headers\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .header(\"X-Item-Count\", Integer::parseInt, equalTo(7));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendHeaderResponse(HttpExchange exchange) throws IOException {\n        try {\n            byte[] body = \"ok\".getBytes(StandardCharsets.UTF_8);\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"X-Item-Count\", \"7\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            try (OutputStream outputStream = exchange.getResponseBody()) {\n                outputStream.write(body);\n            }\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], 