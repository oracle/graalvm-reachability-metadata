bytes = zipFile.getInputStream(zipFile.getEntry(classEntryName)).bytes\n    }\n\n    String[] constantPool = new String[readU2(bytes, 8)]\n    int position = 10\n    int index = 1\n    while (index < constantPool.length) {\n        int tag = bytes[position++] & 0xFF\n        switch (tag) {\n            case 1:\n                int length = readU2(bytes, position)\n                position += 2\n                constantPool[index] = new String(bytes, position, length, StandardCharsets.UTF_8)\n                position += length\n                break\n            case 3:\n            case 4:\n                position += 4\n                break\n            case 5:\n            case 6:\n                position += 8\n                index++\n                break\n            case 7:\n            case 8:\n            case 16:\n                position += 2\n                break\n            case 9:\n            case 10:\n            case 11:\n            case 12:\n            case 18:\n                position += 4\n                break\n            case 15:\n                position += 3\n                break\n            default:\n                throw new GradleException(\"Unsupported class file constant pool tag ${tag}\")\n        }\n        index++\n    }\n\n    position += 6\n    int interfacesCount = readU2(bytes, position)\n    position += 2 + 2 * interfacesCount\n    int fieldsCount = readU2(bytes, position)\n    position += 2\n    for (int fieldIndex = 0; fieldIndex < fieldsCount; fieldIndex++) {\n        position += 6\n        int attributesCount = readU2(bytes, position)\n        position += 2\n        for (int attributeIndex = 0; attributeIndex < attributesCount; attributeIndex++) {\n            position += 2\n            position += 4 + readU4(bytes, position)\n        }\n    }\n\n    int patchedMethods = 0\n    int methodsCount = readU2(bytes, position)\n    position += 2\n    for (int methodIndex = 0; methodIndex < methodsCount; methodIndex++) {\n        int accessFlagsPosition = position\n        int accessFlags = readU2(bytes, position)\n        int nameIndex = readU2(bytes, position + 2)\n        int descriptorIndex = readU2(bytes, position + 4)\n        int attributesCount = readU2(bytes, position + 6)\n        position += 8\n        if (constantPool[nameIndex] == \"class$\" && constantPool[descriptorIndex] == \"(Ljava/lang/String;)Ljava/lang/Class;\") {\n            writeU2(bytes, accessFlagsPosition, accessFlags & ~0x1000)\n            patchedMethods++\n        }\n        for (int attributeIndex = 0; attributeIndex < attributesCount; attributeIndex++) {\n            position += 2\n            position += 4 + readU4(bytes, position)\n        }\n    }\n    if (patchedMethods != 1) {\n        throw new GradleException(\"Expected to patch one TestSpecificationImpl class resolver but patched ${patchedMethods}\")\n    }\n\n    File outputFile = generatedDirectAccessClasses.get().file(classEntryName).asFile\n    outputFile.parentFile.mkdirs()\n    outputFile.bytes = bytes\n    null\n}\n\n// The Groovy-generated class$ method is synthetic, so javac cannot call it directly and"},{"oldText":"    outputs.file(generatedDirectAccessClasses.map { Directory directory ->\n        directory.file(\"io/restassured/internal/SpecificationMergerDirectAccess.class\")\n    })\n    outputs.file(generatedDirectAccessClasses.map { Directory directory ->\n        directory.file(\"io/restassured/internal/TestSpecificationImplDirectAccess.class\")\n    })","newText":"    outputs.file(generatedDirectAccessClasses.map { Directory directory ->\n        directory.file(\"io/restassured/internal/SpecificationMergerDirectAccess.class\")\n    })\n    outputs.file(generatedDirectAccessClasses.map { Directory directory ->\n        directory.file(\"io/restassured/internal/TestSpecificationImpl.class\")\n    })\n    outputs.file(generatedDirectAccessClasses.map { Directory directory ->\n        directory.file(\"io/restassured/internal/TestSpecif