      if (patchedMethods != 1) {
          throw new GradleException(
                  "Expected to patch one TestSpecificationImpl class resolver but patched ${patchedMethods}")
      }
  
      File outputFile = generatedDirectAccessClasses.get().file(classEntryName).asFile
      outputFile.parentFile.mkdirs()
