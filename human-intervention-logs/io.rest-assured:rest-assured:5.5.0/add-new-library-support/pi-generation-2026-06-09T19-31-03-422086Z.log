reset();\n\n        try {\n            Response response = given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .multiPart(\"description\", \"native-image multipart\", \"text/plain\")\n                    .multiPart(\n                            \"payload\",\n                            \"payload.bin\",\n                            \"binary payload\".getBytes(StandardCharsets.UTF_8),\n                            \"application/octet-stream\")\n                    .when()\n                    .post(\"/upload\");\n\n            assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_OK);\n            assertThat(response.asString()).isEqualTo(\"multipart content received\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n\n    private static Class<?> invokeGeneratedClassLookup(String className) throws Throwable {\n        Class<?> multiPartInternalClass = MultiPartInternalTest.class\n                .getClassLoader()\n                .loadClass(MULTI_PART_INTERNAL_CLASS_NAME);\n        Method classHelper = multiPartInternalClass.getDeclaredMethod(\"class$\", String.class);\n        classHelper.setAccessible(true);\n        return (Class<?>) classHelper.invoke(null, className);\n    }\n\n    private static void handleUpload(HttpExchange exchange) throws IOException {\n        try {\n            String contentType = exchange.getRequestHeaders().getFirst(\"Content-Type\");\n            String body = new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.ISO_8859_1);\n            boolean receivedExpectedParts = \"POST\".equals(exchange.getRequestMethod())\n                    && contentType != null\n                    && contentType.startsWith(\"multipart/form-data\")\n                    && body.contains(\"name=\\\"description\\\"\")\n                    && body.contains(\"Content-Type: text/plain\")\n                    && body.contains(\"native-image multipart\")\n                    && body.contains(\"name=\\\"payload\\\"; filename=\\\"payload.bin\\\"\")\n                    && body.contains(\"Content-Type: application/octet-stream\")\n                    && body.contains(\"binary payload\");\n            byte[] responseBytes = (receivedExpectedParts\n                    ? \"multipart content received\"\n                    : \"multipart content missing\").getBytes(StandardCharsets.UTF_8);\n\n            exchange.sendResponseHeaders(\n                    receivedExpectedParts ? HttpURLConnection.HTTP_OK : HttpURLConnection.HTTP_BAD_REQUEST,\n                    responseBytes.length);\n            try (OutputStream outputStream = exchange.getResponseBody()) {\n                outputStream.write(responseBytes);\n            }\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1323, "output": 1666, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 39853, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781033391490, "responseId": "resp_01b9dee2c9eac394016a2869b025448195b1ae61e66e664789"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_dVYliKZ1NhHbpRHIJsd8BeV2|fc_01b9dee2c9eac394016a2869c5cdd88195bf0690182199c26e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4222 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/MultiPartInternalTest.java"}], "isError": false, "timestamp": 1781033425264}]}
