  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package io_rest_assured.rest_assured;
  
  import groovy.lang.MetaClass;
  import io.restassured.RestAssured;
  import io.restassured.authentication.AuthenticationScheme;
  import io.restassured.authentication.NTLMAuthScheme;
  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class NTLMAuthSchemeTest {
      private static final String USER_NAME = "ntlm-user";
      private static final String PASSWORD = "ntlm-password";
      private static final String WORKSTATION = "ntlm-workstation";
      private static final String DOMAIN = "ntlm-domain";
  
      @Test
      void createsNtlmAuthenticationSchemeWithConfiguredCredentials() {
          AuthenticationScheme authenticationScheme = RestAssured.ntlm(
                  USER_NAME, PASSWORD, WORKSTATION, DOMAIN);
  
          assertThat(authenticationScheme).isInstanceOf(NTLMAuthScheme.class);
          NTLMAuthScheme ntlmAuthScheme = (NTLMAuthScheme) authenticationScheme;
          assertThat(ntlmAuthScheme.getUserName()).isEqualTo(USER_NAME);
          assertThat(ntlmAuthScheme.getPassword()).isEqualTo(PASSWORD);
          assertThat(ntlmAuthScheme.getWorkstation()).isEqualTo(WORKSTATION);
          assertThat(ntlmAuthScheme.getDomain()).isEqualTo(DOMAIN);
      }
  
      @Test
      void createsNtlmAuthenticationSchemeFromRequestAuthenticationDsl() {
          RequestSpecification specification = given()
                  .auth()
                  .ntlm(USER_NAME, PASSWORD, WORKSTATION, DOMAIN);
  
          assertThat(SpecificationQuerier.query(specification).getAuthenticationScheme())
                  .isInstanceOf(NTLMAuthScheme.class);
      }
  
      @Test
      void groovyMetaClassResolvesGeneratedClassHelper() {
          NTLMAuthScheme authenticationScheme = (NTLMAuthScheme) RestAssured.ntlm(
                  USER_NAME, PASSWORD, WORKSTATION, DOMAIN);
          MetaClass metaClass = authenticationScheme.getMetaClass();
  
          Object resolvedClass = metaClass.invokeStaticMethod(
                  NTLMAuthScheme.class,
                  "class$",
                  new Object[] {NTLMAuthScheme.class.getName()});
  
          assertThat(resolvedClass).isSameAs(NTLMAuthScheme.class);
      }
  }
