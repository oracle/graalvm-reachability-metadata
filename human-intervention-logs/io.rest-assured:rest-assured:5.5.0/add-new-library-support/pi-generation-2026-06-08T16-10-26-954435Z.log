tionQuerier.query(specification).getAuthenticationScheme())\n                .isInstanceOf(NTLMAuthScheme.class);\n    }\n\n    @Test\n    void groovyMetaClassResolvesGeneratedClassHelper() {\n        NTLMAuthScheme authenticationScheme = (NTLMAuthScheme) RestAssured.ntlm(\n                USER_NAME, PASSWORD, WORKSTATION, DOMAIN);\n        MetaClass metaClass = authenticationScheme.getMetaClass();\n\n        Object resolvedClass = metaClass.invokeStaticMethod(\n                NTLMAuthScheme.class,\n                \"class$\",\n                new Object[] {NTLMAuthScheme.class.getName()});\n\n        assertThat(resolvedClass).isSameAs(NTLMAuthScheme.class);\n    }\n}\n"}], "isError": false, "timestamp": 1780934953483}, {"role": "toolResult", "toolCallId": "call_BqGW5EA8gJUNKf9lpZCCs3pt|fc_06c953a9b5c816d1016a26e9293d40819591dd8adfce7e7196", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.rest-assured:rest-assured:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780934953483}]}
