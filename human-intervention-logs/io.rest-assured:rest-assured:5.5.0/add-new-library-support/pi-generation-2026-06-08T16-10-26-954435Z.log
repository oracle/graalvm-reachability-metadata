      assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);\n        OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;\n        assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);\n    }\n\n    @Test\n    void groovyMetaClassResolvesGeneratedClassHelper() {\n        OAuth2Scheme authenticationScheme = (OAuth2Scheme) RestAssured.oauth2(\n                ACCESS_TOKEN, OAuthSignature.QUERY_STRING);\n        MetaClass metaClass = authenticationScheme.getMetaClass();\n\n        Object resolvedClass = metaClass.invokeStaticMethod(\n                OAuth2Scheme.class,\n                \"class$\",\n                new Object[] {OAuth2Scheme.class.getName()});\n\n        assertThat(resolvedClass).isSameAs(OAuth2Scheme.class);\n    }\n}\n"}
