  package io_rest_assured.rest_assured;
  
  import io.restassured.RestAssured;
  import io.restassured.authentication.AuthenticationScheme;
  import io.restassured.authentication.OAuth2Scheme;
  import io.restassured.authentication.OAuthSignature;
  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OAuth2SchemeTest {
      private static final String ACCESS_TOKEN = "oauth2-access-token";
  
      @Test
      void createsOAuth2AuthenticationSchemeWithConfiguredHeaderSignature() {
          AuthenticationScheme authenticationScheme = RestAssured.oauth2(ACCESS_TOKEN, OAuthSignature.HEADER);
  
          assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);
          OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;
          assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.HEADER);
      }
  
      @Test
      void createsOAuth2AuthenticationSchemeWithConfiguredQuerySignature() {
          AuthenticationScheme authenticationScheme = RestAssured.oauth2(ACCESS_TOKEN, OAuthSignature.QUERY_STRING);
  
          assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);
          OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;
          assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);
      }
  
      @Test
      void createsOAuth2AuthenticationSchemeFromRequestAuthenticationDsl() {
          RequestSpecification specification = given()
                  .auth()
                  .oauth2(ACCESS_TOKEN, OAuthSignature.QUERY_STRING);
  
          AuthenticationScheme authenticationScheme = SpecificationQuerier.query(specification).getAuthenticationScheme();
          assertThat(authenticationScheme).isInstanceOf(OAuth2Scheme.class);
          OAuth2Scheme oauth2Scheme = (OAuth2Scheme) authenticationScheme;
          assertThat(oauth2Scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauth2Scheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);
      }
  
  }
