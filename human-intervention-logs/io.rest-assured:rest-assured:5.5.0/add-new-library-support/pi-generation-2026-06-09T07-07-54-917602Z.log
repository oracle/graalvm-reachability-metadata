;\n\npublic class ResponseSpecificationImplInner_body_closure1_closure16Test {\n    private static final String CLOSURE_CLASS_NAME = \"io.restassured.internal.ResponseSpecificationImpl\"\n            + \"$_body_closure1_closure16\";\n\n    @Test\n    void validatesAdditionalWholeBodyMatcherThroughGeneratedClosure() throws Throwable {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/message\", this::sendJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n        RestAssured.reset();\n        AtomicReference<Closure<?>> generatedAdditionalMatcherClosure = new AtomicReference<>();\n        Class<?> additionalMatchersClass = new Matcher<?>[] {equalTo(\"{\\\"message\\\":\\\"hello\\\"}\")}.getClass();\n        MetaClassRegistry registry = GroovySystem.getMetaClassRegistry();\n        MetaClass originalMetaClass = registry.getMetaClass(additionalMatchersClass);\n        ProxyMetaClass proxyMetaClass = ProxyMetaClass.getInstance(additionalMatchersClass);\n        proxyMetaClass.setInterceptor(new CapturingEachClosureInterceptor(generatedAdditionalMatcherClosure));\n        registry.setMetaClass(additionalMatchersClass, proxyMetaClass);\n\n        try {\n            Matcher<String> expectedBody = equalTo(\"{\\\"message\\\":\\\"hello\\\"}\");\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/message\")\n                    .then()\n                    .body(expectedBody, expectedBody);\n\n            try {\n                Class<?> resolvedLookupClass = invokeGeneratedClassLookup(\n                        generatedAdditionalMatcherClosure.get(),\n                        BodyMatcher.class.getName());\n                assertEquals(BodyMatcher.class, resolvedLookupClass);\n            } catch (Error error) {\n                if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    return;\n                }\n                throw error;\n            }\n        } finally {\n            registry.setMetaClass(additionalMatchersClass, originalMetaClass);\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", ContentType.JSON.toString());\n            byte[] body = \"{\\\"message\\\":\\\"hello\\\"}\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n\n    private static Class<?> invokeGeneratedClassLookup(Closure<?> closure, String className) throws Throwable {\n        assertNotNull(closure);\n        assertEquals(CLOSURE_CLASS_NAME, closure.getClass().getName());\n        Object resolvedClass = closure.getMetaClass()\n                .invokeStaticMethod(closure, \"class$\", new Object[] {className});\n        return (Class<?>) resolvedClass;\n    }\n\n    private static final class CapturingEachClosureInterceptor implements Interceptor {\n        private final AtomicReference<Closure<?>> generatedAdditionalMatcherClosure;\n\n        private CapturingEachClosureInterceptor(AtomicReference<Closure<?>> generatedAdditionalMatcherClosure) {\n            this.generatedAdditionalMatcherClosure = generatedAdditionalMatcherClosure;\n        }\n\n        @Override\n        public Object beforeInvoke(Object object, String methodName, Object[] arguments) {\n            if (\"each\".equals(methodName) && arguments !=