[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/MapCreatorInner_createArgumentArrayFromKeyAndValue_closure3Test.java","edits":[{"oldText":"import io.restassured.internal.MapCreator;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport static org.junit.jupiter.api.Assertions.assertSame;\n","newText":"import io.restassured.internal.MapCreator;\nimport org.codehaus.groovy.runtime.InvokerHelper;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.reflect.Method;\nimport java.util.Map;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n"},{"oldText":"    @Test\n    void resolvesCompilerGeneratedClassResolver() throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                MapCreator.class,\n                MethodHandles.lookup());\n        Class<?> closureClass = lookup.findClass(CLOSURE_CLASS_NAME);\n        MethodHandle classResolver = lookup.findStatic(\n                closureClass,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n\n        Class<?> resolvedClass = (Class<?>) classResolver.invokeWithArguments(CLOSURE_CLASS_NAME);\n\n        assertSame(closureClass, resolvedClass);\n    }\n","newText":"    @Test\n    void createMapFromParamsCopiesAdditionalKeyValuePairsThroughClosure() {\n        Map<String, Object> map = MapCreator.createMapFromParams(\n                MapCreator.CollisionStrategy.OVERWRITE,\n                \"first\",\n                \"one\",\n                \"second\",\n                \"two\",\n                \"third\",\n                \"three\");\n\n        assertEquals(\"one\", map.get(\"first\"));\n        assertEquals(\"two\", map.get(\"second\"));\n        assertEquals(\"three\", map.get(\"third\"));\n    }\n\n    @Test\n    void resolvesCompilerGeneratedClassResolverWithMethodHandle() throws Throwable {\n        Class<?> closureClass = closureClass();\n        MethodHandle classResolver = classResolver(closureClass);\n\n        Class<?> resolvedClass = (Class<?>) classResolver.invokeWithArguments(String.class.getName());\n\n        assertSame(String.class, resolvedClass);\n    }\n\n    @Test\n    void resolvesCompilerGeneratedClassResolverThroughGroovyStaticDispatch() throws Throwable {\n        Object resolvedClass = InvokerHelper.invokeStaticMethod(\n                closureClass(),\n                \"class$\",\n                new Object[] {String.class.getName()});\n\n        assertSame(String.class, resolvedClass);\n    }\n\n    @Test\n    void resolvesCompilerGeneratedClassResolverWithJavaMethodDispatch() throws Throwable {\n        Method classResolver = closureClass().getDeclaredMethod(\"class$\", String.class);\n        classResolver.setAccessible(true);\n\n        Object resolvedClass = classResolver.invoke(null, String.class.getName());\n\n        assertSame(String.class, resolvedClass);\n    }\n\n    private static Class<?> closureClass() throws IllegalAccessException, ClassNotFoundException {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                MapCreator.class,\n                MethodHandles.lookup());\n        return lookup.findClass(CLOSURE_CLASS_NAME);\n    }\n\n    private static MethodHandle classResolver(Class<?> closureClass)\n            throws IllegalAccessException, NoSuchMethodException {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                closureClass,\n                MethodHandles.lookup());\n        return lookup.findStatic(\n                closureClass,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n    }\n"}]}
