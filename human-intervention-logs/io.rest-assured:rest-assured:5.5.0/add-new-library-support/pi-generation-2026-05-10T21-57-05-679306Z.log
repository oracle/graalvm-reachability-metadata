  metadata/org.json/json/index.json:9:    "description" : "JSON-java is a reference implementation of JSON for Java that parses JSON text into Java objects and generates JSON text from Java classes. It also provides encoders and decoders plus conversion utilities for JSON, XML, HTTP headers, cookies, and CDL.",
