  metadata/org.http4s/http4s-core_3/index.json:9:    "description" : "http4s-core_3 provides the core Scala 3 HTTP model and abstractions for building functional HTTP clients and servers, including requests, responses, headers, routes, entities, and related syntax. It is the foundation used by http4s client and server modules while integrating with Cats Effect and FS2 for effectful and streaming HTTP programs.",
  metadata/io.jsonwebtoken/jjwt-gson/index.json:9:    "description" : "Provides Gson-based JSON serialization and deserialization support for the JJWT library. When present on the runtime classpath, it lets JJWT automatically use Gson to process JWT headers and claims.",
  metadata/io.jsonwebtoken/jjwt-gson/index.json:29:    "description" : "Provides Gson-based JSON serialization and deserialization support for the JJWT library. When present on the runtime classpath, it lets JJWT automatically use Gson to process JWT headers and claims.",
  metadata/io.jsonwebtoken/jjwt-jackson/index.json:10:    "description" : "jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back using Jackson.",
  metadata/io.jsonwebtoken/jjwt-jackson/index.json:25:    "description" : "jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back using Jackson.",
  metadata/io.jsonwebtoken/jjwt-jackson/index.json:45:    "description" : "jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back using Jackson.",
  metadata/com.typesafe.akka/akka-parsing_2.13/index.json:9:    "description" : "Akka Parsing provides Akka HTTP's internal parsing toolkit, including the parboiled2-based parser DSL and supporting parser input, rule, and error-formatting utilities. It underpins Akka HTTP's HTTP message parsing so higher-level modules can parse requests, responses, headers, and related protocol data efficiently.",
  metadata/io.jsonwebtoken/jjwt-orgjson/index.json:12:    "description": "The jjwt-orgjson module provides JJWT's org.json-based serializer and deserializer so JWT headers and claims can be read and written using JSON-Java. It is the recommended JSON backend for Android applications and supports simple object-to-JSON marshaling instead of POJO unmarshalling.",
  metadata/io.jsonwebtoken/jjwt-orgjson/index.json:28:    "description": "The jjwt-orgjson module provides JJWT's org.json-based serializer and deserializer so JWT claims and headers can be read and written using JSON-Java. It is the recommended JSON backend for Android applications and supports simple object-to-JSON marshaling rather than POJO unmarshalling.",
  metadata/io.ktor/ktor-server-content-negotiation-jvm/index.json:9:    "description" : "Ktor Server ContentNegotiation is the server-side Ktor plugin for negotiating request and response media types with Accept and Content-Type headers. It registers content converters so Kotlin/JVM server applications can deserialize incoming request bodies and serialize outgoing responses for formats such as JSON, XML, CBOR, and ProtoBuf.",
  metadata/io.ktor/ktor-client-content-negotiation-jvm/index.json:9:    "description" : "Ktor client ContentNegotiation adds a client plugin for negotiating request and response media types with Accept and Content-Type headers. It registers content converters so Kotlin/JVM clients can serialize outgoing bodies and deserialize incoming responses for formats such as JSON, XML, CBOR, and ProtoBuf.",
  metadata/com.lihaoyi/requests_3/index.json:9:    "description" : "Requests-Scala is a Scala HTTP client inspired by Python Requests for making synchronous HTTP calls from JVM applications. It wraps Java networking APIs with a small Scala interface for building requests, sending request bodies, handling headers and authentication, and reading responses.",
