[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ExplicitNoAuthSchemeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Base64;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicBoolean;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.authentication.ExplicitNoAuthScheme;\nimport io.restassured.specification.RequestSpecification;\nimport io.restassured.specification.SpecificationQuerier;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ExplicitNoAuthSchemeTest {\n    private static final String USER_NAME = \"default-user\";\n    private static final String PASSWORD = \"default-password\";\n    private static final String AUTHORIZATION_HEADER = \"Basic \" + Base64.getEncoder()\n            .encodeToString((USER_NAME + \":\" + PASSWORD).getBytes(StandardCharsets.ISO_8859_1));\n\n    @AfterEach\n    void resetRestAssuredDefaults() {\n        RestAssured.reset();\n    }\n\n    @Test\n    void createsExplicitNoAuthenticationSchemeFromRequestAuthenticationDsl() {\n        RequestSpecification specification = given().auth().none();\n\n        assertThat(SpecificationQuerier.query(specification).getAuthenticationScheme())\n                .isInstanceOf(ExplicitNoAuthScheme.class);\n    }\n\n    @Test\n    void explicitNoAuthenticationOverridesDefaultAuthenticationScheme() throws Exception {\n        AtomicBoolean authorizationHeaderSeen = new AtomicBoolean(false);\n        AtomicInteger requestCount = new AtomicInteger(0);\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/secured\", exchange -> sendSecuredResponse(exchange, authorizationHeaderSeen, requestCount));\n        server.setExecutor(executor);\n        server.start();\n\n        RestAssured.authentication = RestAssured.basic(USER_NAME, PASSWORD);\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .auth()\n                    .none()\n                    .when()\n                    .get(\"/secured\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_UNAUTHORIZED);\n\n            assertThat(authorizationHeaderSeen).isFalse();\n            assertThat(requestCount).hasValue(1);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendSecuredResponse(\n            HttpExchange exchange, AtomicBoolean authorizationHeaderSeen, AtomicInteger requestCount) throws IOException {\n        try {\n            requestCount.incrementAndGet();\n            Headers requestHeaders = exchange.getRequestHeaders();\n            authorizationHeaderSeen.set(AUTHORIZATION_HEADER.equals(requestHeaders.getFirst(\"Authorization\")));\n            Headers responseHeaders = exchange.getResponseHeaders();\n            responseHeaders.add(\"WWW-Authenticate\", \"Basic realm=\\\"rest-assured-test\\\"\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}
