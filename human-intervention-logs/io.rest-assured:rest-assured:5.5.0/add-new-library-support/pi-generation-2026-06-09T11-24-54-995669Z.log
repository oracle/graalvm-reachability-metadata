    String prettyPrint(ResponseOptions responseOptions, ResponseBody responseBody) {
      def body = asPrettyString(responseOptions, responseBody)
      println body
      body
    }
  
    def peek(ResponseOptions responseOptions, ResponseBody responseBody) {
