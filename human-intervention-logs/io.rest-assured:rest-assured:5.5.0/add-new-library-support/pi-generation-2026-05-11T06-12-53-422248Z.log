      private static void assertDetailedCookieValidation() {
          Response response = new ResponseBuilder()
                  .setStatusCode(200)
                  .setBody("ok")
                  .setHeader("Set-Cookie", "session=abc123; Path=/; HttpOnly; Secure")
                  .build();
  
          response.then()
                  .assertThat()
                  .cookie("session", detailedCookie()
                          .value("abc123")
                          .path("/")
                          .httpOnly(true)
                          .secured(true));
