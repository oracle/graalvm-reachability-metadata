  +Provider<Directory> generatedDirectAccessClasses = layout.buildDirectory.dir("generated/direct-access-test-classes")
  +Closure<Void> writeGeneratedDirectAccessClass = { String path, String content ->
  +    File outputFile = generatedDirectAccessClasses.get().file(path).asFile
  +    outputFile.parentFile.mkdirs()
  +    outputFile.bytes = Base64.decoder.decode(content)
  +    null
  +}
  +
  +Closure<Integer> readU2 = { byte[] bytes, int offset ->
  +    ((bytes[offset] & 0xFF) << 8) | (bytes[offset + 1] & 0xFF)
  +}
  +
  +Closure<Integer> readU4 = { byte[] bytes, int offset ->
  +    ((bytes[offset] & 0xFF) << 24) | ((bytes[offset + 1] & 0xFF) << 16) |
  +            ((bytes[offset + 2] & 0xFF) << 8) | (bytes[offset + 3] & 0xFF)
  +}
  +
  +Closure<Void> writeU2 = { byte[] bytes, int offset, int value ->
  +    bytes[offset] = (byte) ((value >>> 8) & 0xFF)
  +    bytes[offset + 1] = (byte) (value & 0xFF)
  +    null
  +}
  +
  +Closure<Void> writePatchedClassResolverClass = { String classEntryName ->
  +    File restAssuredJar = configurations.testRuntimeClasspath.files.find { File file ->
  +        file.name == "rest-assured-${libraryVersion}.jar"
  +    }
  +    if (restAssuredJar == null) {
  +        throw new GradleException("Could not find rest-assured runtime JAR for ${libraryVersion}")
  +    }
  +
  +    byte[] bytes
  +    new ZipFile(restAssuredJar).withCloseable { ZipFile zipFile ->
  +        bytes = zipFile.getInputStream(zipFile.getEntry(classEntryName)).bytes
  +    }
  +
  +    String[] constantPool = new String[readU2(bytes, 8)]
  +    int position = 10
  +    int index = 1
  +    while (index < constantPool.length) {
  +        int tag = bytes[position++] & 0xFF
  +        switch (tag) {
  +            case 1:
  +                int length = readU2(bytes, position)
  +                position += 2
  +                constantPool[index] = new String(bytes, position, length, StandardCharsets.UTF_8)
  +                position += length
  +                break
  +            case 3:
  +            case 4:
  +                position += 4
  +                break
  +            case 5:
  +            case 6:
  +                position += 8
  +                index++
