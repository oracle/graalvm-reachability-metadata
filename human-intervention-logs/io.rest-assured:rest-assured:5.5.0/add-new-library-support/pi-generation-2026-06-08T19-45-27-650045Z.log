  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.net.HttpURLConnection;
  import java.net.InetSocketAddress;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicBoolean;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import com.sun.net.httpserver.HttpExchange;
  import com.sun.net.httpserver.HttpServer;
  import io.restassured.RestAssured;
  import io.restassured.authentication.NoAuthScheme;
  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.BeforeEach;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class NoAuthSchemeTest {
  
      @BeforeEach
      void resetRestAssuredDefaultsBeforeTest() {
          RestAssured.reset();
      }
  
      @AfterEach
      void resetRestAssuredDefaultsAfterTest() {
          RestAssured.reset();
      }
  
      @Test
      void defaultRequestAuthenticationSchemeUsesNoAuthentication() {
          RequestSpecification specification = given();
  
          assertThat(SpecificationQuerier.query(specification).getAuthenticationScheme())
                  .isInstanceOf(NoAuthScheme.class);
      }
  
      @Test
      void groovyObjectDispatchResolvesGeneratedClassHelper() throws Throwable {
          NoAuthScheme authenticationScheme = (NoAuthScheme) SpecificationQuerier
                  .query(given())
                  .getAuthenticationScheme();
          MethodHandle groovyDispatchHelper = MethodHandles.publicLookup().findVirtual(
                  NoAuthScheme.class,
                  "this$dist$invoke$1",
                  MethodType.methodType(Object.class, String.class, Object.class));
  
          Object resolvedClass = groovyDispatchHelper.invoke(
                  authenticationScheme,
                  "class$",
                  new Object[] {NoAuthScheme.class.getName()});
  
          assertThat(resolvedClass).isSameAs(NoAuthScheme.class);
      }
  
      @Test
      void defaultNoAuthenticationSchemeDoesNotSendAuthorizationHeader() throws Exception {
          AtomicBoolean authorizationHeaderSeen = new AtomicBoolean(false);
          AtomicInteger requestCount = new AtomicInteger(0);
          ExecutorService executor = Executors.newSingleThreadExecutor();
          HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
          server.createContext("/public", exchange -> sendResponse(exchange, authorizationHeaderSeen, requestCount));
          server.setExecutor(executor);
          server.start();
  
          try {
              given()
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .when()
                      .get("/public")
                      .then()
                      .statusCode(HttpURLConnection.HTTP_OK);
  
              assertThat(authorizationHeaderSeen).isFalse();
              assertThat(requestCount.get()).isEqualTo(1);
          } finally {
              server.stop(0);
              executor.shutdownNow();
              executor.awaitTermination(5, TimeUnit.SECONDS);
          }
      }
  
      private static void sendResponse(
              HttpExchange exchange,
              AtomicBoolean authorizationHeaderSeen,
              AtomicInteger requestCount) throws IOException {
          try {
              requestCount.incrementAndGet();
              authorizationHeaderSeen.set(exchange.getRequestHeaders().containsKey("Authorization"));
              exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, -1);
          } finally {
              exchange.close();
          }
      }
  }
