onAddsAuthorizationHeaderDirectly() {\n        RequestSpecification specification = given()\n                .auth()\n                .preemptive()\n                .basic(USER_NAME, PASSWORD);\n\n        String authorization = SpecificationQuerier.query(specification)\n                .getHeaders()\n                .getValue(\"Authorization\");\n        assertThat(authorization).isEqualTo(BASIC_AUTHORIZATION_HEADER);\n    }\n\n    @Test\n    void preemptiveOAuth2AuthenticationAddsAuthorizationHeaderDirectly() {\n        RequestSpecification specification = given()\n                .auth()\n                .preemptive()\n                .oauth2(ACCESS_TOKEN);\n\n        String authorization = SpecificationQuerier.query(specification)\n                .getHeaders()\n                .getValue(\"Authorization\");\n        assertThat(authorization).isEqualTo(\"Bearer \" + ACCESS_TOKEN);\n    }\n\n    @Test\n    void groovyObjectDispatchResolvesGeneratedClassHelper() {\n        PreemptiveAuthSpec preemptiveAuthSpec = given()\n                .auth()\n                .preemptive();\n\n        Object resolvedClass = ((GroovyObject) preemptiveAuthSpec).invokeMethod(\n                \"class$\",\n                new Object[] {RequestSpecification.class.getName()});\n\n        assertThat(resolvedClass).isSameAs(RequestSpecification.class);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1398, "output": 1151, "cacheRead": 29184, "cacheWrite": 0, "totalTokens": 31733, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780947895562, "responseId": "resp_0b5b6e45c3e1f628016a271bb851008197b1d8af633fc8a81c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_HOMXmLKBd2MAebrQSZjIphWD|fc_0b5b6e45c3e1f628016a271bc94f6881978a9f4e5a41854d00", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2449 bytes to tests/src/io.rest-ass