  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  import java.net.HttpURLConnection;
  import java.net.InetSocketAddress;
  import java.nio.charset.StandardCharsets;
  import java.util.Base64;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import com.sun.net.httpserver.Headers;
  import com.sun.net.httpserver.HttpExchange;
  import com.sun.net.httpserver.HttpServer;
  import io.restassured.RestAssured;
  import io.restassured.authentication.AuthenticationScheme;
  import io.restassured.authentication.PreemptiveBasicAuthScheme;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.hamcrest.Matchers.equalTo;
  
  public class PreemptiveBasicAuthSchemeTest {
      private static final String USER_NAME = "preemptive-user";
      private static final String PASSWORD = "preemptive-password";
      private static final String AUTHORIZATION_HEADER = "Basic " + Base64.getEncoder()
              .encodeToString((USER_NAME + ":" + PASSWORD).getBytes(StandardCharsets.ISO_8859_1));
  
      @Test
      void createsPreemptiveBasicAuthenticationSchemeWithConfiguredCredentials() {
          AuthenticationScheme authenticationScheme = RestAssured.preemptive().basic(USER_NAME, PASSWORD);
  
          assertThat(authenticationScheme).isInstanceOf(PreemptiveBasicAuthScheme.class);
          PreemptiveBasicAuthScheme preemptiveBasicAuthScheme = (PreemptiveBasicAuthScheme) authenticationScheme;
          assertThat(preemptiveBasicAuthScheme.getUserName()).isEqualTo(USER_NAME);
          assertThat(preemptiveBasicAuthScheme.getPassword()).isEqualTo(PASSWORD);
          assertThat(preemptiveBasicAuthScheme.generateAuthToken()).isEqualTo(AUTHORIZATION_HEADER);
      }
  
      @Test
      void groovyObjectDispatchResolvesGeneratedClassHelper() {
          PreemptiveBasicAuthScheme preemptiveBasicAuthScheme = (PreemptiveBasicAuthScheme) RestAssured
                  .preemptive()
                  .basic(USER_NAME, PASSWORD);
  
          Object resolvedClass = preemptiveBasicAuthScheme.invokeMethod(
                  "class$",
                  new Object[] {PreemptiveBasicAuthScheme.class.getName()});
  
          assertThat(resolvedClass).isSameAs(PreemptiveBasicAuthScheme.class);
      }
  
      @Test
      void appliesPreemptiveBasicAuthenticationWithoutChallenge() throws Exception {
          AtomicInteger requestCount = new AtomicInteger();
          ExecutorService executor = Executors.newSingleThreadExecutor();
          HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
          server.createContext("/secured", exchange -> sendPreemptiveResponse(exchange, requestCount));
          server.setExecutor(executor);
          server.start();
  
          AuthenticationScheme previousAuthentication = RestAssured.authentication;
          RestAssured.authentication = RestAssured.preemptive().basic(USER_NAME, PASSWORD);
          try {
              given()
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .when()
                      .get("/secured")
                      .then()
                      .statusCode(HttpURLConnection.HTTP_OK)
                      .body(equalTo("preemptive"));
              assertThat(requestCount.get()).isEqualTo(1);
          } finally {
              RestAssured.authentication = previousAuthentication;
              server.stop(0);
              executor.shutdownNow();
              executor.awaitTermination(5, TimeUnit.SECONDS);
          }
      }
  
      private static void sendPreemptiveResponse(HttpExchange exchange, AtomicInteger requestCount) throws IOException {
          requestCount.incrementAndGet();
          try {
              Headers requestHeaders = exchange.getRequestHeaders();
              if (!AUTHORIZATION_HEADER.equals(requestHeaders.getFirst("Authorization"))) {
                  Headers responseHeaders = exchange.getResponseHeaders();
                  responseHeaders.add("WWW-Authenticate", "Basic realm=\"rest-assured-test\"");
                  exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);
                  return;
              }
  
              byte[] body = "preemptive".getBytes(StandardCharsets.UTF_8);
              exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);
              exchange.getResponseBody().write(body);
          } finally {
              exchange.close();
          }
      }
  }
