plyPathParamsAndSendRequest_closure34Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.filter.FilterContext;\nimport io.restassured.filter.time.TimingFilter;\nimport io.restassured.response.Response;\nimport io.restassured.specification.FilterableRequestSpecification;\nimport io.restassured.specification.FilterableResponseSpecification;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RequestSpecificationImplInner_applyPathParamsAndSendRequest_closure34Test {\n    @Test\n    void existingTimingFilterIsRecognizedWhenSendingPathParameterizedRequest() throws Throwable {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/timed\", exchange -> handleTimed(exchange));\n        server.setExecutor(executor);\n        server.start();\n        RestAssured.reset();\n\n        AtomicInteger timingFilterInvocations = new AtomicInteger();\n\n        try {\n            Response response = given()\n                    .filter(new RecordingTimingFilter(timingFilterInvocations))\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/timed/{recordId}\", \"42\");\n\n            assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_OK);\n            assertThat(response.asString()).isEqualTo(\"timed-42\");\n            assertThat(timingFilterInvocations).hasValue(1);\n            assertThat(response.time()).isGreaterThanOrEqualTo(0L);\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void handleTimed(HttpExchange exchange) throws IOException {\n        try {\n            String requestPath = exchange.getRequestURI().getPath();\n            String recordId = requestPath.substring(requestPath.lastIndexOf('/') + 1);\n            byte[] responseBytes = (\"timed-\" + recordId).getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);\n            try (OutputStream outputStream = exchange.getResponseBody()) {\n                outputStream.write(responseBytes);\n            }\n        } finally {\n            exchange.close();\n        }\n    }\n\n    private static final class RecordingTimingFilter extends TimingFilter {\n        private final AtomicInteger invocations;\n\n        private RecordingTimingFilter(AtomicInteger invocations) {\n            this.invocations = invocations;\n        }\n\n        @Override\n        public Response filter(\n                FilterableRequestSpecification requestSpec,\n                FilterableResponseSpecification responseSpec,\n                FilterContext ctx) {\n            invocations.incrementAndGet();\n            return super.filter(requestSpec, responseSpec, ctx);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 991, 