ecordId = requestPath.substring(requestPath.lastIndexOf('/') + 1);\n            byte[] responseBytes = (\"timed-\" + recordId).getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);\n            try (OutputStream outputStream = exchange.getResponseBody()) {\n                outputStream.write(responseBytes);\n            }\n        } finally {\n            exchange.close();\n        }\n    }\n\n    private static final class RecordingTimingFilter extends TimingFilter {\n        private final AtomicInteger invocations;\n\n        private RecordingTimingFilter(AtomicInteger invocations) {\n            this.invocations = invocations;\n        }\n\n        @Override\n        public Response filter(\n                FilterableRequestSpecification requestSpec,\n                FilterableResponseSpecification responseSpec,\n                FilterContext ctx) {\n            invocations.incrementAndGet();\n            return super.filter(requestSpec, responseSpec, ctx);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780955940503}}
