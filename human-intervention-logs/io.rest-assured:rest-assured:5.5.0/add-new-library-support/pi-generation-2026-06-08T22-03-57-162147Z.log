          try {
              Response response = given()
                      .config(config().httpClient(httpClientConfig()
                              .setParam(CoreProtocolPNames.USER_AGENT, USER_AGENT_VALUE)))
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
