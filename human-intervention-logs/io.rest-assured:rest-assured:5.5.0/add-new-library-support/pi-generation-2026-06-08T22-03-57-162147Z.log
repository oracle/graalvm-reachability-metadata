      31	public class RequestSpecificationImplInner_applyRestAssuredConfig_closure20Test {
      32	    @Test
      33	    void requestLevelRedirectParameterIsAppliedToHttpClient() throws Throwable {
      34	        ExecutorService executor = Executors.newSingleThreadExecutor();
      35	        HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
      36	        server.createContext(
      37	                "/redirect",
      38	                RequestSpecificationImplInner_applyRestAssuredConfig_closure20Test::sendRedirect);
      39	        server.createContext("/target", RequestSpecificationImplInner_applyRestAssuredConfig_closure20Test::sendTarget);
      40	        server.setExecutor(executor);
      41	        server.start();
      42	        RestAssured.reset();
      43	
      44	        try {
      45	            Response response = given()
      46	                    .baseUri("http://127.0.0.1")
      47	                    .port(server.getAddress().getPort())
      48	                    .redirects().follow(false)
      49	                    .when()
      50	                    .get("/redirect");
      51	
      52	            assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_MOVED_TEMP);
      53	            assertThat(response.header("Location")).isEqualTo("/target");
      54	
      55	            String dynamicallyLoadedClassName = "org.apache.http.params.HttpParams";
      56	            assertEquals(dynamicallyLoadedClassName, invokeGeneratedClassLookup(dynamicallyLoadedClassName).getName());
      57	        } finally {
      58	            RestAssured.reset();
      59	            server.stop(0);
      60	            executor.shutdownNow();
      61	            executor.awaitTermination(5, TimeUnit.SECONDS);
      62	        }
      63	    }
