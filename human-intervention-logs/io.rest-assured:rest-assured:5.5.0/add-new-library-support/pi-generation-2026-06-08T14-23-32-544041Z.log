[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/DetailedCookieAssertionTest.java","edits":[{"oldText":"import com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport org.junit.jupiter.api.Test;\n","newText":"import com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.assertion.DetailedCookieAssertion;\nimport io.restassured.http.Cookie;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"import static io.restassured.RestAssured.given;\nimport static io.restassured.matcher.RestAssuredMatchers.detailedCookie;\n","newText":"import static io.restassured.RestAssured.given;\nimport static io.restassured.matcher.RestAssuredMatchers.detailedCookie;\nimport static org.assertj.core.api.Assertions.assertThat;\n"},{"oldText":"public class DetailedCookieAssertionTest {\n    @Test\n    void validatesDetailedCookieAttributesFromSetCookieHeader() throws Exception {\n","newText":"public class DetailedCookieAssertionTest {\n    @Test\n    void supportsGroovyClassLookupDispatch() {\n        DetailedCookieAssertion assertion = new DetailedCookieAssertion();\n\n        Object loadedClass = assertion.getMetaClass().invokeStaticMethod(\n                DetailedCookieAssertion.class,\n                \"class$\",\n                new Object[] { Cookie.class.getName() });\n\n        assertThat(loadedClass).isEqualTo(Cookie.class);\n    }\n\n    @Test\n    void validatesDetailedCookieAttributesFromSetCookieHeader() throws Exception {\n"}]}
