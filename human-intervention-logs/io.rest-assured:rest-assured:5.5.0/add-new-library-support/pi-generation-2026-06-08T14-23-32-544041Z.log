ss(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/cookies\", this::sendCookieResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/cookies\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .cookie(\"session\", detailedCookie()\n                            .value(\"abc\")\n                            .path(\"/cookies\")\n                            .httpOnly(true)\n                            .sameSite(\"Lax\")\n                            .secured(false));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendCookieResponse(HttpExchange exchange) throws java.io.IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Set-Cookie\", \"session=abc; Path=/cookies; HttpOnly; SameSite=Lax\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, -1);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2214, "output": 1399, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 34333, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780928573290, "responseId": "resp_015053c3e7a7d7a4016a26d03dd4688190b75591fc15a45827"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_F5pje0dOLndZRJXFAJfJtxsY|fc_015053c3e7a7d7a4016a26d0507c4881909ec2f04ca14075f0", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2275 bytes to tests/src/io.rest-assured/rest-assured/5.5.0