  package io_rest_assured.rest_assured;
  
  import io.restassured.config.SSLConfig;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SSLConfigTest {
      private static final String KEY_STORE_RESOURCE = "/ssl-config-test-keystore.p12";
      private static final String KEY_STORE_PASSWORD = "changeit";
  
      @Test
      void loadsKeyStoreResourceWithAbsoluteClasspathPath() {
          SSLConfig sslConfig = SSLConfig.sslConfig()
                  .keystoreType("PKCS12")
                  .keyStore(KEY_STORE_RESOURCE, KEY_STORE_PASSWORD)
                  .relaxedHTTPSValidation("TLS");
  
          assertThat(sslConfig.getSSLSocketFactory()).isNotNull();
          assertThat(sslConfig.isUserConfigured()).isTrue();
      }
