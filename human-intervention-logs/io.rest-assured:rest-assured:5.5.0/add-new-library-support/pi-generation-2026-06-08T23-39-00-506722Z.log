    private def applyPathParamsAndSendRequest(String method, String path, Object... unnamedPathParams) {
      notNull path, "path"
      notNull trimToNull(method), "Method"
      notNull unnamedPathParams, "Path params"
      this.method = method.trim().toUpperCase()
