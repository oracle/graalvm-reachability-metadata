                                  .setName("dependency")
                                  .setNumber(1)
                                  .setType(DescriptorProtos.FieldDescriptorProto.Type.TYPE_MESSAGE)
                                  .setTypeName(".coverage.DependencyMessage")))
                  .build();
  
