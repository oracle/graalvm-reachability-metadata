ticationScheme authenticationScheme = RestAssured.ntlm(USERNAME, PASSWORD, WORKSTATION, DOMAIN);\n\n        NTLMAuthScheme ntlmAuthScheme = assertInstanceOf(NTLMAuthScheme.class, authenticationScheme);\n        assertEquals(USERNAME, ntlmAuthScheme.getUserName());\n        assertEquals(PASSWORD, ntlmAuthScheme.getPassword());\n        assertEquals(WORKSTATION, ntlmAuthScheme.getWorkstation());\n        assertEquals(DOMAIN, ntlmAuthScheme.getDomain());\n    }\n}\n"}
