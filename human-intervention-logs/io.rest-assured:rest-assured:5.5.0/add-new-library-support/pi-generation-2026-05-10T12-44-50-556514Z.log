s);\n    }\n\n    @Test\n    void factoryCreatesConfiguredNtlmAuthenticationScheme() {\n        AuthenticationScheme authenticationScheme = RestAssured.ntlm(USERNAME, PASSWORD, WORKSTATION, DOMAIN);\n\n        NTLMAuthScheme ntlmAuthScheme = assertInstanceOf(NTLMAuthScheme.class, authenticationScheme);\n        assertEquals(USERNAME, ntlmAuthScheme.getUserName());\n        assertEquals(PASSWORD, ntlmAuthScheme.getPassword());\n        assertEquals(WORKSTATION, ntlmAuthScheme.getWorkstation());\n        assertEquals(DOMAIN, ntlmAuthScheme.getDomain());\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 400, "output": 992, "cacheRead": 13824, "cacheWrite": 0, "totalTokens": 15216, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778417059160, "responseId": "resp_06f812db6eb55f6c016a007da3a7b081a1b7e276b6423ffb1b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_9QBroUFJB6WLraPCpsgGKIQx|fc_06f812db6eb55f6c016a007daab79881a1885b7e1e46b0d957", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2144 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/NTLMAuthSchemeTest.java"}], "isError": false, "timestamp": 1778417069615}]}
