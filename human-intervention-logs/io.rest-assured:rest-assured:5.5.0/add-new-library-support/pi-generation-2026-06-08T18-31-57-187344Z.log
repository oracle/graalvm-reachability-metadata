      notNull firstParam, "firstParam"
      notNull firstValue, "firstValue"
      def params = [firstParam, firstValue]
      parameters.each {
        params << it
      }
      return params as Object[]
    }
  
    @Canonical
    static class ArgsAndValue {
      List<Argument> args
      def value
    }
  
