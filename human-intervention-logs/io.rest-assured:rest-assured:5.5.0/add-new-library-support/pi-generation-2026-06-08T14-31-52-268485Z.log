headers\", this::sendHeaderResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/headers\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .header(\"X-Count\", Integer::parseInt, equalTo(3))\n                    .header(\"X-Mode\", equalTo(\"native\"));\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendHeaderResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"X-Count\", \"3\");\n            headers.add(\"X-Mode\", \"native\");\n            byte[] body = \"ok\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 5657, "output": 1105, "cacheRead": 40960, "cacheWrite": 0, "totalTokens": 47722, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780929060644, "responseId": "resp_07ec00887f3787fa016a26d22536a481948ea9623e0cff4f44"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_KY9FKwpT9Wv4ehvH14znBxDB|fc_07ec00887f3787fa016a26d2318ae4819493366ac7c8dae893", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2272 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/HeaderMatcherTest.java"}], "isError": false, "timest