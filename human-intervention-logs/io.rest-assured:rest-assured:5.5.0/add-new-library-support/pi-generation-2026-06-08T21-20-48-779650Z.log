      public LogConfig enableLoggingOfRequestAndResponseIfValidationFails(LogDetail logDetail) {
          return new LogConfig(defaultPrintStream, prettyPrintingEnabled, logDetail, urlEncodeRequestUri, headerBlacklist, true);
