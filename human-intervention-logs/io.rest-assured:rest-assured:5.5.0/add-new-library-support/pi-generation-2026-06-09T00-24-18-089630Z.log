  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  import java.io.OutputStream;
  import java.net.InetSocketAddress;
  import java.nio.charset.StandardCharsets;
  import java.util.concurrent.atomic.AtomicReference;
  
  import com.sun.net.httpserver.HttpExchange;
  import com.sun.net.httpserver.HttpServer;
  import io.restassured.RestAssured;
  import io.restassured.filter.Filter;
  import io.restassured.response.Response;
  import io.restassured.specification.FilterableRequestSpecification;
  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RequestSpecificationImplInner_getDerivedPath_closure38Test {
      @Test
      void specificationQuerierReadsDerivedPathAfterNamedPathParametersAreApplied() {
          RestAssured.reset();
  
          try {
              RequestSpecification specification = RestAssured
                      .given()
                      .baseUri("http://example.com")
                      .basePath("/api")
                      .pathParam("orderId", "first");
              ((FilterableRequestSpecification) specification).path("/orders/{orderId}");
  
              String derivedPath = SpecificationQuerier.query(specification).getDerivedPath();
  
              assertThat(derivedPath).isEqualTo("/api/orders/first");
          } finally {
              RestAssured.reset();
          }
      }
  
      @Test
      void filterCanReadDerivedPathAfterUnnamedPathParametersAreApplied() throws IOException {
          AtomicReference<String> derivedPath = new AtomicReference<>();
          Filter captureDerivedPath = (requestSpecification, responseSpecification, context) -> {
              derivedPath.set(requestSpecification.getDerivedPath());
              return context.next(requestSpecification, responseSpecification);
          };
  
          HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
          server.createContext(
                  "/api/orders/first/items/second",
                  RequestSpecificationImplInner_getDerivedPath_closure38Test::sendObservedPath);
          server.start();
          RestAssured.reset();
  
          try {
              Response response = RestAssured
                      .given()
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .basePath("/api")
                      .filter(captureDerivedPath)
                      .when()
                      .get("/orders/{orderId}/items/{itemId}", "first", "second");
  
              assertThat(response.statusCode()).isEqualTo(200);
              assertThat(response.asString()).isEqualTo("/api/orders/first/items/second");
              assertThat(derivedPath.get()).isEqualTo("/api/orders/first/items/second");
          } finally {
              RestAssured.reset();
              server.stop(0);
          }
      }
  
      private static void sendObservedPath(HttpExchange exchange) throws IOException {
          byte[] responseBytes = exchange.getRequestURI().getPath().getBytes(StandardCharsets.UTF_8);
          exchange.sendResponseHeaders(200, responseBytes.length);
          try (OutputStream outputStream = exchange.getResponseBody()) {
              outputStream.write(responseBytes);
          }
      }
  }
