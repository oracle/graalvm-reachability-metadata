sertThat(requestCount.get()).isEqualTo(1);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendSecuredResponse(\n            HttpExchange exchange,\n            AtomicBoolean authorizationHeaderSeen,\n            AtomicInteger requestCount) throws IOException {\n        try {\n            requestCount.incrementAndGet();\n            Headers requestHeaders = exchange.getRequestHeaders();\n            authorizationHeaderSeen.set(AUTHORIZATION_HEADER.equals(requestHeaders.getFirst(\"Authorization\")));\n            Headers responseHeaders = exchange.getResponseHeaders();\n            responseHeaders.add(\"WWW-Authenticate\", \"Basic realm=\\\"rest-assured-test\\\"\");\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780934414337}}
