  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  import java.net.HttpURLConnection;
  import java.net.InetSocketAddress;
  import java.nio.charset.StandardCharsets;
  import java.util.Base64;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicBoolean;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import com.sun.net.httpserver.Headers;
  import com.sun.net.httpserver.HttpExchange;
  import com.sun.net.httpserver.HttpServer;
  import io.restassured.RestAssured;
  import io.restassured.authentication.ExplicitNoAuthScheme;
  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.BeforeEach;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExplicitNoAuthSchemeTest {
      private static final String USER_NAME = "default-user";
      private static final String PASSWORD = "default-password";
      private static final String AUTHORIZATION_HEADER = "Basic " + Base64.getEncoder()
              .encodeToString((USER_NAME + ":" + PASSWORD).getBytes(StandardCharsets.ISO_8859_1));
  
      @BeforeEach
      void resetRestAssuredDefaultsBeforeTest() {
          RestAssured.reset();
      }
  
      @AfterEach
      void resetRestAssuredDefaultsAfterTest() {
          RestAssured.reset();
      }
  
      @Test
      void createsExplicitNoAuthenticationSchemeFromRequestAuthenticationDsl() {
          RequestSpecification specification = given().auth().none();
  
          assertThat(SpecificationQuerier.query(specification).getAuthenticationScheme())
                  .isInstanceOf(ExplicitNoAuthScheme.class);
      }
  
      @Test
      void groovyObjectDispatchResolvesClassesForExplicitNoAuthenticationScheme() {
          ExplicitNoAuthScheme authenticationScheme = (ExplicitNoAuthScheme) SpecificationQuerier
                  .query(given().auth().none())
                  .getAuthenticationScheme();
  
          Object resolvedClass = authenticationScheme.invokeMethod(
                  "class$", new Object[] {ExplicitNoAuthScheme.class.getName()});
  
          assertThat(resolvedClass).isEqualTo(ExplicitNoAuthScheme.class);
      }
  
      @Test
      void explicitNoAuthenticationOverridesDefaultAuthenticationScheme() throws Exception {
          AtomicBoolean authorizationHeaderSeen = new AtomicBoolean(false);
          AtomicInteger requestCount = new AtomicInteger(0);
          ExecutorService executor = Executors.newSingleThreadExecutor();
          HttpServer server = HttpServer.create(new InetSocketAddress("127.0.0.1", 0), 0);
          server.createContext(
                  "/secured", exchange -> sendSecuredResponse(exchange, authorizationHeaderSeen, requestCount));
          server.setExecutor(executor);
          server.start();
  
          RestAssured.authentication = RestAssured.basic(USER_NAME, PASSWORD);
  
          try {
              given()
                      .baseUri("http://127.0.0.1")
                      .port(server.getAddress().getPort())
                      .auth()
                      .none()
                      .when()
                      .get("/secured")
                      .then()
                      .statusCode(HttpURLConnection.HTTP_UNAUTHORIZED);
  
              assertThat(authorizationHeaderSeen).isFalse();
              assertThat(requestCount.get()).isEqualTo(1);
          } finally {
              server.stop(0);
              executor.shutdownNow();
              executor.awaitTermination(5, TimeUnit.SECONDS);
          }
      }
  
      private static void sendSecuredResponse(
              HttpExchange exchange,
              AtomicBoolean authorizationHeaderSeen,
              AtomicInteger requestCount) throws IOException {
          try {
              requestCount.incrementAndGet();
              Headers requestHeaders = exchange.getRequestHeaders();
              authorizationHeaderSeen.set(AUTHORIZATION_HEADER.equals(requestHeaders.getFirst("Authorization")));
              Headers responseHeaders = exchange.getResponseHeaders();
              responseHeaders.add("WWW-Authenticate", "Basic realm=\"rest-assured-test\"");
              exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);
          } finally {
              exchange.close();
          }
      }
  }
