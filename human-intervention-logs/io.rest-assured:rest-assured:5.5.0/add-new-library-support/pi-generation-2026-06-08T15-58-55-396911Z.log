[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/NoAuthSchemeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicBoolean;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.authentication.NoAuthScheme;\nimport io.restassured.specification.RequestSpecification;\nimport io.restassured.specification.SpecificationQuerier;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class NoAuthSchemeTest {\n\n    @BeforeEach\n    void resetRestAssuredDefaultsBeforeTest() {\n        RestAssured.reset();\n    }\n\n    @AfterEach\n    void resetRestAssuredDefaultsAfterTest() {\n        RestAssured.reset();\n    }\n\n    @Test\n    void defaultRequestAuthenticationSchemeUsesNoAuthentication() {\n        RequestSpecification specification = given();\n\n        assertThat(SpecificationQuerier.query(specification).getAuthenticationScheme())\n                .isInstanceOf(NoAuthScheme.class);\n    }\n\n    @Test\n    void groovyObjectDispatchResolvesClassesForNoAuthenticationScheme() {\n        NoAuthScheme authenticationScheme = (NoAuthScheme) SpecificationQuerier\n                .query(given())\n                .getAuthenticationScheme();\n\n        Object resolvedClass = authenticationScheme.invokeMethod(\n                \"class$\", new Object[] {NoAuthScheme.class.getName()});\n\n        assertThat(resolvedClass).isEqualTo(NoAuthScheme.class);\n    }\n\n    @Test\n    void defaultNoAuthenticationSchemeDoesNotSendAuthorizationHeader() throws Exception {\n        AtomicBoolean authorizationHeaderSeen = new AtomicBoolean(false);\n        AtomicInteger requestCount = new AtomicInteger(0);\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/public\", exchange -> sendResponse(exchange, authorizationHeaderSeen, requestCount));\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/public\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK);\n\n            assertThat(authorizationHeaderSeen).isFalse();\n            assertThat(requestCount.get()).isEqualTo(1);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendResponse(\n            HttpExchange exchange,\n            AtomicBoolean authorizationHeaderSeen,\n            AtomicInteger requestCount) throws IOException {\n        try {\n            requestCount.incrementAndGet();\n            authorizationHeaderSeen.set(exchange.getRequestHeaders().containsKey(\"Authorization\"));\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, -1);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}
