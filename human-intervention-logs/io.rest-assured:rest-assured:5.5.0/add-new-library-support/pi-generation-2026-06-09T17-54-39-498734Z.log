[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/JsonbMapperInner_serialize_closure1Test.java","edits":[{"oldText":"import java.io.Writer;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Type;\n","newText":"import java.io.Writer;\nimport java.lang.reflect.Type;\n"},{"oldText":"import com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\n","newText":"import com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport groovy.lang.GroovySystem;\nimport groovy.lang.MetaClass;\nimport io.restassured.RestAssured;\n"},{"oldText":"    private static Class<?> invokeGeneratedClassLookup(Class<?> closureClass, String className) throws Exception {\n        assertThat(closureClass.getName()).isEqualTo(CLOSURE_CLASS_NAME);\n        Method classHelper = closureClass.getDeclaredMethod(\"class$\", String.class);\n        classHelper.setAccessible(true);\n        return (Class<?>) classHelper.invoke(null, className);\n    }\n","newText":"    private static Class<?> invokeGeneratedClassLookup(Class<?> closureClass, String className) {\n        assertThat(closureClass.getName()).isEqualTo(CLOSURE_CLASS_NAME);\n        MetaClass metaClass = GroovySystem.getMetaClassRegistry().getMetaClass(closureClass);\n        Object resolvedClass = metaClass.invokeStaticMethod(closureClass, \"class$\", new Object[] {className});\n        return (Class<?>) resolvedClass;\n    }\n"}]}
