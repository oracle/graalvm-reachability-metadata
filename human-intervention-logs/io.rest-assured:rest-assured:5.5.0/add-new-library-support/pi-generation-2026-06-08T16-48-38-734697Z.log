  package io_rest_assured.rest_assured;
  
  import java.io.IOException;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import io.restassured.RestAssured;
  import io.restassured.authentication.AuthenticationScheme;
  import io.restassured.authentication.OAuthScheme;
  import io.restassured.authentication.OAuthSignature;
  import io.restassured.config.DecoderConfig;
  import io.restassured.config.EncoderConfig;
  import io.restassured.config.OAuthConfig;
  import io.restassured.internal.http.HTTPBuilder;
  import io.restassured.specification.RequestSpecification;
  import io.restassured.specification.SpecificationQuerier;
  import org.apache.http.client.ClientProtocolException;
  import org.apache.http.impl.client.AbstractHttpClient;
  import org.apache.http.impl.client.DefaultHttpClient;
  import org.junit.jupiter.api.Test;
  
  import static io.restassured.RestAssured.given;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OAuthSchemeTest {
      private static final String CONSUMER_KEY = "oauth-consumer-key";
      private static final String CONSUMER_SECRET = "oauth-consumer-secret";
      private static final String ACCESS_TOKEN = "oauth-access-token";
      private static final String SECRET_TOKEN = "oauth-secret-token";
  
      @Test
      void createsOAuthAuthenticationSchemeWithConfiguredTokens() {
          AuthenticationScheme authenticationScheme = RestAssured.oauth(
                  CONSUMER_KEY, CONSUMER_SECRET, ACCESS_TOKEN, SECRET_TOKEN);
  
          assertThat(authenticationScheme).isInstanceOf(OAuthScheme.class);
          OAuthScheme oauthScheme = (OAuthScheme) authenticationScheme;
          assertThat(oauthScheme.getConsumerKey()).isEqualTo(CONSUMER_KEY);
          assertThat(oauthScheme.getConsumerSecret()).isEqualTo(CONSUMER_SECRET);
          assertThat(oauthScheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauthScheme.getSecretToken()).isEqualTo(SECRET_TOKEN);
          assertThat(oauthScheme.getSignature()).isNull();
      }
  
      @Test
      void createsOAuthAuthenticationSchemeWithConfiguredSignature() {
          AuthenticationScheme authenticationScheme = RestAssured.oauth(
                  CONSUMER_KEY,
                  CONSUMER_SECRET,
                  ACCESS_TOKEN,
                  SECRET_TOKEN,
                  OAuthSignature.QUERY_STRING);
  
          assertThat(authenticationScheme).isInstanceOf(OAuthScheme.class);
          OAuthScheme oauthScheme = (OAuthScheme) authenticationScheme;
          assertThat(oauthScheme.getConsumerKey()).isEqualTo(CONSUMER_KEY);
          assertThat(oauthScheme.getConsumerSecret()).isEqualTo(CONSUMER_SECRET);
          assertThat(oauthScheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauthScheme.getSecretToken()).isEqualTo(SECRET_TOKEN);
          assertThat(oauthScheme.getSignature()).isEqualTo(OAuthSignature.QUERY_STRING);
      }
  
      @Test
      void createsOAuthAuthenticationSchemeFromRequestAuthenticationDsl() {
          RequestSpecification specification = given()
                  .auth()
                  .oauth(
                          CONSUMER_KEY,
                          CONSUMER_SECRET,
                          ACCESS_TOKEN,
                          SECRET_TOKEN,
                          OAuthSignature.HEADER);
  
          AuthenticationScheme authenticationScheme = SpecificationQuerier.query(specification)
                  .getAuthenticationScheme();
          assertThat(authenticationScheme).isInstanceOf(OAuthScheme.class);
          OAuthScheme oauthScheme = (OAuthScheme) authenticationScheme;
          assertThat(oauthScheme.getConsumerKey()).isEqualTo(CONSUMER_KEY);
          assertThat(oauthScheme.getConsumerSecret()).isEqualTo(CONSUMER_SECRET);
          assertThat(oauthScheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);
          assertThat(oauthScheme.getSecretToken()).isEqualTo(SECRET_TOKEN);
          assertThat(oauthScheme.getSignature()).isEqualTo(OAuthSignature.HEADER);
      }
  
      @Test
      void authenticateRegistersOAuthInterceptorWithConfiguredSignature() throws IOException {
          OAuthScheme oauthScheme = (OAuthScheme) RestAssured.oauth(
                  CONSUMER_KEY,
                  CONSUMER_SECRET,
                  ACCESS_TOKEN,
                  SECRET_TOKEN,
                  OAuthSignature.QUERY_STRING);
  
          assertThatOAuthInterceptorIsRegisteredBy(oauthScheme);
      }
  
      @Test
      void authenticateRegistersOAuthInterceptorWhenSignatureIsUnset() throws IOException {
          OAuthScheme oauthScheme = (OAuthScheme) RestAssured.oauth(
                  CONSUMER_KEY, CONSUMER_SECRET, ACCESS_TOKEN, SECRET_TOKEN);
  
          assertThat(oauthScheme.getSignature()).isNull();
          assertThatOAuthInterceptorIsRegisteredBy(oauthScheme);
      }
  
      @Test
      void groovyDispatchResolvesGeneratedClassHelper() throws Throwable {
          OAuthScheme oauthScheme = (OAuthScheme) RestAssured.oauth(
                  CONSUMER_KEY, CONSUMER_SECRET, ACCESS_TOKEN, SECRET_TOKEN);
          MethodHandle dispatch = MethodHandles.publicLookup().findVirtual(
                  OAuthScheme.class,
                  "this$dist$invoke$1",
                  MethodType.methodType(Object.class, String.class, Object.class));
  
          Object resolvedClass = dispatch.invoke(
                  oauthScheme,
                  "class$",
                  new Object[] {OAuthScheme.class.getName()});
  
          assertThat(resolvedClass).isSameAs(OAuthScheme.class);
      }
  
      private static void assertThatOAuthInterceptorIsRegisteredBy(
              OAuthScheme oauthScheme) throws IOException {
          DefaultHttpClient client = new DefaultHttpClient();
          try {
              TestHttpBuilder httpBuilder = new TestHttpBuilder(client);
              int originalInterceptorCount = client.getRequestInterceptorCount();
              oauthScheme.authenticate(httpBuilder);
  
              assertThat(client.getRequestInterceptorCount()).isEqualTo(originalInterceptorCount + 1);
          } finally {
              client.getConnectionManager().shutdown();
          }
      }
  
      private static final class TestHttpBuilder extends HTTPBuilder {
          private TestHttpBuilder(AbstractHttpClient client) {
              super(true, new EncoderConfig(), new DecoderConfig(), new OAuthConfig(), client);
          }
  
          @Override
          protected Object doRequest(
                  RequestConfigDelegate delegate) throws ClientProtocolException, IOException {
              return null;
          }
      }
  }
