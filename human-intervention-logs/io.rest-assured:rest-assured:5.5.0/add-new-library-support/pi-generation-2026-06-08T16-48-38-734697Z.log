"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Base64;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.authentication.AuthenticationScheme;\nimport io.restassured.authentication.PreemptiveBasicAuthScheme;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class PreemptiveBasicAuthSchemeTest {\n    private static final String USER_NAME = \"preemptive-user\";\n    private static final String PASSWORD = \"preemptive-password\";\n    private static final String AUTHORIZATION_HEADER = \"Basic \" + Base64.getEncoder()\n            .encodeToString((USER_NAME + \":\" + PASSWORD).getBytes(StandardCharsets.ISO_8859_1));\n\n    @Test\n    void createsPreemptiveBasicAuthenticationSchemeWithConfiguredCredentials() {\n        AuthenticationScheme authenticationScheme = RestAssured.preemptive().basic(USER_NAME, PASSWORD);\n\n        assertThat(authenticationScheme).isInstanceOf(PreemptiveBasicAuthScheme.class);\n        PreemptiveBasicAuthScheme preemptiveBasicAuthScheme = (PreemptiveBasicAuthScheme) authenticationScheme;\n        assertThat(preemptiveBasicAuthScheme.getUserName()).isEqualTo(USER_NAME);\n        assertThat(preemptiveBasicAuthScheme.getPassword()).isEqualTo(PASSWORD);\n        assertThat(preemptiveBasicAuthScheme.generateAuthToken()).isEqualTo(AUTHORIZATION_HEADER);\n    }\n\n    @Test\n    void appliesPreemptiveBasicAuthenticationWithoutChallenge() throws Exception {\n        AtomicInteger requestCount = new AtomicInteger();\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/secured\", exchange -> sendPreemptiveResponse(exchange, requestCount));\n        server.setExecutor(executor);\n        server.start();\n\n        AuthenticationScheme previousAuthentication = RestAssured.authentication;\n        RestAssured.authentication = RestAssured.preemptive().basic(USER_NAME, PASSWORD);\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/secured\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .body(equalTo(\"preemptive\"));\n            assertThat(requestCount.get()).isEqualTo(1);\n        } finally {\n            RestAssured.authentication = previousAuthentication;\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendPreemptiveResponse(HttpExchange exchange, AtomicInteger requestCount) throws IOException {\n        requestCount.incrementAndGet();\n        try {\n            Headers requestHeaders = exchange.getRequestHeaders();\n            if (!AUTHORIZATION_HEADER.equals(requestHeaders.getFirst(\"Authorization\"))) {\n                Headers responseHeaders = exchange.getResponseHeaders();\n                responseHeaders.add(\"WWW-Authenticate\", \"Basic realm=\\\"rest-assured-test\\\"\");\n                exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);\n                return;\n            }\n\n            byte[] body = \"preemptive\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 7034, "output": 1382, "cacheRead": 29184, "cacheWrite": 0, "totalTokens": 37600, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780937244492, "responseId": "resp_0172a2e9625a6652016a26f21d074881969b2ac0055ec00e63"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tjFmRqHpgodpKyd5klHkmVbd|fc_0172a2e9625a6652016a26f22787808196beb792e14ec315a3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4247 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/PreemptiveBasicAuthSchemeTest.java"}], "isError": false, "timestamp": 1780937265908}]}
