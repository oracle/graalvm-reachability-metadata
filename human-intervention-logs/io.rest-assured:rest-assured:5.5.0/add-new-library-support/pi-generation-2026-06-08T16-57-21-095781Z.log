 * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.authentication.AuthenticationScheme;\nimport io.restassured.authentication.PreemptiveOAuth2HeaderScheme;\nimport io.restassured.specification.RequestSpecification;\nimport io.restassured.specification.SpecificationQuerier;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class PreemptiveOAuth2HeaderSchemeTest {\n    private static final String ACCESS_TOKEN = \"preemptive-oauth2-access-token\";\n    private static final String AUTHORIZATION_HEADER = \"Bearer \" + ACCESS_TOKEN;\n\n    @Test\n    void createsPreemptiveOAuth2HeaderSchemeWithConfiguredAccessToken() {\n        AuthenticationScheme authenticationScheme = RestAssured.oauth2(ACCESS_TOKEN);\n\n        assertThat(authenticationScheme).isInstanceOf(PreemptiveOAuth2HeaderScheme.class);\n        PreemptiveOAuth2HeaderScheme scheme = (PreemptiveOAuth2HeaderScheme) authenticationScheme;\n        assertThat(scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n        assertThat(scheme.generateAuthToken()).isEqualTo(AUTHORIZATION_HEADER);\n    }\n\n    @Test\n    void requestAuthenticationDslUsesPreemptiveHeaderSchemeForDefaultOAuth2() {\n        RequestSpecification specification = given()\n                .auth()\n                .oauth2(ACCESS_TOKEN);\n\n        AuthenticationScheme authenticationScheme = SpecificationQuerier.query(specification)\n                .getAuthenticationScheme();\n        assertThat(authenticationScheme).isInstanceOf(PreemptiveOAuth2HeaderScheme.class);\n        PreemptiveOAuth2HeaderScheme scheme = (PreemptiveOAuth2HeaderScheme) authenticationScheme;\n        assertThat(scheme.getAccessToken()).isEqualTo(ACCESS_TOKEN);\n    }\n\n    @Test\n    void groovyObjectDispatchResolvesGeneratedClassHelper() {\n        PreemptiveOAuth2HeaderScheme scheme = (PreemptiveOAuth2HeaderScheme) RestAssured.oauth2(ACCESS_TOKEN);\n\n        Object resolvedClass = scheme.invokeMethod(\n                \"class$\",\n                new Object[] {PreemptiveOAuth2HeaderScheme.class.getName()});\n\n        assertThat(resolvedClass).isSameAs(PreemptiveOAuth2HeaderScheme.class);\n    }\n\n    @Test\n    void appliesPreemptiveOAuth2AuthenticationWithoutChallenge() throws Exception {\n        AtomicInteger requestCount = new AtomicInteger();\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/secured\", exchange -> sendPreemptiveResponse(exchange, requestCount));\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .auth()\n                    .oauth2(ACCESS_TOKEN)\n                    .when()\n                    .get(\"/secured\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .body(equalTo(\"preemptive-oauth2\"));\n            assertThat(requestCount.get()).isEqualTo(1);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    @Test\n    void preemptiveDslAddsOAuth2AuthorizationHeaderDirectly() {\n        RequestSpecification specification = given()\n                .auth()\n                .preemptive()\n                .oauth2(ACCESS_TOKEN);\n\n        String authorization = SpecificationQuerier.query(specification)\n                .getHeaders()\n                .getValue(\"Authorization\");\n        assertThat(authorization).isEqualTo(AUTHORIZATION_HEADER);\n    }\n\n    private static void sendPreemptiveResponse(HttpExchange exchange, AtomicInteger requestCount) throws IOException {\n        requestCount.incrementAndGet();\n        try {\n            Headers requestHeaders = exchange.getRequestHeaders();\n            if (!AUTHORIZATION_HEADER.equals(requestHeaders.getFirst(\"Authorization\"))) {\n                Headers responseHeaders = exchange.getResponseHeaders();\n                responseHeaders.add(\"WWW-Authenticate\", \"Bearer realm=\\\"rest-assured-test\\\"\");\n                exchange.sendResponseHeaders(HttpURLConnection.HTTP_UNAUTHORIZED, -1);\n                return;\n            }\n\n            byte[] body = \"preemptive-oauth2\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3009, "output": 1893, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 28454, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780937757549, "responseId": "resp_03c34d18ed634605016a26f41dfd848194b82811a4950b5c3e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_1WaEHAUHjaCqW6CgpkeHbfg5|fc_03c34d18ed634605016a26f431d40c8194ac1e1f5f6e42c848"