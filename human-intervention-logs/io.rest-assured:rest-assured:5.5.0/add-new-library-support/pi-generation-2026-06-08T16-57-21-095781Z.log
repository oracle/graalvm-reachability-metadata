  package io.restassured.authentication
  
  import io.restassured.internal.http.HTTPBuilder
  
  /**
   * Used for preemptive oauth2 header authentication
   */
  class PreemptiveOAuth2HeaderScheme implements AuthenticationScheme {
  
    def String accessToken
  
    @Override
    void authenticate(HTTPBuilder httpBuilder) {
      httpBuilder.headers['Authorization'] = generateAuthToken()
    }
  
    public String generateAuthToken() {
      "Bearer " + accessToken
    }
  }
