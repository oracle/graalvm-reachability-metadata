[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/StreamVerifierTest.java","edits":[{"oldText":"import com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.hamcrest.Matchers.equalTo;","newText":"import com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.parsing.Parser;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.hamcrest.Matchers.equalTo;"},{"oldText":"public class StreamVerifierTest {\n    @Test\n    void validatesJsonPathBodyAssertionThroughResponseSpecification() throws Exception {","newText":"public class StreamVerifierTest {\n    private static final String CUSTOM_JSON_CONTENT_TYPE = \"application/vnd.stream-verifier+json\";\n\n    @Test\n    void validatesJsonPathBodyAssertionThroughResponseSpecification() throws Exception {"},{"oldText":"    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", \"application/json; charset=UTF-8\");\n            byte[] body = \"\"\"\n                    {\"message\":\"hello\",\"details\":{\"count\":2}}\n                    \"\"\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}","newText":"    @Test\n    void validatesJsonPathBodyAssertionWithCustomParser() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/custom-message\", this::sendCustomJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n        RestAssured.registerParser(CUSTOM_JSON_CONTENT_TYPE, Parser.JSON);\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/custom-message\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .body(\"message\", equalTo(\"custom\"))\n                    .body(\"details.count\", equalTo(4));\n        } finally {\n            RestAssured.unregisterParser(CUSTOM_JSON_CONTENT_TYPE);\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        sendJsonResponse(exchange, \"application/json; charset=UTF-8\", \"hello\", 2);\n    }\n\n    private void sendCustomJsonResponse(HttpExchange exchange) throws IOException {\n        sendJsonResponse(exchange, CUSTOM_JSON_CONTENT_TYPE, \"custom\", 4);\n    }\n\n    private void sendJsonResponse(HttpExchange exchange, String contentType, String message, int count) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", contentType);\n            byte[] body = \"\"\"\n                    {\"message\":\"%s\",\"details\":{\"count\":%d}}\n                    \"\"\".formatted(message, count).getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}"}]}
