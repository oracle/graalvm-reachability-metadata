          } else {
            theKey = keyValue[0]
            theValue = keyValue[1]
          }
          queryParam(theKey, theValue)
        }
        path = path.substring(0, indexOfQuestionMark)
      }
      return path
    }
  
    private def defineRequestContentTypeAsString(String method) {
