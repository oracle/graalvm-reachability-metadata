[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/build.gradle","edits":[{"oldText":"sourceSets {\n    test {\n        output.dir(generatedDirectAccessClasses, builtBy: generateDirectAccessClass)\n    }\n}\n\n tasks.named(\"compileTestJava\") {","newText":"sourceSets {\n    test {\n        output.dir(generatedDirectAccessClasses, builtBy: generateDirectAccessClass)\n    }\n}\n\nClosure<Void> patchEffectiveJacocoClass = { String classEntryName ->\n    String effectiveJarDirectoryName = \"rest_assured_${libraryVersion.replaceAll('[^A-Za-z0-9]', '_')}_jar\"\n    File sourceFile = generatedDirectAccessClasses.get().file(classEntryName).asFile\n    File effectiveFile = layout.buildDirectory\n            .file(\"jacoco/effective/${effectiveJarDirectoryName}/${classEntryName}\")\n            .get()\n            .asFile\n    if (sourceFile.exists()) {\n        effectiveFile.parentFile.mkdirs()\n        effectiveFile.bytes = sourceFile.bytes\n    }\n    null\n}\n\nClosure<Void> patchTrustAndKeystoreCreateStoreClosureForJacoco = {\n    patchEffectiveJacocoClass(\"io/restassured/internal/TrustAndKeystoreSpecImpl\\$_createStore_closure1.class\")\n    null\n}\n\ntasks.matching { Task task ->\n    task.name == \"jacocoTestReport\"\n}.configureEach { Task task ->\n    task.dependsOn(generateDirectAccessClass)\n    task.doFirst {\n        patchTrustAndKeystoreCreateStoreClosureForJacoco()\n    }\n}\n\ntasks.named(\"test\") {\n    dependsOn(generateDirectAccessClass)\n    doFirst {\n        patchTrustAndKeystoreCreateStoreClosureForJacoco()\n    }\n    doLast {\n        patchTrustAndKeystoreCreateStoreClosureForJacoco()\n    }\n}\n\ntasks.named(\"compileTestJava\") {"}]}
