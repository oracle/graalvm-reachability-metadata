[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/CertAuthSchemeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.security.KeyStore;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\n\nimport javax.net.ssl.KeyManagerFactory;\nimport javax.net.ssl.SSLContext;\nimport javax.net.ssl.TrustManagerFactory;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpsConfigurator;\nimport com.sun.net.httpserver.HttpsServer;\nimport io.restassured.RestAssured;\nimport io.restassured.authentication.AuthenticationScheme;\nimport io.restassured.authentication.CertAuthScheme;\nimport io.restassured.authentication.CertificateAuthSettings;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static io.restassured.authentication.CertificateAuthSettings.certAuthSettings;\nimport static org.apache.http.conn.ssl.SSLSocketFactory.ALLOW_ALL_HOSTNAME_VERIFIER;\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class CertAuthSchemeTest {\n    private static final String KEY_STORE_RESOURCE = \"/ssl-config-test-keystore.p12\";\n    private static final String KEY_STORE_PASSWORD = \"changeit\";\n    private static final String KEY_STORE_TYPE = \"PKCS12\";\n\n    @Test\n    void createsCertificateAuthenticationSchemeWithConfiguredStores() throws Exception {\n        KeyStore keyStore = loadTestKeyStore();\n        KeyStore trustStore = loadTestKeyStore();\n        CertificateAuthSettings settings = certAuthSettings()\n                .keyStoreType(KEY_STORE_TYPE)\n                .trustStoreType(KEY_STORE_TYPE)\n                .keyStore(keyStore)\n                .trustStore(trustStore)\n                .port(8443)\n                .allowAllHostnames();\n\n        AuthenticationScheme authenticationScheme = RestAssured.certificate(\n                \"truststore.p12\", \"trust-password\", \"keystore.p12\", \"key-password\", settings);\n\n        assertThat(authenticationScheme).isInstanceOf(CertAuthScheme.class);\n        CertAuthScheme certAuthScheme = (CertAuthScheme) authenticationScheme;\n        assertThat(certAuthScheme.getPathToTrustStore()).isEqualTo(\"truststore.p12\");\n        assertThat(certAuthScheme.getTrustStorePassword()).isEqualTo(\"trust-password\");\n        assertThat(certAuthScheme.getTrustStoreType()).isEqualTo(KEY_STORE_TYPE);\n        assertThat(certAuthScheme.getTrustStore()).isSameAs(trustStore);\n        assertThat(certAuthScheme.getPathToKeyStore()).isEqualTo(\"keystore.p12\");\n        assertThat(certAuthScheme.getKeyStorePassword()).isEqualTo(\"key-password\");\n        assertThat(certAuthScheme.getKeystoreType()).isEqualTo(KEY_STORE_TYPE);\n        assertThat(certAuthScheme.getKeyStore()).isSameAs(keyStore);\n        assertThat(certAuthScheme.getPort()).isEqualTo(8443);\n        assertThat(certAuthScheme.getX509HostnameVerifier()).isSameAs(ALLOW_ALL_HOSTNAME_VERIFIER);\n    }\n\n    @Test\n    void appliesCertificateAuthenticationToHttpsRequests() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpsServer server = HttpsServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.setHttpsConfigurator(new HttpsConfigurator(createServerSslContext()));\n        server.createContext(\"/certificate\", CertAuthSchemeTest::sendCertificateAcceptedResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            CertificateAuthSettings settings = certAuthSettings()\n                    .keyStoreType(KEY_STORE_TYPE)\n                    .trustStoreType(KEY_STORE_TYPE)\n                    .allowAllHostnames();\n            RestAssured.authentication = RestAssured.certificate(\n                    KEY_STORE_RESOURCE, KEY_STORE_PASSWORD, KEY_STORE_RESOURCE, KEY_STORE_PASSWORD, settings);\n\n            given()\n                    .baseUri(\"https://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/certificate\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .body(equalTo(\"certificate accepted\"));\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static SSLContext createServerSslContext() throws Exception {\n        KeyStore keyStore = loadTestKeyStore();\n        KeyManagerFactory keyManagerFactory = KeyManagerFactory.getInstance(KeyManagerFactory.getDefaultAlgorithm());\n        keyManagerFactory.init(keyStore, KEY_STORE_PASSWORD.toCharArray());\n        TrustManagerFactory trustManagerFactory = TrustManagerFactory.getInstance(\n                TrustManagerFactory.getDefaultAlgorithm());\n        trustManagerFactory.init(keyStore);\n\n        SSLContext sslContext = SSLContext.getInstance(\"TLS\");\n        sslContext.init(keyManagerFactory.getKeyManagers(), trustManagerFactory.getTrustManagers(), null);\n        return sslContext;\n    }\n\n    private static KeyStore loadTestKeyStore() throws Exception {\n        KeyStore keyStore = KeyStore.getInstance(KEY_STORE_TYPE);\n        try (InputStream inputStream = CertAuthSchemeTest.class.getResourceAsStream(KEY_STORE_RESOURCE)) {\n            assertThat(inputStream).isNotNull();\n            keyStore.load(inputStream, KEY_STORE_PASSWORD.toCharArray());\n        }\n        return keyStore;\n    }\n\n    private static void sendCertificateAcceptedResponse(HttpExchange exchange) throws IOException {\n        try {\n            byte[] body = \"certificate accepted\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}
