  import io.restassured.RestAssured;
  import io.restassured.http.ContentType;
  import io.restassured.internal.support.FileReader;
  import io.restassured.response.Response;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FileReaderTest {
      @Test
      void resolvesRuntimeSelectedClassThroughGeneratedGroovyClassLookup() throws Throwable {
          MethodHandle classLookup = MethodHandles.privateLookupIn(FileReader.class, MethodHandles.lookup())
                  .findStatic(FileReader.class, "class$", MethodType.methodType(Class.class, String.class));
  
          Class<?> resolvedClass = (Class<?>) classLookup.invoke(runtimeSelectedRestAssuredTypeName());
  
          assertThat(resolvedClass.getName()).isEqualTo("io.restassured.http.ContentType");
      }
  
