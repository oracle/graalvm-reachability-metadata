src/test/java/io_rest_assured/rest_assured/ContentTypeSubTypeExtractorInner_getSubTypeValueFromContentType_closure1Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.IOException;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\n\nimport com.sun.net.httpserver.Headers;\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ContentTypeSubTypeExtractorInner_getSubTypeValueFromContentType_closure1Test {\n    private static final String BODY = \"Rest Assured café\";\n\n    @Test\n    void extractsCharsetSubtypeWhenRestAssuredDecodesResponseBody() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/latin1\", this::sendLatin1Response);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            String decodedBody = given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/latin1\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .extract()\n                    .asString();\n\n            assertThat(decodedBody).isEqualTo(BODY);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendLatin1Response(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", \"text/plain; charset=ISO-8859-1\");\n            byte[] body = BODY.getBytes(StandardCharsets.ISO_8859_1);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1881, "output": 1150, "cacheRead": 67072, "cacheWrite": 0, "totalTokens": 70103, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781023322349, "responseId": "resp_0b039d431a2fea03016a28425b2664819598d761576fd8c003"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_MaMCuJWThA7IvYpEAr0xRzOB|fc_0b039d431a2fea03016a28426a33348195b30251ce3ddf8df3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2407 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ContentTypeSubTypeExtractorInner_getSubTypeValueFromContentType_closure1Test.java"}], "isError": false, "timestamp": 1781023343400}]}
