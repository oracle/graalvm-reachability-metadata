ParamValues_closure43Test::sendObservedPath);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Response response = RestAssured\n                    .given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .filter(captureUnnamedPathParameterValues)\n                    .when()\n                    .get(\"/library/{category}/books/{bookId}\", \"sci-fi\", 42);\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString()).isEqualTo(\"/library/sci-fi/books/42\");\n            assertThat(unnamedPathParameterValues.get()).containsExactly(\"sci-fi\", \"42\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n\n    private static void sendObservedPath(HttpExchange exchange) throws IOException {\n        byte[] responseBytes = exchange.getRequestURI().getPath().getBytes(StandardCharsets.UTF_8);\n        exchange.sendResponseHeaders(200, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1404, "output": 832, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 27324, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780965817347, "responseId": "resp_0d7a0cc05462283e016a2761b9ce00819381b99b67827b9f99"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_qcITEUBBkDzhQUAD4SrRBQQu|fc_0d7a0cc05462283e016a2761c00e308193a60c3a6db43e3e73", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2764 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_getUnnamedPathParamValues_closure43Test.jav