junit.jupiter.api.Test;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class NoParameterValueTest {\n    @Test\n    void resolvesOwnClassThroughCompilerGeneratedClassResolver() throws Throwable {\n        Class<?> resolvedClass = resolveWithCompilerGeneratedClassResolver(\n                \"io.restassured.internal.NoParameterValue\");\n\n        assertSame(NoParameterValue.class, resolvedClass);\n    }\n\n    @Test\n    void reportsUnknownCompilerGeneratedClassAsNoClassDefFoundError() throws Throwable {\n        NoClassDefFoundError error = assertThrows(\n                NoClassDefFoundError.class,\n                () -> resolveWithCompilerGeneratedClassResolver(\n                        \"io.restassured.internal.NoParameterValueMissingClass\"));\n\n        assertEquals(\"io.restassured.internal.NoParameterValueMissingClass\", error.getMessage());\n    }\n\n    @Test\n    void markerHasGroovyObjectSemantics() {\n        NoParameterValue marker = new NoParameterValue();\n\n        assertTrue(marker instanceof groovy.lang.GroovyObject);\n    }\n\n    private static Class<?> resolveWithCompilerGeneratedClassResolver(String className) throws Throwable {\n        return (Class<?>) classResolver().invokeExact(className);\n    }\n\n    private static MethodHandle classResolver() throws IllegalAccessException, NoSuchMethodException {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                NoParameterValue.class,\n                MethodHandles.lookup());\n        return lookup.findStatic(\n                NoParameterValue.class,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 850, "output": 1408, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25298, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778426939081, "responseId": "resp_0583b49b15aeb7a9016a00a43ba8bc819081c538ecfbda2c41"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_j5KOuePR8370RoqJoHNlkSCh|fc_0583b49b15aeb7a9016a00a448094c8190905d80f65f0ab379", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2255 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/NoParameterValueTest.java"}], "isError": false, "timestamp": 1778426955104}]}
