java.util.Map;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.filter.Filter;\nimport io.restassured.response.Response;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RequestSpecificationImplInner_removeUnnamedPathParam_closure3Test {\n    @Test\n    void filterRemovesUnnamedPathParameterMatchingPlaceholderName() throws IOException {\n        AtomicReference<Map<String, String>> unnamedPathParametersAfterRemoval = new AtomicReference<>();\n        Filter replaceSecondUnnamedPathParameterWithNamedParameter = (requestSpecification, responseSpecification, context) -> {\n            requestSpecification.removeUnnamedPathParam(\"bookId\");\n            requestSpecification.pathParam(\"bookId\", \"12345\");\n            unnamedPathParametersAfterRemoval.set(new LinkedHashMap<>(requestSpecification.getUnnamedPathParams()));\n            return context.next(requestSpecification, responseSpecification);\n        };\n\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\n                \"/library/reference/books/12345\",\n                RequestSpecificationImplInner_removeUnnamedPathParam_closure3Test::sendObservedPath);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Response response = RestAssured\n                    .given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .filter(replaceSecondUnnamedPathParameterWithNamedParameter)\n                    .when()\n                    .get(\"/library/{section}/books/{bookId}\", \"reference\", \"discarded-book-id\");\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString()).isEqualTo(\"/library/reference/books/12345\");\n            assertThat(unnamedPathParametersAfterRemoval.get()).containsExactly(Map.entry(\"section\", \"reference\"));\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n\n    private static void sendObservedPath(HttpExchange exchange) throws IOException {\n        byte[] responseBytes = exchange.getRequestURI().getPath().getBytes(StandardCharsets.UTF_8);\n        exchange.sendResponseHeaders(200, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 897, "output": 1154, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 28675, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780977388886, "responseId": "resp_057ede121fbf4c03016a278eed51ec8195943d5bb5916abe05"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6vhC9hDJGd54E3nSjGHzrkul|fc_057ede121fbf4c03016a278ef8bb648195af4c6b1da8e8a04c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3005 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_removeUnnamedPathParam_closure3Test.java"}], "isError": false, "timestamp": 1780977405582}]}
