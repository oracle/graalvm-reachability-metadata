ionImplInner_statusLine_closure4Test::sendCreatedResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        ResponseSpecification responseSpecification = new ResponseSpecBuilder()\n                .expectStatusLine(containsString(String.valueOf(HttpURLConnection.HTTP_CREATED)))\n                .build();\n\n        try {\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/created\")\n                    .then()\n                    .spec(responseSpecification);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendCreatedResponse(HttpExchange exchange) throws IOException {\n        byte[] body = \"created\".getBytes(StandardCharsets.UTF_8);\n        exchange.sendResponseHeaders(HttpURLConnection.HTTP_CREATED, body.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(body);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2495, "output": 907, "cacheRead": 27136, "cacheWrite": 0, "totalTokens": 30538, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780998188388, "responseId": "resp_01e031d19007cb69016a27e02cd3848193993aaac55c7011b8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0ZJQlve1PF2MTJHELzf1iTcR|fc_01e031d19007cb69016a27e037b9c881938bbaac67e46c5636", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2396 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecificationImplInner_statusLine_closure4Test.java"}], "isError": false, "timestamp": 1780998203998}]}
