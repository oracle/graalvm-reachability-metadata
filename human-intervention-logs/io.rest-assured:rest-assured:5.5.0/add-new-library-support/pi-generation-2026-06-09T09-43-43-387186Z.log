Type.JSON)\n                    .header(\"X-Request-Id\", equalTo(\"request-1\"))\n                    .header(\"X-Body-Bytes\", Integer::parseInt, equalTo(19))\n                    .cookie(\"session\", \"abc\")\n                    .body(\"message\", equalTo(\"hello\"))\n                    .time(lessThan(5L), TimeUnit.SECONDS);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", ContentType.JSON.toString());\n            headers.add(\"X-Request-Id\", \"request-1\");\n            headers.add(\"X-Body-Bytes\", \"19\");\n            headers.add(\"Set-Cookie\", \"session=abc; Path=/; HttpOnly\");\n            byte[] body = \"{\\\"message\\\":\\\"hello\\\"}\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780998155451}, {"role": "toolResult", "toolCallId": "call_4PXQ26B0nvbjh5ajEGXa828m|fc_01e031d19007cb69016a27e00b477881939b0c16fa3e6f2d60", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.rest-assured:rest-assured:$libraryVersion\"\n    testImplementation 'com.github.scribejava:scribejava-apis:2.5.3'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\n