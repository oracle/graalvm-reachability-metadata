tassured.RestAssured.given;\nimport static io.restassured.config.FailureConfig.failureConfig;\nimport static io.restassured.config.RestAssuredConfig.config;\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\npublic class ResponseSpecificationImplInnerHamcrestAssertionClosureTest {\n    @Test\n    void invokesFailureListenersWhenResponseValidationFails() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/validation\", this::sendJsonResponse);\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            AtomicInteger failures = new AtomicInteger();\n            ResponseValidationFailureListener listener = (requestSpecification, responseSpecification, response) -> {\n                failures.incrementAndGet();\n                assertThat(response.getStatusCode()).isEqualTo(HttpURLConnection.HTTP_OK);\n                assertThat(responseSpecification).isNotNull();\n            };\n\n            AssertionError error = assertThrows(AssertionError.class, () -> given()\n                    .config(config().failureConfig(failureConfig().with().failureListeners(listener)))\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/validation\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_CREATED));\n\n            assertThat(error).hasMessageContaining(\"1 expectation failed\");\n            assertThat(failures.get()).isEqualTo(1);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private void sendJsonResponse(HttpExchange exchange) throws IOException {\n        try {\n            Headers headers = exchange.getResponseHeaders();\n            headers.add(\"Content-Type\", ContentType.JSON.toString());\n            byte[] body = \"{\\\"message\\\":\\\"hello\\\"}\".getBytes(StandardCharsets.UTF_8);\n            exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, body.length);\n            exchange.getResponseBody().write(body);\n        } finally {\n            exchange.close();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3147, "output": 1000, "cacheRead": 49664, "cacheWrite": 0, "totalTokens": 53811, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780981554699, "responseId": "resp_0164611d7fc238b0016a279f3375d08195b9ac01a9e41d6f82"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_VFV4sniNMuA27znZdb37T1yQ|fc_0164611d7fc238b0016a279f3b6f108195aecd16f246ee2eb8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3236 bytes to tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/ResponseSpecificationImplInnerHamcrestAssertionClosureTest.java"}], "isError": false, "timestamp": 1780981570065}]}
