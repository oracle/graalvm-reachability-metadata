oid pathParamValidationFiltersUnnamedParamsOverriddenByNamedParams() {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3612, "output": 993, "cacheRead": 34816, "cacheWrite": 0, "totalTokens": 39421, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778436405512, "responseId": "resp_0ff23ac0a4df4f40016a00c9363ab08192b2aeefec4a799094"}}
