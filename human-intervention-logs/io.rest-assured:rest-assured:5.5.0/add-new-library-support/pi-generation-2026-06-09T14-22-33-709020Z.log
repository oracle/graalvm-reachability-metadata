mport static io.restassured.RestAssured.given;\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.hamcrest.Matchers.equalTo;\n\npublic class FormAuthFilterInner_applySessionFilterFromOriginalRequestIfDefined_closure6Test {\n    private static final String USER_NAME = \"session-filter-user\";\n    private static final String PASSWORD = \"session-filter-password\";\n    private static final String SESSION_COOKIE_NAME = \"FORMAUTHSESSION\";\n    private static final String SESSION_COOKIE_VALUE = \"session-filter-valid\";\n    private static final String SESSION_COOKIE = SESSION_COOKIE_NAME + \"=\" + SESSION_COOKIE_VALUE;\n\n    @Test\n    void formAuthenticationAppliesOriginalSessionFilterToLoginRequest() throws Throwable {\n        AtomicBoolean loginRequestSeen = new AtomicBoolean(false);\n        AtomicBoolean authenticatedRequestSeen = new AtomicBoolean(false);\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/secured\", exchange -> sendSecuredResponse(exchange, authenticatedRequestSeen));\n        server.createContext(\"/login\", exchange -> sendLoginResponse(exchange, loginRequestSeen));\n        server.setExecutor(executor);\n        server.start();\n\n        try {\n            SessionFilter sessionFilter = new SessionFilter();\n            RestAssuredConfig config = RestAssuredConfig.config()\n                    .sessionConfig(SessionConfig.sessionConfig().sessionIdName(SESSION_COOKIE_NAME));\n\n            given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .config(config)\n                    .filter(sessionFilter)\n                    .auth()\n                    .form(USER_NAME, PASSWORD)\n                    .when()\n                    .get(\"/secured\")\n                    .then()\n                    .statusCode(HttpURLConnection.HTTP_OK)\n                    .body(equalTo(\"secured content\"));\n\n            assertThat(loginRequestSeen).isTrue();\n            assertThat(authenticatedRequestSeen).isTrue();\n            assertThat(sessionFilter.getSessionId()).isEqualTo(SESSION_COOKIE_VALUE);\n        } finally {\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n[74 more lines in file. Use offset=81 to continue.]"}], "isError": false, "timestamp": 1781015268548}]}
