ort static org.assertj.core.api.Assertions.assertThat;\n\npublic class RequestSpecificationImplInner_applyHttpClientConfig_closure22Test {\n    private static final String USER_AGENT_VALUE = \"rest-assured-http-client-config-test\";\n\n    @Test\n    void configuredHttpClientParameterIsAppliedToRequest() throws Throwable {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\n                \"/client-params\",\n                RequestSpecificationImplInner_applyHttpClientConfig_closure22Test::echoUserAgent);\n        server.setExecutor(executor);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Response response = given()\n                    .config(config().httpClient(httpClientConfig()\n                            .setParam(CoreProtocolPNames.USER_AGENT, USER_AGENT_VALUE)))\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/client-params\");\n\n            assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_OK);\n            assertThat(response.asString()).isEqualTo(USER_AGENT_VALUE);\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void echoUserAgent(HttpExchange exchange) throws IOException {\n        String response = exchange.getRequestHeaders().getFirst(\"User-Agent\");\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n\n        exchange.getResponseHeaders().set(\"Content-Type\", \"text/plain; charset=utf-8\");\n        exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780952943461}, {"role": "toolResult", "toolCallId": "call_yFTjkTSDHproNA4lwWlvp4WE|fc_09b5d41e45b33c8d016a272f6f408c819484bc0c9c17298a47", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.net.HttpURLConnection;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.zip.GZIPOutputStream;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.restassured.RestAssured;\nimport io.restassured.response.Response;\nimport org.junit.jupiter.api.Test;\n\nimport static io.restassured.RestAssured.given;\nimport static io.restassured.config.DecoderConfig.ContentDecoder.GZIP;\nimport static io.restassured.config.DecoderConfig.decoderConfig;\nimport static io.restassured.config.RestAssuredConfig.config;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RequestSpecificationImplInner_applyContentDecoders_closure21Test {\n    @Test\n    void configuredGzipContentDecoderIsAppliedToRequestAndResponse() throws Throwable {\n        ExecutorService executor = Executors.newSingleThreadExecutor();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\n                \"/compressed\",\n                RequestSpecificationImplInner_applyContentDecoders_closure21Test::sendGzipResponse);\n        server.setExecutor(executor);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Response response = given()\n                    .config(config().decoderConfig(decoderConfig().contentDecoders(GZIP)))\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .when()\n                    .get(\"/compressed\");\n\n            assertThat(response.statusCode()).isEqualTo(HttpURLConnection.HTTP_OK);\n            assertThat(response.asString()).contains(\"accept-encoding=gzip\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n            executor.shutdownNow();\n            executor.awaitTermination(5, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendGzipResponse(HttpExchange exchange) throws IOException {\n        String acceptEncoding = exchange.getRequestHeaders().getFirst(\"Accept-Encoding\");\n        byte[] responseBytes = gzip(\"accept-encoding=\" + acceptEncoding);\n\n        exchange.getResponseHeaders().set(\"Content-Type\", \"text/plain; charset=utf-8\");\n        exchange.getResponseHeaders().set(\"Content-Encoding\", \"gzip\");\n        exchange.sendResponseHeaders(HttpURLConnection.HTTP_OK, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n\n    private static byte[] gzip(String value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (GZIPOutputStream gzip = new GZIPOutputStream(bytes)) {\n            gzip.write(value.getBytes(StandardCharsets.UTF_8));\n        }\n        return bytes.toByteArray();\n    }\n}\n"}], "isError": false, "timestamp": 1780952943461}, {"role": "toolResult", "toolCallId": "call_2LtgnjPe05n4wxNT6s1J4ESh|fc_09b5d41e45b33c8d016a272f6f40988194b216f89b417fa47e", "toolName": "bash", "content": [{"type": "text", "text": "tests/src/io.