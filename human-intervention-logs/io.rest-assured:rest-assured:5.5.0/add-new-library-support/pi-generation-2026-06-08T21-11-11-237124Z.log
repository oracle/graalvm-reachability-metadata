        loginRequestSpec.config(cfg.sessionConfig(SessionConfig.sessionConfig().sessionIdName(sessionIdName)))
      }
    }
  
    static def throwIfException(Closure closure) {
      try {
        closure.call()
      } catch (Exception e) {
