port org.junit.jupiter.api.Test;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.util.List;"}, {"oldText": "    @Test\n    void loadsNamedClassThroughCompilerGeneratedClassResolverMethod() throws ReflectiveOperationException {\n        String className = \"io.restassured.filter.log.RequestLoggingFilter\";\n        Method classResolver = RequestLogSpecificationImpl.class.getDeclaredMethod(\"class$\", String.class);\n        classResolver.setAccessible(true);\n\n        Class<?> resolvedClass = (Class<?>) classResolver.invoke(null, className);\n\n        assertEquals(className, resolvedClass.getName());\n    }\n\n    @Test\n    void reportsUnknownCompilerGeneratedClassAsNoClassDefFoundError() throws Throwable {", "newText": "    @Test\n    void invokesCompilerGeneratedClassResolverFromGroovyCodeInSamePackage() {\n        try {\n            Object resolvedClass = new GroovyShell(RequestLogSpecificationImpl.class.getClassLoader()).evaluate(\"\"\"\n                    package io.restassured.internal\n\n                    RequestLogSpecificationImpl.class$('io.restassured.filter.log.RequestLoggingFilter')\n                    \"\"\");\n\n            assertSame(RequestLoggingFilter.class, resolvedClass);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void reportsUnknownCompilerGeneratedClassAsNoClassDefFoundError() throws Throwable {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 894, "output": 1517, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 44395, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778428871947, "responseId": "resp_0a2a56880a0f68eb016a00abc932c0819eae4314921b10f3c2"}}
