[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/MapCreatorInner_createArgumentArray_closure2Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\npublic class MapCreatorInner_createArgumentArray_closure2Test {\n    @Test\n    void generatedGroovyClosureClassHelperResolvesLibraryClassName() throws Throwable {\n        ClassLoader classLoader = Thread.currentThread().getContextClassLoader();\n        Class<?> closureClass = classLoader.loadClass(\n                \"io.restassured.internal.MapCreator$_createArgumentArray_closure2\");\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(closureClass, MethodHandles.lookup());\n        MethodHandle classHelper = lookup.findStatic(\n                closureClass,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n        String markerClassName = \"io.restassured.internal.NoParameterValue\";\n\n        Class<?> resolvedClass = (Class<?>) classHelper.invokeExact(markerClassName);\n\n        assertEquals(markerClassName, resolvedClass.getName());\n    }\n}\n"}
[tool-call] end id=call_QbTP5n0L8KavQD5hg7xJ1vpq|fc_05a238dcbd772a70016a2714df81b48197a30fa23dd7ff9637 name=write args={"path": "tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/MapCreatorInner_createArgumentArray_closure2Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\npublic class MapCreatorInner_createArgumentArray_closure2Test {\n    @Test\n    void generatedGroovyClosureClassHelperResolvesLibraryClassName() throws Throwable {\n        ClassLoader classLoader = Thread.currentThread().getContextClassLoader();\n        Class<?> closureClass = classLoader.loadClass(\n                \"io.restassured.internal.MapCreator$_createArgumentArray_closure2\");\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(closureClass, MethodHandles.lookup());\n        MethodHandle classHelper = lookup.findStatic(\n                closureClass,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n        String markerClassName = \"io.restassured.internal.NoParameterValue\";\n\n        Class<?> resolvedClass = (Class<?>) classHelper.invokeExact(markerClassName);\n\n        assertEquals(markerClassName, resolvedClass.getName());\n    }\n}\n"}
