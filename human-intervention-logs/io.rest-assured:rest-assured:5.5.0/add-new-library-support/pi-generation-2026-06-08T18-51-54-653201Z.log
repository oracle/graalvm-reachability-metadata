ertSame(CollisionStrategy.class, resolvedClass);\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1432, "output": 953, "cacheRead": 46592, "cacheWrite": 0, "totalTokens": 48977, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780944953857, "responseId": "resp_0b9e899f0d38bacd016a27103a97ac8197a2a11046a34191c5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_K8mSijSRDX9z8z29UbUqYVEq|fc_0b9e899f0d38bacd016a27104a9a4c8197bd6b5c4c1a71cfcb", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/MapCreatorInnerCollisionStrategyTest.java."}], "details": {"diff": "    ...\n  5  * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n  6  */\n  7 package io_rest_assured.rest_assured;\n  8 \n- 9 import groovy.lang.MetaClass;\n+ 9 import java.lang.invoke.MethodHandle;\n+10 import java.lang.invoke.MethodHandles;\n+11 import java.lang.invoke.MethodType;\n+12 \n 10 import io.restassured.internal.MapCreator.CollisionStrategy;\n 11 import org.junit.jupiter.api.Test;\n 12 \n 13 import static org.junit.jupiter.api.Assertions.assertEquals;\n 14 import static org.junit.jupiter.api.Assertions.assertSame;\n 15 \n 16 public class MapCreatorInnerCollisionStrategyTest {\n 17     @Test\n-18     void groovyEnumMetaClassResolvesGeneratedClassHelper() {\n+21     void generatedGroovyEnumClassHelperResolvesLibraryClassName() throws Throwable {\n 19         assertEquals(CollisionStrategy.MERGE, CollisionStrategy.valueOf(\"MERGE\"));\n-20         MetaClass metaClass = CollisionStrategy.MERGE.getMetaClass();\n-21 \n-22         Object resolvedClass = metaClass.invokeStaticMethod(\n+23         MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(CollisionStrategy.class, MethodHandles.lookup());\n+24         Metho