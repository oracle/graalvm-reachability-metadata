  package io_rest_assured.rest_assured;
  
  import io.restassured.internal.MapCreator.CollisionStrategy;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class MapCreatorInnerCollisionStrategyTest {
      @Test
      void groovyEnumDispatchResolvesGeneratedClassHelper() {
          assertEquals(CollisionStrategy.OVERWRITE, CollisionStrategy.MERGE.next());
          assertEquals(CollisionStrategy.MERGE, CollisionStrategy.OVERWRITE.next());
          assertEquals(CollisionStrategy.OVERWRITE, CollisionStrategy.MERGE.previous());
  
          String className = "io.restassured.internal.MapCreator";
  
          Class<?> resolvedClass = (Class<?>) CollisionStrategy.MERGE.invokeMethod(
                  "class$",
                  new Object[] {className});
  
          assertEquals(className, resolvedClass.getName());
      }
  }
