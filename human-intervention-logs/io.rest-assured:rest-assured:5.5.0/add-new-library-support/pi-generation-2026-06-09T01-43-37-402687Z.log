[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_headers_closure6Test.java","edits":[{"oldText":"    @Test\n    void sendsHeadersAddedThroughMap() throws IOException {\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/headers\", RequestSpecificationImplInner_headers_closure6Test::echoTraceHeader);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Map<String, Object> headers = new LinkedHashMap<>();\n            headers.put(\"X-Trace\", \"alpha\");\n\n            Response response = RestAssured\n                    .given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .headers(headers)\n                    .when()\n                    .get(\"/headers\");\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString()).isEqualTo(\"alpha\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n","newText":"    @Test\n    void sendsScalarAndListHeadersAddedThroughMap() throws IOException {\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/headers\", RequestSpecificationImplInner_headers_closure6Test::echoTraceHeaders);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Map<String, Object> headers = new LinkedHashMap<>();\n            headers.put(\"X-Trace\", \"alpha\");\n            headers.put(\"X-Sequence\", List.of(\"bravo\", \"charlie\"));\n\n            Response response = RestAssured\n                    .given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .headers(headers)\n                    .when()\n                    .get(\"/headers\");\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString())\n                    .contains(\"trace=alpha\")\n                    .contains(\"sequence=bravo,charlie\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n"},{"oldText":"    private static void echoTraceHeader(HttpExchange exchange) throws IOException {\n        List<String> headers = exchange.getRequestHeaders().get(\"X-Trace\");\n        String response = headers == null ? \"\" : String.join(\",\", headers);\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n\n        exchange.sendResponseHeaders(200, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n","newText":"    private static void echoTraceHeaders(HttpExchange exchange) throws IOException {\n        List<String> traceHeaders = exchange.getRequestHeaders().get(\"X-Trace\");\n        List<String> sequenceHeaders = exchange.getRequestHeaders().get(\"X-Sequence\");\n        String response = \"trace=\" + joinHeaders(traceHeaders)\n                + \"\\nsequence=\" + joinHeaders(sequenceHeaders);\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n\n        exchange.sendResponseHeaders(200, responseBytes.length);\n        try (OutputStream outputStream = exchange.getResponseBody()) {\n            outputStream.write(responseBytes);\n        }\n    }\n\n    private static String joinHeaders(List<String> headers) {\n        return headers == null ? \"\" : String.join(\",\", headers);\n    }\n"}]}
