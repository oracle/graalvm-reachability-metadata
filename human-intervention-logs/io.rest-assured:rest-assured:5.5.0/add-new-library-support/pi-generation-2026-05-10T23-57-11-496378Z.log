ectory directory ->\n        directory.file(\"io/restassured/internal/RequestSpecificationImplRegisterRestAssuredEncodersClosure24DirectAccess.class\")\n    })\n    outputs.file(generatedDirectAccessClasses.map { Directory directory ->\n        directory.file(\"io/restassured/internal/RequestSpecificationImplRegisterRestAssuredEncodersClosure24Closure51DirectAccess.class\")\n    })\n    outputs.file(generatedDirectAccessClasses.map { Directory directory ->\n        directory.file(\"io/restassured/internal/RequestSpecificationImplRegisterRestAssuredEncodersClosure24Closure51Closure52DirectAccess.class\")\n    })\n    inputs.property(\"directAccessClassesVersion\", \"remove-cookie-closure2-v2\")\n\n    doLast {\n        delete(generatedDirectAccessClasses.get()\n                .file(\"io/restassured/internal/RequestSpecificationImplPartiallyApplyPathParamsClosure35Access.class\")\n                .asFile)\n        writeGeneratedDirectAccessClass(\n                \"io/restassured/internal/RequestSpecificationImplHeaderClosure8Access.class\",\n                \"\")\n        writeGeneratedDirectAccessClass(\n                \"io/restassured/internal/RequestSpecificationImplHeadersClosure6DirectAccess.class\",\n                \"\")\n        writeGeneratedDirectAccessClass(\n                \"io/restassured/internal/RequestSpecificationImplHeadersClosure6Closure49DirectAccess.class\",\n                \"\")\n        writeGeneratedDirectAccessClass(\n                \"io/restassured/internal/RequestSpecificationImplNewFilterContextClosure12DirectAccess.class\",\n                \"\")\n        writeGeneratedDirectAccessClass(\n                \"io/restassured/internal/RequestSpecificationImplNewFilterContextClosure13DirectAccess.class\",\n                \"\")\n        writeGeneratedDirectAccessClass(\n                \"io/restassured/internal/RequestSpecificationImpl\\$_removeCookie_closure2.class\",\n                \"\")\n        writeGeneratedDirectAccessClass(\n     