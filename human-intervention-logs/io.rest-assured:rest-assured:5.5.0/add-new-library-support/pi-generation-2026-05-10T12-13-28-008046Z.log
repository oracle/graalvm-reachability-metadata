[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/StreamVerifierTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_rest_assured.rest_assured;\n\nimport io.restassured.assertion.StreamVerifier;\nimport io.restassured.builder.ResponseBuilder;\nimport io.restassured.http.ContentType;\nimport io.restassured.response.Response;\nimport org.junit.jupiter.api.Test;\n\nimport static org.hamcrest.Matchers.equalTo;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\npublic class StreamVerifierTest {\n    @Test\n    void resolvesCompilerGeneratedClassResolverThroughGroovyDispatch() {\n        StreamVerifier verifier = new StreamVerifier();\n\n        Object resolvedClass = verifier.invokeMethod(\n                \"class$\",\n                new Object[] {\"io.restassured.assertion.StreamVerifier\"});\n\n        assertSame(StreamVerifier.class, resolvedClass);\n    }\n\n    @Test\n    void createsJsonAssertionForContentTypeAwareBodyPathValidation() {\n        Response response = new ResponseBuilder()\n                .setStatusCode(200)\n                .setContentType(ContentType.JSON)\n                .setBody(\"{\\\"message\\\":\\\"hello\\\",\\\"count\\\":2}\")\n                .build();\n\n        response.then()\n                .assertThat()\n                .body(\"message\", equalTo(\"hello\"))\n                .body(\"count\", equalTo(2));\n    }\n}\n"}
