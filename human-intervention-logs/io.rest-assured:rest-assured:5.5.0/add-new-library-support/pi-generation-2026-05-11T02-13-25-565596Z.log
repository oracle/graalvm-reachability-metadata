        def errors = []
        if (expectedStatusCode != null) {
          def actualStatusCode = response.getStatusCode()
          if (!expectedStatusCode.matches(actualStatusCode)) {
  
            def errorMessage = new MatcherErrorMessageBuilder<Integer, Matcher<Integer>>("status code")
