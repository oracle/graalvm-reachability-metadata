atedClosure;\nimport org.hamcrest.Matcher;\n\nimport java.util.concurrent.TimeUnit;\n\nfinal class ResponseSpecificationImpl$_time_closure2 extends Closure<Object> implements GeneratedClosure {\n    private final Reference<Matcher<Long>> matcher;\n    private final Reference<TimeUnit> timeUnit;\n\n    ResponseSpecificationImpl$_time_closure2(\n            Object owner,\n            Object thisObject,\n            Reference<Matcher<Long>> matcher,\n            Reference<TimeUnit> timeUnit) {\n        super(owner, thisObject);\n        this.matcher = matcher;\n        this.timeUnit = timeUnit;\n    }\n\n    public Object doCall(Object ignored) {\n        class$(\"groovy.lang.Tuple2\");\n        Tuple2<Matcher<Long>, TimeUnit> expectedResponseTime = new Tuple2<>(matcher.get(), timeUnit.get());\n        ((GroovyObject) getOwner()).setProperty(\"expectedResponseTime\", expectedResponseTime);\n        return expectedResponseTime;\n    }\n\n    public Object doCall() {\n        return doCall(null);\n    }\n\n    public Matcher<Long> getMatcher() {\n        return matcher.get();\n    }\n\n    public TimeUnit getTimeUnit() {\n        return timeUnit.get();\n    }\n\n    static Class<?> class$(String className) {\n        try {\n            return Class.forName(className);\n        } catch (ClassNotFoundException e) {\n            throw new NoClassDefFoundError(e.getMessage());\n        }\n    }\n}\nEOF\nGROOVY=/home/vjovanov/.gradle/caches/9.1.0/transforms/842073080d6f74abfc1619581e1498ec/transformed/original/groovy-3.0.9.jar\nHAM=/home/vjovanov/.gradle/caches/modules-2/files-2.1/org.hamcrest/hamcrest/2.1/9420ba32c29217b54eebd26ff7f9234d31c3fbb2/hamcrest-2.1.jar\njavac --release 8 -cp \"$GROOVY:$HAM\" -d /tmp/ra-time-closure/classes '/tmp/ra-time-closure/io/restassured/internal/ResponseSpecificationImpl$_time_closure2.java'\nbase64 -w0 '/tmp/ra-time-closure/classes/io/restassured/internal/ResponseSpecificationImpl$_time_closure2.class'\n", "timeout": 30}}], "api": "openai-re