  package io_rest_assured.rest_assured;
  
  import io.restassured.filter.time.TimingFilter;
  import io.restassured.internal.RestAssuredResponseOptionsGroovyImpl;
  import org.junit.jupiter.api.Test;
  
  import java.util.Map;
  import java.util.concurrent.TimeUnit;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class RestAssuredResponseOptionsGroovyImplTest {
      @Test
      void convertsRecordedResponseTimeToRequestedUnit() {
          RestAssuredResponseOptionsGroovyImpl responseOptions = new RestAssuredResponseOptionsGroovyImpl();
          responseOptions.setFilterContextProperties(Map.of(TimingFilter.RESPONSE_TIME_MILLISECONDS, 2_000L));
  
          assertEquals(2L, responseOptions.timeIn(TimeUnit.SECONDS));
          assertEquals(2_000L, responseOptions.timeIn(TimeUnit.MILLISECONDS));
