wText": "    private static final String SIMPLE_SCHEMA = \"\"\"\n            <xs:schema xmlns:xs=\"http://www.w3.org/2001/XMLSchema\">\n                <xs:element name=\"person\" type=\"personType\"/>\n                <xs:complexType name=\"personType\">\n                    <xs:sequence>\n                        <xs:element name=\"name\" type=\"xs:string\"/>\n                    </xs:sequence>\n                </xs:complexType>\n            </xs:schema>\n            \"\"\";\n\n    private static final String MAIN_SCHEMA = \"\"\"\n            <xs:schema xmlns:xs=\"http://www.w3.org/2001/XMLSchema\">\n                <xs:include schemaLocation=\"person-types.xsd\"/>\n                <xs:element name=\"person\" type=\"personType\"/>\n            </xs:schema>\n            \"\"\";\n\n    private static final String INCLUDED_SCHEMA = \"\"\"\n            <xs:schema xmlns:xs=\"http://www.w3.org/2001/XMLSchema\">\n                <xs:complexType name=\"personType\">\n                    <xs:sequence>\n                        <xs:element name=\"name\" type=\"xs:string\"/>\n                    </xs:sequence>\n                </xs:complexType>\n            </xs:schema>\n            \"\"\";\n"}, {"oldText": "    @Test\n    void resolvesClassThroughGeneratedGroovyClassLookup() throws Throwable {\n        Class<?> resolvedClass = invokeGeneratedClassLookup(XmlXsdMatcher.class.getName());\n\n        assertSame(XmlXsdMatcher.class, resolvedClass);\n    }\n\n    private static Class<?> invokeGeneratedClassLookup(String className) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(XmlXsdMatcher.class, MethodHandles.lookup());\n        MethodHandle classHelper = lookup.findStatic(\n                XmlXsdMatcher.class,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class));\n        return (Class<?>) classHelper.invokeExact(className);\n    }\n\n    private static final class StringLsInput implements LSInput {\n", "newText": "    @Test\n    void validatesXmlDocumentAgainstXsdMatcherFromReader() {\n        assertThat(XML, matchesXsd(new StringReader(SIMPLE_SCHEMA)));\n    }\n\n    @Test\n    void validatesXmlDocumentAgainstXsdMatcherFromFileAndUrl(@TempDir Path tempDir) throws IOException {\n        Path schema = tempDir.resolve(\"person.xsd\");\n        Files.writeString(schema, SIMPLE_SCHEMA, StandardCharsets.UTF_8);\n\n        assertThat(XML, matchesXsd(schema.toFile()));\n        assertThat(XML, matchesXsd(schema.toUri().toURL()));\n    }\n\n    @Test\n    void describesXsdExpectation() {\n        StringDescription description = new StringDescription();\n\n        matchesXsd(SIMPLE_SCHEMA).describeTo(description);\n\n        assertThat(description.toString(), is(\"the supplied XSD\"));\n    }\n\n    private static final class StringLsInput implements LSInput {\n"}]}
