[tool-call] delta {"path":"tests/src/io.rest-assured/rest-assured/5.5.0/src/test/java/io_rest_assured/rest_assured/RequestSpecificationImplInner_cookie_closure10Test.java","edits":[{"oldText":"import java.util.LinkedHashMap;\nimport java.util.Map;\n\n","newText":""},{"oldText":"    void sendsCookiesAddedFromMap() throws IOException {\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/cookies\", RequestSpecificationImplInner_cookie_closure10Test::echoCookieHeader);\n        server.start();\n        RestAssured.reset();\n\n        Map<String, String> cookies = new LinkedHashMap<>();\n        cookies.put(\"session\", \"abc123\");\n        cookies.put(\"theme\", \"dark\");\n\n        try {\n            Response response = RestAssured\n                    .given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .cookies(cookies)\n                    .when()\n                    .get(\"/cookies\");\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString())\n                    .contains(\"session=abc123\")\n                    .contains(\"theme=dark\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n","newText":"    void sendsAdditionalCookieValuesAddedThroughVarargs() throws IOException {\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/cookies\", RequestSpecificationImplInner_cookie_closure10Test::echoCookieHeader);\n        server.start();\n        RestAssured.reset();\n\n        try {\n            Response response = RestAssured\n                    .given()\n                    .baseUri(\"http://127.0.0.1\")\n                    .port(server.getAddress().getPort())\n                    .cookie(\"flavor\", \"vanilla\", \"chocolate\")\n                    .when()\n                    .get(\"/cookies\");\n\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.asString())\n                    .contains(\"flavor=vanilla\")\n                    .contains(\"flavor=chocolate\");\n        } finally {\n            RestAssured.reset();\n            server.stop(0);\n        }\n    }\n"}]}
