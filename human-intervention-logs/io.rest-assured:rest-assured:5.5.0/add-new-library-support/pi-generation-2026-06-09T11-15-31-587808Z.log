  public class RestAssuredResponseOptionsGroovyImplInner_parseHeaders_closure1Test {
      private static final String CLOSURE_CLASS_NAME = "io.restassured.internal.RestAssuredResponseOptionsGroovyImpl"
              + "$_parseHeaders_closure1";
      private static final String METHOD_HANDLE_LOADED_CLASS_NAME = "io.restassured.http.Header";
