putValueSchema(modernConfiguration)).isEqualTo(INT_SCHEMA);\n        assertThat(org.apache.avro.hadoop.io.AvroSerialization.createDataModel(modernConfiguration))\n                .isInstanceOf(SpecificData.class);\n","newText":"\n        assertThat(org.apache.avro.mapred.AvroJob.createDataModel(legacyJob)).isInstanceOf(ReflectData.class);\n"},{"oldText":"        Configuration conf = new Configuration();\n","newText":"        Configuration conf = hadoopConfiguration();\n"},{"oldText":"        Configuration conf = new Configuration();\n        FileSystem fileSystem = FileSystem.get(conf);\n","newText":"        Configuration conf = hadoopConfiguration();\n        FileSystem fileSystem = FileSystem.get(conf);\n"}]}
