              }
              assertThat(entries).containsExactly("apple=Apple", "banana=Banana", "carrot=Carrot", "durian=Durian");
          }
  
          SortedKeyValueFile.Writer.Options outOfOrderOptions = new SortedKeyValueFile.Writer.Options()
