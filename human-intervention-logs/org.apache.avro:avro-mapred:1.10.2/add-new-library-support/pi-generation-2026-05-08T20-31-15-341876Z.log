        assertNotNull(value);
        assertEquals(1, value.datum().intValue());
  
        // Read the second record.
        key = (AvroKey<CharSequence>) reader.next(key);
        assertNotNull(key);
        assertEquals("two", key.datum().toString());
        value = (AvroValue<Integer>) reader.getCurrentValue(value);
