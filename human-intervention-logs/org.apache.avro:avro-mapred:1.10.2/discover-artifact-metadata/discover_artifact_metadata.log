metadata/org.codehaus.mojo/animal-sniffer-annotations/index.json:9:    "description" : "Animal Sniffer Annotations provides Java annotations that mark APIs Animal Sniffer should ignore when checking JRE compatibility. It is used to selectively suppress compatibility checks for classes, methods, or constructors that intentionally reference newer platform APIs.",
metadata/org.codehaus.mojo/animal-sniffer-annotations/index.json:27:    "description" : "Animal Sniffer Annotations provides Java annotations for marking code that Animal Sniffer should ignore when checking JRE API compatibility. It is typically used to annotate methods, constructors, or types that intentionally reference newer JRE APIs while preserving compatibility checks for the rest of the codebase.",
metadata/org.eclipse.sisu/org.eclipse.sisu.inject/index.json:9:    "description" : "Eclipse Sisu Inject is a JSR-330 dependency injection container built on Google Guice that supports classpath scanning, auto-binding, and dynamic auto-wiring. It lets applications discover named components and wire missing dependencies without requiring explicit Guice module bindings for every component.",
metadata/com.typesafe.play/play-functional_2.13/index.json:9:    "description" : "Play Functional provides the Scala functional-programming building blocks used by Play JSON, including functors, applicatives, monoids, reducers, and product builders. It lets Scala applications compose validation, reading, and writing logic through Play's play.api.libs.functional APIs.",
