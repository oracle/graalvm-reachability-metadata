metadata/com.github.javaparser/javaparser-core/index.json:10:    "description" : "JavaParser parses Java source code and builds an abstract syntax tree that applications can inspect and transform. The core artifact provides the parser and AST model without the optional symbol solver.",
metadata/com.github.javaparser/javaparser-core/index.json:25:    "description" : "JavaParser parses Java source code and builds an abstract syntax tree that applications can inspect and transform. The core artifact provides the parser and AST model without the optional symbol solver.",
