metadata/org.apache.activemq/activemq-client/index.json:9:    "description" : "Apache ActiveMQ Client is the Java client library for Apache ActiveMQ Classic. It provides the Jakarta Messaging (JMS) client and transport classes applications use to connect to brokers and send or receive messages.",
