          @Override
          public int hashCode() {
              int nameHashCode = (127 * "name".hashCode()) ^ name.hashCode();
              int priorityHashCode = (127 * "priority".hashCode()) ^ Integer.valueOf(priority).hashCode();
              return nameHashCode + priorityHashCode;
          }
      }
  }
