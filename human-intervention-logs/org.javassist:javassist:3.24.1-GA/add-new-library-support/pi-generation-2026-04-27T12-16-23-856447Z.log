sources()).contains(FIXTURE_RESOURCE_NAME);\n        } finally {\n            repository.unregisterClassLoader(classLoader);\n        }\n    }\n\n    public static class ScopedPoolFixture {\n    }\n\n    private static class TrackingResourceClassLoader extends ClassLoader {\n        private final List<String> requestedResources = new ArrayList<>();\n\n        TrackingResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            requestedResources.add(name);\n            return super.getResource(name);\n        }\n\n        List<String> requestedResources() {\n            return requestedResources;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1364, "output": 849, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 24741, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777292123072, "responseId": "resp_022b8a2c56845dd80169ef535b856c8196813706357184043f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wxZXStxz2q2ERDWPxafiIQFk|fc_022b8a2c56845dd80169ef53633cec8196aa061f54062135b7", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2098 bytes to tests/src/org.javassist/javassist/3.24.1-GA/src/test/java/org_javassist/javassist/ScopedClassPoolTest.java"}], "isError": false, "timestamp": 1777292134365}]}
