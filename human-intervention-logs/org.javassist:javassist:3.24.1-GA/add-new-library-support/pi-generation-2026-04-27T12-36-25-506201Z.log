      {
          if (System.getSecurityManager() == null)
              return clazz.getDeclaredConstructor(types);
          else {
              try {
                  return AccessController.doPrivileged(
                      new PrivilegedExceptionAction<Constructor<?>>() {
                          public Constructor<?> run() throws Exception {
