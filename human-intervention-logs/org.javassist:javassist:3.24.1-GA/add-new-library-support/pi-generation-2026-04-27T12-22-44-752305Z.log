ct {\n        String message();\n    }\n\n    private static final class IsolatedDefinitionClassLoader extends ClassLoader {\n        private IsolatedDefinitionClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1146, "output": 2144, "cacheRead": 38400, "cacheWrite": 0, "totalTokens": 41690, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777292656435, "responseId": "resp_067293e447af4bdf0169ef5570ff28819ca4aa89986cc796d9"}}
