  package org_javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.Serializable;
  import java.lang.reflect.Method;
  
  import javassist.util.proxy.MethodHandler;
  import javassist.util.proxy.ProxyObjectInputStream;
  import javassist.util.proxy.ProxyObjectOutputStream;
  import javassist.util.proxy.ProxyFactory;
  
  import org.junit.jupiter.api.Test;
  
  public class ProxyObjectInputStreamTest {
      @Test
      void deserializesProxyDescriptorWithSuperclassAndInterfaceNames() throws Exception {
          byte[] serializedProxy = serializeWithProxyDescriptors(ProxyFixture.proxyInstance());
  
          Object deserializedProxy = deserializeWithProxyDescriptors(serializedProxy);
  
          assertThat(deserializedProxy).isInstanceOf(GreetingService.class).isInstanceOf(GreetingOperations.class);
          assertThat(deserializedProxy.getClass()).isSameAs(ProxyFixture.proxyClass());
          assertThat(((GreetingOperations) deserializedProxy).greet("native")).isEqualTo("handled:native");
      }
  
      private static byte[] serializeWithProxyDescriptors(Object object) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ProxyObjectOutputStream output = new ProxyObjectOutputStream(bytes)) {
              output.writeObject(object);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserializeWithProxyDescriptors(byte[] bytes) throws Exception {
          try (ProxyObjectInputStream input = new ProxyObjectInputStream(new ByteArrayInputStream(bytes))) {
              input.setClassLoader(ProxyObjectInputStreamTest.class.getClassLoader());
              return input.readObject();
          }
      }
  
      public interface GreetingOperations extends Serializable {
          String greet(String recipient);
      }
  
      public static class GreetingService implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String prefix;
  
          public GreetingService(String prefix) {
              this.prefix = prefix;
          }
  
          public String greet(String recipient) {
              return prefix + ":" + recipient;
          }
      }
  
      private static final class ProxyFixture {
          private static final Class<?> PROXY_CLASS;
          private static final Object PROXY_INSTANCE;
  
          static {
              try {
                  ProxyFactory factory = proxyFactory();
                  PROXY_CLASS = factory.createClass();
                  PROXY_INSTANCE = factory.create(new Class<?>[] {String.class}, new Object[] {"service"},
                                  new SerializableGreetingHandler("handled"));
              } catch (ReflectiveOperationException ex) {
                  throw new ExceptionInInitializerError(ex);
              }
          }
  
          private static Class<?> proxyClass() {
              return PROXY_CLASS;
          }
  
          private static Object proxyInstance() {
              return PROXY_INSTANCE;
          }
  
          private static ProxyFactory proxyFactory() {
              ProxyFactory factory = new ProxyFactory();
              factory.setUseCache(true);
              factory.setUseWriteReplace(false);
              factory.setSuperclass(GreetingService.class);
              factory.setInterfaces(new Class<?>[] {GreetingOperations.class});
              factory.setFilter(method -> method.getName().equals("greet"));
              return factory;
          }
      }
  
      public static class SerializableGreetingHandler implements MethodHandler, Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String prefix;
  
          public SerializableGreetingHandler(String prefix) {
              this.prefix = prefix;
          }
  
          @Override
          public Object invoke(Object self, Method thisMethod, Method proceed, Object[] args) {
              return prefix + ":" + args[0];
          }
      }
  }
