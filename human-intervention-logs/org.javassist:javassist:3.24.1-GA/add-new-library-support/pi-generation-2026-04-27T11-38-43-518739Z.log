      void exercisesJava9HelperInIsolatedJavassistRuntime() throws Exception {
          try (Java9JavassistLoader loader = new Java9JavassistLoader()) {
              Callable<?> invocation = loader.loadClass(IsolatedInvocation.class.getName())
                      .asSubclass(Callable.class)
