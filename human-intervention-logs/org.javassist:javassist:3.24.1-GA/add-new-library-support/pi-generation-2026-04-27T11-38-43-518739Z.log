  package org_javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import javassist.ClassPool;
  import javassist.CtClass;
  
  import org.junit.jupiter.api.Test;
  
  public class DefineClassHelperJava9Test {
      @Test
      void definesGeneratedClassWithNeighborAwareClassPoolApi() throws Exception {
          ClassPool classPool = classPool();
          CtClass generatedClass = generatedClass(classPool, "NeighborAware");
  
          try {
              assertGeneratedClass(classPool.toClass(
                      generatedClass,
                      DefineClassHelperJava9Test.class,
                      DefineClassHelperJava9Test.class.getClassLoader(),
                      DefineClassHelperJava9Test.class.getProtectionDomain()));
          } finally {
              generatedClass.detach();
          }
      }
  
      @Test
      void definesGeneratedClassWithLegacyClassLoaderApi() throws Exception {
          ClassPool classPool = classPool();
          CtClass generatedClass = generatedClass(classPool, "LegacyClassLoader");
  
          try {
              assertGeneratedClass(classPool.toClass(
                      generatedClass,
                      null,
                      DefineClassHelperJava9Test.class.getClassLoader(),
                      DefineClassHelperJava9Test.class.getProtectionDomain()));
          } finally {
              generatedClass.detach();
          }
      }
  
      private static ClassPool classPool() {
          ClassPool classPool = new ClassPool(false);
          classPool.appendSystemPath();
          return classPool;
      }
  
      private static CtClass generatedClass(ClassPool classPool, String testCase) {
          String packageName = DefineClassHelperJava9Test.class.getPackage().getName();
          String className = packageName + ".DefineClassHelperJava9" + testCase + System.nanoTime();
          return classPool.makeClass(className);
      }
  
      private static void assertGeneratedClass(Class<?> loadedClass) {
          assertThat(loadedClass.getName()).startsWith(
                  DefineClassHelperJava9Test.class.getPackage().getName() + ".DefineClassHelperJava9");
          assertThat(loadedClass.getPackage()).isEqualTo(DefineClassHelperJava9Test.class.getPackage());
          assertThat(loadedClass.getClassLoader()).isSameAs(DefineClassHelperJava9Test.class.getClassLoader());
      }
  }
