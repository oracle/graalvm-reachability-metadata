      private static CtClass generatedClass(ClassPool classPool, String testCase) {
          String packageName = DefineClassHelperJava9Test.class.getPackage().getName();
          String className = packageName + ".DefineClassHelperJava9" + testCase + System.nanoTime();
          return classPool.makeClass(className);
      }
  
      private static void assertGeneratedClass(Class<?> loadedClass) {
          assertThat(loadedClass.getName()).startsWith(
                  DefineClassHelperJava9Test.class.getPackage().getName() + ".DefineClassHelperJava9");
          assertThat(loadedClass.getPackage()).isEqualTo(DefineClassHelperJava9Test.class.getPackage());
          assertThat(loadedClass.getClassLoader()).isSameAs(DefineClassHelperJava9Test.class.getClassLoader());
