[tool-call] delta {"path":"tests/src/org.javassist/javassist/3.24.1-GA/src/test/java/org_javassist/javassist/DefineClassHelperJava9Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport javassist.ClassPool;\nimport javassist.CtClass;\n\nimport org.junit.jupiter.api.Test;\n\npublic class DefineClassHelperJava9Test {\n    @Test\n    void definesGeneratedClassWithNeighborAwareClassPoolApi() throws Exception {\n        String generatedClassName = DefineClassHelperJava9Test.class.getPackage().getName()\n                + \".DefineClassHelperJava9Generated\" + System.nanoTime();\n        ClassPool classPool = new ClassPool(false);\n        classPool.appendSystemPath();\n        CtClass generatedClass = classPool.makeClass(generatedClassName);\n\n        try {\n            Class<?> loadedClass = classPool.toClass(\n                    generatedClass,\n                    DefineClassHelperJava9Test.class,\n                    DefineClassHelperJava9Test.class.getClassLoader(),\n                    DefineClassHelperJava9Test.class.getProtectionDomain());\n\n            assertThat(loadedClass.getName()).isEqualTo(generatedClassName);\n            assertThat(loadedClass.getPackage().getName()).isEqualTo(DefineClassHelperJava9Test.class.getPackage().getName());\n            assertThat(loadedClass.getClassLoader()).isSameAs(DefineClassHelperJava9Test.class.getClassLoader());\n        } finally {\n            generatedClass.detach();\n        }\n    }\n}\n"}
