  DefineClassHelperJava9Test.class.getProtectionDomain()));\n        } finally {\n            generatedClass.detach();\n        }\n    }\n\n    @Test\n    void exercisesJava9HelperInIsolatedJavassistRuntime() throws Exception {\n        try (Java9JavassistLoader loader = new Java9JavassistLoader()) {\n            Callable<?> invocation = loader.loadClass(IsolatedInvocation.class.getName())\n                    .asSubclass(Callable.class)\n                    .getDeclaredConstructor()\n                    .newInstance();\n\n            assertThat(invocation.call()).isEqualTo(IsolatedInvocation.TEMPLATE_CLASS_NAME);\n        }\n    }\n\n    private static ClassPool classPool() {\n"}, {"oldText": "    private static void assertGeneratedClass(Class<?> loadedClass) {\n        assertThat(loadedClass.getName()).startsWith(\n                DefineClassHelperJava9Test.class.getPackage().getName() + \".DefineClassHelperJava9\");\n        assertThat(loadedClass.getPackage()).isEqualTo(DefineClassHelperJava9Test.class.getPackage());\n        assertThat(loadedClass.getClassLoader()).isSameAs(DefineClassHelperJava9Test.class.getClassLoader());\n    }\n}\n", "newText": "    private static void assertGeneratedClass(Class<?> loadedClass) {\n        assertThat(loadedClass.getName()).startsWith(\n                DefineClassHelperJava9Test.class.getPackage().getName() + \".DefineClassHelperJava9\");\n        assertThat(loadedClass.getPackage()).isEqualTo(DefineClassHelperJava9Test.class.getPackage());\n        assertThat(loadedClass.getClassLoader()).isSameAs(DefineClassHelperJava9Test.class.getClassLoader());\n    }\n\n    public static class IsolatedInvocation implements Callable<String> {\n        private static final String TEMPLATE_CLASS_NAME =\n                \"org_javassist.javassist.DefineClassHelperJava9Test$TemplateClass\";\n\n        @Override\n        public String call() throws Exception {\n            byte[] bytecode = Java9JavassistLoader.readClassBytes(TEMPLATE_CLASS_NAME);\n            Class<?> loadedClass = javassist.util.proxy.DefineClassHelper.toClass(\n                    TEMPLATE_CLASS_NAME,\n                    null,\n                    IsolatedInvocation.class.getClassLoader(),\n                    IsolatedInvocation.class.getProtectionDomain(),\n                    bytecode);\n            return loadedClass.getName();\n        }\n    }\n\n    public static class TemplateClass {\n    }\n\n    public static class FakeUnsafe {\n        public Class<?> defineClass(String name, byte[] bytecode, int offset, int length,\n                ClassLoader loader, ProtectionDomain protectionDomain) {\n            return TemplateClass.class;\n        }\n    }\n\n    private static class Java9JavassistLoader extends ClassLoader implements AutoCloseable {\n        private static final String CLASS_FILE = \"javassist.bytecode.ClassFile\";\n        private static final String SECURITY_ACTIONS = \"javassist.util.proxy.SecurityActions\";\n        private static final String FAKE_UNSAFE = DefineClassHelperJava9Test.FakeUnsafe.class.getName();\n        private static final String ISOLATED_INVOCATION = IsolatedInvocation.class.getName();\n        private final Map<String, byte[]> definitions = new HashMap<>();\n\n        Java9JavassistLoader() throws Exception {\n            super(DefineClassHelperJava9Test.class.getClassLoader());\n            definitions.put(CLASS_FILE, java10ClassFileBytes());\n            definitions.put(SECURITY_ACTIONS, securityActionsUsingFakeUnsafeBytes());\n            definitions.put(FAKE_UNSAFE, readClassBytes(FAKE_UNSAFE));\n            definitions.put(ISOLATED_INVOCATION, readClassBytes(ISOLATED_INVOCATION));\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && shouldLoadLocally(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        loadedClass = null;\n                    }\n                }\n                if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            byte[] bytecode = definitions.get(name);\n            if (bytecode == null && name.startsWith(\"javassist.\")) {\n                bytecode = readClassBytes(name);\n            }\n            if (bytecode == null) {\n                throw new ClassNotFoundException(name);\n            }\n            return defineClass(name, bytecode, 0, bytecode.length);\n        }\n\n        @Override\n        public void close() {\n            definitions.clear();\n        }\n\n        private static boolean shouldLoadLocally(String name) {\n            return definitionsClassName(name) || name.startsWith(\"javassist.\");\n        }\n\n        private static boolean definitionsClassName(String name) {\n            return ISOLATED_INVOCATION.equals(name) || FAKE_UNSAFE.equals(name);\n        }\n\n        private static byte[] java10ClassFileBytes() throws Exception {\n            ClassPool classPool = new ClassPool(false);\n            CtClass classFile = classPool.makeClass(CLASS_FILE);\n            classFile.addField(CtField.make(\"public static final int MAJOR_VERSION = 54;\", classFile));\n            try {\n                return classFile.toBytecode();\n            } finally {\n                classFile.detach();\n            }\n        }\n\n        private static byte[] securityActionsUsingFakeUnsafeBytes() throws Exception {\n            ClassPool classPool = new ClassPool(false);\n            classPool.appendClassPath(new LoaderClassPath(DefineClassHelperJava9Test.class.getClassLoader()));\n            CtClass securityActions = classPool.get(SECURITY_ACTIONS);\n            securityActions.getDeclaredMethod(\"getSunMiscUnsafeAnonymously\").setBody(\n                    \"{ return stack.new TheUnsafe(\" + FAKE_UNSAFE + \".class, new \" + FAKE_UNSAFE + \"()); }\");\n            try {\n                return securityActions.toBytecode();\n            } finally {\n                securityActions.detach();\n            }\n        }\n\n        private static byte[] readClassBytes(String className) throws IOException {\n            String resourceName = className.replace('.', '/') + \".class\";\n            try (InputStream input = DefineClassHelperJava9Test.class.getClassLoader()\n                    .getResourceAsStream(resourceName)) {\n                if (input == null) {\n                    throw new IOException(\"Missing class resource: \" + resourceName);\n                }\n                ByteArrayOutputStream output = new ByteArrayOutputStream();\n                byte[] buffer = new byte[4096];\n                int read;\n                while ((read = input.read(buffer)) != -1) {\n                    output.write(buffer, 0, read);\n                }\n                return output.toByteArray();\n            }\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1148, "output": 6961, "cacheRead": 39936, "cacheWrite": 0, "totalTokens": 48045, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777290206707, "responseId": "resp_017e1b0f0ac28b3b0169ef4bdf4604819f8cb975d93d7c0e19"}}
