      25	import java.util.Map;
      26	
      27	public class MapOrientedComponentConfigurator
      28	    extends AbstractComponentConfigurator
      29	{
      30	
      31	    public void configureComponent( Object component, PlexusConfiguration configuration,
      32	                                    ExpressionEvaluator expressionEvaluator, ClassRealm containerRealm,
      33	                                    ConfigurationListener listener )
      34	        throws ComponentConfigurationException
      35	    {
      36	        if ( !( component instanceof MapOrientedComponent ) )
      37	        {
      38	            throw new ComponentConfigurationException(
      39	                "This configurator can only process implementations of " + MapOrientedComponent.class.getName() );
      40	        }
      41	
      42	        MapConverter converter = new MapConverter();
      43	
      44	        Map context = (Map) converter.fromConfiguration( converterLookup, configuration, null, null,
      45	                                                         containerRealm, expressionEvaluator,
      46	                                                         listener );
      47	
      48	        ( (MapOrientedComponent) component ).setComponentConfiguration( context );
      49	    }
      50	
