                    <!-- force the doc-files directory to be copied -->
                    <docfilessubdirs>true</docfilessubdirs>
                    <javadocDirectory>${main.basedir}/activation/src/main/javadoc</javadocDirectory>
                    <detectJavaApiLink>false</detectJavaApiLink>
                </configuration>
            </plugin>
        </plugins>

        <pluginManagement>
	    <plugins>
		<plugin>
