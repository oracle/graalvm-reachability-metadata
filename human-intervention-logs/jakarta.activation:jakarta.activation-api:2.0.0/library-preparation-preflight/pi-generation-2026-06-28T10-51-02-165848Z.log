          <activation.moduleName>
              jakarta.activation
          </activation.moduleName>
          <activation.packages.export>
              jakarta.activation.*; version=${activation.spec.version},
  	    !com.sun.*
          </activation.packages.export>
          <activation.packages.import>
  	    !com.sun.*
          </activation.packages.import>
          <activation.bundle.symbolicName>
              jakarta.activation-api
          </activation.bundle.symbolicName>
      </properties>
      <build>
