Id>jakarta.activation</artifactId>\n                            <version>${project.version}</version>\n                        </artifactItem>\n                    </artifactItems>\n                    <outputDirectory>\n                        ${project.build.outputDirectory}\n                    </outputDirectory>\n\t\t    <!--\n\t\t\tInclude all the implementation source files so that\n\t\t\tjavadoc run as part of \"deploy\" will find all the\n\t\t\trequired classes.\n\n\t\t\tDon't include the metadata files from the original\n\t\t\tjar file.\n\t\t    -->\n\t\t    <excludes>\n\t\t\tMETA-INF/**\n\t\t    </excludes>\n                </configuration>\n            </plugin>\n\n\t    <!--\n\t\t Skip compiling since the dependency plugin pulled in\n\t\t the sources and class files.\n\t    -->\n\t    <plugin>\n\t\t<artifactId>maven-compiler-plugin</artifactId>\n\t\t<executions>\n\t\t    <execution>\n\t\t\t<id>default-compile</id>\n\t\t\t<configuration>\n\t\t\t    <skipMain>true</skipMain>\n\t\t\t</configuration>\n\t\t    </execution>\n\t\t</executions>\n\t    </plugin>\n\n\t    <!--\n\t\tDon't include the implementation classes in the jar files.\n\t    -->\n            <plugin>\n                <artifactId>maven-jar-plugin</artifactId>\n                <configuration>\n                    <finalName>${project.artifactId}</finalName>\n\t\t    <excludes>\n\t\t\t<exclude>com/**</exclude>\n\t\t    </excludes>\n              \n"}], "isError": false, "timestamp": 1782647296561}}
