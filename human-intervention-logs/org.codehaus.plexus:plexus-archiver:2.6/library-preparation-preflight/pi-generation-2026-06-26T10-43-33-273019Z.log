8\t\t * plexus-archiver chooses to round up.\n   109\t\t *\n   110\t\t * Java versions up to java7 round timestamp down, which means we add a heuristic value (which is slightly questionable)\n   111\t\t * Java versions from 8 and up round timestamp up.\n   112\t\t * s\n   113\t     */\n   114\t    private static final boolean isJava7OrLower = Integer.parseInt(System.getProperty(\"java.version\").split(\"\\\\.\")[1]) <= 7;\n   115\t\n   116\t\t// Renamed version of original file, if it exists\n   117\t    private File renamedFile = null;\n   118\t\n   119\t    private File zipFile;\n   120\t\n   121\t    private boolean success;\n   122\t\n   123\t    private ZipArchiveOutputStream zOut;\n   124\t\n   125\t    public String getComment()\n   126\t    {\n   127\t        return comment;\n   128\t    }\n   129\t\n   130\t    public void setComment( String comment )\n     1\tpackage org.codehaus.plexus.archiver.util;\n     2\t\n     3\timport org.codehaus.plexus.archiver.ArchiverException;\n     4\timport org.codehaus.plexus.components.io.attributes.Java7AttributeUtils;\n     5\timport org.codehaus.plexus.components.io.attributes.Java7Reflector;\n     6\timport org.codehaus.plexus.logging.Logger;\n     7\timport org.codehaus.plexus.util.Os;\n     8\timport org.codehaus.plexus.util.cli.CommandLineException;\n     9\timport org.codehaus.plexus.util.cli.CommandLineUtils;\n    10\timport org.codehaus.plexus.util.cli.Commandline;\n    11\t\n    12\timport java.io.File;\n    13\timport java.io.IOException;\n    14\timport java.lang.reflect.Method;\n    15\t\n    16\t@SuppressWarnings(\"JavaDoc\")\n    17\tpublic final class ArchiveEntryUtils\n    18\t{\n    19\t\n    20\t    public static boolean jvmFilePermAvailable;\n    21\t\n    22\t    static\n    23\t    {\n    24\t        try\n    25\t        {\n    26\t            jvmFilePermAvailable = File.class.getMethod( \"setReadable\", Boolean.TYPE) != null;\n    27\t        }\n    28\t        catch ( final Exception e )\n    29\t        {\n    30\t            // ignore exception log this ?\n    31\t        }\n    32\t    }\n    33\t\n    34\t    private ArchiveEntryUtils()\n    35\t    {\n    36\t        // no op\n    37\t    }\n    38\t\n    39\t    /**\n    40\t     * @since 1.1\n    41\t     * @param file\n    42\t     * @param mode\n    43\t     * @param logger\n    44\t     * @param useJvmChmod\n    45\t     *            will use jvm file permissions <b>not available for group level</b>\n    46\t     * @throws ArchiverException\n    47\t     */\n    48\t    public static void chmod( final File file, final int mode, final Logger logger, boolean useJvmChmod )\n    49\t        throws ArchiverException\n    50\t    {\n    51\t        if ( !Os.isFamily( Os.FAMILY_UNIX ) )\n    52\t        {\n    53\t            return;\n    54\t        }\n    55\t\n    56\t\t\tif (Java7Reflector.isAtLeastJava7())\n    57\t\t\t{\n    58\t\t\t\ttry\n    59\t\t\t\t{\n    60\t\t\t\t\tJava7AttributeUtils.chmod(file, mode);\n    61\t\t\t\t\treturn;\n    62\t\t\t\t} catch (IOException e)\n    63\t\t\t\t{\n    64\t\t\t\t\tthrow new ArchiverException(\"Failed setting file attributes with java7+\", e);\n    65\t\t\t\t}\n    66\t\t\t}\n    67\t\n    68\t        final String m = Integer.toOctalString( mode & 0xfff );\n    69\t\n    70\t        if ( useJvmChmod && !jvmFilePermAvailable )\n    71\t        {\n    72\t            useJvmChmod = false;\n    73\t        }\n    74\t\n    75\t        if (useJvmChmod)\n    76\t        {\n    77\t            applyPermissionsWithJvm( file, m, logger );\n    78\t            return;\n    79\t        }\n    80\t\n    81\t        try\n    82\t        {\n    83\t            final Commandline commandline = new Commandline();\n    84\t\n    85\t            commandline.setWorkingDirectory( file.getParentFile().getAbsolutePath() );\n    86\t\n    87\t            if ( logger.isDebugEnabled() )\n    88\t            {\n    89\t                logger.debug( file + \": mode \" + Integer.toOctalString( mode ) + \", chmod \" + m );\n    90\t            }\n    91\t\n    92\t            commandline.setExecutable( \"chmod\" );\n    93\t\n    94\t            commandline.createArg().setValue( m );\n    95\t\n    96\t            final String path = file.getAbsolutePath();\n    97\t\n    98\t            commandline.createArg().setValue( path );\n    99\t\n   100\t            // commenting this debug statement, since it can produce VERY verbose output...\n   101\t            // this method is called often during archive creation.\n   102\t            // logger.debug( \"Executing:\\n\\n\" + commandline.toString() + \"\\n\\n\" );\n   103\t\n   104\t            final CommandLineUtils.StringStreamConsumer stderr = new CommandLineUtils.StringStreamConsumer();\n   105\t\n   106\t            final CommandLineUtils.StringStreamConsumer stdout = new CommandLineUtils.StringStreamConsumer();\n   107\t\n   108\t            final int exitCode = CommandLineUtils.executeCommandLine( commandline, stderr, stdout );\n   109\t\n   110\t            if ( exitCode != 0 )\n   111\t            {\n   112\t                logger.warn( \"-------------------------------\" );\n   113\t                logger.warn( \"Standard error:\" );\n   114\t                logger.warn( \"-------------------------------\" );\n   115\t                logger.warn( stderr.getOutput() );\n   116\t                logger.warn( \"-------------------------------\" );\n   117\t                logger.warn( \"Standard output:\" );\n   118\t                logger.warn( \"-------------------------------\" );\n   119\t                logger.warn( stdout.getOutput() );\n   120\t                logger.warn( \"-------------------------------\" );\n   121\t\n   122\t                throw new ArchiverException( \"chmod exit code was: \" + exitCode );\n   123\t            }\n   124\t        }\n   125\t        catch ( final CommandLineException e )\n   126\t        {\n   127\t            throw new ArchiverException( \"Error while executing chmod.\", e );\n   128\t        }\n   129\t\n   130\t    }\n   131\t\n   132\t    /**\n   133\t     * <b>jvm chmod will be used only if System property <code>useJvmChmod</code> set to true</b>\n   134\t     * \n   135\t     * @param file\n   136\t     * @param mode\n   137\t     * @param logger\n   138\t     * @throws ArchiverException\n   139\t     */\n   140\t    public static void chmod( final File file, final int mode, final Logger logger )\n   141\t        throws ArchiverException\n   142\t    {\n   143\t        chmod( file, mode, logger, Boolean.getBoolean( \"useJvmChmod\" ) && jvmFilePermAvailable );\n   144\t    }\n   145\t\n   146\t    private static void applyPermissionsWithJvm( final File file, final String mode, final Logger logger )\n   147\t        throws ArchiverException\n   148\t    {\n   149\t        final FilePermission filePermission = FilePermissionUtils.getFilePermissionFromMode( mode, logger );\n   150\t\n   151\t        Method method;\n   152\t        try\n   153\t        {\n   154\t            method = File.class.getMethod( \"setReadable\", Boolean.TYPE, Boolean.TYPE);\n   155\t\n   156\t            method.invoke( file,\n   157\t\t\t\t\t\tfilePermission.isReadable(),\n   158\t\t\t\t\t\tfilePermission.isOwnerOnlyReadable());\n   159\t\n   160\t            method = File.class.getMethod( \"setExecutable\", Boolean.TYPE, Boolean.TYPE);\n   161\t            method.invoke( file,\n   162\t\t\t\t\t\tfilePermission.isExecutable(),\n   163\t\t\t\t\t\tfilePermission.isOwnerOnlyExecutable());\n   164\t\n   165\t            method = File.class.getMethod( \"setWritable\", Boolean.TYPE, Boolean.TYPE);\n   166\t            method.invoke( file,\n   167\t\t\t\t\t\tfilePermission.isWritable(),\n   168\t\t\t\t\t\tfilePermission.isOwnerOnlyWritable());\n   169\t        }\n   170\t        catch ( final Exception e )\n"}], "isError": false, "timestamp": 1782470556759}]}
