  package org_springframework_kafka.spring_kafka;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Method;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.aop.framework.ProxyFactory;
  import org.springframework.context.support.GenericApplicationContext;
  import org.springframework.kafka.annotation.KafkaListener;
  import org.springframework.kafka.annotation.KafkaListenerAnnotationBeanPostProcessor;
  import org.springframework.kafka.config.MethodKafkaListenerEndpoint;
  import org.springframework.kafka.support.TopicPartitionOffset;
  
  public class KafkaListenerAnnotationBeanPostProcessorTest {
  
      @Test
      void resolvesKafkaListenerMethodFromJdkProxyInterface() throws NoSuchMethodException {
          try (GenericApplicationContext context = new GenericApplicationContext()) {
              context.refresh();
              CapturingKafkaListenerAnnotationBeanPostProcessor processor =
                      new CapturingKafkaListenerAnnotationBeanPostProcessor();
              processor.setBeanFactory(context.getBeanFactory());
              ListenerContract proxy = createJdkProxy(new ListenerTarget());
  
              Object processed = processor.postProcessAfterInitialization(proxy, "listenerTarget");
  
              assertThat(processed).isSameAs(proxy);
              assertThat(processor.invocations).hasValue(1);
              assertThat(processor.capturedMethod).isEqualTo(ListenerContract.class.getMethod("listen", String.class));
          }
      }
  
      private static ListenerContract createJdkProxy(ListenerTarget target) {
          ProxyFactory proxyFactory = new ProxyFactory(target);
          proxyFactory.setInterfaces(ListenerContract.class);
          return (ListenerContract) proxyFactory.getProxy();
      }
  
      public interface ListenerContract {
  
          void listen(String payload);
      }
  
      public static final class ListenerTarget implements ListenerContract {
  
          @Override
          @KafkaListener(id = "proxiedListener", topics = "orders")
          public void listen(String payload) {
          }
      }
  
      private static final class CapturingKafkaListenerAnnotationBeanPostProcessor
              extends KafkaListenerAnnotationBeanPostProcessor<Object, Object> {
  
          private final AtomicInteger invocations = new AtomicInteger();
  
          private Method capturedMethod;
  
          @Override
          protected void processListener(MethodKafkaListenerEndpoint<?, ?> endpoint, KafkaListener kafkaListener,
                  Object bean, String beanName, String[] topics, TopicPartitionOffset[] tps) {
  
              this.invocations.incrementAndGet();
              this.capturedMethod = endpoint.getMethod();
              assertThat(bean).isInstanceOf(ListenerContract.class);
              assertThat(beanName).isEqualTo("listenerTarget");
              assertThat(kafkaListener.id()).isEqualTo("proxiedListener");
              assertThat(topics).containsExactly("orders");
              assertThat(tps).isEmpty();
          }
      }
  }
