  				.getBeansOfType(RetryTopicConfiguration.class);
  		return retryTopicProcessors
  				.values()
  				.stream()
  				.filter(topicConfiguration -> topicConfiguration.hasConfigurationForTopics(topics))
  				.findFirst()
  				.orElse(null);
