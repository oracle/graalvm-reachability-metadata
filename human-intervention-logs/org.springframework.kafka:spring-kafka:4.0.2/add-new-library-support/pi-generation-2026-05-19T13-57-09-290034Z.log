[tool-call] delta {"path":"tests/src/org.springframework.kafka/spring-kafka/4.0.2/src/test/java/org_springframework_kafka/spring_kafka/DelegatingDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_kafka.spring_kafka;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.charset.StandardCharsets;\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport org.apache.kafka.common.header.Headers;\nimport org.apache.kafka.common.header.internals.RecordHeaders;\nimport org.apache.kafka.common.serialization.Deserializer;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.kafka.support.serializer.DelegatingDeserializer;\nimport org.springframework.kafka.support.serializer.DelegatingSerializer;\n\npublic class DelegatingDeserializerTest {\n\n    private static final AtomicInteger CONSTRUCTIONS = new AtomicInteger();\n\n    private static final AtomicInteger CONFIGURATIONS = new AtomicInteger();\n\n    @Test\n    void configuresDelegateFromSelectorMappingClass() {\n        CONSTRUCTIONS.set(0);\n        CONFIGURATIONS.set(0);\n        DelegatingDeserializer deserializer = new DelegatingDeserializer();\n        Map<String, Object> configs = new HashMap<>();\n        configs.put(DelegatingSerializer.VALUE_SERIALIZATION_SELECTOR_CONFIG,\n                Map.of(\"text\", RecordingDeserializer.class));\n\n        deserializer.configure(configs, false);\n        Headers headers = new RecordHeaders()\n                .add(DelegatingSerializer.VALUE_SERIALIZATION_SELECTOR, \"text\".getBytes(StandardCharsets.UTF_8));\n        Object result = deserializer.deserialize(\"orders\", headers, \"accepted\".getBytes(StandardCharsets.UTF_8));\n\n        assertThat(result).isEqualTo(\"orders:accepted\");\n        assertThat(CONSTRUCTIONS).hasValue(1);\n        assertThat(CONFIGURATIONS).hasValue(1);\n        deserializer.close();\n    }\n\n    public static class RecordingDeserializer implements Deserializer<String> {\n\n        public RecordingDeserializer() {\n            CONSTRUCTIONS.incrementAndGet();\n        }\n\n        @Override\n        public void configure(Map<String, ?> configs, boolean isKey) {\n            assertThat(isKey).isFalse();\n            assertThat(configs).containsKey(DelegatingSerializer.VALUE_SERIALIZATION_SELECTOR_CONFIG);\n            CONFIGURATIONS.incrementAndGet();\n        }\n\n        @Override\n        public String deserialize(String topic, byte[] data) {\n            return topic + \":\" + new String(data, StandardCharsets.UTF_8);\n        }\n\n        @Override\n        public String deserialize(String topic, Headers headers, byte[] data) {\n            assertThat(headers.lastHeader(DelegatingSerializer.VALUE_SERIALIZATION_SELECTOR)).isNotNull();\n            return deserialize(topic, data);\n        }\n    }\n}\n"}
