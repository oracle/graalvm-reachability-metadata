upport.serializer.FailedDeserializationInfo;\nimport org.springframework.validation.Errors;\nimport org.springframework.validation.Validator;\n\npublic class ErrorHandlingDeserializerTest {\n\n    private static final AtomicInteger DELEGATE_CONSTRUCTIONS = new AtomicInteger();\n\n    private static final AtomicInteger FUNCTION_CONSTRUCTIONS = new AtomicInteger();\n\n    private static final AtomicInteger VALIDATOR_CONSTRUCTIONS = new AtomicInteger();\n\n    @Test\n    void configureCreatesDelegateFunctionAndValidatorFromConfiguredClasses() {\n        DELEGATE_CONSTRUCTIONS.set(0);\n        FUNCTION_CONSTRUCTIONS.set(0);\n        VALIDATOR_CONSTRUCTIONS.set(0);\n        Map<String, Object> configs = Map.of(\n                ErrorHandlingDeserializer.VALUE_DESERIALIZER_CLASS, FailingDeserializer.class,\n                ErrorHandlingDeserializer.VALUE_FUNCTION, RecoveryFunction.class,\n                ErrorHandlingDeserializer.VALIDATOR_CLASS, AcceptingValidator.class);\n        ErrorHandlingDeserializer<String> deserializer = new ErrorHandlingDeserializer<>();\n\n        deserializer.configure(configs, false);\n        Headers headers = new RecordHeaders();\n        String result = deserializer.deserialize(\"orders\", headers, \"bad\".getBytes(StandardCharsets.UTF_8));\n\n        assertThat(result).isEqualTo(\"orders:value:bad\");\n        assertThat(headers.lastHeader(KafkaUtils.VALUE_DESERIALIZER_EXCEPTION_HEADER)).isNotNull();\n        assertThat(DELEGATE_CONSTRUCTIONS).hasValue(1);\n        assertThat(FUNCTION_CONSTRUCTIONS).hasValue(1);\n        assertThat(VALIDATOR_CONSTRUCTIONS).hasValue(1);\n        deserializer.close();\n    }\n\n    public static class FailingDeserializer implements Deserializer<String> {\n\n        public FailingDeserializer() {\n            DELEGATE_CONSTRUCTIONS.incrementAndGet();\n        }\n\n        @Override\n        public String deserialize(String topic, byte[] data) {\n            throw new IllegalArgumentException(\"Cannot deserialize \" + topic);\n        }\n\n        @Override\n        public String deserialize(String topic, Headers headers, byte[] data) {\n            return deserialize(topic, data);\n        }\n    }\n\n    public static class RecoveryFunction implements Function<FailedDeserializationInfo, String> {\n\n        public RecoveryFunction() {\n            FUNCTION_CONSTRUCTIONS.incrementAndGet();\n        }\n\n        @Override\n        public String apply(FailedDeserializationInfo info) {\n            assertThat(info.isForKey()).isFalse();\n            assertThat(info.getException()).isInstanceOf(IllegalArgumentException.class);\n            return info.getTopic() + \":value:\" + new String(info.getData(), StandardCharsets.UTF_8);\n        }\n    }\n\n    public static class AcceptingValidator implements Validator {\n\n        public AcceptingValidator() {\n            VALIDATOR_CONSTRUCTIONS.incrementAndGet();\n        }\n\n        @Override\n        public boolean supports(Class<?> clazz) {\n            return true;\n        }\n\n        @Override\n        public void validate(Object target, Errors errors) {\n            assertThat(errors).isNotNull();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779199004147}, {"role": "toolResult", "toolCallId": "call_tlEijVQohWcOIdrAXivomgSe|fc_035279eeac17c424016a0c6c1bf20881a1bf6be7ee7cfb213c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_kafka.spring_kafka;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.charset.StandardCharsets;\nimport java.util.function.BiFunction;\n\nimport org.apache.commons.logging.LogFactory;\nimport org.apache.kafka.clients.admin.NewTopic;\nimport org.apache.kafka.common.header.Header;\nimport org.apache.kafka.common.header.Headers;\nimport org.apache.kafka.common.header.internals.RecordHeaders;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.core.log.LogAccessor;\nimport org.springframework.kafka.config.TopicBuilder;\nimport org.springframework.kafka.support.KafkaUtils;\nimport org.springframework.kafka.support.serializer.DeserializationException;\nimport org.springframework.kafka.support.serializer.SerializationUtils;\n\npublic class SerializationUtilsTest {\n\n    private static final LogAccessor LOGGER = new LogAccessor(LogFactory.getLog(SerializationUtilsTest.class));\n\n    @Test\n    void invokesConfiguredMethodWithPayloadAndHeaders() {\n        Headers headers = new RecordHeaders().add(\"marker\", \"header-value\".getBytes(StandardCharsets.UTF_8));\n        BiFunction<String, Headers, String> function = SerializationUtils.propertyToMethodInvokingFunction(\n                MethodTargets.class.getName() + \".parseWithHeaders\",\n                String.class,\n                MethodTargets.class.getClassLoader());\n\n        String result = function.apply(\"payload\", headers);\n\n        assertThat(result).isEqualTo(\"payload:header-value\");\n    }\n\n    @Test\n    void invokesConfiguredMethodWithPayloadOnly() {\n        BiFunction<String, Headers, TopicBuilder> function = SerializationUtils.propertyToMethodInvokingFunction(\n                TopicBuilder.class.getName() + \".name\",\n                String.class,\n                Thread.currentThread().getContextClassLoader());\n\n        NewTopic topic = function.apply(\"orders\", new RecordHeaders()).build();\n\n        assertThat(topic.name()).isEqualTo(\"orders\");\n    }\n\n    @Test\n    void storesAndReadsSerializableDeserializationException() {\n        Headers headers = new RecordHeaders();\n        byte[] data = \"serialized-key\".getBytes(StandardCharsets.UTF_8);\n\n        SerializationUtils.deserializationException(headers, data, new IllegalArgumentException(\"bad key\"), true);\n        DeserializationException exception = SerializationUtils.byteArrayToDeserializationException(\n                LOGGER,\n                headers.lastHeader(KafkaUtils.KEY_DESERIALIZER_EXCEPTION_HEADER));\n\n        assertThat(exception).isNotNull();\n        assertThat(exception.getData()).isEqualTo(data);\n        assertThat(exception.isKey()).isTrue();\n        assertThat(exception.getCause()).isInstanceOf(IllegalArgumentException.class);\n        assertThat(exception.getCause()).hasMessage(\"bad key\");\n    }\n\n    @Test\n    void storesFallbackDeserializationExceptionWhenCauseCannotBeSerialized() {\n        Headers headers = new RecordHeaders();\n        byte[] data = \"serialized-value\".getBytes(StandardCharsets.UTF_8);\n\n        SerializationUtils.deserializationException(\n                headers, data, new NonSerializableCauseException(\"bad value\"), false);\n        DeserializationException exception = SerializationUtils.byteArrayToDeserializationException(\n                LOGGER,\n                headers.lastHeader(KafkaUtils.VALUE_DESERIALIZER_EXCEPTION_HEADER));\n\n        assertThat(exception).isNotNull();\n        assertThat(exception.getData()).isEqualTo(data);\n        assertThat(exception.isKey()).isFalse();\n        assertThat(exception.getCause()).isInstanceOf(RuntimeException.class);\n        assertThat(exception.getCause().getMessage())\n                .contains(\"Could not serialize type \" + NonSerializableCauseException.class.getName())\n                .contains(\"Original exception message: bad value\");\n    }\n\n    public static final class MethodTargets {\n\n        private MethodTargets() {\n        }\n\n        public static String parseWithHeaders(String payload, Headers headers) {\n            Header marker = headers.lastHeader(\"marker\");\n            assertThat(marker).isNotNull();\n            return payload + \":\" + new String(marker.value(), StandardCharsets.UTF_8);\n        }\n    }\n\n    @SuppressWarnings(\"serial\")\n    private static final class NonSerializableCauseException extends Exception {\n\n        private final Object nonSerializable = new Object();\n\n        private NonSerializableCauseException(String message) {\n            super(message);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779199004147}]}
