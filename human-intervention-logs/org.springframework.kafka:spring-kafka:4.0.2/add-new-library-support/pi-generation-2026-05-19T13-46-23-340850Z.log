  package org_springframework_kafka.spring_kafka;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.nio.charset.StandardCharsets;
  import java.util.function.BiFunction;
  
  import org.apache.commons.logging.LogFactory;
  import org.apache.kafka.clients.admin.NewTopic;
  import org.apache.kafka.common.header.Header;
  import org.apache.kafka.common.header.Headers;
  import org.apache.kafka.common.header.internals.RecordHeaders;
  import org.junit.jupiter.api.Test;
  
  import org.springframework.core.log.LogAccessor;
  import org.springframework.kafka.config.TopicBuilder;
  import org.springframework.kafka.support.KafkaUtils;
  import org.springframework.kafka.support.serializer.DeserializationException;
  import org.springframework.kafka.support.serializer.SerializationUtils;
  
  public class SerializationUtilsTest {
  
      private static final LogAccessor LOGGER = new LogAccessor(LogFactory.getLog(SerializationUtilsTest.class));
  
      @Test
      void invokesConfiguredMethodWithPayloadAndHeaders() {
          Headers headers = new RecordHeaders().add("marker", "header-value".getBytes(StandardCharsets.UTF_8));
          BiFunction<String, Headers, String> function = SerializationUtils.propertyToMethodInvokingFunction(
                  MethodTargets.class.getName() + ".parseWithHeaders",
                  String.class,
                  MethodTargets.class.getClassLoader());
  
          String result = function.apply("payload", headers);
  
          assertThat(result).isEqualTo("payload:header-value");
      }
  
      @Test
      void invokesConfiguredMethodWithPayloadOnly() {
          BiFunction<String, Headers, TopicBuilder> function = SerializationUtils.propertyToMethodInvokingFunction(
                  TopicBuilder.class.getName() + ".name",
                  String.class,
                  Thread.currentThread().getContextClassLoader());
  
          NewTopic topic = function.apply("orders", new RecordHeaders()).build();
  
          assertThat(topic.name()).isEqualTo("orders");
      }
  
      @Test
      void storesAndReadsSerializableDeserializationException() {
          Headers headers = new RecordHeaders();
          byte[] data = "serialized-key".getBytes(StandardCharsets.UTF_8);
  
          SerializationUtils.deserializationException(headers, data, new IllegalArgumentException("bad key"), true);
          DeserializationException exception = SerializationUtils.byteArrayToDeserializationException(
                  LOGGER,
                  headers.lastHeader(KafkaUtils.KEY_DESERIALIZER_EXCEPTION_HEADER));
  
          assertThat(exception).isNotNull();
          assertThat(exception.getData()).isEqualTo(data);
          assertThat(exception.isKey()).isTrue();
          assertThat(exception.getCause()).isInstanceOf(IllegalArgumentException.class);
          assertThat(exception.getCause()).hasMessage("bad key");
      }
  
      @Test
      void storesFallbackDeserializationExceptionWhenCauseCannotBeSerialized() {
          Headers headers = new RecordHeaders();
          byte[] data = "serialized-value".getBytes(StandardCharsets.UTF_8);
  
          SerializationUtils.deserializationException(
                  headers, data, new NonSerializableCauseException("bad value"), false);
          DeserializationException exception = SerializationUtils.byteArrayToDeserializationException(
                  LOGGER,
                  headers.lastHeader(KafkaUtils.VALUE_DESERIALIZER_EXCEPTION_HEADER));
  
          assertThat(exception).isNotNull();
          assertThat(exception.getData()).isEqualTo(data);
          assertThat(exception.isKey()).isFalse();
          assertThat(exception.getCause()).isInstanceOf(RuntimeException.class);
          assertThat(exception.getCause().getMessage())
                  .contains("Could not serialize type " + NonSerializableCauseException.class.getName())
                  .contains("Original exception message: bad value");
      }
  
      public static final class MethodTargets {
  
          private MethodTargets() {
          }
  
          public static String parseWithHeaders(String payload, Headers headers) {
              Header marker = headers.lastHeader("marker");
              assertThat(marker).isNotNull();
              return payload + ":" + new String(marker.value(), StandardCharsets.UTF_8);
          }
      }
  
      @SuppressWarnings("serial")
      private static final class NonSerializableCauseException extends Exception {
  
          private final Object nonSerializable = new Object();
  
          private NonSerializableCauseException(String message) {
              super(message);
          }
      }
