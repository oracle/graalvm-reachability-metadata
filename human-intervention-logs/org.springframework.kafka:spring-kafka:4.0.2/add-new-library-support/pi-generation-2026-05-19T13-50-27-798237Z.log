[tool-call] delta {"path":"tests/src/org.springframework.kafka/spring-kafka/4.0.2/src/test/java/org_springframework_kafka/spring_kafka/ErrorHandlingDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_kafka.spring_kafka;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.charset.StandardCharsets;\nimport java.util.Map;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.function.Function;\n\nimport org.apache.kafka.common.header.Headers;\nimport org.apache.kafka.common.header.internals.RecordHeaders;\nimport org.apache.kafka.common.serialization.Deserializer;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.kafka.support.KafkaUtils;\nimport org.springframework.kafka.support.serializer.ErrorHandlingDeserializer;\nimport org.springframework.kafka.support.serializer.FailedDeserializationInfo;\nimport org.springframework.validation.Errors;\nimport org.springframework.validation.Validator;\n\npublic class ErrorHandlingDeserializerTest {\n\n    private static final AtomicInteger DELEGATE_CONSTRUCTIONS = new AtomicInteger();\n\n    private static final AtomicInteger FUNCTION_CONSTRUCTIONS = new AtomicInteger();\n\n    private static final AtomicInteger VALIDATOR_CONSTRUCTIONS = new AtomicInteger();\n\n    @Test\n    void configureCreatesDelegateFunctionAndValidatorFromConfiguredClasses() {\n        DELEGATE_CONSTRUCTIONS.set(0);\n        FUNCTION_CONSTRUCTIONS.set(0);\n        VALIDATOR_CONSTRUCTIONS.set(0);\n        Map<String, Object> configs = Map.of(\n                ErrorHandlingDeserializer.VALUE_DESERIALIZER_CLASS, FailingDeserializer.class,\n                ErrorHandlingDeserializer.VALUE_FUNCTION, RecoveryFunction.class,\n                ErrorHandlingDeserializer.VALIDATOR_CLASS, AcceptingValidator.class);\n        ErrorHandlingDeserializer<String> deserializer = new ErrorHandlingDeserializer<>();\n\n        deserializer.configure(configs, false);\n        Headers headers = new RecordHeaders();\n        String result = deserializer.deserialize(\"orders\", headers, \"bad\".getBytes(StandardCharsets.UTF_8));\n\n        assertThat(result).isEqualTo(\"orders:value:bad\");\n        assertThat(headers.lastHeader(KafkaUtils.VALUE_DESERIALIZER_EXCEPTION_HEADER)).isNotNull();\n        assertThat(DELEGATE_CONSTRUCTIONS).hasValue(1);\n        assertThat(FUNCTION_CONSTRUCTIONS).hasValue(1);\n        assertThat(VALIDATOR_CONSTRUCTIONS).hasValue(1);\n        deserializer.close();\n    }\n\n    public static class FailingDeserializer implements Deserializer<String> {\n\n        public FailingDeserializer() {\n            DELEGATE_CONSTRUCTIONS.incrementAndGet();\n        }\n\n        @Override\n        public String deserialize(String topic, byte[] data) {\n            throw new IllegalArgumentException(\"Cannot deserialize \" + topic);\n        }\n\n        @Override\n        public String deserialize(String topic, Headers headers, byte[] data) {\n            return deserialize(topic, data);\n        }\n    }\n\n    public static class RecoveryFunction implements Function<FailedDeserializationInfo, String> {\n\n        public RecoveryFunction() {\n            FUNCTION_CONSTRUCTIONS.incrementAndGet();\n        }\n\n        @Override\n        public String apply(FailedDeserializationInfo info) {\n            assertThat(info.isForKey()).isFalse();\n            assertThat(info.getException()).isInstanceOf(IllegalArgumentException.class);\n            return info.getTopic() + \":value:\" + new String(info.getData(), StandardCharsets.UTF_8);\n        }\n    }\n\n    public static class AcceptingValidator implements Validator {\n\n        public AcceptingValidator() {\n            VALIDATOR_CONSTRUCTIONS.incrementAndGet();\n        }\n\n        @Override\n        public boolean supports(Class<?> clazz) {\n            return true;\n        }\n\n        @Override\n        public void validate(Object target, Errors errors) {\n        }\n    }\n}\n"}
