  package org.apache.camel.tools.apt.helper;
  
  import java.io.File;
  import java.net.URI;
  import java.net.URL;
  import java.util.ArrayList;
  import java.util.Date;
  import java.util.LinkedHashMap;
  import java.util.List;
  import java.util.Map;
  import java.util.Set;
