    <artifactId>apt</artifactId>
    <name>Camel :: Annotation Processor</name>
    <description>Processes Camel endpoint source code</description>
  
    <properties>
    </properties>
  
    <dependencies>
      <dependency>
        <groupId>org.slf4j</groupId>
        <artifactId>slf4j-api</artifactId>
