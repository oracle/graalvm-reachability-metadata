[tool-call] delta {"path":"tests/src/org.http4s/http4s-crypto_3/0.2.4/src/test/scala/org_http4s/http4s_crypto_3/Http4s_crypto_3Test.scala","edits":[{"oldText":"import scodec.bits.ByteVector\n\nimport scala.concurrent.duration._\n","newText":"import scodec.bits.ByteVector\n\nimport scala.concurrent.duration._\nimport javax.crypto.spec.{SecretKeySpec => JavaSecretKeySpec}\n"},{"oldText":"  @Test\n  def hmacKeyGeneratorCreatesUsableKeysForEachAlgorithm(): Unit = {\n","newText":"  @Test\n  def hmacJavaSecretKeyInteropPreservesAlgorithmAndKeyBytes(): Unit = {\n    val algorithm: HmacAlgorithm = HmacAlgorithm.SHA256\n    val javaKey: javax.crypto.SecretKey = new JavaSecretKeySpec(hmacKey.toArray, algorithm.toStringJava())\n    val importedKey: SecretKey[HmacAlgorithm] = rightValue(Hmac[Result].importJavaKey(javaKey))\n    val importedDigest: ByteVector = rightValue(Hmac[Result].digest(importedKey, data))\n    val directDigest: ByteVector = rightValue(Hmac[Result].digest(SecretKeySpec(hmacKey, algorithm), data))\n    val exportedKey: javax.crypto.SecretKey = SecretKeySpec(hmacKey, algorithm).toJava()\n\n    assertEquals(algorithm, importedKey.algorithm)\n    assertEquals(directDigest, importedDigest)\n    assertEquals(algorithm.toStringJava(), exportedKey.getAlgorithm)\n    assertEquals(hmacKey, ByteVector.view(exportedKey.getEncoded))\n  }\n\n  @Test\n  def hmacKeyGeneratorCreatesUsableKeysForEachAlgorithm(): Unit = {\n"}]}
