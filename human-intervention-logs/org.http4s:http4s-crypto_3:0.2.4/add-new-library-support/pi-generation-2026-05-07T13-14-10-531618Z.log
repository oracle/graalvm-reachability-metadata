          F.fromOption(
            for {
              algorithm <- HmacAlgorithm.fromStringJava(key.getAlgorithm())
              key <- Option(key.getEncoded())
            } yield SecretKeySpec(ByteVector.view(key), algorithm),
            new InvalidKeyException
          )
      }
