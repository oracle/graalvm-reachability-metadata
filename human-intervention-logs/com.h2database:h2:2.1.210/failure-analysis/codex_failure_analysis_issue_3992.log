ectOutputStream;\\nimport java.sql.Connection;\\nimport java.sql.Driver;\\nimport java.sql.DriverManager;\\nimport java.sql.DriverPropertyInfo;\\nimport java.sql.ResultSet;\\nimport java.sql.SQLException;\\nimport java.sql.SQLFeatureNotSupportedException;\\nimport java.util.Properties;\\nimport java.util.logging.Logger;\\n\\nimport javax.naming.InitialContext;\\nimport javax.naming.NamingException;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatExceptionOfType;\\n\\n/**\\n * Exercises reflective utility paths in {@link JdbcUtils} through its public API.\\n */\\npublic class JdbcUtilsTest {\\n    @Test\\n    void loadsUserClassWithDefaultClassLoader() {\\n        Class<String> loadedClass = JdbcUtils.loadUserClass(String.class.getName());\\n\\n        assertThat(loadedClass).isSameAs(String.class);\\n    }\\n\\n    @Test\\n    void initializesConfiguredJavaObjectSerializer() throws Exception {\\n        assertThat(JdbcUtils.serializer).isInstanceOf(ConfiguredSerializer.class);\\n\\n        byte[] serialized = JdbcUtils.serializer.serialize(\\\"h2 serializer\\\");\\n\\n        assertThat(JdbcUtils.serializer.deserialize(serialized)).isEqualTo(\\\"h2 serializer\\\");\\n    }\\n\\n    @Test\\n    void serializesWithDefaultJavaSerializationWhenNoSerializerIsConfigured() {\\n        JavaObjectSerializer configuredSerializer = JdbcUtils.serializer;\\n        try {\\n            JdbcUtils.serializer = null;\\n\\n            byte[] serialized = JdbcUtils.serialize(\\\"h2 default serialization\\\", null);\\n\\n            assertThat(JdbcUtils.deserialize(serialized, null)).isEqualTo(\\\"h2 default serialization\\\");\\n        } finally {\\n            JdbcUtils.serializer = configuredSerializer;\\n        }\\n    }\\n\\n    @Test\\n    void instantiatesExplicitJdbcDriver() {\\n        assertThatExceptionOfType(SQLException.class)\\n                .isThrownBy(() -> JdbcUtils.getConnection(RejectingDriv