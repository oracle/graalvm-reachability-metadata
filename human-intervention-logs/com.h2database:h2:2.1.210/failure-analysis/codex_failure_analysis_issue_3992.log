hat;\\n\\npublic class ServerTest {\\n    @Test\\n    void openBrowserAttemptsDesktopIntegrationWhenNoBrowserIsConfigured() throws Exception {\\n        String originalBrowser = System.getProperty(\\\"h2.browser\\\");\\n        try {\\n            System.clearProperty(\\\"h2.browser\\\");\\n\\n            try {\\n                Server.openBrowser(\\\"http://127.0.0.1:1/\\\");\\n            } catch (Exception exception) {\\n                assertThat(exception).isNotNull();\\n            }\\n        } finally {\\n            setOrClearProperty(\\\"h2.browser\\\", originalBrowser);\\n        }\\n    }\\n\\n    private static void setOrClearProperty(String key, String value) {\\n        if (value == null) {\\n            System.clearProperty(key);\\n        } else {\\n            System.setProperty(key, value);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777887223153}, {\"role\": \"toolResult\", \"toolCallId\": \"call_XcAHoegOulHGc8cP7Ov6q6Dw|fc_036c189a9a94e45e0169f867f6d590819fbd976044043be9c8\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n */\\npackage com.ibm.icu.text;\\n\\nimport java.util.Comparator;\\nimport java.util.Locale;\\n\\npublic final class Collator implements Comparator<String> {\\n    private int strength;\\n\\n    private Collator() {\\n    }\\n\\n    public static Collator getInstance(Locale locale) {\\n        return new Collator();\\n    }\\n\\n    public static Locale[] getAvailableLocales() {\\n        return new Locale[] {Locale.ENGLISH, Locale.US};\\n    }\\n\\n    public void setStrength(int strength) {\\n        this.strength = strength;\\n    }\\n\\n    @Override\\n    public int compare(String first, String second) {\\n        if (strength <= java.text.Collator.SECONDARY) {\\n            return first.compareToIgnoreCase(second);\\n        }\\n        return first.compareTo(second);\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\":