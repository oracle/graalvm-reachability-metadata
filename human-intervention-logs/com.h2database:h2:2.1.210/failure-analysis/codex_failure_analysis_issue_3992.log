n * Copyright and related rights waived via CC0\\n */\\npackage h2;\\n\\nimport org.h2.api.DatabaseEventListener;\\nimport org.h2.api.JavaObjectSerializer;\\nimport org.h2.api.TableEngine;\\nimport org.h2.command.ddl.CreateTableData;\\nimport org.h2.table.Table;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.nio.charset.StandardCharsets;\\nimport java.sql.Connection;\\nimport java.sql.DriverManager;\\nimport java.sql.PreparedStatement;\\nimport java.sql.SQLException;\\nimport java.sql.Statement;\\nimport java.sql.Types;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class DatabaseTest {\\n    @Test\\n    void databaseEventListenerIsInstantiatedFromUrl() throws Exception {\\n        NoOpDatabaseEventListener.initializedUrl = null;\\n\\n        try (Connection connection = DriverManager.getConnection(\\\"jdbc:h2:mem:database-listener;\\\"\\n                + \\\"DATABASE_EVENT_LISTENER='\\\" + NoOpDatabaseEventListener.class.getName() + \\\"'\\\")) {\\n            assertThat(connection.isClosed()).isFalse();\\n        }\\n\\n        assertThat(NoOpDatabaseEventListener.initializedUrl).contains(\\\"database-listener\\\");\\n    }\\n\\n    @Test\\n    void javaObjectSerializerIsInstantiatedFromUrl() throws Exception {\\n        Utf8JavaObjectSerializer.serializeCount = 0;\\n\\n        try (Connection connection = DriverManager.getConnection(\\\"jdbc:h2:mem:database-serializer;\\\"\\n                + \\\"JAVA_OBJECT_SERIALIZER='\\\" + Utf8JavaObjectSerializer.class.getName() + \\\"'\\\");\\n                Statement statement = connection.createStatement()) {\\n            statement.execute(\\\"CREATE TABLE objects(object_value JAVA_OBJECT)\\\");\\n            try (PreparedStatement preparedStatement = connection.prepareStatement(\\\"INSERT INTO objects VALUES (?)\\\")) {\\n                preparedStatement.setObject(1, \\\"serialized\\\", Types.JAVA_OBJECT);\\n                preparedStatement.executeUpdate();\\n            }\\n        }\\n\\n        assertThat(Utf8JavaObjectSerializer.serializeCount).isPositive();\\n    }\\n\\n    @Test\\n    void tableEngineIsInstantiatedFromCreateTableStatement() throws Exception {\\n        FailingTableEngine.constructed = false;\\n\\n        try (Connection connection = DriverManager.getConnection(\\\"jdbc:h2:mem:database-table-engine;DB_CLOSE_DELAY=-1\\\");\\n                Statement statement = connection.createStatement()) {\\n            try {\\n                statement.execute(\\\"CREATE TABLE custom_engine(id INT) ENGINE \\\\\\\"\\\" + FailingTableEngine.class.getName()\\n                        + \\\"\\\\\\\"\\\");\\n            } catch (SQLException exception) {\\n                assertThat(exception).isNotNull();\\n            }\\n        }\\n\\n        assertThat(FailingTableEngine.constructed).isTrue();\\n    }\\n\\n    public static final class NoOpDatabaseEventListener implements DatabaseEventListener {\\n        static String initializedUrl;\\n\\n        public NoOpDatabaseEventListener() {\\n        }\\n\\n        @Override\\n        public void init(String url) {\\n            initializedUrl = url;\\n        }\\n\\n        @Override\\n        public void exceptionThrown(SQLException e, String sql) {\\n        }\\n    }\\n\\n    public static final class Utf8JavaObjectSerializer implements JavaObjectSerializer {\\n        static int serializeCount;\\n\\n        public Utf8JavaObjectSerializer() {\\n        }\\n\\n        @Override\\n        public byte[] serialize(Object obj) {\\n            serializeCount++;\\n            return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);\\n        }\\n\\n        @Override\\n        public Object deserialize(byte[] bytes) {\\n            return new String(bytes, StandardCharsets.UTF_8);\\n        }\\n    }\\n\\n    public static final class FailingTableEngine implements TableEngine {\\n        static boolean constructed;\\n\\n        public FailingTableEngine() {\\n            constructed = true;\\n        }\\n\\n        @Override\\n        public Table createTable(CreateTableData data) {\\n            return null;\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777887147890}, {\"role\": \"toolResult\", \"toolCallId\": \"call_HoXcTTZ3gfZWUDmvcuAoqtCH|fc_036c189a9a94e45e0169f867ab9420819fb63a71658167f022\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\nplugins {\\n    id \\\"org.graalvm.internal.tck\\\"\\n}\\n\\nString libraryVersion = tck.testedLibraryVersion.get()\\n\\ndependencies {\\n\\ttestImplementation(\\\"com.h2database:h2:$libraryVersion\\\")\\n\\ttestImplementation(\\\"org.assertj:assertj-core:3.22.0\\\")\\n}\\n\\ntasks.withType(Test).configureEach {\\n    systemProperty(\\\"h2.nioCleanerHack\\\", \\\"true\\\")\\n    systemProperty(\\\"h2.useThreadContextClassLoader\\\", \\\"true\\\")\\n}\\n\\ngraalvmNative {\\n    binaries {\\n        test {\\n            runtimeArgs(\\\"-Dh2.nioCleanerHack=true\\\")\\n            runtimeArgs(\\\"-Dh2.useThreadContextClassLoader=true\\\")\\n        }\\n    }\\n    agent {\\n        defaultMode = \\\"conditional\\\"\\n        modes {\\n            conditional {\\n                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n            }\\n        }\\n        metadataCopy {\\n            mergeWithExisting = true\\n            inputTaskNames.add(\\\"test\\\")\\n            outputDirectories.add(\\\"src/test/resources/META-INF/native-image/com.h2database/h2\\\")\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777887147890}]}\n4406:[tool-call] delta {\"path\":\"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/JdbcUtilsAnonymous1Test.java\",\"edits\":[{\"oldText\":\"import java.io.ByteArrayOutputStream;\\nimport java.io.ObjectOutputS