.substring(0, idx));\\n                String country = name.substring(idx + 1);\\n                Locale locale = new Locale(language, country);\\n                if (compareLocaleNames(locale, name)) {\\n                    result = Collator.getInstance(locale);\\n                }\\n            }\\n        } else if (name.indexOf('-') > 0) {\\n            Locale locale = Locale.forLanguageTag(name);\\n            if (!locale.getLanguage().isEmpty()) {\\n                return Collator.getInstance(locale);\\n            }\\n        }\\n        if (result == null) {\\n            for (Locale locale : getCollationLocales(false)) {\\n                if (compareLocaleNames(locale, name)) {\\n                    result = Collator.getInstance(locale);\\n                    break;\\n                }\\n            }\\n        }\\n        return result;\\n    }\\n\\n    public String getName() {\\n        return name == null ? OFF : name;\\n    }\\n\\n    public int getStrength() {\\n        return strength;\\n    }\\n\\n    @Override\\n    public boolean equals(Object obj) {\\n\\n[30 more lines in file. Use offset=255 to continue.]\"}], \"isError\": false, \"timestamp\": 1777887182011}]}\n5487:[thinking] I’m considering whether I can check a static set from the serializer constructor stack, but actually, that doesn’t seem necessary. I need to focus on the ServerTest: specifically, I wonder if using `openBrowser` with `os.name` set to Windows could lead to a break in `java.awt.Desktop.isDesktopSupported()`. It might throw an Error based on `os.name`, and I need to remember that the server catches Exception, not Error.\n5491:[tool-call] delta {\"path\":\"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/ServerTest.java\",\"edits\":[{\"oldText\":\"        String originalBrowser = System.getProperty(\\\"h2.browser\\\");\\n        String originalOsName = System.getProperty(\\\"os.name\\\");\\n        try {\\n            System.clearProperty(\\\"h2.browser\\\");\\n         