on();\\n\\n        Method method = MethodUtils.getAccessibleMethod(InterfaceOnlyImplementation.class, \\\"describe\\\");\\n        Object value = MethodUtils.invokeExactMethod(target, \\\"describe\\\");\\n\\n        assertThat(method).isNotNull();\\n        assertThat(method.getDeclaringClass()).isEqualTo(Describable.class);\\n        assertThat(value).isEqualTo(\\\"interface\\\");\\n    }\\n\\n    @Test\\n    void getAccessibleMethodFallsBackToPublicSuperclassOverride() throws Exception {\\n        OverridingHiddenChild target = new OverridingHiddenChild();\\n\\n        Method method = MethodUtils.getAccessibleMethod(OverridingHiddenChild.class, \\\"greet\\\", String.class);\\n        Object value = MethodUtils.invokeExactMethod(target, \\\"greet\\\", new Object[] { \\\"Lang\\\" }, new Class<?>[] { String.class });\\n\\n        assertThat(method).isNotNull();\\n        assertThat(method.getDeclaringClass()).isEqualTo(PublicGreeter.class);\\n        assertThat(value).isEqualTo(\\\"child:Lang\\\");\\n    }\\n\\n    @Test\\n    void invokeMethodCoversExactMatchingAndVarArgsAdaptation() throws Exception {\\n        InvocationTarget target = new InvocationTarget();\\n\\n        Method exactMethod = MethodUtils.getMatchingAccessibleMethod(InvocationTarget.class, \\\"echo\\\", String.class);\\n        Method varArgsMethod = MethodUtils.getMatchingAccessibleMethod(\\n                InvocationTarget.class,\\n                \\\"sum\\\",\\n                String.class,\\n                Integer.class,\\n                Integer.class,\\n                Integer.class);\\n        Object exactValue = MethodUtils.invokeMethod(target, \\\"echo\\\", \\\"commons\\\");\\n        Object varArgsValue = MethodUtils.invokeMethod(target, \\\"sum\\\", \\\"total\\\", 1, 2, 3);\\n\\n        assertThat(exactMethod).isNotNull();\\n        assertThat(exactMethod.getName()).isEqualTo(\\\"echo\\\");\\n        assertThat(varArgsMethod).isNotNull();\\n        assertThat(varArgsMethod.isVarArgs()).isTrue();\\n        assertThat(exactValue).isEqualTo(\\\"echo:commons\\\");\\n        assertThat(varArgsValue).isEqualTo(\\\"total=6\\\");\\n    }\\n\\n    @Test\\n    void invokeStaticMethodsCoverExactAndVarArgsPaths() throws Exception {\\n        Object exactValue = MethodUtils.invokeExactStaticMethod(StaticInvocationTarget.class, \\\"type\\\");\\n        Object varArgsValue = MethodUtils.invokeStaticMethod(StaticInvocationTarget.class, \\\"sum\\\", \\\"static\\\", 4, 5);\\n\\n        assertThat(exactValue).isEqualTo(\\\"static\\\");\\n        assertThat(varArgsValue).isEqualTo(\\\"static=9\\\");\\n    }\\n\\n    @Test\\n    void getMatchingMethodSearchesDeclaredMethodsAcrossTheHierarchy() {\\n        Method method = MethodUtils.getMatchingMethod(HierarchyChild.class, \\\"accept\\\", Integer.class);\\n\\n        assertThat(method).isNotNull();\\n        assertThat(method.getDeclaringClass()).isEqualTo(HierarchyChild.class);\\n    }\\n\\n    @Test\\n    void getMethodsListWithAnnotationSupportsPublicAndDeclaredSearches() {\\n        List<Method> publicMethods = MethodUtils.getMethodsListWithAnnotation(AnnotatedChild.class, Marker.class, false, false);\\n        List<Method> declaredMethods = MethodUtils.getMethodsListWithAnnotation(AnnotatedChild.class, Marker.class, true, true);\\n\\n        assertThat(publicMethods)\\n                .extracting(Method::getName)\\n                .contains(\\\"publicAnnotated\\\", \\\"inheritedPublicAnnotated\\\")\\n                .doesNotContain(\\\"privateAnnotated\\\");\\n        assertThat(declaredMethods)\\n                .extracting(Method::getName)\\n                .contains(\\\"publicAnnotated\\\", \\\"privateAnnotated\\\", \\\"inheritedPublicAnnotated\\\", \\\"packagePrivateAnnotated\\\");\\n    }\\n\\n    public interface Describable {\\n        String describe();\\n    }\\n\\n    static class InterfaceOnlyImplementation implements Describable {\\n        @Override\\n        public String describe() {\\n            return \\\"interface\\\";\\n        }\\n    }\\n\\n    public static class PublicGreeter {\\n        public String greet(String name) {\\n            return \\\"base:\\\" + name;\\n        }\\n    }\\n\\n    static class OverridingHiddenChild extends PublicGreeter {\\n        @Override\\n        public String greet(String name) {\\n            return \\\"child:\\\" + name;\\n        }\\n    }\\n\\n    public static class InvocationTarget {\\n        public String echo(String value) {\\n            return \\\"echo:\\\" + value;\\n        }\\n\\n        public String sum(String prefix, int... values) {\\n            int total = 0;\\n            for (int value : values) {\\n                total += value;\\n            }\\n            return prefix + \\\"=\\\" + total;\\n        }\\n    }\\n\\n    public static class StaticInvocationTarget {\\n        public static String type() {\\n            return \\\"static\\\";\\n        }\\n\\n        public static String sum(String prefix, int... values) {\\n            int total = 0;\\n            for (int value : values) {\\n                total += value;\\n            }\\n            return prefix + \\\"=\\\" + total;\\n        }\\n    }\\n\\n    public static class HierarchyParent {\\n        public Number accept(Number value) {\\n            return value;\\n        }\\n    }\\n\\n    public static class HierarchyChild extends HierarchyParent {\\n        public Integer accept(Integer value) {\\n            return value;\\n        }\\n    }\\n\\n    @Retention(RetentionPolicy.RUNTIME)\\n    @Target(ElementType.METHOD)\\n    public @interface Marker {\\n    }\\n\\n    public static class AnnotatedParent {\\n        @Marker\\n        public void inheritedPublicAnnotated() {\\n        }\\n\\n        @Marker\\n        void packagePrivateAnnotated() {\\n        }\\n    }\\n\\n    public static class AnnotatedChild extends AnnotatedParent {\\n        @Marker\\n        public void publicAnnotated() {\\n        }\\n\\n        @Marke