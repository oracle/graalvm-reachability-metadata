[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/CompareModeIcu4JTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.value.CompareMode;\nimport org.junit.jupiter.api.Test;\n\nimport java.text.Collator;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CompareModeIcu4JTest {\n    @Test\n    void createsIcuCollatorFromLanguageLocale() {\n        CompareMode compareMode = CompareMode.getInstance(CompareMode.ICU4J + \"en\", Collator.TERTIARY);\n\n        assertThat(compareMode.getName()).isEqualTo(\"en\");\n        assertThat(compareMode.compareString(\"abc\", \"abd\", false)).isLessThan(0);\n        assertThat(compareMode.equalsChars(\"A\", 0, \"a\", 0, true)).isTrue();\n    }\n\n    @Test\n    void createsIcuCollatorFromLanguageAndCountryLocale() {\n        CompareMode compareMode = CompareMode.getInstance(CompareMode.ICU4J + \"en_US\", Collator.SECONDARY);\n\n        assertThat(compareMode.getName()).isEqualTo(\"en_US\");\n        assertThat(compareMode.compareString(\"color\", \"colour\", false)).isLessThan(0);\n    }\n\n    @Test\n    void createsIcuCollatorByScanningAvailableLocales() {\n        CompareMode compareMode = CompareMode.getInstance(CompareMode.ICU4J + \"ENGLISH\", Collator.PRIMARY);\n\n        assertThat(compareMode.getName()).isEqualTo(\"ENGLISH\");\n        assertThat(compareMode.compareString(\"resume\", \"résumé\", false)).isEqualTo(0);\n    }\n}\n"}
