      static boolean compareLocaleNames(Locale locale, String name) {
          return name.equalsIgnoreCase(locale.toString()) || name.equalsIgnoreCase(locale.toLanguageTag()) ||
                  name.equalsIgnoreCase(getName(locale));
      }
  
