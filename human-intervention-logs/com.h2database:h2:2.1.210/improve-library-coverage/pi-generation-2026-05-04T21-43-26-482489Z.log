      public static String getDriver(String url) {
          if (url.startsWith("jdbc:")) {
              url = url.substring("jdbc:".length());
              for (int i = 0; i < DRIVERS.length; i += 2) {
                  String prefix = DRIVERS[i];
                  if (url.startsWith(prefix)) {
                      return DRIVERS[i + 1];
                  }
              }
          }
          return null;
      }
  
