  package h2;
  
  import org.h2.mvstore.type.ObjectDataType;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ObjectDataTypeTest {
      @Test
      void serializesAndDeserializesJavaObjectValues() {
          String value = "serialized value";
  
          byte[] serialized = ObjectDataType.serialize(value);
          Object deserialized = ObjectDataType.deserialize(serialized);
  
          assertThat(serialized).startsWith((byte) 0xAC, (byte) 0xED);
          assertThat(deserialized).isEqualTo(value);
      }
  }
