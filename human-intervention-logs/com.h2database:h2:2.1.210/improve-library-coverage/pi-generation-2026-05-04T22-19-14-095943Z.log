  package h2;
  
  import org.h2.api.JavaObjectSerializer;
  import org.h2.util.JdbcUtils;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.sql.Connection;
  import java.sql.Driver;
  import java.sql.DriverManager;
  import java.sql.DriverPropertyInfo;
  import java.sql.ResultSet;
  import java.sql.SQLException;
  import java.sql.SQLFeatureNotSupportedException;
  import java.util.Properties;
  import java.util.logging.Logger;
  
  import javax.naming.InitialContext;
  import javax.naming.NamingException;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatExceptionOfType;
  
  /**
   * Exercises reflective utility paths in {@link JdbcUtils} through its public API.
   */
  public class JdbcUtilsTest {
      @Test
      void loadsUserClassWithDefaultClassLoader() {
          Class<String> loadedClass = JdbcUtils.loadUserClass(String.class.getName());
  
          assertThat(loadedClass).isSameAs(String.class);
      }
  
      @Test
      void initializesConfiguredJavaObjectSerializer() throws Exception {
          assertThat(JdbcUtils.serializer).isInstanceOf(ConfiguredSerializer.class);
  
          byte[] serialized = JdbcUtils.serializer.serialize("h2 serializer");
  
          assertThat(JdbcUtils.serializer.deserialize(serialized)).isEqualTo("h2 serializer");
      }
  
      @Test
      void serializesWithDefaultJavaSerializationWhenNoSerializerIsConfigured() {
          JavaObjectSerializer configuredSerializer = JdbcUtils.serializer;
          try {
              JdbcUtils.serializer = null;
  
              byte[] serialized = JdbcUtils.serialize("h2 default serialization", null);
  
              assertThat(JdbcUtils.deserialize(serialized, null)).isEqualTo("h2 default serialization");
          } finally {
              JdbcUtils.serializer = configuredSerializer;
          }
      }
  
      @Test
      void instantiatesExplicitJdbcDriver() {
          assertThatExceptionOfType(SQLException.class)
                  .isThrownBy(() -> JdbcUtils.getConnection(RejectingDriver.class.getName(),
                          "jdbc:rejecting:test", "sa", "secret"))
                  .withMessageContaining("not suitable");
      }
  
      @Test
