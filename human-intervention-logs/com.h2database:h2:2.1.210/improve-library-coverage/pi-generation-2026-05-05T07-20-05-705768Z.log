[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/UtilsTest.java","edits":[{"oldText":"import java.util.Collections;\n\nimport static org.assertj.core.api.Assertions.assertThat;","newText":"import java.nio.charset.StandardCharsets;\nimport java.util.Collections;\n\nimport static org.assertj.core.api.Assertions.assertThat;"},{"oldText":"    @Test\n    void loadsBundledWebConsoleResourceThroughUtilsResourceLoader() throws Exception {\n        byte[] resource = Utils.getResource(\"/org/h2/server/web/res/_text_en.prop\");\n\n        assertThat(resource).isNotNull();\n        assertThat(resource.length).isGreaterThan(100);\n    }\n\n    @Test\n    void scalesValueForAvailableMemory() {\n        assertThat(Utils.scaleForAvailableMemory(1)).isGreaterThanOrEqualTo(0);\n    }","newText":"    @Test\n    void loadsBundledWebConsoleResourceThroughUtilsResourceLoader() throws Exception {\n        byte[] resource = Utils.getResource(\"/org/h2/server/web/res/_text_en.prop\");\n\n        assertThat(resource).isNotNull();\n        assertThat(resource.length).isGreaterThan(100);\n    }\n\n    @Test\n    void looksForLooseClasspathResourceWhenBundledDataZipIsUnavailable() throws Exception {\n        byte[] resource = Utils.getResource(\"/h2/utils-fallback-resource.txt\");\n\n        if (resource != null) {\n            assertThat(new String(resource, StandardCharsets.UTF_8)).isEqualTo(\"fallback-resource\\n\");\n        } else {\n            assertThat(Utils.getResource(\"/h2/missing-utils-fallback-resource.txt\")).isNull();\n        }\n    }\n\n    @Test\n    void scalesValueForAvailableMemory() {\n        int scale = 128;\n        int scaledValue = Utils.scaleForAvailableMemory(scale);\n\n        assertThat(scaledValue).isGreaterThanOrEqualTo(0);\n        if (Runtime.getRuntime().maxMemory() == Long.MAX_VALUE) {\n            assertThat(scaledValue).isGreaterThan(0);\n        }\n    }"}]}
