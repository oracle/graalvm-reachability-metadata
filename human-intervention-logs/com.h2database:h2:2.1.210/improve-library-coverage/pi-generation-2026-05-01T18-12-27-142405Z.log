  package h2;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.h2.util.SourceCompiler;
  import org.junit.jupiter.api.Test;
  
  import java.io.File;
  import java.lang.reflect.InvocationTargetException;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import javax.tools.JavaCompiler;
  import javax.tools.ToolProvider;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class SourceCompilerAnonymous1Test {
      private static final String NULL_BYTECODE_COMPILER_CLASS = "org.h2.util.NullBytecodeSourceCompiler";
      private static final String MISSING_SYSTEM_CLASS = "h2.generated.MissingSystemClass";
  
      private static final String NULL_BYTECODE_COMPILER_SOURCE = """
              package org.h2.util;
  
              public class NullBytecodeSourceCompiler extends SourceCompiler {
                  @Override
                  byte[] javacCompile(String packageName, String className, String source) {
                      return null;
                  }
              }
              """;
  
      @Test
      void fallsBackToSystemClassLookupWhenLegacyCompilerProducesNoBytecode() throws Exception {
          assertDynamicClassLoading(() -> {
              Path classesDirectory = Files.createTempDirectory("h2-source-compiler-fallback");
              URL h2Location = SourceCompiler.class.getProtectionDomain().getCodeSource().getLocation().toURI().toURL();
              compileNullBytecodeCompiler(classesDirectory, h2Location);
  
              try (URLClassLoader sourceCompilerLoader = new URLClassLoader(
                      new URL[] { classesDirectory.toUri().toURL(), h2Location },
                      ClassLoader.getPlatformClassLoader())) {
                  Class<?> compilerClass = sourceCompilerLoader.loadClass(NULL_BYTECODE_COMPILER_CLASS);
                  Object compiler = compilerClass.getDeclaredConstructor().newInstance();
                  compilerClass.getMethod("setJavaSystemCompiler", boolean.class).invoke(compiler, false);
                  compilerClass.getMethod("setSource", String.class, String.class)
                          .invoke(compiler, MISSING_SYSTEM_CLASS, "String value() { return \"unreachable\"; }");
  
                  assertThatThrownBy(() -> compilerClass.getMethod("getClass", String.class)
                          .invoke(compiler, MISSING_SYSTEM_CLASS))
                          .isInstanceOf(InvocationTargetException.class)
                          .cause()
                          .isInstanceOf(ClassNotFoundException.class)
                          .hasMessage(MISSING_SYSTEM_CLASS);
              }
          });
      }
  
      private static void compileNullBytecodeCompiler(Path classesDirectory, URL h2Location) throws Exception {
          Path sourceFile = classesDirectory.resolve("org/h2/util/NullBytecodeSourceCompiler.java");
          Files.createDirectories(sourceFile.getParent());
          Files.writeString(sourceFile, NULL_BYTECODE_COMPILER_SOURCE);
  
          JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();
          String classPath = h2Location.getPath() + File.pathSeparator + System.getProperty("java.class.path");
          int exitCode = compiler.run(null, null, null,
                  "-classpath", classPath,
                  "-d", classesDirectory.toString(),
                  sourceFile.toString());
          assertThat(exitCode).isZero();
      }
  
      private static void assertDynamicClassLoading(DynamicClassLoadingAssertion assertion) throws Exception {
          try {
              assertion.run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private interface DynamicClassLoadingAssertion {
          void run() throws Exception;
      }
  }
