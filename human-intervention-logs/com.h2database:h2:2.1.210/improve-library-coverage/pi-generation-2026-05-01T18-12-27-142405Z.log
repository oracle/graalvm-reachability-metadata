        \"-classpath\", classPath,\n                    \"-d\", classesDirectory.toString(),\n                    sourceFile.toString());\n        }\n        Process process = new ProcessBuilder(\"javac\",\n                \"-classpath\", classPath,\n                \"-d\", classesDirectory.toString(),\n                sourceFile.toString())\n                .inheritIO()\n                .start();\n        return process.waitFor();\n    }\n\n    private static SourceCompiler newSourceCompiler(Class<? extends SourceCompiler> compilerType) throws Throwable {\n        MethodHandle constructor = MethodHandles.publicLookup()\n                .findConstructor(compilerType, MethodType.methodType(void.class));\n        return (SourceCompiler) constructor.invoke();\n    }\n\n    private static void assertDynamicClassLoading(DynamicClassLoadingAssertion assertion) throws Throwable {\n        try {\n            assertion.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private interface DynamicClassLoadingAssertion {\n        void run() throws Throwable;\n    }\n}\n"}
