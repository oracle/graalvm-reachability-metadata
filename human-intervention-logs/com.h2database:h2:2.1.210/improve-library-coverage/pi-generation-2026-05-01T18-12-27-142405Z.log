   \"\"\";\n\n    @Test\n    void fallsBackToSystemClassLookupWhenLegacyCompilerProducesNoBytecode() throws Throwable {\n        assertDynamicClassLoading(() -> {\n            Class<? extends SourceCompiler> compilerType = defineNullBytecodeCompiler();\n            SourceCompiler compiler = newSourceCompiler(compilerType);\n            compiler.setJavaSystemCompiler(false);\n            compiler.setSource(MISSING_SYSTEM_CLASS, \"String value() { return \\\"unreachable\\\"; }\");\n\n            Throwable thrown = catchThrowable(() -> compiler.getClass(MISSING_SYSTEM_CLASS));\n\n            assertThat(thrown)\n                    .isInstanceOf(ClassNotFoundException.class)\n                    .hasMessage(MISSING_SYSTEM_CLASS);\n        });\n    }\n\n    private static Class<? extends SourceCompiler> defineNullBytecodeCompiler() throws Throwable {\n        Path classesDirectory = Files.createTempDirectory(\"h2-source-compiler-fallback\");\n        byte[] compilerBytes = compileNullBytecodeCompiler(classesDirectory);\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(SourceCompiler.class, MethodHandles.lookup());\n        return lookup.defineClass(compilerBytes).asSubclass(SourceCompiler.class);\n    }\n\n    private static byte[] compileNullBytecodeCompiler(Path classesDirectory) throws Exception {\n        Path sourceFile = classesDirectory.resolve(\"org/h2/util/NullBytecodeSourceCompiler.java\");\n        Path classFile = classesDirectory.resolve(\"org/h2/util/NullBytecodeSourceCompiler.class\");\n        Files.createDirectories(sourceFile.getParent());\n        Files.writeString(sourceFile, NULL_BYTECODE_COMPILER_SOURCE);\n\n        URL h2Location = SourceCompiler.class.getProtectionDomain().getCodeSource().getLocation().toURI().toURL();\n        String classPath = Path.of(h2Location.toURI()) + File.pathSeparator + System.getProperty(\"java.class.path\");\n        int exitCode = compileJavaSource(sourceFile, classesDirectory, classPath);\n        assertThat(exitCode).isZero();\n        return Files.readAllBytes(classFile);\n    }\n\n    private static int compileJavaSource(Path sourceFile, Path classesDirectory, String classPath) throws Exception {\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\n        if (compiler != null) {\n            return compiler.run(null, null, null,\n                    \"-classpath\", classPath,\n                    \"-d\", classesDirectory.toString(),\n                    sourceFile.toString());\n        }\n        Process process = new ProcessBuilder(\"javac\",\n                \"-classpath\", classPath,\n                \"-d\", classesDirectory.toString(),\n                sourceFile.toString())\n                .inheritIO()\n                .start();\n        return process.waitFor();\n    }\n\n    private static SourceCompiler newSourceCompiler(Class<? extends SourceCompiler> compilerType) throws Throwable {\n        MethodHandle constructor = MethodHandles.publicLookup()\n                .findConstructor(compilerType, MethodType.methodType(void.class));\n        return (SourceCompiler) constructor.invoke();\n    }\n\n    private static void assertDynamicClassLoading(DynamicClassLoadingAssertion assertion) throws Throwable {\n        try {\n            assertion.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private interface DynamicClassLoadingAssertion {\n        void run() throws Throwable;\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/SourceCompilerAnonymous1Test.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage h2;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\n