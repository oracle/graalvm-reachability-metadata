.newInstance();\n            nullBytecodeCompiler.setJavaSystemCompiler(false);\n            nullBytecodeCompiler.setSource(MISSING_SYSTEM_CLASS, \"String value() { return \\\"unreachable\\\"; }\");\n\n            assertThatThrownBy(() -> nullBytecodeCompiler.getClass(MISSING_SYSTEM_CLASS))\n                    .isInstanceOf(ClassNotFoundException.class)\n                    .hasMessage(MISSING_SYSTEM_CLASS);\n        });\n    }\n\n    private static void assertDynamicClassLoading(DynamicClassLoadingAssertion assertion) throws Exception {\n        try {\n            assertion.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private interface DynamicClassLoadingAssertion {\n        void run() throws Exception;\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/SourceCompilerAnonymous1Test.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage h2;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.h2.util.SourceCompiler;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\npublic class SourceCompilerAnonymous1Test {\\n    private static final String NULL_BYTECODE_COMPILER_CLASS = \\\"org.h2.util.NullBytecodeSourceCompiler\\\";\\n    private static final String MISSING_SYSTEM_CLASS = \\\"h2.generated.MissingSystemClass\\\";\\n\\n    private static final String NULL_BYTECODE_COMPILER_SOURCE = \\\"\\\"\\\"\\n            package org.h2.util;\\n\\n            public class NullBytecodeSourceCompiler extends SourceCompiler {\\n                @Override\\n                public byte[] javacCompile(String packageName, String className, St