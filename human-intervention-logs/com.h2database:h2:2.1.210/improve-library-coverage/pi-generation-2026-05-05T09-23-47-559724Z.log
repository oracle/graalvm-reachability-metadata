j:73.2\")\n\ttestImplementation(\"org.assertj:assertj-core:3.22.0\")\n}\n\ntasks.named(\"test\") {\n    jvmArgs \"--add-opens=java.base/java.nio=ALL-UNNAMED\"\n    systemProperty \"h2.nioCleanerHack\", \"true\"\n}\n\ntasks.named(\"nativeTest\") {\n    runtimeArgs.add(\"-Dh2.nioCleanerHack=true\")\n}\n", "newText": "String libraryVersion = tck.testedLibraryVersion.get()\nString upgradeLegacyVersion = \"1.4.200\"\n\nconfigurations {\n    upgradeLegacyH2\n}\n\ndependencies {\n\ttestImplementation(\"com.h2database:h2:$libraryVersion\")\n\ttestImplementation(\"com.ibm.icu:icu4j:73.2\")\n\ttestImplementation(\"org.assertj:assertj-core:3.22.0\")\n    upgradeLegacyH2(\"com.h2database:h2:$upgradeLegacyVersion\")\n}\n\nString upgradeLegacyH2Jar = configurations.upgradeLegacyH2.singleFile.absolutePath\n\ntasks.named(\"test\") {\n    jvmArgs \"--add-opens=java.base/java.nio=ALL-UNNAMED\"\n    systemProperty \"h2.nioCleanerHack\", \"true\"\n    systemProperty \"h2.upgrade.oldJar\", upgradeLegacyH2Jar\n}\n\ntasks.named(\"nativeTest\") {\n    runtimeArgs.add(\"-Dh2.nioCleanerHack=true\")\n    runtimeArgs.add(\"-Dh2.upgrade.oldJar=$upgradeLegacyH2Jar\")\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1186, "output": 2950, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 32808, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777972927214, "responseId": "resp_0cb4ed4b853199510169f9b6bfb3f081a3b0931283858795d6"}}
