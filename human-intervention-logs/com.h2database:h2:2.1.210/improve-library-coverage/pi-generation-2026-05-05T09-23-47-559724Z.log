TaskNames.add(\"test\")\n            outputDirectories.add(\"src/test/resources/META-INF/native-image/com.h2database/h2\")\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777972979951}, {"role": "toolResult", "toolCallId": "call_ea4Gyt8Uh1xA5w0M2KjRfcmf|fc_0cb4ed4b853199510169f9b6f3c0a081a3b3d3a4399918cf2d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.h2.tools.Upgrade;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.StandardCopyOption;\nimport java.sql.Driver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UpgradeTest {\n    private static final int LEGACY_BUILD_ID = 200;\n    private static final String LEGACY_VERSION = \"1.4.\" + LEGACY_BUILD_ID;\n    private static final String LEGACY_JAR_PROPERTY = \"h2.upgrade.oldJar\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void loadsAndUnloadsLegacyH2DriverThroughUpgradeTool() throws Exception {\n        String previousUserHome = System.getProperty(\"user.home\");\n        Driver driver = null;\n        try {\n            System.setProperty(\"user.home\", temporaryDirectory.toString());\n            installLegacyJarInTemporaryMavenRepository();\n\n            driver = Upgrade.loadH2(LEGACY_BUILD_ID);\n\n            assertThat(driver.getMajorVersion()).isEqualTo(1);\n            assertThat(driver.getMinorVersion()).isEqualTo(4);\n\n            Driver loadedDriver = driver;\n            driver = null;\n            Upgrade.unloadH2(loadedDriver);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            if (driver != null) {\n                Upgrade.unloadH2(driver);\n            }\n            restoreUserHome(previousUserHome);\n        }\n    }\n\n    private void installLegacyJarInTemporaryMavenRepository() throws IOException {\n        String legacyJar = System.getProperty(LEGACY_JAR_PROPERTY);\n        assertThat(legacyJar).isNotBlank();\n\n        Path targetJar = temporaryDirectory.resolve(\".m2/repository/com/h2database/h2\")\n                .resolve(LEGACY_VERSION)\n                .resolve(\"h2-\" + LEGACY_VERSION + \".jar\");\n        Files.createDirectories(targetJar.getParent());\n        Files.copy(Path.of(legacyJar), targetJar, StandardCopyOption.REPLACE_EXISTING);\n    }\n\n    private static void restoreUserHome(String previousUserHome) {\n        if (previousUserHome == null) {\n            System.clearProperty(\"user.home\");\n        } else {\n            System.setProperty(\"user.home\", previousUserHome);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777972979951}, {"role": "toolResult", "toolCallId": "call_dxnzZB8NB1dkn1ZdxKlAH25L|fc_0cb4ed4b853199510169f9b6f3c0a881a38ce40aa79259160e", "toolName": "bash", "content": [{"type": "text", "text": "diff --git i/tests/src/com.h2database/h2/2.1.210/build.gradle w/tests/src/com.h2database/h2/2.1.210/build.gradle\nindex c44db7e3df..5516442b49 100644\n--- i/tests/src/com.h2database/h2/2.1.210/build.gradle\n+++ w/tests/src/com.h2database/h2/2.1.210/build.gradle\n@@ -9,20 +9,30 @@ plugins {\n }\n \n String libraryVersion = tck.testedLibraryVersion.get()\n+String upgradeLegacyVersion = \"1.4.200\"\n+\n+configurations {\n+    upgradeLegacyH2\n+}\n \n dependencies {\n \ttestImplementation(\"com.h2database:h2:$libraryVersion\")\n \ttestImplementation(\"com.ibm.icu:icu4j:73.2\")\n \ttestImplementation(\"org.assertj:assertj-core:3.22.0\")\n+    upgradeLegacyH2(\"com.h2database:h2:$upgradeLegacyVersion\")\n }\n \n+String upgradeLegacyH2Jar = configurations.upgradeLegacyH2.singleFile.absolutePath\n+\n tasks.named(\"test\") {\n     jvmArgs \"--add-opens=java.base/java.nio=ALL-UNNAMED\"\n     systemProperty \"h2.nioCleanerHack\", \"true\"\n+    systemProperty \"h2.upgrade.oldJar\", upgradeLegacyH2Jar\n }\n \n tasks.named(\"nativeTest\") {\n     runtimeArgs.add(\"-Dh2.nioCleanerHack=true\")\n+    runtimeArgs.add(\"-Dh2.upgrade.oldJar=$upgradeLegacyH2Jar\")\n }\n \n graalvmNative {\n"}], "isError": false, "timestamp": 1777972979956}]}
