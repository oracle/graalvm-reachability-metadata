qKFqYLzz9MqoZ5Xwe_JMiq824Ar4zV6j0d93Zr8Ix_IggWHtLB48oAh_zragXvIPmMqOFYA==\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_udxlVaoAYa3iBvwc4ogPppEl|fc_0c63de0c9d2afd170169f4d1cce23481a287b627a336662220", "name": "write", "arguments": {"path": "tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DefaultAuthenticatorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.UserToRolesMapper;\nimport org.h2.security.auth.DefaultAuthenticator;\nimport org.h2.security.auth.impl.StaticRolesMapper;\nimport org.h2.security.auth.impl.StaticUserCredentialsValidator;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultAuthenticatorTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void configuresRealmValidatorAndRoleMapperFromXml() throws Exception {\n        Path configFile = tempDir.resolve(\"h2auth.xml\");\n        Files.writeString(configFile, \"\"\"\n                <h2Auth allowUserRegistration=\"true\" createMissingRoles=\"false\">\n                    <realm name=\"testRealm\" validatorClass=\"%s\">\n                        <property name=\"userNamePattern\" value=\".*\"/>\n                        <property name=\"password\" value=\"secret\"/>\n                    </realm>\n                    <userToRolesMapper className=\"%s\">\n                        <property name=\"roles\" value=\"admin,reader\"/>\n                    </userToRolesMapper>\n                </h2Auth>\n                \"\"\".formatted(StaticUserCredentialsValidator.class.getName(), StaticRolesMapper.class.getName()),\n                StandardCharsets.UTF_8);\n\n        DefaultAuthenticator authenticator = new DefaultAuthenticator(true);\n        authenticator.configureFromUrl(configFile.toUri().toURL());\n\n        assertThat(authenticator.isAllowUserRegistration()).isTrue();\n        assertThat(authenticator.isCreateMissingRoles()).isFalse();\n        assertThat(authenticator.getUserToRolesMappers()).hasSize(1);\n\n        UserToRolesMapper mapper = authenticator.getUserToRolesMappers().get(0);\n        assertThat(mapper).isInstanceOf(StaticRolesMapper.class);\n        assertThat(mapper.mapUserToRoles(null)).containsExactlyInAnyOrder(\"admin\", \"reader\");\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DefaultAuthenticatorTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage h2;\\n\\nimport org.h2.api.UserToRolesMapper;\\nimport org.h2.security.auth.DefaultAuthenticator;\\nimport org.h2.security.auth.impl.StaticRolesMapper;\\nimport org.h2.security.auth.impl.StaticUserCredentialsValidator;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\n\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class DefaultAuthenticatorTest {\\n    @TempDir\\n    Path tempDir;\\n\\n    @Test\\n    void configuresRealmValidatorAndRoleMapperFromXml() throws Exception {\\n        Path configFile = tempDir.resolve(\\\"h2auth.xml\\\");\\n        Files.writeString(configFile, \\\"\\\"\\\"\\n                <h2Auth allowUserRegistration=\\\"true\\\" createMissingRoles=\\\"false\\\">\\n                    <realm name=\\\"testRealm\\\" validatorClass=\\\"%s\\\">\\n                        <property name=\\\"userNamePattern\\\" value=\\\".*\\\"/>\\n                        <property name=\\\"password\\\" value=\\\"secret\\\"/>\\n                    </realm>\\n                    <userToRolesMapper className=\\\"%s\\\">\\n                        <property name=\\\"roles\\\" value=\\\"admin,reader\\\"/>\\n                    </userToRolesMapper>\\n                </h2Auth>\\n                \\\"\\\"\\\".formatted(StaticUserCredentialsValidator.class.getName(), StaticRolesMapper.class.getName()),\\n                StandardCharsets.UTF_8);\\n\\n        DefaultAuthenticator authenticator = new DefaultAuthenticator(true);\\n        authenticator.configureFromUrl(configFile.toUri().toURL());\\n\\n        assertThat(authenticator.isAllowUserRegistration()).isTrue();\\n        assertThat(authenticator.isCreateMissingRoles()).isFalse();\\n        assertThat(authenticator.getUserToRolesMappers()).hasSize(1);\\n\\n        UserToRolesMapper mapper = authenticator.getUserToRolesMappers().get(0);\\n        assertThat(mapper).isInstanceOf(StaticRolesMapper.class);\\n        assertThat(mapper.mapUserToRoles(null)).containsExactlyInAnyOrder(\\\"admin\\\", \\\"reader\\\");\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3200, "output": 1791, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 30591, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777652154566, "responseId": "resp_0c63de0c9d2afd170169f4d1bb462081a283aaa95269d44e6f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_udxlVaoAYa3iBvwc4ogPppEl|fc_0c63de0c9d2afd170169f4d1cce23481a287b627a336662220", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2174 bytes to tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DefaultAuthenticatorTest.java"}], "isError": false, "timestamp": 1777652176085}]}
