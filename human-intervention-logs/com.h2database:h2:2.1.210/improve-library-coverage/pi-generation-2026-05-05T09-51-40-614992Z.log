          } catch (DbException e) {
              throw DbException.toSQLException(e);
          }
      }
  
      private static void wait(int i) {
          try {
              // sleep at most 4096 ms
              long sleep = (long) i * (long) i;
              Thread.sleep(sleep);
          } catch (InterruptedException e) {
              // ignore
          }
      }
  
