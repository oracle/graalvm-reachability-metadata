      public Server start() throws SQLException {
          try {
              started = true;
              service.start();
              String url = service.getURL();
              int idx = url.indexOf('?');
              if (idx >= 0) {
                  url = url.substring(0, idx);
              }
              String name = service.getName() + " (" + url + ')';
              Thread t = new Thread(this, name);
              t.setDaemon(service.isDaemon());
              t.start();
              for (int i = 1; i < 64; i += i) {
                  wait(i);
                  if (isRunning(false)) {
