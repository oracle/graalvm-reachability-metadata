ltAuthenticator;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.net.URLConnection;\nimport java.net.URLStreamHandler;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collection;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultAuthenticatorTest {\n    @Test\n    void configuresValidatorsAndRoleMappersFromXmlClassNames() throws Exception {\n        String xml = \"\"\"\n                <h2Auth allowUserRegistration=\"true\" createMissingRoles=\"true\">\n                  <realm name=\"test\" validatorClass=\"%s\"/>\n                  <userToRolesMapper className=\"%s\"/>\n                </h2Auth>\n                \"\"\".formatted(AcceptingValidator.class.getName(), FixedRolesMapper.class.getName());\n\n        DefaultAuthenticator authenticator = new DefaultAuthenticator();\n        authenticator.configureFromUrl(inMemoryUrl(xml));\n\n        assertThat(AcceptingValidator.configured).isTrue();\n        assertThat(FixedRolesMapper.configured).isTrue();\n    }\n\n    private static URL inMemoryUrl(String xml) throws IOException {\n        byte[] bytes = xml.getBytes(StandardCharsets.UTF_8);\n        return new URL(null, \"memory:h2-auth.xml\", new URLStreamHandler() {\n            @Override\n            protected URLConnection openConnection(URL url) {\n                return new URLConnection(url) {\n                    @Override\n                    public void connect() {\n                    }\n\n                    @Override\n                    public java.io.InputStream getInputStream() {\n                        return new java.io.ByteArrayInputStream(bytes);\n                    }\n                };\n            }\n        });\n    }\n\n    public static final class AcceptingValidator implements CredentialsValidator {\n        static boolean configured;\n\n        public AcceptingValidator() {\n        }\n\n        @Override\n        