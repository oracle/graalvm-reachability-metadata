ner.created).isTrue();\n        assertThat(RemoteSerializer.created).isTrue();\n    }\n\n    public static final class RemoteListener implements DatabaseEventListener {\n        static boolean created;\n\n        public RemoteListener() {\n            created = true;\n        }\n    }\n\n    public static final class RemoteSerializer implements JavaObjectSerializer {\n        static boolean created;\n\n        public RemoteSerializer() {\n            created = true;\n        }\n\n        @Override\n        public byte[] serialize(Object obj) {\n            return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);\n        }\n\n        @Override\n        public Object deserialize(byte[] bytes) {\n            return new String(bytes, StandardCharsets.UTF_8);\n        }\n    }\n}\n"}
