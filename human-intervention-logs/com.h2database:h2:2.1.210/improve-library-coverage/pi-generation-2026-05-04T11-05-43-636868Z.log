Set.next()).isTrue();\n            }\n        }\n    }\n\n    private static Connection proxyConnection() {\n        return (Connection) Proxy.newProxyInstance(\n                JdbcUtilsTest.class.getClassLoader(),\n                new Class<?>[]{Connection.class},\n                (proxy, method, args) -> switch (method.getName()) {\n                    case \"isClosed\" -> false;\n                    case \"close\" -> null;\n                    case \"unwrap\" -> null;\n                    case \"isWrapperFor\" -> false;\n                    default -> throw new SQLFeatureNotSupportedException(method.getName());\n                });\n    }\n\n    public static final class MockDriver implements Driver {\n        public MockDriver() {\n        }\n\n        @Override\n        public Connection connect(String url, Properties info) {\n            return proxyConnection();\n        }\n\n        @Override\n        public boolean acceptsURL(String url) {\n            return url.startsWith(\"jdbc:h2mock:\");\n        }\n\n        @Override\n        public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {\n            return new DriverPropertyInfo[0];\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 1;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public boolean jdbcCompliant() {\n            return false;\n        }\n\n        @Override\n        public Logger getParentLogger() {\n            return Logger.getGlobal();\n        }\n    }\n\n    public static final class MockContext implements Context {\n        public MockContext() {\n        }\n\n        @Override\n        public Object lookup(String name) {\n            return new MockDataSource();\n        }\n\n        @Override\n        public Object lookup(Name name) {\n            return new MockDataSource();\n        }\n\n        @Override\n        public void close() 