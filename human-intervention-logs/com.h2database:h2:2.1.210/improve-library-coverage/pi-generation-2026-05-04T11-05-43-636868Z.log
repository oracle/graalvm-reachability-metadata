[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/UserAggregateTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.AggregateFunction;\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.ResultSet;\nimport java.sql.Statement;\nimport java.sql.Types;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UserAggregateTest {\n    @Test\n    void instantiatesUserAggregateForSqlAggregateAlias() throws Exception {\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:userAggregate;DB_CLOSE_DELAY=-1\", \"sa\", \"\")) {\n            try (Statement statement = connection.createStatement()) {\n                statement.execute(\"CREATE AGGREGATE SUM_LENGTH FOR '\" + SumLength.class.getName() + \"'\");\n                try (ResultSet resultSet = statement.executeQuery(\"SELECT SUM_LENGTH(x) FROM (VALUES 'a', 'bb') t(x)\")) {\n                    assertThat(resultSet.next()).isTrue();\n                    assertThat(resultSet.getInt(1)).isEqualTo(3);\n                }\n            }\n        }\n    }\n\n    public static final class SumLength implements AggregateFunction {\n        private int sum;\n\n        public SumLength() {\n        }\n\n        @Override\n        public int getType(int[] inputTypes) {\n            return Types.INTEGER;\n        }\n\n        @Override\n        public void add(Object value) {\n            sum += String.valueOf(value).length();\n        }\n\n        @Override\n        public Object getResult() {\n            return sum;\n        }\n    }\n}\n"}
