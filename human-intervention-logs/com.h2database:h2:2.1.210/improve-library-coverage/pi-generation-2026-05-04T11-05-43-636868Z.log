g composeName(String name, String prefix) {\n            return prefix + name;\n        }\n    }\n\n    public static final class MockDataSource implements DataSource {\n        @Override\n        public Connection getConnection() {\n            return proxyConnection();\n        }\n\n        @Override\n        public Connection getConnection(String username, String password) {\n            return proxyConnection();\n        }\n\n        @Override\n        public PrintWriter getLogWriter() {\n            return null;\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) {\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) {\n        }\n\n        @Override\n        public int getLoginTimeout() {\n            return 0;\n        }\n\n        @Override\n        public Logger getParentLogger() {\n            return Logger.getGlobal();\n        }\n\n        @Override\n        public <T> T unwrap(Class<T> iface) throws SQLException {\n            throw new SQLException();\n        }\n\n        @Override\n        public boolean isWrapperFor(Class<?> iface) {\n            return false;\n        }\n    }\n\n    private static final class SQLFeatureNotSupportedException extends SQLException {\n        SQLFeatureNotSupportedException(String reason) {\n            super(reason);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 626, "output": 2002, "cacheRead": 59392, "cacheWrite": 0, "totalTokens": 62020, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777892363081, "responseId": "resp_0862332e2fffc54b0169f87c0be61081a095a6fc53abd72422"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_axzl1pRdYq0gFICmr8m5vn6j|fc_0862332e2fffc54b0169f87c0cccd481a0ae81407a7bc263eb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 8720 bytes to tests/src/com.h2