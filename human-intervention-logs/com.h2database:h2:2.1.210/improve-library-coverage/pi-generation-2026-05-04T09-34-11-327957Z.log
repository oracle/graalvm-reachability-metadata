  package h2;
  
  import org.h2.api.DatabaseEventListener;
  import org.h2.api.JavaObjectSerializer;
  import org.h2.tools.Server;
  import org.junit.jupiter.api.Test;
  
  import java.nio.charset.StandardCharsets;
  import java.sql.Connection;
  import java.sql.DriverManager;
  import java.sql.ResultSet;
  import java.sql.SQLException;
  import java.sql.Statement;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SessionRemoteTest {
      @Test
      void remoteSessionInstantiatesUrlListenerAndDynamicSettingsSerializer() throws Exception {
          CountingDatabaseEventListener.constructed = 0;
          CountingJavaObjectSerializer.constructed = 0;
          Server server = Server.createTcpServer("-tcpPort", "0", "-tcpDaemon", "-ifNotExists").start();
          try {
              String url = "jdbc:h2:tcp://localhost:" + server.getPort() + "/mem:session-remote"
                      + ";AUTO_RECONNECT=TRUE"
                      + ";DATABASE_EVENT_LISTENER='" + CountingDatabaseEventListener.class.getName() + "'"
                      + ";JAVA_OBJECT_SERIALIZER='" + CountingJavaObjectSerializer.class.getName() + "'";
              try (Connection connection = DriverManager.getConnection(url);
                      Statement statement = connection.createStatement();
                      ResultSet resultSet = statement.executeQuery("SELECT CURRENT_TIMESTAMP")) {
                  assertThat(resultSet.next()).isTrue();
              }
          } finally {
              server.stop();
          }
  
          assertThat(CountingDatabaseEventListener.constructed).isPositive();
          assertThat(CountingJavaObjectSerializer.constructed).isPositive();
      }
  
      public static final class CountingDatabaseEventListener implements DatabaseEventListener {
          static int constructed;
  
          public CountingDatabaseEventListener() {
              constructed++;
          }
  
          @Override
          public void init(String url) {
          }
  
          @Override
          public void exceptionThrown(SQLException e, String sql) {
          }
      }
  
      public static final class CountingJavaObjectSerializer implements JavaObjectSerializer {
          static int constructed;
  
          public CountingJavaObjectSerializer() {
              constructed++;
          }
  
          @Override
          public byte[] serialize(Object obj) {
              return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);
          }
  
          @Override
          public Object deserialize(byte[] bytes) {
              return new String(bytes, StandardCharsets.UTF_8);
          }
      }
  }
