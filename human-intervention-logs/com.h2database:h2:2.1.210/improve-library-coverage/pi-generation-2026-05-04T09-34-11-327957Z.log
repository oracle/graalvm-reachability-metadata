  /*
   * Copyright and related rights waived via CC0
   */
  package h2;
  
  import org.h2.api.DatabaseEventListener;
  import org.h2.api.JavaObjectSerializer;
  import org.h2.api.TableEngine;
  import org.h2.command.ddl.CreateTableData;
  import org.h2.table.Table;
  import org.junit.jupiter.api.Test;
  
  import java.nio.charset.StandardCharsets;
  import java.sql.Connection;
  import java.sql.DriverManager;
  import java.sql.PreparedStatement;
  import java.sql.SQLException;
  import java.sql.Statement;
  import java.sql.Types;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DatabaseTest {
      @Test
      void databaseEventListenerIsInstantiatedFromUrl() throws Exception {
          NoOpDatabaseEventListener.initializedUrl = null;
  
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:database-listener;"
                  + "DATABASE_EVENT_LISTENER='" + NoOpDatabaseEventListener.class.getName() + "'")) {
              assertThat(connection.isClosed()).isFalse();
          }
  
          assertThat(NoOpDatabaseEventListener.initializedUrl).contains("database-listener");
      }
  
      @Test
      void javaObjectSerializerIsInstantiatedFromUrl() throws Exception {
          Utf8JavaObjectSerializer.serializeCount = 0;
  
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:database-serializer;"
                  + "JAVA_OBJECT_SERIALIZER='" + Utf8JavaObjectSerializer.class.getName() + "'");
                  Statement statement = connection.createStatement()) {
              statement.execute("CREATE TABLE objects(object_value JAVA_OBJECT)");
              try (PreparedStatement preparedStatement = connection.prepareStatement("INSERT INTO objects VALUES (?)")) {
                  preparedStatement.setObject(1, "serialized", Types.JAVA_OBJECT);
                  preparedStatement.executeUpdate();
              }
          }
  
          assertThat(Utf8JavaObjectSerializer.serializeCount).isPositive();
      }
  
      @Test
      void tableEngineIsInstantiatedFromCreateTableStatement() throws Exception {
          FailingTableEngine.constructed = false;
  
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:database-table-engine;DB_CLOSE_DELAY=-1");
                  Statement statement = connection.createStatement()) {
              try {
                  statement.execute("CREATE TABLE custom_engine(id INT) ENGINE \"" + FailingTableEngine.class.getName()
                          + "\"");
              } catch (SQLException exception) {
                  assertThat(exception).isNotNull();
              }
          }
  
          assertThat(FailingTableEngine.constructed).isTrue();
      }
  
      public static final class NoOpDatabaseEventListener implements DatabaseEventListener {
          static String initializedUrl;
  
          public NoOpDatabaseEventListener() {
          }
  
          @Override
          public void init(String url) {
              initializedUrl = url;
          }
  
          @Override
          public void exceptionThrown(SQLException e, String sql) {
          }
      }
  
      public static final class Utf8JavaObjectSerializer implements JavaObjectSerializer {
          static int serializeCount;
  
          public Utf8JavaObjectSerializer() {
          }
  
          @Override
          public byte[] serialize(Object obj) {
              serializeCount++;
              return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);
          }
  
          @Override
          public Object deserialize(byte[] bytes) {
              return new String(bytes, StandardCharsets.UTF_8);
          }
      }
  
      public static final class FailingTableEngine implements TableEngine {
          static boolean constructed;
  
          public FailingTableEngine() {
              constructed = true;
          }
  
          @Override
          public Table createTable(CreateTableData data) {
              return null;
          }
      }
  }
