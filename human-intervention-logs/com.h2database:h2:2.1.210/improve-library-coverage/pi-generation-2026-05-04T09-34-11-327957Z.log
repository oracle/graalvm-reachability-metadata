   */
  package h2;
  
  import org.h2.util.Utils;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UtilsTest {
      @Test
      void reflectiveUtilityMethodsReachUserSuppliedTargets() throws Exception {
          assertThat(Utils.callStaticMethod("h2.UtilsTest$Target.staticValue", "abc")).isEqualTo("ABC");
          assertThat(Utils.callMethod(new Target("prefix"), "combine", "suffix")).isEqualTo("prefix-suffix");
          assertThat(Utils.newInstance("h2.UtilsTest$Target", "created")).hasToString("created");
      }
  
      @Test
      void resourceLoaderReadsBundledZipEntry() throws Exception {
          byte[] resource = Utils.getResource("/org/h2/res/help.csv");
  
          assertThat(resource).isNotNull().isNotEmpty();
      }
  
      @Test
      void scalesByAvailableMemory() {
          assertThat(Utils.scaleForAvailableMemory(1024)).isGreaterThanOrEqualTo(0);
      }
  
      public static final class Target {
          private final String value;
  
          public Target(String value) {
              this.value = value;
          }
  
          public static String staticValue(String value) {
              return value.toUpperCase();
          }
  
          public String combine(String suffix) {
              return value + '-' + suffix;
          }
  
          @Override
          public String toString() {
              return value;
          }
      }
  }
