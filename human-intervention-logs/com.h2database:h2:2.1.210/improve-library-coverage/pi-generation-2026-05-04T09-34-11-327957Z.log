n        assertThat(resource).isNotNull().isNotEmpty();\n    }\n\n    @Test\n    void scalesByAvailableMemory() {\n        assertThat(Utils.scaleForAvailableMemory(1024)).isGreaterThanOrEqualTo(0);\n    }\n\n    public static final class Target {\n        private final String value;\n\n        public Target(String value) {\n            this.value = value;\n        }\n\n        public static String staticValue(String value) {\n            return value.toUpperCase();\n        }\n\n        public String combine(String suffix) {\n            return value + '-' + suffix;\n        }\n\n        @Override\n        public String toString() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777886897751}, {"role": "toolResult", "toolCallId": "call_EEb6pUklKn8L7wCDlWI5GKLL|fc_036c189a9a94e45e0169f866b1857c819f9ffce9fa913cc737", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n */\npackage h2;\n\nimport org.h2.api.Trigger;\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.Statement;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TriggerObjectTest {\n    @Test\n    void triggerClassIsInstantiatedWhenCreated() throws Exception {\n        CountingTrigger.fireCount = 0;\n\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:trigger-object;DB_CLOSE_DELAY=-1\");\n                Statement statement = connection.createStatement()) {\n            statement.execute(\"CREATE TABLE events(id INT)\");\n            statement.execute(\"CREATE TRIGGER events_insert AFTER INSERT ON events FOR EACH ROW CALL '\"\n                    + CountingTrigger.class.getName() + \"'\");\n            statement.execute(\"INSERT INTO events VALUES (1)\");\n        }\n\n        assertThat(CountingTrigger.fireCount).isEqualTo(1);\n    }\n\n    public static final class CountingTrigger implements Trigger {\n        static int fireCount;\n\n        public CountingTrigger() {\n        }\n\n        @Override\n        public void fire(Connection conn, Object[] oldRow, Object[] newRow) {\n            fireCount++;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777886897752}, {"role": "toolResult", "toolCallId": "call_Ok6kfsgPQYdAog2ohId4z16a|fc_036c189a9a94e45e0169f866b18588819fb7b6496a5310d948", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n */\npackage h2;\n\nimport org.h2.message.TraceSystem;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.nio.file.Path;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TraceSystemTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void adapterTraceWriterIsInstantiatedWhenFileLevelUsesAdapter() {\n        TraceSystem traceSystem = new TraceSystem(tempDir.resolve(\"trace.trace.db\").toString());\n\n        traceSystem.setLevelFile(TraceSystem.ADAPTER);\n\n        assertThat(traceSystem).isNotNull();\n    }\n}\n"}], "isError": false, "timestamp": 1777886897752}, {"role": "toolResult", "toolCallId": "call_4vgyFn3pHS7iFP6zNyNyLPib|fc_036c189a9a94e45e0169f866b18590819f91425c65a75a2c51", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n\ttestImplementation(\"com.h2database:h2:$libraryVersion\")\n\ttestImplementation(\"org.assertj:assertj-core:3.22.0\")\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n          