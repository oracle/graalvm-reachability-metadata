  package h2;
  
  import org.h2.api.Trigger;
  import org.junit.jupiter.api.Test;
  
  import java.sql.Connection;
  import java.sql.DriverManager;
  import java.sql.Statement;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TriggerObjectTest {
      @Test
      void instantiatesTriggerClassWhenTableIsModified() throws Exception {
          CountingTrigger.fireCount = 0;
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:triggerObject;DB_CLOSE_DELAY=-1", "sa", "")) {
              try (Statement statement = connection.createStatement()) {
                  statement.execute("CREATE TABLE events(id INT)");
                  statement.execute("CREATE TRIGGER events_insert AFTER INSERT ON events FOR EACH ROW CALL '"
                          + CountingTrigger.class.getName() + "'");
                  statement.execute("INSERT INTO events VALUES (1)");
              }
          }
          assertThat(CountingTrigger.fireCount).isEqualTo(1);
      }
  
      public static final class CountingTrigger implements Trigger {
          static int fireCount;
  
          public CountingTrigger() {
          }
  
          @Override
          public void fire(Connection conn, Object[] oldRow, Object[] newRow) {
              fireCount++;
          }
      }
  }
