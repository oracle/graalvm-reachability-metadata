uld have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.util.MemoryUnmapper;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.ByteBuffer;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MemoryUnmapperTest {\n    @Test\n    void attemptsToUnmapDirectByteBuffer() {\n        boolean unmapped = MemoryUnmapper.unmap(ByteBuffer.allocateDirect(16));\n\n        assertThat(unmapped).isIn(true, false);\n    }\n}\n"}], "isError": false, "timestamp": 1777897826807}, {"role": "toolResult", "toolCallId": "call_pptGNfykrdRNgn1JZVn6Uu3Q|fc_02928e0d39233fc60169f8916272048192b6447182fe6c5a6f", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.h2.util.SourceCompiler;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SourceCompilerTest {\n    @Test\n    void compilesSourceAndReturnsPublicStaticMethod() throws Exception {\n        SourceCompiler compiler = new SourceCompiler();\n        compiler.setSource(\"h2.dynamic.GeneratedFunction\", \"\"\"\n                int answer() {\n                    return 42;\n                }\n                \"\"\");\n        try {\n            Method method = compiler.getMethod(\"h2.dynamic.GeneratedFunction\");\n\n            assertThat(method.invoke(null)).isEqualTo(42);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777897826807}, {"role": "toolResult", "toolCallId": "call_bOAPWtjkNtri8E7bQFyVol52|fc_02928e0d39233fc60169f89162721481928012e1e770d45ddf", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.api.DatabaseEventListener;\nimport org.h2.api.JavaObjectSerializer;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.charset.StandardCharsets;\nimport java.sql.Connection;\nimport java.sql.DriverManager;\nimport java.sql.PreparedStatement;\nimport java.sql.SQLException;\nimport java.sql.Statement;\nimport java.sql.Types;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DatabaseTest {\n    @Test\n    void instantiatesConfiguredDatabaseEventListenerAndJavaObjectSerializer() throws Exception {\n        String url = \"jdbc:h2:mem:databaseDynamicAccess;DATABASE_TO_UPPER=false;\"\n                + \"DATABASE_EVENT_LISTENER='\" + Listener.class.getName() + \"';\"\n                + \"JAVA_OBJECT_SERIALIZER='\" + Serializer.class.getName() + \"'\";\n        try (Connection connection = DriverManager.getConnection(url, \"sa\", \"\")) {\n            try (Statement statement = connection.createStatement()) {\n                statement.execute(\"CREATE TABLE serialized_payload(data_value JAVA_OBJECT)\");\n                try (PreparedStatement preparedStatement = connection.prepareStatement(\"INSERT INTO serialized_payload VALUES (?)\")) {\n                    preparedStatement.setObject(1, \"payload\", Types.JAVA_OBJECT);\n                    preparedStatement.executeUpdate();\n                }\n                statement.execute(\"SELECT 1\");\n            }\n        }\n        assertThat(Listener.initialized).isTrue();\n        assertThat(Serializer.created).isTrue();\n    }\n\n    public static final class Listener implements DatabaseEventListener {\n        static boolean initialized;\n\n        public Listener() {\n        }\n\n        @Override\n        public void init(String url) {\n            initialized = true;\n        }\n\n        @Override\n        public void exceptionThrown(SQLException e, String sql) {\n        }\n    }\n\n    public static final class Serializer implements JavaObjectSerializer {\n        static boolean created;\n\n        public Serializer() {\n            created = true;\n        }\n\n        @Override\n        public byte[] serialize(Object obj) {\n            return String.valueOf(obj).getBytes(StandardCharsets.UTF_8);\n        }\n\n        @Override\n        public Object deserialize(byte[] bytes) {\n            return new String(bytes, StandardCharsets.UTF_8);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777897826807}, {"role": "toolResult", "toolCallId": "call_14zm1nO7PaEZfKXurtvErw3V|fc_02928e0d39233fc60169f89162721c81928fb7e77a55868bc6", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.util.JdbcUtils;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.PrintWriter;\nimport java.lang.reflect.Proxy;\nimport java.sql.Connection;\nimport java.sql.Driver;\nimport java.sql.DriverPropertyInfo;\nimport java.sql.ResultSet;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.Hashtable;\nimport java.util.Properties;\nimport java.util.logging.Logger;\nimport javax.naming.Binding;\nimport javax.naming.Context;\nimport javax.naming.Name;\nimport javax.naming.NameClassPair;\nimport javax.naming.NameParser;\nimport javax.naming.NamingEnumeration;\nimport javax.naming.NamingException;\nimport javax.sql.DataSource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JdbcUtilsTest {\n    @Test\n    void loadsUserClassAndBuildsConnectionsThroughDriverAndJndiBranches() throws Exception {\n        assertThat(JdbcUtils.loadUserClass(MockDriver.class.getName())).isSameAs(MockDriver.class);\n\n        try (Connection connection = JdbcUtils.getConnection(MockDriver.class.getName(), \"jdbc:h2mock:\", \"sa\", \"\")) {\n            assertThat(connection.isClosed()).isFalse();\n        }\n\n        try (Connection connection = JdbcUtils.getConnection(MockContext.class.getName(), \"java:h2mock\", null, null)) {\n            assertThat(connection.isClosed()).isFalse();\n        }\n    }\n\n    @Test\n    void collectsDatabaseMetadataWithReflection() throws Exception {\n        try (Connection connection = JdbcUtils.getConnection(null, \"jdbc:h2:mem:jdbcUtils;DB_CLOSE_DELAY=-1\", \"sa\", \"\")) {\n            try (ResultSet resultSet = JdbcUtils.getMetaResultSet(connection, \"@info\")) {\n                assertThat(resultSet.next()).isTrue();\n            }\n        }\n    }\n\n    private static Connection proxyConnection() {\n        return (Connection) Proxy.newProxyInstance(\n                JdbcUtilsTest.class.getClassLoader(),\n                new Class<?>[]{Connection.class},\n                (proxy, method, args) -> switch (method.getName()) {\n                    case \"isClosed\" -> false;\n                    case \"close\" -> null;\n                    case \"unwrap\" -> null;\n                    case \"isWrapperFor\" -> false;\n                    default -> throw new SQLFeatureNotSupportedException(method.getName());\n                });\n    }\n\n    public static final class MockDriver implements Driver {\n        public MockDriver() {\n        }\n\n        @Override\n        public Connection connect(String url, Properties info) {\n            return proxyConnection();\n        }\n\n        @Override\n        public boolean acceptsURL(String url) {\n            return url.startsWith(\"jdbc:h2mock:\");\n        }\n\n        @Override\n        public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {\n            return new DriverPropertyInfo[0];\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 1;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public boolean jdbcCompliant() {\n            return false;\n        }\n\n        @Override\n        public Logger getParentLogger() {\n            return Logger.getGlobal();\n        }\n    }\n\n    public static final class MockContext implements Context {\n        public MockContext() {\n        }\n\n        @Override\n        public Object lookup(String name) {\n            return new MockDataSource();\n        }\n\n        @Override\n        public Object lookup(Name name) {\n            return new MockDataSource();\n        }\n\n        @Override\n        public void close() {\n        }\n\n        @Override\n        public String getNameInNamespace() {\n            return \"\";\n        }\n\n        @Override\n        public Object addToEnvironment(String propName, Object propVal) {\n            return null;\n        }\n\n        @Override\n        public Object removeFromEnvironment(String propName) {\n            return null;\n        }\n\n        @Override\n        public Hashtable<?, ?> getEnvironment() {\n            return new Hashtable<>();\n        }\n\n        @Override\n        public void bind(Name name, Object obj) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void bind(String name, Object obj) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void rebind(Name name, Object obj) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void rebind(String name, Object obj) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void unbind(Name name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void unbind(String name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void rename(Name oldName, Name newName) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void rename(String oldName, String newName) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public NamingEnumeration<NameClassPair> list(Name name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public NamingEnumeration<NameClassPair> list(String name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public NamingEnumeration<Binding> listBindings(Name name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public NamingEnumeration<Binding> listBindings(String name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void destroySubcontext(Name name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public void destroySubcontext(String name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public Context createSubcontext(Name name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public Context createSubcontext(String name) throws NamingException {\n            throw new NamingException();\n        }\n\n        @Override\n        public Object lookupLink(Name name) throws Naming