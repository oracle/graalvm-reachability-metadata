      public static void closeSilently(Connection conn) {
          if (conn != null) {
              try {
                  conn.close();
              } catch (SQLException e) {
                  // ignore
              }
          }
      }
  
      /**
       * Close a result set without throwing an exception.
       *
       * @param rs the result set or null
       */
      public static void closeSilently(ResultSet rs) {
          if (rs != null) {
              try {
                  rs.close();
              } catch (SQLException e) {
                  // ignore
              }
          }
      }
  
