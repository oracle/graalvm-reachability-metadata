  package h2;
  
  import org.h2.value.CompareMode;
  import org.junit.jupiter.api.Test;
  
  import java.text.Collator;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CompareModeIcu4JTest {
      @Test
      void createsIcu4jCompareModeThroughOptionalCollatorApi() {
          CompareMode compareMode = CompareMode.getInstance(CompareMode.ICU4J + "en_US", Collator.PRIMARY);
          CompareMode localeListCompareMode = CompareMode.getInstance(CompareMode.ICU4J + "ENGLISH", Collator.SECONDARY);
  
          assertThat(compareMode.compareString("a", "b", false)).isLessThan(0);
          assertThat(compareMode.compareString("a", "A", true)).isGreaterThan(0);
          assertThat(localeListCompareMode.compareString("a", "b", false)).isLessThan(0);
      }
  }
