  package h2;
  
  import org.h2.store.fs.FilePath;
  import org.junit.jupiter.api.Test;
  
  import java.io.InputStream;
  import java.nio.charset.StandardCharsets;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FilePathDiskTest {
      @Test
      void readsClasspathResourceThroughDiskFilePath() throws Exception {
          FilePath path = FilePath.get("classpath:h2-classpath-resource.txt");
  
          assertThat(path.size()).isGreaterThan(0L);
          try (InputStream inputStream = path.newInputStream()) {
              assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).contains("resource loaded");
          }
      }
  }
