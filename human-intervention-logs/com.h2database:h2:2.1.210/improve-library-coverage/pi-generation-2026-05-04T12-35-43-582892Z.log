o/1.0/>.\n */\npackage h2;\n\nimport org.h2.store.fs.FilePath;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FilePathDiskTest {\n    @Test\n    void readsClasspathResourceThroughDiskFilePath() throws Exception {\n        FilePath path = FilePath.get(\"classpath:h2-classpath-resource.txt\");\n\n        assertThat(path.size()).isGreaterThan(0L);\n        try (InputStream inputStream = path.newInputStream()) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).contains(\"resource loaded\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777897829174}, {"role": "toolResult", "toolCallId": "call_gWS7MA5guYjUcait1ynqWKA7|fc_02928e0d39233fc60169f89164eab08192be70b84be8d808e1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.message.TraceSystem;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TraceSystemTest {\n    @Test\n    void createsTraceWriterAdapterForAdapterLevel() {\n        TraceSystem traceSystem = new TraceSystem(null);\n\n        traceSystem.setLevelFile(TraceSystem.ADAPTER);\n\n        assertThat(traceSystem.getLevelFile()).isIn(TraceSystem.ERROR, TraceSystem.ADAPTER);\n    }\n}\n"}], "isError": false, "timestamp": 1777897829174}, {"role": "toolResult", "toolCallId": "call_uYRFBTltpxu21rMoKpVRuVsP|fc_02928e0d39233fc60169f89164eab88192b38c5be4765113d3", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://cr