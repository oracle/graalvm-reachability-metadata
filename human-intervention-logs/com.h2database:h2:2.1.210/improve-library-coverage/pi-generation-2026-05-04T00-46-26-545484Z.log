import java.sql.SQLException;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UserAggregateTest {\n    @Test\n    void instantiatesAggregateImplementation() throws Exception {\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:user_aggregate;DB_CLOSE_DELAY=-1\")) {\n            connection.createStatement().execute(\"CREATE AGGREGATE SUM_PLUS_ONE FOR '\" + SumPlusOne.class.getName()\n                    + \"'\");\n            connection.createStatement().execute(\"CREATE TABLE values_table(value INT)\");\n            connection.createStatement().execute(\"INSERT INTO values_table VALUES (1), (2), (3)\");\n            try (ResultSet resultSet = connection.createStatement()\n                    .executeQuery(\"SELECT SUM_PLUS_ONE(value) FROM values_table\")) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getInt(1)).isEqualTo(7);\n            }\n        }\n    }\n\n    public static final class SumPlusOne implements AggregateFunction {\n        private int sum = 1;\n\n        @Override\n        public void init(Connection conn) {\n        }\n\n        @Override\n        public int getType(int[] inputTypes) {\n            return java.sql.Types.INTEGER;\n        }\n\n        @Override\n        public void add(Object value) {\n            if (value instanceof Number number) {\n                sum += number.intValue();\n            }\n        }\n\n        @Override\n        public Object getResult() {\n            return sum;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 517, "output": 521, "cacheRead": 62976, "cacheWrite": 0, "totalTokens": 64014, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777855376141, "responseId": "resp_00e34745d23d0c090169f7eb90fa44819197db3dbf5a8e03cd"}, "toolResults": [{"role": "toolResult", "toolCal