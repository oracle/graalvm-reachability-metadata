[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/UtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.util.Utils;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.charset.StandardCharsets;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UtilsTest {\n    @Test\n    void invokesPublicUtilityReflectionHelpers() throws Exception {\n        Object upper = Utils.callStaticMethod(UtilityTarget.class.getName() + \".upper\", \"h2\");\n        Object repeated = Utils.callMethod(new UtilityTarget(\"ha\"), \"repeat\", 3);\n        Object constructed = Utils.newInstance(UtilityTarget.class.getName(), \"created\");\n\n        assertThat(upper).isEqualTo(\"H2\");\n        assertThat(repeated).isEqualTo(\"hahaha\");\n        assertThat(constructed).hasToString(\"created\");\n    }\n\n    @Test\n    void loadsResourceFromH2UtilityResourceLookup() throws Exception {\n        byte[] data = Utils.getResource(\"/h2/h2-resource.txt\");\n\n        assertThat(new String(data, StandardCharsets.UTF_8)).contains(\"h2 dynamic resource\");\n    }\n\n    @Test\n    void scalesForAvailableMemory() {\n        assertThat(Utils.scaleForAvailableMemory(1)).isGreaterThanOrEqualTo(0);\n    }\n\n    public static final class UtilityTarget {\n        private final String value;\n\n        public UtilityTarget(String value) {\n            this.value = value;\n        }\n\n        public static String upper(String value) {\n            return value.toUpperCase();\n        }\n\n        public String repeat(Integer count) {\n            return value.repeat(count);\n        }\n\n        @Override\n        public String toString() {\n            return value;\n        }\n    }\n}\n"}
