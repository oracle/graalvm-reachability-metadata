[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DefaultAuthenticatorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.security.auth.DefaultAuthenticator;\nimport org.junit.jupiter.api.Test;\n\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultAuthenticatorTest {\n    @Test\n    void configuresValidatorsAndRoleMappersFromXml() throws Exception {\n        Path config = Files.createTempFile(\"h2-auth\", \".xml\");\n        Files.writeString(config, \"\"\"\n                <h2Auth allowUserRegistration=\"true\" createMissingRoles=\"true\">\n                  <realm name=\"test\" validatorClass=\"org.h2.security.auth.impl.StaticUserCredentialsValidator\">\n                    <property name=\"userNamePattern\" value=\".+\"/>\n                    <property name=\"password\" value=\"secret\"/>\n                  </realm>\n                  <userToRolesMapper className=\"org.h2.security.auth.impl.AssignRealmNameRole\"/>\n                </h2Auth>\n                \"\"\", StandardCharsets.UTF_8);\n\n        DefaultAuthenticator authenticator = new DefaultAuthenticator(false);\n        authenticator.configureFromUrl(config.toUri().toURL());\n\n        assertThat(authenticator.isAllowUserRegistration()).isTrue();\n        assertThat(authenticator.isCreateMissingRoles()).isTrue();\n        Files.deleteIfExists(config);\n    }\n}\n"}
