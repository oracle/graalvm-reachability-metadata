              if (paramCount > 0) {
                  Class<?> lastArg = paramClasses[paramClasses.length - 1];
                  if (lastArg.isArray() && method.isVarArgs()) {
                      varArgs = true;
                      varArgClass = lastArg.getComponentType();
                  }
