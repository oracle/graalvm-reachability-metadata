                      }
                  }
              } catch (SecurityException e) {
                  // workaround for the Google App Engine: don't use a thread
                  runnable.run();
                  generateAlternativeSeed();
              }
  
          } catch (Exception e) {
              // NoSuchAlgorithmException
              warn("SecureRandom", e);
              secureRandom = new SecureRandom();
          }
          return secureRandom;
      }
  
  
