[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/ObjectDataTypeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage h2;\n\nimport org.h2.mvstore.type.ObjectDataType;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectDataTypeTest {\n    @Test\n    void serializesAndDeserializesJavaObjectValues() {\n        String value = \"serialized value\";\n\n        byte[] serialized = ObjectDataType.serialize(value);\n        Object deserialized = ObjectDataType.deserialize(serialized);\n\n        assertThat(serialized).startsWith((byte) 0xAC, (byte) 0xED);\n        assertThat(deserialized).isEqualTo(value);\n    }\n}\n"}
