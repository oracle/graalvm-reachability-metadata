is test\");\n        }\n\n        @Override\n        public boolean isTraySupported() {\n            return false;\n        }\n\n        @Override\n        public KeyboardFocusManagerPeer getKeyboardFocusManagerPeer() {\n            return KEYBOARD_FOCUS_MANAGER_PEER;\n        }\n\n        @Override\n        protected boolean syncNativeQueue(long timeout) {\n            return false;\n        }\n\n        @Override\n        public void grab(Window window) {\n        }\n\n        @Override\n        public void ungrab(Window window) {\n        }\n\n        @Override\n        public boolean isTaskbarSupported() {\n            return false;\n        }\n    }\n\n    private static final class RecordingDesktopPeer implements DesktopPeer {\n        private static final RecordingDesktopPeer INSTANCE = new RecordingDesktopPeer();\n        private static final AtomicReference<URI> BROWSED_URI = new AtomicReference<>();\n\n        static void reset() {\n            BROWSED_URI.set(null);\n        }\n\n        static URI browsedUri() {\n            return BROWSED_URI.get();\n        }\n\n        @Override\n        public boolean isSupported(Desktop.Action action) {\n            return action == Desktop.Action.BROWSE;\n        }\n\n        @Override\n        public void open(File file) {\n            throw new UnsupportedOperationException(\"Opening files is not used by this test\");\n        }\n\n        @Override\n        public void edit(File file) {\n            throw new UnsupportedOperationException(\"Editing files is not used by this test\");\n        }\n\n        @Override\n        public void print(File file) {\n            throw new UnsupportedOperationException(\"Printing files is not used by this test\");\n        }\n\n        @Override\n        public void mail(URI mailtoURL) {\n            throw new UnsupportedOperationException(\"Mail is not used by this test\");\n        }\n\n        @Override\n        public void browse(URI uri) {\n            BROWSED_URI.set(ur