ublic Boolean get() {\n                    MemoryUnmapper.unmap(ByteBuffer.allocateDirect(16));\n                    return Boolean.TRUE;\n                }\n            }\n            \"\"\";\n\n    @Test\n    void unmapRejectsHeapBuffersWithoutThrowing() {\n        ByteBuffer buffer = ByteBuffer.allocate(16);\n\n        boolean unmapped = MemoryUnmapper.unmap(buffer);\n\n        assertThat(unmapped).isFalse();\n        assertThat(buffer.capacity()).isEqualTo(16);\n    }\n\n    @Test\n    void unmapAttemptsToCleanDirectBuffers() {\n        ByteBuffer buffer = ByteBuffer.allocateDirect(16);\n        buffer.putInt(42);\n\n        assertThatCode(() -> MemoryUnmapper.unmap(buffer)).doesNotThrowAnyException();\n    }\n\n    @Test\n    void unmapUsesLegacyCleanerFallbackWhenUnsafeDoesNotExposeInvokeCleaner() throws Exception {\n        assertDynamicClassLoading(() -> {\n            Path classesDirectory = compileLegacyFallbackFixture();\n\n            try (LegacyFallbackClassLoader classLoader = new LegacyFallbackClassLoader(\n                    new URL[] { classesDirectory.toUri().toURL() })) {\n                ServiceLoader<Supplier> serviceLoader = ServiceLoader.load(Supplier.class, classLoader);\n                Supplier exercise = serviceLoader.findFirst().orElseThrow();\n\n                Object result = exercise.get();\n\n                assertThat(result).isEqualTo(Boolean.TRUE);\n            }\n        });\n    }\n\n    private static Path compileLegacyFallbackFixture() throws Exception {\n        Path sourcesDirectory = Files.createTempDirectory(\"h2-memory-unmapper-source\");\n        Path classesDirectory = Files.createTempDirectory(\"h2-memory-unmapper-classes\");\n        List<Path> sources = Arrays.asList(\n                writeSource(sourcesDirectory, \"org/h2/util/MemoryUnmapper.java\", MEMORY_UNMAPPER_SOURCE),\n                writeSource(sourcesDirectory, \"org/h2/engine/SysProperties.java\", SYS_PROPERTIES_SOURCE),\n                writeSource(source