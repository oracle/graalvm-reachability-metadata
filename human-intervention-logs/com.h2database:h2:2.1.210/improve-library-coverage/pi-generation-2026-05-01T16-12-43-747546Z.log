          }
      }
  
      private char[] removePassword() {
          Object p = prop.remove("PASSWORD");
          preservePasswordForAuthentication(p);
          if (p == null) {
              return new char[0];
          } else if (p instanceof char[]) {
              return (char[]) p;
          } else {
  
