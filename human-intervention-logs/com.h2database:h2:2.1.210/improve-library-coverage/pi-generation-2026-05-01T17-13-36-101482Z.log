  package h2;
  
  import org.h2.engine.SysProperties;
  import org.h2.tools.Server;
  import org.junit.jupiter.api.AfterAll;
  import org.junit.jupiter.api.BeforeAll;
  import org.junit.jupiter.api.Test;
  
  import sun.awt.LightweightFrame;
  import sun.awt.SunToolkit;
  
  import java.awt.AWTException;
  import java.awt.Component;
  import java.awt.Desktop;
  import java.awt.SystemTray;
  import java.awt.TrayIcon;
  import java.awt.Window;
  import java.awt.peer.DesktopPeer;
  import java.awt.peer.FramePeer;
  import java.awt.peer.KeyboardFocusManagerPeer;
  import java.awt.peer.SystemTrayPeer;
  import java.awt.peer.TrayIconPeer;
  import java.io.File;
  import java.net.URI;
  import java.util.concurrent.atomic.AtomicReference;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ServerTest {
      private static final String HEADLESS_PROPERTY = "java.awt.headless";
      private static final String TOOLKIT_PROPERTY = "awt.toolkit";
  
      private static String previousBrowser;
      private static String previousHeadless;
      private static String previousToolkit;
  
      @BeforeAll
      static void configureDesktopToolkit() {
          previousBrowser = System.clearProperty(SysProperties.H2_BROWSER);
          previousHeadless = System.setProperty(HEADLESS_PROPERTY, "false");
          previousToolkit = System.setProperty(TOOLKIT_PROPERTY, RecordingToolkit.class.getName());
      }
  
      @AfterAll
      static void restoreProperties() {
          restoreProperty(SysProperties.H2_BROWSER, previousBrowser);
          restoreProperty(HEADLESS_PROPERTY, previousHeadless);
          restoreProperty(TOOLKIT_PROPERTY, previousToolkit);
      }
  
      @Test
      void openBrowserUsesDesktopBrowseWhenNoBrowserCommandIsConfigured() throws Exception {
          URI expectedUri = URI.create("https://localhost/h2-console");
          RecordingDesktopPeer.reset();
  
          Server.openBrowser(expectedUri.toString());
  
          assertThat(RecordingDesktopPeer.browsedUri()).isEqualTo(expectedUri);
      }
  
      private static void restoreProperty(String property, String value) {
          if (value == null) {
              System.clearProperty(property);
          } else {
              System.setProperty(property, value);
          }
      }
  
      public static final class RecordingToolkit extends SunToolkit {
          private static final KeyboardFocusManagerPeer KEYBOARD_FOCUS_MANAGER_PEER = new KeyboardFocusManagerPeer() {
              @Override
              public void setCurrentFocusedWindow(Window window) {
              }
  
              @Override
              public Window getCurrentFocusedWindow() {
                  return null;
              }
  
              @Override
              public void setCurrentFocusOwner(Component component) {
              }
  
              @Override
              public Component getCurrentFocusOwner() {
                  return null;
              }
  
              @Override
              public void clearGlobalFocusOwner(Window window) {
              }
          };
  
          @Override
          public DesktopPeer createDesktopPeer(Desktop target) {
              return RecordingDesktopPeer.INSTANCE;
          }
  
          @Override
          public boolean isDesktopSupported() {
              return true;
          }
  
          @Override
          public FramePeer createLightweightFrame(LightweightFrame target) {
              throw new UnsupportedOperationException("Lightweight frames are not used by this test");
          }
  
          @Override
          public TrayIconPeer createTrayIcon(TrayIcon target) throws AWTException {
              throw new UnsupportedOperationException("Tray icons are not used by this test");
          }
  
          @Override
          public SystemTrayPeer createSystemTray(SystemTray target) {
              throw new UnsupportedOperationException("System tray is not used by this test");
          }
  
          @Override
          public boolean isTraySupported() {
              return false;
          }
  
          @Override
          public KeyboardFocusManagerPeer getKeyboardFocusManagerPeer() {
              return KEYBOARD_FOCUS_MANAGER_PEER;
          }
  
          @Override
          protected boolean syncNativeQueue(long timeout) {
              return false;
          }
  
          @Override
          public void grab(Window window) {
          }
  
          @Override
          public void ungrab(Window window) {
          }
  
          @Override
          public boolean isTaskbarSupported() {
              return false;
          }
      }
  
      private static final class RecordingDesktopPeer implements DesktopPeer {
          private static final RecordingDesktopPeer INSTANCE = new RecordingDesktopPeer();
          private static final AtomicReference<URI> BROWSED_URI = new AtomicReference<>();
  
          static void reset() {
              BROWSED_URI.set(null);
          }
  
          static URI browsedUri() {
              return BROWSED_URI.get();
          }
  
          @Override
          public boolean isSupported(Desktop.Action action) {
              return action == Desktop.Action.BROWSE;
          }
  
          @Override
          public void open(File file) {
              throw new UnsupportedOperationException("Opening files is not used by this test");
          }
  
          @Override
          public void edit(File file) {
              throw new UnsupportedOperationException("Editing files is not used by this test");
          }
  
          @Override
          public void print(File file) {
              throw new UnsupportedOperationException("Printing files is not used by this test");
          }
  
          @Override
          public void mail(URI mailtoURL) {
              throw new UnsupportedOperationException("Mail is not used by this test");
          }
  
          @Override
          public void browse(URI uri) {
              BROWSED_URI.set(uri);
          }
      }
  }
