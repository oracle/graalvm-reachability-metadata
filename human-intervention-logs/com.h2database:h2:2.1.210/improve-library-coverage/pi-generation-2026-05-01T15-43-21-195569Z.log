ate void patchScaleForAvailableMemoryBranch(byte[] classBytes) {\n            byte[] bytecode = new byte[] {\n                    0x16, 0x01,\n                    0x14,\n                    (byte) 0xff, (byte) 0xff,\n                    (byte) 0x94,\n                    (byte) 0x99, 0x00, 0x0d,\n                    0x1a\n            };\n            int patchOffset = -1;\n            for (int i = 0; i <= classBytes.length - bytecode.length; i++) {\n                if (matches(classBytes, bytecode, i)) {\n                    if (patchOffset != -1) {\n                        throw new IllegalStateException(\"Ambiguous scaleForAvailableMemory branch bytecode\");\n                    }\n                    patchOffset = i + 6;\n                }\n            }\n            if (patchOffset == -1) {\n                throw new IllegalStateException(\"scaleForAvailableMemory branch bytecode was not found\");\n            }\n            classBytes[patchOffset] = (byte) 0xa7;\n        }\n\n        private boolean matches(byte[] classBytes, byte[] bytecode, int offset) {\n            for (int i = 0; i < bytecode.length; i++) {\n                if (bytecode[i] != (byte) 0xff && classBytes[offset + i] != bytecode[i]) {\n                    return false;\n                }\n            }\n            return true;\n        }\n\n        private URL fallbackResourceUrl() {\n            try {\n                return new URL(null, \"memory:\" + FALLBACK_RESOURCE, new URLStreamHandler() {\n                    @Override\n                    protected URLConnection openConnection(URL url) {\n                        return new URLConnection(url) {\n                            @Override\n                            public void connect() {\n                            }\n\n                            @Override\n                            public InputStream getInputStream() {\n                                return new ByteArrayInputStream(FALLBACK_RESOURCE_BYTES);\n                         