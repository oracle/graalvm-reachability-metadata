[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/FilePathDiskTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage h2;\n\nimport org.h2.store.fs.FilePath;\nimport org.h2.util.IOUtils;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FilePathDiskTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void classpathPathReadsBundledResourceWithClassLookup() throws Exception {\n        FilePath path = FilePath.get(\"classpath:/org/h2/util/data.zip\");\n\n        assertThat(path.size()).isPositive();\n        try (InputStream inputStream = path.newInputStream()) {\n            assertThat(inputStream.read()).isNotNegative();\n        }\n    }\n\n    @Test\n    void classpathPathFallsBackToContextClassLoader() throws Exception {\n        Path packageDir = Files.createDirectories(tempDir.resolve(\"custom\"));\n        Files.writeString(packageDir.resolve(\"resource.txt\"), \"context-loader\", StandardCharsets.UTF_8);\n        ClassLoader original = Thread.currentThread().getContextClassLoader();\n\n        try (URLClassLoader loader = new URLClassLoader(new URL[] {tempDir.toUri().toURL()}, null)) {\n            Thread.currentThread().setContextClassLoader(loader);\n            try (InputStream inputStream = FilePath.get(\"classpath:custom/resource.txt\").newInputStream()) {\n                assertThat(new String(IOUtils.readBytesAndClose(inputStream, -1), StandardCharsets.UTF_8))\n                        .isEqualTo(\"context-loader\");\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(original);\n        }\n    }\n}\n"}
