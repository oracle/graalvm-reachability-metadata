[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/ObjectDataTypeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage h2;\n\nimport org.h2.mvstore.MVMap;\nimport org.h2.mvstore.MVStore;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.io.Serializable;\nimport java.nio.file.Path;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectDataTypeTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void mvStoreSerializesAndDeserializesCustomObjects() {\n        String storeFile = tempDir.resolve(\"objects.mv\").toString();\n        Payload payload = new Payload(\"metadata\", 42);\n\n        try (MVStore store = new MVStore.Builder().fileName(storeFile).open()) {\n            MVMap<String, Object> map = store.openMap(\"objects\");\n            map.put(\"payload\", payload);\n            store.commit();\n        }\n\n        try (MVStore store = new MVStore.Builder().fileName(storeFile).open()) {\n            MVMap<String, Object> map = store.openMap(\"objects\");\n            assertThat(map.get(\"payload\")).isEqualTo(payload);\n        }\n    }\n\n    public record Payload(String name, int value) implements Serializable {\n    }\n}\n"}
