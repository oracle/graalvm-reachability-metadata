[tool-call] delta {"path":"tests/src/com.h2database/h2/2.1.210/src/test/java/h2/DefaultAuthenticatorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage h2;\n\nimport org.h2.api.CredentialsValidator;\nimport org.h2.api.UserToRolesMapper;\nimport org.h2.security.auth.AuthenticationException;\nimport org.h2.security.auth.AuthenticationInfo;\nimport org.h2.security.auth.ConfigProperties;\nimport org.h2.security.auth.DefaultAuthenticator;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultAuthenticatorTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void authenticatorConfigurationInstantiatesValidatorAndRoleMapperClasses() throws Exception {\n        AlwaysValidCredentialsValidator.configured = false;\n        FixedRolesMapper.configured = false;\n        Path config = tempDir.resolve(\"h2-auth.xml\");\n        Files.writeString(config, \"\"\"\n                <h2Auth allowUserRegistration=\"true\" createMissingRoles=\"false\">\n                  <realm name=\"test\" validatorClass=\"h2.DefaultAuthenticatorTest$AlwaysValidCredentialsValidator\"/>\n                  <userToRolesMapper className=\"h2.DefaultAuthenticatorTest$FixedRolesMapper\"/>\n                </h2Auth>\n                \"\"\");\n\n        DefaultAuthenticator authenticator = new DefaultAuthenticator();\n        authenticator.configureFromUrl(config.toUri().toURL());\n\n        assertThat(AlwaysValidCredentialsValidator.configured).isTrue();\n        assertThat(FixedRolesMapper.configured).isTrue();\n    }\n\n    public static final class AlwaysValidCredentialsValidator implements CredentialsValidator {\n        static boolean configured;\n\n        public AlwaysValidCredentialsValidator() {\n        }\n\n        @Override\n        public void configure(ConfigProperties configProperties) {\n            configured = true;\n        }\n\n        @Override\n        public boolean validateCredentials(AuthenticationInfo authenticationInfo) {\n            return true;\n        }\n    }\n\n    public static final class FixedRolesMapper implements UserToRolesMapper {\n        static boolean configured;\n\n        public FixedRolesMapper() {\n        }\n\n        @Override\n        public void configure(ConfigProperties configProperties) {\n            configured = true;\n        }\n\n        @Override\n        public Collection<String> mapUserToRoles(AuthenticationInfo authenticationInfo) throws AuthenticationException {\n            return List.of(\"TEST_ROLE\");\n        }\n    }\n}\n"}
