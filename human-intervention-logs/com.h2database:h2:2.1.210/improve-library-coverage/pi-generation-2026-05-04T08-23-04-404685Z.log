          case Value.BOOLEAN:
              prep.setBoolean(parameterIndex, value.getBoolean());
              break;
          case Value.TINYINT:
              prep.setByte(parameterIndex, value.getByte());
              break;
          case Value.SMALLINT:
              prep.setShort(parameterIndex, value.getShort());
              break;
          case Value.INTEGER:
              prep.setInt(parameterIndex, value.getInt());
