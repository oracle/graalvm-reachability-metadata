          case Value.BIGINT:
              prep.setLong(parameterIndex, value.getLong());
              break;
          case Value.NUMERIC:
          case Value.DECFLOAT:
              prep.setBigDecimal(parameterIndex, value.getBigDecimal());
              break;
          case Value.DOUBLE:
              prep.setDouble(parameterIndex, value.getDouble());
