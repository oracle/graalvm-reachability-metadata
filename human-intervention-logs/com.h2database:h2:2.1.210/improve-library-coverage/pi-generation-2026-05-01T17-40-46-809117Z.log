  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  configurations {
      legacyH2 {
          canBeConsumed = false
          canBeResolved = true
      }
  }
  
  dependencies {
      testImplementation("com.h2database:h2:$libraryVersion")
      testImplementation("com.ibm.icu:icu4j:71.1")
      testImplementation("org.assertj:assertj-core:3.22.0")
      legacyH2("com.h2database:h2:1.4.200")
  }
  
  tasks.named("processTestResources") {
      from(configurations.legacyH2) {
          into("h2-upgrade")
          rename { "legacy-h2.jar" }
      }
  }
  
  tasks.withType(Test).configureEach {
      systemProperty("h2.javaObjectSerializer", "h2.JdbcUtilsTest")
      systemProperty("h2.nioCleanerHack", "true")
      jvmArgs(
              "--add-opens", "java.base/java.nio=ALL-UNNAMED",
              "--add-opens", "java.base/jdk.internal.ref=ALL-UNNAMED")
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
          metadataCopy {
              mergeWithExisting = true
              inputTaskNames.add("test")
              outputDirectories.add("src/test/resources/META-INF/native-image/com.h2database/h2")
          }
