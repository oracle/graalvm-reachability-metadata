              if (serializer != null) {
                  return serializer.serialize(obj);
              }
              ByteArrayOutputStream out = new ByteArrayOutputStream();
              ObjectOutputStream os = new ObjectOutputStream(out);
              os.writeObject(obj);
              return out.toByteArray();
  
