  import javax.naming.NamingException;
  import javax.sql.DataSource;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JdbcUtilsTest {
      private static final String JNDI_NAME = "java:comp/env/jdbc/h2";
  
      static {
          System.setProperty("h2.javaObjectSerializer", TrackingSerializer.class.getName());
      }
  
      @Test
      void loadUserClassUsesDefaultClassForName() {
          Class<String> loadedClass = JdbcUtils.loadUserClass("java.lang.String");
  
          assertThat(loadedClass).isSameAs(String.class);
      }
  
      @Test
      void getConnectionInstantiatesDriverClass() throws SQLException {
          try (Connection connection = JdbcUtils.getConnection(TrackingDriver.class.getName(),
                  "jdbc:tracking:driver", "sa", "secret")) {
              assertThat(connection.isClosed()).isFalse();
              assertThat(TrackingDriver.lastUrl).isEqualTo("jdbc:tracking:driver");
              assertThat(TrackingDriver.lastProperties).containsEntry("user", "sa");
          }
      }
  
      @Test
      void getConnectionInstantiatesJndiContextClass() throws SQLException {
          try (Connection connection = JdbcUtils.getConnection(TrackingContext.class.getName(), JNDI_NAME, "sa",
                  "secret")) {
              assertThat(connection.isClosed()).isFalse();
              assertThat(TrackingContext.lastLookupName).isEqualTo(JNDI_NAME);
              assertThat(TrackingDataSource.lastUser).isEqualTo("sa");
          }
      }
  
      @Test
      void getMetaResultSetInvokesDatabaseMetaDataMethods() throws SQLException {
          try (Connection connection = DriverManager.getConnection("jdbc:h2:mem:jdbc_utils_metadata;DB_CLOSE_DELAY=-1");
                  ResultSet resultSet = JdbcUtils.getMetaResultSet(connection, "@info")) {
              boolean foundMetadataUrl = false;
              while (resultSet.next()) {
                  if ("meta.getURL".equals(resultSet.getString(1))) {
                      foundMetadataUrl = true;
                      assertThat(resultSet.getString(2)).contains("jdbc:h2:mem:jdbc_utils_metadata");
                  }
              }
              assertThat(foundMetadataUrl).isTrue();
          }
      }
  
      public static final class TrackingSerializer implements JavaObjectSerializer {
          public TrackingSerializer() {
          }
  
          @Override
          public byte[] serialize(Object obj) throws IOException {
              ByteArrayOutputStream bytes = new ByteArrayOutputStream();
              try (ObjectOutputStream objects = new ObjectOutputStream(bytes)) {
                  objects.writeObject(obj);
              }
              return bytes.toByteArray();
          }
  
          @Override
          public Object deserialize(byte[] bytes) throws IOException, ClassNotFoundException {
              try (ObjectInputStream objects = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
                  return objects.readObject();
              }
          }
      }
  
      public static final class TrackingDriver implements Driver {
          private static String lastUrl;
          private static Properties lastProperties;
  
          public TrackingDriver() {
          }
  
          @Override
          public Connection connect(String url, Properties info) throws SQLException {
              lastUrl = url;
              lastProperties = info;
              return DriverManager.getConnection("jdbc:h2:mem:jdbc_utils_driver;DB_CLOSE_DELAY=-1");
          }
  
          @Override
          public boolean acceptsURL(String url) {
              return url.startsWith("jdbc:tracking:");
          }
  
          @Override
          public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {
              return new DriverPropertyInfo[0];
          }
  
          @Override
          public int getMajorVersion() {
              return 1;
          }
  
          @Override
          public int getMinorVersion() {
              return 0;
          }
  
          @Override
          public boolean jdbcCompliant() {
              return false;
          }
  
          @Override
          public Logger getParentLogger() throws SQLFeatureNotSupportedException {
              throw new SQLFeatureNotSupportedException();
          }
      }
  
