otFoundException;\nimport javax.naming.NameParser;\nimport javax.naming.NamingEnumeration;\nimport javax.naming.NamingException;\nimport javax.sql.DataSource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JdbcUtilsTest {\n    private static final String JNDI_NAME = \"java:comp/env/jdbc/h2\";\n\n    static {\n        System.setProperty(\"h2.javaObjectSerializer\", TrackingSerializer.class.getName());\n    }\n\n    @Test\n    void loadUserClassUsesDefaultClassForName() {\n        Class<String> loadedClass = JdbcUtils.loadUserClass(\"java.lang.String\");\n\n        assertThat(loadedClass).isSameAs(String.class);\n    }\n\n    @Test\n    void getConnectionInstantiatesDriverClass() throws SQLException {\n        try (Connection connection = JdbcUtils.getConnection(TrackingDriver.class.getName(),\n                \"jdbc:tracking:driver\", \"sa\", \"secret\")) {\n            assertThat(connection.isClosed()).isFalse();\n            assertThat(TrackingDriver.lastUrl).isEqualTo(\"jdbc:tracking:driver\");\n            assertThat(TrackingDriver.lastProperties).containsEntry(\"user\", \"sa\");\n        }\n    }\n\n    @Test\n    void getConnectionInstantiatesJndiContextClass() throws SQLException {\n        try (Connection connection = JdbcUtils.getConnection(TrackingContext.class.getName(), JNDI_NAME, \"sa\",\n                \"secret\")) {\n            assertThat(connection.isClosed()).isFalse();\n            assertThat(TrackingContext.lastLookupName).isEqualTo(JNDI_NAME);\n            assertThat(TrackingDataSource.lastUser).isEqualTo(\"sa\");\n        }\n    }\n\n    @Test\n    void getMetaResultSetInvokesDatabaseMetaDataMethods() throws SQLException {\n        try (Connection connection = DriverManager.getConnection(\"jdbc:h2:mem:jdbc_utils_metadata;DB_CLOSE_DELAY=-1\");\n                ResultSet resultSet = JdbcUtils.getMetaResultSet(connection, \"@info\")) {\n            boolean foundMetadataUrl = false;\n            while (resultSet.next()) {\n                if (\"meta.getURL\".equals(resultSet.getString(1))) {\n                    foundMetadataUrl = true;\n                    assertThat(resultSet.getString(2)).contains(\"jdbc:h2:mem:jdbc_utils_metadata\");\n                }\n            }\n            assertThat(foundMetadataUrl).isTrue();\n        }\n    }\n\n    public static final class TrackingSerializer implements JavaObjectSerializer {\n        public TrackingSerializer() {\n        }\n\n        @Override\n        public byte[] serialize(Object obj) throws IOException {\n            ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n            try (ObjectOutputStream objects = new ObjectOutputStream(bytes)) {\n                objects.writeObject(obj);\n            }\n            return bytes.toByteArray();\n        }\n\n        @Override\n        public Object deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n            try (ObjectInputStream objects = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n                return objects.readObject();\n            }\n        }\n    }\n\n    public static final class TrackingDriver implements Driver {\n        private static String lastUrl;\n        private static Properties lastProperties;\n\n        public TrackingDriver() {\n        }\n\n        @Override\n        public Connection connect(String url, Properties info) throws SQLException {\n            lastUrl = url;\n            lastProperties = info;\n            return DriverManager.getConnection(\"jdbc:h2:mem:jdbc_utils_driver;DB_CLOSE_DELAY=-1\");\n        }\n\n        @Override\n        public boolean acceptsURL(String url) {\n            return url.startsWith(\"jdbc:tracking:\");\n        }\n\n        @Override\n        public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {\n            return new DriverPropertyInfo[0];\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 1;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public boolean jdbcCompliant() {\n            return false;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException();\n        }\n    }\n\n    public static final class TrackingContext implements Context {\n        private static String lastLookupName;\n        private final Hashtable<String, Object> environment = new Hashtable<>();\n\n        public TrackingContext() {\n        }\n\n        @Override\n        public Object lookup(String name) throws NamingException {\n            lastLookupName = name;\n            if (JNDI_NAME.equals(name)) {\n                return new TrackingDataSource();\n            }\n            throw new NameNotFoundException(name);\n        }\n\n        @Override\n        public Object lookup(Name name) throws NamingException {\n            return lookup(name.toString());\n        }\n\n        @Override\n        public void bind(String name, Object obj) throws NamingException {\n            throw new NameAlreadyBoundException(name);\n        }\n\n        @Override\n        public void bind(Name name, Object obj) throws NamingException {\n            bind(name.toString(), obj);\n        }\n\n        @Override\n        public void rebind(String name, Object obj) {\n            throw new UnsupportedOperationException(name);\n        }\n\n        @Override\n        public void rebind(Name name, Object obj) {\n            rebind(name.toString(), obj);\n        }\n\n        @Override\n        public void unbind(String name) {\n            throw new UnsupportedOperationException(name);\n        }\n\n        @Override\n        public void unbind(Name name) {\n            unbind(name.toString());\n        }\n\n        @Override\n        public void rename(String oldName, String newName) {\n            throw new UnsupportedOperationException(oldName + \" to \" + newName);\n        }\n\n        @Override\n        public void rename(Name oldName, Name newName) {\n            rename(oldName.toString(), newName.toString());\n        }\n\n        @Override\n        public NamingEnumeration<NameClassPair> list(String name) {\n            throw new UnsupportedOperationException(name);\n        }\n\n        @Override\n        public NamingEnumeration<NameClassPair> list(Name name) {\n            return list(name.toString());\n        }\n\n        @Override\n        public NamingEnumeration<Binding> listBindings(String name) {\n            throw new UnsupportedOperationException(name);\n        }\n\n        @Override\n        public NamingEnumeration<Binding> listBindings(Name name) {\n            return listBindings(name.toString());\n        }\n\n        @Override\n        public void destroySubcontext(String name) {\n            throw new UnsupportedOperationException(name);\n        }\n\n        @Override\n        public void destroySubcontext(Name name) {\n            destroySubcontext(name.toString());\n        }\n\n        @Override\n        public Context createSubcontext(String name) {\n            throw new UnsupportedOperationException(name);\n        }\n\n        @Override\n        public Context createSubcontext(Name name) {\n            return createSubcontext(name.toString());\n        }\n\n        @Override\n        public Object lookupLink(String name) throws NamingException {\n            return lookup(name);\n        }\n\n        @Override\n        public Object lookupLink(Name name) throws NamingException {\n            return lookupLink(name.toString());\n        }\n\n        @Override\n        public NameParser getNameParser(String name) {\n            return CompositeNameParser.INSTANCE;\n        }\n\n        @Override\n        public NameParser getNameParser(Name name) {\n            return getNameParser(name.toString());\n        }\n\n        @Override\n        public String composeName(String name, String prefix) {\n            return prefix + '/' + name;\n        }\n\n        @Override\n        public Name composeName(Name name, Name prefix) throws NamingException {\n            Name result = (Name) prefix.clone();\n            result.addAll(name);\n            return result;\n        }\n\n        @Override\n        public Object addToEnvironment(String propName, Object propVal) {\n            return environment.put(propName, propVal);\n        }\n\n        @Override\n        public Object removeFromEnvironment(String propName) {\n            return environment.remove(propName);\n        }\n\n        @Override\n        public Hashtable<?, ?> getEnvironment() {\n            return environment;\n        }\n\n        @Override\n        public void close() {\n            environment.clear();\n        }\n\n        @Override\n        public String getNameInNamespace() {\n            return \"java:comp/env\";\n        }\n    }\n\n    public enum CompositeNameParser implements NameParser {\n        INSTANCE;\n\n        @Override\n        public Name parse(String name) throws NamingException {\n            return new javax.naming.CompositeName(name);\n        }\n    }\n\n    public static final class TrackingDataSource implements DataSource {\n        private static String lastUser;\n\n        @Override\n        public Connection getConnection() throws SQLException {\n            return DriverManager.getConnection(\"jdbc:h2:mem:jdbc_utils_jndi;DB_CLOSE_DELAY=-1\");\n        }\n\n        @Override\n        public Connection getConnection(String username, String password) throws SQLException {\n            lastUser = username;\n            return getConnection();\n        }\n\n        @Override\n        public PrintWriter getLogWriter() {\n            return null;\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) {\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) {\n        }\n\n        @Override\n        public int getLoginTimeout() {\n            return 0;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException();\n        }\n\n        @Override\n        public <T> T unwrap(Class<T> iface) throws SQLException {\n            throw new SQLException(\"No wrapper for \" + iface.getName());\n        }\n\n        @Override\n        public boolean isWrapperFor(Class<?> iface) {\n            return false;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 500, "output": 2658, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 28246, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777817031282, "responseId": "resp_04b35eb5b18da78c0169f755c7c3688191864a9e18b730bcfe"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_WKhCqgXw1guiGSGgxQgfo1wI|fc_04b35eb5b18da78c0169f755caff708191b74db86d5197e33b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 11258 bytes to tests/src/com.h2database/h2/2.1.210/src/test/java/h2/JdbcUtilsTest.java"}], "isError": false, "timestamp": 1777817056845}]}
