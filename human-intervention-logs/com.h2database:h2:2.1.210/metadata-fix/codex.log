{"type":"item.started","item":{"id":"item_83","type":"command_execution","command":"/usr/bin/zsh -lc \"python3 - <<'PY'\nimport json\nfrom pathlib import Path\n\nh2_path = Path('metadata/com.h2database/h2/2.1.210/reachability-metadata.json')\nsrc_path = Path('metadata/com.mchange/mchange-commons-java/0.2.15/reachability-metadata.json')\n\nh2 = json.loads(h2_path.read_text())\nsrc = json.loads(src_path.read_text())\n\nprefixes = (\n    'java.awt.',\n    'java.awt.geom.',\n    'java.awt.image.',\n    'sun.awt.',\n    'sun.font.',\n    'sun.java2d.',\n)\nextra = {'java.lang.System'}\ncondition = {'typeReached': 'org.h2.tools.Server'}\n\ndef member_key(member):\n    if 'name' in member and 'parameterTypes' in member:\n        return ('method', member['name'], tuple(member['parameterTypes']))\n    if 'name' in member:\n        return ('field', member['name'])\n    return tuple(sorted(member.items()))\n\nselected = []\nfor entry in src['reflection']:\n    t = entry.get('type')\n    if not isinstance(t, str):\n        continue\n    if t in extra or t.startswith(prefixes):\n        new_entry = {k: v for k, v in entry.items() if k \"'!= '\"'condition'}\n        new_entry['condition'] = condition\n        selected.append(new_entry)\n\nby_key = {}\nfor idx, entry in enumerate(h2['reflection']):\n    cond = entry.get('condition', {})\n    key = (cond.get('typeReached'), entry.get('type'))\n    by_key[key] = idx\n\nfor entry in selected:\n    key = (entry['condition']['typeReached'], entry['type'])\n    if key not in by_key:\n        h2['reflection'].append(entry)\n        by_key[key] = len(h2['reflection']) - 1\n        continue\n\n    target = h2['reflection'][by_key[key]]\n    for flag in ('jniAccessible', 'allDeclaredMethods', 'allDeclaredFields', 'allPublicMethods', 'allPublicFields'):\n        if entry.get(flag):\n            target[flag] = True\n\n    for arr_name in ('methods', 'fields'):\n        incoming = entry.get(arr_name)\n        if not incoming:\n            continue\n        existing = target.setdefault(arr_name, [])\n        seen = {member_key(m) for m in existing}\n        for member in incoming:\n            mk = member_key(member)\n            if mk not in seen:\n                existing.append(member)\n                seen.add(mk)\n\nh2_path.write_text(json.dumps(h2, indent=2) + '\\\\n')\nprint(f'merged {len(selected)} entries')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
