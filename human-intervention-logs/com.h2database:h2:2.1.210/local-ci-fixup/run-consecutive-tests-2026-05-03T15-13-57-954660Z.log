});\n   133\t\n   134\t        // Read data back\n   135\t        withConnection(url, connection -> {\n   136\t            try (ResultSet resultSet = connection.prepareStatement(\"SELECT * FROM datatypes\").executeQuery()) {\n   137\t                resultSet.next();\n   138\t                for (int i = 1; i <= 29; i++) {\n   139\t                    System.out.printf(\"column %d: %s%n\", i, resultSet.getObject(i));\n   140\t                }\n   141\t            }\n   142\t        });\n   143\t    }\n   144\t\n   145\t    private static void cleanupFileBackedDatabase(String url) throws IOException {\n   146\t        if (!FILE_URL.equals(url)) {\n   147\t            return;\n   148\t        }\n   149\t        Path dataDirectory = Path.of(\"data\");\n   150\t        if (!Files.exists(dataDirectory)) {\n   151\t            return;\n   152\t        }\n   153\t        try (var files = Files.list(dataDirectory)) {\n   154\t            for (Path file : files.filter(Files::isRegularFile)\n   155\t                    .filter(path -> path.getFileName().toString().startsWith(\"test.\"))\n   156\t                    .toList()) {\n   157\t                Files.deleteIfExists(file);\n   158\t            }\n   159\t        }\n   160\t    }\n   161\t\n   162\t    private static void withConnection(String url, ConnectionCallback callback) throws SQLException {\n   163\t        try (Connection connection = DriverManager.getConnection(url)) {\n   164\t            connection.setAutoCommit(false);\n   165\t            callback.run(connection);\n   166\t        }\n   167\t    }\n   168\t\n   169\t    private interface ConnectionCallback {\n   170\t        void run(Connection connection) throws SQLException;\n   171\t    }\n   172\t}\n","exit_code":0,"status":"completed"}}
