tartsWith(\"${\") && !expression.startsWith(\"#{\")) {\n            expression = \"${\" + expression;\n        }\n        if (!expression.endsWith(\"}\")) {\n            expression = expression + \"}\";\n        }\n        return expression;\n    }\n\n    @Override\n    protected boolean appliesToListElements() {\n        return false;\n    }\n}\n"}], "isError": false, "timestamp": 1777807902043}]}
