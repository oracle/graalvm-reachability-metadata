  }\n\n    @Test\n    void getAnnotationArrayWrapsSingleAnnotationAttribute() {\n        final SampleAnnotation annotation = AnnotatedComponent.class.getAnnotation(SampleAnnotation.class);\n        final AnnotationAttributes attributes = new AnnotationAttributes(SampleAnnotation.class);\n        attributes.put(\"nested\", annotation);\n\n        final SampleAnnotation[] annotations = attributes.getAnnotationArray(\"nested\", SampleAnnotation.class);\n\n        assertThat(annotations).containsExactly(annotation);\n    }\n\n    @SampleAnnotation(\"spring\")\n    private static final class AnnotatedComponent {\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface SampleAnnotation {\n\n        String value();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 979, "output": 903, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 21850, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780855110411, "responseId": "resp_023cfb257dfe2a6d016a25b146e31c81939e1847fe6033b9ab"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_lVnB1mAcgQkkn7V1BPmoqIek|fc_023cfb257dfe2a6d016a25b1578b9c8193bc023598b3595e12", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1580 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/AnnotationAttributesTest.java"}], "isError": false, "timestamp": 1780855131093}]}
