  import org.springframework.core.type.classreading.AnnotationMetadataReadingVisitor;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RecursiveAnnotationArrayVisitorTest {
  
      @Test
      @SuppressWarnings("deprecation")
      void annotationMetadataReadingVisitorReadsPopulatedAndEmptyArrayAttributes() {
          final AnnotationMetadataReadingVisitor visitor = new AnnotationMetadataReadingVisitor(
                  RecursiveAnnotationArrayVisitorTest.class.getClassLoader());
          final int parsingOptions = ClassReader.SKIP_DEBUG | ClassReader.SKIP_CODE
                  | ClassReader.SKIP_FRAMES;
          new ClassReader(arrayAnnotatedClass()).accept(visitor, parsingOptions);
  
          final AnnotationAttributes attributes = visitor.getAnnotationAttributes(
                  ArrayContainer.class.getName(), false);
  
          assertThat(attributes).isNotNull();
          assertThat(attributes.getStringArray("names")).containsExactly("spring", "core");
          assertThat(attributes.getStringArray("emptyNames")).isEmpty();
      }
  
      private static byte[] arrayAnnotatedClass() {
          final ClassWriter writer = new ClassWriter(0);
          writer.visit(Opcodes.V1_8, Opcodes.ACC_PUBLIC,
                  "org_springframework/spring_core/GeneratedArrayAnnotatedComponent", null,
                  "java/lang/Object", null);
  
          final AnnotationVisitor annotation = writer.visitAnnotation(
                  descriptor(ArrayContainer.class), true);
          final AnnotationVisitor names = annotation.visitArray("names");
          names.visit(null, "spring");
          names.visit(null, "core");
          names.visitEnd();
          final AnnotationVisitor emptyNames = annotation.visitArray("emptyNames");
          emptyNames.visitEnd();
          annotation.visitEnd();
  
          writer.visitEnd();
          return writer.toByteArray();
      }
  
      private static String descriptor(Class<?> type) {
          return "L" + type.getName().replace('.', '/') + ";";
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface ArrayContainer {
  
          String[] names() default {};
  
          String[] emptyNames() default {};
      }
  }
