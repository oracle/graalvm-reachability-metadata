pyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.asm.ClassReader;\nimport org.springframework.asm.ClassWriter;\nimport org.springframework.asm.Label;\nimport org.springframework.asm.MethodVisitor;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.springframework.asm.Opcodes.ACC_PUBLIC;\nimport static org.springframework.asm.Opcodes.ACC_STATIC;\nimport static org.springframework.asm.Opcodes.ACC_SUPER;\nimport static org.springframework.asm.Opcodes.ALOAD;\nimport static org.springframework.asm.Opcodes.ARETURN;\nimport static org.springframework.asm.Opcodes.ASTORE;\nimport static org.springframework.asm.Opcodes.DUP;\nimport static org.springframework.asm.Opcodes.GOTO;\nimport static org.springframework.asm.Opcodes.IFEQ;\nimport static org.springframework.asm.Opcodes.ILOAD;\nimport static org.springframework.asm.Opcodes.INVOKESPECIAL;\nimport static org.springframework.asm.Opcodes.NEW;\nimport static org.springframework.asm.Opcodes.V1_8;\n\npublic class ClassWriterTest {\n\n    @Test\n    void computeFramesResolvesCommonSuperclassForMergedBranchTypes() {\n        final ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        writer.visit(V1_8, ACC_PUBLIC | ACC_SUPER, \"example/GeneratedLists\", null, \"java/lang/Object\", null);\n        addChooseListMethod(writer);\n        writer.visitEnd();\n\n        final byte[] bytecode = writer.toByteArray();\n\n        assertThat(bytecode).isNotEmpty();\n        assertThat(new ClassReader(bytecode).getClassName()).isEqualTo(\"example/GeneratedLists\");\n    }\n\n    private static void addChooseListMethod(ClassWriter writer) {\n        final MethodVisitor method = writer.visitMethod(\n                ACC_PUBLIC | ACC_STATIC, \"choose\", \"(Z)Ljava/util/AbstractList;\", null, null);\n        final Label useLinkedList = new Label();\n        final Label returnList = new Label();\n\n        method.visitCode();\n        method.visitVarInsn(ILOAD, 0);\n        method.visitJumpInsn(IFEQ, useLinkedList);\n        method.visitTypeInsn(NEW, \"java/util/ArrayList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/ArrayList\", \"<init>\", \"()V\", false);\n        method.visitVarInsn(ASTORE, 1);\n        method.visitJumpInsn(GOTO, returnList);\n\n        method.visitLabel(useLinkedList);\n        method.visitTypeInsn(NEW, \"java/util/LinkedList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/LinkedList\", \"<init>\", \"()V\", false);\n        method.visitVarInsn(ASTORE, 1);\n\n        method.visitLabel(returnList);\n        method.visitVarInsn(ALOAD, 1);\n        method.visitInsn(ARETURN);\n        method.visitMaxs(0, 0);\n        method.visitEnd();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 872, "output": 1312, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 27272, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780856952145, "responseId": "resp_0f0422daf036a878016a25b8a43b508194b6409cc786976b61"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_yDP9gmgqKG9W7ahqQT6muXx8|fc_0f0422daf036a878016a25b8b37adc81949b91caac313a98a8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2943 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/ClassWriterTest.java"}], "isError": false, "timestamp": 1780857017117}]}
