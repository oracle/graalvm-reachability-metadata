s(metaInfDirectory);\n        Path factoriesFile = metaInfDirectory.resolve(\"spring.factories\");\n        Files.writeString(factoriesFile, content, StandardCharsets.ISO_8859_1);\n        return factoriesFile.toUri().toURL();\n    }\n\n    private static final class SpringFactoriesClassLoader extends ClassLoader {\n\n        private final URL factoriesResource;\n\n        private SpringFactoriesClassLoader(URL factoriesResource) {\n            super(SpringFactoriesLoaderTest.class.getClassLoader());\n            this.factoriesResource = factoriesResource;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (SpringFactoriesLoader.FACTORIES_RESOURCE_LOCATION.equals(name)) {\n                return Collections.enumeration(List.of(this.factoriesResource));\n            }\n            return super.getResources(name);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 357, "output": 1257, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 24142, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777705216566, "responseId": "resp_0f6bd1f96d305e060169f5a101007481a082a87ce058e95ee4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ddHsulosFgbWtTX5ZCQzrbHc|fc_0f6bd1f96d305e060169f5a10cafc881a0a5eb188e67f32ba9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2481 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/SpringFactoriesLoaderTest.java"}], "isError": false, "timestamp": 1777705230980}]}
