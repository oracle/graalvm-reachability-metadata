[tool-call] delta {"path":"tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/SunReflectionFactoryHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.objenesis.SpringObjenesis;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SunReflectionFactoryHelperTest {\n\n    @Test\n    void springObjenesisCreatesInstancesWithoutCallingTargetConstructor() {\n        ConstructorBypassedComponent.constructorCalls.set(0);\n        final SpringObjenesis objenesis = new SpringObjenesis();\n\n        final ConstructorBypassedComponent instance = objenesis.newInstance(ConstructorBypassedComponent.class);\n\n        assertThat(instance).isNotNull();\n        assertThat(ConstructorBypassedComponent.constructorCalls).hasValue(0);\n        assertThat(instance.message).isNull();\n        assertThat(instance.number).isZero();\n    }\n\n    private static final class ConstructorBypassedComponent {\n\n        private static final AtomicInteger constructorCalls = new AtomicInteger();\n\n        private final String message;\n\n        private final int number;\n\n        private ConstructorBypassedComponent() {\n            constructorCalls.incrementAndGet();\n            this.message = \"constructed\";\n            this.number = 42;\n        }\n    }\n}\n"}
