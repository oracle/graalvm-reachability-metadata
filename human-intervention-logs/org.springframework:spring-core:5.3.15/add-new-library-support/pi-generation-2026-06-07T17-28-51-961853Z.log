a CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\nimport java.util.List;\nimport java.util.stream.Collectors;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.util.ReflectionUtils;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionUtilsTest {\n\n    @Test\n    void accessibleConstructorFindsAndOpensPrivateConstructors() throws Exception {\n        final Constructor<ConstructedComponent> constructor = ReflectionUtils.accessibleConstructor(\n                ConstructedComponent.class, String.class);\n\n        assertThat(constructor.getDeclaringClass()).isEqualTo(ConstructedComponent.class);\n        assertThat(constructor.canAccess(null)).isTrue();\n    }\n\n    @Test\n    void methodUtilitiesFindDeclaredInterfaceDefaultAndInvokePrivateMethods() {\n        final Method privateMethod = ReflectionUtils.findMethod(MethodComponent.class, \"message\", String.class);\n        final Method interfaceMethod = ReflectionUtils.findMethod(DefaultMessageProvider.class, \"defaultMessage\");\n        final Method[] declaredMethods = ReflectionUtils.getDeclaredMethods(MethodComponent.class);\n        final MethodComponent target = new MethodComponent(\"spring\");\n\n        assertThat(privateMethod).isNotNull();\n        ReflectionUtils.makeAccessible(privateMethod);\n        assertThat(ReflectionUtils.invokeMethod(privateMethod, target, \"core\")).isEqualTo(\"spring-core\");\n\n        assertThat(interfaceMethod).isNotNull();\n        assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(DefaultMessageProvider.class);\n\n        final List<String> methodNames = Arrays.stream(declaredMethods)\n                .map(Method::getName)\n                .collect(Collectors.toList());\n        assertThat(methodNames).contains(\"message\", \"defaultMessage\");\n    }\n\n    @Test\n    void fieldUtilitiesFindSetAndReadPrivateFields() {\n        final Field field = ReflectionUtils.findField(FieldComponent.class, \"value\", String.class);\n        final FieldComponent target = new FieldComponent(\"initial\");\n\n        assertThat(field).isNotNull();\n        ReflectionUtils.makeAccessible(field);\n        ReflectionUtils.setField(field, target, \"updated\");\n\n        assertThat(ReflectionUtils.getField(field, target)).isEqualTo(\"updated\");\n    }\n\n    @Test\n    void shallowCopyFieldStateCopiesMutableInstanceFieldsAcrossHierarchy() {\n        final CopyComponent source = new CopyComponent(\"source\", 42);\n        final CopyComponent destination = new CopyComponent(\"destination\", 7);\n\n        ReflectionUtils.shallowCopyFieldState(source, destination);\n\n        assertThat(destination.name()).isEqualTo(\"source\");\n        assertThat(destination.count()).isEqualTo(42);\n        assertThat(destination.parentName()).isEqualTo(\"parent-source\");\n    }\n\n    private static final class ConstructedComponent {\n\n        private ConstructedComponent(String value) {\n        }\n    }\n\n    private interface DefaultMessageProvider {\n\n        default String defaultMessage() {\n            return \"default\";\n        }\n    }\n\n    private static final class MethodComponent implements DefaultMessageProvider {\n\n        private final String prefix;\n\n        private MethodComponent(String prefix) {\n            this.prefix = prefix;\n        }\n\n        private String message(String suffix) {\n            return prefix + '-' + suffix;\n        }\n    }\n\n    private static final class FieldComponent {\n\n        private String value;\n\n        private FieldComponent(String value) {\n            this.value = value;\n        }\n    }\n\n    private static class CopyParentComponent {\n\n        private String parentName;\n\n        CopyParentComponent(String parentName) {\n            this.parentName = parentName;\n        }\n\n        String parentName() {\n            return parentName;\n        }\n    }\n\n    private static final class CopyComponent extends CopyParentComponent {\n\n        private String name;\n\n        private int count;\n\n        private CopyComponent(String name, int count) {\n            super(\"parent-\" + name);\n            this.name = name;\n            this.count = count;\n        }\n\n        String name() {\n            return name;\n        }\n\n        int count() {\n            return count;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780853265147}, {"role": "toolResult", "toolCallId": "call_hJLYOiq6lu7uwEPBxlmvJNT3|fc_0fff4e6da0792ddb016a25aa10bf28819398c64d64bc4c30c4", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.springframework:spring-core:$libraryVersion\"\n    testImplementation 'org.jboss:jboss-vfs:3.2.15.Final'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\nTaskProvider<Test> openedDefineClassTest = tasks.register('openedDefineClassTest', Test) {\n    description = 'Exercises the ClassLoader.defineClass path that needs java.lang opened.'\n    group = 'verification'\n    testClassesDirs = sourceSets.test.output.classesDirs\n    classpath = sourceSets.test.runtimeClasspath\n    useJUnitPlatform()\n    jvmArgs '--add-opens=java.base/java.lang=ALL-UNNAMED'\n    filter {\n        includeTestsMatching 'org_springframework.spring_core.ReflectUtilsTest.' +\n                'defineClassUsesProtectedClassLoaderDefineClassWithoutContextClass'\n    }\n}\n\ntasks.named('test') {\n    filter {\n        excludeTestsMatching 'org_springframework.spring_core.ReflectUtilsTest.' +\n                'defineClassUsesProtectedClassLoaderDefineClassWithoutContextClass'\n    }\n    dependsOn openedDefineClassTest\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n    binaries {\n        all {\n            buildArgs.add('--add-opens=java.base/java.lang=ALL-UNNAMED')\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780853265147}, {"role": "toolResult", "toolCallId": "call_HuCAUrBtkQuPfoC7aEYOjirS|fc_0fff4e6da0792ddb016a25aa10bf30819384988a88a0e6e552", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2183-66c60ad9/local_repositories/source_context/org.springframework/spring-core/5.3.15/main/org/springframework/objenesis/instantiator/sun/SunReflectionFactoryHelper.java'"}], "details": {}, "isError": true, "timestamp": 1780853265147}, {"role": "toolResult", "toolCallId": "call_r8NJ4iYZmTYv5i221J2MG4nU|fc_0fff4e6da0792ddb016a25aa10bf3881939a119c8153a7d848", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2183-66c60ad9/local_repositories/source_context/org.springframework/spring-core/5.3.15/main/org/springframework/objenesis/SpringObjenesis.java'"}], "details": {}, "isError": true, "timestamp": 1780853265147}]}
