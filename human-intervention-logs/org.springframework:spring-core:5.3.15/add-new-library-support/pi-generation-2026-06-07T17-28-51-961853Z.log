          static final AtomicInteger constructorCalls = new AtomicInteger();
  
          final String message;
          final int number;
  
          ConstructorBypassedType() {
              constructorCalls.incrementAndGet();
              this.message = "constructed";
              this.number = 42;
          }
      }
  
  }
