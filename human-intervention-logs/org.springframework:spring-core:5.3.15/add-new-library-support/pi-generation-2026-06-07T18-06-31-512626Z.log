  package org_springframework.spring_core;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.nio.charset.StandardCharsets;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.core.io.ClassPathResource;
  import org.springframework.core.io.Resource;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassPathResourceTest {
  
      private static final String RESOURCE_PATH = "org_springframework/spring_core/classpath-resource.txt";
  
      private static final String RESOURCE_CONTENT = "Spring class path resource contents";
  
      @Test
      void classRelativeResourceUsesClassResourceLookup() throws IOException {
          Resource resource = new ClassPathResource("classpath-resource.txt", ClassPathResourceTest.class);
  
          assertThat(resource.exists()).isTrue();
          assertThat(read(resource)).isEqualTo(RESOURCE_CONTENT);
      }
  
      @Test
      void classLoaderResourceUsesProvidedClassLoaderLookup() throws IOException {
          ClassLoader classLoader = ClassPathResourceTest.class.getClassLoader();
          Resource resource = new ClassPathResource(RESOURCE_PATH, classLoader);
  
          assertThat(resource.exists()).isTrue();
          assertThat(read(resource)).isEqualTo(RESOURCE_CONTENT);
      }
  
      @Test
      void nullClassResourceUsesSystemClassLoaderLookup() throws IOException {
          Resource resource = new ClassPathResource(RESOURCE_PATH, (Class<?>) null);
  
          assertThat(resource.exists()).isTrue();
          assertThat(read(resource)).isEqualTo(RESOURCE_CONTENT);
      }
  
      private static String read(Resource resource) throws IOException {
          try (InputStream inputStream = resource.getInputStream()) {
              return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);
          }
      }
  }
