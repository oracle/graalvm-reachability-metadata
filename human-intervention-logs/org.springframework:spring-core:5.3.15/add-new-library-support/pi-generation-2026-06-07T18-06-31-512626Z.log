[tool-call] delta {"path":"tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/PathMatchingResourcePatternResolverTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.core.io.DefaultResourceLoader;\nimport org.springframework.core.io.Resource;\nimport org.springframework.core.io.ResourceLoader;\nimport org.springframework.core.io.support.PathMatchingResourcePatternResolver;\nimport org.springframework.core.io.support.ResourcePatternResolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PathMatchingResourcePatternResolverTest {\n\n    private static final String RESOURCE_PATH = \"org_springframework/spring_core/classpath-resource.txt\";\n\n    private static final String RESOURCE_CONTENT = \"Spring class path resource contents\";\n\n    @Test\n    void classpathAllResourceResolutionUsesProvidedClassLoader() throws IOException {\n        ClassLoader classLoader = PathMatchingResourcePatternResolverTest.class.getClassLoader();\n        PathMatchingResourcePatternResolver resolver = new PathMatchingResourcePatternResolver(classLoader);\n\n        Resource[] resources = resolver.getResources(ResourcePatternResolver.CLASSPATH_ALL_URL_PREFIX + RESOURCE_PATH);\n\n        assertThat(readExistingResourceContents(resources)).contains(RESOURCE_CONTENT);\n    }\n\n    @Test\n    void classpathAllResourceResolutionUsesSystemResourcesWhenNoClassLoaderIsExposed() throws IOException {\n        PathMatchingResourcePatternResolver resolver =\n                new PathMatchingResourcePatternResolver(new SystemResourceLoader());\n\n        Resource[] resources = resolver.getResources(ResourcePatternResolver.CLASSPATH_ALL_URL_PREFIX + RESOURCE_PATH);\n\n        assertThat(readExistingResourceContents(resources)).contains(RESOURCE_CONTENT);\n    }\n\n    private static List<String> readExistingResourceContents(Resource[] resources) throws IOException {\n        assertThat(resources).isNotEmpty();\n        List<String> contents = new ArrayList<>();\n        for (Resource resource : resources) {\n            if (resource.exists()) {\n                contents.add(read(resource));\n            }\n        }\n        return contents;\n    }\n\n    private static String read(Resource resource) throws IOException {\n        try (InputStream inputStream = resource.getInputStream()) {\n            return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\n        }\n    }\n\n    private static final class SystemResourceLoader implements ResourceLoader {\n\n        private final DefaultResourceLoader delegate = new DefaultResourceLoader();\n\n        @Override\n        public Resource getResource(String location) {\n            return this.delegate.getResource(location);\n        }\n\n        @Override\n        public ClassLoader getClassLoader() {\n            return null;\n        }\n    }\n}\n"}
