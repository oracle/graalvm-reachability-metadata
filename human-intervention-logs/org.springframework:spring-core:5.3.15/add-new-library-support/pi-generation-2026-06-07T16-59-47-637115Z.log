[tool-call] delta {"path":"tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/ReflectionUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\nimport java.util.List;\nimport java.util.stream.Collectors;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.util.ReflectionUtils;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionUtilsTest {\n\n    @Test\n    void accessibleConstructorFindsAndOpensPrivateConstructors() throws Exception {\n        final Constructor<ConstructedComponent> constructor = ReflectionUtils.accessibleConstructor(\n                ConstructedComponent.class, String.class);\n\n        assertThat(constructor.getDeclaringClass()).isEqualTo(ConstructedComponent.class);\n        assertThat(constructor.canAccess(null)).isTrue();\n    }\n\n    @Test\n    void methodUtilitiesFindDeclaredInterfaceDefaultAndInvokePrivateMethods() {\n        final Method privateMethod = ReflectionUtils.findMethod(MethodComponent.class, \"message\", String.class);\n        final Method interfaceMethod = ReflectionUtils.findMethod(DefaultMessageProvider.class, \"defaultMessage\");\n        final Method[] declaredMethods = ReflectionUtils.getDeclaredMethods(MethodComponent.class);\n        final MethodComponent target = new MethodComponent(\"spring\");\n\n        assertThat(privateMethod).isNotNull();\n        ReflectionUtils.makeAccessible(privateMethod);\n        assertThat(ReflectionUtils.invokeMethod(privateMethod, target, \"core\")).isEqualTo(\"spring-core\");\n\n        assertThat(interfaceMethod).isNotNull();\n        assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(DefaultMessageProvider.class);\n\n        final List<String> methodNames = Arrays.stream(declaredMethods)\n                .map(Method::getName)\n                .collect(Collectors.toList());\n        assertThat(methodNames).contains(\"message\", \"defaultMessage\");\n    }\n\n    @Test\n    void fieldUtilitiesFindSetAndReadPrivateFields() {\n        final Field field = ReflectionUtils.findField(FieldComponent.class, \"value\", String.class);\n        final FieldComponent target = new FieldComponent(\"initial\");\n\n        assertThat(field).isNotNull();\n        ReflectionUtils.makeAccessible(field);\n        ReflectionUtils.setField(field, target, \"updated\");\n\n        assertThat(ReflectionUtils.getField(field, target)).isEqualTo(\"updated\");\n    }\n\n    @Test\n    void shallowCopyFieldStateCopiesMutableInstanceFieldsAcrossHierarchy() {\n        final CopyComponent source = new CopyComponent(\"source\", 42);\n        final CopyComponent destination = new CopyComponent(\"destination\", 7);\n\n        ReflectionUtils.shallowCopyFieldState(source, destination);\n\n        assertThat(destination.name()).isEqualTo(\"source\");\n        assertThat(destination.count()).isEqualTo(42);\n        assertThat(destination.parentName()).isEqualTo(\"parent-source\");\n    }\n\n    private static final class ConstructedComponent {\n\n        private ConstructedComponent(String value) {\n        }\n    }\n\n    private interface DefaultMessageProvider {\n\n        default String defaultMessage() {\n            return \"default\";\n        }\n    }\n\n    private static final class MethodComponent implements DefaultMessageProvider {\n\n        private final String prefix;\n\n        private MethodComponent(String prefix) {\n            this.prefix = prefix;\n        }\n\n        private String message(String suffix) {\n            return prefix + '-' + suffix;\n        }\n    }\n\n    private static final class FieldComponent {\n\n        private String value;\n\n        private FieldComponent(String value) {\n            this.value = value;\n        }\n    }\n\n    private static class CopyParentComponent {\n\n        private String parentName;\n\n        CopyParentComponent(String parentName) {\n            this.parentName = parentName;\n        }\n\n        String parentName() {\n            return parentName;\n        }\n    }\n\n    private static final class CopyComponent extends CopyParentComponent {\n\n        private String name;\n\n        private int count;\n\n        private CopyComponent(String name, int count) {\n            super(\"parent-\" + name);\n            this.name = name;\n            this.count = count;\n        }\n\n        String name() {\n            return name;\n        }\n\n        int count() {\n            return count;\n        }\n    }\n}\n"}
