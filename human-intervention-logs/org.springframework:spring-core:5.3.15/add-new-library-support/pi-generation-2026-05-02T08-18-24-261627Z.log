  	<A extends Annotation> MergedAnnotation<A> get(Class<A> annotationType,
  			@Nullable Predicate<? super MergedAnnotation<A>> predicate);
  
  	/**
  	 * Get a matching annotation or meta-annotation of the specified type, or
