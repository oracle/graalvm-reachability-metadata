  	 * @return a {@link MergedAnnotation} instance
  	 * @see MergedAnnotationPredicates
  	 */
  	<A extends Annotation> MergedAnnotation<A> get(String annotationType,
  			@Nullable Predicate<? super MergedAnnotation<A>> predicate);
  
