  		return processClassHierarchy(context, new int[] {0}, source, processor,
  				includeInterfaces, includeEnclosing);
  	}
  
  	@Nullable
  	private static <C, R> R processClassHierarchy(C context, int[] aggregateIndex, Class<?> source,
