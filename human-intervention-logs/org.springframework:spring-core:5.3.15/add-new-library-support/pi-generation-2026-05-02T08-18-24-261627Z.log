  				if (ObjectUtils.containsElement(annotations, bridgedAnnotations[i])) {
  					bridgedAnnotations[i] = null;
  				}
  			}
  			return processor.doWithAnnotations(context, aggregateIndex, source, bridgedAnnotations);
  		}
  		return null;
  	}
  
