  package org_springframework.spring_core;
  
  import java.io.Serializable;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.util.ArrayList;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.util.ClassUtils;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassUtilsTest {
  
      @Test
      void forNameResolvesStandardSourceAndInternalNames() throws Exception {
          final ClassLoader classLoader = ClassUtilsTest.class.getClassLoader();
  
          assertThat(ClassUtils.forName("java.util.ArrayList", classLoader)).isEqualTo(ArrayList.class);
          assertThat(ClassUtils.forName("java.lang.Integer[]", classLoader)).isEqualTo(Integer[].class);
          assertThat(ClassUtils.forName("[Ljava.util.ArrayList;", classLoader)).isEqualTo(ArrayList[].class);
          assertThat(ClassUtils.forName("[[Ljava.lang.Integer;", classLoader)).isEqualTo(Integer[][].class);
          assertThat(ClassUtils.forName(
                  "org_springframework.spring_core.ClassUtilsTest.NestedComponent", classLoader))
                  .isEqualTo(NestedComponent.class);
      }
  
      @Test
      void visibilityChecksLoadEquivalentClassesThroughClassLoader() {
          final ClassLoader childLoader = new ChildClassLoader(ClassUtilsTest.class.getClassLoader());
  
          assertThat(ClassUtils.isVisible(String.class, childLoader)).isTrue();
      }
  
      @Test
      void createCompositeInterfaceBuildsProxyClassForInterfaces() {
          final Class<?> compositeInterface = ClassUtils.createCompositeInterface(
                  new Class<?>[] {Runnable.class, Serializable.class}, ClassUtilsTest.class.getClassLoader());
  
          assertThat(Proxy.isProxyClass(compositeInterface)).isTrue();
          assertThat(Runnable.class).isAssignableFrom(compositeInterface);
          assertThat(Serializable.class).isAssignableFrom(compositeInterface);
      }
  
      @Test
      void constructorAndMethodUtilitiesFindPublicMembers() throws Exception {
          final Constructor<PublicMemberTarget> constructor = ClassUtils.getConstructorIfAvailable(
                  PublicMemberTarget.class, String.class);
          final Method publicMethod = ClassUtils.getMethod(PublicMemberTarget.class, "publicMethod", String.class);
          final Method optionalMethod = ClassUtils.getMethodIfAvailable(
                  PublicMemberTarget.class, "publicMethod", String.class);
          final Method staticMethod = ClassUtils.getStaticMethod(PublicMemberTarget.class, "staticMethod", String.class);
  
          assertThat(constructor).isNotNull();
          assertThat(constructor.newInstance("spring").value()).isEqualTo("spring");
          assertThat(publicMethod.invoke(new PublicMemberTarget("core"), "spring")).isEqualTo("core-spring");
          assertThat(optionalMethod).isEqualTo(publicMethod);
          assertThat(staticMethod).isNotNull();
          assertThat(staticMethod.invoke(null, "spring")).isEqualTo("SPRING");
      }
  
      @Test
      void methodNameUtilitiesInspectDeclaredAndPublicMethods() {
          final Method uniqueOverload = ClassUtils.getMethodIfAvailable(PublicMemberTarget.class, "uniqueOverload",
                  (Class<?>[]) null);
  
          assertThat(ClassUtils.getMethodCountForName(MethodHierarchyChild.class, "countedMethod")).isEqualTo(3);
          assertThat(ClassUtils.hasAtLeastOneMethodWithName(MethodHierarchyChild.class, "countedMethod")).isTrue();
          assertThat(uniqueOverload).isNotNull();
          assertThat(uniqueOverload.getParameterCount()).isZero();
      }
  
      @Test
      void methodResolutionFindsTargetAndInterfaceMethods() throws Exception {
          final Method interfaceMethod = PublicContract.class.getMethod("contractValue");
          final Method implementationMethod = PublicContractImplementation.class.getMethod("contractValue");
  
          final Method mostSpecificMethod = ClassUtils.getMostSpecificMethod(
                  interfaceMethod, PublicContractImplementation.class);
          final Method exposedInterfaceMethod = ClassUtils.getInterfaceMethodIfPossible(implementationMethod);
  
          assertThat(mostSpecificMethod).isEqualTo(implementationMethod);
          assertThat(exposedInterfaceMethod).isEqualTo(interfaceMethod);
      }
  
      public static final class NestedComponent {
      }
  
      private static final class ChildClassLoader extends ClassLoader {
  
          ChildClassLoader(ClassLoader parent) {
              super(parent);
          }
      }
  
      public static final class PublicMemberTarget {
  
          private final String value;
  
          public PublicMemberTarget(String value) {
              this.value = value;
          }
  
          public String value() {
              return value;
          }
  
          public String publicMethod(String suffix) {
              return value + '-' + suffix;
          }
  
          public String uniqueOverload() {
  
