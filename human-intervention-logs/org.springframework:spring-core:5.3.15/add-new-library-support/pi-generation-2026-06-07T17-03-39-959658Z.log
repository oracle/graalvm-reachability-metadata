              super(parent);
          }
  
          public Class<?> publicDefineClass(String name, byte[] bytes, ProtectionDomain protectionDomain) {
              return defineClass(name, bytes, 0, bytes.length, protectionDomain);
          }
      }
  
      private static final class ChildOnlyClassLoader extends ClassLoader {
  
          ChildOnlyClassLoader(ClassLoader parent) {
              super(parent);
          }
      }
  
      private static final class ConstructorTarget {
  
          private final String value;
  
          private ConstructorTarget(String value) {
              this.value = value;
          }
  
          String value() {
              return value;
          }
      }
  
      private static class MethodParent {
  
          String inheritedValue() {
              return "parent";
          }
      }
  
      private interface MethodInterface {
  
          String interfaceValue();
      }
  
      private static final class MethodChild extends MethodParent implements MethodInterface {
  
          String childValue() {
              return "child";
          }
  
          @Override
          public String interfaceValue() {
              return "interface";
          }
      }
  
      private interface SingleMethodFactory {
  
          Object newInstance();
      }
  }
