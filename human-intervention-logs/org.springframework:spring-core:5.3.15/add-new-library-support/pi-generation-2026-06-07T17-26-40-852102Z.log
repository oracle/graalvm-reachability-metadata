nnotationAttributes(CompositeComponent.class, attributes, false);\n\n        assertThat((NestedAnnotation[]) attributes.get(\"mirrored\"))\n                .extracting(NestedAnnotation::name)\n                .containsExactly(\"alpha\", \"bravo\");\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void getAnnotationsSynthesizesAnnotationArrayForNonJdkElement() {\n        final Annotation[] annotations = AnnotationUtils.getAnnotations(CompositeComponent.class);\n\n        assertThat(annotations).isNotNull();\n        assertThat(annotations).hasSize(1);\n        assertThat(annotations[0]).isInstanceOf(CompositeAnnotation.class);\n        assertThat(((CompositeAnnotation) annotations[0]).nested())\n                .extracting(NestedAnnotation::name)\n                .containsExactly(\"alpha\", \"bravo\");\n    }\n\n    @NamedAnnotation(value = \"spring\", qualifier = \"core\")\n    private static final class NamedComponent {\n    }\n\n    @CompositeAnnotation(nested = {\n            @NestedAnnotation(name = \"alpha\"),\n            @NestedAnnotation(name = \"bravo\")\n    })\n    private static final class CompositeComponent {\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface NamedAnnotation {\n\n        String value();\n\n        String qualifier() default \"\";\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface MirroredNestedArrayAnnotation {\n\n        @AliasFor(\"mirrored\")\n        NestedAnnotation[] value() default {};\n\n        @AliasFor(\"value\")\n        NestedAnnotation[] mirrored() default {};\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface CompositeAnnotation {\n\n        NestedAnnotation[] nested();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface NestedAnnotation {\n\n        String name();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 881, "output": 1720, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 34345, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780853159368, "responseId": "resp_004ef1b48b4fd396016a25a9a7e56081939ae36acd6ea5df28"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_DWy0RX5NMfk3aYzGQfTLzV4W|fc_004ef1b48b4fd396016a25a9be72cc8193811df67d93cd14ee", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3304 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/AnnotationUtilsTest.java"}], "isError": false, "timestamp": 1780853190388}]}
