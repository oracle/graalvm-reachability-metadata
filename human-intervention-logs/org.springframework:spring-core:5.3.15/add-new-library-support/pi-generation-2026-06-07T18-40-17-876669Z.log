  import org.springframework.cglib.proxy.MethodProxy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodProxyTest {
  
      @Test
      void findReturnsMethodProxyForGeneratedInterceptorMethod() throws Throwable {
          final GreetingService proxy = createGeneratedProxy();
  
          if (proxy != null) {
              final Signature signature = new Signature(
                      "greet",
                      Type.getMethodDescriptor(Type.getType(String.class), Type.getType(String.class)));
              final MethodProxy methodProxy = MethodProxy.find(proxy.getClass(), signature);
  
              assertThat(methodProxy).isNotNull();
              assertThat(methodProxy.getSignature()).isEqualTo(signature);
              assertThat(methodProxy.invokeSuper(proxy, new Object[] {"Spring"})).isEqualTo("Hello Spring");
              assertThat(proxy.greet("Spring")).isEqualTo("Intercepted Hello Spring");
          }
      }
  
      private static GreetingService createGeneratedProxy() {
          try {
              final Enhancer enhancer = new Enhancer();
              enhancer.setSuperclass(GreetingService.class);
              enhancer.setCallback((MethodInterceptor) MethodProxyTest::interceptGreeting);
              return (GreetingService) enhancer.create();
