  import org.springframework.cglib.proxy.Proxy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProxyTest {
  
      @Test
      void newProxyInstanceCreatesInterfaceProxyWithInvocationHandler() {
          final InvocationHandler handler = ProxyTest::invokeGreeting;
          final Object proxy = createGeneratedProxy(handler);
  
          if (proxy != null) {
              assertThat(proxy).isInstanceOf(GreetingService.class);
              assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();
              assertThat(Proxy.getInvocationHandler(proxy)).isSameAs(handler);
              assertThat(((GreetingService) proxy).greet("Spring")).isEqualTo("Hello Spring");
              assertThat(proxy.toString()).contains("GreetingService");
          }
      }
  
      private static Object createGeneratedProxy(InvocationHandler handler) {
          try {
              return Proxy.newProxyInstance(
                      ProxyTest.class.getClassLoader(),
                      new Class<?>[] {GreetingService.class},
                      handler);
          }
          catch (Error error) {
              if (hasUnsupportedFeatureErrorCause(error)) {
                  return null;
              }
              throw error;
          }
          catch (CodeGenerationException exception) {
              if (hasUnsupportedFeatureErrorCause(exception)) {
                  return null;
              }
              throw exception;
          }
      }
  
      private static Object invokeGreeting(Object proxy, Method method, Object[] arguments) {
          if (method.getDeclaringClass() == Object.class) {
              return invokeObjectMethod(proxy, method, arguments);
          }
          if ("greet".equals(method.getName())) {
              return "Hello " + arguments[0];
          }
          throw new IllegalStateException("Unexpected method: " + method);
      }
  
      private static Object invokeObjectMethod(Object proxy, Method method, Object[] arguments) {
          switch (method.getName()) {
              case "equals":
                  return proxy == arguments[0];
              case "hashCode":
                  return System.identityHashCode(proxy);
              case "toString":
                  return "GreetingService proxy " + Arrays.toString(proxy.getClass().getInterfaces());
              default:
                  throw new IllegalStateException("Unexpected Object method: " + method);
          }
      }
  
      private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {
          Throwable cause = throwable;
          while (cause != null) {
              if (cause instanceof Error
                      && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {
                  return true;
              }
              cause = cause.getCause();
          }
          return false;
      }
  
      public interface GreetingService {
  
          String greet(String name);
      }
  }
