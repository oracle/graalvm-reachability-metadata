work.spring_core;\n\nimport java.lang.reflect.Method;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.cglib.core.CodeGenerationException;\nimport org.springframework.cglib.proxy.Callback;\nimport org.springframework.cglib.proxy.Enhancer;\nimport org.springframework.cglib.proxy.Factory;\nimport org.springframework.cglib.proxy.MethodInterceptor;\nimport org.springframework.cglib.proxy.MethodProxy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnhancerTest {\n\n    @Test\n    void cachedProxyCreationInstallsFactoryDataAndCallbackSetters() {\n        final Object proxy = createGeneratedProxy(() -> {\n            final Enhancer enhancer = new Enhancer();\n            enhancer.setSuperclass(GreetingService.class);\n            enhancer.setCallback((MethodInterceptor) EnhancerTest::interceptGreeting);\n            return enhancer.create();\n        });\n\n        if (proxy != null) {\n            assertThat(proxy).isInstanceOf(GreetingService.class);\n            assertThat(proxy).isInstanceOf(Factory.class);\n            assertThat(((GreetingService) proxy).greet(\"Spring\"))\n                    .isEqualTo(\"Hello Spring through enhancer\");\n            assertThat(Enhancer.isEnhanced(proxy.getClass())).isTrue();\n\n            final Callback[] callbacks = new Callback[] {\n                    (MethodInterceptor) EnhancerTest::interceptRegisteredGreeting};\n            try {\n                Enhancer.registerCallbacks(proxy.getClass(), callbacks);\n                Enhancer.registerStaticCallbacks(proxy.getClass(), callbacks);\n            }\n            finally {\n                Enhancer.registerCallbacks(proxy.getClass(), null);\n                Enhancer.registerStaticCallbacks(proxy.getClass(), null);\n            }\n        }\n    }\n\n    private static Object interceptGreeting(\n            Object object,\n            Method method,\n            Object[] arguments,\n            MethodProxy methodProxy) throws Throwable {\n        final Object value = methodProxy.invokeSuper(object, arguments);\n        if (\"greet\".equals(method.getName())) {\n            return value + \" through enhancer\";\n        }\n        return value;\n    }\n\n    private static Object interceptRegisteredGreeting(\n            Object object,\n            Method method,\n            Object[] arguments,\n            MethodProxy methodProxy) throws Throwable {\n        if (\"greet\".equals(method.getName())) {\n            return \"Registered \" + arguments[0];\n        }\n        return methodProxy.invokeSuper(object, arguments);\n    }\n\n    private static Object createGeneratedProxy(ProxyFactory proxyFactory) {\n        try {\n            return proxyFactory.create();\n        }\n        catch (Error error) {\n            if (hasUnsupportedFeatureErrorCause(error)) {\n                return null;\n            }\n            throw error;\n        }\n        catch (CodeGenerationException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return null;\n            }\n            throw exception;\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable cause = throwable;\n        while (cause != null) {\n            if (cause instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {\n                return true;\n            }\n            cause = cause.getCause();\n        }\n        return false;\n    }\n\n    @FunctionalInterface\n    private interface ProxyFactory {\n\n        Object create();\n    }\n\n    public static class GreetingService {\n\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780857286322}, {"role": "toolResult", "toolCallId": "call_Upack7OrUICzau2VU0Zkpu0y|fc_0821a8188c74fc3e016a25b9c