  		return getRequiredAttributeValue(attributeName, Class.class);
  	}
  
  	@Override
  	public Class<?>[] getClassArray(String attributeName) {
  		return getRequiredAttributeValue(attributeName, Class[].class);
  	}
  
  	@Override
