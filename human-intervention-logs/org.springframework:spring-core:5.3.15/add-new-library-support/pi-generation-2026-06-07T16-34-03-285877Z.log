et.class, new Class<?>[] {String.class});\n        final Object instance = ReflectUtils.newInstance(constructor, new Object[] {\"spring\"});\n        assertThat(instance).isInstanceOf(ConstructorTarget.class);\n        assertThat(((ConstructorTarget) instance).value()).isEqualTo(\"spring\");\n    }\n\n    @Test\n    void methodDiscoveryWalksDeclaredMethodsInterfacesAndSuperclasses() throws Exception {\n        final Method inheritedMethod = ReflectUtils.findDeclaredMethod(\n                MethodChild.class, \"inheritedValue\", new Class<?>[0]);\n        assertThat(inheritedMethod.getDeclaringClass()).isEqualTo(MethodParent.class);\n\n        final List<Method> methods = new ArrayList<>();\n        ReflectUtils.addAllMethods(MethodChild.class, methods);\n        final List<String> methodNames = methods.stream().map(Method::getName).collect(Collectors.toList());\n        assertThat(methodNames).contains(\"childValue\", \"inheritedValue\", \"interfaceValue\");\n\n        final Method interfaceMethod = ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);\n        assertThat(interfaceMethod.getName()).isEqualTo(\"newInstance\");\n    }\n\n    @Test\n    void defineClassUsesPreferredLookupForMatchingContextLoader() throws Exception {\n        final String className = \"org_springframework.spring_core.ReflectUtilsPreferredDefined\";\n        final byte[] classBytes = generateSimpleClass(className);\n\n        final Class<?> definedClass = defineGeneratedClass(() -> ReflectUtils.defineClass(\n                className, classBytes, ReflectUtilsTest.class.getClassLoader(), null, ReflectUtilsTest.class));\n\n        if (definedClass != null) {\n            assertThat(definedClass.getName()).isEqualTo(className);\n            assertThat(definedClass.getClassLoader()).isSameAs(ReflectUtilsTest.class.getClassLoader());\n        }\n    }\n\n    @Test\n    void defineClassUsesPublicDefineClassOnCustomLoader() throws Exception {\n        final String className = \"org_springframework.spring_core.ReflectUtilsPublicDefined\";\n        final byte[] classBytes = generateSimpleClass(className);\n        final PublicDefineClassLoader loader = new PublicDefineClassLoader(ReflectUtilsTest.class.getClassLoader());\n\n        final Class<?> definedClass = defineGeneratedClass(() -> ReflectUtils.defineClass(\n                className, classBytes, loader, null, null));\n\n        if (definedClass != null) {\n            assertThat(definedClass.getName()).isEqualTo(className);\n            assertThat(definedClass.getClassLoader()).isSameAs(loader);\n        }\n    }\n\n    @Test\n    void defineClassFallsBackToContextLookupForDifferentLoaders() throws Exception {\n        final String className = \"org_springframework.spring_core.ReflectUtilsFallbackDefined\";\n        final byte[] classBytes = generateSimpleClass(className);\n        final ClassLoader loader = new ChildOnlyClassLoader(ReflectUtilsTest.class.getClassLoader());\n\n        final Class<?> definedClass = defineGeneratedClass(() -> ReflectUtils.defineClass(\n                className, classBytes, loader, null, ReflectUtilsTest.class));\n\n        if (definedClass != null) {\n            assertThat(definedClass.getName()).isEqualTo(className);\n        }\n    }\n\n    private static Class<?> defineGeneratedClass(DefineClassAction action) throws Exception {\n        try {\n            return action.defineClass();\n        }\n        catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return null;\n        }\n        catch (CodeGenerationException exception) {\n            final Throwable cause = exception.getCause();\n            if (cause instanceof Error && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {\n                return null;\n            }\n            throw exception;\n        }\n    }\n\n    private static byte[] generateSimpleClass(String className) {\n        final String internalName = className.replace('.', '/');\n        final ClassWriter classWriter = new ClassWriter(0);\n        classWriter.visit(Opcodes.V1_8, Opcodes.ACC_PUBLIC, internalName, null, \"java/lang/Object\", null);\n\n        final MethodVisitor constructor = classWriter.visitMethod(Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\", false);\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n\n        final MethodVisitor message = classWriter.visitMethod(\n                Opcodes.ACC_PUBLIC, \"message\", \"()Ljava/lang/String;\", null, null);\n        message.visitCode();\n        message.visitLdcInsn(\"defined\");\n        message.visitInsn(Opcodes.ARETURN);\n        message.visitMaxs(1, 1);\n        message.visitEnd();\n\n        classWriter.visitEnd();\n        return classWriter.toByteArray();\n    }\n\n    @FunctionalInterface\n    private interface DefineClassAction {\n        Class<?> defineClass() throws Exception;\n    }\n\n    public static class PublicDefineClassLoader extends ClassLoader {\n\n        PublicDefineClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public Class<?> publicDefineClass(String name, byte[] bytes, ProtectionDomain protectionDomain) {\n            return defineClass(name, bytes, 0, bytes.length, protectionDomain);\n        }\n    }\n\n    private static final class ChildOnlyClassLoader extends ClassLoader {\n\n        ChildOnlyClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n\n    private static final class ConstructorTarget {\n\n        private final String value;\n\n        private ConstructorTarget(String value) {\n            this.value = value;\n        }\n\n        String value() {\n       