  package org_springframework.spring_core;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.jboss.vfs.VFS;
  import org.jboss.vfs.VirtualFile;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import org.springframework.core.io.Resource;
  import org.springframework.core.io.VfsResource;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class VfsUtilsTest {
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void vfsResourceAccessesFileBackedVirtualFile() throws IOException {
          Path resourceFile = temporaryDirectory.resolve("sample.txt");
          String contents = "Spring VFS resource contents";
          Files.writeString(resourceFile, contents, StandardCharsets.UTF_8);
  
          VirtualFile virtualFile = VFS.getChild(resourceFile.toUri());
          Resource resource = new VfsResource(virtualFile);
  
          assertThat(resource.exists()).isTrue();
          assertThat(resource.isReadable()).isTrue();
          assertThat(resource.contentLength()).isEqualTo(contents.getBytes(StandardCharsets.UTF_8).length);
          assertThat(resource.lastModified()).isGreaterThan(0L);
          assertThat(resource.getFilename()).isEqualTo("sample.txt");
          assertThat(resource.getURL().getProtocol()).isEqualTo("vfs");
          assertThat(resource.getURI().getScheme()).isEqualTo("vfs");
          assertThat(Files.readString(resource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo(contents);
          try (InputStream inputStream = resource.getInputStream()) {
              assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(contents);
          }
      }
  
      @Test
      void vfsResourceCreatesRelativeResources() throws IOException {
          Path nestedDirectory = Files.createDirectory(temporaryDirectory.resolve("nested"));
          Path nestedFile = nestedDirectory.resolve("child.txt");
          Path siblingFile = temporaryDirectory.resolve("sibling.txt");
          Files.writeString(nestedFile, "nested", StandardCharsets.UTF_8);
          Files.writeString(siblingFile, "sibling", StandardCharsets.UTF_8);
  
          VirtualFile virtualDirectory = VFS.getChild(temporaryDirectory.toUri());
          Resource directoryResource = new VfsResource(virtualDirectory);
  
          Resource nestedResource = directoryResource.createRelative("nested/child.txt");
          assertThat(nestedResource.exists()).isTrue();
          assertThat(nestedResource.getFilename()).isEqualTo("child.txt");
          assertThat(Files.readString(nestedResource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo("nested");
  
          Resource siblingResource = directoryResource.createRelative("sibling.txt");
          assertThat(siblingResource.exists()).isTrue();
          assertThat(siblingResource.getFilename()).isEqualTo("sibling.txt");
          assertThat(Files.readString(siblingResource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo("sibling");
      }
  }
