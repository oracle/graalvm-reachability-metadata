  @Deprecated
  abstract class AbstractRecursiveAnnotationVisitor extends AnnotationVisitor {
  
  	protected final Log logger = LogFactory.getLog(getClass());
  
  	protected final AnnotationAttributes attributes;
  
  	@Nullable
