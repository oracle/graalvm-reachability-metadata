  package org_springframework.spring_core;
  
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.core.annotation.MergedAnnotation;
  import org.springframework.core.annotation.MergedAnnotation.Adapt;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypeMappedAnnotationTest {
  
      @Test
      void asMapAdaptsNestedAnnotationArraysToMapsAndSynthesizedAnnotations() {
          final MergedAnnotation<CompositeAnnotation> annotation = mergedAnnotationWithNestedMaps();
  
          final Map<String, Object> mapView = annotation.asMap(Adapt.ANNOTATION_TO_MAP);
          final Object[] nestedMaps = (Object[]) mapView.get("nested");
  
          assertThat(nestedMaps).hasSize(2);
          assertThat(nestedMaps[0]).isInstanceOf(Map.class);
          assertThat(((Map<?, ?>) nestedMaps[0]).get("name")).isEqualTo("alpha");
          assertThat(((Map<?, ?>) nestedMaps[1]).get("name")).isEqualTo("bravo");
  
          final Map<String, Object> synthesizedView = annotation.asMap();
          final NestedAnnotation[] nestedAnnotations = (NestedAnnotation[]) synthesizedView.get("nested");
  
          assertThat(nestedAnnotations).extracting(NestedAnnotation::name).containsExactly("alpha", "bravo");
      }
  
      @Test
      void synthesizeAdaptsNestedAnnotationArraysToAnnotationArrays() {
          final CompositeAnnotation synthesized = mergedAnnotationWithNestedMaps().synthesize();
  
          assertThat(synthesized.nested()).extracting(NestedAnnotation::name).containsExactly("alpha", "bravo");
      }
  
      @Test
      void scalarAttributeValueCanBeReadAsSingleElementArray() {
          final MergedAnnotation<CompositeAnnotation> annotation = MergedAnnotation.of(
                  CompositeAnnotation.class, Map.of("names", "spring"));
  
          assertThat(annotation.getStringArray("names")).containsExactly("spring");
      }
  
      @Test
      void emptyObjectArrayCanRepresentEmptyClassArray() {
          final MergedAnnotation<CompositeAnnotation> annotation = MergedAnnotation.of(
                  CompositeAnnotation.class, Map.of("classes", new Object[0]));
  
          assertThat(annotation.getClassArray("classes")).isEmpty();
      }
  
      private static MergedAnnotation<CompositeAnnotation> mergedAnnotationWithNestedMaps() {
          final Object[] nested = new Object[] {
                  Map.of("name", "alpha"),
                  Map.of("name", "bravo")
          };
          return MergedAnnotation.of(CompositeAnnotation.class, Map.of("nested", nested));
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface CompositeAnnotation {
  
          NestedAnnotation[] nested() default {};
  
          String[] names() default {};
  
          Class<?>[] classes() default {};
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface NestedAnnotation {
  
          String name();
      }
  }
