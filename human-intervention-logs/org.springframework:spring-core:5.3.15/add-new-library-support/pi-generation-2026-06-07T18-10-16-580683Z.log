adataReadingVisitor visitor = new AnnotationMetadataReadingVisitor(\n                RecursiveAnnotationArrayVisitorTest.class.getClassLoader());\n        new ClassReader(arrayAnnotatedClass()).accept(visitor, ClassReader.SKIP_DEBUG | ClassReader.SKIP_CODE\n                | ClassReader.SKIP_FRAMES);\n\n        final AnnotationAttributes attributes = visitor.getAnnotationAttributes(ArrayContainer.class.getName(), false);\n\n        assertThat(attributes).isNotNull();\n        assertThat(attributes.getStringArray(\"names\")).containsExactly(\"spring\", \"core\");\n        assertThat(attributes.getStringArray(\"emptyNames\")).isEmpty();\n    }\n\n    private static byte[] arrayAnnotatedClass() {\n        final ClassWriter writer = new ClassWriter(0);\n        writer.visit(Opcodes.V1_8, Opcodes.ACC_PUBLIC,\n                \"org_springframework/spring_core/GeneratedArrayAnnotatedComponent\", null,\n                \"java/lang/Object\", null);\n\n        final AnnotationVisitor annotation = writer.visitAnnotation(descriptor(ArrayContainer.class), true);\n        final AnnotationVisitor names = annotation.visitArray(\"names\");\n        names.visit(null, \"spring\");\n        names.visit(null, \"core\");\n        names.visitEnd();\n        final AnnotationVisitor emptyNames = annotation.visitArray(\"emptyNames\");\n        emptyNames.visitEnd();\n        annotation.visitEnd();\n\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static String descriptor(Class<?> type) {\n        return \"L\" + type.getName().replace('.', '/') + \";\";\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface ArrayContainer {\n\n        String[] names() default {};\n\n        String[] emptyNames() default {};\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1306, "output": 1662, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 29592, "cost": {"input": 0, "output": 0, "cacheRead"