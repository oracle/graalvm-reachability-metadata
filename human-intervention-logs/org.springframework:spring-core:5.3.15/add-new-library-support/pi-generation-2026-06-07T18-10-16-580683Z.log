  package org_springframework.spring_core;
  
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.core.annotation.AnnotationAttributes;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnnotationAttributesTest {
  
      @Test
      void constructorResolvesAnnotationTypeWithSuppliedClassLoader() {
          final AnnotationAttributes attributes = new AnnotationAttributes(
                  SampleAnnotation.class.getName(), SampleAnnotation.class.getClassLoader());
  
          assertThat(attributes.annotationType()).isEqualTo(SampleAnnotation.class);
      }
  
      @Test
      void getAnnotationArrayWrapsSingleAnnotationAttribute() {
          final SampleAnnotation annotation = AnnotatedComponent.class.getAnnotation(SampleAnnotation.class);
          final AnnotationAttributes attributes = new AnnotationAttributes(SampleAnnotation.class);
          attributes.put("nested", annotation);
  
          final SampleAnnotation[] annotations = attributes.getAnnotationArray("nested", SampleAnnotation.class);
  
          assertThat(annotations).containsExactly(annotation);
      }
  
      @SampleAnnotation("spring")
      private static final class AnnotatedComponent {
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface SampleAnnotation {
  
          String value();
      }
  }
