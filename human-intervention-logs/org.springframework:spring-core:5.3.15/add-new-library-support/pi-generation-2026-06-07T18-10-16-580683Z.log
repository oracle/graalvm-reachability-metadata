[tool-call] delta {"path":"tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/RecursiveAnnotationArrayVisitorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.asm.AnnotationVisitor;\nimport org.springframework.asm.ClassReader;\nimport org.springframework.asm.ClassWriter;\nimport org.springframework.asm.Opcodes;\nimport org.springframework.core.annotation.AnnotationAttributes;\nimport org.springframework.core.type.classreading.AnnotationMetadataReadingVisitor;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RecursiveAnnotationArrayVisitorTest {\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void annotationMetadataReadingVisitorReadsPopulatedAndEmptyArrayAttributes() {\n        final AnnotationMetadataReadingVisitor visitor = new AnnotationMetadataReadingVisitor(\n                RecursiveAnnotationArrayVisitorTest.class.getClassLoader());\n        new ClassReader(arrayAnnotatedClass()).accept(visitor, ClassReader.SKIP_DEBUG | ClassReader.SKIP_CODE\n                | ClassReader.SKIP_FRAMES);\n\n        final AnnotationAttributes attributes = visitor.getAnnotationAttributes(ArrayContainer.class.getName(), false);\n\n        assertThat(attributes).isNotNull();\n        assertThat(attributes.getStringArray(\"names\")).containsExactly(\"spring\", \"core\");\n        assertThat(attributes.getStringArray(\"emptyNames\")).isEmpty();\n    }\n\n    private static byte[] arrayAnnotatedClass() {\n        final ClassWriter writer = new ClassWriter(0);\n        writer.visit(Opcodes.V1_8, Opcodes.ACC_PUBLIC,\n                \"org_springframework/spring_core/GeneratedArrayAnnotatedComponent\", null,\n                \"java/lang/Object\", null);\n\n        final AnnotationVisitor annotation = writer.visitAnnotation(descriptor(ArrayContainer.class), true);\n        final AnnotationVisitor names = annotation.visitArray(\"names\");\n        names.visit(null, \"spring\");\n        names.visit(null, \"core\");\n        names.visitEnd();\n        final AnnotationVisitor emptyNames = annotation.visitArray(\"emptyNames\");\n        emptyNames.visitEnd();\n        annotation.visitEnd();\n\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static String descriptor(Class<?> type) {\n        return \"L\" + type.getName().replace('.', '/') + \";\";\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface ArrayContainer {\n\n        String[] names() default {};\n\n        String[] emptyNames() default {};\n    }\n}\n"}
