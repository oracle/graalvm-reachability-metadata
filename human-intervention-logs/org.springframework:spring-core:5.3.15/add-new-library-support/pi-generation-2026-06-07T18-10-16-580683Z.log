  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RecursiveAnnotationArrayVisitorTest {
  
      @Test
      @SuppressWarnings("deprecation")
      void annotationMetadataReadingVisitorReadsPopulatedAndEmptyArrayAttributes() {
          final AnnotationMetadataReadingVisitor visitor = new AnnotationMetadataReadingVisitor(
                  RecursiveAnnotationArrayVisitorTest.class.getClassLoader());
