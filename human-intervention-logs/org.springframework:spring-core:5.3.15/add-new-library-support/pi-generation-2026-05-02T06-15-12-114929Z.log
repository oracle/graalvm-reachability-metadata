  	@AliasFor("attribute")
  	String value() default "";
  
  	/**
  	 * The name of the attribute that <em>this</em> attribute is an alias for.
  	 * @see #value
  	 */
  	@AliasFor("value")
  	String attribute() default "";
  
  	/**
