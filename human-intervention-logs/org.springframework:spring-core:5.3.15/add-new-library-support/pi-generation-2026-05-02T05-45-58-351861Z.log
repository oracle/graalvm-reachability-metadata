  	}
  
  	@Override
  	protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
  		if (isEligibleForOverriding(name)) {
  			Class<?> result = loadClassForOverriding(name);
  			if (result != null) {
