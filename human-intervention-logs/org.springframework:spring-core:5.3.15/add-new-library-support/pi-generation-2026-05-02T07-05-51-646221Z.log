nstantiatorTest.java"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2578, "output": 1434, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 33708, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777705523322, "responseId": "resp_06719a1e1c175d880169f5a233c6a88195bee8aaeedb81f1a9"}}
