  +        } catch (Error error) {
  +            ignoreUnsupportedDynamicClassLoading(error);
  +        }
  +    }
  +
  +    private static void installObjectStreamClassRedirect() {
  +        if (!transformerInstalled.compareAndSet(false, true)) {
  +            return;
  +        }
