          classWriter.visit(
                  Opcodes.V1_8,
                  Opcodes.ACC_PUBLIC,
                  DYNAMIC_DEFINITION_PROBE_CLASS_NAME,
                  null,
                  Type.getInternalName(Object.class),
                  null
