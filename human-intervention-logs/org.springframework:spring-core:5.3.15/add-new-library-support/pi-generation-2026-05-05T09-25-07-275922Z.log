rce;\nimport org.springframework.core.io.VfsResource;\n\npublic class VfsUtilsTest {\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void vfsResourceDelegatesToVirtualFileThroughVfsUtils() throws Exception {\n        Path resourceFile = temporaryDirectory.resolve(\"sample.txt\");\n        Files.writeString(resourceFile, \"spring-vfs\", StandardCharsets.UTF_8);\n\n        Resource resource = new VfsResource(new VirtualFile(resourceFile));\n\n        assertThat(resource.exists()).isTrue();\n        assertThat(resource.isReadable()).isTrue();\n        assertThat(resource.contentLength()).isEqualTo(10L);\n        assertThat(resource.lastModified()).isGreaterThan(0L);\n        assertThat(resource.getFilename()).isEqualTo(\"sample.txt\");\n        assertThat(resource.getURL()).isEqualTo(resourceFile.toUri().toURL());\n        assertThat(resource.getURI()).isEqualTo(resourceFile.toUri());\n        assertThat(resource.getFile()).isEqualTo(resourceFile.toFile());\n        try (InputStream inputStream = resource.getInputStream()) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"spring-vfs\");\n        }\n    }\n\n    @Test\n    void vfsResourceCreatesRelativeResourcesThroughVfsUtils() throws Exception {\n        Path rootDirectory = temporaryDirectory.resolve(\"root\");\n        Path nestedFile = rootDirectory.resolve(\"nested\").resolve(\"child.txt\");\n        Files.createDirectories(nestedFile.getParent());\n        Files.writeString(nestedFile, \"nested\", StandardCharsets.UTF_8);\n\n        Resource root = new VfsResource(new VirtualFile(rootDirectory));\n        Resource relative = root.createRelative(\"nested/child.txt\");\n\n        assertThat(relative).isInstanceOf(VfsResource.class);\n        assertThat(relative.exists()).isTrue();\n        assertThat(relative.getFilename()).isEqualTo(\"child.txt\");\n        assertThat(relative.contentLength()).isEqualTo(6L);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 938, "output": 1955, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 31053, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777972978167, "responseId": "resp_0bf2ba5f4d8f26120169f9b6f2ee1481a0878d51220fb42f44"}}
[tool-exec] start id=call_sa3PAvAt74zwN37zSUAGe0L7|fc_0bf2ba5f4d8f26120169f9b707a95481a0bdac21e2c8602635 name=write args={"path": "tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/VfsUtilsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.jboss.vfs.VirtualFile;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.springframework.core.io.Resource;\nimport org.springframework.core.io.VfsResource;\n\npublic class VfsUtilsTest {\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void vfsResourceDelegatesToVirtualFileThroughVfsUtils() throws Exception {\n        Path resourceFile = temporaryDirectory.resolve(\"sample.txt\");\n        Files.writeString(resourceFile, \"spring-vfs\", StandardCharsets.UTF_8);\n\n        Resource resource = new VfsResource(new VirtualFile(resourceFile));\n\n        assertThat(resource.exists()).isTrue();\n        assertThat(resource.isReadable()).isTrue();\n        assertThat(resource.contentLength()).isEqualTo(10L);\n        assertThat(resource.lastModified()).isGreaterThan(0L);\n        assertThat(resource.getFilename()).isEqualTo(\"sample.txt\");\n        assertThat(resource.getURL()).isEqualTo(resourceFile.toUri().toURL());\n        assertThat(resource.getURI()).isEqualTo(resourceFile.toUri());\n        assertThat(resource.getFile()).isEqualTo(resourceFile.toFile());\n        try (InputStream inputStream = resource.getInputStream()) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"spring-vfs\");\n        }\n    }\n\n    @Test\n    void vfsResourceCreatesRelativeResourcesThroughVfsUtils() throws Exception {\n        Path rootDirectory = temporaryDirectory.resolve(\"root\");\n        Path nestedFile = rootDirectory.resolve(\"nested\").resolve(\"child.txt\");\n        Files.createDirectories(nestedFile.getParent());\n        Files.writeString(nestedFile, \"nested\", StandardCharsets.UTF_8);\n\n        Resource root = new VfsResource(new VirtualFile(rootDirectory));\n        Resource relative = root.createRelative(\"nested/child.txt\");\n\n        assertThat(relative).isInstanceOf(VfsResource.class);\n        assertThat(relative.exists()).isTrue();\n        assertThat(relative.getFilename()).isEqualTo(\"child.txt\");\n        assertThat(relative.contentLength()).isEqualTo(6L);\n    }\n}\n"}
