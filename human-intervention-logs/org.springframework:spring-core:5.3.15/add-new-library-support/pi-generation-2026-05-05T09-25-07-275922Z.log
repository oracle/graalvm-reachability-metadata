ssertions.assertThat;\n\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.jboss.vfs.VirtualFile;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.springframework.core.io.Resource;\nimport org.springframework.core.io.VfsResource;\n\npublic class VfsUtilsTest {\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void vfsResourceDelegatesToVirtualFileThroughVfsUtils() throws Exception {\n        Path resourceFile = temporaryDirectory.resolve(\"sample.txt\");\n        Files.writeString(resourceFile, \"spring-vfs\", StandardCharsets.UTF_8);\n\n        Resource resource = new VfsResource(new VirtualFile(resourceFile));\n\n        assertThat(resource.exists()).isTrue();\n        assertThat(resource.isReadable()).isTrue();\n        assertThat(resource.contentLength()).isEqualTo(10L);\n        assertThat(resource.lastModified()).isGreaterThan(0L);\n        assertThat(resource.getFilename()).isEqualTo(\"sample.txt\");\n        assertThat(resource.getURL()).isEqualTo(resourceFile.toUri().toURL());\n        assertThat(resource.getURI()).isEqualTo(resourceFile.toUri());\n        assertThat(resource.getFile()).isEqualTo(resourceFile.toFile());\n        try (InputStream inputStream = resource.getInputStream()) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"spring-vfs\");\n        }\n    }\n\n    @Test\n    void vfsResourceCreatesRelativeResourcesThroughVfsUtils() throws Exception {\n        Path rootDirectory = temporaryDirectory.resolve(\"root\");\n        Path nestedFile = rootDirectory.resolve(\"nested\").resolve(\"child.txt\");\n        Files.createDirectories(nestedFile.getParent());\n        Files.writeString(nestedFile, \"nested\", StandardCharsets.UTF_8);\n\n        Resource root = new VfsResource(new VirtualFile(rootDirectory));\n        Resource relative = root.createRelative(\"nested/child.txt\");\n\n        assertThat(relative).isInstanceOf(VfsResource.class);\n        assertThat(relative.exists()).isTrue();\n        assertThat(relative.getFilename()).isEqualTo(\"child.txt\");\n        assertThat(relative.contentLength()).isEqualTo(6L);\n    }\n}\n"}], "isError": false, "timestamp": 1777973065832}, {"role": "toolResult", "toolCallId": "call_23aQvKJWGRAraRXBw0Jy7IDW|fc_0bf2ba5f4d8f26120169f9b74982ac81a0a31b0a2ef96d77c2", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.jboss.vfs;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URI;\nimport java.net.URL;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\npublic class VirtualFile {\n    private final Path path;\n\n    public VirtualFile(Path path) {\n        this.path = path;\n    }\n\n    public boolean exists() {\n        return Files.exists(path);\n    }\n\n    public InputStream openStream() throws IOException {\n        return Files.newInputStream(path);\n    }\n\n    public long getSize() throws IOException {\n        return Files.size(path);\n    }\n\n    public long getLastModified() throws IOException {\n        return Files.getLastModifiedTime(path).toMillis();\n    }\n\n    public URI toURI() {\n        return path.toUri();\n    }\n\n    public URL toURL() throws IOException {\n        return toURI().toURL();\n    }\n\n    public String getName() {\n        Path fileName = path.getFileName();\n        return fileName == null ? \"\" : fileName.toString();\n    }\n\n    public String getPathName() {\n        return path.toString();\n    }\n\n    public File getPhysicalFile() {\n        return path.toFile();\n    }\n\n    public VirtualFile getChild(String childPath) {\n        return new VirtualFile(path.resolve(childPath));\n    }\n\n    public void visit(VirtualFileVisitor visitor) {\n        visitor.visit(this);\n    }\n\n    @Override\n    public String toString() {\n        return path.toString();\n    }\n}\n"}], "isError": false, "timestamp": 1777973065832}, {"role": "toolResult", "toolCallId": "call_0ICyXiUmcb5m69HqcrkWGZS0|fc_0bf2ba5f4d8f26120169f9b74982b481a09953ec43eec7c5b7", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.jboss.vfs;\n\nimport java.net.URI;\nimport java.net.URL;\nimport java.nio.file.Path;\nimport java.nio.file.Paths;\n\npublic final class VFS {\n    private VFS() {\n    }\n\n    public static VirtualFile getChild(URL url) throws Exception {\n        return getChild(url.toURI());\n    }\n\n    public static VirtualFile getChild(URI uri) {\n        return new VirtualFile(Paths.get(uri));\n    }\n}\n"}], "isError": false, "timestamp": 1777973065832}]}
