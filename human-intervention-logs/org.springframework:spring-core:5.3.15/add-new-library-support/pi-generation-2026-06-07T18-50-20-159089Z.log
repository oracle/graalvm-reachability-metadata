  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_springframework.spring_core;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.Arrays;
  import java.util.List;
  import java.util.stream.Collectors;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.util.ReflectionUtils;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectionUtilsTest {
  
      @Test
      void accessibleConstructorFindsAndOpensPrivateConstructors() throws Exception {
          final Constructor<ConstructedComponent> constructor = ReflectionUtils.accessibleConstructor(
                  ConstructedComponent.class, String.class);
  
          assertThat(constructor.getDeclaringClass()).isEqualTo(ConstructedComponent.class);
          assertThat(constructor.canAccess(null)).isTrue();
      }
  
      @Test
      void methodUtilitiesFindDeclaredInterfaceDefaultAndInvokePrivateMethods() {
          final Method privateMethod = ReflectionUtils.findMethod(MethodComponent.class, "message", String.class);
          final Method interfaceMethod = ReflectionUtils.findMethod(DefaultMessageProvider.class, "defaultMessage");
          final Method[] declaredMethods = ReflectionUtils.getDeclaredMethods(MethodComponent.class);
          final MethodComponent target = new MethodComponent("spring");
  
          assertThat(privateMethod).isNotNull();
          ReflectionUtils.makeAccessible(privateMethod);
          assertThat(ReflectionUtils.invokeMethod(privateMethod, target, "core")).isEqualTo("spring-core");
  
          assertThat(interfaceMethod).isNotNull();
          assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(DefaultMessageProvider.class);
  
          final List<String> methodNames = Arrays.stream(declaredMethods)
                  .map(Method::getName)
                  .collect(Collectors.toList());
          assertThat(methodNames).contains("message", "defaultMessage");
      }
  
      @Test
      void fieldUtilitiesFindSetAndReadPrivateFields() {
          final Field field = ReflectionUtils.findField(FieldComponent.class, "value", String.class);
          final FieldComponent target = new FieldComponent("initial");
  
          assertThat(field).isNotNull();
          ReflectionUtils.makeAccessible(field);
          ReflectionUtils.setField(field, target, "updated");
  
          assertThat(ReflectionUtils.getField(field, target)).isEqualTo("updated");
      }
  
      @Test
      void shallowCopyFieldStateCopiesMutableInstanceFieldsAcrossHierarchy() {
          final CopyComponent source = new CopyComponent("source", 42);
          final CopyComponent destination = new CopyComponent("destination", 7);
  
          ReflectionUtils.shallowCopyFieldState(source, destination);
  
          assertThat(destination.name()).isEqualTo("source");
          assertThat(destination.count()).isEqualTo(42);
          assertThat(destination.parentName()).isEqualTo("parent-source");
      }
  
      private static final class ConstructedComponent {
  
          private ConstructedComponent(String value) {
          }
      }
  
      private interface DefaultMessageProvider {
  
          default String defaultMessage() {
              return "default";
          }
      }
  
      private static final class MethodComponent implements DefaultMessageProvider {
  
          private final String prefix;
  
          private MethodComponent(String prefix) {
              this.prefix = prefix;
          }
  
          private String message(String suffix) {
              return prefix + '-' + suffix;
          }
      }
  
      private static final class FieldComponent {
  
          private String value;
  
          private FieldComponent(String value) {
              this.value = value;
          }
      }
  
      private static class CopyParentComponent {
  
          private String parentName;
  
          CopyParentComponent(String parentName) {
              this.parentName = parentName;
          }
  
          String parentName() {
              return parentName;
          }
      }
  
      private static final class CopyComponent extends CopyParentComponent {
  
          private String name;
  
          private int count;
  
          private CopyComponent(String name, int count) {
              super("parent-" + name);
              this.name = name;
              this.count = count;
          }
  
          String name() {
              return name;
          }
  
          int count() {
              return count;
          }
      }
