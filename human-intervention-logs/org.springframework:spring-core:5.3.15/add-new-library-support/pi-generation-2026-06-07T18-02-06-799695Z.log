blic static final class MethodSource {\n\n        private final String value;\n\n        public MethodSource(String value) {\n            this.value = value;\n        }\n\n        public MethodTarget toMethodTarget() {\n            return new MethodTarget(this.value + \"-target\");\n        }\n    }\n\n    public static final class MethodTarget {\n\n        private final String value;\n\n        public MethodTarget(String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return this.value;\n        }\n    }\n\n    public static final class StaticFactorySource {\n\n        private final String value;\n\n        public StaticFactorySource(String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return this.value;\n        }\n    }\n\n    public static final class StaticFactoryTarget {\n\n        private final String value;\n\n        private StaticFactoryTarget(String value) {\n            this.value = value;\n        }\n\n        public static StaticFactoryTarget valueOf(StaticFactorySource source) {\n            return new StaticFactoryTarget(source.value() + \"-target\");\n        }\n\n        public String value() {\n            return this.value;\n        }\n    }\n\n    public static final class ConstructorSource {\n\n        private final String value;\n\n        public ConstructorSource(String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return this.value;\n        }\n    }\n\n    public static final class ConstructorTarget {\n\n        private final String value;\n\n        public ConstructorTarget(ConstructorSource source) {\n            this.value = source.value() + \"-target\";\n        }\n\n        public String value() {\n            return this.value;\n        }\n    }\n}\n"}
