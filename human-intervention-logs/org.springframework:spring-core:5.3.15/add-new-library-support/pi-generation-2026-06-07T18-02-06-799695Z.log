rtName = ClassUtils.getShortName(entityClass);\n\t\tint lastDot = shortName.lastIndexOf('.');\n\t\tif (lastDot != -1) {\n\t\t\treturn shortName.substring(lastDot + 1);\n\t\t}\n\t\telse {\n\t\t\treturn shortName;\n\t\t}\n\t}\n\n}\n"}], "isError": false, "timestamp": 1780855305224}}
