  package org_springframework.spring_core;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.core.convert.support.DefaultConversionService;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ObjectToObjectConverterTest {
  
      @Test
      void convertsUsingSourceToTargetMethod() {
          final DefaultConversionService conversionService = new DefaultConversionService();
          final MethodSource source = new MethodSource("method");
  
          final MethodTarget target = conversionService.convert(source, MethodTarget.class);
  
          assertThat(target).isNotNull();
          assertThat(target.value()).isEqualTo("method-target");
      }
  
      @Test
      void convertsUsingTargetStaticFactoryMethod() {
          final DefaultConversionService conversionService = new DefaultConversionService();
          final StaticFactorySource source = new StaticFactorySource("factory");
  
          final StaticFactoryTarget target = conversionService.convert(source, StaticFactoryTarget.class);
  
          assertThat(target).isNotNull();
          assertThat(target.value()).isEqualTo("factory-target");
      }
  
      @Test
      void convertsUsingTargetConstructor() {
          final DefaultConversionService conversionService = new DefaultConversionService();
          final ConstructorSource source = new ConstructorSource("constructor");
  
          final ConstructorTarget target = conversionService.convert(source, ConstructorTarget.class);
  
          assertThat(target).isNotNull();
          assertThat(target.value()).isEqualTo("constructor-target");
      }
  
      public static final class MethodSource {
  
          private final String value;
  
          public MethodSource(String value) {
              this.value = value;
          }
  
          public MethodTarget toMethodTarget() {
              return new MethodTarget(this.value + "-target");
          }
      }
  
      public static final class MethodTarget {
  
          private final String value;
  
          public MethodTarget(String value) {
              this.value = value;
          }
  
          public String value() {
              return this.value;
          }
      }
  
      public static final class StaticFactorySource {
  
          private final String value;
  
          public StaticFactorySource(String value) {
              this.value = value;
          }
  
          public String value() {
              return this.value;
          }
      }
  
      public static final class StaticFactoryTarget {
  
          private final String value;
  
          private StaticFactoryTarget(String value) {
              this.value = value;
          }
  
          public static StaticFactoryTarget valueOf(StaticFactorySource source) {
              return new StaticFactoryTarget(source.value() + "-target");
          }
  
          public String value() {
              return this.value;
          }
      }
  
      public static final class ConstructorSource {
  
          private final String value;
  
          public ConstructorSource(String value) {
              this.value = value;
          }
  
          public String value() {
              return this.value;
          }
      }
  
      public static final class ConstructorTarget {
  
          private final String value;
  
          public ConstructorTarget(ConstructorSource source) {
              this.value = source.value() + "-target";
          }
  
          public String value() {
              return this.value;
          }
      }
