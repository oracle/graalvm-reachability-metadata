          constructor.visitVarInsn(Opcodes.ALOAD, 0);
          constructor.visitMethodInsn(
                  Opcodes.INVOKESPECIAL,
                  Type.getInternalName(Object.class),
                  "<init>",
                  "()V",
                  false
