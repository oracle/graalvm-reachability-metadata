      private static final class ObjectStreamClassRedirectingMethodVisitor extends MethodVisitor {
  
          private ObjectStreamClassRedirectingMethodVisitor(MethodVisitor methodVisitor) {
              super(Opcodes.ASM9, methodVisitor);
