              Type type = (Type) value;
              if (type.getSort() == Type.OBJECT) {
                  return Type.getObjectType(remapInternalName(type.getInternalName()));
              }
              if (type.getSort() == Type.METHOD) {
                  return Type.getMethodType(remapDescriptor(type.getDescriptor()));
              }
          }
          return value;
