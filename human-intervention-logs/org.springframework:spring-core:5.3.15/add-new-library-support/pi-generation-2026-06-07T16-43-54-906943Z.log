  		try {
  			forName(className, classLoader);
  			return true;
  		}
  		catch (IllegalAccessError err) {
  			throw new IllegalStateException("Readability mismatch in inheritance hierarchy of class [" +
  					className + "]: " + err.getMessage(), err);
