dardCharsets.UTF_8)).isEqualTo(contents);\n        try (InputStream inputStream = resource.getInputStream()) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(contents);\n        }\n    }\n\n    @Test\n    void vfsResourceCreatesRelativeResources() throws IOException {\n        Path nestedDirectory = Files.createDirectory(temporaryDirectory.resolve(\"nested\"));\n        Path nestedFile = nestedDirectory.resolve(\"child.txt\");\n        Path siblingFile = temporaryDirectory.resolve(\"sibling.txt\");\n        Files.writeString(nestedFile, \"nested\", StandardCharsets.UTF_8);\n        Files.writeString(siblingFile, \"sibling\", StandardCharsets.UTF_8);\n\n        VirtualFile virtualDirectory = VFS.getChild(temporaryDirectory.toUri());\n        Resource directoryResource = new VfsResource(virtualDirectory);\n\n        Resource nestedResource = directoryResource.createRelative(\"nested/child.txt\");\n        assertThat(nestedResource.exists()).isTrue();\n        assertThat(nestedResource.getFilename()).isEqualTo(\"child.txt\");\n        assertThat(Files.readString(nestedResource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo(\"nested\");\n\n        Resource siblingResource = directoryResource.createRelative(\"sibling.txt\");\n        assertThat(siblingResource.exists()).isTrue();\n        assertThat(siblingResource.getFilename()).isEqualTo(\"sibling.txt\");\n        assertThat(Files.readString(siblingResource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo(\"sibling\");\n    }\n}\n"}], "isError": false, "timestamp": 1780850536694}}
