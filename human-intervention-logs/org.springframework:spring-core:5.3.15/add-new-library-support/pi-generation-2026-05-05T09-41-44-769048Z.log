lassName);\n+            assertThat(generatedClass.getClassLoader())\n+                    .isIn(delegatingLoader, ReflectUtilsTest.class.getClassLoader());\n+        }\n+        catch (InvocationTargetException exception) {\n+            rethrowUnlessUnsupportedFeatureError(exception.getCause());\n+        }\n+        catch (FindException exception) {\n+            // Native Image code sources point at the executable, not the original modular JAR.\n+            return;\n+        }\n+        catch (Error error) {\n+            rethrowUnlessUnsupportedFeatureError(error);\n         }\n     }\n \n@@ -127,6 +177,21 @@ public class ReflectUtilsTest {\n         }\n     }\n \n+    private static Class<?> loadReflectUtilsFromNamedModule() throws Exception {\n+        URI springCoreLocation = ReflectUtils.class.getProtectionDomain().getCodeSource().getLocation().toURI();\n+        ModuleFinder finder = ModuleFinder.of(Path.of(springCoreLocation));\n+        ModuleReference springCoreModule = finder.findAll().stream()\n+                .filter(reference -> reference.descriptor().packages().contains(\"org.springframework.cglib.core\"))\n+                .findFirst()\n+                .orElseThrow(() -> new IllegalStateException(\"No module contains Spring CGLIB core\"));\n+        String moduleName = springCoreModule.descriptor().name();\n+        Configuration configuration = ModuleLayer.boot().configuration()\n+                .resolve(finder, ModuleFinder.of(), Set.of(moduleName));\n+        ModuleLayer moduleLayer = ModuleLayer.boot()\n+                .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n+        return moduleLayer.findLoader(moduleName).loadClass(ReflectUtils.class.getName());\n+    }\n+\n     private static byte[] createClassBytes(String className) {\n         String internalName = className.replace('.', '/');\n         ClassWriter classWriter = new ClassWriter(0);\n"}], "isError": false, "timestamp": 1777975494811}]}
