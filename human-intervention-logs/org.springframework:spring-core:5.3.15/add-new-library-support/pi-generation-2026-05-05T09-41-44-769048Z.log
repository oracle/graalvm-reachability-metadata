[tool-call] delta {"path":"tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/ReflectUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\nimport java.security.ProtectionDomain;\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.springframework.asm.ClassWriter;\nimport org.springframework.asm.MethodVisitor;\nimport org.springframework.asm.Opcodes;\nimport org.springframework.cglib.core.CodeGenerationException;\nimport org.springframework.cglib.core.ReflectUtils;\n\npublic class ReflectUtilsTest {\n    private static final String TEST_PACKAGE = \"org_springframework.spring_core\";\n\n    @Test\n    void findConstructorAndFindMethodResolveNamedPrimitiveAndArrayTypes() {\n        Constructor<?> constructor = ReflectUtils.findConstructor(\"String(byte[])\");\n        Method method = ReflectUtils.findMethod(\"java.lang.String.substring(int)\");\n\n        assertThat(constructor.getDeclaringClass()).isEqualTo(String.class);\n        assertThat(constructor.getParameterTypes()).containsExactly(byte[].class);\n        assertThat(method.getDeclaringClass()).isEqualTo(String.class);\n        assertThat(method.getParameterTypes()).containsExactly(int.class);\n    }\n\n    @Test\n    void getConstructorAndNewInstanceCreateObjectThroughNonPublicConstructor() {\n        Constructor<?> constructor = ReflectUtils.getConstructor(ConstructedValue.class,\n                new Class<?>[] {String.class, int.class});\n\n        ConstructedValue value = (ConstructedValue) ReflectUtils.newInstance(constructor,\n                new Object[] {\"spring\", 15});\n\n        assertThat(value.text()).isEqualTo(\"spring\");\n        assertThat(value.number()).isEqualTo(15);\n    }\n\n    @Test\n    void findDeclaredMethodWalksSuperclassHierarchy() throws Exception {\n        Method method = ReflectUtils.findDeclaredMethod(ConcreteValue.class, \"inheritedValue\",\n                new Class<?>[] {String.class});\n\n        assertThat(method.getDeclaringClass()).isEqualTo(AbstractValue.class);\n        assertThat(method.getParameterTypes()).containsExactly(String.class);\n    }\n\n    @Test\n    void addAllMethodsCollectsDeclaredInheritedInterfaceAndObjectMethods() {\n        List<Method> methods = ReflectUtils.addAllMethods(ConcreteValue.class, new ArrayList<>());\n\n        assertThat(methods).extracting(Method::getName)\n                .contains(\"localValue\", \"inheritedValue\", \"interfaceValue\", \"toString\");\n    }\n\n    @Test\n    void findInterfaceMethodReturnsTheSingleDeclaredInterfaceMethod() {\n        Method method = ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);\n\n        assertThat(method.getName()).isEqualTo(\"newInstance\");\n        assertThat(method.getReturnType()).isEqualTo(Object.class);\n    }\n\n    @Test\n    void defineClassUsesLookupDefineClassWhenContextLoaderMatches() throws Exception {\n        String className = TEST_PACKAGE + \".ReflectUtilsGeneratedPreferred\";\n\n        Class<?> generatedClass = defineClass(className, ReflectUtilsTest.class.getClassLoader(),\n                ReflectUtilsTest.class);\n\n        if (generatedClass != null) {\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());\n        }\n    }\n\n    @Test\n    void defineClassUsesPublicDefineClassMethodOnCustomClassLoader() throws Exception {\n        String className = TEST_PACKAGE + \".ReflectUtilsGeneratedPublic\";\n        PublicDefineClassLoader classLoader = new PublicDefineClassLoader(ReflectUtilsTest.class.getClassLoader());\n\n        Class<?> generatedClass = defineClass(className, classLoader, null);\n\n        if (generatedClass != null) {\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isEqualTo(classLoader);\n        }\n    }\n\n    @Test\n    void defineClassFallsBackToLookupDefineClassWhenTargetLoaderDiffersFromContextLoader() throws Exception {\n        String className = TEST_PACKAGE + \".ReflectUtilsGeneratedFallback\";\n        ClassLoader delegatingLoader = new ClassLoader(ReflectUtilsTest.class.getClassLoader()) {\n        };\n\n        Class<?> generatedClass = defineClass(className, delegatingLoader, ReflectUtilsTest.class);\n\n        if (generatedClass != null) {\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());\n        }\n    }\n\n    private static Class<?> defineClass(String className, ClassLoader classLoader, Class<?> contextClass)\n            throws Exception {\n        try {\n            return ReflectUtils.defineClass(className, createClassBytes(className), classLoader, null, contextClass);\n        }\n        catch (CodeGenerationException exception) {\n            rethrowUnlessUnsupportedFeatureError(exception);\n            return null;\n        }\n        catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n            return null;\n        }\n    }\n\n    private static byte[] createClassBytes(String className) {\n        String internalName = className.replace('.', '/');\n        ClassWriter classWriter = new ClassWriter(0);\n        classWriter.visit(Opcodes.V1_8, Opcodes.ACC_PUBLIC, internalName, null, \"java/lang/Object\", null);\n        MethodVisitor constructor = classWriter.visitMethod(Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\", false);\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n        classWriter.visitEnd();\n        return classWriter.toByteArray();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            current = current.getCause();\n        }\n        if (throwable instanceof RuntimeException runtimeException) {\n            throw runtimeException;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n        throw new IllegalStateException(throwable);\n    }\n\n    public static final class PublicDefineClassLoader extends ClassLoader {\n        PublicDefineClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public Class<?> publicDefineClass(String name, byte[] bytes, ProtectionDomain protectionDomain) {\n            return defineClass(name, bytes, 0, bytes.length, protectionDomain);\n        }\n    }\n\n    private interface SingleMethodFactory {\n        Object newInstance();\n    }\n\n    private interface ValueContract {\n        String interfaceValue();\n    }\n\n    private abstract static class AbstractValue implements ValueContract {\n        String inheritedValue(String prefix) {\n            return prefix + \"-inherited\";\n        }\n    }\n\n    private static final class ConcreteValue extends AbstractValue {\n        String localValue() {\n            return \"local\";\n        }\n\n        @Override\n        public String int