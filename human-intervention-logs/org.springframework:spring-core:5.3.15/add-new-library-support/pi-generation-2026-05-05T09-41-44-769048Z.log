  package org_springframework.spring_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.InputStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.jboss.vfs.VirtualFile;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.springframework.core.io.Resource;
  import org.springframework.core.io.VfsResource;
  
  public class VfsUtilsTest {
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void vfsResourceDelegatesToVirtualFileThroughVfsUtils() throws Exception {
          Path resourceFile = temporaryDirectory.resolve("sample.txt");
          Files.writeString(resourceFile, "spring-vfs", StandardCharsets.UTF_8);
  
          Resource resource = new VfsResource(new VirtualFile(resourceFile));
  
          assertThat(resource.exists()).isTrue();
          assertThat(resource.isReadable()).isTrue();
          assertThat(resource.contentLength()).isEqualTo(10L);
          assertThat(resource.lastModified()).isGreaterThan(0L);
          assertThat(resource.getFilename()).isEqualTo("sample.txt");
          assertThat(resource.getURL()).isEqualTo(resourceFile.toUri().toURL());
          assertThat(resource.getURI()).isEqualTo(resourceFile.toUri());
          assertThat(resource.getFile()).isEqualTo(resourceFile.toFile());
          try (InputStream inputStream = resource.getInputStream()) {
              assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo("spring-vfs");
          }
      }
  
      @Test
      void vfsResourceCreatesRelativeResourcesThroughVfsUtils() throws Exception {
          Path rootDirectory = temporaryDirectory.resolve("root");
          Path nestedFile = rootDirectory.resolve("nested").resolve("child.txt");
          Path siblingFile = rootDirectory.resolve("sibling.txt");
          Files.createDirectories(nestedFile.getParent());
          Files.writeString(nestedFile, "nested", StandardCharsets.UTF_8);
          Files.writeString(siblingFile, "sibling", StandardCharsets.UTF_8);
  
          Resource root = new VfsResource(new VirtualFile(rootDirectory));
          Resource nestedRelative = root.createRelative("nested/child.txt");
          Resource siblingRelative = root.createRelative("sibling.txt");
  
          assertThat(nestedRelative).isInstanceOf(VfsResource.class);
          assertThat(nestedRelative.exists()).isTrue();
          assertThat(nestedRelative.getFilename()).isEqualTo("child.txt");
          assertThat(nestedRelative.contentLength()).isEqualTo(6L);
          assertThat(siblingRelative).isInstanceOf(VfsResource.class);
          assertThat(siblingRelative.exists()).isTrue();
          assertThat(siblingRelative.getFilename()).isEqualTo("sibling.txt");
          assertThat(siblingRelative.contentLength()).isEqualTo(7L);
      }
  }
