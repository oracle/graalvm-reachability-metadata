  public class ReflectUtilsTest {
      private static final String TEST_PACKAGE = "org_springframework.spring_core";
  
      @Test
      void findConstructorAndFindMethodResolveNamedPrimitiveAndArrayTypes() {
          Constructor<?> constructor = ReflectUtils.findConstructor("String(byte[])");
          Method method = ReflectUtils.findMethod("java.lang.String.substring(int)");
  
          assertThat(constructor.getDeclaringClass()).isEqualTo(String.class);
          assertThat(constructor.getParameterTypes()).containsExactly(byte[].class);
          assertThat(method.getDeclaringClass()).isEqualTo(String.class);
  
