 assertThat(ClassUtils.isVisible(String.class, childLoader)).isTrue();\n    }\n\n    @Test\n    void createCompositeInterfaceBuildsProxyClassForInterfaces() {\n        final Class<?> compositeInterface = ClassUtils.createCompositeInterface(\n                new Class<?>[] {Runnable.class, Serializable.class}, ClassUtilsTest.class.getClassLoader());\n\n        assertThat(Proxy.isProxyClass(compositeInterface)).isTrue();\n        assertThat(Runnable.class).isAssignableFrom(compositeInterface);\n        assertThat(Serializable.class).isAssignableFrom(compositeInterface);\n    }\n\n    @Test\n    void constructorAndMethodUtilitiesFindPublicMembers() throws Exception {\n        final Constructor<PublicMemberTarget> constructor = ClassUtils.getConstructorIfAvailable(\n                PublicMemberTarget.class, String.class);\n        final Method publicMethod = ClassUtils.getMethod(PublicMemberTarget.class, \"publicMethod\", String.class);\n        final Method optionalMethod = ClassUtils.getMethodIfAvailable(\n                PublicMemberTarget.class, \"publicMethod\", String.class);\n        final Method staticMethod = ClassUtils.getStaticMethod(PublicMemberTarget.class, \"staticMethod\", String.class);\n\n        assertThat(constructor).isNotNull();\n        assertThat(constructor.newInstance(\"spring\").value()).isEqualTo(\"spring\");\n        assertThat(publicMethod.invoke(new PublicMemberTarget(\"core\"), \"spring\")).isEqualTo(\"core-spring\");\n        assertThat(optionalMethod).isEqualTo(publicMethod);\n        assertThat(staticMethod).isNotNull();\n        assertThat(staticMethod.invoke(null, \"spring\")).isEqualTo(\"SPRING\");\n    }\n\n    @Test\n    void methodNameUtilitiesInspectDeclaredAndPublicMethods() {\n        final Method uniqueOverload = ClassUtils.getMethodIfAvailable(PublicMemberTarget.class, \"uniqueOverload\",\n                (Class<?>[]) null);\n\n        assertThat(ClassUtils.getMethodCountForName(MethodHierarchyChild.class, \"countedMethod\")).isEqualTo(3);\n        assertThat(ClassUtils.hasAtLeastOneMethodWithName(MethodHierarchyChild.class, \"countedMethod\")).isTrue();\n        assertThat(uniqueOverload).isNotNull();\n        assertThat(uniqueOverload.getParameterCount()).isZero();\n    }\n\n    @Test\n    void methodResolutionFindsTargetAndInterfaceMethods() throws Exception {\n        final Method interfaceMethod = PublicContract.class.getMethod(\"contractValue\");\n        final Method implementationMethod = PublicContractImplementation.class.getMethod(\"contractValue\");\n\n        final Method mostSpecificMethod = ClassUtils.getMostSpecificMethod(\n                interfaceMethod, PublicContractImplementation.class);\n        final Method exposedInterfaceMethod = ClassUtils.getInterfaceMethodIfPossible(implementationMethod);\n\n        assertThat(mostSpecificMethod).isEqualTo(implementationMethod);\n        assertThat(exposedInterfaceMethod).isEqualTo(interfaceMethod);\n    }\n\n    public static final class NestedComponent {\n    }\n\n    private static final class ChildClassLoader extends ClassLoader {\n\n        ChildClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n\n    public static final class PublicMemberTarget {\n\n        private final String value;\n\n        public PublicMemberTarget(String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return value;\n        }\n\n        public String publicMethod(String suffix) {\n            return value + '-' + suffix;\n        }\n\n        public String uniqueOverload() {\n            return value;\n        }\n\n        public static String staticMethod(String input) {\n            return input.toUpperCase();\n        }\n    }\n\n    public interface MethodHierarchyContract {\n\n        void countedMethod();\n    }\n\n    public static class MethodHierarchyParent {\n\n        public void countedMethod() {\n        }\n    }\n\n    public static final class MethodHierarchyChild extends MethodHierarchyParent implements MethodHierarchyContract {\n\n        @Override\n        public void countedMethod() {\n        }\n    }\n\n    public interface PublicContract {\n\n        String contractValue();\n    }\n\n    public static final class PublicContractImplementation implements PublicContract {\n\n        @Override\n        public String contractValue() {\n            return \"contract\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780852207563}]}
