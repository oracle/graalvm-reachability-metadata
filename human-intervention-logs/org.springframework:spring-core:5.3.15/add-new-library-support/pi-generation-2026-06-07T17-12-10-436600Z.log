[tool-call] delta {"path":"tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/OverridingClassLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.core.OverridingClassLoader;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OverridingClassLoaderTest {\n\n    @Test\n    void loadClassUsesOverrideDelegateForEligibleClasses() throws Exception {\n        final ClassLoader parent = OverridingClassLoaderTest.class.getClassLoader();\n        final OverridingClassLoader loader = new OverridingClassLoader(parent, parent);\n\n        final Class<?> loadedClass = loader.loadClass(ReloadableComponent.class.getName());\n\n        assertThat(loadedClass).isSameAs(ReloadableComponent.class);\n    }\n\n    @Test\n    void loadClassDefinesEligibleClassFromParentResource() throws Exception {\n        final OverridingClassLoader loader = new OverridingClassLoader(\n                OverridingClassLoaderTest.class.getClassLoader());\n\n        final Class<?> loadedClass = loadClassAllowingNativeImageUnsupportedFeature(\n                () -> loader.loadClass(ReloadableComponent.class.getName()));\n\n        if (loadedClass != null) {\n            assertThat(loadedClass.getName()).isEqualTo(ReloadableComponent.class.getName());\n            assertThat(loadedClass).isNotSameAs(ReloadableComponent.class);\n            assertThat(loadedClass.getClassLoader()).isSameAs(loader);\n            assertThat(loader.loadClass(ReloadableComponent.class.getName())).isSameAs(loadedClass);\n        }\n    }\n\n    private static Class<?> loadClassAllowingNativeImageUnsupportedFeature(ClassLoadingAction action) throws Exception {\n        try {\n            return action.loadClass();\n        }\n        catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return null;\n        }\n    }\n\n    @FunctionalInterface\n    private interface ClassLoadingAction {\n        Class<?> loadClass() throws Exception;\n    }\n\n    public static final class ReloadableComponent {\n    }\n}\n"}
