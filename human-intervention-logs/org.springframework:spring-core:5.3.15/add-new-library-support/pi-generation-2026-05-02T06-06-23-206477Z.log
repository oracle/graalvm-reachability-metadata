mpleAnnotation.class);\n        AnnotationAttributes attributes = new AnnotationAttributes(SampleContainer.class);\n        attributes.put(\"value\", annotation);\n\n        SampleAnnotation[] annotations = attributes.getAnnotationArray(\"value\", SampleAnnotation.class);\n\n        assertThat(annotations).hasSize(1);\n        assertThat(annotations[0].value()).isEqualTo(\"sample\");\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface SampleContainer {\n\n        SampleAnnotation[] value();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface SampleAnnotation {\n\n        String value();\n    }\n\n    @SampleAnnotation(\"sample\")\n    static class AnnotatedSample {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 7875, "output": 949, "cacheRead": 6144, "cacheWrite": 0, "totalTokens": 14968, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777701947873, "responseId": "resp_00796d58f07b92c60169f5943c35dc81948684188eb06d0ac3"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_d69v00wknEsAGbMruymnrGpH|fc_00796d58f07b92c60169f594479dd081949172f6f1aac3412c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1817 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/AnnotationAttributesTest.java"}], "isError": false, "timestamp": 1777701962772}]}
