esProvidedClassLoaderLookup() throws IOException {\n        ClassLoader classLoader = ClassPathResourceTest.class.getClassLoader();\n        Resource resource = new ClassPathResource(RESOURCE_PATH, classLoader);\n\n        assertThat(resource.exists()).isTrue();\n        assertThat(read(resource)).isEqualTo(RESOURCE_CONTENT);\n    }\n\n    @Test\n    void nullClassResourceUsesSystemClassLoaderLookup() throws IOException {\n        Resource resource = new ClassPathResource(RESOURCE_PATH, (Class<?>) null);\n\n        assertThat(resource.exists()).isTrue();\n        assertThat(read(resource)).isEqualTo(RESOURCE_CONTENT);\n    }\n\n    private static String read(Resource resource) throws IOException {\n        try (InputStream inputStream = resource.getInputStream()) {\n            return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 582, "output": 994, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 22056, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780851928005, "responseId": "resp_0697869c626121d4016a25a4d8a26481958cdb7c6caa829958"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Smmi7QpBIVduxcShSFn2bGQA|fc_0697869c626121d4016a25a4e66b74819581f43763c44ce2ad", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1988 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/ClassPathResourceTest.java"}], "isError": false, "timestamp": 1780851947307}]}
