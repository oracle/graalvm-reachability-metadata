[tool-call] delta {"path":"tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/AbstractClassLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.cglib.transform.AbstractClassLoader;\nimport org.springframework.cglib.transform.ClassFilter;\nimport org.springframework.core.SpringVersion;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AbstractClassLoaderTest {\n\n    @Test\n    void loadClassDelegatesToParentWhenFilterRejectsClass() throws Exception {\n        final ClassLoader parent = AbstractClassLoaderTest.class.getClassLoader();\n        final ClassLoader loader = new TestClassLoader(parent, parent, className -> false);\n\n        final Class<?> loadedClass = loader.loadClass(String.class.getName());\n\n        assertThat(loadedClass).isSameAs(String.class);\n    }\n\n    @Test\n    void loadClassDefinesAcceptedClassFromConfiguredClassPath() throws Exception {\n        final ClassLoader parent = AbstractClassLoaderTest.class.getClassLoader();\n        final ClassLoader loader = new TestClassLoader(\n                parent,\n                parent,\n                className -> SpringVersion.class.getName().equals(className));\n\n        final Class<?> loadedClass = loadClassAllowingNativeImageUnsupportedFeature(\n                () -> loader.loadClass(SpringVersion.class.getName()));\n\n        if (loadedClass != null) {\n            assertThat(loadedClass.getName()).isEqualTo(SpringVersion.class.getName());\n            assertThat(loadedClass).isNotSameAs(SpringVersion.class);\n            assertThat(loadedClass.getClassLoader()).isSameAs(loader);\n            assertThat(loader.loadClass(SpringVersion.class.getName())).isSameAs(loadedClass);\n        }\n    }\n\n    private static Class<?> loadClassAllowingNativeImageUnsupportedFeature(\n            ClassLoadingAction action) throws Exception {\n        try {\n            return action.loadClass();\n        }\n        catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return null;\n        }\n    }\n\n    @FunctionalInterface\n    private interface ClassLoadingAction {\n        Class<?> loadClass() throws Exception;\n    }\n\n    private static final class TestClassLoader extends AbstractClassLoader {\n\n        private TestClassLoader(\n                ClassLoader parent,\n                ClassLoader classPath,\n                ClassFilter filter) {\n            super(parent, classPath, filter);\n        }\n    }\n}\n"}
