ead.currentThread().setContextClassLoader(ResourceUtilsTest.class.getClassLoader());\n        try {\n            final File resourceFile = ResourceUtils.getFile(RESOURCE_LOCATION);\n\n            assertThat(resourceFile).isFile();\n            assertThat(resourceFile).hasContent(RESOURCE_CONTENT);\n        }\n        catch (FileNotFoundException ex) {\n            assertThat(ex).hasMessageContaining(\"does not reside in the file system\");\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static String read(URL resourceUrl) throws IOException {\n        try (InputStream inputStream = resourceUrl.openStream()) {\n            return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\n        }\n    }\n}\n"}
