 contents\";\n        Files.writeString(resourceFile, contents, StandardCharsets.UTF_8);\n\n        VirtualFile virtualFile = VFS.getChild(resourceFile.toUri());\n        Resource resource = new VfsResource(virtualFile);\n\n        assertThat(resource.exists()).isTrue();\n        assertThat(resource.isReadable()).isTrue();\n        assertThat(resource.contentLength()).isEqualTo(contents.getBytes(StandardCharsets.UTF_8).length);\n        assertThat(resource.lastModified()).isGreaterThan(0L);\n        assertThat(resource.getFilename()).isEqualTo(\"sample.txt\");\n        assertThat(resource.getURL().getProtocol()).isEqualTo(\"vfs\");\n        assertThat(resource.getURI().getScheme()).isEqualTo(\"vfs\");\n        assertThat(Files.readString(resource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo(contents);\n        try (InputStream inputStream = resource.getInputStream()) {\n            assertThat(new String(inputStream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(contents);\n        }\n    }\n\n    @Test\n    void vfsResourceCreatesRelativeResources() throws IOException {\n        Path nestedDirectory = Files.createDirectory(temporaryDirectory.resolve(\"nested\"));\n        Path nestedFile = nestedDirectory.resolve(\"child.txt\");\n        Path siblingFile = temporaryDirectory.resolve(\"sibling.txt\");\n        Files.writeString(nestedFile, \"nested\", StandardCharsets.UTF_8);\n        Files.writeString(siblingFile, \"sibling\", StandardCharsets.UTF_8);\n\n        VirtualFile virtualDirectory = VFS.getChild(temporaryDirectory.toUri());\n        Resource directoryResource = new VfsResource(virtualDirectory);\n\n        Resource nestedResource = directoryResource.createRelative(\"nested/child.txt\");\n        assertThat(nestedResource.exists()).isTrue();\n        assertThat(nestedResource.getFilename()).isEqualTo(\"child.txt\");\n        assertThat(Files.readString(nestedResource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo(\"nested\");\n\n        Resource siblingResource = directoryResource.createRelative(\"sibling.txt\");\n        assertThat(siblingResource.exists()).isTrue();\n        assertThat(siblingResource.getFilename()).isEqualTo(\"sibling.txt\");\n        assertThat(Files.readString(siblingResource.getFile().toPath(), StandardCharsets.UTF_8)).isEqualTo(\"sibling\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1740, "output": 1058, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 31470, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780849665633, "responseId": "resp_0cdae3cc1c28d319016a259c023bb48197828e89375fc9638e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_J33txCteeEQVI0SInAJpdb1z|fc_0cdae3cc1c28d319016a259c08e89c8197b0f234e26b19aeca", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3237 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/VfsUtilsTest.java"}], "isError": false, "timestamp": 1780849682737}]}
