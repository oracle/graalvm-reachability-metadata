ived a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayDeque;\nimport java.util.Collection;\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.core.CollectionFactory;\nimport org.springframework.util.ConcurrentReferenceHashMap;\n\npublic class CollectionFactoryTest {\n\n    @Test\n    void createsConcreteCollectionThroughDefaultConstructor() {\n        Collection<String> collection = CollectionFactory.createCollection(ArrayDeque.class, 4);\n\n        collection.add(\"first\");\n        collection.add(\"second\");\n\n        assertThat(collection).isInstanceOf(ArrayDeque.class);\n        assertThat(collection).containsExactly(\"first\", \"second\");\n    }\n\n    @Test\n    void createsConcreteMapThroughDefaultConstructor() {\n        Map<String, String> map = CollectionFactory.createMap(ConcurrentReferenceHashMap.class, 4);\n\n        map.put(\"spring\", \"core\");\n\n        assertThat(map).isInstanceOf(ConcurrentReferenceHashMap.class);\n        assertThat(map).containsEntry(\"spring\", \"core\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 637, "output": 710, "cacheRead": 27648, "cacheWrite": 0, "totalTokens": 28995, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777703735142, "responseId": "resp_0069c71e94caeafc0169f59b3799fc819eb4417f0a8ad1b5db"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_BlGvFrUeJlpPmwM5PDYzzp6Q|fc_0069c71e94caeafc0169f59b3ce8dc819eb3d5ddfad18d38f2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1288 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/CollectionFactoryTest.java"}]