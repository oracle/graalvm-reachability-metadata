  	@SuppressWarnings("rawtypes")
  	private static Class<? extends Enum> asEnumType(Class<?> enumType) {
  		Assert.notNull(enumType, "Enum type must not be null");
  		if (!Enum.class.isAssignableFrom(enumType)) {
