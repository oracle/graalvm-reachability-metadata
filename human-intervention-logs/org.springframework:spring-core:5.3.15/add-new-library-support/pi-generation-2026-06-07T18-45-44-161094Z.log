   final GreetingTarget otherTarget = new GreetingTarget(\"Hi\");\n            final GreetingOperation otherOperation = (GreetingOperation) delegate.newInstance(otherTarget);\n            assertThat(otherOperation.apply(\"Spring\")).isEqualTo(\"Hi Spring\");\n        }\n    }\n\n    @Test\n    void createStaticGeneratesDelegateForStaticMethod() {\n        final MethodDelegate delegate = createMethodDelegate(\n                () -> MethodDelegate.createStatic(GreetingTarget.class, \"staticGreet\", GreetingOperation.class));\n\n        if (delegate != null) {\n            final GreetingOperation operation = (GreetingOperation) delegate;\n            assertThat(operation.apply(\"Spring\")).isEqualTo(\"Static Spring\");\n        }\n    }\n\n    private static MethodDelegate createMethodDelegate(MethodDelegateFactory factory) {\n        try {\n            return factory.create();\n        }\n        catch (Error error) {\n            if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return null;\n            }\n            throw error;\n        }\n        catch (CodeGenerationException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return null;\n            }\n            throw exception;\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable cause = throwable;\n        while (cause != null) {\n            if (cause instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {\n                return true;\n            }\n            cause = cause.getCause();\n        }\n        return false;\n    }\n\n    @FunctionalInterface\n    private interface MethodDelegateFactory {\n\n        MethodDelegate create();\n    }\n\n    public interface GreetingOperation {\n\n        String apply(String name);\n    }\n\n    public static class GreetingTarget {\n\n        private final String greeting;\n\n        public GreetingTarget(String greeting) {\n            this.greeting = greeting;\n        }\n\n        public String greet(String name) {\n            return greeting + \" \" + name;\n        }\n\n        public static String staticGreet(String name) {\n            return \"Static \" + name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 192, "output": 975, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 31887, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780857842529, "responseId": "resp_0441c562586ceded016a25bbf310708196a4ecabb314766150"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FTqzt3t7M7eCc2tGLMHr0HOG|fc_0441c562586ceded016a25bbf8db648196bb3836d886dd68a9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3332 bytes to tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/MethodDelegateInnerGeneratorTest.java"}], "isError": false, "timestamp": 1780857857410}]}
