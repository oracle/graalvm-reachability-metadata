  package org_springframework.spring_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import org.springframework.cglib.core.CodeGenerationException;
  import org.springframework.cglib.reflect.MethodDelegate;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodDelegateInnerGeneratorTest {
  
      @Test
      void createGeneratesDelegateForInstanceMethod() {
          final GreetingTarget target = new GreetingTarget("Hello");
          final MethodDelegate delegate = createMethodDelegate(
                  () -> MethodDelegate.create(target, "greet", GreetingOperation.class));
  
          if (delegate != null) {
              final GreetingOperation operation = (GreetingOperation) delegate;
              assertThat(operation.apply("Spring")).isEqualTo("Hello Spring");
              assertThat(delegate.getTarget()).isSameAs(target);
  
              final GreetingTarget otherTarget = new GreetingTarget("Hi");
              final GreetingOperation otherOperation = (GreetingOperation) delegate.newInstance(otherTarget);
              assertThat(otherOperation.apply("Spring")).isEqualTo("Hi Spring");
          }
      }
  
      private static MethodDelegate createMethodDelegate(MethodDelegateFactory factory) {
          try {
              return factory.create();
          }
          catch (Error error) {
              if (NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return null;
              }
              throw error;
          }
          catch (CodeGenerationException exception) {
              if (hasUnsupportedFeatureErrorCause(exception)) {
                  return null;
              }
              throw exception;
          }
      }
  
      private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {
          Throwable cause = throwable;
          while (cause != null) {
              if (cause instanceof Error
                      && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {
                  return true;
              }
              cause = cause.getCause();
          }
          return false;
      }
  
      @FunctionalInterface
      private interface MethodDelegateFactory {
  
          MethodDelegate create();
      }
  
      public interface GreetingOperation {
  
          String apply(String name);
      }
  
      public static class GreetingTarget {
  
          private final String greeting;
  
          public GreetingTarget(String greeting) {
              this.greeting = greeting;
          }
  
          public String greet(String name) {
              return greeting + " " + name;
          }
      }
  }
