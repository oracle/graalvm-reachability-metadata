 target Classloader\n   525\t\t\tif (c == null) {\n   526\t\t\t\tif (protectionDomain == null) {\n   527\t\t\t\t\tprotectionDomain = PROTECTION_DOMAIN;\n   528\t\t\t\t}\n   529\t\n   530\t\t\t\t// Look for publicDefineClass(String name, byte[] b, ProtectionDomain protectionDomain)\n   531\t\t\t\ttry {\n   532\t\t\t\t\tMethod publicDefineClass = loader.getClass().getMethod(\n   533\t\t\t\t\t\t\t\"publicDefineClass\", String.class, byte[].class, ProtectionDomain.class);\n   534\t\t\t\t\tc = (Class) publicDefineClass.invoke(loader, className, b, protectionDomain);\n   535\t\t\t\t}\n   536\t\t\t\tcatch (InvocationTargetException ex) {\n   537\t\t\t\t\tif (!(ex.getTargetException() instanceof UnsupportedOperationException)) {\n   538\t\t\t\t\t\tthrow new CodeGenerationException(ex.getTargetException());\n   539\t\t\t\t\t}\n   540\t\t\t\t\t// in case of UnsupportedOperationException, fall through\n   541\t\t\t\t\tt = ex.getTargetException();\n   542\t\t\t\t}\n   543\t\t\t\tcatch (Throwable ex) {\n   544\t\t\t\t\t// publicDefineClass method not available -> fall through\n   545\t\t\t\t\tt = ex;\n   546\t\t\t\t}\n   547\t\n   548\t\t\t\t// Classic option: protected ClassLoader.defineClass method\n   549\t\t\t\tif (c == null && classLoaderDefineClassMethod != null) {\n   550\t\t\t\t\tObject[] args = new Object[]{className, b, 0, b.length, protectionDomain};\n   551\t\t\t\t\ttry {\n   552\t\t\t\t\t\tif (!classLoaderDefineClassMethod.isAccessible()) {\n   553\t\t\t\t\t\t\tclassLoaderDefineClassMethod.setAccessible(true);\n   554\t\t\t\t\t\t}\n   555\t\t\t\t\t\tc = (Class) classLoaderDefineClassMethod.invoke(loader, args);\n   556\t\t\t\t\t}\n   557\t\t\t\t\tcatch (InvocationTargetException ex) {\n   558\t\t\t\t\t\tthrow new CodeGenerationException(ex.getTargetException());\n   559\t\t\t\t\t}\n   560\t\t\t\t\tcatch (Throwable ex) {\n   561\t\t\t\t\t\t// Fall through if setAccessible fails with InaccessibleObjectException on JDK 9+\n   562\t\t\t\t\t\t// (on the module path and/o