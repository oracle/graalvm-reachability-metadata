{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/org.springframework/spring-core/5.3.15/src/test/java/org_springframework/spring_core/MethodProxyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework.spring_core;\n\nimport java.lang.reflect.Method;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.asm.Type;\nimport org.springframework.cglib.core.CodeGenerationException;\nimport org.springframework.cglib.core.Signature;\nimport org.springframework.cglib.proxy.Enhancer;\nimport org.springframework.cglib.proxy.MethodInterceptor;\nimport org.springframework.cglib.proxy.MethodProxy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MethodProxyTest {\n\n    @Test\n    void findReturnsMethodProxyForGeneratedInterceptorMethod() throws Throwable {\n        final GreetingService proxy = createGeneratedProxy();\n\n        if (proxy != null) {\n            final Signature signature = new Signature(\n                    \"greet\",\n                    Type.getMethodDescriptor(Type.getType(String.class), Type.getType(String.class)));\n            final MethodProxy methodProxy = MethodProxy.find(proxy.getClass(), signature);\n\n            assertThat(methodProxy).isNotNull();\n            assertThat(methodProxy.getSignature()).isEqualTo(signature);\n            assertThat(methodProxy.invokeSuper(proxy, new Object[] {\"Spring\"})).isEqualTo(\"Hello Spring\");\n            assertThat(proxy.greet(\"Spring\")).isEqualTo(\"Intercepted Hello Spring\");\n        }\n    }\n\n    private static GreetingService createGeneratedProxy() {\n        try {\n            final Enhancer enhancer = new Enhancer();\n            enhancer.setSuperclass(GreetingService.class);\n            enhancer.setCallback((MethodInterceptor) MethodProxyTest::interceptGreeting);\n            return (GreetingService) enhancer.create();\n        }\n        catch (Error error) {\n            if (hasUnsupportedFeatureErrorCause(error)) {\n                return null;\n            }\n            throw error;\n        }\n        catch (CodeGenerationException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return null;\n            }\n            throw exception;\n        }\n    }\n\n    private static Object interceptGreeting(\n            Object object,\n            Method method,\n            Object[] arguments,\n            MethodProxy methodProxy) throws Throwable {\n        if (\"greet\".equals(method.getName())) {\n            return \"Intercepted \" + methodProxy.invokeSuper(object, arguments);\n        }\n        return methodProxy.invokeSuper(object, arguments);\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable cause = throwable;\n        while (cause != null) {\n            if (cause instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) cause)) {\n                return true;\n            }\n            cause = cause.getCause();\n        }\n        return false;\n    }\n\n    public static class GreetingService {\n\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
