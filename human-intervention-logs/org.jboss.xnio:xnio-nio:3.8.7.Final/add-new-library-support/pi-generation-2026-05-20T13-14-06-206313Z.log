t(addresses.getSourceAddress()).isInstanceOf(InetSocketAddress.class);\n            assertThat(((InetSocketAddress) addresses.getSourceAddress()).getPort())\n                    .isEqualTo(senderAddress.getPort());\n        } finally {\n            closeQuietly(sender);\n            closeQuietly(receiver);\n            closeWorker(worker);\n        }\n    }\n\n    @Test\n    void compressionChannelsRoundTripDataThroughHalfDuplexPipe() throws Exception {\n        XnioWorker worker = createWorker();\n        StreamSourceChannel source = null;\n        StreamSinkChannel sink = null;\n        StreamSourceChannel inflatingSource = null;\n        StreamSinkChannel deflatingSink = null;\n        try {\n            ChannelPipe<StreamSourceChannel, StreamSinkChannel> pipe = worker.createHalfDuplexPipe();\n            source = pipe.getLeftSide();\n            sink = pipe.getRightSide();\n            OptionMap compressionOptions = OptionMap.builder()\n                    .set(Options.COMPRESSION_TYPE, CompressionType.GZIP)\n                    .set(Options.COMPRESSION_LEVEL, 1)\n                    .getMap();\n            inflatingSource = worker.getInflatingChannel(source, compressionOptions);\n            deflatingSink = worker.getDeflatingChannel(sink, compressionOptions);\n\n            String payload = \"compressible payload \".repeat(16);\n            writeFully(deflatingSink, payload);\n            shutdownWrites(deflatingSink);\n\n            assertThat(readFully(inflatingSource, payload.length())).isEqualTo(payload);\n        } finally {\n            closeQuietly(deflatingSink);\n            closeQuietly(inflatingSource);\n            closeQuietly(sink);\n            closeQuietly(source);\n            closeWorker(worker);\n        }\n    }\n\n    private static XnioWorker createWorker() throws IOException {"}, {"oldText": "    private static String readFully(StreamSourceChannel channel, int expectedBytes) throws IOException {\n        ByteBuffer buffer = ByteBuffer.allocate(expectedBytes);\n        long deadline = deadlineNanos();\n        while (buffer.hasRemaining()) {\n            int read = channel.read(buffer);\n            if (read == -1) {\n                throw new IOException(\"Stream ended before the expected bytes were read\");\n            }\n            if (read == 0) {\n                ensureTimeRemaining(deadline, \"reading stream data\");\n                channel.awaitReadable(1, TimeUnit.SECONDS);\n            }\n        }\n        buffer.flip();\n        return StandardCharsets.UTF_8.decode(buffer).toString();\n    }\n\n    private static void sendDatagram(", "newText": "    private static String readFully(StreamSourceChannel channel, int expectedBytes) throws IOException {\n        ByteBuffer buffer = ByteBuffer.allocate(expectedBytes);\n        long deadline = deadlineNanos();\n        while (buffer.hasRemaining()) {\n            int read = channel.read(buffer);\n            if (read == -1) {\n                throw new IOException(\"Stream ended before the expected bytes were read\");\n            }\n            if (read == 0) {\n                ensureTimeRemaining(deadline, \"reading stream data\");\n                channel.awaitReadable(1, TimeUnit.SECONDS);\n            }\n        }\n        buffer.flip();\n        return StandardCharsets.UTF_8.decode(buffer).toString();\n    }\n\n    private static void shutdownWrites(StreamSinkChannel channel) throws IOException {\n        channel.shutdownWrites();\n        long deadline = deadlineNanos();\n        while (!channel.flush()) {\n            ensureTimeRemaining(deadline, \"finishing stream writes\");\n            channel.awaitWritable(1, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendDatagram("}]}
