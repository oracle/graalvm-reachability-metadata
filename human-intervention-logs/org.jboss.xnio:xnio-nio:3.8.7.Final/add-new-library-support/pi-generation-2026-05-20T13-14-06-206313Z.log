SourceChannel source = null;\n        StreamSinkChannel sink = null;\n        StreamSourceChannel inflatingSource = null;\n        StreamSinkChannel deflatingSink = null;\n        try {\n            ChannelPipe<StreamSourceChannel, StreamSinkChannel> pipe = worker.createHalfDuplexPipe();\n            source = pipe.getLeftSide();\n            sink = pipe.getRightSide();\n            OptionMap compressionOptions = OptionMap.builder()\n                    .set(Options.COMPRESSION_TYPE, CompressionType.DEFLATE)\n                    .set(Options.COMPRESSION_LEVEL, 1)\n                    .getMap();\n            inflatingSource = worker.getInflatingChannel(source, compressionOptions);\n            deflatingSink = worker.getDeflatingChannel(sink, compressionOptions);\n\n            String payload = \"compressible payload \".repeat(16);\n            writeFully(deflatingSink, payload);\n            shutdownWrites(deflatingSink);\n\n            assertThat(readFully(inflatingSource, payload.length())).isEqualTo(payload);\n        } finally {\n            closeQuietly(deflatingSink);\n            closeQuietly(inflatingSource);\n            closeQuietly(sink);\n            closeQuietly(source);\n            closeWorker(worker);\n        }\n    }\n\n    private static XnioWorker createWorker() throws IOException {", "newText": "    @Test\n    void ioThreadExecutesImmediateDelayedAndIntervalTasks() throws Exception {\n        XnioWorker worker = createWorker();\n        XnioExecutor.Key intervalKey = null;\n        try {\n            CountDownLatch immediateTask = new CountDownLatch(1);\n            CountDownLatch delayedTask = new CountDownLatch(1);\n            CountDownLatch intervalTask = new CountDownLatch(2);\n            AtomicReference<Thread> immediateThread = new AtomicReference<>();\n            AtomicReference<XnioWorker> currentWorker = new AtomicReference<>();\n\n            XnioIoThread ioThread = worker.getIoThread();\n            ioThread.execute(() -> {\n                immediateThread.set(Thread.currentThread());\n                currentWorker.set(XnioIoThread.currentThread().getWorker());\n                immediateTask.countDown();\n            });\n            ioThread.executeAfter(delayedTask::countDown, 10, TimeUnit.MILLISECONDS);\n            intervalKey = ioThread.executeAtInterval(intervalTask::countDown, 10, TimeUnit.MILLISECONDS);\n\n            assertThat(immediateTask.await(TIMEOUT_SECONDS, TimeUnit.SECONDS)).isTrue();\n            assertThat(delayedTask.await(TIMEOUT_SECONDS, TimeUnit.SECONDS)).isTrue();\n            assertThat(intervalTask.await(TIMEOUT_SECONDS, TimeUnit.SECONDS)).isTrue();\n            assertThat(intervalKey.remove()).isTrue();\n            intervalKey = null;\n            assertThat(immediateThread.get()).isInstanceOf(XnioIoThread.class);\n            assertThat(currentWorker.get()).isSameAs(worker);\n        } finally {\n            if (intervalKey != null) {\n                intervalKey.remove();\n            }\n            closeWorker(worker);\n        }\n    }\n\n    private static XnioWorker createWorker() throws IOException {"}, {"oldText": "    private static void shutdownWrites(StreamSinkChannel channel) throws IOException {\n        channel.shutdownWrites();\n        long deadline = deadlineNanos();\n        while (!channel.flush()) {\n            ensureTimeRemaining(deadline, \"finishing stream writes\");\n            channel.awaitWritable(1, TimeUnit.SECONDS);\n        }\n    }\n\n    private static void sendDatagram(", "newText": "    private static void sendDatagram("}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 926, "output": 1109, "cacheRead": 49152, "cacheWrite": 0, "totalTokens": 51187, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779282934102, "responseId": "resp_0303906f27df5217016a0db3f6be1c8191a2a798afd562b44a"}}
