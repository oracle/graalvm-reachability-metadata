[tool-call] delta {"path":"tests/src/org.jboss.xnio/xnio-nio/3.8.7.Final/src/test/java/org_jboss_xnio/xnio_nio/Xnio_nioTest.java","edits":[{"oldText":"import org.xnio.ChannelPipe;\nimport org.xnio.CompressionType;\nimport org.xnio.FileAccess;","newText":"import org.xnio.ChannelPipe;\nimport org.xnio.FileAccess;"},{"oldText":"    @Test\n    void deflatingAndInflatingChannelsRoundTripThroughHalfDuplexPipe() throws Exception {\n        XnioWorker worker = createWorker();\n        try {\n            ChannelPipe<StreamSourceChannel, StreamSinkChannel> pipe = worker.createHalfDuplexPipe();\n            try (StreamSourceChannel inflated = worker.getInflatingChannel(pipe.getLeftSide(), compressionOptions());\n                    StreamSinkChannel deflated = worker.getDeflatingChannel(\n                            pipe.getRightSide(), compressionOptions())) {\n                String message = \"compressed nio payload that crosses a half-duplex pipe\";\n\n                writeText(deflated, message);\n\n                assertThat(readText(inflated, message.length())).isEqualTo(message);\n                assertThat(Channels.shutdownWritesBlocking(deflated, IO_TIMEOUT_SECONDS, TimeUnit.SECONDS)).isTrue();\n            }\n        } finally {\n            shutdownWorker(worker);\n        }\n    }\n\n","newText":"    @Test\n    void oneWayPipeTransfersDataFromSinkToSource() throws Exception {\n        XnioWorker worker = createWorker();\n        AtomicReference<StreamSourceChannel> source = new AtomicReference<>();\n        AtomicReference<StreamSinkChannel> sink = new AtomicReference<>();\n        CountDownLatch pipeCreated = new CountDownLatch(2);\n        try {\n            worker.createOneWayPipe(channel -> {\n                source.set(channel);\n                pipeCreated.countDown();\n            }, channel -> {\n                sink.set(channel);\n                pipeCreated.countDown();\n            }, OptionMap.EMPTY);\n\n            assertThat(pipeCreated.await(IO_TIMEOUT_SECONDS, TimeUnit.SECONDS)).isTrue();\n            assertThat(source.get()).isNotNull();\n            assertThat(sink.get()).isNotNull();\n\n            writeText(sink.get(), \"one-way nio pipe\");\n            assertThat(readText(source.get(), \"one-way nio pipe\".length())).isEqualTo(\"one-way nio pipe\");\n        } finally {\n            IoUtils.safeClose(source.get());\n            IoUtils.safeClose(sink.get());\n            shutdownWorker(worker);\n        }\n    }\n\n"},{"oldText":"    private static OptionMap compressionOptions() {\n        return OptionMap.builder()\n                .set(Options.COMPRESSION_TYPE, CompressionType.DEFLATE)\n                .set(Options.COMPRESSION_LEVEL, 6)\n                .getMap();\n    }\n\n","newText":""}]}
[tool-call] end id=call_scW04VoGa1ZOLs5aHFn9XGo2|fc_033eef9c63851753016a25ebdc43f08190ab13fe3fc877a941 name=edit args={"path": "tests/src/org.jboss.xnio/xnio-nio/3.8.7.Final/src/test/java/org_jboss_xnio/xnio_nio/Xnio_nioTest.java", "edits": [{"oldText": "import org.xnio.ChannelPipe;\nimport org.xnio.CompressionType;\nimport org.xnio.FileAccess;", "newText": "import org.xnio.ChannelPipe;\nimport org.xnio.FileAccess;"}, {"oldText": "    @Test\n    void deflatingAndInflatingChannelsRoundTripThroughHalfDuplexPipe() throws Exception {\n        XnioWorker worker = createWorker();\n        try {\n            ChannelPipe<StreamSourceChannel, StreamSinkChannel> pipe = worker.createHalfDuplexPipe();\n            try (StreamSourceChannel inflated = worker.getInflatingChannel(pipe.getLeftSide(), compressionOptions());\n                    StreamSinkChannel deflated = worker.getDeflatingChannel(\n                            pipe.getRightSide(), compressionOptions())) {\n                String message = \"compressed nio payload that crosses a half-duplex pipe\";\n\n                writeText(deflated, message);\n\n                assertThat(readText(inflated, message.length())).isEqualTo(message);\n                assertThat(Channels.shutdownWritesBlocking(deflated, IO_TIMEOUT_SECONDS, TimeUnit.SECONDS)).isTrue();\n            }\n        } finally {\n            shutdownWorker(worker);\n        }\n    }\n\n", "newText": "    @Test\n    void oneWayPipeTransfersDataFromSinkToSource() throws Exception {\n        XnioWorker worker = createWorker();\n        AtomicReference<StreamSourceChannel> source = new AtomicReference<>();\n        AtomicReference<StreamSinkChannel> sink = new AtomicReference<>();\n        CountDownLatch pipeCreated = new CountDownLatch(2);\n        try {\n            worker.createOneWayPipe(channel -> {\n                source.set(channel);\n                pipeCreated.countDown();\n            }, channel -> {\n                sink.set(channel);\n                pipeCreated.countDown();\n            }, OptionMap.EMPTY);\n\n            assertThat(pipeCreated.await(IO_TIMEOUT_SECONDS, TimeUnit.SECONDS)).isTrue();\n            assertThat(source.get()).isNotNull();\n            assertThat(sink.get()).isNotNull();\n\n            writeText(sink.get(), \"one-way nio pipe\");\n            assertThat(readText(source.get(), \"one-way nio pipe\".length())).isEqualTo(\"one-way nio pipe\");\n        } finally {\n            IoUtils.safeClose(source.get());\n            IoUtils.safeClose(sink.get());\n            shutdownWorker(worker);\n        }\n    }\n\n"}, {"oldText": "    private static OptionMap compressionOptions() {\n        return OptionMap.builder()\n                .set(Options.COMPRESSION_TYPE, CompressionType.DEFLATE)\n                .set(Options.COMPRESSION_LEVEL, 6)\n                .getMap();\n    }\n\n", "newText": ""}]}
