              matched.putAll(subgraphs.row(filteringContext));
          }
  
          return matched;
      }
  
      @Override
      public boolean presentInScopes(final String name) {
          return fields.containsValue(name) || subgraphs.containsColumn(name);
      }
  
      @Override
