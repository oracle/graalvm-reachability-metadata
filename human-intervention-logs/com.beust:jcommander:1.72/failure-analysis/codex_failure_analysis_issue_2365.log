1920:            coverage_snapshot = _load_dynamic_access_snapshot_from_report(claimed_issue)\n../2365-b97c4115/forge/forge_metadata.py:1924:            coverage=coverage_snapshot,\n../2365-b97c4115/forge/forge_metadata.py:1941:    coverage_snapshot = _load_dynamic_access_snapshot_from_metrics(run_metrics)\n../2365-b97c4115/forge/forge_metadata.py:1942:    if coverage_snapshot is None:\n../2365-b97c4115/forge/forge_metadata.py:1943:        coverage_snapshot = _load_dynamic_access_snapshot_from_report(claimed_issue)\n../2365-b97c4115/forge/forge_metadata.py:1944:    if coverage_snapshot is None:\n../2365-b97c4115/forge/forge_metadata.py:1948:            coverage_snapshot.covered_calls > 0\n../2365-b97c4115/forge/forge_metadata.py:1949:            and coverage_snapshot.coverage_ratio > LOW_DYNAMIC_ACCESS_COVERAGE_RATIO\n../2365-b97c4115/forge/forge_metadata.py:1956:        coverage=coverage_snapshot,\n../2365-b97c4115/forge/forge_metadata.py:1957:        reason=\"low_dynamic_access_coverage\",\n../2365-b97c4115/forge/forge_metadata.py:1988:    if candidate.coverage is None:\n../2365-b97c4115/forge/forge_metadata.py:1991:    coverage = candidate.coverage\n../2365-b97c4115/forge/forge_metadata.py:1992:    coverage_percent = coverage.coverage_ratio * 100.0\n../2365-b97c4115/forge/forge_metadata.py:2002:        f\"- Dynamic access coverage: {coverage.covered_calls}/{coverage.total_calls} \"\n../2365-b97c4115/forge/forge_metadata.py:2003:        f\"({coverage_percent:.2f}%) from {coverage.source}\\n\"\n../2365-b97c4115/forge/forge_metadata.py:2006:        \"Analyze the generated tests, metadata, stats, and dynamic-access report in this repository. \"\n../2365-b97c4115/forge/forge_metadata.py:2010:        \"- Explain briefly why dynamic-access coverage is missing or still very low.\\n\"\n../2365-b97c4115/forge/forge_metadata.py:2023:    if candidate.reason == \"test_generation_failed\" or candidate.coverage is None:\n../2365-b97c4115/forge/forge_metadata.py:2026:    coverage_percent = candidate.coverage.coverage_ratio * 100.0\n../2365-b97c4115/forge/forge_metadata.py:2029:        f\"Automation completed for `{claimed_issue.issue_coordinates}`, but dynamic-access coverage remains \"\n../2365-b97c4115/forge/forge_metadata.py:2030:        f\"`{candidate.coverage.covered_calls}/{candidate.coverage.total_calls}` ({coverage_percent:.2f}%). \"\n../2365-b97c4115/forge/forge_metadata.py:2031:        \"This suggests the generated tests are not exercising the required dynamic-access paths well enough.\\n\\n\"\n../2365-b97c4115/forge/forge_metadata.py:2033:        \"- Inspect the generated tests and compare them with the dynamic-access report to find uncovered call sites.\\n\"\n../2365-b97c4115/forge/forge_metadata.py:2144:    coverage_details = \"- Dynamic-access coverage: unavailable\"\n../2365-b97c4115/forge/forge_metadata.py:2145:    if candidate.coverage is not None:\n../2365-b97c4115/forge/forge_metadata.py:2146:        coverage_percent = candidate.coverage.coverage_ratio * 100.0\n../2365-b97c4115/forge/forge_metadata.py:2147:        coverage_details = (\n../2365-b97c4115/forge/forge_metadata.py:2148:            f\"- Dynamic-access coverage: {candidate.coverage.covered_calls}/\"\n../2365-b97c4115/forge/forge_metadata.py:2149:            f\"{candidate.coverage.total_calls} ({coverage_percent:.2f}%) from {candidate.coverage.source}\"\n../2365-b97c4115/forge/forge_metadata.py:2168:        f\"{coverage_details}\\n\\n\"\n../2365-b97c4115/forge/forge_metadata.py:2680:            coverage=None,\n../2365-b97c4115/forge/forge_metadata.py:2746:            pipeline_argv.append(\"--keep-tests-without-dynamic-access\")\n../2365-b97c4115/forge/forge_metadata.py:2839:            \"improve-coverage-workflow\",\n../2365-b97c4115/forge/forge_metadata.py:2840:            f\"Invoking improve_library_coverage workflow for issue #{issue_number}: \"\n../2365-b97c4115/forge/forge_metadata.py:2853:        rc = run_improve_library_coverage_workflow(pipeline_argv)\n../2365-b97c4115/forge/forge_metadata.py:2859:                f\"ERROR: improve_library_coverage workflow failed for issue #{issue_number} (exit {rc})\",\n../2365-b97c4115/forge/forge_metadata.py:3673:        run_make_pr_improve_coverage(\n../2365-b97c4115/forge/forge_metadata.py:4799:        \"--keep-tests-without-dynamic-access\",\n../2365-b97c4115/forge/forge_metadata.py:4802:            \"Forwarded to the new-library pipeline. Keeps generated tests for dynamic-access \"\n../2365-b97c4115/forge/forge_metadata.py:4803:            \"strategies even when no dynamic-access coverage is added.\"\n../2365-b97c4115/forge/utility_scripts/jacoco_parser.py:7:JaCoCo XML coverage parser.\n../2365-b97c4115/forge/utility_scripts/jacoco_parser.py:8:Parses lines coverage from JaCoCo XML and aggregates all <counter type='LINE'> elements.\n../2365-b97c4115/forge/utility_scripts/jacoco_parser.py:19:def compute_line_coverage(xml_path: str):\n../2365-b97c4115/forge/utility_scripts/jacoco_parser.py:21:    Aggregate line counters from a JaCoCo XML report and return coverage percent.\n../2365-b97c4115/forge/utility_scripts/jacoco_parser.py:57:    percent, covered_total = compute_line_coverage(xml_path)\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:3:description: Review pull requests with the `fixes-native-image-run-fail` label in graalvm-reachability-metadata. Use when asked to review or triage a PR that fixes a native-image runtime failure for an existing library version update. Focus on validating the runtime/native fix, keeping the diff scoped, and ensuring dynamic-access coverage does not drop between the previously tested version and the new version.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:9:These PRs repair metadata or tests after an existing library version compiles and builds a native image, but the native image fails when the test runs. Review them more lightly than `library-new-request` PRs: the library is already supported, so the goal is to restore native-image behavior for a newer version while preserving existing dynamic-access coverage.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:19:- Treat dynamic-access coverage preservation as the main quality gate. The new version should not report lower dynamic-access coverage than the previously tested version unless the PR gives a concrete, credible reason.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:20:- For numeric gates, compare the reported evidence as-is. Do not inspect generation filters, agent configuration, or metadata contents to second-guess why dynamic-access or metadata-count numbers are what they are.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:53:4. Check dynamic-access coverage across versions.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:55:   - Compare `dynamicAccess.coverageRatio`, `coveredCalls`, `totalCalls`, and the `dynamicAccess.breakdown` entries for reflection, resources, proxies, serialization, JNI, or any other present report type.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:56:   - Do not use `user-code-filter.json`, agent configuration, or metadata file contents to argue that the reported dynamic-access values are not comparable. Use the stats values as reported unless the stats are missing or stale.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:57:   - A lower `coverageRatio` or lower `coveredCalls` for the new version is blocking unless the total dynamic-access surface changed and the PR explains why the reduction is expected.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:58:   - If metadata fixes make the native run pass but the dynamic-access ratio drops, ask for restored coverage first. Passing native execution is not enough by itself.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:59:   - If `totalCalls` increases while `coveredCalls` stays flat or the ratio drops, ask for additional test coverage or metadata unless the uncovered calls are clearly outside the library behavior under test.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:67:   - Do not require an exact match. Differences are normal when upstream APIs move, generated metadata is cleaned up, or dynamic-access totals change.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:69:   - When the new total is below 25% of the original and the tests and dynamic-access stats still claim comparable coverage, ask for restored metadata or a concrete explanation of the API/package change.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:76:   - If CI is flaky but the diff and coverage comparison are sound, ask for a rerun instead of blocking on speculation.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:84:- Dynamic-access coverage does not drop between the previous and new tested versions, or any apparent drop is convincingly explained by a changed upstream API surface.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:90:- The fix makes native execution pass by skipping the failing native path, disabling assertions, or removing coverage.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:91:- Dynamic-access coverage drops without a credible explanation and replacement coverage.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:100:- The API or native runtime change is plausible but the PR does not explain why a coverage drop is expected.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:107:- For coverage drops: say that dynamic-access coverage must not regress between tested versions, cite the old and new values, and ask for either restored coverage or a concrete explanation.\n../2365-b97c4115/skills/review-fixes-native-image-run-fail/SKILL.md:109:- For native skips: say that the PR avoids the failing native path instead of fixing it, so it does not demonstrate native-image runtime coverage.\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:77:    \"\"\"Return True when the dynamic-access stats entry matches the expected object shape.\"\"\"\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:81:    required_keys = {\"coveredCalls\", \"totalCalls\", \"coverageRatio\", \"breakdown\"}\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:85:def _is_valid_library_coverage_entry(entry) -> bool:\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:86:    \"\"\"Return True when the library-coverage entry matches the expected object shape.\"\"\"\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:94:def _sanitize_library_coverage(library_coverage) -> dict | None:\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:95:    \"\"\"Drop invalid coverage counters so metrics output remains schema-compatible.\"\"\"\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:96:    if not isinstance(library_coverage, dict):\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:101:        entry = library_coverage.get(metric)\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:102:        if _is_valid_library_coverage_entry(entry):\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:123:    library_coverage = _sanitize_library_coverage(version_entry.get(\"libraryCoverage\"))\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:124:    if library_coverage is not None:\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:125:        sanitized[\"libraryCoverage\"] = library_coverage\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:140:def _stats_coverage_metrics(repo_path: str, package: str, artifact: str, library_version: str) -> tuple[float, int] | None:\n../2365-b97c4115/forge/utility_scripts/metrics_writer.py:141:    \"\"\"Return coverage metrics from exploded stats files when available