[tool-call] delta {"path":"tests/src/com.beust/jcommander/1.72/src/test/java/com_beust/jcommander/ParameterizedTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_beust.jcommander;\n\nimport com.beust.jcommander.JCommander;\nimport com.beust.jcommander.Parameter;\nimport com.beust.jcommander.ParameterDescription;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ParameterizedTest {\n    @Test\n    void parsesFieldBackedParametersAndReadsTheirDefaults() {\n        FieldBackedOptions options = new FieldBackedOptions();\n        JCommander commander = JCommander.newBuilder()\n                .addObject(options)\n                .build();\n\n        assertThat(defaultValue(commander, \"--name\")).isEqualTo(\"default-name\");\n\n        commander.parse(\"--name\", \"custom-name\", \"--enabled\");\n\n        assertThat(options.getName()).isEqualTo(\"custom-name\");\n        assertThat(options.isEnabled()).isTrue();\n    }\n\n    @Test\n    void parsesMethodBackedParameterAndReadsDefaultThroughGetter() {\n        GetterBackedMethodOptions options = new GetterBackedMethodOptions();\n        JCommander commander = JCommander.newBuilder()\n                .addObject(options)\n                .build();\n\n        assertThat(defaultValue(commander, \"--port\")).isEqualTo(8181);\n\n        commander.parse(\"--port\", \"9090\");\n\n        assertThat(options.getPort()).isEqualTo(9090);\n    }\n\n    @Test\n    void readsMethodBackedParameterDefaultFromMatchingFieldWhenGetterIsAbsent() {\n        FieldFallbackMethodOptions options = new FieldFallbackMethodOptions();\n        JCommander commander = JCommander.newBuilder()\n                .addObject(options)\n                .build();\n\n        assertThat(defaultValue(commander, \"--token\")).isEqualTo(\"initial-token\");\n\n        commander.parse(\"--token\", \"parsed-token\");\n\n        assertThat(options.currentToken()).isEqualTo(\"parsed-token\");\n    }\n\n    private static Object defaultValue(JCommander commander, String optionName) {\n        for (ParameterDescription description : commander.getParameters()) {\n            if (description.getNames().contains(optionName)) {\n                return description.getDefault();\n            }\n        }\n        throw new AssertionError(\"No parameter description for \" + optionName);\n    }\n\n    public static class FieldBackedOptions {\n        @Parameter(names = \"--name\")\n        private String name = \"default-name\";\n\n        @Parameter(names = \"--enabled\")\n        private boolean enabled;\n\n        String getName() {\n            return name;\n        }\n\n        boolean isEnabled() {\n            return enabled;\n        }\n    }\n\n    public static class GetterBackedMethodOptions {\n        private int port = 8181;\n\n        @Parameter(names = \"--port\")\n        public void setPort(int port) {\n            this.port = port;\n        }\n\n        public int getPort() {\n            return port;\n        }\n    }\n\n    public static class FieldFallbackMethodOptions {\n        private String token = \"initial-token\";\n\n        @Parameter(names = \"--token\")\n        public void setToken(String token) {\n            this.token = token;\n        }\n\n        String currentToken() {\n            return token;\n        }\n    }\n}\n"}
