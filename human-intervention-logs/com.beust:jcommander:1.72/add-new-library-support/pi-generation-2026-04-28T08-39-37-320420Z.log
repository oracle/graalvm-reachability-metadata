ed from command resource bundle\");\n    }\n\n    @Parameters(\n            commandNames = \"localized\",\n            commandDescription = \"Fallback command description\",\n            commandDescriptionKey = \"command.description\",\n            resourceBundle = \"com_beust.jcommander.parameter_descriptions\")\n    public static class LocalizedCommand {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 540, "output": 946, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 19406, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777365534157, "responseId": "resp_0ac935e5cea6b5c30169f0721e987c8193a8da717a4ef1fc92"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pNE97BVHtW2z9GxpYhnSZKFE|fc_0ac935e5cea6b5c30169f0722924bc819387e1f5bc89a89b7a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1245 bytes to tests/src/com.beust/jcommander/1.72/src/test/java/com_beust/jcommander/JCommanderTest.java"}], "isError": false, "timestamp": 1777365546978}]}
