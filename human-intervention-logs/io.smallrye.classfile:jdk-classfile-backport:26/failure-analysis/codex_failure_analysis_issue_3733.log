ER_CLASS));\\n        assertThat(loader.resourceRequests).isEqualTo(1);\\n        assertThat(loader.lastRequestedResource).isEqualTo(GENERATED_CLASS_RESOURCE);\\n    }\\n\\n    private static final class InMemoryClassResourceLoader extends ClassLoader {\\n        private final String resourceName;\\n        private final byte[] classBytes;\\n        private int resourceRequests;\\n        private String lastRequestedResource;\\n\\n        private InMemoryClassResourceLoader(String resourceName, byte[] classBytes) {\\n            super(ClassHierarchyResolverAnonymous2Test.class.getClassLoader());\\n            this.resourceName = resourceName;\\n            this.classBytes = classBytes.clone();\\n        }\\n\\n        @Override\\n        public InputStream getResourceAsStream(String name) {\\n            resourceRequests++;\\n            lastRequestedResource = name;\\n            if (resourceName.equals(name)) {\\n                return new ByteArrayInputStream(classBytes);\\n            }\\n            return super.getResourceAsStream(name);\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 904, \"output\": 1086, \"cacheRead\": 24064, \"cacheWrite\": 0, \"totalTokens\": 26054, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777600764614, \"responseId\": \"resp_00740f9c0fc860c10169f408fd132881a2a55d525fedf1336e\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_2xEZTDlaFAso5UjA1HRHHPyY|fc_00740f9c0fc860c10169f4090a46c881a2a6e3a6a888984ef5\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 2574 bytes to tests/src/io.smallrye.classfile/jdk-classfile-backport/26/src/test/java/io_smallrye_classfile/jdk_classfile_backport/ClassHierarchyResolverAnonymous2Test.java\"}], \"isError\": false, \"timestamp\": 1777600780490}]}\n1892:[tool-call]