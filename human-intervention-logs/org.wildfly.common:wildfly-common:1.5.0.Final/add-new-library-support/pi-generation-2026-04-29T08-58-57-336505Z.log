[tool-call] delta {"path":"tests/src/org.wildfly.common/wildfly-common/1.5.0.Final/src/test/java/org_wildfly_common/wildfly_common/Wildfly_commonTest.java","edits":[{"oldText":"import java.util.ArrayList;\nimport java.util.EnumSet;\nimport java.util.List;\n","newText":"import java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.EnumSet;\nimport java.util.List;\n"},{"oldText":"import org.wildfly.common.ref.Reference;\nimport org.wildfly.common.ref.References;\nimport org.wildfly.common.selector.GlobalSelector;\nimport org.wildfly.common.selector.Selector;\nimport org.wildfly.common.selector.SelectorPermission;\nimport org.wildfly.common.selector.ThreadLocalSelector;\n","newText":"import org.wildfly.common.ref.Reference;\nimport org.wildfly.common.ref.References;\nimport org.wildfly.common.string.CompositeCharSequence;\n"},{"oldText":"    @Test\n    void selectorsSwitchBetweenGlobalAndThreadLocalValues() {\n        SelectableValue global = new SelectableValue();\n        SelectableValue firstThreadValue = new SelectableValue();\n        SelectableValue secondThreadValue = new SelectableValue();\n        ThreadLocal<SelectableValue> threadLocal = ThreadLocal.withInitial(() -> firstThreadValue);\n        Selector.Getter<SelectableValue> getter = Selector.selectorGetterFor(SelectableValue.class);\n\n        try {\n            assertThat(Selector.<SelectableValue>nullSelector().get()).isNull();\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isNull();\n\n            Selector.setSelectorFor(SelectableValue.class, new GlobalSelector<>(global));\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isSameAs(global);\n            assertThat(getter.getSelector().get()).isSameAs(global);\n\n            Selector.setSelectorFor(SelectableValue.class, new ThreadLocalSelector<>(threadLocal));\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isSameAs(firstThreadValue);\n            assertThat(getter.getSelector().get()).isSameAs(firstThreadValue);\n\n            threadLocal.set(secondThreadValue);\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isSameAs(secondThreadValue);\n            assertThat(Selector.selectorGetterActionFor(SelectableValue.class).run().getSelector().get())\n                    .isSameAs(secondThreadValue);\n\n            String permissionName = SelectableValue.class.getName();\n            SelectorPermission allActions = new SelectorPermission(permissionName, \"get,set,change\");\n            assertThat(allActions.getActions()).isEqualTo(\"get,set,change\");\n            assertThat(allActions.implies(Selector.getGetPermissionFor(SelectableValue.class))).isTrue();\n            assertThat(allActions.implies(Selector.getSetPermissionFor(SelectableValue.class))).isTrue();\n            assertThat(new SelectorPermission(permissionName, \"get\")\n                    .implies(Selector.getChangePermissionFor(SelectableValue.class))).isFalse();\n        } finally {\n            Selector.setSelectorFor(SelectableValue.class, null);\n            threadLocal.remove();\n        }\n\n        assertThat(Selector.selectorFor(SelectableValue.class).get()).isNull();\n    }\n\n","newText":"    @Test\n    void compositeCharSequencesBehaveAsSingleCharSequence() {\n        CompositeCharSequence sequence = new CompositeCharSequence(\"Wild\", \"Fly\", \" \", new StringBuilder(\"Common\"));\n\n        assertThat(sequence.length()).isEqualTo(\"WildFly Common\".length());\n        assertThat(sequence.charAt(0)).isEqualTo('W');\n        assertThat(sequence.charAt(4)).isEqualTo('F');\n        assertThat(sequence.charAt(8)).isEqualTo('C');\n        assertThat(sequence.toString()).isEqualTo(\"WildFly Common\");\n        assertThat(sequence.subSequence(0, 4).toString()).isEqualTo(\"Wild\");\n        assertThat(sequence.subSequence(4, 8).toString()).isEqualTo(\"Fly \");\n        assertThat(sequence.subSequence(6, 11).toString()).isEqualTo(\"y Com\");\n        assertThat(sequence.subSequence(3, 3)).isEqualTo(\"\");\n        assertThat(sequence.equals(new StringBuilder(\"WildFly Common\"))).isTrue();\n        assertThat(sequence.hashCode()).isEqualTo(\"WildFly Common\".hashCode());\n\n        CompositeCharSequence fromList = new CompositeCharSequence(Arrays.asList(\"WildFly\", \" Common\"));\n        assertThat(fromList).isEqualTo(sequence);\n        assertThatThrownBy(() -> sequence.charAt(sequence.length())).isInstanceOf(IndexOutOfBoundsException.class);\n        assertThatThrownBy(() -> sequence.subSequence(-1, 2)).isInstanceOf(IndexOutOfBoundsException.class);\n    }\n\n"},{"oldText":"    private static final class SelectableValue {\n    }\n\n    private static final class ContextValue implements Contextual<ContextValue> {\n","newText":"    private static final class ContextValue implements Contextual<ContextValue> {\n"}]}
