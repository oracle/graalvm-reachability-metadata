ss);\\n\\n        try {\\n            assertThat(Selector.<SelectableValue>nullSelector().get()).isNull();\\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isNull();\\n\\n            Selector.setSelectorFor(SelectableValue.class, new GlobalSelector<>(global));\\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isSameAs(global);\\n            assertThat(getter.getSelector().get()).isSameAs(global);\\n\\n            Selector.setSelectorFor(SelectableValue.class, new ThreadLocalSelector<>(threadLocal));\\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isSameAs(firstThreadValue);\\n            assertThat(getter.getSelector().get()).isSameAs(firstThreadValue);\\n\\n            threadLocal.set(secondThreadValue);\\n            assertThat(Selector.selectorFor(SelectableValue.class).get()).isSameAs(secondThreadValue);\\n            assertThat(Selector.selectorGetterActionFor(SelectableValue.class).run().getSelector().get())\\n                    .isSameAs(secondThreadValue);\\n\\n            String permissionName = SelectableValue.class.getName();\\n            SelectorPermission allActions = new SelectorPermission(permissionName, \\\"get,set,change\\\");\\n            assertThat(allActions.getActions()).isEqualTo(\\\"get,set,change\\\");\\n            assertThat(allActions.implies(Selector.getGetPermissionFor(SelectableValue.class))).isTrue();\\n            assertThat(allActions.implies(Selector.getSetPermissionFor(SelectableValue.class))).isTrue();\\n            assertThat(new SelectorPermission(permissionName, \\\"get\\\")\\n                    .implies(Selector.getChangePermissionFor(SelectableValue.class))).isFalse();\\n        } finally {\\n            Selector.setSelectorFor(SelectableValue.class, null);\\n            threadLocal.remove();\\n        }\\n\\n        assertThat(Selector.selectorFor(SelectableValue.class).get()).isNull();\\n    }\\n\\n\", \"newText\": \"    @Test\\n    void co