.evaluate((context, target) -> target.append(context.getKey().toUpperCase())))\n   169\t                .isEqualTo(\"A+B=C\");\n   170\t\n   171\t        Expression general = Expression.compile(\"grant ${{permission.name}}\", Expression.Flag.GENERAL_EXPANSION);\n   172\t        assertThat(general.evaluate((context, target) -> target.append(context.getKey().replace('.', '-'))))\n   173\t                .isEqualTo(\"grant permission-name\");\n   174\t\n   175\t        String propertyName = \"wildfly.common.test.property\";\n   176\t        String previous = System.getProperty(propertyName);\n   177\t        try {\n   178\t            System.setProperty(propertyName, \"configured\");\n   179\t            assertThat(Expression.compile(\"value=${\" + propertyName + \":fallback}\").evaluateWithProperties(true))\n   180\t                    .isEqualTo(\"value=configured\");\n   181\t            System.clearProperty(propertyName);\n   182\t            assertThat(Expression.compile(\"value=${\" + propertyName + \":fallback}\").evaluateWithProperties(true))\n   183\t                    .isEqualTo(\"value=fallback\");\n   184\t            assertThat(Expression.compile(\"value=${\" + propertyName + \"}\").evaluateWithProperties(false))\n   185\t                    .isEqualTo(\"value=\");\n   186\t        } finally {\n   187\t            if (previous == null) {\n   188\t                System.clearProperty(propertyName);\n   189\t            } else {\n   190\t                System.setProperty(propertyName, previous);\n   191\t            }\n   192\t        }\n   193\t\n   194\t        assertThat(Expression.compile(\"${unterminated\", Expression.Flag.LENIENT_SYNTAX)\n   195\t                .evaluate((context, target) -> target.append(context.getKey())))\n   196\t                .isEqualTo(\"unterminated\");\n   197\t    }\n   198\t\n   199\t    @Test\n   200\t    void inetCidrAndAddressTablesSelectMostSpecificMappings() throws Exception {\n   201\t        Inet4Address host = Inet.parseInet4AddressOrFail(\"192.168.1.42\");\n   202\t        assertThat(Inet.isInet4Address(\"192.168.1.42\")).isTrue();\n   203\t        assertThat(Inet.isInet4Address(\"999.168.1.42\")).isFalse();\n   204\t        assertThat(Inet.toOptimalString(host)).isEqualTo(\"192.168.1.42\");\n   205\t        assertThat(Inet.toURLString(Inet.parseInet6AddressOrFail(\"2001:db8::1\"), false))\n   206\t                .isEqualTo(\"[2001:db8::1]\");\n   207\t        assertThat(Inet.toInet6Address(host).getAddress())\n   208\t                .endsWith((byte) 192, (byte) 168, (byte) 1, (byte) 42);\n   209\t        assertThat(URIs.getUserFromURI(new java.net.URI(\"http://alice:secret@example.test/path\")))\n   210\t                .isEqualTo(\"alice\");\n   211\t        assertThat(Inet.getAllAddressesByNameAndType(\"127.0.0.1\", Inet4Address.class))\n   212\t                .singleElement()\n   213\t                .extracting(java.net.InetAddress::getHostAddress)\n   214\t                .isEqualTo(\"127.0.0.1\");\n   215\t        assertThat(Inet.getAllAddressesByNameAndType(\"::1\", Inet6Address.class))\n   216\t                .singleElement()\n   217\t                .extracting(java.net.InetAddress::getAddress)\n   218\t                .isEqualTo(Inet.parseInet6AddressOrFail(\"::1\").getAddress());\n   219\t\n   220\t        CidrAddress office = CidrAddress.create(host, 24);\n   221\t        CidrAddress officeHost = CidrAddress.create(new byte[] {(byte) 192, (byte) 168, 1, 42}, 32);\n   222\t        CidrAddress privateNet = Inet.parseCidrAddress(\"192.168.0.0/16\");\n   223\t        assertThat(office.toString()).isEqualTo(\"192.168.1.0/24\");\n   224\t        assertThat(office.getNetworkAddress().getHostAddress()).isEqualTo(\"192.168.1.0\");\n   225\t        assertThat(office.getBroadcastAddress().getHostAddress()).isEqualTo(\"192.168.1.255\");\n   226\t        assertThat(office.matches(host)).isTrue();\n   227\t        assertThat(office.matches(Inet.parseInet4AddressOrFail(\"192.168.2.1\"))).isFalse();\n   228\t        assertThat(privateNet.matches(office)).isTrue();\n   229\t        assertThat(office.compareTo(officeHost)).isLessThan(0);\n   230\t        assertThat(Inet.parseCidrAddress(\"invalid/24\")).isNull();\n   231\t\n   232\t        CidrAddressTable<String> table = new CidrAddressTable<>();\n   233\t        assertThat(table.isEmpty()).isTrue();\n   234\t        assertThat(table.put(privateNet, \"private\")).isNull();\n   235\t        assertThat(table.put(office, \"office\")).isNull();\n   236\t        assertThat(table.put(officeHost, \"host\")).isNull();\n   237\t        assertThat(table.get(host)).isEqualTo(\"host\");\n   238\t        assertThat(table.get(Inet.parseInet4AddressOrFail(\"192.168.1.99\"))).isEqualTo(\"office\");\n   239\t        assertThat(table.get(Inet.parseInet4AddressOrFail(\"192.168.2.99\"))).isEqualTo(\"private\");\n   240\t        assertThat(table.getOrDefault(Inet.parseInet4AddressOrFail(\"10.0.0.1\"), \"default\")).isEqualTo(\"default\");\n   241\t        assertThat(table.putIfAbsent(office, \"ignored\")).isEqualTo(\"office\");\n   242\t        assertThat(table.replaceExact(office, \"office-v2\")).isEqualTo(\"office\");\n   243\t        assertThat(table.replaceExact(office, \"office-v2\", \"office-v3\")).isTrue();\n   244\t        assertThat(table.removeExact(officeHost, \"host\")).isTrue();\n   245\t        assertThat(table.get(host)).isEqualTo(\"office-v3\");\n   246\t\n   247\t        CidrAddressTable<String> cloned = table.clone();\n   248\t        table.clear();\n   249\t        assertThat(table).isEmpty();\n   250\t        assertThat(cloned).hasSize(2);\n   251\t        List<String> values = new ArrayList<>();\n   252\t        for (CidrAddressTable.Mapping<String> mapping : cloned) {\n   253\t            values.add(mapping.getValue());\n   254\t            if (mapping.getRange().equals(office)) {\n   255\t                assertThat(mapping.getParent().getValue()).isEqualTo(\"private\");\n   256\t            }\n   257\t        }\n   258\t        assertThat(values).containsExactly(\"private\", \"office-v3\");\n   259\t    }\n   260\t\n   261\t    @Test\n   262\t    void archivesReadEntriesAndNestedArchives() throws Exception {\n   263\t        Path archivePath = Files.createTempFile(\"wildfly-common-archive\", \".zip\");\n   264\t        byte[] settings = \"mode=dev\\n\".getBytes(StandardCharsets.UTF_8);\n   265\t        byte[] nestedArchive = createZip(\"nested/readme.txt\", \"nested archive\".getBytes(StandardCharsets.UTF_8));\n   266\t        try {\n   267\t            try (ZipOutputStream zip = new ZipOutputStream(Files.newOutputStream(archivePath))) {\n   268\t                addZipEntry(zip, \"config/\", new byte[0]);\n   269\t                addZipEntry(zip, \"config/settings.txt\", settings);\n   270\t                addZipEntry(zip, \"nested.zip\", nestedArchive);\n   271\t            }\n   272\t\n   273\t            try (Archive archive = Archive.open(archivePath)) {\n   274\t                long directoryHandle = archive.getEntryHandle(\"config/\");\n   275\t                assertThat(directoryHandle).isNotEqualTo(-1L);\n   276\t                assertThat(archive.getEntryName(directoryHandle)).isEqualTo(\"config/\");\n   277\t\n   278\t                long settingsHandle = archive.getEntryHandle(\"config/settings.txt\");\n   279\t                assertThat(settingsHandle).isNotEqualTo(-1L);\n   280\t                assertThat(archive.entryNameEquals(settingsHandle, \"config/settings.txt\")).isTrue();\n   281\t                assertThat(archive.getEntryName(settingsHandle)).isEqualTo(\"config/settings.txt\");\n   282\t                assertThat(archive.isDirectory(settingsHandle)).isFalse();\n   283\t                assertThat(archive.getUncompressedSize(settingsHandle)).isEqualTo((long) settings.length);\n   284\t                assertThat(readBuffer(archive.getEntryContents(settingsHandle))).isEqualTo(settings);\n   285\t\n   286\t                List<String> entryNames = new ArrayList<>();\n   287\t                for (long handle = archive.getFirstEntryHandle(); handle != -1L; handle = archive.getNextEntryHandle(handle)) {\n   288\t                    entryNames.add(archive.getEntryName(handle));\n   289\t                }\n   290\t                assertThat(entryNames).containsExactly(\"config/\", \"config/settings.txt\", \"nested.zip\");\n   291\t\n   292\t                try (Archive nested = archive.getNestedArchive(archive.getEntryHandle(\"nested.zip\"))) {\n   293\t                    long nestedHandle = nested.getEntryHandle(\"nested/readme.txt\");\n   294\t                    assertThat(nestedHandle).isNotEqualTo(-1L);\n   295\t                    assertThat(readBuffer(nested.getEntryContents(nestedHandle)))\n   296\t                            .isEqualTo(\"nested archive\".getBytes(StandardCharsets.UTF_8));\n   297\t                }\n   298\t            }\n   299\t        } finally {\n   300\t            Files.deleteIfExists(archivePath);\n   301\t        }\n   302\t    }\n   303\t\n   304\t    @Test\n   305\t    void arraysFlagsAndHashHelpersBehaveAsValueUtilities() {\n   306\t        byte[] bytes = {0, 1, 2, 3, 2};\n   307\t        assertThat(Arrays2.equals(bytes, 1, new byte[] {1, 2, 3}, 0, 3)).isTrue();\n   308\t        assertThat(Arrays2.equals(bytes, -1, new byte[] {0}, 0, 1)).isFalse();\n   309\t        assertThat(Arrays2.indexOf(bytes, 2)).isEqualTo(2);\n   310\t        assertThat(Arrays2.indexOf(bytes, 2, 3)).isEqualTo(4);\n   311\t        assertThat(Arrays2.toString(new byte[] {0x0f, (byte) 0xa0})).isEqualTo(\"0fa0\");\n   312\t        assertThat(Arrays2.equals(\"wildfly\", 4, new char[] {'f', 'l', 'y'})).isTrue();\n   313\t        assertThat(Arrays2.compactNulls(new String[] {\"a\", null, \"b\", null})).containsExactly(\"a\", \"b\");\n   314\t        assertThat(Arrays2.createArray(String.class, 2)).hasSize(2);\n   315\t        assertThat(Arrays2.objectToString(new int[] {1, 2, 3})).isEqualTo(\"[1, 2, 3]\");\n   316\t\n   317\t        ArrayIterator<String> iterator = new ArrayIterator<>(new String[] {\"a\", \"b\", \"c\"}, 1);\n   318\t        assertThat(iterator.previous()).isEqualTo(\"a\");\n   319\t        assertThat(iterator.next()).isEqualTo(\"a\");\n   320\t        assertThat(iterator.next()).isEqualTo(\"b\");\n   321\t        assertThat(iterator.nextIndex()).isEqualTo(2);\n   322\t        assertThat(iterator.previousIndex()).isEqualTo(1);\n   323\t\n   324\t        ArrayIterator<String> descending = new ArrayIterator<>(new String[] {\"a\", \"b\", \"c\"}, true);\n   325\t        assertThat(descending.next()).isEqualTo(\"c\");\n   326\t        assertThat(descending.next()).isEqualTo(\"b\");\n   327\t        assertThat(descending.previous()).isEqualTo(\"b\");\n   328\t\n   329\t        TestFlags flags = TestFlags.NONE.with(TestFlag.READ, TestFlag.EXECUTE);\n   330\t        assertThat(flags).containsExactly(TestFlag.READ, TestFlag.EXECUTE);\n   331\t        assertThat(flags.first()).isEqualTo(TestFlag.READ);\n   332\t        assertThat(flags.last()).isEqualTo(TestFlag.EXECUTE);\n   333\t        assertThat(flags.containsAll(TestFlag.READ, TestFlag.EXECUTE)).isTrue();\n   334\t        assertThat(flags.containsAny(TestFlag.WRITE, TestFlag.EXECUTE)).isTrue();\n   335\t        assertThat(flags.without(TestFlag.READ)).containsExactly(TestFlag.EXECUTE);\n   336\t        assertThat(flags.headSet(TestFlag.EXECUTE)).containsExactly(TestFlag.READ);\n   337\t        assertThat(flags.tailSet(TestFlag.WRITE)).containsExactly(TestFlag.EXECUTE);\n   338\t        assertThat(flags.complement()).containsExactly(TestFlag.WRITE);\n   339\t        List<TestFlag> descendingFlags = new ArrayList<>();\n   340\t        flags.descendingIterator().forEachRemaining(descendingFlags::add);\n   341\t        assertThat(descendingFlags).containsExactly(TestFlag.EXECUTE, TestFlag.READ);\n   342\t\n   343\t        assertThat(HashMath.roundToPowerOfTwo(17)).isEqualTo(32);\n   344\t  