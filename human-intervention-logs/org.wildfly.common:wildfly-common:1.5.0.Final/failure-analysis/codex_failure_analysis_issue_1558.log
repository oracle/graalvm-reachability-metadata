);\n    78\t        binary.appendBE((short) 0x1234)\n    79\t                .appendBE(0x56789abc)\n    80\t                .appendBE(0x0123456789abcdefL)\n    81\t                .appendPackedUnsignedBE(0x1fff)\n    82\t                .append(ByteIterator.ofBytes((byte) 0xaa, (byte) 0xbb));\n    83\t        ByteIterator iterator = binary.iterate();\n    84\t        assertThat(iterator.getBE16()).isEqualTo(0x1234);\n    85\t        assertThat(iterator.getBE32()).isEqualTo(0x56789abc);\n    86\t        assertThat(iterator.getBE64()).isEqualTo(0x0123456789abcdefL);\n    87\t        assertThat(iterator.getPackedBE32()).isEqualTo(0x1fff);\n    88\t        assertThat(iterator.drain()).containsExactly((byte) 0xaa, (byte) 0xbb);\n    89\t\n    90\t        MessageDigest digest = MessageDigest.getInstance(\"SHA-256\");\n    91\t        builder.updateDigest(digest);\n    92\t        String digestHex = ByteIterator.ofBytes(digest.digest()).hexEncode().drainToString();\n    93\t        assertThat(digestHex).hasSize(64);\n    94\t\n    95\t        builder.setLength(builder.length() + 2);\n    96\t        assertThat(builder.toArray()).endsWith((byte) 0, (byte) 0);\n    97\t        assertThatThrownBy(() -> new ByteStringBuilder().appendAscii(CodePointIterator.ofString(\"\\u00e9\")))\n    98\t                .isInstanceOf(IllegalArgumentException.class);\n    99\t    }\n   100\t\n   101\t    @Test\n   102\t    void byteAndCodePointIteratorsRoundTripTextAndEncodings() throws Exception {\n   103\t        byte[] payload = \"WildFly Common\".getBytes(StandardCharsets.UTF_8);\n   104\t\n   105\t        assertThat(ByteIterator.ofBytes(payload).base64Encode().drainToString()).isEqualTo(\"V2lsZEZseSBDb21tb24=\");\n   106\t        assertThat(ByteIterator.ofBytes(payload).base64Encode(Base64Alphabet.STANDARD, false).drainToString())\n   107\t                .isEqualTo(\"V2lsZEZseSBDb21tb24\");\n   108\t        assertThat(ByteIterator.ofBytes(payload).base32Encode(Base32Alphabet.STANDARD).drainToString())\n   109\t                .isEqualTo(\"K5UWYZCGNR4SAQ3PNVWW63Q=\");\n   110\t        assertThat(ByteIterator.ofBytes(payload).base32Encode(Base32Alphabet.LOWERCASE, false).drainToString())\n   111\t                .isEqualTo(\"k5uwyzcgnr4saq3pnvww63q\");\n   112\t        assertThat(ByteIterator.ofBytes(payload).hexEncode().drainToString())\n   113\t                .isEqualTo(\"57696c64466c7920436f6d6d6f6e\");\n   114\t\n   115\t        assertThat(CodePointIterator.ofString(\"V2lsZEZseSBDb21tb24=\").base64Decode().drain()).isEqualTo(payload);\n   116\t        assertThat(CodePointIterator.ofString(\"K5UWYZCGNR4SAQ3PNVWW63Q=\").base32Decode().drain()).isEqualTo(payload);\n   117\t        assertThat(CodePointIterator.ofString(\"57696c64466c7920436f6d6d6f6e\").hexDecode().drain()).isEqualTo(payload);\n   118\t        assertThat(CodePointIterator.ofUtf8Bytes(payload).drainToString()).isEqualTo(\"WildFly Common\");\n   119\t        assertThat(CodePointIterator.ofLatin1Bytes(new byte[] {(byte) 0x41, (byte) 0xe9}).drainToString())\n   120\t                .isEqualTo(\"A\\u00e9\");\n   121\t\n   122\t        ByteIterator positioned = ByteIterator.ofBytes(new byte[] {1, 2, 3, 4, 5}, 1, 3);\n   123\t        assertThat(positioned.peekNext()).isEqualTo(2);\n   124\t        assertThat(positioned.next()).isEqualTo(2);\n   125\t        assertThat(positioned.peekPrevious()).isEqualTo(2);\n   126\t        assertThat(positioned.previous()).isEqualTo(2);\n   127\t        assertThat(positioned.getIndex()).isZero();\n   128\t        assertThat(positioned.limitedTo(2).drain()).containsExactly((byte) 2, (byte) 3);\n   129\t\n   130\t        assertThat(ByteIterator.ofByteBuffer(ByteBuffer.wrap(new byte[] {9, 8, 7})).drain())\n   131\t                .containsExactly((byte) 9, (byte) 8, (byte) 7);\n   132\t        assertThat(ByteIterator.ofIterators(ByteIterator.ofBytes((byte) 1), ByteIterator.ofBytes((byte) 2)).drain())\n   133\t                .containsExactly((byte) 1, (byte)