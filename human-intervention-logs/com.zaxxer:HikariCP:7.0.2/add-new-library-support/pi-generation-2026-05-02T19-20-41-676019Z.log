* You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com.zaxxer.hikaricp.test;\n\nimport com.zaxxer.hikari.util.UtilityElf;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.ArrayList;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UtilityElfTest {\n    @Test\n    void safeIsAssignableFromHandlesPresentAndMissingTypes() {\n        ArrayList<String> values = new ArrayList<>();\n\n        assertThat(UtilityElf.safeIsAssignableFrom(values, \"java.util.List\")).isTrue();\n        assertThat(UtilityElf.safeIsAssignableFrom(values, \"example.missing.DoesNotExist\")).isFalse();\n    }\n\n    @Test\n    void createInstanceUsesNoArgConstructor() {\n        NoArgConstructedDependency dependency = UtilityElf.createInstance(\n                NoArgConstructedDependency.class.getName(),\n                NoArgConstructedDependency.class);\n\n        assertThat(dependency).isNotNull();\n        assertThat(dependency.getValue()).isEqualTo(\"created\");\n    }\n\n    @Test\n    void createInstanceUsesMatchingArgumentConstructor() {\n        ArgumentConstructedDependency dependency = UtilityElf.createInstance(\n                ArgumentConstructedDependency.class.getName(),\n                ArgumentConstructedDependency.class,\n                \"jdbc:test\");\n\n        assertThat(dependency).isNotNull();\n        assertThat(dependency.getValue()).isEqualTo(\"jdbc:test\");\n    }\n\n    public static final class NoArgConstructedDependency {\n        private final String value;\n\n        public NoArgConstructedDependency() {\n            this.value = \"created\";\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n\n    public static final class ArgumentConstructedDependency {\n        private final String value;\n\n        public ArgumentConstructedDependency(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777749354410}, {"role": "toolResult", "toolCallId": "call_qUS6vDrKSOPCaBvxAj7YnqAh|fc_024569182bc7a96d0169f64d6a09c481a1877888b52efc2a74", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com.zaxxer.hikaricp.test;\n\nimport com.zaxxer.hikari.util.FastList;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FastListTest {\n    @Test\n    public void defaultConstructorCreatesListWithDefaultCapacity() {\n        FastList<String> values = new FastList<>(String.class);\n\n        values.add(\"first\");\n\n        assertThat(values.size()).isEqualTo(1);\n        assertThat(values.get(0)).isEqualTo(\"first\");\n    }\n\n    @Test\n    public void sizedConstructorCreatesListWithRequestedCapacity() {\n        FastList<String> values = new FastList<>(String.class, 2);\n\n        values.add(\"first\");\n        values.add(\"second\");\n\n        assertThat(values.size()).isEqualTo(2);\n        assertThat(values.get(0)).isEqualTo(\"first\");\n        assertThat(values.get(1)).isEqualTo(\"second\");\n    }\n\n    @Test\n    public void addResizesBackingArrayWhenCapacityIsExceeded() {\n        FastList<String> values = new FastList<>(String.class, 1);\n\n        values.add(\"first\");\n        values.add(\"second\");\n\n        assertThat(values.size()).isEqualTo(2);\n        assertThat(values.get(0)).isEqualTo(\"first\");\n        assertThat(values.get(1)).isEqualTo(\"second\");\n        assertThat(values.removeLast()).isEqualTo(\"second\");\n        assertThat(values.removeLast()).isEqualTo(\"first\");\n        assertThat(values.isEmpty()).isTrue();\n    }\n}\n"}], "isError": false, "timestamp": 1777749354410}]}
