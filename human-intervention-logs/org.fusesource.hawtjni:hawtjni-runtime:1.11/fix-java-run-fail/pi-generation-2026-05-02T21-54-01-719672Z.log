                          return true;
                      }
                  }
              }
              
              // Fall back to extracting to the tmp dir
              customPath = System.getProperty("java.io.tmpdir");
              File target = extract(errors, resource, prefix, suffix, file(customPath));
              if( target!=null ) {
                  if( load(errors, target) ) {
