  package org_apache_pekko.pekko_actor_typed_3
  
  import com.typesafe.config.ConfigFactory
  import org.apache.pekko.actor.typed.ActorSystem
  import org.apache.pekko.actor.typed.scaladsl.Behaviors
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.util.UUID
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  
  class ExtensionsImplTest {
    @Test
    def loadsExtensionIdThroughJavaSingletonAccessor(): Unit = {
      val extensionIdClassName: String = classOf[JavaSingletonConfiguredExtensionId].getName
      val config = ConfigFactory
        .parseString(s"""
          pekko.actor.typed.library-extensions = ["$extensionIdClassName"]
          pekko.actor.typed.extensions = []
          """)
        .withFallback(ConfigFactory.load())
      val systemName: String = s"extensions-impl-${UUID.randomUUID().toString}"
      val system: ActorSystem[Nothing] = ActorSystem(Behaviors.empty, systemName, config)
  
      try {
        val extensionId: JavaSingletonConfiguredExtensionId = JavaSingletonConfiguredExtensionId.getInstance()
  
        assertThat(system.hasExtension(extensionId)).isTrue()
        assertThat(system.extension(extensionId).systemName()).isEqualTo(systemName)
      } finally {
        system.terminate()
        Await.result(system.whenTerminated, 10.seconds)
      }
    }
  }
