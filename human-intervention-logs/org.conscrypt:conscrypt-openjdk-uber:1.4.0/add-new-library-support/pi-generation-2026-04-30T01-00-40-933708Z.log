          if (loadError != null) {
              throw loadError;
          }
      }
  
      // --- DSA/RSA public/private key handling functions -----------------------
  
      static native long EVP_PKEY_new_RSA(byte[] n, byte[] e, byte[] d, byte[] p, byte[] q,
