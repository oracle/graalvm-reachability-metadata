                      .getMethod("getKey", String.class, String.class, SSLEngine.class)
                      .invoke(mDelegate, identityHint, identity, engine);
          } catch (Exception e) {
              throw new RuntimeException("Failed to invoke getKey", e);
          }
      }
  }
