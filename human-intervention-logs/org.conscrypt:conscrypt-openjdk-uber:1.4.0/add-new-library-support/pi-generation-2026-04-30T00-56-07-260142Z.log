              }
  
          } catch (Exception e) {
              errLocal = e;
          }
  
          if (blacklist == null) {
              blacklist = Platform.newDefaultBlacklist();
          }
          if (ctLogStore == null) {
              ctLogStore = Platform.newDefaultLogStore();
          }
  
          if (ctPolicy == null) {
              ctPolicy = Platform.newDefaultPolicy(ctLogStore);
