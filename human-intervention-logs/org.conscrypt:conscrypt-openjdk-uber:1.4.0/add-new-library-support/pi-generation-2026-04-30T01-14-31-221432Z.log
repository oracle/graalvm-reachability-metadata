      static OpenSSLKey wrapJCAPrivateKeyForTLSStackOnly(PrivateKey privateKey,
              ECParameterSpec params) throws InvalidKeyException {
          if (params == null) {
              if (privateKey instanceof ECKey) {
                  params = ((ECKey) privateKey).getParams();
              }
