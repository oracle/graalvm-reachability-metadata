          ): F[Unit] = unit
  
          def setStatus(status: StatusCode): F[Unit] = unit
          def setStatus(status: StatusCode, description: String): F[Unit] = unit
  
          private[otel4s] def end: F[Unit] = unit
          private[otel4s] def end(timestamp: FiniteDuration): F[Unit] = unit
