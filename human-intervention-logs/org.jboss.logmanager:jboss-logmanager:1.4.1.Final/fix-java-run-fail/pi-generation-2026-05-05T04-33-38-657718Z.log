                  builder.append(record.getSourceMethodName());
              }
          };
      }
  
      private static final String separatorString;
  
      static {
          separatorString = doPrivileged(new PrivilegedAction<String>() {
              public String run() {
                  return System.getProperty("line.separator");
              }
          });
      }
  
