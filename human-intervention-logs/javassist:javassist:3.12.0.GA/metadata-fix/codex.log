{"type":"item.completed","item":{"id":"item_46","type":"agent_message","text":"I have enough to stop guessing. I’m building a tiny throwaway native image probe that references `HotSwapper` and prints the actual `ServiceConfigurationError` causes for JDI connectors under the same metadata config."}}
{"type":"item.started","item":{"id":"item_47","type":"command_execution","command":"/usr/bin/bash -lc 'tmpdir=$(mktemp -d)\ncat > \"$tmpdir/ConnectorProbe.java\" <<'\"'EOF'\nimport java.util.Iterator;\nimport java.util.ServiceConfigurationError;\nimport java.util.ServiceLoader;\n\nimport com.sun.jdi.connect.Connector;\nimport javassist.util.HotSwapper;\n\npublic class ConnectorProbe {\n    public static void main(String[] args) {\n        System.out.println(HotSwapper.class.getName());\n        ServiceLoader<Connector> loader = ServiceLoader.load(Connector.class, Connector.class.getClassLoader());\n        Iterator<Connector> iterator = loader.iterator();\n        int count = 0;\n        while (true) {\n            try {\n                if (\"'!iterator.hasNext()) {\n                    break;\n                }\n                Connector connector = iterator.next();\n                System.out.println(\"PROVIDER=\" + connector.getClass().getName() + \" NAME=\" + connector.name());\n                count++;\n            } catch (ServiceConfigurationError error) {\n                System.out.println(\"SERVICE_ERROR=\" + error);\n                Throwable cause = error.getCause();\n                while (cause != null) {\n                    cause.printStackTrace(System.out);\n                    Throwable next = cause.getCause();\n                    if (next == cause) {\n                        break;\n                    }\n                    cause = next;\n                }\n            } catch (Throwable throwable) {\n                throwable.printStackTrace(System.out);\n            }\n        }\n        System.out.println(\"COUNT=\" + count);\n    }\n}\nEOF\n\"$GRAALVM_HOME/bin/javac\" --add-modules=jdk.jdi -cp /home/vjovanov/.gradle/caches/modules-2/files-2.1/javassist/javassist/3.12.0.GA/88b21d1ef06323beff58664cffa62848c033ecd2/javassist-3.12.0.GA.jar \"$tmpdir/ConnectorProbe.java\"\n\"$GRAALVM_HOME/bin/native-image\" --no-fallback --add-modules=jdk.jdi -H