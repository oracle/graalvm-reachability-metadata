{"type":"item.started","item":{"id":"item_87","type":"command_execution","command":"/usr/bin/bash -lc 'tmpdir=$(mktemp -d)\ncat > \"$tmpdir/ConnectorProbe.java\" <<'\"'EOF'\nimport java.util.Iterator;\nimport java.util.ServiceConfigurationError;\nimport java.util.ServiceLoader;\n\nimport com.sun.jdi.connect.Connector;\n\npublic class ConnectorProbe {\n    public static void main(String[] args) {\n        ServiceLoader<Connector> loader = ServiceLoader.load(Connector.class, Connector.class.getClassLoader());\n        Iterator<Connector> iterator = loader.iterator();\n        int count = 0;\n        while (true) {\n            try {\n                if (\"'!iterator.hasNext()) {\n                    break;\n                }\n                Connector connector = iterator.next();\n                System.out.println(\"PROVIDER=\" + connector.getClass().getName() + \" NAME=\" + connector.name());\n                count++;\n            } catch (ServiceConfigurationError error) {\n                System.out.println(\"SERVICE_ERROR=\" + error);\n                Throwable cause = error.getCause();\n                while (cause != null) {\n                    cause.printStackTrace(System.out);\n                    Throwable next = cause.getCause();\n                    if (next == cause) {\n                        break;\n                    }\n                    cause = next;\n                }\n            } catch (Throwable throwable) {\n                throwable.printStackTrace(System.out);\n            }\n        }\n        System.out.println(\"COUNT=\" + count);\n    }\n}\nEOF\n\"$GRAALVM_HOME/bin/javac\" --add-modules=jdk.jdi \"$tmpdir/ConnectorProbe.java\"\n\"$GRAALVM_HOME/bin/native-image\" --no-fallback --add-modules=jdk.jdi -H:+ReportExceptionStackTraces -H:FutureDefaults=all -H:ConfigurationFileDirectories=/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2858-bf134d3f/metadata/javassist/javassist/3.12.0.GA -cp