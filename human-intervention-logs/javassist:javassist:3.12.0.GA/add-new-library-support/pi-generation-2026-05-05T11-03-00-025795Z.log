Test\n    void exercisesConstructorLookupNewInstanceFieldsAndMethodDispatch() throws Throwable {\n        ClassMetaobject.useContextClassLoader = false;\n        ClassMetaobject metaobject = new ClassMetaobject(new String[] {ReflectiveFixture.class.getName()});\n\n        Object instance = metaobject.newInstance(new Object[] {\"created through constructor\"});\n        assertThat(instance).isInstanceOf(ReflectiveFixture.class);\n        assertThat(((ReflectiveFixture) instance).label).isEqualTo(\"created through constructor\");\n\n        metaobject.trapFieldWrite(\"publicStaticValue\", \"updated through metaobject\");\n        assertThat(metaobject.trapFieldRead(\"publicStaticValue\")).isEqualTo(\"updated through metaobject\");\n\n        assertThat(metaobject.getMethodName(0)).isEqualTo(\"staticGreeting\");\n        assertThat(metaobject.getParameterTypes(0)).containsExactly(String.class);\n        assertThat(metaobject.getReturnType(0)).isEqualTo(String.class);\n        assertThat(metaobject.trapMethodcall(0, new Object[] {\"Javassist\"})).isEqualTo(\"Hello, Javassist\");\n\n        assertThat(ClassMetaobject.invoke(instance, 7, new Object[] {\"dispatch\"})).isEqualTo(\n                \"created through constructor:dispatch\");\n    }\n\n    @Test\n    void deserializationReloadsClassThroughContextClassLoader() throws Exception {\n        ClassMetaobject.useContextClassLoader = false;\n        ClassMetaobject serializedMetaobject = new ClassMetaobject(new String[] {ReflectiveFixture.class.getName()});\n        byte[] serialized = serialize(serializedMetaobject);\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        RecordingClassLoader recordingClassLoader = new RecordingClassLoader(originalContextClassLoader);\n\n        ClassMetaobject.useContextClassLoader = true;\n        Thread.currentThread().setContextClassLoader(recordingClassLoader);\n        try {\n            ClassMetaobject deserializedMetaobject = deserialize(serialized);\n\n            assertThat(deserializedMetaobject.getJavaClass()).isEqualTo(ReflectiveFixture.class);\n            assertThat(recordingClassLoader.loadedClassName.get()).isEqualTo(ReflectiveFixture.class.getName());\n            assertThat(deserializedMetaobject.newInstance(new Object[0])).isInstanceOf(ReflectiveFixture.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static byte[] serialize(ClassMetaobject metaobject) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(metaobject);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static ClassMetaobject deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ClassMetaobject) input.readObject();\n        }\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private final AtomicReference<String> loadedClassName = new AtomicReference<>();\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (ReflectiveFixture.class.getName().equals(name)) {\n                loadedClassName.set(name);\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    public static class ReflectiveFixture {\n        public static String publicStaticValue = \"initial\";\n\n        private final String label;\n\n        public ReflectiveFixture() {\n            this(\"constructed\");\n        }\n\n        public ReflectiveFixture(String label) {\n            this.label = label;\n        }\n\n        public static String _m_0