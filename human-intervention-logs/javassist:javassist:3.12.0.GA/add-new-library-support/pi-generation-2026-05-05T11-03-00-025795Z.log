  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.annotation.Annotation;
  
  import javassist.bytecode.ConstPool;
  import javassist.bytecode.annotation.IntegerMemberValue;
  import javassist.bytecode.annotation.StringMemberValue;
  import org.junit.jupiter.api.Test;
  
  public class AnnotationImplTest {
      @Test
      void proxyAnnotationSupportsAnnotationContractAgainstRegularImplementation() throws Exception {
          ConstPool constPool = new ConstPool(AnnotationImplTest.class.getName());
          javassist.bytecode.annotation.Annotation bytecodeAnnotation = new javassist.bytecode.annotation.Annotation(
                  ExampleAnnotation.class.getName(), constPool);
          bytecodeAnnotation.addMemberValue("value", new StringMemberValue("covered", constPool));
          bytecodeAnnotation.addMemberValue("priority", new IntegerMemberValue(constPool, 7));
  
          ExampleAnnotation proxy = (ExampleAnnotation) bytecodeAnnotation.toAnnotationType(
                  AnnotationImplTest.class.getClassLoader(), null);
          ExampleAnnotation matchingAnnotation = new RegularExampleAnnotation("covered", 7);
          ExampleAnnotation differentAnnotation = new RegularExampleAnnotation("covered", 8);
  
          assertThat(proxy.annotationType()).isEqualTo(ExampleAnnotation.class);
          assertThat(proxy.value()).isEqualTo("covered");
          assertThat(proxy.priority()).isEqualTo(7);
          assertThat(proxy.hashCode()).isEqualTo(matchingAnnotation.hashCode());
          assertThat(proxy).isEqualTo(matchingAnnotation);
          assertThat(proxy).isNotEqualTo(differentAnnotation);
      }
  
      public @interface ExampleAnnotation {
          String value();
  
          int priority();
      }
  
      private static final class RegularExampleAnnotation implements ExampleAnnotation {
          private final String value;
          private final int priority;
  
          private RegularExampleAnnotation(String value, int priority) {
              this.value = value;
              this.priority = priority;
          }
  
          @Override
          public String value() {
              return value;
          }
  
          @Override
          public int priority() {
              return priority;
          }
  
          @Override
          public Class<? extends Annotation> annotationType() {
              return ExampleAnnotation.class;
          }
  
          @Override
          public boolean equals(Object object) {
              if (!(object instanceof ExampleAnnotation)) {
                  return false;
              }
              ExampleAnnotation other = (ExampleAnnotation) object;
              return value.equals(other.value()) && priority == other.priority();
          }
  
          @Override
          public int hashCode() {
              return memberHashCode("value", value) + memberHashCode("priority", Integer.valueOf(priority));
          }
  
          private static int memberHashCode(String name, Object value) {
              return (127 * name.hashCode()) ^ value.hashCode();
          }
      }
  }
