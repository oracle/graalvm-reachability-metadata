  package javassist_javassist;
  
  import javassist.ClassClassPath;
  import javassist.ClassPool;
  import javassist.CtClass;
  import javassist.CtNewConstructor;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SecurityActionsTest {
      private static final String BRIDGE_CLASS_NAME = "javassist.util.proxy.SecurityActionsCoverageBridge";
      private static final String PROBE_RESULT_PROPERTY = "javassist.security.actions.coverage.result";
  
      @Test
      void bridgeExercisesDeclaredConstructorLookupAndFieldSet() throws Exception {
          try {
              System.clearProperty(PROBE_RESULT_PROPERTY);
  
              Class<?> bridgeClass = createBridgeClass();
              bridgeClass.newInstance();
  
              assertThat(System.getProperty(PROBE_RESULT_PROPERTY)).isEqualTo("true");
          } catch (Error error) {
              verifyUnsupportedDynamicClassLoading(error);
          }
      }
  
      private static Class<?> createBridgeClass() throws Exception {
          ClassPool classPool = new ClassPool(true);
          classPool.insertClassPath(new ClassClassPath(SecurityActionsTest.class));
          CtClass bridgeClass = classPool.makeClass(BRIDGE_CLASS_NAME);
          bridgeClass.addConstructor(CtNewConstructor.make(
                  "public SecurityActionsCoverageBridge() throws Exception {"
                          + "java.lang.reflect.Constructor constructor = "
                          + "SecurityActions.getDeclaredConstructor("
                          + "StringBuilder.class, new Class[] { String.class });"
                          + "StringBuilder constructed = "
                          + "(StringBuilder) constructor.newInstance(new Object[] { \"initial\" });"
                          + "java.awt.Point target = new java.awt.Point(1, 2);"
                          + "java.lang.reflect.Field valueField = java.awt.Point.class.getField(\"x\");"
                          + "SecurityActions.set(valueField, target, new Integer(7));"
                          + "boolean constructorMatches = \"initial\".equals(constructed.toString());"
                          + "boolean fieldWasSet = target.x == 7;"
                          + "System.setProperty("
                          + "\"" + PROBE_RESULT_PROPERTY + "\", "
                          + "Boolean.toString(constructorMatches && fieldWasSet));"
                          + "}",
                  bridgeClass));
          return classPool.toClass(
                  bridgeClass,
                  SecurityActionsTest.class.getClassLoader(),
                  SecurityActionsTest.class.getProtectionDomain());
      }
  
      private static void verifyUnsupportedDynamicClassLoading(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
  }
