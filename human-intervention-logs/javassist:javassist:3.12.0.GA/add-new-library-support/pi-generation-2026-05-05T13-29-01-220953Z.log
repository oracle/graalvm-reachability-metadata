ist.bytecode.Opcode;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class ClassPoolTest {\n    private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();\n\n    @Test\n    void generatedSamePackageInvokerCallsSyntheticClassLiteralHelper() throws Exception {\n        ClassPool pool = new ClassPool(true);\n        CtClass generatedClass = pool.makeClass(nextClassPoolPackageClassName());\n        addClassLiteralResolverMethod(generatedClass);\n\n        try {\n            Class<?> loadedClass = pool.toClass(\n                    generatedClass,\n                    ClassPool.class.getClassLoader(),\n                    ClassPool.class.getProtectionDomain());\n            Object resolver = loadedClass.getDeclaredConstructor().newInstance();\n\n            assertThat(loadedClass.getMethod(\"resolve\", String.class).invoke(resolver, String.class.getName()))\n                    .isSameAs(String.class);\n        } catch (Throwable throwable) {\n            rethrowIfNotUnsupportedFeatureError(throwable);\n        } finally {\n            generatedClass.detach();\n        }\n    }\n\n    @Test\n    void toClassDefinesGeneratedClassWithProvidedClassLoader() throws Exception {\n        ClassPool pool = new ClassPool(true);\n        CtClass generatedClass = pool.makeClass(nextGeneratedClassName());\n\n        try {\n            Class<?> loadedClass = pool.toClass(\n                    generatedClass,\n                    new GeneratedClassLoader(),\n                    ClassPoolTest.class.getProtectionDomain());\n\n            assertThat(loadedClass.getName()).isEqualTo(generatedClass.getName());\n            assertThat(loadedClass.getClassLoader()).isInstanceOf(GeneratedClassLoader.class);\n        } catch (Throwable throwable) {\n            rethrowIfNotUnsupportedFeatureError(throwable);\n        } finally {\n            generatedClass.detach();\n        }\n    }\n\n    private static void addClassLiteralResolverMethod(CtClass generatedClass) throws Exception {\n        ConstPool constPool = generatedClass.getClassFile().getConstPool();\n        Bytecode bytecode = new Bytecode(constPool, 1, 2);\n        bytecode.addAload(1);\n        bytecode.addInvokestatic(\n                ClassPool.class.getName(),\n                \"class$\",\n                \"(Ljava/lang/String;)Ljava/lang/Class;\");\n        bytecode.addOpcode(Opcode.ARETURN);\n\n        MethodInfo methodInfo = new MethodInfo(\n                constPool,\n                \"resolve\",\n                \"(Ljava/lang/String;)Ljava/lang/Class;\");\n        methodInfo.setAccessFlags(AccessFlag.PUBLIC);\n        methodInfo.setCodeAttribute(bytecode.toCodeAttribute());\n        generatedClass.getClassFile().addMethod(methodInfo);\n    }\n\n    private static String nextGeneratedClassName() {\n        return ClassPoolTest.class.getPackageName()\n                + \".ClassPoolGenerated\"\n                + CLASS_COUNTER.incrementAndGet();\n    }\n\n    private static String nextClassPoolPackageClassName() {\n        return ClassPool.class.getPackageName()\n                + \".ClassPoolHelperInvoker\"\n                + CLASS_COUNTER.incrementAndGet();\n    }\n\n    private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {\n        if (!hasUnsupportedFeatureError(throwable)) {\n            if (throwable instanceof Exception exception) {\n                throw exception;\n            }\n            if (throwable instanceof Error error) {\n                throw error;\n            }\n            throw new AssertionError(throwable);\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static final class GeneratedClassLoader extends ClassLoader {\n        private GeneratedClassLoader() {\n            super(ClassPoolTest.class.getClassLoader());\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777987707401}]}
