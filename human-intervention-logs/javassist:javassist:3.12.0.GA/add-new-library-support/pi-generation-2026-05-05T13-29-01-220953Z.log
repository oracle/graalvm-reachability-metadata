  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Arrays;
  
  import javassist.Loader;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  public class LoaderTest {
      @AfterEach
      void resetFixtureState() {
          MainFixture.receivedArguments = new String[0];
          MainFixture.invocationCount = 0;
      }
  
      @Test
      void runLoadsDelegatedClassAndInvokesItsMainMethod() throws Throwable {
          Loader loader = new Loader(getClass().getClassLoader(), null);
          loader.delegateLoadingOf(MainFixture.class.getName());
  
          loader.run(MainFixture.class.getName(), new String[] {"alpha", "beta"});
  
          assertThat(MainFixture.invocationCount).isEqualTo(1);
          assertThat(MainFixture.receivedArguments).containsExactly("alpha", "beta");
      }
  
      @Test
      void delegatesBootstrapClassLookupToSystemClassLoaderWhenParentIsNull() throws Exception {
          Loader loader = new Loader(null, null);
  
          Class<?> loadedClass = loader.loadClass(String.class.getName());
  
          assertThat(loadedClass).isSameAs(String.class);
      }
  
      @Test
      void readsClassBytesAsResourceBeforeDefiningNonDelegatedClass() throws Exception {
          Loader loader = new Loader(getClass().getClassLoader(), null);
  
          try {
              Class<?> loadedClass = loader.loadClass("javassist.CtClass");
  
              assertThat(loadedClass.getName()).isEqualTo("javassist.CtClass");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      public static class MainFixture {
          private static String[] receivedArguments = new String[0];
          private static int invocationCount;
  
          public static void main(String[] args) {
              receivedArguments = Arrays.copyOf(args, args.length);
              invocationCount++;
          }
      }
  }
