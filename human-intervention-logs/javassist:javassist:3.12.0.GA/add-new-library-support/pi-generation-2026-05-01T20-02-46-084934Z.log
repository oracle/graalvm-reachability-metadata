          String cmd = proxyHeader + "/lookup HTTP/1.0";
          lookupCommand = cmd.getBytes();
          cmd = proxyHeader + "/rmi HTTP/1.0";
          rmiCommand = cmd.getBytes();
          this.servername = host;
          this.port = port;
      }
  
      /**
