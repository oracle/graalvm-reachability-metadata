  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.concurrent.atomic.AtomicReference;
  
  import javassist.tools.reflect.ClassMetaobject;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  public class ClassMetaobjectTest {
      @AfterEach
      void resetClassMetaobjectState() {
          ClassMetaobject.useContextClassLoader = false;
          ReflectiveFixture.publicStaticValue = "initial";
      }
  
      @Test
      void exercisesConstructorLookupNewInstanceFieldsAndMethodDispatch() throws Throwable {
          ClassMetaobject.useContextClassLoader = false;
          ClassMetaobject metaobject = new ClassMetaobject(new String[] {ReflectiveFixture.class.getName()});
  
          Object instance = metaobject.newInstance(new Object[] {"created through constructor"});
          assertThat(instance).isInstanceOf(ReflectiveFixture.class);
          assertThat(((ReflectiveFixture) instance).label).isEqualTo("created through constructor");
  
          metaobject.trapFieldWrite("publicStaticValue", "updated through metaobject");
          assertThat(metaobject.trapFieldRead("publicStaticValue")).isEqualTo("updated through metaobject");
  
          assertThat(metaobject.getMethodName(0)).isEqualTo("staticGreeting");
          assertThat(metaobject.getParameterTypes(0)).containsExactly(String.class);
          assertThat(metaobject.getReturnType(0)).isEqualTo(String.class);
          assertThat(metaobject.trapMethodcall(0, new Object[] {"Javassist"})).isEqualTo("Hello, Javassist");
  
          assertThat(ClassMetaobject.invoke(instance, 7, new Object[] {"dispatch"})).isEqualTo(
                  "created through constructor:dispatch");
      }
  
      @Test
      void deserializationReloadsClassThroughContextClassLoader() throws Exception {
          ClassMetaobject.useContextClassLoader = false;
          ClassMetaobject serializedMetaobject = new ClassMetaobject(new String[] {ReflectiveFixture.class.getName()});
          byte[] serialized = serialize(serializedMetaobject);
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          RecordingClassLoader recordingClassLoader = new RecordingClassLoader(originalContextClassLoader);
  
          ClassMetaobject.useContextClassLoader = true;
          Thread.currentThread().setContextClassLoader(recordingClassLoader);
          try {
              ClassMetaobject deserializedMetaobject = deserialize(serialized);
  
              assertThat(deserializedMetaobject.getJavaClass()).isEqualTo(ReflectiveFixture.class);
              assertThat(recordingClassLoader.loadedClassName.get()).isEqualTo(ReflectiveFixture.class.getName());
              assertThat(deserializedMetaobject.newInstance(new Object[0])).isInstanceOf(ReflectiveFixture.class);
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private static byte[] serialize(ClassMetaobject metaobject) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(metaobject);
          }
          return bytes.toByteArray();
      }
  
      private static ClassMetaobject deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (ClassMetaobject) input.readObject();
          }
      }
  
      private static final class RecordingClassLoader extends ClassLoader {
          private final AtomicReference<String> loadedClassName = new AtomicReference<>();
  
          private RecordingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (ReflectiveFixture.class.getName().equals(name)) {
                  loadedClassName.set(name);
              }
              return super.loadClass(name);
          }
      }
  
      public static class ReflectiveFixture {
          public static String publicStaticValue = "initial";
  
          private final String label;
  
          public ReflectiveFixture() {
              this("constructed");
          }
  
          public ReflectiveFixture(String label) {
              this.label = label;
          }
  
          public static String _m_0_staticGreeting(String name) {
              return "Hello, " + name;
          }
  
          public String _m_7_instanceGreeting(String suffix) {
              return label + ":" + suffix;
          }
      }
  }
