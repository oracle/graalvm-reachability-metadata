      private void computeSignature(MethodFilter filter) // throws CannotCompileException
      {
          makeSortedMethodList();
  
          int l = signatureMethods.size();
          int maxBytes = ((l + 7) >> 3);
          signature = new byte[maxBytes];
          for (int idx = 0; idx < l; idx++)
