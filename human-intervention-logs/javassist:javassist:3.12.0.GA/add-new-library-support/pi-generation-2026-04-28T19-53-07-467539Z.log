oxyFactoryTest {\n    @Test\n    void createsProxyWithConstructorArgumentsAndSerializesProxyDescriptor() throws Throwable {\n        ProxyFactory factory = new ProxyFactory();\n        factory.setUseCache(false);\n        factory.setUseWriteReplace(false);\n        factory.setSuperclass(GreetingService.class);\n        factory.setFilter(method -> method.getName().equals(\"greet\"));\n\n        GreetingService proxy = (GreetingService) factory.create(\n                new Class[] {String.class},\n                new Object[] {\"original\"},\n                new GreetingHandler());\n\n        assertThat(ProxyFactory.isProxyClass(proxy.getClass())).isTrue();\n        assertThat(proxy.prefix()).isEqualTo(\"original\");\n        assertThat(proxy.greet(\"Javassist\")).isEqualTo(\"handled:Javassist\");\n\n        GreetingService restored = deserialize(serialize(proxy));\n\n        assertThat(ProxyFactory.isProxyClass(restored.getClass())).isTrue();\n        assertThat(restored.prefix()).isEqualTo(\"original\");\n        assertThat(restored.greet(\"Native Image\")).isEqualTo(\"handled:Native Image\");\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ProxyObjectOutputStream output = new ProxyObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static GreetingService deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ProxyObjectInputStream input = new ProxyObjectInputStream(new ByteArrayInputStream(bytes))) {\n            input.setClassLoader(ProxyFactoryTest.class.getClassLoader());\n            return (GreetingService) input.readObject();\n        }\n    }\n\n    public static class GreetingService implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String prefix;\n\n        public GreetingService(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String prefix() {\n            return prefix;\n        }\n\n        public String greet(String name) {\n            return prefix + \":\" + name;\n        }\n    }\n\n    private static class GreetingHandler implements MethodHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Object self, Method method, Method proceed, Object[] args) throws Throwable {\n            if (\"greet\".equals(method.getName())) {\n                return \"handled:\" + args[0];\n            }\n            return proceed.invoke(self, args);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2310, "output": 1355, "cacheRead": 41472, "cacheWrite": 0, "totalTokens": 45137, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777405941981, "responseId": "resp_06f59b2502f31d040169f10ff69074819393601374c4a75d4f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_S26QSzF4VNApmdGuLSJHQxYa|fc_06f59b2502f31d040169f11000775481938f67620695d1b270", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3322 bytes to tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist_javassist/ProxyFactoryTest.java"}], "isError": false, "timestamp": 1777405956165}]}
