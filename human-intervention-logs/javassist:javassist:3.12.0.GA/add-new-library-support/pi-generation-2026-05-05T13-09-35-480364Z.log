  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import javassist.bytecode.ConstPool;
  import javassist.bytecode.annotation.Annotation;
  import javassist.bytecode.annotation.ArrayMemberValue;
  import javassist.bytecode.annotation.MemberValue;
  import javassist.bytecode.annotation.StringMemberValue;
  import org.junit.jupiter.api.Test;
  
  public class ArrayMemberValueTest {
      @Test
      void proxyAnnotationReturnsMultiDimensionalStringArrayMember() throws Exception {
          ConstPool constPool = new ConstPool(ArrayMemberValueTest.class.getName());
          Annotation annotation = new Annotation(MatrixAnnotation.class.getName(), constPool);
          ArrayMemberValue matrix = new ArrayMemberValue(constPool);
          matrix.setValue(new MemberValue[] {
                  row(constPool, "alpha", "beta"),
                  row(constPool, "gamma", "delta")
          });
          annotation.addMemberValue("value", matrix);
  
          MatrixAnnotation proxy = (MatrixAnnotation) annotation.toAnnotationType(
                  ArrayMemberValueTest.class.getClassLoader(), null);
          String[][] value = proxy.value();
  
          assertThat(value).hasDimensions(2, 2);
          assertThat(value[0]).containsExactly("alpha", "beta");
          assertThat(value[1]).containsExactly("gamma", "delta");
      }
  
      private static ArrayMemberValue row(ConstPool constPool, String... values) {
          ArrayMemberValue row = new ArrayMemberValue(constPool);
          MemberValue[] memberValues = new MemberValue[values.length];
          for (int i = 0; i < values.length; i++) {
              memberValues[i] = new StringMemberValue(values[i], constPool);
          }
          row.setValue(memberValues);
          return row;
      }
  
      public @interface MatrixAnnotation {
          String[][] value();
      }
  }
