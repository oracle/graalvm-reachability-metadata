pha\", \"beta\"),\n                row(constPool, \"gamma\")\n        });\n        annotation.addMemberValue(\"value\", matrix);\n\n        MatrixAnnotation proxy = (MatrixAnnotation) annotation.toAnnotationType(\n                ArrayMemberValueTest.class.getClassLoader(), null);\n        String[][] value = proxy.value();\n\n        assertThat(value).hasDimensions(2, 2);\n        assertThat(value[0]).containsExactly(\"alpha\", \"beta\");\n        assertThat(value[1]).containsExactly(\"gamma\");\n    }\n\n    private static ArrayMemberValue row(ConstPool constPool, String... values) {\n        ArrayMemberValue row = new ArrayMemberValue(constPool);\n        MemberValue[] memberValues = new MemberValue[values.length];\n        for (int i = 0; i < values.length; i++) {\n            memberValues[i] = new StringMemberValue(values[i], constPool);\n        }\n        row.setValue(memberValues);\n        return row;\n    }\n\n    public @interface MatrixAnnotation {\n        String[][] value();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 669, "output": 1339, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26584, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777986537327, "responseId": "resp_0f2f12ff67e0499d0169f9ebea1fbc81a09ae9fb6b3384128b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Q0pJunFNYdiJGZjYHGdVlYeV|fc_0f2f12ff67e0499d0169f9ebf55c8081a0a257ff71ff8cc00e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2001 bytes to tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/ArrayMemberValueTest.java"}], "isError": false, "timestamp": 1777986552450}]}
