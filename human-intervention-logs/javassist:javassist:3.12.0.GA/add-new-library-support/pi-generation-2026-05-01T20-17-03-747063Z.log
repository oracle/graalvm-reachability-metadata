       * <br><code>args[1..n]</code> are parameters passed
       *                      to the target <code>main()</code>.
       * </ul>
       *
       * @see javassist.Loader#run(String[])
       */
      public static void main(String[] args) throws Throwable {
          Loader cl = new Loader();
          cl.run(args);
      }
  
