  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.BufferedInputStream;
  import java.io.BufferedOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.OutputStream;
  import java.net.ServerSocket;
  import java.net.Socket;
  import java.net.SocketTimeoutException;
  import java.nio.charset.StandardCharsets;
  import java.util.concurrent.BlockingQueue;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.LinkedBlockingQueue;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicReference;
  
  import javassist.tools.rmi.ObjectImporter;
  import javassist.tools.rmi.Proxy;
  import javassist.tools.rmi.RemoteRef;
  import org.junit.jupiter.api.Test;
  
  public class ObjectImporterTest {
      @Test
      void lookupAndCallSerializeParametersAndCreateProxyFromServerResponses() throws Exception {
          try (FixtureServer server = new FixtureServer()) {
              AtomicReference<String> lookupName = new AtomicReference<>();
              AtomicReference<RemoteRef> remoteArgument = new AtomicReference<>();
              AtomicReference<String> valueArgument = new AtomicReference<>();
              server.enqueue(exchange -> {
                  ObjectInputStream input = exchange.openObjectInputStream();
                  lookupName.set(input.readUTF());
                  try (ObjectOutputStream output = exchange.openObjectOutputStream()) {
                      output.writeInt(42);
                      output.writeUTF(RemoteProxyFixture.class.getName());
                  }
              });
              server.enqueue(exchange -> {
                  ObjectInputStream input = exchange.openObjectInputStream();
                  assertThat(input.readInt()).isEqualTo(42);
                  assertThat(input.readInt()).isEqualTo(7);
                  assertThat(input.readInt()).isEqualTo(2);
                  remoteArgument.set((RemoteRef) input.readObject());
                  valueArgument.set((String) input.readObject());
                  try (ObjectOutputStream output = exchange.openObjectOutputStream()) {
                      output.writeBoolean(true);
                      output.writeObject("remote result");
                  }
              });
  
              ObjectImporter importer = new ObjectImporter("127.0.0.1", server.getPort());
              Object lookedUp = importer.lookupObject("service-name");
              Object result = importer.call(42, 7, new Object[] {lookedUp, "plain value"});
  
              assertThat(lookedUp).isInstanceOf(RemoteProxyFixture.class);
              assertThat(((RemoteProxyFixture) lookedUp)._getObjectId()).isEqualTo(42);
              assertThat(result).isEqualTo("remote result");
              assertThat(lookupName.get()).isEqualTo("service-name");
              assertThat(remoteArgument.get().oid).isEqualTo(42);
              assertThat(valueArgument.get()).isEqualTo("plain value");
          }
      }
  
      @Test
      void callCreatesProxyWhenResultIsRemoteReference() throws Exception {
          try (FixtureServer server = new FixtureServer()) {
              server.enqueue(exchange -> {
                  ObjectInputStream input = exchange.openObjectInputStream();
                  assertThat(input.readInt()).isEqualTo(11);
                  assertThat(input.readInt()).isEqualTo(5);
                  assertThat(input.readInt()).isZero();
                  try (ObjectOutputStream output = exchange.openObjectOutputStream()) {
                      output.writeBoolean(true);
                      output.writeObject(new RemoteRef(84, RemoteProxyFixture.class.getName()));
                  }
              });
  
              ObjectImporter importer = new ObjectImporter("127.0.0.1", server.getPort());
              Object result = importer.call(11, 5, new Object[0]);
  
              assertThat(result).isInstanceOf(RemoteProxyFixture.class);
              assertThat(((RemoteProxyFixture) result)._getObjectId()).isEqualTo(84);
          }
      }
  
      public static class RemoteProxyFixture implements Proxy {
          private final ObjectImporter importer;
          private final int objectId;
  
          public RemoteProxyFixture(ObjectImporter importer, int objectId) {
              this.importer = importer;
              this.objectId = objectId;
          }
  
          @Override
          public int _getObjectId() {
              assertThat(importer).isNotNull();
              return objectId;
          }
      }
  
      private interface ExchangeHandler {
          void handle(Exchange exchange) throws Exception;
      }
  
      private static final class Exchange {
          private final Socket socket;
  
          private Exchange(Socket socket) {
              this.socket = socket;
          }
  
          private ObjectInputStream openObjectInputStream() throws IOException {
              InputStream input = new BufferedInputStream(socket.getInputStream());
              skipHttpHeader(input);
              return new ObjectInputStream(input);
          }
  
          private ObjectOutputStream openObjectOutputStream() throws IOException {
              OutputStream output = new BufferedOutputStream(socket.getOutputStream());
              output.write("HTTP/1.0 200 OK\r\n\r\n".getBytes(StandardCharsets.US_ASCII));
              return new ObjectOutputStream(output);
          }
  
          private static void skipHttpHeader(InputStream input) throws IOException {
              int previous = -1;
              int current;
              int matched = 0;
              while ((current = input.read()) >= 0) {
                  if (previous == '\r' && current == '\n') {
                      matched++;
                      if (matched == 2) {
                          return;
                      }
                  } else if (current != '\r') {
                      matched = 0;
                  }
                  previous = current;
              }
              throw new IOException("Unexpected end of request headers");
          }
      }
  
      private static final class FixtureServer implements AutoCloseable {
          private final BlockingQueue<ExchangeHandler> handlers = new LinkedBlockingQueue<>();
          private final ServerSocket serverSocket;
          private final ExecutorService executor;
          private final AtomicReference<Throwable> failure = new AtomicReference<>();
  
          private FixtureServer() throws IOException {
              serverSocket = new ServerSocket(0);
              serverSocket.setSoTimeout(250);
              executor = Executors.newSingleThreadExecutor();
              executor.submit(this::serve);
          }
  
          private int getPort() {
              return serverSocket.getLocalPort();
          }
  
          private void enqueue(ExchangeHandler handler) {
              handlers.add(handler);
          }
  
          private void serve() {
              while (!serverSocket.isClosed()) {
                  try {
                      Socket socket = serverSocket.accept();
                      ExchangeHandler handler = handlers.poll(5, TimeUnit.SECONDS);
                      if (handler == null) {
                          throw new IOException("No fixture handler was available for request");
                      }
                      try (Socket accepted = socket) {
                          handler.handle(new Exchange(accepted));
                      }
                  } catch (SocketTimeoutException ignored) {
                      // Periodically re-check whether the server was closed.
                  } catch (Throwable throwable) {
                      if (!serverSocket.isClosed()) {
                          failure.compareAndSet(null, throwable);
                      }
                      return;
                  }
              }
          }
  
          @Override
          public void close() throws Exception {
              serverSocket.close();
              executor.shutdownNow();
              assertThat(executor.awaitTermination(5, TimeUnit.SECONDS)).isTrue();
              Throwable throwable = failure.get();
              if (throwable != null) {
                  throw new AssertionError("Fixture server failed", throwable);
              }
          }
      }
