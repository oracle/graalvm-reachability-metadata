nimport javassist.tools.web.Viewer;\nimport org.junit.jupiter.api.Test;\n\npublic class ViewerTest {\n    @Test\n    void runLoadsViewerThroughItsClassLoaderAndInvokesMain() throws Throwable {\n        Viewer viewer = new Viewer(\"127.0.0.1\", 1);\n        PrintStream originalError = System.err;\n        ByteArrayOutputStream errorOutput = new ByteArrayOutputStream();\n\n        try (PrintStream replacementError = new PrintStream(errorOutput, true, StandardCharsets.UTF_8)) {\n            System.setErr(replacementError);\n\n            viewer.run(Viewer.class.getName(), new String[0]);\n        } finally {\n            System.setErr(originalError);\n        }\n\n        assertThat(viewer.getServer()).isEqualTo(\"127.0.0.1\");\n        assertThat(viewer.getPort()).isOne();\n        assertThat(errorOutput.toString(StandardCharsets.UTF_8)).contains(\"Usage: java javassist.tools.web.Viewer\");\n    }\n\n    @Test\n    void loadClassDelegatesCoreJavaClassesToTheSystemLoader() throws Exception {\n        Viewer viewer = new Viewer(\"127.0.0.1\", 1);\n\n        Class<?> loadedClass = viewer.loadClass(String.class.getName());\n\n        assertThat(loadedClass).isSameAs(String.class);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 645, "output": 975, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 16468, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777982591059, "responseId": "resp_0395f714f1380b5f0169f9dc7f6738819d8922d39a10135cce"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_gOeMRVhyoUv88IfY12DFtGZL|fc_0395f714f1380b5f0169f9dc894f00819dbeec8e70e800b334", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1565 bytes to tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/ViewerTest.java"}], "isError": false, "timestamp": 1777982602714}]}
