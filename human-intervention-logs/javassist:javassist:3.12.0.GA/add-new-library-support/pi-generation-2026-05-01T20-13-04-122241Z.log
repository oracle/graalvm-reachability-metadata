              serverSocket.close();
              thread.join(5_000L);
              if (thread.isAlive()) {
                  throw new AssertionError("RMI test server did not finish");
              }
              Throwable thrown = failure.get();
              if (thrown != null) {
                  throw new AssertionError("RMI test server failed", thrown);
              }
          }
      }
