              return rvalue;
          else
              throw new RemoteException(errmsg);
      }
  
      private void skipHeader(InputStream in) throws IOException {
          int len;
          do {
              int c;
              len = 0;
              while ((c = in.read()) >= 0 && c != 0x0d)
                  ++len;
  
