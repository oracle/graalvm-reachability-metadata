  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayOutputStream;
  import java.io.Serializable;
  import java.lang.reflect.Method;
  
  import javassist.util.proxy.MethodHandler;
  import javassist.util.proxy.ProxyFactory;
  import javassist.util.proxy.ProxyObject;
  import javassist.util.proxy.ProxyObjectOutputStream;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ProxyFactoryTest {
      @Test
      void createInstantiatesProxyWithMatchingConstructorAndMethodHandler() throws Exception {
          try {
              ProxyFactory factory = new ProxyFactory();
              factory.setSuperclass(GreetingService.class);
              factory.setFilter(method -> method.getName().equals("message"));
  
              MethodHandler handler = (self, thisMethod, proceed, args) -> "handled " + args[0];
              GreetingService proxy = (GreetingService) factory.create(
                      new Class[] {String.class},
                      new Object[] {"initial"},
                      handler);
  
              assertThat(ProxyFactory.isProxyClass(proxy.getClass())).isTrue();
              assertThat(proxy.prefix()).isEqualTo("initial");
              assertThat(proxy.message("call")).isEqualTo("handled call");
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          }
      }
  
      @Test
      void proxyObjectOutputStreamSerializesProxyClassDescriptorWithFilterSignature() throws Exception {
          try {
              ProxyFactory factory = new ProxyFactory();
              factory.setUseWriteReplace(false);
              factory.setSuperclass(GreetingService.class);
              factory.setFilter(method -> method.getName().equals("message"));
  
              GreetingService proxy = (GreetingService) factory.create(
                      new Class[] {String.class},
                      new Object[] {"serializable"});
              ((ProxyObject) proxy).setHandler(new SerializableMethodHandler());
  
              ByteArrayOutputStream bytes = new ByteArrayOutputStream();
              try (ProxyObjectOutputStream output = new ProxyObjectOutputStream(bytes)) {
                  output.writeObject(proxy);
              }
  
              assertThat(bytes.toByteArray()).isNotEmpty();
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          }
      }
  
      private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {
          if (!hasUnsupportedFeatureError(throwable)) {
              if (throwable instanceof Exception exception) {
                  throw exception;
              }
              if (throwable instanceof Error error) {
                  throw error;
              }
              throw new AssertionError(throwable);
          }
      }
  
      private static boolean hasUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public static class GreetingService implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String prefix;
  
          public GreetingService(String prefix) {
              this.prefix = prefix;
          }
  
          public String prefix() {
              return prefix;
          }
  
          public String message(String value) {
              return prefix + " " + value;
          }
      }
  
      private static final class SerializableMethodHandler implements MethodHandler, Serializable {
          private static final long serialVersionUID = 1L;
  
          @Override
          public Object invoke(Object self, Method thisMethod, Method proceed, Object[] args) {
              return args[0];
          }
      }
  }
