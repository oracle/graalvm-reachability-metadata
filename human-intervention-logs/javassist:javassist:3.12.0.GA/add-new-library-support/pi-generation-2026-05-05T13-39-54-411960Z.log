[tool-call] delta {"path":"tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/SecurityActionsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport javassist.ClassPool;\nimport javassist.CtClass;\nimport javassist.CtNewMethod;\nimport javassist.util.proxy.ProxyFactory;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class SecurityActionsTest {\n    private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();\n\n    @Test\n    void generatedProxyPackageInvokerGetsDeclaredConstructor() throws Exception {\n        CtClass generatedClass = null;\n        try {\n            generatedClass = makeInvokerClass();\n            Object invoker = newInvoker(generatedClass);\n            Method constructorFor = invoker.getClass().getMethod(\"constructorFor\", Class.class, Class[].class);\n\n            Constructor<?> constructor = (Constructor<?>) constructorFor.invoke(\n                    invoker,\n                    ConstructorTarget.class,\n                    new Class[] {String.class});\n\n            assertThat(constructor.getDeclaringClass()).isSameAs(ConstructorTarget.class);\n            assertThat(constructor.getParameterTypes()).containsExactly(String.class);\n        } catch (Throwable throwable) {\n            rethrowIfNotUnsupportedFeatureError(throwable);\n        } finally {\n            detach(generatedClass);\n        }\n    }\n\n    @Test\n    void generatedProxyPackageInvokerSetsFieldValue() throws Exception {\n        CtClass generatedClass = null;\n        try {\n            generatedClass = makeInvokerClass();\n            Object invoker = newInvoker(generatedClass);\n            Method setField = invoker.getClass().getMethod(\"setField\", Field.class, Object.class, Object.class);\n            SetTarget target = new SetTarget();\n            Field field = SetTarget.class.getField(\"value\");\n\n            setField.invoke(invoker, field, target, \"updated\");\n\n            assertThat(target.value).isEqualTo(\"updated\");\n        } catch (Throwable throwable) {\n            rethrowIfNotUnsupportedFeatureError(throwable);\n        } finally {\n            detach(generatedClass);\n        }\n    }\n\n    private static CtClass makeInvokerClass() throws Exception {\n        ClassPool pool = new ClassPool(true);\n        CtClass generatedClass = pool.makeClass(nextInvokerClassName());\n        generatedClass.addMethod(CtNewMethod.make(\"\"\"\n                public java.lang.reflect.Constructor constructorFor(Class target, Class[] parameterTypes) throws Exception {\n                    return SecurityActions.getDeclaredConstructor(target, parameterTypes);\n                }\n                \"\"\", generatedClass));\n        generatedClass.addMethod(CtNewMethod.make(\"\"\"\n                public void setField(java.lang.reflect.Field field, Object target, Object value) throws Exception {\n                    SecurityActions.set(field, target, value);\n                }\n                \"\"\", generatedClass));\n        return generatedClass;\n    }\n\n    private static Object newInvoker(CtClass generatedClass) throws Exception {\n        ClassPool pool = generatedClass.getClassPool();\n        Class<?> invokerClass = pool.toClass(\n                generatedClass,\n                ProxyFactory.class.getClassLoader(),\n                ProxyFactory.class.getProtectionDomain());\n        return invokerClass.getDeclaredConstructor().newInstance();\n    }\n\n    private static String nextInvokerClassName() {\n        return ProxyFactory.class.getPackageName()\n                + \".SecurityActionsInvoker\"\n                + CLASS_COUNTER.incrementAndGet();\n    }\n\n    private static void detach(CtClass generatedClass) {\n        if (generatedClass != null) {\n            generatedClass.detach();\n        }\n    }\n\n    private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {\n        if (!hasUnsupportedFeatureError(throwable)) {\n            if (throwable instanceof Exception exception) {\n                throw exception;\n            }\n            if (throwable instanceof Error error) {\n                throw error;\n            }\n            throw new AssertionError(throwable);\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static final class ConstructorTarget {\n        public ConstructorTarget(String value) {\n            assertThat(value).isNotEmpty();\n        }\n    }\n\n    public static final class SetTarget {\n        public String value = \"initial\";\n    }\n}\n"}
