          ConstPool constPool = generatedClass.getClassFile().getConstPool();
          generatedClass.getClassFile().addMethod(makeConstructorForMethod(constPool));
          generatedClass.getClassFile().addMethod(makeSetFieldMethod(constPool));
          return generatedClass;
      }
  
      private static MethodInfo makeConstructorForMethod(ConstPool constPool) {
          MethodInfo methodInfo = new MethodInfo(constPool, "constructorFor", GET_DECLARED_CONSTRUCTOR_DESCRIPTOR);
          methodInfo.setAccessFlags(AccessFlag.PUBLIC);
  
          Bytecode bytecode = new Bytecode(constPool, 2, 3);
          bytecode.addAload(1);
          bytecode.addAload(2);
          bytecode.addInvokestatic(SECURITY_ACTIONS_CLASS, "getDeclaredConstructor", GET_DECLARED_CONSTRUCTOR_DESCRIPTOR);
          bytecode.addOpcode(Opcode.ARETURN);
          methodInfo.setCodeAttribute(bytecode.toCodeAttribute());
          return methodInfo;
      }
  
      private static MethodInfo makeSetFieldMethod(ConstPool constPool) {
          MethodInfo methodInfo = new MethodInfo(constPool, "setField", SET_DESCRIPTOR);
          methodInfo.setAccessFlags(AccessFlag.PUBLIC);
  
          Bytecode bytecode = new Bytecode(constPool, 3, 4);
          bytecode.addAload(1);
          bytecode.addAload(2);
          bytecode.addAload(3);
          bytecode.addInvokestatic(SECURITY_ACTIONS_CLASS, "set", SET_DESCRIPTOR);
          bytecode.addOpcode(Opcode.RETURN);
          methodInfo.setCodeAttribute(bytecode.toCodeAttribute());
          return methodInfo;
      }
  
      private static Object newInvoker(CtClass generatedClass) throws Exception {
          ClassPool pool = generatedClass.getClassPool();
          Class<?> invokerClass = pool.toClass(
                  generatedClass,
                  ProxyFactory.class.getClassLoader(),
                  ProxyFactory.class.getProtectionDomain());
          return invokerClass.getDeclaredConstructor().newInstance();
      }
  
      private static String nextInvokerClassName() {
          return ProxyFactory.class.getPackageName()
                  + ".SecurityActionsInvoker"
                  + CLASS_COUNTER.incrementAndGet();
      }
  
      private static void detach(CtClass generatedClass) {
          if (generatedClass != null) {
              generatedClass.detach();
  
