              assertThat(constructor.getParameterTypes()).containsExactly(String.class);
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          } finally {
              detach(generatedClass);
          }
      }
  
      @Test
      void generatedProxyPackageInvokerSetsFieldValue() throws Exception {
          CtClass generatedClass = null;
          try {
              generatedClass = makeInvokerClass();
              Object invoker = newInvoker(generatedClass);
              Method setField = invoker.getClass().getMethod("setField", Field.class, Object.class, Object.class);
              SetTarget target = new SetTarget();
              Field field = SetTarget.class.getField("value");
  
              setField.invoke(invoker, field, target, "updated");
  
              assertThat(target.value).isEqualTo("updated");
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          } finally {
              detach(generatedClass);
          }
      }
  
