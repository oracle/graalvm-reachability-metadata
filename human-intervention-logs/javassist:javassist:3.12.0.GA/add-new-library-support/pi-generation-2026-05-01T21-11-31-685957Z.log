          if (System.getSecurityManager() == null)
              return clazz.getDeclaredMethod(name, types);
          else {
              try {
                  return (Method) AccessController
                          .doPrivileged(new PrivilegedExceptionAction() {
                              public Object run() throws Exception {
                                  return clazz.getDeclaredMethod(name, types);
