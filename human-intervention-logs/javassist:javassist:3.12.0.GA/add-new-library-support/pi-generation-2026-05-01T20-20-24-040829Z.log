              for (int i = 0; i < interfaces.length; i++) {
                  Class interfaze = interfaces[i];
                  if (interfaze != ProxyObject.class) {
                      name = interfaces[i].getName();
                      writeObject(name);
                  }
              }
              writeInt(signature.length);
              write(signature);
          } else {
              writeBoolean(false);
              super.writeClassDescriptor(desc);
          }
      }
  }
