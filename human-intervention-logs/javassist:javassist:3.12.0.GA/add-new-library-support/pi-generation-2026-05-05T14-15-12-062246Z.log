  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.concurrent.atomic.AtomicInteger;
  
  import javassist.ClassPool;
  import javassist.CtClass;
  import javassist.bytecode.AccessFlag;
  import javassist.bytecode.Bytecode;
  import javassist.bytecode.ConstPool;
  import javassist.bytecode.MethodInfo;
  import javassist.bytecode.Opcode;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ClassPoolTest {
      private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();
  
      @Test
      void generatedSamePackageInvokerCallsSyntheticClassLiteralHelper() throws Exception {
          ClassPool pool = new ClassPool(true);
          CtClass generatedClass = pool.makeClass(nextClassPoolPackageClassName());
          addClassLiteralResolverMethod(generatedClass);
  
          try {
              Class<?> loadedClass = pool.toClass(
                      generatedClass,
                      ClassPool.class.getClassLoader(),
                      ClassPool.class.getProtectionDomain());
              Object resolver = loadedClass.getDeclaredConstructor().newInstance();
  
              assertThat(loadedClass.getMethod("resolve", String.class).invoke(resolver, String.class.getName()))
                      .isSameAs(String.class);
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          } finally {
              generatedClass.detach();
          }
      }
  
      @Test
      void toClassDefinesGeneratedClassWithProvidedClassLoader() throws Exception {
          ClassPool pool = new ClassPool(true);
          CtClass generatedClass = pool.makeClass(nextGeneratedClassName());
  
          try {
              Class<?> loadedClass = pool.toClass(
                      generatedClass,
                      new GeneratedClassLoader(),
                      ClassPoolTest.class.getProtectionDomain());
  
              assertThat(loadedClass.getName()).isEqualTo(generatedClass.getName());
              assertThat(loadedClass.getClassLoader()).isInstanceOf(GeneratedClassLoader.class);
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          } finally {
              generatedClass.detach();
          }
      }
  
      private static void addClassLiteralResolverMethod(CtClass generatedClass) throws Exception {
          ConstPool constPool = generatedClass.getClassFile().getConstPool();
          Bytecode bytecode = new Bytecode(constPool, 1, 2);
          bytecode.addAload(1);
          bytecode.addInvokestatic(
                  ClassPool.class.getName(),
                  "class$",
                  "(Ljava/lang/String;)Ljava/lang/Class;");
          bytecode.addOpcode(Opcode.ARETURN);
  
          MethodInfo methodInfo = new MethodInfo(
                  constPool,
                  "resolve",
                  "(Ljava/lang/String;)Ljava/lang/Class;");
          methodInfo.setAccessFlags(AccessFlag.PUBLIC);
          methodInfo.setCodeAttribute(bytecode.toCodeAttribute());
          generatedClass.getClassFile().addMethod(methodInfo);
      }
  
      private static String nextGeneratedClassName() {
          return ClassPoolTest.class.getPackageName()
                  + ".ClassPoolGenerated"
                  + CLASS_COUNTER.incrementAndGet();
      }
  
      private static String nextClassPoolPackageClassName() {
          return ClassPool.class.getPackageName()
                  + ".ClassPoolHelperInvoker"
                  + CLASS_COUNTER.incrementAndGet();
      }
  
      private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {
          if (!hasUnsupportedFeatureError(throwable)) {
              if (throwable instanceof Exception exception) {
                  throw exception;
              }
              if (throwable instanceof Error error) {
                  throw error;
              }
              throw new AssertionError(throwable);
          }
      }
  
      private static boolean hasUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static final class GeneratedClassLoader extends ClassLoader {
          private GeneratedClassLoader() {
              super(ClassPoolTest.class.getClassLoader());
          }
      }
  }
