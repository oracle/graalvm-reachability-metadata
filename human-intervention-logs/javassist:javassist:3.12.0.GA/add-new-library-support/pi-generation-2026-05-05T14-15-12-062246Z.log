                  }
                  else {
                      classResourceName = classname.substring(0, lastIndex)
                              .replaceAll("[\\.]", "/")
                              + classname.substring(lastIndex) + ".class";
                  }
  
                  isLocal = dcl.getResource(classResourceName) != null;
              }
  
