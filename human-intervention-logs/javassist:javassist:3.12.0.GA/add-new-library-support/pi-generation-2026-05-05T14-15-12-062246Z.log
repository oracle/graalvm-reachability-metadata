  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.MalformedURLException;
  import java.net.URL;
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.List;
  import java.util.Map;
  
  import javassist.ClassPool;
  import javassist.CtClass;
  import javassist.scopedpool.ScopedClassPool;
  import javassist.scopedpool.ScopedClassPoolFactory;
  import javassist.scopedpool.ScopedClassPoolFactoryImpl;
  import javassist.scopedpool.ScopedClassPoolRepository;
  import org.junit.jupiter.api.Test;
  
  public class ScopedClassPoolTest {
      @Test
      void getChecksAssociatedClassLoaderForLocalClassResource() throws Exception {
          String className = "example.scopedpool.LocalFixture";
          String resourceName = "example/scopedpool/LocalFixture.class";
          ResourceOnlyClassLoader classLoader = new ResourceOnlyClassLoader(resourceName);
          MinimalRepository repository = new MinimalRepository();
          ScopedClassPool pool = repository.createScopedClassPool(classLoader, new ClassPool(true));
  
          try {
              CtClass loadedClass = pool.get(className);
  
              assertThat(loadedClass.getName()).isEqualTo(className);
              assertThat(classLoader.requestedResourceNames()).contains(resourceName);
          } finally {
              pool.close();
          }
      }
  
      private static URL fixtureResourceUrl() {
          try {
              return new URL("file:/scoped-class-pool/LocalFixture.class");
          } catch (MalformedURLException exception) {
              throw new ExceptionInInitializerError(exception);
          }
      }
  
      private static final class ResourceOnlyClassLoader extends ClassLoader {
          private static final URL FIXTURE_RESOURCE_URL = fixtureResourceUrl();
  
          private final String localClassResourceName;
          private final List<String> requestedResourceNames = new ArrayList<>();
  
          private ResourceOnlyClassLoader(String localClassResourceName) {
              super(null);
              this.localClassResourceName = localClassResourceName;
          }
  
          @Override
          public URL getResource(String name) {
              requestedResourceNames.add(name);
              if (localClassResourceName.equals(name)) {
                  return FIXTURE_RESOURCE_URL;
              }
              return null;
          }
  
          private List<String> requestedResourceNames() {
              return requestedResourceNames;
          }
      }
  
      private static final class MinimalRepository implements ScopedClassPoolRepository {
          private final ScopedClassPoolFactory factory = new ScopedClassPoolFactoryImpl();
  
          @Override
          public void setClassPoolFactory(ScopedClassPoolFactory factory) {
              throw new UnsupportedOperationException("This test repository uses a fixed factory");
          }
  
          @Override
          public ScopedClassPoolFactory getClassPoolFactory() {
              return factory;
          }
  
          @Override
          public boolean isPrune() {
              return false;
          }
  
          @Override
          public void setPrune(boolean prune) {
              throw new UnsupportedOperationException(
                      "This test repository does not support pruning");
          }
  
          @Override
          public ScopedClassPool createScopedClassPool(
                  ClassLoader classLoader,
                  ClassPool sourcePool) {
              return factory.create(classLoader, sourcePool, this);
          }
  
          @Override
          public ClassPool findClassPool(ClassLoader classLoader) {
              return createScopedClassPool(classLoader, new ClassPool(true));
          }
  
          @Override
          public ClassPool registerClassLoader(ClassLoader classLoader) {
              return findClassPool(classLoader);
          }
  
          @Override
          public Map getRegisteredCLs() {
              return Collections.emptyMap();
          }
  
          @Override
          public void clearUnregisteredClassLoaders() {
              // This test repository never retains registered class loaders.
          }
  
          @Override
          public void unregisterClassLoader(ClassLoader classLoader) {
              // This test repository never retains registered class loaders.
          }
      }
  }
