       */
      public MemberValue[] getValue() {
          return values;
      }
  
      /**
       * Sets the elements of the array.
       */
      public void setValue(MemberValue[] elements) {
          values = elements;
          if (elements != null && elements.length > 0)
              type = elements[0];
      }
  
      /**
