              throw new RuntimeException("cannot load the class: " + className, pae.getException());
          }
      }
  
      Object readResolve() throws ObjectStreamException {
          try {
              int n = interfaces.length;
              Class[] infs = new Class[n];
              for (int i = 0; i < n; i++)
