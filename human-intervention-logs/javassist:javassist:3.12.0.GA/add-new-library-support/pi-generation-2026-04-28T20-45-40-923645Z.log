  +                .contains("HTTP/1.0 200 OK\r\n")
  +                .contains("Content-Length: " + CLASSPATH_RESOURCE_CONTENT.length() + "\r\n")
  +                .contains("Content-Type: application/octet-stream\r\n")
  +                .endsWith(CLASSPATH_RESOURCE_CONTENT);
  +    }
  +}
