  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.nio.charset.StandardCharsets;
  
  import javassist.ClassPool;
  import javassist.LoaderClassPath;
  import javassist.tools.rmi.AppletServer;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class AppletServerTest {
      private static final int METHOD_SEARCH_LIMIT = 128;
  
      @Test
      void exportedObjectCanReceiveSerializedRmiInvocationAndReturnSerializedValue() throws Exception {
          try {
              AppletServer server = new AppletServer(0, classPoolForTestRuntime());
              try {
                  int objectId = server.exportObject("echo-service", new EchoService());
                  Object echoResult = null;
  
                  for (int methodId = 0; methodId < METHOD_SEARCH_LIMIT && echoResult == null; methodId++) {
                      Response response = invokeMethod(server, objectId, methodId, "argument");
                      if (response.success && "echo:argument".equals(response.value)) {
                          echoResult = response.value;
                      }
                  }
  
                  assertThat(echoResult).isEqualTo("echo:argument");
              } finally {
                  server.end();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static ClassPool classPoolForTestRuntime() {
          ClassPool classPool = new ClassPool(null);
          classPool.appendClassPath(new LoaderClassPath(AppletServerTest.class.getClassLoader()));
          return classPool;
      }
  
      public static class EchoService {
          public String echo(Object value) {
              return "echo:" + value;
          }
      }
  
      private static Response invokeMethod(AppletServer server, int objectId, int methodId, Object argument)
          throws Exception {
          ByteArrayOutputStream requestBytes = new ByteArrayOutputStream();
          try (ObjectOutputStream request = new ObjectOutputStream(requestBytes)) {
              request.writeInt(objectId);
              request.writeInt(methodId);
              request.writeInt(1);
              request.writeObject(argument);
          }
  
          ByteArrayOutputStream responseBytes = new ByteArrayOutputStream();
          server.doReply(new ByteArrayInputStream(requestBytes.toByteArray()), responseBytes, "POST /rmi HTTP/1.0");
          return readResponse(responseBytes.toByteArray());
      }
  
      private static Response readResponse(byte[] bytes) throws IOException, ClassNotFoundException {
          ByteArrayInputStream input = new ByteArrayInputStream(bytes);
          skipHttpHeader(input);
          try (ObjectInputStream response = new ObjectInputStream(input)) {
              boolean success = response.readBoolean();
              if (success) {
                  return new Response(true, response.readObject());
              }
              return new Response(false, response.readUTF());
          }
      }
  
      private static void skipHttpHeader(ByteArrayInputStream input) throws IOException {
          byte[] expectedHeader = "HTTP/1.0 200 OK\r\n\r\n".getBytes(StandardCharsets.US_ASCII);
          byte[] actualHeader = input.readNBytes(expectedHeader.length);
  
          assertThat(actualHeader).containsExactly(expectedHeader);
      }
  
      private static final class Response {
          private final boolean success;
          private final Object value;
  
          private Response(boolean success, Object value) {
              this.success = success;
              this.value = value;
          }
      }
  }
