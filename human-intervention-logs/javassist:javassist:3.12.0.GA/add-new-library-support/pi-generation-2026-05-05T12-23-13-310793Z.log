      /**
       * Provide a hook so that subclasses can do their own
       * caching of classes.
       *
       * @see #getCached(String)
       * @see #cacheCtClass(String,CtClass,boolean)
       */
      protected CtClass removeCached(String classname) {
          return (CtClass)classes.remove(classname);
