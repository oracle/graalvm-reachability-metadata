[tool-call] delta {"path":"tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/AppletServerTest.java","edits":[{"oldText":"import javassist.tools.rmi.AppletServer;\nimport org.graalvm.internal.tck.NativeImageSupport;\n","newText":"import javassist.tools.rmi.AppletServer;\nimport javassist.tools.rmi.RemoteRef;\nimport org.graalvm.internal.tck.NativeImageSupport;\n"},{"oldText":"    void exportedObjectCanReceiveSerializedRmiInvocationAndReturnSerializedValue() throws Exception {\n        try {\n            appendTestRuntimeToDefaultClassPool();\n            AppletServer server = new AppletServer(0);\n            try {\n                int objectId = server.exportObject(\"echo-service\", new EchoService());\n                Object echoResult = null;\n\n                for (int methodId = 0; methodId < METHOD_SEARCH_LIMIT && echoResult == null; methodId++) {\n                    Response response = invokeMethod(server, objectId, methodId, \"argument\");\n                    if (response.success && \"echo:argument\".equals(response.value)) {\n                        echoResult = response.value;\n                    }\n                }\n\n                assertThat(echoResult).isEqualTo(\"echo:argument\");\n            } finally {\n                server.end();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n","newText":"    void exportedObjectCanReceiveSerializedRmiInvocationAndReturnSerializedValue() throws Exception {\n        try {\n            appendTestRuntimeToDefaultClassPool();\n            AppletServer server = new AppletServer(0);\n            try {\n                int objectId = server.exportObject(\"remote-ref\", new RemoteRef(7));\n                Object equalsResult = null;\n\n                for (int methodId = 0; methodId < METHOD_SEARCH_LIMIT && equalsResult == null; methodId++) {\n                    Response response = invokeMethod(server, objectId, methodId, new RemoteRef(objectId));\n                    if (response.success && Boolean.TRUE.equals(response.value)) {\n                        equalsResult = response.value;\n                    }\n                }\n\n                assertThat(equalsResult).isEqualTo(Boolean.TRUE);\n            } finally {\n                server.end();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n"},{"oldText":"    public static class EchoService {\n        public String echo(Object value) {\n            return \"echo:\" + value;\n        }\n    }\n\n","newText":""}]}
