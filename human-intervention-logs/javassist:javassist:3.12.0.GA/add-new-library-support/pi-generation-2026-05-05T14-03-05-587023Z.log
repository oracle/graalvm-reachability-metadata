  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.Serializable;
  import java.lang.reflect.Method;
  
  import javassist.util.proxy.MethodHandler;
  import javassist.util.proxy.ProxyFactory;
  import javassist.util.proxy.ProxyObject;
  import javassist.util.proxy.ProxyObjectInputStream;
  import javassist.util.proxy.ProxyObjectOutputStream;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ProxyObjectInputStreamTest {
      @Test
      void deserializesProxyDescriptorWithSuperclassInterfaceAndFilterSignature() throws Exception {
          try {
              Greeting proxy = createSerializableProxy();
              byte[] serializedProxy = serializeWithProxyDescriptor(proxy);
  
              Object deserialized;
              try (ProxyObjectInputStream input = new ProxyObjectInputStream(new ByteArrayInputStream(serializedProxy))) {
                  input.setClassLoader(getClass().getClassLoader());
                  deserialized = input.readObject();
              }
  
              assertThat(deserialized).isInstanceOf(Greeting.class);
              assertThat(ProxyFactory.isProxyClass(deserialized.getClass())).isTrue();
              assertThat(((Greeting) deserialized).greet("reader")).isEqualTo("handled reader");
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          }
      }
  
      private static Greeting createSerializableProxy() throws Exception {
          ProxyFactory factory = new ProxyFactory();
          factory.setUseCache(true);
          factory.setUseWriteReplace(false);
          factory.setSuperclass(SerializableBase.class);
          factory.setInterfaces(new Class[] {Greeting.class});
          factory.setFilter(method -> method.getName().equals("greet"));
  
          Greeting proxy = (Greeting) factory.create(new Class[0], new Object[0]);
          ((ProxyObject) proxy).setHandler(new GreetingHandler());
          return proxy;
      }
  
      private static byte[] serializeWithProxyDescriptor(Greeting proxy) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ProxyObjectOutputStream output = new ProxyObjectOutputStream(bytes)) {
              output.writeObject(proxy);
          }
          return bytes.toByteArray();
      }
  
      private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {
          if (!hasUnsupportedFeatureError(throwable)) {
              if (throwable instanceof Exception exception) {
                  throw exception;
              }
              if (throwable instanceof Error error) {
                  throw error;
              }
              throw new AssertionError(throwable);
          }
      }
  
      private static boolean hasUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public interface Greeting extends Serializable {
          String greet(String name);
      }
  
      public static class SerializableBase implements Serializable {
          private static final long serialVersionUID = 1L;
      }
  
      private static final class GreetingHandler implements MethodHandler, Serializable {
          private static final long serialVersionUID = 1L;
  
          @Override
          public Object invoke(Object self, Method thisMethod, Method proceed, Object[] args) {
              return "handled " + args[0];
          }
