ntextClassLoader(originalClassLoader);\n            }\n\n            assertThat(deserialized).isInstanceOf(SerializableService.class);\n            assertThat(ProxyFactory.isProxyClass(deserialized.getClass())).isTrue();\n            assertThat(((SerializableService) deserialized).message(\"reader\")).isEqualTo(\"resolved reader\");\n        } catch (Throwable throwable) {\n            rethrowIfNotUnsupportedFeatureError(throwable);\n        }\n    }\n\n    private static SerializableService createProxyUsingWriteReplaceSerialization() throws Exception {\n        ProxyFactory factory = new ProxyFactory();\n        factory.setUseCache(true);\n        factory.setUseWriteReplace(true);\n        factory.setSuperclass(SerializableService.class);\n        factory.setFilter(method -> method.getName().equals(\"message\"));\n\n        SerializableService proxy = (SerializableService) factory.create(new Class[0], new Object[0]);\n        ((ProxyObject) proxy).setHandler(new SerializableHandler());\n        return proxy;\n    }\n\n    private static byte[] serializeWithStandardObjectStream(SerializableService proxy) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(proxy);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {\n        if (!hasUnsupportedFeatureError(throwable)) {\n            if (throwable instanceof Exception exception) {\n                throw exception;\n            }\n            if (throwable instanceof Error error) {\n                throw error;\n            }\n            throw new AssertionError(throwable);\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class SerializableService implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        public String message(String value) {\n            return \"service \" + value;\n        }\n    }\n\n    private static final class SerializableHandler implements MethodHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Object self, Method thisMethod, Method proceed, Object[] args) {\n            return \"resolved \" + args[0];\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 808, "output": 973, "cacheRead": 14336, "cacheWrite": 0, "totalTokens": 16117, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777989756478, "responseId": "resp_0ab4a72128b75aa90169f9f87cd7d0819ea5c9f6d1dcea7940"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_8mkXOzI4AO8B19dgOINl7PnU|fc_0ab4a72128b75aa90169f9f87fe2e8819e9326edb407bab7b8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4157 bytes to tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/SerializedProxyTest.java"}], "isError": false, "timestamp": 1777989764920}]}
