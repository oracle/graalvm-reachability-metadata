n exception;\n        }\n\n        throw new AssertionError(\"Expected Desc.getClazz to fail\");\n    }\n\n    private static final class EmptyClassLoader extends ClassLoader {\n        private EmptyClassLoader() {\n            super(null);\n        }\n    }\n", "newText": "    private static final class EmptyClassLoader extends ClassLoader {\n        private EmptyClassLoader() {\n            super(null);\n        }\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private String loadedName;\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            loadedName = name;\n            return super.loadClass(name);\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 31246, "output": 1173, "cacheRead": 6144, "cacheWrite": 0, "totalTokens": 38563, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777668694083, "responseId": "resp_0fe604eb53e3f3010169f512570a6c81969520540e91af735b"}}
