              result[num] = getClassObject(cname.replace('/', '.'));
          }
          catch (ClassNotFoundException e) {
              // "new RuntimeException(e)" is not available in JDK 1.3.
              throw new RuntimeException(e.getMessage());
          }
  
          return result;
