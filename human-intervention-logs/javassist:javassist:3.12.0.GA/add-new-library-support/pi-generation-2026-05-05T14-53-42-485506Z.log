  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.io.IOException;
  import java.io.InputStream;
  
  import javassist.util.proxy.FactoryHelper;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class FactoryHelperTest {
      @Test
      void isolatedClassLoaderInitializesFactoryHelperStaticBlock() throws Exception {
          try {
              IsolatedJavassistClassLoader loader = new IsolatedJavassistClassLoader(
                      Thread.currentThread().getContextClassLoader());
  
              Class<?> factoryHelper = Class.forName("javassist.util.proxy.FactoryHelper", true, loader);
  
              assertThat(factoryHelper.getName()).isEqualTo("javassist.util.proxy.FactoryHelper");
              assertThat(factoryHelper.getClassLoader()).isSameAs(loader);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void typeIndexFindsPrimitiveMetadata() {
          int intIndex = FactoryHelper.typeIndex(Integer.TYPE);
          int doubleIndex = FactoryHelper.typeIndex(Double.TYPE);
  
          assertThat(FactoryHelper.wrapperTypes[intIndex]).isEqualTo(Integer.class.getName());
          assertThat(FactoryHelper.wrapperDesc[intIndex]).isEqualTo("(I)V");
          assertThat(FactoryHelper.unwarpMethods[intIndex]).isEqualTo("intValue");
          assertThat(FactoryHelper.unwrapDesc[intIndex]).isEqualTo("()I");
          assertThat(FactoryHelper.dataSize[intIndex]).isEqualTo(1);
          assertThat(FactoryHelper.wrapperTypes[doubleIndex]).isEqualTo(Double.class.getName());
          assertThat(FactoryHelper.dataSize[doubleIndex]).isEqualTo(2);
      }
  
      @Test
      void typeIndexRejectsNonPrimitiveType() {
          assertThatThrownBy(() -> FactoryHelper.typeIndex(String.class))
                  .isInstanceOf(RuntimeException.class)
                  .hasMessage("bad type:java.lang.String");
      }
  
      private static final class IsolatedJavassistClassLoader extends ClassLoader {
          private static final String JAVASSIST_PACKAGE = "javassist.";
          private static final String CLASS_FILE_SUFFIX = ".class";
  
          private IsolatedJavassistClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
