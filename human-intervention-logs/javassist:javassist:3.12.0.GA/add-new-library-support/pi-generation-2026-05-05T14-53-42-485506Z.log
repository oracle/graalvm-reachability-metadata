[tool-call] delta {"path":"tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/FactoryHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport javassist.util.proxy.FactoryHelper;\nimport org.junit.jupiter.api.Test;\n\npublic class FactoryHelperTest {\n    @Test\n    void typeIndexFindsPrimitiveMetadata() {\n        int intIndex = FactoryHelper.typeIndex(Integer.TYPE);\n        int doubleIndex = FactoryHelper.typeIndex(Double.TYPE);\n\n        assertThat(FactoryHelper.wrapperTypes[intIndex]).isEqualTo(Integer.class.getName());\n        assertThat(FactoryHelper.wrapperDesc[intIndex]).isEqualTo(\"(I)V\");\n        assertThat(FactoryHelper.unwarpMethods[intIndex]).isEqualTo(\"intValue\");\n        assertThat(FactoryHelper.unwrapDesc[intIndex]).isEqualTo(\"()I\");\n        assertThat(FactoryHelper.dataSize[intIndex]).isEqualTo(1);\n        assertThat(FactoryHelper.wrapperTypes[doubleIndex]).isEqualTo(Double.class.getName());\n        assertThat(FactoryHelper.dataSize[doubleIndex]).isEqualTo(2);\n    }\n\n    @Test\n    void typeIndexRejectsNonPrimitiveType() {\n        assertThatThrownBy(() -> FactoryHelper.typeIndex(String.class))\n                .isInstanceOf(RuntimeException.class)\n                .hasMessage(\"bad type:java.lang.String\");\n    }\n}\n"}
