assist/3.12.0.GA/src/test/java/javassist/javassist/ProxyFactoryTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.Serializable;\nimport java.lang.reflect.Method;\n\nimport javassist.util.proxy.MethodHandler;\nimport javassist.util.proxy.ProxyFactory;\nimport javassist.util.proxy.ProxyObject;\nimport javassist.util.proxy.ProxyObjectOutputStream;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class ProxyFactoryTest {\n    @Test\n    void createInstantiatesProxyWithMatchingConstructorAndMethodHandler() throws Exception {\n        try {\n            ProxyFactory factory = new ProxyFactory();\n            factory.setSuperclass(GreetingService.class);\n            factory.setFilter(method -> method.getName().equals(\"message\"));\n\n            MethodHandler handler = (self, thisMethod, proceed, args) -> \"handled \" + args[0];\n            GreetingService proxy = (GreetingService) factory.create(\n                    new Class[] {String.class},\n                    new Object[] {\"initial\"},\n                    handler);\n\n            assertThat(ProxyFactory.isProxyClass(proxy.getClass())).isTrue();\n            assertThat(proxy.prefix()).isEqualTo(\"initial\");\n            assertThat(proxy.message(\"call\")).isEqualTo(\"handled call\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void proxyObjectOutputStreamSerializesProxyClassDescriptorWithFilterSignature() throws Exception {\n        try {\n            ProxyFactory factory = new ProxyFactory();\n            factory.setUseWriteReplace(false);\n            factory.setSuperclass(GreetingService.class);\n            factory.setFilter(method -> method.getName().equals(\"message\"));\n\n            GreetingService proxy = (GreetingService) factory.create(\n                    new Class[] {String.class},\n                    new Object[] {\"serializable\"});\n            ((ProxyObject) proxy).setHandler(new SerializableMethodHandler());\n\n            ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n            try (ProxyObjectOutputStream output = new ProxyObjectOutputStream(bytes)) {\n                output.writeObject(proxy);\n            }\n\n            assertThat(bytes.toByteArray()).isNotEmpty();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public static class GreetingService implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String prefix;\n\n        public GreetingService(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String prefix() {\n            return prefix;\n        }\n\n        public String message(String value) {\n            return prefix + \" \" + value;\n        }\n    }\n\n    private static final class SerializableMethodHandler implements MethodHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Object self, Method thisMethod, Method proceed, Object[] args) {\n            return args[0];\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2025, "output": 1197, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 27798, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777981037760, "responseId": "resp_099e8ca