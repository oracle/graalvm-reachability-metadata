[tool-call] delta {"path":"tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/WebserverTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Arrays;\n\nimport javassist.tools.web.Webserver;\nimport org.junit.jupiter.api.Test;\n\npublic class WebserverTest {\n    private static final byte[] HEADER_SEPARATOR = \"\\r\\n\\r\\n\".getBytes(StandardCharsets.US_ASCII);\n    private static final byte[] CLASS_FILE_MAGIC = {(byte) 0xca, (byte) 0xfe, (byte) 0xba, (byte) 0xbe};\n\n    @Test\n    void doReplyServesClassFileFromClasspathResourceWhenFileIsNotReadable() throws Exception {\n        Webserver server = new Webserver(0);\n        try {\n            ByteArrayOutputStream response = new ByteArrayOutputStream();\n\n            server.doReply(\n                InputStream.nullInputStream(),\n                response,\n                \"GET /javassist/tools/web/Webserver.class HTTP/1.0\");\n\n            byte[] responseBytes = response.toByteArray();\n            int headerEnd = findHeaderEnd(responseBytes);\n            byte[] body = Arrays.copyOfRange(responseBytes, headerEnd + HEADER_SEPARATOR.length, responseBytes.length);\n            String header = new String(responseBytes, 0, headerEnd, StandardCharsets.US_ASCII);\n\n            assertThat(header).contains(\"HTTP/1.0 200 OK\");\n            assertThat(header).contains(\"Content-Type: application/octet-stream\");\n            assertThat(header).contains(\"Content-Length: \" + body.length);\n            assertThat(body).startsWith(CLASS_FILE_MAGIC);\n        } finally {\n            server.end();\n        }\n    }\n\n    private static int findHeaderEnd(byte[] responseBytes) {\n        for (int offset = 0; offset <= responseBytes.length - HEADER_SEPARATOR.length; offset++) {\n            if (containsHeaderSeparatorAt(responseBytes, offset)) {\n                return offset;\n            }\n        }\n\n        throw new AssertionError(\"HTTP response header terminator was not found\");\n    }\n\n    private static boolean containsHeaderSeparatorAt(byte[] responseBytes, int offset) {\n        for (int index = 0; index < HEADER_SEPARATOR.length; index++) {\n            if (responseBytes[offset + index] != HEADER_SEPARATOR[index]) {\n                return false;\n            }\n        }\n\n        return true;\n    }\n}\n"}
