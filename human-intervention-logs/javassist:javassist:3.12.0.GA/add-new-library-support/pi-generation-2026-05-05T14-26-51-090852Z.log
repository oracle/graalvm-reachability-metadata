      public void addTranslator(ClassPool cp, Translator t)
          throws NotFoundException, CannotCompileException
      {
          classPool = cp;
          translator = t;
          t.start(classPool);
      }
  
      /**
       * Closes the socket.
       */
      public void end() throws IOException {
          socket.close();
      }
  
      /**
