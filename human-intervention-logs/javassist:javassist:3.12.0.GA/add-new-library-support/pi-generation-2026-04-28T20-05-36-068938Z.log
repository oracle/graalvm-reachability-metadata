  import java.io.BufferedInputStream;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.nio.charset.StandardCharsets;
  
  import javassist.ClassClassPath;
  import javassist.ClassPool;
  import javassist.tools.rmi.AppletServer;
  import javassist.tools.rmi.RemoteRef;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AppletServerTest {
      @Test
      void exportsObjectAndProcessesSerializedRmiCall() throws Exception {
          AppletServer server = new AppletServer(0, createClassPool());
          try {
              int objectId = server.exportObject("same-object-service", new AppletServerRmiFixture());
  
              Object responseValue = callSameObjectMethod(server, objectId);
  
              assertThat(responseValue).isEqualTo(Boolean.TRUE);
          } finally {
              server.end();
          }
      }
  
      private static ClassPool createClassPool() {
          ClassPool classPool = new ClassPool(true);
          classPool.insertClassPath(new ClassClassPath(AppletServer.class));
          classPool.insertClassPath(new ClassClassPath(AppletServerRmiFixture.class));
          return classPool;
      }
  
      private static Object callSameObjectMethod(AppletServer server, int objectId) throws Exception {
          for (int methodId = 0; methodId < 128; methodId++) {
              RmiResponse response = invokeRmi(server, objectId, methodId);
              if (response.success() && Boolean.TRUE.equals(response.value())) {
                  return response.value();
              }
          }
  
          throw new AssertionError("Same-object method was not reachable through AppletServer RMI dispatch");
      }
  
      private static RmiResponse invokeRmi(AppletServer server, int objectId, int methodId) throws Exception {
          ByteArrayOutputStream requestBytes = new ByteArrayOutputStream();
          try (ObjectOutputStream request = new ObjectOutputStream(requestBytes)) {
              request.writeInt(objectId);
              request.writeInt(methodId);
              request.writeInt(1);
              request.writeObject(new RemoteRef(objectId));
          }
  
          ByteArrayOutputStream responseBytes = new ByteArrayOutputStream();
          server.doReply(
                  new ByteArrayInputStream(requestBytes.toByteArray()),
                  responseBytes,
                  "POST /rmi HTTP/1.0");
  
          return readRmiResponse(responseBytes.toByteArray());
      }
  
      private static RmiResponse readRmiResponse(byte[] responseBytes) throws IOException, ClassNotFoundException {
          InputStream response = new BufferedInputStream(new ByteArrayInputStream(responseBytes));
          skipHttpHeader(response);
          try (ObjectInputStream objectResponse = new ObjectInputStream(response)) {
              boolean success = objectResponse.readBoolean();
              if (success) {
                  return new RmiResponse(true, objectResponse.readObject());
              }
  
              return new RmiResponse(false, objectResponse.readUTF());
          }
      }
  
      private static void skipHttpHeader(InputStream input) throws IOException {
          byte[] marker = "\r\n\r\n".getBytes(StandardCharsets.US_ASCII);
          int matched = 0;
          int current;
          while ((current = input.read()) >= 0) {
              if (current == marker[matched]) {
                  matched++;
                  if (matched == marker.length) {
                      return;
                  }
              } else {
                  matched = current == marker[0] ? 1 : 0;
              }
          }
  
          throw new IOException("HTTP response header did not terminate");
      }
  
      private static final class RmiResponse {
          private final boolean success;
          private final Object value;
  
          private RmiResponse(boolean success, Object value) {
              this.success = success;
              this.value = value;
          }
  
          private boolean success() {
              return success;
          }
  
          private Object value() {
              return value;
          }
      }
  }
