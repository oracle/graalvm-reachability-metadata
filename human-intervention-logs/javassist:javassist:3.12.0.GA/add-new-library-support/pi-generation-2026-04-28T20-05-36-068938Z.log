ectId = server.exportObject(\"echo-service\", new EchoService());\n+\n+            Object responseValue = callEchoMethod(server, objectId);\n+\n+            assertThat(responseValue).isEqualTo(RESPONSE_VALUE);\n+        } finally {\n+            server.end();\n+        }\n+    }\n+\n+    private static Object callEchoMethod(AppletServer server, int objectId) throws Exception {\n+        for (int methodId = 0; methodId < 128; methodId++) {\n+            RmiResponse response = invokeRmi(server, objectId, methodId, REQUEST_VALUE);\n+            if (response.success() && RESPONSE_VALUE.equals(response.value())) {\n+                return response.value();\n+            }\n+        }\n+\n+        throw new AssertionError(\"Echo method was not reachable through AppletServer RMI dispatch\");\n+    }\n+\n+    private static RmiResponse invokeRmi(AppletServer server, int objectId, int methodId, String argument)\n+            throws Exception {\n+        ByteArrayOutputStream requestBytes = new ByteArrayOutputStream();\n+        try (ObjectOutputStream request = new ObjectOutputStream(requestBytes)) {\n+            request.writeInt(objectId);\n+            request.writeInt(methodId);\n+            request.writeInt(1);\n+            request.writeObject(argument);\n+        }\n+\n+        ByteArrayOutputStream responseBytes = new ByteArrayOutputStream();\n+        server.doReply(\n+                new ByteArrayInputStream(requestBytes.toByteArray()),\n+                responseBytes,\n+                \"POST /rmi HTTP/1.0\");\n+\n+        return readRmiResponse(responseBytes.toByteArray());\n+    }\n+\n+    private static RmiResponse readRmiResponse(byte[] responseBytes) throws IOException, ClassNotFoundException {\n+        InputStream response = new BufferedInputStream(new ByteArrayInputStream(responseBytes));\n+        skipHttpHeader(response);\n+        try (ObjectInputStream objectResponse = new ObjectInputStream(response)) {\n+            boolean success = objectResponse.r