gMemberValue(value, constPool));\n        annotation.addMemberValue(\"count\", new IntegerMemberValue(constPool, count));\n        return annotation;\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface FixtureAnnotation {\n        String value();\n\n        int count();\n    }\n\n    @FixtureAnnotation(value = \"sample\", count = 17)\n    private static class AnnotatedFixture {\n    }\n}\n"}
