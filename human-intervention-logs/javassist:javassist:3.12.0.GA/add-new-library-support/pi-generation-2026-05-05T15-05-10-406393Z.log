[tool-call] delta {"path":"tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/RuntimeSupportInnerDefaultMethodHandlerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\n\nimport javassist.util.proxy.MethodHandler;\nimport javassist.util.proxy.RuntimeSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class RuntimeSupportInnerDefaultMethodHandlerTest {\n    @Test\n    void defaultMethodHandlerInvokesProceedMethodOnSelf() throws Throwable {\n        SampleTarget target = new SampleTarget(\"prefix\");\n        Method proceed = SampleTarget.class.getMethod(\"message\", String.class);\n        MethodHandler handler = RuntimeSupport.default_interceptor;\n\n        Object result = handler.invoke(target, proceed, proceed, new Object[] {\"value\"});\n\n        assertThat(result).isEqualTo(\"prefix:value\");\n    }\n\n    public static class SampleTarget {\n        private final String prefix;\n\n        public SampleTarget(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String message(String value) {\n            return prefix + \":\" + value;\n        }\n    }\n}\n"}
