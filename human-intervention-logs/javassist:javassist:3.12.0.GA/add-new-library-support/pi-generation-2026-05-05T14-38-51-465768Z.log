  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.catchThrowable;
  
  import java.io.IOException;
  
  import com.sun.jdi.connect.IllegalConnectorArgumentsException;
  import javassist.util.HotSwapper;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class HotSwapperTest {
      @Test
      void constructorInitializesTriggerClassBeforeDebuggerAttach() {
          Throwable thrown = catchThrowable(() -> new HotSwapper("0"));
  
          if (thrown instanceof Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } else {
              assertThat(thrown)
                  .as("port 0 is not a listening JDWP target")
                  .isInstanceOfAny(IOException.class, IllegalConnectorArgumentsException.class);
          }
      }
  }
