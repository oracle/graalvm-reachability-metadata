ents": {"path": "tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/HotSwapperTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.catchThrowable;\n\nimport java.io.IOException;\n\nimport com.sun.jdi.connect.IllegalConnectorArgumentsException;\nimport javassist.util.HotSwapper;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class HotSwapperTest {\n    @Test\n    void constructorInitializesTriggerClassBeforeDebuggerAttach() {\n        Throwable thrown = catchThrowable(() -> new HotSwapper(\"0\"));\n\n        if (thrown instanceof Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } else {\n            assertThat(thrown)\n                .as(\"port 0 is not a listening JDWP target\")\n                .isInstanceOfAny(IOException.class, IllegalConnectorArgumentsException.class);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 615, "output": 1357, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 24500, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777991894306, "responseId": "resp_08d38e632ddd66d30169fa00d6c9fc81a289d3e09074699d26"}}
