ss<?> loaded = loader.loadClass(String.class.getName());\n\n        assertThat(loaded).isSameAs(String.class);\n    }\n\n    @Test\n    void attemptsOwnClassResourceLookupBeforeParentFallback() {\n        Loader loader = new Loader(LoaderTest.class.getClassLoader(), null);\n\n        assertThatThrownBy(() -> loader.loadClass(\"javassist_javassist.loader.MissingClass\"))\n                .isInstanceOf(ClassNotFoundException.class);\n    }\n\n    public static class InvokedMain {\n        private static int invocationCount;\n        private static String[] arguments = new String[0];\n\n        public static void main(String[] args) {\n            invocationCount++;\n            arguments = args.clone();\n        }\n\n        static void reset() {\n            invocationCount = 0;\n            arguments = new String[0];\n        }\n\n        static int invocationCount() {\n            return invocationCount;\n        }\n\n        static String[] arguments() {\n            return arguments.clone();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3044, "output": 1332, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 20248, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777404819350, "responseId": "resp_0edfe0cd0cfc85a20169f10b93cd1c81a09cccf00ade3b2675"}}
