              this.value = value;
          }
  
          public String describe() {
              return prefix + ":" + value;
          }
  
          public int _m_7_increment(int delta) {
              value += delta;
              return value;
          }
  
          public static String _m_0_join(String left, String right) {
              return left + ":" + right + ":" + sharedValue;
          }
      }
