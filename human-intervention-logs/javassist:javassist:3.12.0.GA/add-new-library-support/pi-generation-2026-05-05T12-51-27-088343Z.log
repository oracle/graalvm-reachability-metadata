  package javassist.javassist;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import javassist.ClassPool;
  import javassist.CtClass;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ClassPoolTest {
      private static final String CLASS_POOL_HELPER_CLASS_NAME = "javassist.ClassPool$1";
      private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();
  
      @Test
      void isolatedClassLoadingInitializesClassPoolStaticDefineClassMethods() throws Exception {
          try {
              IsolatedClassPoolLoader isolatedLoader = new IsolatedClassPoolLoader();
              Class<?> isolatedClassPool = Class.forName(ClassPool.class.getName(), true, isolatedLoader);
  
              assertThat(isolatedClassPool.getName()).isEqualTo(ClassPool.class.getName());
              assertThat(isolatedClassPool.getClassLoader()).isSameAs(isolatedLoader);
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          }
      }
  
      @Test
      void toClassDefinesGeneratedClassWithProvidedClassLoader() throws Exception {
          ClassPool pool = new ClassPool(true);
          CtClass generatedClass = pool.makeClass(nextGeneratedClassName());
  
          try {
              Class<?> loadedClass = pool.toClass(
                      generatedClass,
                      new GeneratedClassLoader(),
                      ClassPoolTest.class.getProtectionDomain());
  
              assertThat(loadedClass.getName()).isEqualTo(generatedClass.getName());
              assertThat(loadedClass.getClassLoader()).isInstanceOf(GeneratedClassLoader.class);
          } catch (Throwable throwable) {
              rethrowIfNotUnsupportedFeatureError(throwable);
          } finally {
              generatedClass.detach();
          }
      }
  
      private static String nextGeneratedClassName() {
          return ClassPoolTest.class.getPackageName()
                  + ".ClassPoolGenerated"
                  + CLASS_COUNTER.incrementAndGet();
      }
  
      private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {
          if (!hasUnsupportedFeatureError(throwable)) {
              if (throwable instanceof Exception exception) {
                  throw exception;
              }
              if (throwable instanceof Error error) {
                  throw error;
              }
              throw new AssertionError(throwable);
          }
      }
  
      private static boolean hasUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static final class IsolatedClassPoolLoader extends ClassLoader {
          private IsolatedClassPoolLoader() {
              super(ClassPoolTest.class.getClassLoader());
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null && shouldLoadIsolated(name)) {
                      loadedClass = findClass(name);
                  } else if (loadedClass == null) {
                      loadedClass = super.loadClass(name, false);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          @Override
          protected Class<?> findClass(String name) throws ClassNotFoundException {
              if (!shouldLoadIsolated(name)) {
                  throw new ClassNotFoundException(name);
              }
              byte[] bytes = readClassBytes(name);
              return defineClass(name, bytes, 0, bytes.length);
          }
  
          private boolean shouldLoadIsolated(String name) {
              return ClassPool.class.getName().equals(name) || CLASS_POOL_HELPER_CLASS_NAME.equals(name);
          }
  
          private byte[] readClassBytes(String name) throws ClassNotFoundException {
              String resourceName = name.replace('.', '/') + ".class";
              try (InputStream input = getParent().getResourceAsStream(resourceName)) {
                  if (input == null) {
                      throw new ClassNotFoundException(name);
                  }
                  return input.readAllBytes();
              } catch (IOException exception) {
