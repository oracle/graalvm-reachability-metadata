er loader = new Loader(null, null);\n\n        Class<?> loadedClass = loader.loadClass(String.class.getName());\n\n        assertThat(loadedClass).isSameAs(String.class);\n    }\n\n    @Test\n    void readsClassBytesAsResourceBeforeDefiningNonDelegatedClass() throws Exception {\n        Loader loader = new Loader(getClass().getClassLoader(), null);\n\n        try {\n            Class<?> loadedClass = loader.loadClass(\"javassist.CtClass\");\n\n            assertThat(loadedClass.getName()).isEqualTo(\"javassist.CtClass\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public static class MainFixture {\n        private static String[] receivedArguments = new String[0];\n        private static int invocationCount;\n\n        public static void main(String[] args) {\n            receivedArguments = Arrays.copyOf(args, args.length);\n            invocationCount++;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777985386702}]}
