You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javassist.javassist;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport javassist.ClassPool;\nimport javassist.CtClass;\nimport javassist.CtNewMethod;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class ClassPoolTest {\n    private static final AtomicInteger CLASS_COUNTER = new AtomicInteger();\n\n    @Test\n    void toClassDefinesGeneratedClassWithProvidedClassLoader() throws Exception {\n        ClassPool pool = new ClassPool(false);\n        CtClass generatedClass = pool.makeClass(nextGeneratedClassName());\n        generatedClass.addMethod(CtNewMethod.make(\"\"\"\n                public String message() {\n                    return \"defined by ClassPool\";\n                }\n                \"\"\", generatedClass));\n\n        try {\n            Class<?> loadedClass = pool.toClass(\n                    generatedClass,\n                    new GeneratedClassLoader(),\n                    ClassPoolTest.class.getProtectionDomain());\n            Object instance = loadedClass.getDeclaredConstructor().newInstance();\n\n            assertThat(loadedClass.getClassLoader()).isInstanceOf(GeneratedClassLoader.class);\n            assertThat(loadedClass.getMethod(\"message\").invoke(instance)).isEqualTo(\"defined by ClassPool\");\n        } catch (Throwable throwable) {\n            rethrowIfNotUnsupportedFeatureError(throwable);\n        } finally {\n            generatedClass.detach();\n        }\n    }\n\n    private static String nextGeneratedClassName() {\n        return ClassPoolTest.class.getPackageName() + \".ClassPoolGenerated\" + CLASS_COUNTER.incrementAndGet();\n    }\n\n    private static void rethrowIfNotUnsupportedFeatureError(Throwable throwable) throws Exception {\n        if (!hasUnsupportedFeatureError(throwable)) {\n            if (throwable instanceof Exception exception) {\n                throw exception;\n            }\n            if (throwable instanceof Error error) {\n                throw error;\n            }\n            throw new AssertionError(throwable);\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static final class GeneratedClassLoader extends ClassLoader {\n        private GeneratedClassLoader() {\n            super(ClassPoolTest.class.getClassLoader());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 10821, "output": 1203, "cacheRead": 7168, "cacheWrite": 0, "totalTokens": 19192, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777985406871, "responseId": "resp_053294151caacb700169f9e77f3c30819099fa6e20cc821f6c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Dsb2irCgGGODVluqcZOILhAd|fc_053294151caacb700169f9e787d9548190b35aa5dbda54b74d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2874 bytes to tests/src/javassist/javassist/3.12.0.GA/src/test/java/javassist/javassist/ClassPoolTest.java"}], "isError": false, "timestamp": 1777985422006}]}
