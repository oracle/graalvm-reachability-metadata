py).containsEntry(Status.WAITING, Signal.YELLOW);\\n        assertThat(copy.inverse()).containsEntry(Signal.YELLOW, Status.WAITING);\\n    }\\n\\n    @SuppressWarnings(\\\"unchecked\\\")\\n    private static <T> T roundTrip(T value) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\n            output.writeObject(value);\\n        }\\n\\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\\n            return (T) input.readObject();\\n        }\\n    }\\n\\n    private enum Status {\\n        READY,\\n        BLOCKED,\\n        WAITING\\n    }\\n\\n    private enum Signal {\\n        GREEN,\\n        RED,\\n        YELLOW\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777757234006}}\n3144:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0bed9c6fb5b7bb6d0169f66c282320819eb4cca9692dfd345b\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp9mwxx8BtlTDIfs78GiDKknkQtq8JqeAOOW8h3MKXb17lohEiCqFbdTrWwUeMiG2ePqATRTtfqRTRsLKNsgT8EmrkiWNjey_SCN70l13XT2eUEY--A2qxcGHUWshJWSejDE02GCC9HA3po0Ua2nhK7UrNbubTAFVYKEdoZe6r62LUGI_2NfYuAYlYLaEuNq0edpa3NbuBkUJdXTggSZEvm8eeqpopem4ryVFEfy0NTodebESFm9l3_0GDMXT7DL6nENmjwFowDeQsOFZXw5-idu1PAGtz6mmahw0lU78x3keX8mzhrY__iWwwAerv-SuTWP-5OKaYOVJJfVzpA-qTm5SGtapqw0TF2MnAARC9NoCgHJbXCsBVD9LnvVjxedU96CnmSJpRV1bljzX0d1voeefIRKRfN7WgjlT_a6QaX7J59iqDtmnovVdcfo4dy7wtgLnZfyL-amYgZoujQ4Zw6yCsHgzHpYFMHT0Dw5hLLQxcesri-7SQZqJkG7Q_NfiZWh9GNM2xA6ljViw_HITPrlF4w7iqurTfLw74me8ztmD8DzYynBfIuvnv-8SzB-MeQWJ4heFpFP7JnNYPfcaMM2qFBd7HRVmT1VMASzlXoH6VoVYT6Ohxgzz7j8lrDvUC9oR6REg_8itoFH5-zhlunOJ-kb0t5UliBefAd0gKr8btK1ME9UGO1oZ1y0l4T0RIGOlVHZkYIu4w8B0gWBAD-hfGdfeh63HX3KKDWWFSalYv4L3E6tfB223rfMUla