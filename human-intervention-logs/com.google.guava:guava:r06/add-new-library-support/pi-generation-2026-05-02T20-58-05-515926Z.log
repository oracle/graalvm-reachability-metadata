[tool-call] delta {"path":"tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/PlatformTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.collect.ObjectArrays;\nimport org.junit.jupiter.api.Test;\n\npublic class PlatformTest {\n    @Test\n    void createsArrayFromComponentClassThroughObjectArrays() {\n        String[] array = ObjectArrays.newArray(String.class, 3);\n\n        assertThat(array).hasSize(3);\n        assertThat(array.getClass().getComponentType()).isEqualTo(String.class);\n        assertThat(array).containsExactly(null, null, null);\n    }\n\n    @Test\n    void createsArrayFromReferenceArrayThroughObjectArrays() {\n        Number[] reference = new Integer[] {1, 2};\n\n        Number[] array = ObjectArrays.newArray(reference, 4);\n\n        assertThat(array).hasSize(4);\n        assertThat(array).isInstanceOf(Integer[].class);\n        assertThat(array.getClass().getComponentType()).isEqualTo(Integer.class);\n        assertThat(array).containsExactly(null, null, null, null);\n    }\n}\n"}
