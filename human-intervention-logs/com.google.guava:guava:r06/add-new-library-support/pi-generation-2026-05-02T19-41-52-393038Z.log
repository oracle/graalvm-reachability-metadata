\n                    ? System.getSecurityManager()\n                    : null;\n            try {\n                Object queue = queueConstructor.newInstance();\n                completed = true;\n\n                assertThat(queue).isNotNull();\n                if (previousSecurityManager != null) {\n                    assertThat(securityManager.wasGetClassLoaderDenied()).isTrue();\n                }\n            } catch (Throwable throwable) {\n                rethrowIfNotNativeImageUnsupportedFeatureError(throwable);\n            } finally {\n                if (previousSecurityManager != null) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n            }\n        }\n\n        assertThat(completed).isTrue();\n    }\n\n    private static URL findGuavaRuntimeLocation() throws Exception {\n        String classResource = FINALIZABLE_REFERENCE_QUEUE_CLASS_NAME.replace('.', '/') + \".class\";\n        URL resource = ClassLoader.getSystemResource(classResource);\n        assertThat(resource).as(\"Guava runtime class resource\").isNotNull();\n\n        String resourceUrl = resource.toExternalForm();\n        if (resourceUrl.startsWith(\"jar:\")) {\n            int separator = resourceUrl.indexOf(\"!/\");\n            assertThat(separator).isPositive();\n            return URI.create(resourceUrl.substring(\"jar:\".length(), separator)).toURL();\n        }\n\n        assertThat(resourceUrl).endsWith(classResource);\n        return URI.create(resourceUrl.substring(0, resourceUrl.length() - classResource.length())).toURL();\n    }\n\n    private static void rethrowIfNotNativeImageUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            current = current.getCause();\n        }\n\n        if (throwable instanceof RuntimeException runtimeException) {\n            throw runtimeException;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n        throw new AssertionError(throwable);\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n        try {\n            SecurityManager previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(securityManager);\n            if (System.getSecurityManager() == securityManager) {\n                return true;\n            }\n            System.setSecurityManager(previousSecurityManager);\n            return false;\n        } catch (UnsupportedOperationException unsupportedOperationException) {\n            return false;\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class DenyGetClassLoaderSecurityManager extends SecurityManager {\n        private boolean getClassLoaderDenied;\n\n        @Override\n        public void checkPermission(Permission permission) {\n            if (permission instanceof RuntimePermission && \"getClassLoader\".equals(permission.getName())) {\n                getClassLoaderDenied = true;\n                throw new SecurityException(\"system class loader access denied for coverage test\");\n            }\n        }\n\n        private boolean wasGetClassLoaderDenied() {\n            return getClassLoaderDenied;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 671, "output": 2617, "cacheRead": 43008, "cacheWrite": 0, "totalTokens": 46296, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777750823216, "responseId": "resp_04012b1346cd859e0169f65327a88881949ca2483aee46bfc2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tOUyKh3dBvki81OiYeaVIbGd|fc_04012b1346cd859e0