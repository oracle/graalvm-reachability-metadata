  package com_google_guava.guava;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.junit.jupiter.api.Assertions.fail;
  
  import com.google.common.base.FinalizableReferenceQueue;
  import com.google.common.base.FinalizableWeakReference;
  import java.util.concurrent.CountDownLatch;
  import java.util.concurrent.TimeUnit;
  import org.junit.jupiter.api.Test;
  
  public class FinalizerTest {
      @Test
      void invokesFinalizeReferentForEnqueuedReference() throws Exception {
          InheritableThreadLocal<String> parentValue = new InheritableThreadLocal<String>();
          parentValue.set("parent-value");
  
          try {
              FinalizableReferenceQueue queue = new FinalizableReferenceQueue();
              CountDownLatch cleanupFinished = new CountDownLatch(1);
              Object referent = new Object();
              RecordingFinalizableWeakReference reference = new RecordingFinalizableWeakReference(
                      referent, queue, cleanupFinished);
  
              assertThat(reference.get()).isSameAs(referent);
              assertThat(reference.enqueue()).isTrue();
  
              awaitFinalizer(queue, cleanupFinished);
          } finally {
              parentValue.remove();
          }
      }
  
      private static void awaitFinalizer(
              FinalizableReferenceQueue queue,
              CountDownLatch cleanupFinished) throws InterruptedException {
          long deadlineNanos = System.nanoTime() + TimeUnit.SECONDS.toNanos(10);
          while (!cleanupFinished.await(100, TimeUnit.MILLISECONDS)) {
              if (System.nanoTime() >= deadlineNanos) {
                  fail("Timed out waiting for FinalizableReference.finalizeReferent() to run.");
              }
  
              new RecordingFinalizableWeakReference(new Object(), queue, new CountDownLatch(0));
          }
      }
  
      private static final class RecordingFinalizableWeakReference
              extends FinalizableWeakReference<Object> {
          private final CountDownLatch cleanupFinished;
  
          private RecordingFinalizableWeakReference(
                  Object referent, FinalizableReferenceQueue queue, CountDownLatch cleanupFinished) {
              super(referent, queue);
              this.cleanupFinished = cleanupFinished;
          }
  
          @Override
          public void finalizeReferent() {
              cleanupFinished.countDown();
          }
