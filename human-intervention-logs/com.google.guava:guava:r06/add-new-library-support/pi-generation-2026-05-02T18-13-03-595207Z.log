[tool-call] delta {"path":"tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/LinkedHashMultimapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.collect.LinkedHashMultimap;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.AbstractMap;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\npublic class LinkedHashMultimapTest {\n    @Test\n    void serializesAndDeserializesEntryIterationOrder() throws Exception {\n        LinkedHashMultimap<String, String> multimap = LinkedHashMultimap.create();\n        multimap.put(\"letters\", \"alpha\");\n        multimap.put(\"numbers\", \"one\");\n        multimap.put(\"letters\", \"beta\");\n        multimap.put(\"symbols\", null);\n        multimap.put(null, \"missing-key\");\n\n        LinkedHashMultimap<String, String> copy = roundTrip(multimap);\n\n        assertThat(copy).isEqualTo(multimap);\n        assertThat(copy.keySet()).containsExactly(\"letters\", \"numbers\", \"symbols\", null);\n        assertThat(copy.entries()).containsExactly(\n                entry(\"letters\", \"alpha\"),\n                entry(\"numbers\", \"one\"),\n                entry(\"letters\", \"beta\"),\n                entry(\"symbols\", null),\n                entry(null, \"missing-key\"));\n        assertThat(copy.values()).containsExactly(\"alpha\", \"one\", \"beta\", null, \"missing-key\");\n        assertThat(copy.get(\"letters\")).containsExactly(\"alpha\", \"beta\");\n    }\n\n    private static Map.Entry<String, String> entry(String key, String value) {\n        return new AbstractMap.SimpleImmutableEntry<>(key, value);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}
