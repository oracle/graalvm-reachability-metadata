private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3713, "output": 844, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 22989, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777748495674, "responseId": "resp_0accf6c30695a0910169f64a100368819e832ee58bee8f81e9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_WTVAf0WUzzp16gZYEJuybRcu|fc_0accf6c30695a0910169f64a1815f4819ebcac7999e84178cd", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2349 bytes to tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/MultimapsInnerCustomSetMultimapTest.java"}], "isError": false, "timestamp": 1777748506093}]}
