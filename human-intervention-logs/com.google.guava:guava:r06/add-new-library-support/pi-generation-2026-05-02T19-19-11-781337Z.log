[tool-call] delta {"path":"tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/TreeMultimapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.collect.TreeMultimap;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.Collections;\nimport java.util.Comparator;\nimport org.junit.jupiter.api.Test;\n\npublic class TreeMultimapTest {\n    @Test\n    void serializesAndDeserializesComparatorsAndSortedEntries() throws Exception {\n        Comparator<String> descendingStrings = Collections.reverseOrder();\n        TreeMultimap<String, String> multimap = TreeMultimap.create(descendingStrings, descendingStrings);\n        multimap.put(\"letters\", \"alpha\");\n        multimap.put(\"letters\", \"gamma\");\n        multimap.put(\"letters\", \"beta\");\n        multimap.put(\"numbers\", \"one\");\n        multimap.put(\"numbers\", \"three\");\n        multimap.put(\"symbols\", \"asterisk\");\n\n        TreeMultimap<String, String> copy = roundTrip(multimap);\n\n        assertThat(copy).isEqualTo(multimap);\n        assertThat(copy).isNotSameAs(multimap);\n        assertThat(copy.keySet()).containsExactly(\"symbols\", \"numbers\", \"letters\");\n        assertThat(copy.get(\"letters\")).containsExactly(\"gamma\", \"beta\", \"alpha\");\n        assertThat(copy.get(\"numbers\")).containsExactly(\"three\", \"one\");\n\n        copy.put(\"letters\", \"delta\");\n        copy.put(\"animals\", \"zebra\");\n\n        assertThat(copy.keySet()).containsExactly(\"symbols\", \"numbers\", \"letters\", \"animals\");\n        assertThat(copy.get(\"letters\")).containsExactly(\"gamma\", \"delta\", \"beta\", \"alpha\");\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}
