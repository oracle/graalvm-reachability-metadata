  package com_google_guava.guava;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.collect.LinkedHashMultimap;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.AbstractMap;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class LinkedHashMultimapTest {
      @Test
      void serializesAndDeserializesEntryIterationOrder() throws Exception {
          LinkedHashMultimap<String, String> multimap = LinkedHashMultimap.create();
          multimap.put("letters", "alpha");
          multimap.put("numbers", "one");
          multimap.put("letters", "beta");
          multimap.put("symbols", null);
          multimap.put(null, "missing-key");
  
          LinkedHashMultimap<String, String> copy = roundTrip(multimap);
  
          assertThat(copy).isEqualTo(multimap);
          assertThat(copy.keySet()).containsExactly("letters", "numbers", "symbols", null);
          assertThat(copy.entries()).containsExactly(
                  entry("letters", "alpha"),
                  entry("numbers", "one"),
                  entry("letters", "beta"),
                  entry("symbols", null),
                  entry(null, "missing-key"));
          assertThat(copy.values()).containsExactly("alpha", "one", "beta", null, "missing-key");
          assertThat(copy.get("letters")).containsExactly("alpha", "beta");
      }
  
      private static Map.Entry<String, String> entry(String key, String value) {
          return new AbstractMap.SimpleImmutableEntry<>(key, value);
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T roundTrip(T value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());
          try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {
              return (T) input.readObject();
          }
      }
  }
