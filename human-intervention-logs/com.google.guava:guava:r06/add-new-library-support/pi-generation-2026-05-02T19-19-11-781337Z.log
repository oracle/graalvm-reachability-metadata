n\n        copy.put(\"letters\", \"delta\");\n        copy.put(\"animals\", \"zebra\");\n\n        assertThat(copy.keySet()).containsExactly(\"symbols\", \"numbers\", \"letters\", \"animals\");\n        assertThat(copy.get(\"letters\")).containsExactly(\"gamma\", \"delta\", \"beta\", \"alpha\");\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 602, "output": 947, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 14349, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777749525851, "responseId": "resp_09969407b5907bc60169f64e1631a0819785616875703da464"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_217sR6SYvPrsgoOaM9GhRpXJ|fc_09969407b5907bc60169f64e1d833481979b715e17f6dea51b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2328 bytes to tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/TreeMultimapTest.java"}], "isError": false, "timestamp": 1777749536916}]}
