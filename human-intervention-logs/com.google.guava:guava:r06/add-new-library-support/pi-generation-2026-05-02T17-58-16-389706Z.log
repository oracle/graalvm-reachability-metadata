ia CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.collect.EnumBiMap;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.junit.jupiter.api.Test;\n\npublic class EnumBiMapTest {\n    @Test\n    void serializesAndDeserializesEnumKeyAndValueTypes() throws Exception {\n        EnumBiMap<Status, Signal> map = EnumBiMap.create(Status.class, Signal.class);\n        map.put(Status.READY, Signal.GREEN);\n        map.put(Status.BLOCKED, Signal.RED);\n\n        EnumBiMap<Status, Signal> copy = roundTrip(map);\n\n        assertThat(copy).isEqualTo(map);\n        assertThat(copy).isNotSameAs(map);\n        assertThat(copy.keyType()).isSameAs(Status.class);\n        assertThat(copy.valueType()).isSameAs(Signal.class);\n        assertThat(copy.inverse()).containsEntry(Signal.GREEN, Status.READY);\n        assertThat(copy.inverse()).containsEntry(Signal.RED, Status.BLOCKED);\n\n        copy.put(Status.WAITING, Signal.YELLOW);\n\n        assertThat(copy).containsEntry(Status.WAITING, Signal.YELLOW);\n        assertThat(copy.inverse()).containsEntry(Signal.YELLOW, Status.WAITING);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n\n    private enum Status {\n        READY,\n        BLOCKED,\n        WAITING\n    }\n\n    private enum Signal {\n        GREEN,\n        RED,\n        YELLOW\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1096, "output": 963, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26635, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777744660049, "responseId": "resp_021cbdbd199f6fd20169f63b1483e881938f48f082085f6e96"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6dwzUE1GzoHCprKrrIwUdQII|fc_021cbdbd199f6fd20169f63b1abff48193a0f07dbc0d17a2a2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2111 bytes to tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/EnumBiMapTest.java"}], "isError": false, "timestamp": 1777744669768}]}
