  package com_google_guava.guava;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.collect.TreeMultimap;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.Collections;
  import java.util.Comparator;
  import org.junit.jupiter.api.Test;
  
  public class TreeMultimapTest {
      @Test
      void serializesAndDeserializesComparatorsAndSortedEntries() throws Exception {
          Comparator<String> descendingStrings = Collections.reverseOrder();
          TreeMultimap<String, String> multimap = TreeMultimap.create(descendingStrings, descendingStrings);
          multimap.put("letters", "alpha");
          multimap.put("letters", "gamma");
          multimap.put("letters", "beta");
          multimap.put("numbers", "one");
          multimap.put("numbers", "three");
          multimap.put("symbols", "asterisk");
  
          TreeMultimap<String, String> copy = roundTrip(multimap);
  
          assertThat(copy).isEqualTo(multimap);
          assertThat(copy).isNotSameAs(multimap);
          assertThat(copy.keySet()).containsExactly("symbols", "numbers", "letters");
          assertThat(copy.get("letters")).containsExactly("gamma", "beta", "alpha");
          assertThat(copy.get("numbers")).containsExactly("three", "one");
  
          copy.put("letters", "delta");
          copy.put("animals", "zebra");
  
          assertThat(copy.keySet()).containsExactly("symbols", "numbers", "letters", "animals");
          assertThat(copy.get("letters")).containsExactly("gamma", "delta", "beta", "alpha");
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T roundTrip(T value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());
          try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {
              return (T) input.readObject();
          }
      }
  }
