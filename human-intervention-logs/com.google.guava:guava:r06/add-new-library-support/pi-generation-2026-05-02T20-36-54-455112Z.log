[tool-call] delta {"path":"tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/ImmutableListMultimapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.collect.ImmutableListMultimap;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.junit.jupiter.api.Test;\n\npublic class ImmutableListMultimapTest {\n    @Test\n    void serializesAndDeserializesKeysAndValueLists() throws Exception {\n        ImmutableListMultimap<String, String> multimap = ImmutableListMultimap.<String, String>builder()\n                .put(\"letters\", \"alpha\")\n                .put(\"letters\", \"beta\")\n                .put(\"numbers\", \"one\")\n                .build();\n\n        ImmutableListMultimap<String, String> copy = roundTrip(multimap);\n\n        assertThat(copy).isEqualTo(multimap);\n        assertThat(copy.keySet()).containsExactly(\"letters\", \"numbers\");\n        assertThat(copy.get(\"letters\")).containsExactly(\"alpha\", \"beta\");\n        assertThat(copy.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(copy.get(\"missing\")).isEmpty();\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}
