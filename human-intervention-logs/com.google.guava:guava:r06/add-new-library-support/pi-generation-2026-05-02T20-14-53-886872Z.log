  package com_google_guava.guava;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.collect.EnumBiMap;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import org.junit.jupiter.api.Test;
  
  public class EnumBiMapTest {
      @Test
      void serializesAndDeserializesEnumKeyAndValueTypes() throws Exception {
          EnumBiMap<Status, Signal> map = EnumBiMap.create(Status.class, Signal.class);
          map.put(Status.READY, Signal.GREEN);
          map.put(Status.BLOCKED, Signal.RED);
  
          EnumBiMap<Status, Signal> copy = roundTrip(map);
  
          assertThat(copy).isEqualTo(map);
          assertThat(copy).isNotSameAs(map);
          assertThat(copy.keyType()).isSameAs(Status.class);
          assertThat(copy.valueType()).isSameAs(Signal.class);
          assertThat(copy.inverse()).containsEntry(Signal.GREEN, Status.READY);
          assertThat(copy.inverse()).containsEntry(Signal.RED, Status.BLOCKED);
  
          copy.put(Status.WAITING, Signal.YELLOW);
  
          assertThat(copy).containsEntry(Status.WAITING, Signal.YELLOW);
          assertThat(copy.inverse()).containsEntry(Signal.YELLOW, Status.WAITING);
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T roundTrip(T value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());
          try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {
              return (T) input.readObject();
          }
      }
  
      private enum Status {
          READY,
          BLOCKED,
          WAITING
      }
  
      private enum Signal {
          GREEN,
          RED,
          YELLOW
      }
  }
