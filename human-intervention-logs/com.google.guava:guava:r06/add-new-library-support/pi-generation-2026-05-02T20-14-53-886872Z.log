yteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.junit.jupiter.api.Test;\n\npublic class EnumHashBiMapTest {\n    @Test\n    void serializesAndDeserializesKeyTypeAndEntries() throws Exception {\n        EnumHashBiMap<Priority, String> map = EnumHashBiMap.create(Priority.class);\n        map.put(Priority.LOW, \"deferred\");\n        map.put(Priority.MEDIUM, null);\n        map.put(Priority.HIGH, \"urgent\");\n\n        EnumHashBiMap<Priority, String> copy = roundTrip(map);\n\n        assertThat(copy).isEqualTo(map);\n        assertThat(copy).isNotSameAs(map);\n        assertThat(copy.keyType()).isSameAs(Priority.class);\n        assertThat(copy.inverse()).containsEntry(\"deferred\", Priority.LOW);\n        assertThat(copy.inverse()).containsEntry(null, Priority.MEDIUM);\n        assertThat(copy.inverse()).containsEntry(\"urgent\", Priority.HIGH);\n\n        copy.forcePut(Priority.LOW, \"urgent\");\n\n        assertThat(copy).doesNotContainKey(Priority.HIGH);\n        assertThat(copy).containsEntry(Priority.LOW, \"urgent\");\n        assertThat(copy.inverse()).containsEntry(\"urgent\", Priority.LOW);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n\n    private enum Priority {\n        LOW,\n        MEDIUM,\n        HIGH\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 790, "output": 617, "cacheRead": 11776, "cacheWrite": 0, "totalTokens": 13183, "cost": {"input": 0, "output": 0, "