Text": "import com.google.common.util.concurrent.SimpleTimeLimiter;\nimport java.util.concurrent.ExecutorService;\n", "newText": "import com.google.common.base.Function;\nimport com.google.common.util.concurrent.SimpleTimeLimiter;\nimport java.util.concurrent.ExecutorService;\n"}, {"oldText": "            TimedOperation target = new TimedOperation() {\n                @Override\n                public String describe(String value) throws InterruptedException {\n                    return Thread.currentThread().getName() + \":\" + value;\n                }\n            };\n\n            TimedOperation proxy = limiter.newProxy(target, TimedOperation.class, 5, TimeUnit.SECONDS);\n\n            assertThat(proxy.describe(\"payload\")).isEqualTo(\"simple-time-limiter-worker:payload\");\n", "newText": "            Function<String, String> target = new Function<String, String>() {\n                @Override\n                public String apply(String value) {\n                    return Thread.currentThread().getName() + \":\" + value;\n                }\n            };\n\n            Function<String, String> proxy = limiter.newProxy(target, functionInterface(), 5, TimeUnit.SECONDS);\n\n            assertThat(proxy.apply(\"payload\")).isEqualTo(\"simple-time-limiter-worker:payload\");\n"}, {"oldText": "\n    public interface TimedOperation {\n        String describe(String value) throws InterruptedException;\n    }\n", "newText": "\n    @SuppressWarnings(\"unchecked\")\n    private static Class<Function<String, String>> functionInterface() {\n        return (Class<Function<String, String>>) (Class<?>) Function.class;\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1186, "output": 1710, "cacheRead": 34304, "cacheWrite": 0, "totalTokens": 37200, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777757295864, "responseId": "resp_0bed9c6fb5b7bb6d0169f66c705