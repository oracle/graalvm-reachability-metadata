ttp://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.util.concurrent.SimpleTimeLimiter;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport org.junit.jupiter.api.Test;\n\npublic class SimpleTimeLimiterTest {\n    @Test\n    void proxiesInterruptibleInterfaceMethodThroughExecutor() throws Exception {\n        ExecutorService executor = Executors.newSingleThreadExecutor(runnable -> new Thread(runnable, \"simple-time-limiter-worker\"));\n        try {\n            SimpleTimeLimiter limiter = new SimpleTimeLimiter(executor);\n            TimedOperation target = new TimedOperation() {\n                @Override\n                public String describe(String value) throws InterruptedException {\n                    return Thread.currentThread().getName() + \":\" + value;\n                }\n            };\n\n            TimedOperation proxy = limiter.newProxy(target, TimedOperation.class, 5, TimeUnit.SECONDS);\n\n            assertThat(proxy.describe(\"payload\")).isEqualTo(\"simple-time-limiter-worker:payload\");\n        } finally {\n            executor.shutdownNow();\n            assertThat(executor.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n\n    public interface TimedOperation {\n        String describe(String value) throws InterruptedException;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1336, "output": 1673, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 32705, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777757234026, "responseId": "resp_0bed9c6fb5b7bb6d0169f66c327eb0819eb459b07328854f23"}}
