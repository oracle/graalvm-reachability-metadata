  package com_google_guava.guava;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.collect.MapMaker;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.concurrent.ConcurrentMap;
  import java.util.concurrent.TimeUnit;
  import org.junit.jupiter.api.Test;
  
  public class CustomConcurrentHashMapInnerAbstractSerializationProxyTest {
      @Test
      void serializesAndDeserializesCustomConcurrentMapEntries() throws Exception {
          ConcurrentMap<String, Integer> map = new MapMaker()
                  .expiration(1, TimeUnit.DAYS)
                  .concurrencyLevel(1)
                  .makeMap();
          map.put("alpha", 1);
          map.put("beta", 2);
  
          ConcurrentMap<String, Integer> copy = roundTrip(map);
  
          assertThat(copy).hasSize(2);
          assertThat(copy).containsEntry("alpha", 1);
          assertThat(copy).containsEntry("beta", 2);
          assertThat(copy.putIfAbsent("gamma", 3)).isNull();
          assertThat(copy).containsEntry("gamma", 3);
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T roundTrip(T value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());
          try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {
              return (T) input.readObject();
          }
      }
  }
