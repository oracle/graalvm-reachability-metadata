[tool-call] delta {"path":"tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/SerializationTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.collect.ArrayListMultimap;\nimport com.google.common.collect.HashBiMap;\nimport com.google.common.collect.HashMultiset;\nimport com.google.common.collect.ImmutableMultiset;\nimport com.google.common.collect.Multiset;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.junit.jupiter.api.Test;\n\npublic class SerializationTest {\n    @Test\n    void serializesAndDeserializesHashBiMapEntries() throws Exception {\n        HashBiMap<String, String> biMap = HashBiMap.create();\n        biMap.put(\"alpha\", \"one\");\n        biMap.put(\"beta\", \"two\");\n\n        HashBiMap<String, String> copy = roundTrip(biMap);\n\n        assertThat(copy).isEqualTo(biMap);\n        assertThat(copy.inverse().get(\"one\")).isEqualTo(\"alpha\");\n        assertThat(copy.inverse().get(\"two\")).isEqualTo(\"beta\");\n    }\n\n    @Test\n    void serializesAndDeserializesHashMultisetElementsAndCounts() throws Exception {\n        HashMultiset<String> multiset = HashMultiset.create();\n        multiset.add(\"red\", 2);\n        multiset.add(\"blue\", 3);\n\n        HashMultiset<String> copy = roundTrip(multiset);\n\n        assertThat(copy).isEqualTo(multiset);\n        assertThat(copy.count(\"red\")).isEqualTo(2);\n        assertThat(copy.count(\"blue\")).isEqualTo(3);\n        assertThat(copy.entrySet()).hasSize(2);\n    }\n\n    @Test\n    void serializesAndDeserializesArrayListMultimapKeysAndValues() throws Exception {\n        ArrayListMultimap<String, String> multimap = ArrayListMultimap.create();\n        multimap.put(\"letters\", \"a\");\n        multimap.put(\"letters\", \"b\");\n        multimap.put(\"numbers\", \"one\");\n\n        ArrayListMultimap<String, String> copy = roundTrip(multimap);\n\n        assertThat(copy).isEqualTo(multimap);\n        assertThat(copy.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(copy.get(\"numbers\")).containsExactly(\"one\");\n    }\n\n    @Test\n    void deserializesImmutableMultisetFinalFields() throws Exception {\n        ImmutableMultiset<String> multiset = ImmutableMultiset.of(\"oak\", \"oak\", \"pine\");\n\n        ImmutableMultiset<String> copy = roundTrip(multiset);\n\n        assertThat(copy).isEqualTo(multiset);\n        assertThat(copy.count(\"oak\")).isEqualTo(2);\n        assertThat(copy.count(\"pine\")).isEqualTo(1);\n        assertThat(copy.entrySet())\n            .extracting(Multiset.Entry::getElement)\n            .containsExactlyInAnyOrder(\"oak\", \"pine\");\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}
