  package com_google_guava.guava;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.collect.ArrayListMultimap;
  import com.google.common.collect.HashBiMap;
  import com.google.common.collect.HashMultiset;
  import com.google.common.collect.ImmutableMultiset;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import org.junit.jupiter.api.Test;
  
  public class SerializationTest {
      @Test
      void serializesAndDeserializesHashBiMapEntries() throws Exception {
          HashBiMap<String, String> biMap = HashBiMap.create();
          biMap.put("alpha", "one");
          biMap.put("beta", "two");
  
          HashBiMap<String, String> copy = roundTrip(biMap);
  
          assertThat(copy).isEqualTo(biMap);
          assertThat(copy.inverse().get("one")).isEqualTo("alpha");
          assertThat(copy.inverse().get("two")).isEqualTo("beta");
      }
  
      @Test
      void serializesAndDeserializesHashMultisetElementsAndCounts() throws Exception {
          HashMultiset<String> multiset = HashMultiset.create();
          multiset.add("red", 2);
          multiset.add("blue", 3);
  
          HashMultiset<String> copy = roundTrip(multiset);
  
          assertThat(copy).isEqualTo(multiset);
          assertThat(copy.count("red")).isEqualTo(2);
          assertThat(copy.count("blue")).isEqualTo(3);
          assertThat(copy.entrySet()).hasSize(2);
      }
  
      @Test
      void serializesAndDeserializesArrayListMultimapKeysAndValues() throws Exception {
          ArrayListMultimap<String, String> multimap = ArrayListMultimap.create();
          multimap.put("letters", "a");
          multimap.put("letters", "b");
          multimap.put("numbers", "one");
  
          ArrayListMultimap<String, String> copy = roundTrip(multimap);
  
          assertThat(copy).isEqualTo(multimap);
          assertThat(copy.get("letters")).containsExactly("a", "b");
          assertThat(copy.get("numbers")).containsExactly("one");
      }
  
      @Test
      void deserializesImmutableMultisetFinalFields() throws Exception {
          ImmutableMultiset<String> multiset = ImmutableMultiset.of("oak", "oak", "pine");
  
          ImmutableMultiset<String> copy = roundTrip(multiset);
  
          assertThat(copy).isEqualTo(multiset);
          assertThat(copy.count("oak")).isEqualTo(2);
          assertThat(copy.count("pine")).isEqualTo(1);
          assertThat(copy.entrySet()).hasSize(2);
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T roundTrip(T value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());
          try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {
              return (T) input.readObject();
          }
      }
  }
