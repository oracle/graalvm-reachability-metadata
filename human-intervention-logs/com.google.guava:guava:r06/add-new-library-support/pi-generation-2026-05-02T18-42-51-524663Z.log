[tool-call] delta {"path":"tests/src/com.google.guava/guava/r06/src/test/java/com_google_guava/guava/MultimapsInnerCustomListMultimapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.base.Supplier;\nimport com.google.common.base.Suppliers;\nimport com.google.common.collect.ListMultimap;\nimport com.google.common.collect.Multimaps;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.ArrayList;\nimport java.util.Collection;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\npublic class MultimapsInnerCustomListMultimapTest {\n    @Test\n    void serializesAndDeserializesCustomListMultimapFactoryAndBackingMap() throws Exception {\n        Map<String, Collection<String>> backingMap = new LinkedHashMap<>();\n        Supplier<? extends List<String>> listSupplier = Suppliers.ofInstance(new ArrayList<String>());\n        ListMultimap<String, String> multimap = Multimaps.newListMultimap(backingMap, listSupplier);\n        multimap.put(\"letters\", \"alpha\");\n        multimap.put(\"letters\", \"beta\");\n\n        ListMultimap<String, String> copy = roundTrip(multimap);\n\n        assertThat(copy).isEqualTo(multimap);\n        assertThat(copy.keySet()).containsExactly(\"letters\");\n        assertThat(copy.get(\"letters\")).containsExactly(\"alpha\", \"beta\");\n\n        copy.put(\"letters\", \"gamma\");\n        assertThat(copy.get(\"letters\")).containsExactly(\"alpha\", \"beta\", \"gamma\");\n        assertThat(multimap.get(\"letters\")).containsExactly(\"alpha\", \"beta\");\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}
