mport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.concurrent.ConcurrentMap;\nimport java.util.concurrent.TimeUnit;\nimport org.junit.jupiter.api.Test;\n\npublic class CustomConcurrentHashMapInnerAbstractSerializationProxyTest {\n    @Test\n    void serializesAndDeserializesCustomConcurrentMapEntries() throws Exception {\n        ConcurrentMap<String, Integer> map = new MapMaker()\n                .expiration(1, TimeUnit.DAYS)\n                .concurrencyLevel(1)\n                .makeMap();\n        map.put(\"alpha\", 1);\n        map.put(\"beta\", 2);\n\n        ConcurrentMap<String, Integer> copy = roundTrip(map);\n\n        assertThat(copy).hasSize(2);\n        assertThat(copy).containsEntry(\"alpha\", 1);\n        assertThat(copy).containsEntry(\"beta\", 2);\n        assertThat(copy.putIfAbsent(\"gamma\", 3)).isNull();\n        assertThat(copy).containsEntry(\"gamma\", 3);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2676, "output": 1010, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 16486, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777744017632, "responseId": "resp_0ce33c2a1561448f0169f63892022c81a39a4475f14bcf9fc0"}}
