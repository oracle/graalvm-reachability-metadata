    HashBiMap<String, String> forward = HashBiMap.create();\n        forward.put(\"alpha\", \"one\");\n        forward.put(\"beta\", \"two\");\n\n        BiMap<String, String> inverseCopy = roundTrip(forward.inverse());\n\n        assertThat(inverseCopy).containsEntry(\"one\", \"alpha\");\n        assertThat(inverseCopy).containsEntry(\"two\", \"beta\");\n        assertThat(inverseCopy.inverse()).containsEntry(\"alpha\", \"one\");\n        assertThat(inverseCopy.inverse()).containsEntry(\"beta\", \"two\");\n        assertThat(inverseCopy.inverse().inverse()).isSameAs(inverseCopy);\n\n        inverseCopy.put(\"three\", \"gamma\");\n\n        assertThat(inverseCopy).containsEntry(\"three\", \"gamma\");\n        assertThat(inverseCopy.inverse()).containsEntry(\"gamma\", \"three\");\n        assertThat(forward).doesNotContainEntry(\"gamma\", \"three\");\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 802, "output": 864, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 23170, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777751936620, "responseId": "resp_09265b6e37bb4f0c0169f65781108c8190aefd6490b3495ffd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Sm9t8Pr0eUmA2cISJSro0OUy|fc_09265b6e37bb4f0c0169f65785e52c8190903a93426e97190f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 20