yImpl(this, array);\n    }\n    @Override public boolean contains(Object o) {\n      return Maps.containsEntryImpl(delegate(), o);\n    }\n    @Override public boolean containsAll(Collection<?> c) {\n      return Collections2.containsAll(this, c);\n    }\n    @Override public boolean removeAll(Collection<?> c) {\n      return Iterators.removeAll(iterator(), c);\n    }\n    @Override public boolean retainAll(Collection<?> c) {\n      return Iterators.retainAll(iterator(), c);\n    }\n  }\n\n  /** The inverse of any other {@code AbstractBiMap} subclass. */\n  private static class Inverse<K, V> extends AbstractBiMap<K, V> {\n    private Inverse(Map<K, V> backward, AbstractBiMap<V, K> forward) {\n      super(backward, forward);\n    }\n\n    /*\n     * Serialization stores the forward bimap, the inverse of this inverse.\n     * Deserialization calls inverse() on the forward bimap and returns that\n     * inverse.\n     *\n     * If a bimap and its inverse are serialized together, the deserialized\n     * instances have inverse() methods that return the other.\n     */\n\n    /**\n     * @serialData the forward bimap\n     */\n    @GwtIncompatible(\"java.io.ObjectOuputStream\")\n    private void writeObject(ObjectOutputStream stream) throws IOException {\n      stream.defaultWriteObject();\n      stream.writeObject(inverse());\n    }\n\n    @GwtIncompatible(\"java.io.ObjectInputStream\")\n    @SuppressWarnings(\"unchecked\") // reading data stored by writeObject\n    private void readObject(ObjectInputStream stream)\n        throws IOException, ClassNotFoundException {\n      stream.defaultReadObject();\n      setInverse((AbstractBiMap<V, K>) stream.readObject());\n    }\n\n    @GwtIncompatible(\"Not needed in the emulated source.\")\n    Object readResolve() {\n      return inverse().inverse();\n    }\n\n    @GwtIncompatible(\"Not needed in emulated source.\")\n    private static final long serialVersionUID = 0;\n  }\n\n  @GwtIncompatible(\"Not needed in emulated source.\")\n  private static final long serialVersionUID = 0;\n}\n"}], "isError": false, "timestamp": 1777751913912}, {"role": "toolResult", "toolCallId": "call_0pIE08Rn3iHAdv2bxZ0SOu0Q|fc_09265b6e37bb4f0c0169f657698bec8190848101fb237f0f2b", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.collect.ArrayListMultimap;\nimport com.google.common.collect.HashBiMap;\nimport com.google.common.collect.HashMultiset;\nimport com.google.common.collect.ImmutableMultiset;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.junit.jupiter.api.Test;\n\npublic class SerializationTest {\n    @Test\n    void serializesAndDeserializesHashBiMapEntries() throws Exception {\n        HashBiMap<String, String> biMap = HashBiMap.create();\n        biMap.put(\"alpha\", \"one\");\n        biMap.put(\"beta\", \"two\");\n\n        HashBiMap<String, String> copy = roundTrip(biMap);\n\n        assertThat(copy).isEqualTo(biMap);\n        assertThat(copy.inverse().get(\"one\")).isEqualTo(\"alpha\");\n        assertThat(copy.inverse().get(\"two\")).isEqualTo(\"beta\");\n    }\n\n    @Test\n    void serializesAndDeserializesHashMultisetElementsAndCounts() throws Exception {\n        HashMultiset<String> multiset = HashMultiset.create();\n        multiset.add(\"red\", 2);\n        multiset.add(\"blue\", 3);\n\n        HashMultiset<String> copy = roundTrip(multiset);\n\n        assertThat(copy).isEqualTo(multiset);\n        assertThat(copy.count(\"red\")).isEqualTo(2);\n        assertThat(copy.count(\"blue\")).isEqualTo(3);\n        assertThat(copy.entrySet()).hasSize(2);\n    }\n\n    @Test\n    void serializesAndDeserializesArrayListMultimapKeysAndValues() throws Exception {\n        ArrayListMultimap<String, String> multimap = ArrayListMultimap.create();\n        multimap.put(\"letters\", \"a\");\n        multimap.put(\"letters\", \"b\");\n        multimap.put(\"numbers\", \"one\");\n\n        ArrayListMultimap<String, String> copy = roundTrip(multimap);\n\n        assertThat(copy).isEqualTo(multimap);\n        assertThat(copy.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(copy.get(\"numbers\")).containsExactly(\"one\");\n    }\n\n    @Test\n    void deserializesImmutableMultisetFinalFields() throws Exception {\n        ImmutableMultiset<String> multiset = ImmutableMultiset.of(\"oak\", \"oak\", \"pine\");\n\n        ImmutableMultiset<String> copy = roundTrip(multiset);\n\n        assertThat(copy).isEqualTo(multiset);\n        assertThat(copy.count(\"oak\")).isEqualTo(2);\n        assertThat(copy.count(\"pine\")).isEqualTo(1);\n        assertThat(copy.entrySet()).hasSize(2);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777751913912}, {"role": "toolResult", "toolCallId": "call_3N5kyVtYGj91BwZeVQJ9iB6E|fc_09265b6e37bb4f0c0169f657698bf8819090d07089fd89ccd7", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classes\" : [ {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"com.google.common.collect.AbstractBiMap$Inverse.readObject(AbstractBiMap.java:38