[tool-call] delta {"path":"tests/src/org.eclipse.angus/logging-mailhandler/1.0.0/src/test/java/org_eclipse_angus/logging_mailhandler/LogManagerPropertiesTest.java","edits":[{"oldText":"import com.sun.mail.util.logging.MailHandler;\nimport java.io.ByteArrayInputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Properties;\nimport java.util.logging.Filter;\nimport java.util.logging.Level;\nimport java.util.logging.LogManager;\nimport java.util.logging.LogRecord;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.function.Executable;\n","newText":"import com.sun.mail.util.logging.MailHandler;\nimport jakarta.mail.Address;\nimport jakarta.mail.MessagingException;\nimport jakarta.mail.Session;\nimport jakarta.mail.Transport;\nimport jakarta.mail.URLName;\nimport java.io.ByteArrayInputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Base64;\nimport java.util.Properties;\nimport java.util.logging.Filter;\nimport java.util.logging.Level;\nimport java.util.logging.LogManager;\nimport java.util.logging.LogRecord;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.function.Executable;\n"},{"oldText":"    private static final Object LOG_MANAGER_LOCK = new Object();\n\n    @Test\n","newText":"    private static final Object LOG_MANAGER_LOCK = new Object();\n    private static final String GENERATED_FILTER_CLASS_NAME = \"dyn.GeneratedFilter\";\n    private static final String GENERATED_FILTER_CLASS_BYTES = \"\"\"\n            yv66vgAAADQAEAEAE2R5bi9HZW5lcmF0ZWRGaWx0ZXIHAAEBABBqYXZhL2xhbmcvT2JqZWN0BwAD\n            AQAYamF2YS91dGlsL2xvZ2dpbmcvRmlsdGVyBwAFAQAGPGluaXQ+AQADKClWDAAHAAgKAAQACQEA\n            BENvZGUBAAppc0xvZ2dhYmxlAQAgKExqYXZhL3V0aWwvbG9nZ2luZy9Mb2dSZWNvcmQ7KVoBAApT\n            b3VyY2VGaWxlAQAUR2VuZXJhdGVkRmlsdGVyLmphdmEAIQACAAQAAQAGAAAAAgABAAcACAABAAsA\n            AAARAAAAAQABAAUqtwAKsQAAAAAAAQAMAA0AAQALAAAADgAAAAEAAgACBKwAAAAAAAEADgAAAAIA\n    