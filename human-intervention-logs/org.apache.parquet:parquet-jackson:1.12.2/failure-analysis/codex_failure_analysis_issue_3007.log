on;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.lang.annotation.ElementType;\\nimport java.lang.annotation.Retention;\\nimport java.lang.annotation.RetentionPolicy;\\nimport java.lang.annotation.Target;\\nimport java.lang.reflect.Constructor;\\nimport java.lang.reflect.Field;\\nimport java.lang.reflect.Method;\\nimport java.util.Base64;\\nimport java.util.HashMap;\\nimport java.util.Map;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport shaded.parquet.com.fasterxml.jackson.databind.util.ClassUtil;\\n\\npublic class ClassUtilTest {\\n    private static final String HOST_CLASS_NAME = \\\"org_apache_parquet.parquet_jackson.BrokenMethodHost\\\";\\n    private static final String DEPENDENCY_CLASS_NAME = \\\"org_apache_parquet.parquet_jackson.MissingMethodDependency\\\";\\n    private static final String HOST_BYTES = \\\"\\\"\\\"\\n            \\n            \\\"\\\"\\\";\\n    private static final String DEPENDENCY_BYTES = \\\"\\\"\\\"\\n            \\n            \\\"\\\"\\\";\\n\\n    @Test\\n    void createsInstanceUsingDefaultConstructor() {\\n        Constructor<DefaultConstructible> constructor = ClassUtil.findConstructor(DefaultConstructible.class, true);\\n        DefaultConstructible instance = ClassUtil.createInstance(DefaultConstructible.class, true);\\n\\n        assertThat(constructor.getParameterCount()).isZero();\\n        assertThat(instance.getValue()).isEqualTo(\\\"created\\\");\\n    }\\n\\n    @Test\\n    void exposesDeclaredMembersAndConstructors() {\\n        Field[] fields = ClassUtil.getDeclaredFields(MemberTarget.class);\\n        Method[] declaredMethods = ClassUtil.getDeclaredMethods(MemberTarget.class);\\n        Method[] classMethods = ClassUtil.getClassMethods(MemberTarget.class);\\n        ClassUtil.Ctor[] constructors = ClassUtil.getConstructors(MemberTarget.class);\\n\\n        assertThat(fields).extracting(Field::getName).contains(\\\"name\\\", \\