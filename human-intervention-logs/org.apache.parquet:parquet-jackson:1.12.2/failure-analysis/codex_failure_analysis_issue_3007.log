orUtilitiesFindConstructorsAndCreateInstances() {\\n        Constructor<ConstructibleType> constructor = ClassUtil.findConstructor(ConstructibleType.class, true);\\n        ConstructibleType instance = ClassUtil.createInstance(ConstructibleType.class, true);\\n        ClassUtil.Ctor[] constructors = ClassUtil.getConstructors(MultiConstructorType.class);\\n\\n        assertThat(constructor.getParameterCount()).isZero();\\n        assertThat(instance.value()).isEqualTo(\\\"created\\\");\\n        assertThat(constructors)\\n                .extracting(ClassUtil.Ctor::getParamCount)\\n                .containsExactlyInAnyOrder(0, 1);\\n    }\\n\\n    @Test\\n    void declaredMemberUtilitiesReturnFieldsAndMethods() {\\n        Field[] fields = ClassUtil.getDeclaredFields(IntrospectedType.class);\\n        Method[] declaredMethods = ClassUtil.getDeclaredMethods(IntrospectedType.class);\\n        Method[] classMethods = ClassUtil.getClassMethods(IntrospectedType.class);\\n\\n        assertThat(fields).extracting(Field::getName).contains(\\\"name\\\", \\\"count\\\");\\n        assertThat(declaredMethods).extracting(Method::getName).contains(\\\"name\\\", \\\"count\\\");\\n        assertThat(classMethods).extracting(Method::getName).contains(\\\"name\\\", \\\"count\\\");\\n    }\\n\\n    @Test\\n    void annotatedEnumValueIsFoundFromDeclaredFields() {\\n        Enum<?> defaultValue = ClassUtil.findFirstAnnotatedEnumValue(enumClass(Choice.class), DefaultChoice.class);\\n\\n        assertThat(defaultValue).isEqualTo(Choice.SECOND);\\n    }\\n\\n    @Test\\n    void classMethodsFallbackUsesContextClassLoaderWhenMethodTypesAreMissing() throws Exception {\\n        try {\\n            BrokenMethodClassLoader classLoader = new BrokenMethodClassLoader();\\n            Class<?> brokenClass = classLoader.defineBrokenMethodHolder();\\n            ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\\n            Thread.currentThread().setContextClassLoader(classLoader);\\n            try {\\n                assertThatIllegalArgumentException()\\n                        .isThrownBy(() -> ClassUtil.getClassMethods(brokenClass))\\n                        .withMessageContaining(\\\"Failed on call to `getDeclaredMethods()`\\\")\\n                        .withMessageContaining(GENERATED_CLASS_NAME);\\n            } finally {\\n                Thread.currentThread().setContextClassLoader(originalClassLoader);\\n            }\\n        } catch (Error error) {\\n            rethrowUnlessUnsupportedFeatureError(error);\\n        }\\n    }\\n\\n    @SuppressWarnings({\\\"unchecked\\\", \\\"rawtypes\\\"})\\n    private static Class<Enum<?>> enumClass(Class<? extends Enum<?>> enumClass) {\\n        return (Class) enumClass;\\n    }\\n\\n    private static byte[] createBrokenMethodHolderBytes() throws IOException {\\n        ByteArrayOutputStream classBytes = new ByteArrayOutputStream();\\n        try (DataOutputStream output = new DataOutputStream(classBytes)) {\\n            output.writeInt(0xCAFEBABE);\\n            output.writeShort(0);\\n            output.writeShort(52);\\n            output.writeShort(14);\\n            writeUtf8(output, GENERATED_INTERNAL_NAME);\\n            output.writeByte(7);\\n            output.writeShort(1);\\n            writeUtf8(output, \\\"java/lang/Object\\\");\\n            output.writeByte(7);\\n            output.writeShort(3);\\n            writeUtf8(output, \\\"<init>\\\");\\n            writeUtf8(output, \\\"()V\\\");\\n            output.writeByte(12);\\n            output.writeShort(5);\\n            output.writeShort(6);\\n            output.writeByte(10);\\n            output.writeShort(4);\\n            output.writeShort(7);\\n            writeUtf8(output, \\\"missingDependency\\\");\\n            writeUtf8(output, \\\"()L\\\" + MISSING_DEPENDENCY_INTERNAL_NAME + \\\";\\\");\\n            writeUtf8(output, \\\"Code\\\");\\n            writeUtf8(output, \\\"SourceFile\\\");\\n            writeUtf8(output, \\\"BrokenMethodHolder.java\\\");\\n            output.writeShort(0x0021);\\n            output.writeShort(2);\\n            output.writeShort(4);\\n            output.writeShort(0);\\n            output.writeShort(0);\\n            output.writeShort(2);\\n            writeDefaultConstructor(output);\\n            writeMissingDependencyMethod(output);\\n            output.writeShort(1);\\n            output.writeShort(12);\\n            output.writeInt(2);\\n            output.writeShort(13);\\n        }\\n        return classBytes.toByteArray();\\n    }\\n\\n    private static void writeDefaultConstructor(DataOutputStream output) throws IOException {\\n        output.writeShort(0x0001);\\n        output.writeShort(5);\\n        output.writeShort(6);\\n        output.writeShort(1);\\n        output.writeShort(11);\\n        output.writeInt(17);\\n        output.writeShort(1);\\n        output.writeShort(1);\\n        output.writeInt(5);\\n        output.writeByte(0x2A);\\n        output.writeByte(0xB7);\\n        output.writeShort(8);\\n        output.writeByte(0xB1);\\n        output.writeShort(0);\\n        output.writeShort(0);\\n    }\\n\\n    private static void writeMissingDependencyMethod(DataOutputStream output) throws IOException {\\n        output.writeShort(0x0001);\\n        output.writeShort(9);\\n        output.writeShort(10);\\n        output.writeShort(1);\\n        output.writeShort(11);\\n        output.writeInt(14);\\n        output.writeShort(1);\\n        output.writeShort(1);\\n        output.writeInt(2);\\n        output.writeByte(0x01);\\n        output.writeByte(0xB0);\\n        output.writeShort(0);\\n        output.writeShort(0);\\n    }\\n\\n    private static void writeUtf8(DataOutputStream output, String value) throws IOException {\\n        output.writeByte(1);\\n        output.writeUTF(value);\\n    }\\n\\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\\n        if (!NativeImageSuppor