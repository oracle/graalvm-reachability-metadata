065305d0169f731d6a1dc81969b94d0c1cf9facf7\", \"name\": \"write\", \"arguments\": {\"path\": \"tests/src/org.apache.parquet/parquet-jackson/1.12.2/src/test/java/org_apache_parquet/parquet_jackson/ClassUtilTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_parquet.parquet_jackson;\\n\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.DataOutputStream;\\nimport java.io.IOException;\\nimport java.lang.annotation.Retention;\\nimport java.lang.annotation.RetentionPolicy;\\nimport java.lang.reflect.Constructor;\\nimport java.lang.reflect.Field;\\nimport java.lang.reflect.Method;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport shaded.parquet.com.fasterxml.jackson.databind.util.ClassUtil;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatIllegalArgumentException;\\n\\npublic class ClassUtilTest {\\n    private static final String GENERATED_CLASS_NAME =\\n            \\\"org_apache_parquet.parquet_jackson.BrokenMethodHolder\\\";\\n    private static final String GENERATED_INTERNAL_NAME = GENERATED_CLASS_NAME.replace('.', '/');\\n    private static final String MISSING_DEPENDENCY_INTERNAL_NAME =\\n            \\\"org_apache_parquet/parquet_jackson/MissingMethodDependency\\\";\\n\\n    @Test\\n    void constructorUtilitiesFindConstructorsAndCreateInstances() {\\n        Constructor<ConstructibleType> constructor = ClassUtil.findConstructor(ConstructibleType.class, true);\\n        ConstructibleType instance = ClassUtil.createInstance(ConstructibleType.class, true);\\n        ClassUtil.Ctor[] constructors = ClassUtil.getConstructors(MultiConstructorType.class);\\n\\n        assertThat(constructor.getParameterCount()).isZero();\\n        assertThat(instance.value()).isEqualTo(\\\"created\\\");\\n        assertThat(constructors)\\n                .extracting(ClassUtil.Ctor::getParamCount)\\n                .containsExactlyInAnyOrder(0, 1);\\n    }\\n\\n    @Test\\n    void declaredMemberUtilitiesReturnFieldsAndMethods() {\\n        Field[] fields = ClassUtil.getDeclaredFields(IntrospectedType.class);\\n        Method[] declaredMethods = ClassUtil.getDeclaredMethods(IntrospectedType.class);\\n        Method[] classMethods = ClassUtil.getClassMethods(IntrospectedType.class);\\n\\n        assertThat(fields).extracting(Field::getName).contains(\\\"name\\\", \\\"count\\\");\\n        assertThat(declaredMethods).extracting(Method::getName).contains(\\\"name\\\", \\\"count\\\");\\n        assertThat(classMethods).extracting(Method::getName).contains(\\\"name\\\", \\\"count\\\");\\n    }\\n\\n    @Test\\n    void annotatedEnumValueIsFoundFromDeclaredFields() {\\n        Enum<?> defaultValue = ClassUtil.findFirstAnnotatedEnumValue(enumClass(Choice.class), DefaultChoice.class);\\n\\n        assertThat(defaultValue).isEqualTo(Choice.SECOND);\\n    }\\n\\n    @Test\\n    void classMethodsFallbackUsesContextClassLoaderWhenMethodTypesAreMissing() throws Exception {\\n        try {\\n            BrokenMethodClassLoader classLoader = new BrokenMethodClassLoader();\\n            Class<?> brokenClass = classLoader.defineBrokenMethodHolder();\\n            ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\\n            Thread.currentThread().setContextClassLoader(classLoader);\\n            try {\\n                assertThatIllegalArgumentException()\\n                        .isThrownBy(() -> ClassUtil.getClassMethods(brokenClass))\\n                        .withMessageContaining(\\\"Failed on call to `getDeclaredMethods()`\\\")\\n                        .withMessageContaining(GENERATED_CLASS_NAME);\\n            } finally {\\n                Thread.currentThread().setContextClassLoader(o