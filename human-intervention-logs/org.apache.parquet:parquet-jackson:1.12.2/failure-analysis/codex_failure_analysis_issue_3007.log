il.Ctor::getParamCount)\\n                .containsExactlyInAnyOrder(0, 1);\\n    }\\n\\n    @Test\\n    void declaredMemberUtilitiesReturnFieldsAndMethods() {\\n        Field[] fields = ClassUtil.getDeclaredFields(IntrospectedType.class);\\n        Method[] declaredMethods = ClassUtil.getDeclaredMethods(IntrospectedType.class);\\n        Method[] classMethods = ClassUtil.getClassMethods(IntrospectedType.class);\\n\\n        assertThat(fields).extracting(Field::getName).contains(\\\"name\\\", \\\"count\\\");\\n        assertThat(declaredMethods).extracting(Method::getName).contains(\\\"name\\\", \\\"count\\\");\\n        assertThat(classMethods).extracting(Method::getName).contains(\\\"name\\\", \\\"count\\\");\\n    }\\n\\n    @Test\\n    void annotatedEnumValueIsFoundFromDeclaredFields() {\\n        Enum<?> defaultValue = ClassUtil.findFirstAnnotatedEnumValue(enumClass(Choice.class), DefaultChoice.class);\\n\\n        assertThat(defaultValue).isEqualTo(Choice.SECOND);\\n    }\\n\\n    @Test\\n    void classMethodsFallbackUsesContextClassLoaderWhenMethodTypesAreMissing() throws Exception {\\n        try {\\n            BrokenMethodClassLoader classLoader = new BrokenMethodClassLoader();\\n            Class<?> brokenClass = classLoader.defineBrokenMethodHolder();\\n            ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\\n            Thread.currentThread().setContextClassLoader(classLoader);\\n            try {\\n                assertThatIllegalArgumentException()\\n                        .isThrownBy(() -> ClassUtil.getClassMethods(brokenClass))\\n                        .withMessageContaining(\\\"Failed on call to `getDeclaredMethods()`\\\")\\n                        .withMessageContaining(GENERATED_CLASS_NAME);\\n            } finally {\\n                Thread.currentThread().setContextClassLoader(originalClassLoader);\\n            }\\n        } catch (Error error) {\\n            rethrowUnlessUnsupportedFeatureError(error);\\n        }\\n    }\\n\\n    @SuppressWarnings({\\\"unchecked\\\", \\\"rawtypes\\\"})\\n    private static Class<Enum<?>> enumClass(Class<? extends Enum<?>> enumClass) {\\n        return (Class) enumClass;\\n    }\\n\\n    private static byte[] createBrokenMethodHolderBytes() throws IOException {\\n        ByteArrayOutputStream classBytes = new ByteArrayOutputStream();\\n        try (DataOutputStream output = new DataOutputStream(classBytes)) {\\n            output.writeInt(0xCAFEBABE);\\n            output.writeShort(0);\\n            output.writeShort(52);\\n            output.writeShort(16);\\n            writeUtf8(output, GENERATED_INTERNAL_NAME);\\n            output.writeByte(7);\\n            output.writeShort(1);\\n            writeUtf8(output, \\\"java/lang/Object\\\");\\n            output.writeByte(7);\\n            output.writeShort(3);\\n            writeUtf8(output, \\\"<init>\\\");\\n            writeUtf8(output, \\\"()V\\\");\\n            output.writeByte(12);\\n            output.writeShort(5);\\n            output.writeShort(6);\\n            output.writeByte(10);\\n            output.writeShort(4);\\n            output.writeShort(7);\\n            writeUtf8(output, \\\"missingDependency\\\");\\n            writeUtf8(output, \\\"()L\\\" + MISSING_DEPENDENCY_INTERNAL_NAME + \\\";\\\");\\n            writeUtf8(output, \\\"Code\\\");\\n            writeUtf8(output, \\\"SourceFile\\\");\\n            writeUtf8(output, \\\"BrokenMethodHolder.java\\\");\\n            output.writeShort(0x0021);\\n            output.writeShort(2);\\n            output.writeShort(4);\\n            output.writeShort(0);\\n            output.writeShort(0);\\n            output.writeShort(2);\\n            writeDefaultConstructor(output);\\n            writeMissingDependencyMethod(output);\\n            output.writeShort(1);\\n            output.writeShort(14);\\n            output.writeInt(2);\\n            output.writeShort(15);\\n        }\\n        return classBytes.toByteArray();\\n    }\\n\\n    private static void writeDefaultConstructor(DataOutputStream output) throws IOException {\\n        output.writeShort(0x0001);\\n        output.writeShort(5);\\n        output.writeShort(6);\\n        output.writeShort(1);\\n        output.writeShort(13);\\n        output.writeInt(17);\\n        output.writeShort(1);\\n        output.writeShort(1);\\n        output.writeInt(5);\\n        output.writeByte(0x2A);\\n        output.writeByte(0xB7);\\n        output.writeShort(8);\\n        output.writeByte(0xB1);\\n        output.writeShort(0);\\n        output.writeShort(0);\\n    }\\n\\n    private static void writeMissingDependencyMethod(DataOutputStream output) throws IOException {\\n        output.writeShort(0x0001);\\n        output.writeShort(11);\\n        output.writeShort(12);\\n        output.writeShort(1);\\n        output.writeShort(13);\\n        output.writeInt(14);\\n        output.writeShort(1);\\n        output.writeShort(1);\\n        output.writeInt(2);\\n        output.writeByte(0x01);\\n        output.writeByte(0xB0);\\n        output.writeShort(0);\\n        output.writeShort(0);\\n    }\\n\\n    private static void writeUtf8(DataOutputStream output, String value) throws IOException {\\n        output.writeByte(1);\\n        output.writeUTF(value);\\n    }\\n\\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n            throw error;\\n        }\\n    }\\n\\n    private static final class BrokenMethodClassLoader extends ClassLoader {\\n        private BrokenMethodClassLoader() {\\n            super(ClassUtilTest.class.getClassLoader());\\n        }\\n\\n        private Class<?> defineBrokenMethodHolder() throws IOException {\\n            byte[] classBytes = createBrokenMethodHolderBytes();\\n            return defineClass(GENERATED_CLASS_NAME, classBytes, 0, classBytes.length);\\n        }\\n    }\\n\\n    public static final class ConstructibleType {\\n        public ConstructibleType() {\\n        }\\n\\n        String value() {\\n            return \\\"created\\\";\\n        }\\n    }\\n\\n    public static final class MultiConstructorType {\\n        public MultiConstructorType() {\\n        }\\n\\n        public MultiConstructorType(String ignored) {\\n        }\\n    }\\n\\n    private static final class IntrospectedType {\\n        private final String name = \\\"example\\\";\\n        private final int count = 1;\\n\\n        String name() {\\n            return name;\\n        }\\n\\n        int count() {\\n            return count;\\n        }\\n    }\\n\\n    @Retention(RetentionPolicy.RUNTIME)\\n    private @interface DefaultChoice {\\n    }\\n\\n    private enum Choice {\\n        FIRST,\\n        @DefaultChoice\\n        SECOND\\n    }\\n}\\n\"}\n../3007-b10f0dbb/human-intervention-logs/org.apache.parquet:parquet-jackson:1.12.2/add-new-library-support/pi-generation-2026-05-03T11-32-30-261705Z.log:2493:[tool-call] end id=call_zuSJqnQ1bIezalJRCNa5LF7O|fc_0a2cc192c065305d0169f731d6a1dc81969b94d0c1cf9facf7 name=write args={\"path\": \"tests/src/org.apache.parquet/parquet-jackson/1.12.2/src/test/java/org_apache_parquet/parquet_jackson/ClassUtilTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_parquet.parquet_jackson;\\n\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.DataOutputStream;\\nimport java.io.IOException;\\nimport java.lang.annotation.Retention;\\nimport java.lang.annotation.RetentionPolicy;\\nimport java.lang.reflect.Constructor;\\nimport java.lang.reflect.Field;\\nimport java.lang.reflect.Method;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport shaded.parquet.com.fasterxml.jackson.databin