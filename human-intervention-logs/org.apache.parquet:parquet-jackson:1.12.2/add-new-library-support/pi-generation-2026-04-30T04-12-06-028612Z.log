tMapper MAPPER = new ObjectMapper();\n\n    @Test\n    void invokesBuilderBuildMethodAfterDeserializingArrayElements() throws Exception {\n        ArrayBackedMessage message = MAPPER.readValue(\"\"\"\n                [\"daily-summary\", 5, [\"parquet\", \"jackson\"]]\n                \"\"\", ArrayBackedMessage.class);\n\n        assertThat(message.getName()).isEqualTo(\"daily-summary\");\n        assertThat(message.getPriority()).isEqualTo(5);\n        assertThat(message.getLabels()).containsExactly(\"parquet\", \"jackson\");\n        assertThat(message.isBuiltByBuilder()).isTrue();\n    }\n\n    @JsonFormat(shape = JsonFormat.Shape.ARRAY)\n    @JsonPropertyOrder({ \"name\", \"priority\", \"labels\" })\n    @JsonDeserialize(builder = ArrayBackedMessage.Builder.class)\n    public static final class ArrayBackedMessage {\n        private final String name;\n        private final int priority;\n        private final List<String> labels;\n        private final boolean builtByBuilder;\n\n        private ArrayBackedMessage(Builder builder) {\n            this.name = builder.name;\n            this.priority = builder.priority;\n            this.labels = List.copyOf(builder.labels);\n            this.builtByBuilder = builder.buildInvoked;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public int getPriority() {\n            return priority;\n        }\n\n        public List<String> getLabels() {\n            return labels;\n        }\n\n        public boolean isBuiltByBuilder() {\n            return builtByBuilder;\n        }\n\n        @JsonFormat(shape = JsonFormat.Shape.ARRAY)\n        @JsonPropertyOrder({ \"name\", \"priority\", \"labels\" })\n        @JsonPOJOBuilder(withPrefix = \"with\")\n        public static final class Builder {\n            private String name;\n            private int priority;\n            private List<String> labels = new ArrayList<>();\n            private boolean buildInvoked;\n\n            public Builder withName(String name) {\n                this.name = name;\n                return this;\n            }\n\n            public Builder withPriority(int priority) {\n                this.priority = priority;\n                return this;\n            }\n\n            public Builder withLabels(List<String> labels) {\n                this.labels = new ArrayList<>(labels);\n                return this;\n            }\n\n            public ArrayBackedMessage build() {\n                this.buildInvoked = true;\n                return new ArrayBackedMessage(this);\n            }\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.parquet/parquet-jackson/1.12.2/src/test/java/org_apache_parquet/parquet_jackson/BeanAsArrayBuilderDeserializerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_parquet.parquet_jackson;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.util.ArrayList;\\nimport java.util.List;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport shaded.parquet.com.fasterxml.jackson.annotation.JsonFormat;\\nimport shaded.parquet.com.fasterxml.jackson.annotation.JsonPropertyOrder;\\nimport shaded.parquet.com.fasterxml.jackson.databind.ObjectMapper;\\nimport shaded.parquet.com.fasterxml.jackson.databind.annotation.JsonDeserialize;\\nimport shaded.parquet.com.fasterxml.jackson.databind.annotation.JsonPOJOBuilder;\\n\\npublic class BeanAsArrayBuilderDeserializerTest {\\n    private static final ObjectMapper MAPPER = new ObjectMapper();\\n\\n    @Test\\n    void invokesBuilderBuildMethodAfterDeserializingArrayElements() throws Exception {\\n        ArrayBackedMessage message = MAPPER.readValue(\\\"\\\"\\\"\\n                [\\\"daily-summary\\\", 5, [\\\"parquet\\\", \\\"jackson\\\"]]\\n              