  package org_apache_parquet.parquet_jackson;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.annotation.ElementType;
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  import java.lang.annotation.Target;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.Base64;
  import java.util.HashMap;
  import java.util.Map;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import shaded.parquet.com.fasterxml.jackson.databind.util.ClassUtil;
  
  public class ClassUtilTest {
      private static final String HOST_CLASS_NAME = "org_apache_parquet.parquet_jackson.BrokenMethodHost";
      private static final String DEPENDENCY_CLASS_NAME = "org_apache_parquet.parquet_jackson.MissingMethodDependency";
      private static final String HOST_BYTES = """
              
              """;
      private static final String DEPENDENCY_BYTES = """
              
              """;
  
      @Test
      void createsInstanceUsingDefaultConstructor() {
          Constructor<DefaultConstructible> constructor = ClassUtil.findConstructor(DefaultConstructible.class, true);
          DefaultConstructible instance = ClassUtil.createInstance(DefaultConstructible.class, true);
  
          assertThat(constructor.getParameterCount()).isZero();
          assertThat(instance.getValue()).isEqualTo("created");
      }
  
      @Test
      void exposesDeclaredMembersAndConstructors() {
          Field[] fields = ClassUtil.getDeclaredFields(MemberTarget.class);
          Method[] declaredMethods = ClassUtil.getDeclaredMethods(MemberTarget.class);
          Method[] classMethods = ClassUtil.getClassMethods(MemberTarget.class);
          ClassUtil.Ctor[] constructors = ClassUtil.getConstructors(MemberTarget.class);
  
          assertThat(fields).extracting(Field::getName).contains("name", "count");
          assertThat(declaredMethods).extracting(Method::getName).contains("rename", "count");
          assertThat(classMethods).extracting(Method::getName).contains("rename", "count");
          assertThat(constructors).extracting(ClassUtil.Ctor::getParamCount).contains(0, 2);
      }
  
      @Test
      @SuppressWarnings({"rawtypes", "unchecked"})
      void locatesAnnotatedEnumConstant() {
          Enum<?> annotatedValue = ClassUtil.findFirstAnnotatedEnumValue((Class) Choice.class, Primary.class);
  
          assertThat(annotatedValue).isEqualTo(Choice.FIRST);
      }
  
      @Test
      void reloadsClassMethodsThroughContextLoaderWhenMethodTypesAreInitiallyMissing() throws Exception {
          try {
              ByteArrayClassLoader brokenLoader = new ByteArrayClassLoader(Map.of(HOST_CLASS_NAME, decode(HOST_BYTES)));
              ByteArrayClassLoader completeLoader = new ByteArrayClassLoader(Map.of(
                      HOST_CLASS_NAME, decode(HOST_BYTES),
                      DEPENDENCY_CLASS_NAME, decode(DEPENDENCY_BYTES)));
              Class<?> brokenClass = brokenLoader.loadClass(HOST_CLASS_NAME);
              Thread currentThread = Thread.currentThread();
              ClassLoader originalContextLoader = currentThread.getContextClassLoader();
  
              try {
                  currentThread.setContextClassLoader(completeLoader);
                  Method[] methods = ClassUtil.getClassMethods(brokenClass);
  
                  assertThat(methods).extracting(Method::getName).containsExactly("missing");
                  assertThat(completeLoader.loadedClassNames()).contains(HOST_CLASS_NAME);
              } finally {
                  currentThread.setContextClassLoader(originalContextLoader);
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static byte[] decode(String encodedBytes) {
          return Base64.getDecoder().decode(encodedBytes.replaceAll("\\s", ""));
      }
  
      public static final class DefaultConstructible {
          private final String value;
  
          public DefaultConstructible() {
              this.value = "created";
          }
  
          public String getValue() {
              return value;
          }
      }
  
      public static final class MemberTarget {
          private String name;
          private int count;
  
          public MemberTarget() {
              this("default", 1);
          }
  
          public MemberTarget(String name, int count) {
              this.name = name;
              this.count = count;
          }
  
          public String rename(String newName) {
              this.name = newName;
              return name;
          }
  
          public int count() {
              return count;
          }
      }
  
      public enum Choice {
          @Primary
          FIRST,
          SECOND
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      @Target(ElementType.FIELD)
      public @interface Primary {
      }
  
      private static final class ByteArrayClassLoader extends ClassLoader {
          private final Map<String, byte[]> classBytes;
          private final Map<String, Class<?>> loadedClasses = new HashMap<>();
  
          private ByteArrayClassLoader(Map<String, byte[]> classBytes) {
              super(ClassUtilTest.class.getClassLoader());
              this.classBytes = classBytes;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              Class<?> definedClass = loadedClasses.get(name);
              if (definedClass == null && classBytes.containsKey(name)) {
                  byte[] bytes = classBytes.get(name);
                  definedClass = defineClass(name, bytes, 0, bytes.length);
                  loadedClasses.put(name, definedClass);
              }
              if (definedClass == null) {
                  return super.loadClass(name, resolve);
              }
              if (resolve) {
                  resolveClass(definedClass);
              }
              return definedClass;
          }
  
          private Iterable<String> loadedClassNames() {
              return loadedClasses.keySet();
          }
      }
  }
