EPENDENCY_BYTES)));\n            Class<?> brokenClass = brokenLoader.loadClass(HOST_CLASS_NAME);\n            Thread currentThread = Thread.currentThread();\n            ClassLoader originalContextLoader = currentThread.getContextClassLoader();\n\n            try {\n                currentThread.setContextClassLoader(completeLoader);\n                Method[] methods = ClassUtil.getClassMethods(brokenClass);\n\n                assertThat(methods).extracting(Method::getName).containsExactly(\"missing\");\n                assertThat(completeLoader.loadedClassNames()).contains(HOST_CLASS_NAME);\n            } finally {\n                currentThread.setContextClassLoader(originalContextLoader);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static byte[] decode(String encodedBytes) {\n        return Base64.getDecoder().decode(encodedBytes.replaceAll(\"\\\\s\", \"\"));\n    }\n\n    public static final class DefaultConstructible {\n        private final String value;\n\n        public DefaultConstructible() {\n            this.value = \"created\";\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n\n    public static final class MemberTarget {\n        private String name;\n        private int count;\n\n        public MemberTarget() {\n            this(\"default\", 1);\n        }\n\n        public MemberTarget(String name, int count) {\n            this.name = name;\n            this.count = count;\n        }\n\n        public String rename(String newName) {\n            this.name = newName;\n            return name;\n        }\n\n        public int count() {\n            return count;\n        }\n    }\n\n    public enum Choice {\n        @Primary\n        FIRST,\n        SECOND\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.FIELD)\n    public @interface Primary {\n    }\n\n    private static final class ByteArrayClassLoader extends ClassLoader {\n        private final Map<String, byte[]> classBytes;\n        private final Map<String, Class<?>> loadedClasses = new HashMap<>();\n\n        private ByteArrayClassLoader(Map<String, byte[]> classBytes) {\n            super(ClassUtilTest.class.getClassLoader());\n            this.classBytes = classBytes;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            Class<?> definedClass = loadedClasses.get(name);\n            if (definedClass == null && classBytes.containsKey(name)) {\n                byte[] bytes = classBytes.get(name);\n                definedClass = defineClass(name, bytes, 0, bytes.length);\n                loadedClasses.put(name, definedClass);\n            }\n            if (definedClass == null) {\n                return super.loadClass(name, resolve);\n            }\n            if (resolve) {\n                resolveClass(definedClass);\n            }\n            return definedClass;\n        }\n\n        private Iterable<String> loadedClassNames() {\n            return loadedClasses.keySet();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777809159996}]}
