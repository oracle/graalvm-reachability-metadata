       Enum<?> defaultValue = ClassUtil.findFirstAnnotatedEnumValue(enumClass(Choice.class), DefaultChoice.class);\n\n        assertThat(defaultValue).isEqualTo(Choice.SECOND);\n    }\n", "newText": "    void constructorUtilitiesFindConstructorsAndCreateInstances() {\n        Constructor<ClassUtil> constructor = ClassUtil.findConstructor(ClassUtil.class, true);\n        ClassUtil instance = ClassUtil.createInstance(ClassUtil.class, true);\n        ClassUtil.Ctor[] constructors = ClassUtil.getConstructors(ClassUtil.Ctor.class);\n\n        assertThat(constructor.getParameterCount()).isZero();\n        assertThat(instance).isInstanceOf(ClassUtil.class);\n        assertThat(constructors)\n                .extracting(ClassUtil.Ctor::getParamCount)\n                .containsExactly(1);\n    }\n\n    @Test\n    void declaredMemberUtilitiesReturnFieldsAndMethods() {\n        Field[] fields = ClassUtil.getDeclaredFields(ClassUtil.class);\n        Method[] declaredMethods = ClassUtil.getDeclaredMethods(ClassUtil.class);\n        Method[] classMethods = ClassUtil.getClassMethods(ClassUtil.class);\n\n        assertThat(fields).extracting(Field::getName).contains(\"NO_CTORS\", \"NO_FIELDS\");\n        assertThat(declaredMethods).extracting(Method::getName).contains(\"getDeclaredFields\", \"getDeclaredMethods\");\n        assertThat(classMethods).extracting(Method::getName).contains(\"getClassMethods\", \"getConstructors\");\n    }\n\n    @Test\n    void annotatedEnumLookupInspectsEnumConstantFields() {\n        Enum<?> defaultValue = ClassUtil.findFirstAnnotatedEnumValue(enumClass(JsonParser.Feature.class), Retention.class);\n\n        assertThat(defaultValue).isNull();\n    }\n"}, {"oldText": "\n    public static final class ConstructibleType {\n        public ConstructibleType() {\n        }\n\n        String value() {\n            return \"created\";\n        }\n    }\n\n    public static final class MultiConstructorType {\n        public MultiConstructorType() {\n        }\n\n        public MultiConstructorType(String ignored) {\n        }\n    }\n\n    private static final class IntrospectedType {\n        private final String name = \"example\";\n        private final int count = 1;\n\n        String name() {\n            return name;\n        }\n\n        int count() {\n            return count;\n        }\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    private @interface DefaultChoice {\n    }\n\n    private enum Choice {\n        FIRST,\n        @DefaultChoice\n        SECOND\n    }\n", "newText": "\n"}]}
