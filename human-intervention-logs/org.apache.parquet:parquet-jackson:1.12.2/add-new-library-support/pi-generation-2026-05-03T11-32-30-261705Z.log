              writeUtf8(output, "(I)V");
              output.writeByte(12);
              output.writeShort(5);
              output.writeShort(6);
              output.writeByte(10);
              output.writeShort(4);
              output.writeShort(7);
              output.writeByte(3);
              output.writeInt(Opcodes.ASM10_EXPERIMENTAL);
              writeUtf8(output, "Code");
              writeUtf8(output, "()V");
              writeUtf8(output, "SourceFile");
              writeUtf8(output, "ConstantsPreviewVisitor.java");
              output.writeShort(0x0021);
              output.writeShort(2);
              output.writeShort(4);
              output.writeShort(0);
              output.writeShort(0);
