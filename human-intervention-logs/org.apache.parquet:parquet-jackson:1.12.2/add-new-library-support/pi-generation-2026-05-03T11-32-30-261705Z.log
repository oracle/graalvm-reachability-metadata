  package org_apache_parquet.parquet_jackson;
  
  import java.io.ByteArrayOutputStream;
  import java.io.DataOutputStream;
  import java.io.IOException;
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import shaded.parquet.com.fasterxml.jackson.databind.util.ClassUtil;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatIllegalArgumentException;
  
  public class ClassUtilTest {
      private static final String GENERATED_CLASS_NAME =
              "org_apache_parquet.parquet_jackson.BrokenMethodHolder";
      private static final String GENERATED_INTERNAL_NAME = GENERATED_CLASS_NAME.replace('.', '/');
      private static final String MISSING_DEPENDENCY_INTERNAL_NAME =
              "org_apache_parquet/parquet_jackson/MissingMethodDependency";
  
      @Test
      void constructorUtilitiesFindConstructorsAndCreateInstances() {
          Constructor<ConstructibleType> constructor = ClassUtil.findConstructor(ConstructibleType.class, true);
          ConstructibleType instance = ClassUtil.createInstance(ConstructibleType.class, true);
          ClassUtil.Ctor[] constructors = ClassUtil.getConstructors(MultiConstructorType.class);
  
          assertThat(constructor.getParameterCount()).isZero();
          assertThat(instance.value()).isEqualTo("created");
          assertThat(constructors)
                  .extracting(ClassUtil.Ctor::getParamCount)
                  .containsExactlyInAnyOrder(0, 1);
      }
  
      @Test
      void declaredMemberUtilitiesReturnFieldsAndMethods() {
          Field[] fields = ClassUtil.getDeclaredFields(IntrospectedType.class);
          Method[] declaredMethods = ClassUtil.getDeclaredMethods(IntrospectedType.class);
          Method[] classMethods = ClassUtil.getClassMethods(IntrospectedType.class);
  
          assertThat(fields).extracting(Field::getName).contains("name", "count");
          assertThat(declaredMethods).extracting(Method::getName).contains("name", "count");
          assertThat(classMethods).extracting(Method::getName).contains("name", "count");
      }
  
      @Test
      void annotatedEnumValueIsFoundFromDeclaredFields() {
          Enum<?> defaultValue = ClassUtil.findFirstAnnotatedEnumValue(enumClass(Choice.class), DefaultChoice.class);
  
          assertThat(defaultValue).isEqualTo(Choice.SECOND);
      }
  
      @Test
      void classMethodsFallbackUsesContextClassLoaderWhenMethodTypesAreMissing() throws Exception {
          try {
              BrokenMethodClassLoader classLoader = new BrokenMethodClassLoader();
              Class<?> brokenClass = classLoader.defineBrokenMethodHolder();
              ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
              Thread.currentThread().setContextClassLoader(classLoader);
              try {
                  assertThatIllegalArgumentException()
                          .isThrownBy(() -> ClassUtil.getClassMethods(brokenClass))
                          .withMessageContaining("Failed on call to `getDeclaredMethods()`")
                          .withMessageContaining(GENERATED_CLASS_NAME);
              } finally {
                  Thread.currentThread().setContextClassLoader(originalClassLoader);
              }
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          }
      }
  
      @SuppressWarnings({"unchecked", "rawtypes"})
      private static Class<Enum<?>> enumClass(Class<? extends Enum<?>> enumClass) {
          return (Class) enumClass;
      }
  
      private static byte[] createBrokenMethodHolderBytes() throws IOException {
          ByteArrayOutputStream classBytes = new ByteArrayOutputStream();
          try (DataOutputStream output = new DataOutputStream(classBytes)) {
              output.writeInt(0xCAFEBABE);
              output.writeShort(0);
              output.writeShort(52);
              output.writeShort(14);
              writeUtf8(output, GENERATED_INTERNAL_NAME);
              output.writeByte(7);
              output.writeShort(1);
              writeUtf8(output, "java/lang/Object");
              output.writeByte(7);
              output.writeShort(3);
              writeUtf8(output, "<init>");
              writeUtf8(output, "()V");
              output.writeByte(12);
              output.writeShort(5);
              output.writeShort(6);
              output.writeByte(10);
              output.writeShort(4);
              output.writeShort(7);
              writeUtf8(output, "missingDependency");
              writeUtf8(output, "()L" + MISSING_DEPENDENCY_INTERNAL_NAME + ";");
              writeUtf8(output, "Code");
              writeUtf8(output, "SourceFile");
              writeUtf8(output, "BrokenMethodHolder.java");
              output.writeShort(0x0021);
              output.writeShort(2);
              output.writeShort(4);
              output.writeShort(0);
              output.writeShort(0);
              output.writeShort(2);
              writeDefaultConstructor(output);
              writeMissingDependencyMethod(output);
              output.writeShort(1);
              output.writeShort(12);
              output.writeInt(2);
              output.writeShort(13);
          }
          return classBytes.toByteArray();
      }
  
      private static void writeDefaultConstructor(DataOutputStream output) throws IOException {
          output.writeShort(0x0001);
          output.writeShort(5);
          output.writeShort(6);
          output.writeShort(1);
          output.writeShort(11);
          output.writeInt(17);
          output.writeShort(1);
          output.writeShort(1);
          output.writeInt(5);
          output.writeByte(0x2A);
          output.writeByte(0xB7);
          output.writeShort(8);
          output.writeByte(0xB1);
          output.writeShort(0);
          output.writeShort(0);
      }
  
      private static void writeMissingDependencyMethod(DataOutputStream output) throws IOException {
          output.writeShort(0x0001);
          output.writeShort(9);
          output.writeShort(10);
          output.writeShort(1);
          output.writeShort(11);
          output.writeInt(14);
          output.writeShort(1);
          output.writeShort(1);
          output.writeInt(2);
          output.writeByte(0x01);
          output.writeByte(0xB0);
          output.writeShort(0);
          output.writeShort(0);
      }
  
      private static void writeUtf8(DataOutputStream output, String value) throws IOException {
          output.writeByte(1);
          output.writeUTF(value);
      }
  
      private static void rethrowUnlessUnsupportedFeatureError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static final class BrokenMethodClassLoader extends ClassLoader {
          private BrokenMethodClassLoader() {
              super(ClassUtilTest.class.getClassLoader());
          }
  
          private Class<?> defineBrokenMethodHolder() throws IOException {
              byte[] classBytes = createBrokenMethodHolderBytes();
              return defineClass(GENERATED_CLASS_NAME, classBytes, 0, classBytes.length);
          }
      }
  
      public static final class ConstructibleType {
          public ConstructibleType() {
          }
  
          String value() {
              return "created";
          }
      }
  
      public static final class MultiConstructorType {
          public MultiConstructorType() {
          }
  
          public MultiConstructorType(String ignored) {
          }
      }
  
      private static final class IntrospectedType {
          private final String name = "example";
          private final int count = 1;
  
          String name() {
              return name;
          }
  
          int count() {
              return count;
          }
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      private @interface DefaultChoice {
      }
  
      private enum Choice {
          FIRST,
          @DefaultChoice
          SECOND
      }
  }
