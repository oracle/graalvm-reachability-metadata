r;\nimport shaded.parquet.com.fasterxml.jackson.databind.introspect.AnnotatedMethod;\n\npublic class AnnotatedMethodTest {\n    private static final Class<?>[] NO_PARAMETERS = new Class<?>[0];\n\n    @Test\n    void invokesStaticMethodsViaCallVariants() throws Exception {\n        AnnotatedMethod noArgMethod = staticMethod(\"staticGreeting\", 0);\n        AnnotatedMethod arrayArgMethod = staticMethod(\"staticPair\", 2);\n        AnnotatedMethod oneArgMethod = staticMethod(\"staticTag\", 1);\n\n        assertThat(noArgMethod.call()).isEqualTo(\"hello\");\n        assertThat(arrayArgMethod.call(new Object[] { \"left\", \"right\" })).isEqualTo(\"left:right\");\n        assertThat(oneArgMethod.call1(\"value\")).isEqualTo(\"tag:value\");\n    }\n\n    @Test\n    void invokesInstanceMethodsWithTargetObjectsAndArguments() throws Exception {\n        MethodTarget target = new MethodTarget(\"seed\");\n        AnnotatedMethod noArgMethod = instanceMethod(\"describe\", NO_PARAMETERS);\n        AnnotatedMethod argumentMethod = instanceMethod(\"combine\", String.class, int.class);\n\n        assertThat(noArgMethod.callOn(target)).isEqualTo(\"description:seed\");\n        assertThat(argumentMethod.callOnWith(target, \"branch\", 3)).isEqualTo(\"seed:branch:3\");\n    }\n\n    @Test\n    void getsAndSetsBeanValuesThroughAnnotatedMethods() {\n        MethodTarget target = new MethodTarget(\"initial\");\n        AnnotatedMethod getter = instanceMethod(\"getName\", NO_PARAMETERS);\n        AnnotatedMethod setter = instanceMethod(\"setName\", String.class);\n\n        assertThat(getter.getValue(target)).isEqualTo(\"initial\");\n        setter.setValue(target, \"updated\");\n        assertThat(getter.getValue(target)).isEqualTo(\"updated\");\n    }\n\n    @Test\n    void resolvesMethodAfterJavaSerializationRoundTrip() throws Exception {\n        AnnotatedMethod original = instanceMethod(\"describe\", NO_PARAMETERS);\n\n        AnnotatedMethod restored = serializeAndDeserialize(original);\n\n        assertThat(restored.getName()).isEqualTo(original.getName());\n        assertThat(restored.callOn(new MethodTarget(\"restored\"))).isEqualTo(\"description:restored\");\n    }\n\n    private static AnnotatedMethod instanceMethod(String name, Class<?>... parameterTypes) {\n        AnnotatedMethod method = beanDescription().findMethod(name, parameterTypes);\n\n        assertThat(method).isNotNull();\n        return method;\n    }\n\n    private static AnnotatedMethod staticMethod(String name, int parameterCount) {\n        for (AnnotatedMethod method : beanDescription().getClassInfo().getStaticMethods()) {\n            if (name.equals(method.getName()) && method.getParameterCount() == parameterCount) {\n                return method;\n            }\n        }\n        throw new AssertionError(\"Missing static method \" + name + \" with \" + parameterCount + \" parameters\");\n    }\n\n    private static BeanDescription beanDescription() {\n        ObjectMapper mapper = new ObjectMapper();\n        return mapper.getSerializationConfig().introspect(mapper.constructType(MethodTarget.class));\n    }\n\n    private static AnnotatedMethod serializeAndDeserialize(AnnotatedMethod method) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {\n            objectOutput.writeObject(method);\n        }\n\n        ByteArrayInputStream input = new ByteArrayInputStream(output.toByteArray());\n        try (ObjectInputStream objectInput = new ObjectInputStream(input)) {\n            return (AnnotatedMethod) objectInput.readObject();\n        }\n    }\n\n    public static final class MethodTarget {\n        private String name;\n\n        public MethodTarget() {\n            this(\"default\");\n        }\n\n        MethodTarget(String name) {\n            this.name = name;\n        }\n\n        public static String staticGreeting() {\n            return \"hello\";\n        }\n\n        public static String staticPair(String left, String right) {\n            return left + \":\" + right;\n        }\n\n        public static String staticTag(String value) {\n            return \"tag:\" + value;\n        }\n\n        public String describe() {\n            return \"description:\" + name;\n        }\n\n        public String combine(String label, int count) {\n            return name + \":\" + label + \":\" + count;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.parquet/parquet-jackson/1.12.2/src/test/java/org_apache_parquet/parquet_jackson/AnnotatedMethodTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_parquet.parquet_jackson;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.ObjectInputStream;\\nimport java.io.ObjectOutputStream;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport shaded.parquet.com.fasterxml.jackson.databind.BeanDescription;\\nimport shaded.parquet.com.fasterxml.jackson.databind.ObjectMapper;\\nimport shaded.parquet.com.fasterxml.jackson.databind.introspect.AnnotatedMethod;\\n\\npublic class AnnotatedMethodTest {\\n    private static final Class<?>[] NO_PARAMETERS = new Class<?>[0];\\n\\n    @Test\\n    void invokesStaticMethodsViaCallVariants() throws Exception {\\n        AnnotatedMethod noArgMethod = staticMethod(\\\"staticGreeting\\\", 0);\\n        AnnotatedMethod arrayArgMethod = staticMethod(\\\"staticPair\\\", 2);\\n        AnnotatedMethod oneArgMethod = staticMethod(\\\"staticTag\\\", 1);\\n\\n        assertThat(noArgMethod.call()).isEqualTo(\\\"hello\\\");\\n        assertThat(arrayArgMethod.call(new Object[] { \\\"left\\\", \\\"right\\\" })).isEqualTo(\\\"left:right\\\");\\n        assertThat(oneArgMethod.call1(\\\"value\\\")).isEqualTo(\\\"tag:value\\\");\\n    }\\n\\n    @Test\\n    void invokesInstanceMethodsWithTargetObjectsAndArguments() throws Exception {\\n        MethodTarget target = new MethodTarget(\\\"seed\\\");\\n        AnnotatedMethod noArgMethod = instanceMethod(\\\"describe\\\", NO_PARAMETERS);\\n        AnnotatedMethod argumentMethod = instanceMethod(\\\"combine\\\", String.class, int.class);\\n\\n        assertThat(noArgMethod.callOn(target)).isEqualTo(\\\"description:seed\\\");\\n        assertThat(argumentMethod.callOnWith(target, \\\"branch\\\", 3)).isEqualTo(\\\"seed:branch:3\\\");\\n    }\\n\\n    @Test\\n    void getsAndSetsBeanValuesThroughAnnotatedMethods() {\\n        MethodTarget target = new MethodTarget(\\\"initial\\\");\\n        AnnotatedMethod getter = instanceMethod(\\\"getName\\\", NO_PARAMETERS);\\n        AnnotatedMethod setter = instanceMethod(\\\"setName\\\", String.class);\\n\\n        assertThat(getter.getValue(target)).isEqualTo(\\\"initial\\\");\\n        setter.setValue(target, \\\"updated\\\");\\n        assertThat(getter.getValue(target)).isEqualTo(\\\"updated\\\");\\n    }\\n\\n    @Test\\n    void resolvesMethodAfterJavaSerializationRoundTrip() throws Exception {\\n        AnnotatedMethod original = instanceMethod(\\\"describe\\\", NO_PARAMETERS);\\n\\n        AnnotatedMethod restored = serializeAndDeserialize(original);\\n\\n        assertThat(restored.getName()).isEqualTo(original.getName());\\n        assertThat(restored.callOn(new MethodTarget(\\\"restored\\\"))).isEqualTo(\\\"description:restored\\\");\\n    }\\n\\n    private static AnnotatedMethod instanceMethod(String name, Class<?>... parameterTypes) {\\n        AnnotatedMethod method = beanDescription().findMethod(name, parameterTypes);\\n\\n        assertThat(method).isNotNull();\\n        return method;\\n    }\\n\\n    private static AnnotatedMethod staticMethod(String name, int parameterCount) {\\n        for (AnnotatedMethod method : beanDescription().getClassInfo().getStaticMethods()) {\\n            if (name.equals(method.getName()) && method.getParameterCount() == parameterCount) {\\n                return method;\\n            }\\n        }\\n        throw new AssertionError(\\\"Missing static method \\\" + name + \\\" with \\\" + parameterCount + \\\" parameters\\\");\\n    }\\n\\n    private static BeanDescription beanDescription() {\\n        ObjectMapper mapper = new ObjectMapper();\\n        return mapper.getSerializationConfig().introspect(mapper.constructType(MethodTarget.class));\\n    }\\n\\n    private static AnnotatedMethod serializeAndDeserialize(AnnotatedMethod method) throws Exception {\\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\\n        try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {\\n            objectOutput.writeObject(method);\\n        }\\n\\n        ByteArrayInputStream input = new ByteArrayInputStream(output.toByteArray());\\n        try (ObjectInputStream objectInput = new ObjectInputStream(input)) {\\n            return (AnnotatedMethod) objectInput.readObject();\\n        }\\n    }\\n\\n    public static final class MethodTarget {\\n        private String name;\\n\\n        public MethodTarget() {\\n            this(\\\"default\\\");\\n        }\\n\\n        MethodTarget(String name) {\\n            this.name = name;\\n        }\\n\\n        public static String staticGreeting() {\\n            return \\\"hello\\\";\\n        }\\n\\n        public static String staticPair(String left, String right) {\\n            return left + \\\":\\\" + right;\\n        }\\n\\n        public static String staticTag(String value) {\\n            return \\\"tag:\\\" + value;\\n        }\\n\\n        public String describe() {\\n            return \\\"description:\\\" + name;\\n        }\\n\\n        public String combine(String label, int count) {\\n            return name + \\\":\\\" + label + \\\":\\\" + count;\\n        }\\n\\n        public String getName() {\\n            return name;\\n        }\\n\\n        public void setName(String name) {\\n            this.name = name;\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1950, "output": 2129, "cacheRead": 38912, "cacheWrite": 0, "totalTokens": 42991, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777516168091, "responseId": "resp_0f8b9843540de41f0169f2be88beb481919534378bd293943b"}}
[tool-exec] start id=call_dWy5Oa6HqZSfHutBhYwnisqr|fc_0f8b9843540de41f0169f2be94047081918a000e821a7f623e name=write args={"path": "tests/src/org.apache.parquet/parquet-jackson/1.12.2/src/test/java/org_apache_parquet/parquet_jackson/AnnotatedMethodTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_parquet.parquet_jackson;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.junit.jupiter.api.Test;\n\nimport shaded.parquet.com.fasterxml.jackson.databind.BeanDescription;\nimport shaded.parquet.com.fasterxml.jackson.databind.ObjectMapper;\nimport shaded.parquet.com.fasterxml.jackson.databind.introspect.AnnotatedMethod;\n\npublic class AnnotatedMethodTest {\n    private static final Class<?>[] NO_PARAMETERS = new Class<?>[0];\n\n    @Test\n    void invokesStaticMethodsViaCallVariants() throws Exception {\n        AnnotatedMethod noArgMethod = staticMethod(\"staticGreeting\", 0);\n        AnnotatedMethod arrayArgMethod = staticMethod(\"staticPair\", 2);\n        AnnotatedMethod oneArgMethod = staticMethod(\"staticTag\", 1);\n\n        assertThat(noArgMethod.call()).isEqualTo(\"hello\");\n        assertThat(arrayArgMethod.call(new Object[] { \"left\", \"right\" })).isEqualTo(\"left:right\");\n        assertThat(oneArgMethod.call1(\"value\")).isEqualTo(\"tag:value\");\n    }\n\n    @Test\n    void invokesInstanceMethodsWithTargetObjectsAndArguments() throws Exception {\n        MethodTarget target = new MethodTarget(\"seed\");\n        AnnotatedMethod noArgMethod = instanceMethod(\"describe\", NO_PARAMETERS);\n        AnnotatedMethod argumentMethod = instanceMethod(\"combine\", String.class, int.class);\n\n        assertThat(noArgMethod.callOn(target)).isEqualTo(\"description:seed\");\n        assertThat(argumentMethod.callOnWith(target, \"branch\", 3)).isEqualTo(\"seed:branch:3\");\n    }\n\n    @Test\n    void getsAndSetsBeanValuesThroughAnnotatedMethods() {\n        MethodTarget target = new MethodTarget(\"initial\");\n        AnnotatedMethod getter = instanceMethod(\"getName\", NO_PARAMETERS);\n        AnnotatedMethod setter = instanceMethod(\"setName\", String.class);\n\n        assertThat(getter.getValue(target)).isEqualTo(\"initial\");\n        setter.setValue(target, \"updated\");\n        assertThat(getter.getValue(target)).isEqualTo(\"updated\");\n    }\n\n    @Test\n    void resolvesMethodAfterJavaSerializationRoundTrip() throws Exception {\n        AnnotatedMethod original = instanceMethod(\"describe\", NO_PARAMETERS);\n\n        AnnotatedMethod restored = serializeAndDeserialize(original);\n\n        assertThat(restored.getName()).isEqualTo(original.getName());\n        assertThat(restored.callOn(new MethodTarget(\"restored\"))).isEqualTo(\"description:restored\");\n    }\n\n    private static AnnotatedMethod instanceMethod(String name, Class<?>... parameterTypes) {\n        AnnotatedMethod method = beanDescription().findMethod(name, parameterTypes);\n\n        assertThat(method).isNotNull();\n        return method;\n    }\n\n    private static AnnotatedMethod staticMethod(String name, int parameterCount) {\n        for (AnnotatedMethod method : beanDescription().getClassInfo().getStaticMethods()) {\n            if (name.equals(method.getName()) && method.getParameterCount() == parameterCount) {\n                return method;\n            }\n        }\n        throw new AssertionError(\"Missing static method \" + name + \" with \" + parameterCount + \" parameters\");\n    }\n\n    private static BeanDescription beanDescription() {\n        ObjectMapper mapper = new ObjectMapper();\n        return mapper.getSerializationConfig().introspect(mapper.constructType(MethodTarget.class));\n    }\n\n    private static AnnotatedMethod serializeAndDeserialize(AnnotatedMethod method) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {\n            objectOutput.writeObject(method);\n        }\n\n        ByteArrayInputStream input = new ByteArrayInputStream(output.toByteArray());\n        try (ObjectInputStream objectInput = new ObjectInputStream(input)) {\n            return (AnnotatedMethod) objectInput.readObject();\n        }\n    }\n\n    public static final class MethodTarget {\n        private String name;\n\n        public MethodTarget() {\n            this(\"default\");\n        }\n\n        MethodTarget(String name) {\n            this.name = name;\n        }\n\n        public static String staticGreeting() {\n            return \"hello\";\n        }\n\n        public static String staticPair(String left, String right) {\n            return left + \":\" + right;\n        }\n\n        public static String staticTag(String value) {\n            return \"tag:\" + value;\n        }\n\n        public String describe() {\n            return \"description:\" + name;\n        }\n\n        public String combine(String label, int count) {\n            return name + \":\" + label + \":\" + count;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n    }\n}\n"}
