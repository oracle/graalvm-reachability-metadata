[tool-call] delta {"path":"tests/src/org.apache.parquet/parquet-jackson/1.12.2/src/test/java/org_apache_parquet/parquet_jackson/OptionalHandlerFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_parquet.parquet_jackson;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport javax.xml.namespace.QName;\n\nimport org.junit.jupiter.api.Test;\n\nimport shaded.parquet.com.fasterxml.jackson.databind.ObjectMapper;\n\npublic class OptionalHandlerFactoryTest {\n    private static final ObjectMapper MAPPER = new ObjectMapper();\n\n    @Test\n    void usesOptionalXmlHandlersForQNameRoundTrip() throws Exception {\n        QName name = new QName(\"urn:parquet:test\", \"column\", \"p\");\n\n        String json = MAPPER.writeValueAsString(name);\n        QName roundTripped = MAPPER.readValue(json, QName.class);\n\n        assertThat(json).isEqualTo(\"\\\"{urn:parquet:test}column\\\"\");\n        assertThat(roundTripped).isEqualTo(name);\n        assertThat(roundTripped.getPrefix()).isEmpty();\n    }\n}\n"}
