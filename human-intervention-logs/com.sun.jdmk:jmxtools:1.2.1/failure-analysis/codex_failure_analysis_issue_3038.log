houghtworks.paranamer/paranamer/index.json:16:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/thoughtworks/paranamer/paranamer/$version$/paranamer-$version$-sources.jar\",\nmetadata/com.thoughtworks.paranamer/paranamer/index.json:17:    \"repository-url\" : \"https://github.com/paul-hammant/paranamer\",\nmetadata/com.thoughtworks.paranamer/paranamer/index.json:18:    \"test-code-url\" : \"https://github.com/paul-hammant/paranamer/tree/paranamer-$version$/paranamer/src/test\",\nmetadata/com.thoughtworks.paranamer/paranamer/index.json:19:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/thoughtworks/paranamer/paranamer/$version$/paranamer-$version$-javadoc.jar\",\nmetadata/com.thoughtworks.paranamer/paranamer/index.json:20:    \"description\" : \"ParaNamer is a Java library that exposes constructor and method parameter names at runtime. It can read parameter names from generated metadata, annotations, debug symbols, or bytecode so frameworks can bind arguments without manual name declarations.\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/github/ajalt/mordant/mordant-core-jvm/$version$/mordant-core-jvm-$version$-sources.jar\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:6:    \"repository-url\" : \"https://github.com/ajalt/mordant\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:7:    \"test-code-url\" : \"https://github.com/ajalt/mordant/tree/$version$/mordant/src/jvmTest\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/github/ajalt/mordant/mordant-core-jvm/$version$/mordant-core-jvm-$version$-javadoc.jar\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:9:    \"description\" : \"Mordant Core is a Kotlin multiplatform library for rendering styled terminal output, including ANSI colors, text styling, widgets, 