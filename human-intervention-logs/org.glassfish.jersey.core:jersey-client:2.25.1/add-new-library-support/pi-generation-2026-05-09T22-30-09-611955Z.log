  package org_glassfish_jersey_core.jersey_client;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.HttpURLConnection;
  import java.net.ProtocolException;
  import java.net.URL;
  import java.util.Collections;
  import java.util.List;
  import java.util.Map;
  
  import javax.ws.rs.client.Client;
  import javax.ws.rs.core.Response;
  
  import org.glassfish.jersey.client.ClientConfig;
  import org.glassfish.jersey.client.HttpUrlConnectorProvider;
  import org.glassfish.jersey.client.JerseyClientBuilder;
  import org.junit.jupiter.api.Test;
  
  public class HttpUrlConnectorAnonymous5Test {
      @Test
      void nonStandardHttpMethodUsesHttpUrlConnectionWorkaround() throws Exception {
          RecordingHttpUrlConnection delegate = new RecordingHttpUrlConnection(new URL("http://example.test/delegate"));
          DelegatingRecordingHttpUrlConnection connection = new DelegatingRecordingHttpUrlConnection(
                  new URL("http://example.test/resource"), delegate);
          HttpUrlConnectorProvider connectorProvider = new HttpUrlConnectorProvider()
                  .connectionFactory(url -> connection)
                  .useSetMethodWorkaround();
          Client client = JerseyClientBuilder.createClient(new ClientConfig().connectorProvider(connectorProvider));
  
          try {
              Response response = client.target("http://example.test/resource")
                      .request()
                      .method("PROPFIND");
  
              try {
                  assertThat(response.getStatus()).isEqualTo(HttpURLConnection.HTTP_NO_CONTENT);
                  assertThat(connection.recordedMethod()).isEqualTo("PROPFIND");
                  assertThat(delegate.recordedMethod()).isEqualTo("PROPFIND");
              } finally {
                  response.close();
              }
          } finally {
              client.close();
          }
      }
  
      private static class DelegatingRecordingHttpUrlConnection extends RecordingHttpUrlConnection {
          @SuppressWarnings("unused")
          private final HttpURLConnection delegate;
  
          DelegatingRecordingHttpUrlConnection(URL url, HttpURLConnection delegate) {
              super(url);
              this.delegate = delegate;
          }
      }
  
      private static class RecordingHttpUrlConnection extends HttpURLConnection {
          @SuppressWarnings("unused")
          private String method;
  
          RecordingHttpUrlConnection(URL url) {
              super(url);
          }
  
          String recordedMethod() {
              return method;
          }
  
          @Override
          public void setRequestMethod(String method) throws ProtocolException {
              throw new ProtocolException("Force Jersey's reflective workaround for " + method);
          }
  
          @Override
          public int getResponseCode() {
              return HTTP_NO_CONTENT;
          }
  
          @Override
          public String getResponseMessage() {
              return "No Content";
          }
  
          @Override
          public Map<String, List<String>> getHeaderFields() {
              return Collections.emptyMap();
          }
  
          @Override
          public InputStream getInputStream() throws IOException {
              return new ByteArrayInputStream(new byte[0]);
          }
  
          @Override
          public void disconnect() {
          }
  
          @Override
          public boolean usingProxy() {
              return false;
          }
  
          @Override
          public void connect() throws IOException {
          }
      }
  }
