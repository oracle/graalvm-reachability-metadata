[tool-call] delta {"path":"tests/src/org.glassfish.jersey.core/jersey-client/2.25.1/src/test/java/org_glassfish_jersey_core/jersey_client/HttpUrlConnectorAnonymous5Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jersey_core.jersey_client;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.HttpURLConnection;\nimport java.net.ProtocolException;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collections;\nimport java.util.List;\nimport java.util.Map;\n\nimport javax.ws.rs.client.Client;\nimport javax.ws.rs.client.ClientBuilder;\nimport javax.ws.rs.core.Response;\n\nimport org.glassfish.jersey.client.ClientConfig;\nimport org.glassfish.jersey.client.HttpUrlConnectorProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class HttpUrlConnectorAnonymous5Test {\n    private static final String CUSTOM_METHOD = \"PROPFIND\";\n\n    @Test\n    void customMethodWorkaroundUpdatesConnectionAndDelegate() throws IOException {\n        RecordingConnectionFactory connectionFactory = new RecordingConnectionFactory();\n        HttpUrlConnectorProvider connectorProvider = new HttpUrlConnectorProvider()\n                .connectionFactory(connectionFactory)\n                .useSetMethodWorkaround();\n        ClientConfig clientConfig = new ClientConfig().connectorProvider(connectorProvider);\n        Client client = ClientBuilder.newClient(clientConfig);\n\n        try {\n            Response response = client.target(\"http://example.test/resource\").request().method(CUSTOM_METHOD);\n\n            try {\n                assertThat(response.getStatus()).isEqualTo(HttpURLConnection.HTTP_OK);\n                assertThat(response.readEntity(String.class)).isEqualTo(\"handled\");\n            } finally {\n                response.close();\n            }\n        } finally {\n            client.close();\n        }\n\n        RecordingHttpURLConnection connection = connectionFactory.connection;\n        assertThat(connection.unsupportedMethodAttempts).isEqualTo(2);\n        assertThat(connection.method).isEqualTo(CUSTOM_METHOD);\n        assertThat(connection.delegate.method).isEqualTo(CUSTOM_METHOD);\n    }\n\n    private static final class RecordingConnectionFactory implements HttpUrlConnectorProvider.ConnectionFactory {\n        private RecordingHttpURLConnection connection;\n\n        @Override\n        public HttpURLConnection getConnection(URL url) {\n            connection = new RecordingHttpURLConnection(url, new DelegateHttpURLConnection(url));\n            return connection;\n        }\n    }\n\n    private static final class RecordingHttpURLConnection extends HttpURLConnection {\n        private final DelegateHttpURLConnection delegate;\n        private String method;\n        private int unsupportedMethodAttempts;\n\n        private RecordingHttpURLConnection(URL url, DelegateHttpURLConnection delegate) {\n            super(url);\n            this.delegate = delegate;\n        }\n\n        @Override\n        public void setRequestMethod(String method) throws ProtocolException {\n            if (CUSTOM_METHOD.equals(method)) {\n                unsupportedMethodAttempts++;\n                throw new ProtocolException(\"Unsupported method: \" + method);\n            }\n            this.method = method;\n        }\n\n        @Override\n        public String getRequestMethod() {\n            return method;\n        }\n\n        @Override\n        public int getResponseCode() {\n            return HTTP_OK;\n        }\n\n        @Override\n        public String getResponseMessage() {\n            return \"OK\";\n        }\n\n        @Override\n        public Map<String, List<String>> getHeaderFields() {\n            return Collections.emptyMap();\n        }\n\n        @Override\n        public InputStream getInputStream() {\n            return new ByteArrayInputStream(\"handled\".getBytes(StandardCharsets.UTF_8));\n        }\n\n        @Override\n        public void disconnect() {\n            connected = false;\n        }\n\n        @Override\n        public boolean usingProxy() {\n            return false;\n        }\n\n        @Override\n        public void connect() {\n            connected = true;\n        }\n    }\n\n    private static final class DelegateHttpURLConnection extends HttpURLConnection {\n        private String method;\n\n        private DelegateHttpURLConnection(URL url) {\n            super(url);\n        }\n\n        @Override\n        public void setRequestMethod(String method) {\n            this.method = method;\n        }\n\n        @Override\n        public String getRequestMethod() {\n            return method;\n        }\n\n        @Override\n        public void disconnect() {\n            connected = false;\n        }\n\n        @Override\n        public boolean usingProxy() {\n            return false;\n        }\n\n        @Override\n        public void connect() {\n            connected = true;\n        }\n    }\n}\n"}
