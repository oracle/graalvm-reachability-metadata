  package com_typesafe_play.play_3
  
  import java.util.concurrent.atomic.AtomicBoolean
  
  import scala.concurrent.ExecutionContext
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import play.api.http.DefaultFileMimeTypes
  import play.api.http.FileMimeTypes
  import play.api.http.FileMimeTypesConfiguration
  import play.api.http.HeaderNames.CONTENT_DISPOSITION
  import play.api.mvc.Result
  import play.api.mvc.Results
  
  class ResultsInnerStatusTest {
    @Test
    def sendResourceLoadsClasspathResourceFromProvidedClassLoader(): Unit = {
      implicit val executionContext: ExecutionContext = ExecutionContext.global
      implicit val fileMimeTypes: FileMimeTypes = new DefaultFileMimeTypes(
        FileMimeTypesConfiguration(Map("txt" -> "text/plain"))
      )
      val onCloseCalled: AtomicBoolean = new AtomicBoolean(false)
      val resourceName: String = "results-status/classpath-resource.txt"
  
      val result: Result = Results.Ok.sendResource(
        resourceName,
        getClass.getClassLoader,
        inline = false,
        fileName = _ => Some("download.txt"),
        onClose = () => onCloseCalled.set(true)
      )
  
      assertThat(result.header.status).isEqualTo(200)
      assertThat(result.body.contentType).isEqualTo(Some("text/plain"))
      assertThat(result.body.contentLength.exists(_ > 0)).isTrue
      assertThat(result.header.headers(CONTENT_DISPOSITION)).contains("attachment").contains("download.txt")
      assertThat(onCloseCalled.get()).isFalse
    }
  }
