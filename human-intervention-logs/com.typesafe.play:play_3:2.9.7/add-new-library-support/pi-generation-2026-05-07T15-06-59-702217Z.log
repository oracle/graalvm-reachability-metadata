  package com_typesafe_play.play_3
  
  import org.assertj.core.api.Assertions.assertThat
  import org.assertj.core.api.Assertions.catchThrowable
  import org.junit.jupiter.api.Test
  import play.api.Configuration
  import play.api.Environment
  import play.api.PlayException
  import play.api.inject.Modules
  
  class ModulesTest {
    @Test
    def attemptsToLoadConfiguredModuleByClassName(): Unit = {
      val moduleClassName: String = "com_typesafe_play.play_3.LocatedUnsupportedConstructorModule"
      val reachableModule: LocatedUnsupportedConstructorModule = new LocatedUnsupportedConstructorModule("reachable")
      assertThat(reachableModule.marker).isEqualTo("reachable")
      assertThat(classOf[LocatedUnsupportedConstructorModule].getName).isEqualTo(moduleClassName)
  
      val classLoader: ClassLoader = new LocatedModuleClassLoader(getClass.getClassLoader, moduleClassName)
      val environment: Environment = Environment.simple().copy(classLoader = classLoader)
      val configuration: Configuration = Configuration.from(
        Map(
          "play.modules.enabled" -> Seq(moduleClassName),
          "play.modules.disabled" -> Seq("Module")
        )
      )
  
      val thrown: Throwable = catchThrowable(() => {
        Modules.locate(environment, configuration)
        ()
      })
  
      assertThat(thrown).isInstanceOf(classOf[PlayException])
      assertThat(thrown.asInstanceOf[PlayException].title).isEqualTo("No valid constructors")
      assertThat(thrown.asInstanceOf[PlayException].description).contains(moduleClassName)
    }
  }
  
  final class LocatedUnsupportedConstructorModule(val marker: String)
  
  final class LocatedModuleClassLoader(parent: ClassLoader, moduleClassName: String) extends ClassLoader(parent) {
    override def loadClass(name: String): Class[?] = {
      if (name == moduleClassName) classOf[LocatedUnsupportedConstructorModule]
      else super.loadClass(name)
    }
  }
