[tool-call] delta {"path":"tests/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/DefaultMessagesApiProviderTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_play.play_3\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport play.api.Configuration\nimport play.api.Environment\nimport play.api.http.HttpConfiguration\nimport play.api.i18n.DefaultLangs\nimport play.api.i18n.DefaultMessagesApiProvider\nimport play.api.i18n.Lang\nimport play.api.i18n.MessagesApi\n\nclass DefaultMessagesApiProviderTest {\n  @Test\n  def loadsMessageResourcesThroughEnvironmentClassLoader(): Unit = {\n    val configuration: Configuration = Configuration\n      .from(Map(\"play.i18n.path\" -> \"test-messages\"))\n      .withFallback(Configuration.reference)\n    val environment: Environment = Environment.simple().copy(classLoader = getClass.getClassLoader)\n    val langs: DefaultLangs = new DefaultLangs(Seq(Lang(\"en\")))\n    val messagesApi: MessagesApi = new DefaultMessagesApiProvider(\n      environment,\n      configuration,\n      langs,\n      HttpConfiguration()\n    ).get\n\n    implicit val lang: Lang = Lang(\"en\")\n    assertThat(messagesApi(\"test.english\")).isEqualTo(\"English message loaded from test resources\")\n    assertThat(messagesApi(\"test.default\")).isEqualTo(\"Default message loaded from test resources\")\n    assertThat(messagesApi.messages.get(\"en\").exists(_.contains(\"test.english\"))).isTrue\n    assertThat(messagesApi.messages.get(\"default\").exists(_.contains(\"test.default\"))).isTrue\n  }\n}\n"}
[tool-call] end id=call_0x23mUWLaDuKnlonUMmSaChX|fc_04a0b7b477528f8a0169fcb4ece9008190a208cc211e444b65 name=write args={"path": "tests/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/DefaultMessagesApiProviderTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_play.play_3\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport play.api.Configuration\nimport play.api.Environment\nimport play.api.http.HttpConfiguration\nimport play.api.i18n.DefaultLangs\nimport play.api.i18n.DefaultMessagesApiProvider\nimport play.api.i18n.Lang\nimport play.api.i18n.MessagesApi\n\nclass DefaultMessagesApiProviderTest {\n  @Test\n  def loadsMessageResourcesThroughEnvironmentClassLoader(): Unit = {\n    val configuration: Configuration = Configuration\n      .from(Map(\"play.i18n.path\" -> \"test-messages\"))\n      .withFallback(Configuration.reference)\n    val environment: Environment = Environment.simple().copy(classLoader = getClass.getClassLoader)\n    val langs: DefaultLangs = new DefaultLangs(Seq(Lang(\"en\")))\n    val messagesApi: MessagesApi = new DefaultMessagesApiProvider(\n      environment,\n      configuration,\n      langs,\n      HttpConfiguration()\n    ).get\n\n    implicit val lang: Lang = Lang(\"en\")\n    assertThat(messagesApi(\"test.english\")).isEqualTo(\"English message loaded from test resources\")\n    assertThat(messagesApi(\"test.default\")).isEqualTo(\"Default message loaded from test resources\")\n    assertThat(messagesApi.messages.get(\"en\").exists(_.contains(\"test.english\"))).isTrue\n    assertThat(messagesApi.messages.get(\"default\").exists(_.contains(\"test.default\"))).isTrue\n  }\n}\n"}
