n    implicit val lang: Lang = Lang(\"en\")\n    assertThat(messagesApi(\"test.english\")).isEqualTo(\"English message loaded from test resources\")\n    assertThat(messagesApi(\"test.default\")).isEqualTo(\"Default message loaded from test resources\")\n    assertThat(messagesApi.messages.get(\"en\").exists(_.contains(\"test.english\"))).isTrue\n    assertThat(messagesApi.messages.get(\"default\").exists(_.contains(\"test.default\"))).isTrue\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 602, "output": 963, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 28189, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778169060135, "responseId": "resp_04a0b7b477528f8a0169fcb4e64e1481908123ab3a5586c6e6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0x23mUWLaDuKnlonUMmSaChX|fc_04a0b7b477528f8a0169fcb4ece9008190a208cc211e444b65", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1579 bytes to tests/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/DefaultMessagesApiProviderTest.scala"}], "isError": false, "timestamp": 1778169071588}]}
