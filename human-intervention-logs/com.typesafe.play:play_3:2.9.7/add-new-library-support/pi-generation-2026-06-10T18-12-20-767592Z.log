 Map[String, String]\n  ): Unit = {}\n\n  override def configure(properties: Map[String, String], config: Option[URL]): Unit = {}\n\n  override def loggerFactory: ILoggerFactory = LoggerFactory.getILoggerFactory\n\n  override def shutdown(): Unit = {}\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3948, "output": 909, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 22777, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781115076315, "responseId": "resp_0c02c79e7d5b8b09016a29a8c5120081978d6385e35c6c3b2f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ziWSqw0MzrAarACr63oD96Gq|fc_0c02c79e7d5b8b09016a29a8d320d48197a0522cad34e4eb3b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1413 bytes to tests/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/LoggerConfiguratorTest.scala"}], "isError": false, "timestamp": 1781115092924}]}
