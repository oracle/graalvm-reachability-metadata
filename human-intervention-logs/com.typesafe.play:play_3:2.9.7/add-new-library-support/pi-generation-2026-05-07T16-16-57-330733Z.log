  package com_typesafe_play.play_3
  
  import java.util.Optional
  import java.util.concurrent.TimeUnit
  
  import scala.concurrent.Await
  import scala.concurrent.duration.Duration
  
  import akka.actor.ActorSystem
  import akka.stream.Materializer
  import akka.stream.SystemMaterializer
  import akka.util.ByteString
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import play.mvc.Http.HeaderNames.CONTENT_DISPOSITION
  import play.api.http.DefaultFileMimeTypes
  import play.api.http.FileMimeTypesConfiguration
  import play.mvc.FileMimeTypes
  import play.mvc.Result
  import play.mvc.Results
  
  class StatusHeaderTest {
    @Test
    def sendResourceReadsClasspathResourceFromProvidedClassLoader(): Unit = {
      val actorSystem: ActorSystem = ActorSystem.create("status-header-test")
  
      try {
        val materializer: Materializer = SystemMaterializer.get(actorSystem).materializer()
        val fileMimeTypes: FileMimeTypes = new FileMimeTypes(
          new DefaultFileMimeTypes(FileMimeTypesConfiguration(Map("txt" -> "text/plain")))
        )
        val resourceName: String = "status-header/classpath-resource.txt"
        val result: Result = Results
          .ok()
          .sendResource(
            resourceName,
            getClass.getClassLoader,
            false,
            Optional.of("download.txt"),
            fileMimeTypes
          )
  
        val bytes: ByteString = result.body().consumeData(materializer).toCompletableFuture.get(10, TimeUnit.SECONDS)
  
        assertThat(result.status()).isEqualTo(200)
        assertThat(result.contentType()).hasValue("text/plain")
        assertThat(result.header(CONTENT_DISPOSITION).orElse("")).contains("attachment").contains("download.txt")
        assertThat(bytes.utf8String).isEqualTo("status header resource payload\n")
      } finally {
        Await.result(actorSystem.terminate(), Duration(10, TimeUnit.SECONDS))
      }
    }
  }
