tains(\"download.txt\")\n      assertThat(bytes.utf8String).isEqualTo(\"status header resource payload\\n\")\n    } finally {\n      Await.result(actorSystem.terminate(), Duration(10, TimeUnit.SECONDS))\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1778170574183}]}
