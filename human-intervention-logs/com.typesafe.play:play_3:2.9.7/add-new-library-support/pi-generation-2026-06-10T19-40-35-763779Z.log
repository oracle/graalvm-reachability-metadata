  package com_typesafe_play.play_3
  
  import java.net.URL
  import java.net.URLConnection
  import java.net.URLStreamHandler
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import play.utils.Resources
  
  class ResourcesTest {
    @Test
    def detectsBundleResourceFileIsNotADirectoryWithClassLoaderResourceLookups(): Unit = {
      val bundleResourceUrl: URL = new URL(
        "bundle",
        "",
        -1,
        "logger-configurator.properties",
        new NoOpUrlStreamHandler
      )
  
      val isDirectory: Boolean = Resources.isDirectory(getClass.getClassLoader, bundleResourceUrl)
  
      assertThat(isDirectory).isFalse()
    }
  }
  
  private final class NoOpUrlStreamHandler extends URLStreamHandler {
    override protected def openConnection(url: URL): URLConnection = new URLConnection(url) {
      override def connect(): Unit = {}
    }
  }
