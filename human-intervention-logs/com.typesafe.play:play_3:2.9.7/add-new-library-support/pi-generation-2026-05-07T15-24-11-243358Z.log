  package com_typesafe_play.play_3
  
  import scala.reflect.ClassTag
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import play.api.Configuration
  import play.api.Environment
  import play.api.http.EnabledFilters
  import play.api.inject.BindingKey
  import play.api.inject.Injector
  import play.api.mvc.EssentialAction
  import play.api.mvc.EssentialFilter
  
  class EnabledFiltersTest {
    @Test
    def loadsConfiguredFilterClassNamesFromEnvironmentClassLoader(): Unit = {
      val filterClassName: String = classOf[ConfiguredEssentialFilter].getName
      val configuration: Configuration = Configuration.from(
        Map(
          "play.filters.enabled" -> Seq(filterClassName),
          "play.filters.disabled" -> Seq.empty[String]
        )
      )
  
      val filterInstance: ConfiguredEssentialFilter = new ConfiguredEssentialFilter
      val injector: ConfiguredFilterInjector = new ConfiguredFilterInjector(filterInstance)
  
      val environment: Environment = Environment.simple().copy(classLoader = getClass.getClassLoader)
      val enabledFilters: EnabledFilters = new EnabledFilters(environment, configuration, injector)
  
      assertThat(enabledFilters.filters).hasSize(1)
      assertThat(enabledFilters.filters.head).isSameAs(filterInstance)
    }
  }
  
  final class ConfiguredEssentialFilter extends EssentialFilter {
    override def apply(next: EssentialAction): EssentialAction = next
  }
  
  final class ConfiguredFilterInjector(filterInstance: ConfiguredEssentialFilter) extends Injector {
    override def instanceOf[T](implicit classTag: ClassTag[T]): T = instanceOf(classTag.runtimeClass.asInstanceOf[Class[T]])
  
    override def instanceOf[T](clazz: Class[T]): T = {
      assertThat(clazz).isEqualTo(classOf[ConfiguredEssentialFilter])
      filterInstance.asInstanceOf[T]
    }
  
    override def instanceOf[T](key: BindingKey[T]): T = instanceOf(key.clazz)
  }
