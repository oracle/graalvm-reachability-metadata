ssertThat\nimport org.assertj.core.api.Assertions.catchThrowable\nimport org.junit.jupiter.api.Test\nimport play.api.Configuration\nimport play.api.Environment\nimport play.api.PlayException\nimport play.api.inject.Modules\n\nclass ModulesTest {\n  @Test\n  def attemptsToLoadConfiguredModuleByClassName(): Unit = {\n    val moduleClassName: String = \"com_typesafe_play.play_3.LocatedUnsupportedConstructorModule\"\n    val reachableModule: LocatedUnsupportedConstructorModule = new LocatedUnsupportedConstructorModule(\"reachable\")\n    assertThat(reachableModule.marker).isEqualTo(\"reachable\")\n    assertThat(classOf[LocatedUnsupportedConstructorModule].getName).isEqualTo(moduleClassName)\n\n    val classLoader: ClassLoader = new LocatedModuleClassLoader(getClass.getClassLoader, moduleClassName)\n    val environment: Environment = Environment.simple().copy(classLoader = classLoader)\n    val configuration: Configuration = Configuration.from(\n      Map(\n        \"play.modules.enabled\" -> Seq(moduleClassName),\n        \"play.modules.disabled\" -> Seq(\"Module\")\n      )\n    )\n\n    val thrown: Throwable = catchThrowable(() => {\n      Modules.locate(environment, configuration)\n      ()\n    })\n\n    assertThat(thrown).isInstanceOf(classOf[PlayException])\n    assertThat(thrown.asInstanceOf[PlayException].title).isEqualTo(\"No valid constructors\")\n    assertThat(thrown.asInstanceOf[PlayException].description).contains(moduleClassName)\n  }\n}\n\nfinal class LocatedUnsupportedConstructorModule(val marker: String)\n\nfinal class LocatedModuleClassLoader(parent: ClassLoader, moduleClassName: String) extends ClassLoader(parent) {\n  override def loadClass(name: String): Class[?] = {\n    if (name == moduleClassName) classOf[LocatedUnsupportedConstructorModule]\n    else super.loadClass(name)\n  }\n}\n"}], "isError": false, "timestamp": 1778167344381}, {"role": "toolResult", "toolCallId": "call_2s95jB5ocezG7LRIq1SoANwS|fc_06d30d3aaf5c6ef80169fcae300f40819792894863