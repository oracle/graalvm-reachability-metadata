  package com_typesafe_play.play_3
  
  import scala.concurrent.ExecutionContext
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import play.api.http.HttpConfiguration
  import play.api.mvc.Handler
  import play.api.routing.HandlerDef
  import play.core.j.JavaContextComponents
  import play.core.j.JavaHandler
  import play.core.j.JavaHandlerComponents
  import play.core.routing.HandlerInvokerFactory
  import play.mvc.Action
  import play.mvc.BodyParser
  import play.mvc.Http
  import play.mvc.Result
  import play.mvc.Results
  
  class HandlerInvokerFactoryTest {
    private val components: JavaHandlerComponents = new MinimalJavaHandlerComponents
  
    @Test
    def loadsRootPrefixedControllerClassForJavaActionAnnotations(): Unit = {
      val handler: Handler = createJavaResultHandler(
        controller = "_root_.com_typesafe_play.play_3.HandlerInvokerFactoryRootController",
        routerPackage = "",
        method = "index"
      )
  
      assertThat(handler).isNotNull
    }
  
    @Test
    def loadsControllerClassRelativeToRouterPackageForJavaActionAnnotations(): Unit = {
      val handler: Handler = createJavaResultHandler(
        controller = "HandlerInvokerFactoryRelativeController",
        routerPackage = "com_typesafe_play.play_3",
        method = "show"
      )
  
      assertThat(handler).isNotNull
    }
  
    private def createJavaResultHandler(controller: String, routerPackage: String, method: String): Handler = {
      val handlerDef: HandlerDef = HandlerDef(
        classLoader = getClass.getClassLoader,
        routerPackage = routerPackage,
        controller = controller,
        method = method,
        parameterTypes = Seq.empty,
        verb = "GET",
        path = "/"
      )
  
      val javaHandler: JavaHandler = HandlerInvokerFactory
        .wrapJava
        .createInvoker(Results.ok(), handlerDef)
        .call(Results.ok())
        .asInstanceOf[JavaHandler]
  
      javaHandler.withComponents(components)
    }
  }
  
  class MinimalJavaHandlerComponents extends JavaHandlerComponents {
    override def getBodyParser[A <: BodyParser[_]](parserClass: Class[A]): A = null.asInstanceOf[A]
  
    override def getAction[A <: Action[_]](actionClass: Class[A]): A =
