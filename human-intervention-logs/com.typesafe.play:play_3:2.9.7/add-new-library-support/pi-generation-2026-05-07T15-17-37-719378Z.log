ts/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/HandlerInvokerFactoryTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_play.play_3\n\nimport scala.concurrent.ExecutionContext\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport play.api.http.HttpConfiguration\nimport play.api.mvc.Handler\nimport play.api.routing.HandlerDef\nimport play.core.j.JavaContextComponents\nimport play.core.j.JavaHandler\nimport play.core.j.JavaHandlerComponents\nimport play.core.routing.HandlerInvokerFactory\nimport play.mvc.Action\nimport play.mvc.BodyParser\nimport play.mvc.Http\nimport play.mvc.Result\nimport play.mvc.Results\n\nclass HandlerInvokerFactoryTest {\n  private val components: JavaHandlerComponents = new MinimalJavaHandlerComponents\n\n  @Test\n  def loadsRootPrefixedControllerClassForJavaActionAnnotations(): Unit = {\n    val handler: Handler = createJavaResultHandler(\n      controller = \"_root_.com_typesafe_play.play_3.HandlerInvokerFactoryRootController\",\n      routerPackage = \"\",\n      method = \"index\"\n    )\n\n    assertThat(handler).isNotNull\n  }\n\n  @Test\n  def loadsControllerClassRelativeToRouterPackageForJavaActionAnnotations(): Unit = {\n    val handler: Handler = createJavaResultHandler(\n      controller = \"HandlerInvokerFactoryRelativeController\",\n      routerPackage = \"com_typesafe_play.play_3\",\n      method = \"show\"\n    )\n\n    assertThat(handler).isNotNull\n  }\n\n  private def createJavaResultHandler(controller: String, routerPackage: String, method: String): Handler = {\n    val handlerDef: HandlerDef = HandlerDef(\n      classLoader = getClass.getClassLoader,\n      routerPackage = routerPackage,\n      controller = controller,\n      method = method,\n      parameterTypes = Seq.empty,\n      verb = \"GET\",\n      path = \"/\"\n    )\n\n    val javaHandler: JavaHandler = HandlerInvokerFactory\n      .wrapJava\n      .createInvoker(Results.ok(), handlerDef)\n      .call(Results.ok())\n      .asInstanceOf[JavaHandler]\n\n    javaHandler.withComponents(components)\n  }\n}\n\nclass MinimalJavaHandlerComponents extends JavaHandlerComponents {\n  override def getBodyParser[A <: BodyParser[_]](parserClass: Class[A]): A = null.asInstanceOf[A]\n\n  override def getAction[A <: Action[_]](actionClass: Class[A]): A =\n    throw new UnsupportedOperationException(\"Action creation is not needed for annotation loading\")\n\n  override def actionCreator: play.http.ActionCreator =\n    throw new UnsupportedOperationException(\"ActionCreator is not needed for annotation loading\")\n\n  override def httpConfiguration: HttpConfiguration = HttpConfiguration()\n\n  override def executionContext: ExecutionContext = ExecutionContext.parasitic\n\n  override def contextComponents: JavaContextComponents =\n    throw new UnsupportedOperationException(\"JavaContextComponents are not needed for annotation loading\")\n}\n\nclass HandlerInvokerFactoryRootController {\n  @BodyParser.Of(classOf[HandlerInvokerFactoryDeclaredBodyParser])\n  def index(): Result = Results.ok()\n}\n\nclass HandlerInvokerFactoryRelativeController {\n  @BodyParser.Of(classOf[HandlerInvokerFactoryDeclaredBodyParser])\n  def show(): Result = Results.ok()\n}\n\nclass HandlerInvokerFactoryDeclaredBodyParser extends BodyParser[Object] {\n  override def apply(request: Http.RequestHeader): play.libs.streams.Accumulator[akka.util.ByteString, play.libs.F.Either[Result, Object]] =\n    throw new UnsupportedOperationException(\"Body parsing is not needed for annotation loading\")\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 382, "output": 1298, "cacheRead": 20992, "cacheWrite": 0, "totalTokens": 22672, "cost": {"input": 0, "output": 0, "cac