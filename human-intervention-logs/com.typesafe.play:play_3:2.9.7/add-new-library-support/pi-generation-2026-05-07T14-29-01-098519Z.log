     */
    static boolean setAccessibleWorkaround(final AccessibleObject o) {
      if (o == null || o.isAccessible()) {
        return false;
      }
      final Member m = (Member) o;
      if (!o.isAccessible()
          && Modifier.isPublic(m.getModifiers())
          && isPackageAccess(m.getDeclaringClass().getModifiers())) {
