  package controllers
  
  import java.util.concurrent.atomic.AtomicInteger
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import play.api.Application as ScalaApplication
  import play.api.ApplicationLoader as ScalaApplicationLoader
  import play.api.Configuration
  import play.api.Environment
  import play.api.inject.DefaultApplicationLifecycle
  import play.Application as JavaApplication
  import play.ApplicationLoader as JavaApplicationLoader
  
  class ApplicationLoaderTest {
    @Test
    def instantiatesConfiguredScalaApplicationLoader(): Unit = {
      ConfiguredScalaApplicationLoader.constructionCount.set(0)
  
      val loader: ScalaApplicationLoader = ScalaApplicationLoader(contextFor(classOf[ConfiguredScalaApplicationLoader].getName))
  
      assertThat(loader).isInstanceOf(classOf[ConfiguredScalaApplicationLoader])
      assertThat(ConfiguredScalaApplicationLoader.constructionCount.get()).isEqualTo(1)
    }
  
    @Test
    def instantiatesConfiguredJavaApplicationLoaderAndAdaptsIt(): Unit = {
      ConfiguredJavaApplicationLoader.constructionCount.set(0)
  
      val loader: ScalaApplicationLoader = ScalaApplicationLoader(contextFor(classOf[ConfiguredJavaApplicationLoader].getName))
  
      assertThat(loader.getClass.getName).contains("JavaApplicationLoaderAdapter")
      assertThat(ConfiguredJavaApplicationLoader.constructionCount.get()).isEqualTo(1)
    }
  
    private def contextFor(loaderClassName: String): ScalaApplicationLoader.Context = {
      val environment: Environment = Environment.simple()
      val configuration: Configuration = Configuration.from(Map("play.application.loader" -> loaderClassName))
      ScalaApplicationLoader.Context(
        environment = environment,
        initialConfiguration = configuration,
        lifecycle = new DefaultApplicationLifecycle(),
        devContext = None
      )
    }
  }
  
  object ConfiguredScalaApplicationLoader {
    val constructionCount: AtomicInteger = new AtomicInteger(0)
  }
  
  class ConfiguredScalaApplicationLoader extends ScalaApplicationLoader {
    ConfiguredScalaApplicationLoader.constructionCount.incrementAndGet()
  
    override def load(context: ScalaApplicationLoader.Context): ScalaApplication = {
      throw new AssertionError("The test only verifies ApplicationLoader instantiation.")
    }
  }
  
  object ConfiguredJavaApplicationLoader {
    val constructionCount: AtomicInteger = new AtomicInteger(0)
  }
  
  class ConfiguredJavaApplicationLoader extends JavaApplicationLoader {
    ConfiguredJavaApplicationLoader.constructionCount.incrementAndGet()
  
    override def load(context: JavaApplicationLoader.Context): JavaApplication = {
      throw new AssertionError("The test only verifies ApplicationLoader instantiation.")
    }
  }
