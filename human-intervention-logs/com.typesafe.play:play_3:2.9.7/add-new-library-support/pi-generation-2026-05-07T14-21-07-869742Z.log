thBindableAnonymous12Test {\n  @Test\n  def bindsAndCreatesJavascriptUnbinderForJavaPathBindable(): Unit = {\n    val binder: PathBindable[TestJavaPathValue] = PathBindable.javaPathBindable[TestJavaPathValue]\n\n    val bound: Either[String, TestJavaPathValue] = binder.bind(\"slug\", \"play-framework\")\n\n    assertThat(bound.isRight).isTrue()\n    val value: TestJavaPathValue = bound.toOption.get\n    assertThat(value.unbind(\"slug\")).isEqualTo(\"slug=play-framework\")\n    assertThat(binder.unbind(\"slug\", value)).isEqualTo(\"slug=play-framework\")\n    assertThat(binder.javascriptUnbind).isEqualTo(\"function(k,v){return v.unbind(k)}\")\n  }\n}\n\nclass TestJavaPathValue extends play.mvc.PathBindable[TestJavaPathValue] {\n  private var rendered: String = _\n\n  override def bind(key: String, txt: String): TestJavaPathValue = {\n    rendered = s\"$key=$txt\"\n    this\n  }\n\n  override def unbind(key: String): String = rendered\n\n  override def javascriptUnbind(): String = \"function(k,v){return v.unbind(k)}\"\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1838, "output": 945, "cacheRead": 12288, "cacheWrite": 0, "totalTokens": 15071, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778163645957, "responseId": "resp_0fbe1b84122c59700169fc9fbe9a108191afbde9021f6798b8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_aQ3jU6KkhSBaEddPwyEmeYA1|fc_0fbe1b84122c59700169fc9fc835548191ac31e7e1d6b3856e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1354 bytes to tests/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/PathBindableAnonymous12Test.scala"}], "isError": false, "timestamp": 1778163659185}]}
