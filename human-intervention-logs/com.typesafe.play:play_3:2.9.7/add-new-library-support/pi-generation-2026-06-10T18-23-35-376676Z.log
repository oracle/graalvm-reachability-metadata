umberFormat.getInstance()); os.add(DateFormat.getInstance()); os.add(Collator.getInstance()); os.add(BreakIterator.getWordInstance()); os.add(DateTimeFormatter.ISO_DATE.parse(\"2020-01-01\")); os.add(Pattern.compile(\"a\").matcher(\"a\"));\n os.add(Charset.defaultCharset().newEncoder()); os.add(MessageDigest.getInstance(\"SHA-256\")); os.add(KeyPairGenerator.getInstance(\"RSA\")); os.add(Cipher.getInstance(\"AES\")); os.add(DocumentBuilderFactory.newInstance()); os.add(SAXParserFactory.newInstance());\n for(Object o:os){try{scan(o);}catch(Throwable t){System.err.println(\"err \"+o+\" \"+t);}}\n }\n}\nEOF\njavac /tmp/Scan.java && java -cp /tmp Scan", "timeout": 30}
