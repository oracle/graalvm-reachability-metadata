uting\")).isEqualTo(\"interface:routing\")\n  }\n\n  @Test\n  def resolvesAccessibleMethodFromPublicSuperclassOfNonPublicClass(): Unit = {\n    val implementation: PublicSuperclassTarget = new PrivateSuperclassBackedTarget\n    val method: Method = classOf[PrivateSuperclassBackedTarget]\n      .getMethod(\"fromSuperclass\", classOf[String])\n\n    val accessibleMethod: Method = MethodUtils.getAccessibleMethod(method)\n\n    assertThat(accessibleMethod).isNotNull\n    assertThat(Modifier.isPublic(accessibleMethod.getDeclaringClass.getModifiers)).isTrue\n    assertThat(accessibleMethod.getDeclaringClass).isEqualTo(classOf[PublicSuperclassTarget])\n    assertThat(accessibleMethod.invoke(implementation, \"configuration\"))\n      .isEqualTo(\"private:configuration\")\n  }\n}\n\nclass DirectMethodTarget {\n  def exact(value: String): String = s\"exact:$value\"\n}\n\nclass AssignableMethodTarget {\n  def accept(value: CharSequence): String = s\"accepted:$value\"\n}\n\ntrait InterfaceBackedTarget {\n  def describe(value: String): String\n}\n\nprivate final class PrivateInterfaceBackedTarget extends InterfaceBackedTarget {\n  override def describe(value: String): String = s\"interface:$value\"\n}\n\nclass PublicSuperclassTarget {\n  def fromSuperclass(value: String): String = s\"super:$value\"\n}\n\nprivate final class PrivateSuperclassBackedTarget extends PublicSuperclassTarget {\n  override def fromSuperclass(value: String): String = s\"private:$value\"\n}\n"}], "isError": false, "timestamp": 1781115742248}}
