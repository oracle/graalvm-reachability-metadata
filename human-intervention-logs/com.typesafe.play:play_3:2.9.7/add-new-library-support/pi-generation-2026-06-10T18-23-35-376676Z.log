eturn; for(Method m:c.getMethods()){ if(m.getDeclaringClass()!=c) continue; if(!Modifier.isPublic(m.getModifiers())) continue; Class<?>[] p=m.getParameterTypes(); if(!ifaceHas(c,m.getName(),p)&&publicSuperHas(c,m.getName(),p)) System.out.println(c+\" mods=\"+Modifier.toString(c.getModifiers())+\" method=\"+m+\" super=\"+c.getSuperclass());}}\n public static void main(String[] args)throws Exception{ List<Object> os=new ArrayList<>();\n os.add(Collections.unmodifiableList(new ArrayList<>())); os.add(Collections.synchronizedList(new ArrayList<>())); os.add(Collections.checkedList(new ArrayList<>(), Object.class)); os.add(Collections.emptyList()); os.add(Collections.singletonList(\"x\")); os.add(Collections.enumeration(List.of(\"x\"))); os.add(EnumSet.noneOf(Thread.State.class)); os.add(EnumMap.class.getConstructor(Class.class).newInstance(Thread.State.class));\n os.add(NumberFormat.getInstance()); os.add(DateFormat.getInstance()); os.add(Collator.getInstance()); os.add(BreakIterator.getWordInstance()); os.add(DateTimeFormatter.ISO_DATE.parse(\"2020-01-01\")); os.add(Pattern.compile(\"a\").matcher(\"a\"));\n os.add(Charset.defaultCharset().newEncoder()); os.add(MessageDigest.getInstance(\"SHA-256\")); os.add(KeyPairGenerator.getInstance(\"RSA\")); os.add(Cipher.getInstance(\"AES\")); os.add(DocumentBuilderFactory.newInstance()); os.add(SAXParserFactory.newInstance());\n for(Object o:os){try{scan(o);}catch(Throwable t){System.err.println(\"err \"+o+\" \"+t);}}\n }\n}\nEOF\njavac /tmp/Scan.java && java -cp /tmp Scan", "timeout": 30}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 934, "output": 1204, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 32346, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781115988478, "responseId": "resp_077223540226434e016a29ac55366c8197a098860dde65eeaa"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_LGKuN97u