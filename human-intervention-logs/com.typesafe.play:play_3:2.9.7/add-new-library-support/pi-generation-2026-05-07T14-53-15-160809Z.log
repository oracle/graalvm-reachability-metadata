onfigModule => module\n    }\n\n    assertThat(locatedModule.isDefined).isTrue\n    assertThat(locatedModule.get.config.getString(\"module-test.marker\")).isEqualTo(\"configured\")\n  }\n}\n\nfinal class LocatedScalaEnvironmentModule(\n    val environment: Environment,\n    val configuration: Configuration\n)\n\nfinal class LocatedConfigModule(val config: Config)\n"}
