[tool-call] delta {"path":"tests/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/ModulesTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_play.play_3\n\nimport com.typesafe.config.Config\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport play.api.Configuration\nimport play.api.Environment\nimport play.api.inject.Modules\n\nclass ModulesTest {\n  @Test\n  def locatesConfiguredModuleWithScalaEnvironmentConstructor(): Unit = {\n    val environment: Environment = Environment.simple()\n    val configuration: Configuration = Configuration.from(\n      Map(\"play.modules.enabled\" -> Seq(classOf[LocatedScalaEnvironmentModule].getName))\n    )\n\n    val modules: Seq[Any] = Modules.locate(environment, configuration)\n    val locatedModule: Option[LocatedScalaEnvironmentModule] = modules.collectFirst {\n      case module: LocatedScalaEnvironmentModule => module\n    }\n\n    assertThat(locatedModule.isDefined).isTrue\n    assertThat(locatedModule.get.environment).isSameAs(environment)\n    assertThat(locatedModule.get.configuration).isSameAs(configuration)\n  }\n\n  @Test\n  def fallsBackToConfigConstructorWhenEnvironmentConstructorsAreUnavailable(): Unit = {\n    val environment: Environment = Environment.simple()\n    val configuration: Configuration = Configuration.from(\n      Map(\n        \"play.modules.enabled\" -> Seq(classOf[LocatedConfigModule].getName),\n        \"module-test.marker\" -> \"configured\"\n      )\n    )\n\n    val modules: Seq[Any] = Modules.locate(environment, configuration)\n    val locatedModule: Option[LocatedConfigModule] = modules.collectFirst {\n      case module: LocatedConfigModule => module\n    }\n\n    assertThat(locatedModule.isDefined).isTrue\n    assertThat(locatedModule.get.config.getString(\"module-test.marker\")).isEqualTo(\"configured\")\n  }\n}\n\nfinal class LocatedScalaEnvironmentModule(\n    val environment: Environment,\n    val configuration: Configuration\n)\n\nfinal class LocatedConfigModule(val config: Config)\n"}
