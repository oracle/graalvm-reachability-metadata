.from(\n      Map(\n        \"play.modules.enabled\" -> Seq(classOf[LocatedConfigModule].getName),\n        \"module-test.marker\" -> \"configured\"\n      )\n    )\n\n    val modules: Seq[Any] = Modules.locate(environment, configuration)\n    val locatedModule: Option[LocatedConfigModule] = modules.collectFirst {\n      case module: LocatedConfigModule => module\n    }\n\n    assertThat(locatedModule.isDefined).isTrue\n    assertThat(locatedModule.get.config.getString(\"module-test.marker\")).isEqualTo(\"configured\")\n  }\n}\n\nfinal class LocatedScalaEnvironmentModule(\n    val environment: Environment,\n    val configuration: Configuration\n)\n\nfinal class LocatedConfigModule(val config: Config)\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 603, "output": 1260, "cacheRead": 16384, "cacheWrite": 0, "totalTokens": 18247, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778165514895, "responseId": "resp_00b9b53115e316830169fca70bcea08190ba91e0e1d486ea79"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6OPiDT7GeqHNREGrIzvK2bpk|fc_00b9b53115e316830169fca7164fac819098db652271fef3d4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2054 bytes to tests/src/com.typesafe.play/play_3/2.9.7/src/test/scala/com_typesafe_play/play_3/ModulesTest.scala"}], "isError": false, "timestamp": 1778165529989}]}
