          Commandline clLsRemote = createCommandLine(gitRepository);
  
          GitRemoteInfoConsumer consumer = new GitRemoteInfoConsumer(clLsRemote.toString());
  
          int exitCode = GitCommandLineUtils.execute(clLsRemote, consumer, stderr);
