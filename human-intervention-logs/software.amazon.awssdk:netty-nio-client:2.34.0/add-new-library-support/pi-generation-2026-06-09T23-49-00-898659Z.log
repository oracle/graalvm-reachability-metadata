nseResult(SdkHttpResponse response, String body) {\n    }\n\n    private static final class TestHttpServer implements AutoCloseable {\n        private final HttpServer server;\n        private final ExecutorService executor;\n\n        private TestHttpServer(HttpServer server, ExecutorService executor) {\n            this.server = server;\n            this.executor = executor;\n        }\n\n        static TestHttpServer create(HttpHandler handler) throws Exception {\n            HttpServer server = HttpServer.create(new InetSocketAddress(InetAddress.getLoopbackAddress(), 0), 0);\n            ExecutorService executor = Executors.newSingleThreadExecutor();\n            server.createContext(\"/\", handler);\n            server.setExecutor(executor);\n            server.start();\n            return new TestHttpServer(server, executor);\n        }\n\n        URI uri(String path) {\n            return URI.create(\"http://127.0.0.1:\" + server.getAddress().getPort() + path);\n        }\n\n        @Override\n        public void close() throws Exception {\n            server.stop(0);\n            executor.shutdownNow();\n            assertThat(executor.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 388, "output": 2822, "cacheRead": 47104, "cacheWrite": 0, "totalTokens": 50314, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781048853714, "responseId": "resp_02d5c131a9d80cf5016a28a61662c8819385863aead4037f3f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_JNO311MXlwfV1DmVQwuyQAnX|fc_02d5c131a9d80cf5016a28a62c2e10819382a7e31026fe120b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 7464 bytes to tests/src/software.amazon.awssdk/netty-nio-client/2.34.0/src/test/java/software_amazon_awssdk/netty_nio_client/DnsResolverLoaderTest.java"}], "isError":