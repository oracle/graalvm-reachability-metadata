          if (datagramFqcn == null) {
              throw new IllegalArgumentException("Unknown event loop group : " + eventLoopGroup.getClass());
          }
  
          return invokeSafely(() -> new ReflectiveChannelFactory(Class.forName(datagramFqcn)));
      }
