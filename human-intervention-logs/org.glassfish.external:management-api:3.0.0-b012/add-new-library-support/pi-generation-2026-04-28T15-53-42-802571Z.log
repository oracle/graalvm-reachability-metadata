          String toml = """
                  title = "Workshop"
                  owner = { name = "Tom Preston-Werner", organization = "Acme" }
  
                  [[products]]
                  name = "Hammer"
                  sku = 738594937
  
                  [[products]]
                  name = "Nail"
                  sku = 284758393
                  colors = ["gray", "silver"]
