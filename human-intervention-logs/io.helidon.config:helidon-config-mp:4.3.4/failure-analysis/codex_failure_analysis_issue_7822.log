adlew\n-rw-rw-r--   1 vjovanov vjovanov   2896 Jun  6 02:48 gradlew.bat\ndrwxrwxr-x   3 vjovanov vjovanov   4096 Jun  6 03:10 human-intervention-logs\ndrwxrwxr-x 554 vjovanov vjovanov  20480 Jun  6 02:51 metadata\n-rw-rw-r--   1 vjovanov vjovanov    385 Jun  6 02:48 settings.gradle\ndrwxrwxr-x  13 vjovanov vjovanov   4096 Jun  6 02:48 skills\ndrwxrwxr-x 544 vjovanov vjovanov  20480 Jun  6 03:10 stats\ndrwxrwxr-x   5 vjovanov vjovanov   4096 Jun  6 02:48 tests\nrg: logs/io.helidon.config:helidon-config-mp:4.3.4: IO error for operation on logs/io.helidon.config:helidon-config-mp:4.3.4: No such file or directory (os error 2)\n","exit_code":2,"status":"failed"}}
