      public URIBuilder setUserInfo(final String userInfo) {
          this.userInfo = !TextUtils.isBlank(userInfo) ? userInfo : null;
          this.encodedSchemeSpecificPart = null;
          this.encodedAuthority = null;
          this.encodedUserInfo = null;
          return this;
      }
  
