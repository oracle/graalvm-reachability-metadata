  public class ReflectionUtilsTest {
  
      @Test
      void callsPublicSetterAndGetterByPropertyName() {
          final URIBuilder uriBuilder = new URIBuilder();
  
          assertNull(ReflectionUtils.callGetter(uriBuilder, "Host", String.class));
  
