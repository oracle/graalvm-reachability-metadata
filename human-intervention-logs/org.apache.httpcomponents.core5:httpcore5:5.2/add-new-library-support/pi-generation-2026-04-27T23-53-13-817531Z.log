coco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/package-info.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/PrivateKeyDetails.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/PrivateKeyStrategy.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/SSLContextBuilder$KeyManagerDelegate.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/SSLContextBuilder$TrustManagerDelegate.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/SSLContextBuilder.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/SSLContexts.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/SSLInitializationException.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/ssl/TrustStrategy.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/Args.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/Asserts.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/ByteArrayBuffer.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/CharArrayBuffer.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/Deadline.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/DeadlineTimeoutException.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/Identifiable.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/LangUtils.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/package-info.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/ReflectionUtils.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/TextUtils.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/Timeout.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/TimeoutValueException.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/TimeValue$1.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/TimeValue.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/Tokenizer$Cursor.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/Tokenizer.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/effective/httpcore5_5_2_jar/org/apache/hc/core5/util/VersionInfo.class\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/jacoco/test.exec\ntests/src/org.apache.httpcomponents.core5/httpcore5/5.2/build/libs/org.apache.htt