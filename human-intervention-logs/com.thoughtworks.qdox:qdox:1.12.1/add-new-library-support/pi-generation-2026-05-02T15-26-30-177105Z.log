[tool-call] delta {"path":"tests/src/com.thoughtworks.qdox/qdox/1.12.1/src/test/java/com_thoughtworks_qdox/qdox/JavaDocBuilderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_qdox.qdox;\n\nimport com.thoughtworks.qdox.JavaDocBuilder;\nimport com.thoughtworks.qdox.model.JavaClass;\nimport com.thoughtworks.qdox.model.JavaField;\nimport com.thoughtworks.qdox.model.JavaMethod;\nimport java.io.File;\nimport java.io.StringReader;\nimport java.nio.file.Path;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaDocBuilderTest {\n    @Test\n    void createsModelForBinaryClassFromConfiguredClassLoader() {\n        JavaDocBuilder builder = new JavaDocBuilder();\n\n        JavaClass javaDocBuilderClass = builder.getClassByName(JavaDocBuilder.class.getName());\n\n        assertThat(javaDocBuilderClass).isNotNull();\n        assertThat(javaDocBuilderClass.getFullyQualifiedName()).isEqualTo(JavaDocBuilder.class.getName());\n        assertThat(javaDocBuilderClass.getMethods())\n                .extracting(JavaMethod::getName)\n                .contains(\"JavaDocBuilder\", \"getClassByName\", \"save\", \"load\");\n        assertThat(javaDocBuilderClass.getFields())\n                .extracting(JavaField::getName)\n                .contains(\"context\", \"sources\", \"docletTagFactory\");\n    }\n\n    @Test\n    void savesAndLoadsParsedBuilderModel(@TempDir Path tempDir) throws Exception {\n        JavaDocBuilder builder = new JavaDocBuilder();\n        builder.addSource(new StringReader(\"\"\"\n                package sample;\n                public class SerializedSubject {\n                    private int number;\n                    public int getNumber() { return number; }\n                }\n                \"\"\"));\n        File savedBuilder = tempDir.resolve(\"qdox-builder.ser\").toFile();\n\n        builder.save(savedBuilder);\n        JavaDocBuilder loadedBuilder = JavaDocBuilder.load(savedBuilder);\n\n        JavaClass restoredClass = loadedBuilder.getClassByName(\"sample.SerializedSubject\");\n        assertThat(restoredClass).isNotNull();\n        assertThat(restoredClass.getFieldByName(\"number\")).isNotNull();\n        assertThat(restoredClass.getMethodBySignature(\"getNumber\", null)).isNotNull();\n        assertThat(loadedBuilder.getSources()).hasSize(1);\n    }\n}\n"}
