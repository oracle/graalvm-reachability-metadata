ct {\n                    private int number;\n                    public int getNumber() { return number; }\n                }\n                \"\"\"));\n        File savedBuilder = tempDir.resolve(\"qdox-builder.ser\").toFile();\n\n        builder.save(savedBuilder);\n        JavaDocBuilder loadedBuilder = JavaDocBuilder.load(savedBuilder);\n\n        JavaClass restoredClass = loadedBuilder.getClassByName(\"sample.SerializedSubject\");\n        assertThat(restoredClass).isNotNull();\n        assertThat(restoredClass.getFieldByName(\"number\")).isNotNull();\n        assertThat(restoredClass.getMethodBySignature(\"getNumber\", null)).isNotNull();\n        assertThat(loadedBuilder.getSources()).hasSize(1);\n    }\n}\n"}
