      private void addNewMethods(Set signatures, List methodList,
                                 JavaMethod[] methods) {
          for (int i = 0; i < methods.length; i++) {
              JavaMethod method = methods[i];
  
              if (!method.isPrivate()) {
                  String signature = method.getDeclarationSignature(false);
  
                  if (!signatures.contains(signature)) {
