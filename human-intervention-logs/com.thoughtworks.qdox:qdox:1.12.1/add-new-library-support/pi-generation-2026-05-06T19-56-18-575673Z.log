  package com_thoughtworks_qdox.qdox;
  
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  
  import com.thoughtworks.qdox.tools.QDoxTester;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class QDoxTesterTest {
      @Test
      void syntheticClassLookupUsedByUsageBannerLoadsTesterClass()
              throws NoSuchMethodException, InvocationTargetException, IllegalAccessException {
          Method classLookup = QDoxTester.class.getDeclaredMethod("class$", String.class);
          classLookup.setAccessible(true);
  
          Class<?> testerClass = (Class<?>) classLookup.invoke(null, QDoxTester.class.getName());
  
          assertThat(testerClass).isSameAs(QDoxTester.class);
