          assertThat(classes).containsExactly(ConvertibleTarget.class, null, null);
      }
  
      @Test
      public void getClassResolvesPrimitiveAbbreviationsWithExplicitClassLoader() throws ClassNotFoundException {
          Class<?> resolvedClass = ClassUtils.getClass(
                  ClassUtilsTest.class.getClassLoader(),
                  "int",
                  false);
  
          assertThat(resolvedClass).isEqualTo(int.class);
      }
  
