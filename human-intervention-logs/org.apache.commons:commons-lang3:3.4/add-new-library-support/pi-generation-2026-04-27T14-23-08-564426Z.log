ng name();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Composite {\n        String value();\n\n        int[] numbers();\n\n        Nested nested();\n    }\n\n    @Composite(value = \"alpha\", numbers = {1, 2, 3}, nested = @Nested(name = \"inner\"))\n    public static class MatchingAnnotationLeft {\n    }\n\n    @Composite(value = \"alpha\", numbers = {1, 2, 3}, nested = @Nested(name = \"inner\"))\n    public static class MatchingAnnotationRight {\n    }\n\n    @Composite(value = \"beta\", numbers = {5, 8}, nested = @Nested(name = \"other\"))\n    public static class DifferentAnnotationValues {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 193, "output": 1160, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31049, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777299728350, "responseId": "resp_07958db4474de8c90169ef711114988194a463feb9200420d6"}}
