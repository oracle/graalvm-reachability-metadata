n    public interface TestInstantiable {\n    }\n\n    public static final class DefaultConstructorInstantiable implements TestInstantiable {\n\n        public DefaultConstructorInstantiable() {\n        }\n    }\n\n    public static final class ParameterizedInstantiable implements TestInstantiable {\n\n        private final OutputStream outputStream;\n\n        public ParameterizedInstantiable(OutputStream outputStream) {\n            this.outputStream = outputStream;\n        }\n\n        public OutputStream getOutputStream() {\n            return outputStream;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2106, "output": 1226, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 19204, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777515220995, "responseId": "resp_0dc7c4d96b86f4590169f2bad55cd48190a66bc5ec6a113f82"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YYIVqE5TRWXd0QadMRyl5NZw|fc_0dc7c4d96b86f4590169f2badf43a08190b19b685e3adfbe01", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2165 bytes to tests/src/ch.qos.logback/logback-core/1.2.10/src/test/java/ch_qos_logback/logback_core/OptionHelperTest.java"}], "isError": false, "timestamp": 1777515234049}]}
