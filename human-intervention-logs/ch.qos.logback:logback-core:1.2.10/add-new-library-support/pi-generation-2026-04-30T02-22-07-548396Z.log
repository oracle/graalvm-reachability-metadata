LE\" class=\"ch.qos.logback.core.ConsoleAppender\">\n                    <encoder class=\"ch.qos.logback.core.encoder.EchoEncoder\"/>\n                  </appender>\n                </configuration>\n                \"\"\";\n    }\n\n    public static final class TestConfigurator extends JoranConfiguratorBase<Object> {\n    }\n}\n"}
