\t * name = \"command1 sub1\"\n\t * </pre>\n\t *\n\t * Values are split and trimmed meaning spaces doesn't matter.\n\t * @return the command as an array\n\t */\n\tString[] name() default {};\n\n\t/**\n\t * Define aliases as an array that can be defined as:\n\t *\n\t * <pre class=\"code\">\n\t * alias = { \"alias1\", \"alias2\" }\n\t * alias = \"alias1 alias2\"\n\t * </pre>\n\t *\n\t * Values are split and trimmed meaning spaces doesn't matter.\n\t * @return the aliases as an array\n\t */\n\tString[] alias() default {};\n\n\t/**\n\t * Define a command group.\n\t * @return the command group\n\t */\n\tString group() default \"\";\n\n\t/**\n\t * Define a command description.\n\t * @return the command description\n\t */\n\t@AliasFor(attribute = \"value\")\n\tString description() default \"\";\n\n\t/**\n\t * Define command to be hidden.\n\t * @return true if command should be hidden\n\t */\n\tboolean hidden() default false;\n\n\t/**\n\t * Define a command help message.\n\t * @return the command help message\n\t */\n\tString help() default \"\";\n\n\t/**\n\t * Define availability provider bean name.\n\t * @return the availability provider bean name\n\t */\n\tString availabilityProvider() default \"\";\n\n\t/**\n\t * Define exit status exception mapper bean name.\n\t * @return the exit status exception mapper bean name\n\t */\n\tString exitStatusExceptionMapper() default \"\";\n\n\t/**\n\t * Define completion provider bean name.\n\t * @return the completion provider bean name\n\t */\n\tString completionProvider() default \"\";\n\n}\n"}], "isError": false, "timestamp": 1782517234080}}
