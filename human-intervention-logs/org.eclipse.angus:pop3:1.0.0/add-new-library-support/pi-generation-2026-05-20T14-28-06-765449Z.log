      synchronized void close(boolean force) throws MessagingException {
  	try {
  	    if (port != null) {
  		if (force)
  		    port.close();
  		else
  		    port.quit();
  	    }
  	} catch (IOException ioex) {
  	} finally {
  	    port = null;
  
