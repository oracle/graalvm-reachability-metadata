-api-$version$-javadoc.jar\",\nmetadata/jakarta.persistence/jakarta.persistence-api/index.json:47:    \"source-code-url\" : \"https://repo1.maven.org/maven2/jakarta/persistence/jakarta.persistence-api/$version$/jakarta.persistence-api-$version$-sources.jar\",\nmetadata/jakarta.persistence/jakarta.persistence-api/index.json:49:    \"test-code-url\" : \"N/A\",\nmetadata/jakarta.persistence/jakarta.persistence-api/index.json:50:    \"documentation-url\" : \"https://repo1.maven.org/maven2/jakarta/persistence/jakarta.persistence-api/$version$/jakarta.persistence-api-$version$-javadoc.jar\",\n\ncodex\nThe file already has URL templates later in the same index, but I need to confirm whether those belong to a different metadata entry before touching the requested `4.1.0-M1` object. I’m checking the actual JSON structure and the rendered Maven URLs now.\nexec\n/usr/bin/bash -lc \"sed -n '1,80p' metadata/jakarta.xml.bind/jakarta.xml.bind-api/index.json\" in /home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/4422-a3e9df38\n succeeded in 0ms:\n[\n  {\n    \"latest\" : true,\n    \"metadata-version\" : \"4.1.0-M1\",\n    \"tested-versions\" : [\n      \"4.1.0-M1\"\n    ],\n    \"allowed-packages\" : [\n      \"jakarta.xml.bind\"\n    ]\n  },\n  {\n    \"metadata-version\" : \"4.0.0\",\n    \"tested-versions\" : [\n      \"4.0.0\",\n      \"4.0.1\",\n      \"4.0.2\",\n      \"4.0.3\",\n      \"4.0.4\",\n      \"4.0.5\"\n    ],\n    \"allowed-packages\" : [\n      \"jakarta.xml.bind\"\n    ]\n  },\n  {\n    \"metadata-version\" : \"3.0.0\",\n    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/jakarta/xml/bind/jakarta.xml.bind-api/$version$/jakarta.xml.bind-api-$version$-sources.jar\",\n    \"repository-url\" : \"https://github.com/eclipse-ee4j/jaxb-api\",\n    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/jakarta/xml/bind/jakarta.xml.bind-api-test/$version$/jakarta.xml.bind-api-test-$version$-sources.jar\"