[tool-call] delta {"path":"tests/src/jakarta.xml.bind/jakarta.xml.bind-api/4.1.0-M1/src/test/java/jakarta_xml_bind/jakarta_xml_bind_api/ServiceLoaderUtilTest.java","edits":[{"oldText":"    public void instantiatesProviderClassByName() throws Exception {\n        Object provider = withContextClassLoader(\n                null,\n                ServiceLoaderUtilInvoker::instantiateFactoryBackedContextFactory);\n\n        assertThat(provider).isInstanceOf(FactoryBackedContextFactory.class);\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")","newText":"    public void instantiatesProviderClassByName() throws Exception {\n        Object provider = withContextClassLoader(\n                null,\n                ServiceLoaderUtilInvoker::instantiateFactoryBackedContextFactory);\n\n        assertThat(provider).isInstanceOf(FactoryBackedContextFactory.class);\n    }\n\n    @Test\n    public void loadsSystemPropertyProviderWithoutContextClassLoader() throws Exception {\n        JAXBContext context = withSystemProperty(\n                JAXBContext.JAXB_CONTEXT_FACTORY,\n                FactoryBackedContextFactory.class.getName(),\n                () -> withContextClassLoader(null, () -> JAXBContext.newInstance(ServiceBoundType.class)));\n\n        assertThat(context).isInstanceOf(StubJaxbContext.class);\n        assertThat(((StubJaxbContext) context).getSource()).isEqualTo(\"factory-backed-classes-factory\");\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")"},{"oldText":"    private static <T> T withContextClassLoader(\n            ClassLoader classLoader,\n            ThrowingSupplier<T> supplier) throws Exception {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader previousClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            return supplier.get();\n        } finally {\n            currentThread.setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    @FunctionalInterface","newText":"    private static <T> T withContextClassLoader(\n            ClassLoader classLoader,\n            ThrowingSupplier<T> supplier) throws Exception {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader previousClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            return supplier.get();\n        } finally {\n            currentThread.setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    private static <T> T withSystemProperty(\n            String name,\n            String value,\n            ThrowingSupplier<T> supplier) throws Exception {\n        String previousValue = System.getProperty(name);\n        System.setProperty(name, value);\n        try {\n            return supplier.get();\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(name);\n            } else {\n                System.setProperty(name, previousValue);\n            }\n        }\n    }\n\n    @FunctionalInterface"}]}
