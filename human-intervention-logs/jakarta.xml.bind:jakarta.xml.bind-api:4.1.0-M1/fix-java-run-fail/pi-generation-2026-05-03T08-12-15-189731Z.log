ontainsClass(Class<?>[] classes, Class<?> expectedClass) {\n        for (Class<?> candidate : classes) {\n            if (candidate.equals(expectedClass)) {\n                return true;\n            }\n        }\n        return false;\n    }\n}\n"}], "isError": false, "timestamp": 1777795899327}}
