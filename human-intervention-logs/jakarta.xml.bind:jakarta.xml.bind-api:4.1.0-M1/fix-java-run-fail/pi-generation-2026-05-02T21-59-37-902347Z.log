[tool-call] delta {"path":"tests/src/jakarta.xml.bind/jakarta.xml.bind-api/4.1.0-M1/src/test/java/org/glassfish/jaxb/runtime/v2/ContextFactory.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.glassfish.jaxb.runtime.v2;\n\nimport java.util.Arrays;\nimport java.util.Map;\n\nimport jakarta_xml_bind.jakarta_xml_bind_api.classproperties.PropertiesBoundType;\nimport jakarta_xml_bind.jakarta_xml_bind_api.factorybacked.FactoryBackedBoundType;\nimport jakarta_xml_bind.jakarta_xml_bind_api.support.StubJaxbContext;\nimport jakarta_xml_bind.jakarta_xml_bind_api.support.WrongTypeReturnValue;\nimport jakarta_xml_bind.jakarta_xml_bind_api.wrongtype.WrongTypeBoundType;\n\npublic final class ContextFactory {\n    private ContextFactory() {\n    }\n\n    public static Object createContext(String contextPath, ClassLoader classLoader, Map<?, ?> properties) {\n        if (Boolean.TRUE.equals(properties.get(\"useLegacyFactory\"))) {\n            return null;\n        }\n        return new StubJaxbContext(\"default-context-path-factory\");\n    }\n\n    public static Object createContext(String contextPath, ClassLoader classLoader) {\n        return new StubJaxbContext(\"default-legacy-context-path-factory\");\n    }\n\n    public static Object createContext(Class<?>[] classes, Map<?, ?> properties) {\n        if (contains(classes, WrongTypeBoundType.class)) {\n            return new WrongTypeReturnValue();\n        }\n        if (contains(classes, FactoryBackedBoundType.class)) {\n            return new StubJaxbContext(\"default-factory-backed-classes-factory\");\n        }\n        if (contains(classes, PropertiesBoundType.class)) {\n            return new StubJaxbContext(\"default-properties-classes-factory\");\n        }\n        return new StubJaxbContext(\"default-classes-factory\");\n    }\n\n    private static boolean contains(Class<?>[] classes, Class<?> expectedClass) {\n        return Arrays.asList(classes).contains(expectedClass);\n    }\n}\n"}
