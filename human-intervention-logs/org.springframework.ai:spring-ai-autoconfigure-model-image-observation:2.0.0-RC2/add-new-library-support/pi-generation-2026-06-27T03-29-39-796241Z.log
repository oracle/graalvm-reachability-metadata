                          Tracer.NOOP);
  
          @Bean("imageModelPromptContentObservationHandler")
          TracingAwareLoggingObservationHandler<ImageModelObservationContext> customTracingAwareHandler() {
              return HANDLER;
          }
  
      }
  
  }
