  @InternalAPI
  public const val SPACE: String = " "
  
  @InternalAPI
  public const val END_OF_LINE: String = "\r\n"
  
  @InternalAPI
  public val END_OF_LINE_VARIANTS: Regex = Regex("\r\n|\r|\n")
