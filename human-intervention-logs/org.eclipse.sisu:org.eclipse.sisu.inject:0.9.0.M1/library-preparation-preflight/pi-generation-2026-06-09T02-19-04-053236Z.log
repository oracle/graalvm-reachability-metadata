    </mailingList>\n  </mailingLists>\n\n  <modules>\n    <module>org.eclipse.sisu.inject</module>\n    <module>org.eclipse.sisu.inject.extender</module>\n    <module>org.eclipse.sisu.inject.tests</module>\n    <module>org.eclipse.sisu.inject.site</module>\n  </modules>\n\n  <scm>\n    <connection>scm:git:git://github.com/eclipse/sisu.inject.git</connection>\n    <developerConnection>scm:git:git@github.com:eclipse/sisu.inject.git</developerConnection>\n    <url>https://github.com/eclipse/sisu.inject</url>\n  </scm>\n  <issueManagement>\n    <system>GitHub</system>\n    <url>https://github.com/eclipse/sisu.inject/issues</url>\n  </issueManagement>\n  <ciManagement>\n    <system>Jenkins</system>\n    <url>https://ci.eclipse.org/sisu/job/sisu.inject/</url>\n  </ciManagement>\n\n  <properties>\n    <maven.compiler.source>1.7</maven.compiler.source>\n    <maven.compiler.target>1.7</maven.compiler.target>\n    <tycho.scmUrl>scm:git:https://github.com/eclipse/sisu.inject.git</tycho.scmUrl>\n    <tycho-version>2.6.0</tycho-version>\n  </properties>\n\n  <build>\n    <pluginManagement>\n      <plugins>\n        <plugin>\n          <groupId>org.codehaus.mojo</groupId>\n          <artifactId>animal-sniffer-maven-plugin</artifactId>\n          <version>1.20</version>\n          <configuration>\n            <signature>\n              <groupId>org.codehaus.mojo.signature</groupId>\n              <artifactId>java17</artifactId>\n              <version>1.0</version>\n            </signature>\n          </configuration>\n          <executions>\n            <execution>\n              <id>check-java7</id>\n              <phase>package</phase>\n              <goals>\n                <goal>check</goal>\n              </goals>\n            </execution>\n          </executions>\n        </plugin>\n        <plugin>\n          <artifactId>maven-enforcer-plugin</artifactId>\n          <version>3.0.0</version>\n          <configuration>\n            <rules>\n              <enforceBytecodeVersion>\n                <maxJdkVersion>1.7</maxJdkVersion>\n                <excludes>\n                  <exclude>p2.eclipse-plugin:wrapped.org.junit.jupiter.junit-jupiter-api</exclude>\n                </excludes>\n              </enforceBytecodeVersion>\n            </rules>\n          </configuration>\n          <dependencies>\n            <dependency>\n              <groupId>org.codehaus.mojo</groupId>\n              <artifactId>extra-enforcer-rules</artifactId>\n              <version>1.0-beta-3</version>\n            </dependency>\n          </dependencies>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>target-platform-configuration</artifactId>\n          <version>${tycho-version}</version>\n          <configuration>\n            <executionEnvironment>JavaSE-1.7</executionEnvironment>\n            <target>\n              <artifact>\n                <groupId>org.eclipse.sisu</groupId>\n                <artifactId>org.eclipse.sisu.inject</artifactId>\n                <version>${project.version}</version>\n                <classifier>build</classifier>\n              </artifact>\n            </target>\n            <environments>\n              <environment>\n                <os>win32</os>\n                <ws>win32</ws>\n                <arch>x86</arch>\n              </environment>\n              <environment>\n                <os>linux</os>\n                <ws>gtk</ws>\n                <arch>x86_64</arch>\n              </environment>\n              <environment>\n                <os>macosx</os>\n                <ws>cocoa</ws>\n                <arch>x86_64</arch>\n              </environment>\n            </environments>\n          </configuration>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-compiler-plugin</artifactId>\n          <version>${tycho-version}</version>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-maven-plugin</artifactId>\n          <version>${tycho-version}</version>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-p2-plugin</artifactId>\n          <version>${tycho-version}</version>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-p2-publisher-plugin</artifactId>\n          <version>${tycho-version}</version>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-p2-repository-plugin</artifactId>\n          <version>${tycho-version}</version>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-packaging-plugin</artifactId>\n          <version>${tycho-version}</version>\n          <configuration>\n            <archive>\n              <addMavenDescriptor>false</addMavenDescriptor>\n            </archive>\n            <sourceReferences>\n              <generate>true</generate>\n            </sourceReferences>\n          </configuration>\n          <dependencies>\n            <dependency>\n              <groupId>org.eclipse.tycho.extras</groupId>\n              <artifactId>tycho-sourceref-jgit</artifactId>\n              <version>${tycho-version}</version>\n            </dependency>\n          </dependencies>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-source-plugin</artifactId>\n          <version>${tycho-version}</version>\n          <executions>\n            <execution>\n              <id>plugin-source</id>\n              <goals>\n                <goal>plugin-source</goal>\n              </goals>\n            </execution>\n          </executions>\n        </plugin>\n        <plugin>\n          <groupId>org.eclipse.tycho</groupId>\n          <artifactId>tycho-surefire-plugin</artifactId>\n          <version>${tycho-version}</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-clean-plugin</artifactId>\n          <version>3.1.0</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-resources-plugin</artifactId>\n          <version>3.2.0</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-compiler-plugin</artifactId>\n          <version>3.8.1</version>\n        </plugin>\n        <plugin>\n          <groupId>org.jacoco</groupId>\n          <artifactId>jacoco-maven-plugin</artifactId>\n          <version>0.8.7</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-surefire-plugin</artifactId>\n          <version>3.0.0-M5</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-failsafe-plugin</artifactId>\n          <version>3.0.0-M5</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-jar-plugin</artifactId>\n          <version>3.2.0</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-install-plugin</artifactId>\n          <version>3.0.0-M1</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-deploy-plugin</artifactId>\n          <version>3.0.0-M1</version>\n        </plugin>\n        <plugin>\n          <groupId>org.sonatype.plugins</groupId>\n          <artifactId>nexus-staging-maven-plugin</artifactId>\n          <version>1.6.8</version>\n        </plugin>\n        <plugin>\n          <artifactId>maven-release-plugin</artifactId>\n          <version>3.0.0-M4</version>\n          <configuration>\n            <dryRun>true</dryRun> <!-- releases are made using the prepare/perform_milestone.sh scripts -->\n          </configuration>\n        </plugin>\n        <plugin>\n          <artifactId>maven-javadoc-plugin</artifactId>\n          <version>3.3.1</version>\n          <configuration>\n            <overview>${basedir}/overview.html</overview>\n            <excludePackageNames>*.internal,*.asm</excludePackageNames>\n            <additionalJOption>-Xdoclint:all,-missing</additionalJOption>\n            <detectOfflineLinks>false</detectOfflineLinks>\n            <quiet>true</quiet>\n          </configuration>\n        </plugin>\n        <plugin>\n          <artifactId>maven-site-plugin</artifactId>\n          <version>3.9.1</version>\n        </plugin>\n        <plugin>\n          <groupId>com.diffplug.spotless</groupId>\n          <artifactId>spotless-maven-plugin</artifactId>\n          <version>2.17.3</version>\n        </plugin>\n      </plugins>\n    </pluginManagement>\n  </build>\n\n  <reporting>\n    <plugins>\n      <plugin>\n        <artifactId>maven-project-info-reports-plugin</artifactId>\n        <version>3.1.2</version>\n      </plugin>\n    </plugins>\n  </reporting>\n\n  <profiles>\n    <profile>\n      <id>spotless</id>\n      <activation>\n        <file>\n          <exists>${basedir}/../sisu-eclipse-codestyle.xml</exists>\n        </file>\n      </activation>\n      <build>\n        <plugins>\n          <plugin>\n            <groupId>com.diffplug.spotless</groupId>\n            <artifactId>spotless-maven-plugin</artifactId>\n            <configuration>\n              <java>\n                <eclipse>\n                  <file>${basedir}/../sisu-eclipse-codestyle.xml</file>\n                </eclipse>\n                <includes>\n                  <include>src/**/*.java</include>\n                </includes>\n                <excludes>\n                  <exclude>src/**/asm/*.java</exclude>\n                </excludes>\n              </java>\n            </configuration>\n          </plugin>\n        </plugins>\n      </build>\n    </profile>\n    <profile>\n      <id>m2e</id>\n      <activation>\n        <property>\n          <name>m2e.version</name>\n        </property>\n      </activation>\n      <build>\n        <!-- ignore various mojos that aren't covered by m2e -->\n        <pluginManagement>\n          <plugins>\n            <plugin>\n              <groupId>org.eclipse.m2e</groupId>\n              <artifactId>lifecycle-mapping</artifactId>\n              <version>1.0.0</version>\n              \n--- https://repo1.maven.org/maven2/com/google/inject/guice/4.0/guice-4.0.pom\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd\">\n\n  <modelVersion>4.0.0</modelVersion>\n\n  <parent>\n    <groupId>com.google.inject</groupId>\n    <artifactId>guice-parent</artifactId>\n    <version>4.0</version>\n  </parent>\n\n  <artifactId>guice</artifactId>\n\n  <name>Google Guice - Core Library</name>\n\n  <dependencies>\n    <dependency>\n      <groupId>javax.inject</groupId>\n      <artifactId>javax.inject</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>aopalliance</groupId>\n      <artifactId>aopalliance</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>com.google.guava</groupId>\n      <artifactId>guava</artifactId>\n    </dependency>\n    <!--\n     | CGLIB is embedded by default by the JarJar build profile\n    -->\n    <dependency>\n      <groupId>org.ow2.asm</groupId>\n      <artifactId>asm</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <dependency>\n      <groupId>cglib</groupId>\n      <artifactId>cglib</artifactId>\n      <optional>true</optional>\n    </dependency>\n    <!--\n     | Test dependencies\n    -->\n    <dependency>\n      <groupId>javax.inject</groupId>\n      <artifactId>javax.inject-tck</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>com.google.guava</groupId>\n      <artifactId>guava-testlib</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.springframework</groupId>\n      <artifactId>spring-beans</artifactId>\n      <version>3.0.5.RELEASE</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>biz.aQute</groupId>\n      <artifactId>bnd</artifactId>\n      <version>0.0.384</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.apache.felix</groupId>\n      <artifactId>org.apache.felix.framework</artifactId>\n      <version>3.0.5</version>\n      <scope>test</scope>\n    </dependency>\n  </dependencies>\n\n  <build>\n    <plugins>\n      <!--\n       | Add standard LICENSE and NOTICE files\n      -->\n      <plugin>\n        <artifactId>maven-remote-resources-plugin</artifactId>\n      </plugin>\n      <!--\n       | Enable Java6 conformance checks\n      -->\n      <plugin>\n        <groupId>org.codehaus.mojo</groupId>\n        <artifactId>animal-sniffer-maven-plugin</artifactId>\n      </plugin>\n      <plugin>\n        <artifactId>maven-surefire-plugin</artifactId>\n        <configuration>\n          <!--\n           | Temporarily excluded tests\n          -->\n          <excludes>\n            <exclude>**/*$*</exclude>\n            <exclude>**/ErrorHandlingTest*</exclude>\n            <exclude>**/OSGiContainerTest*</exclude>\n            <exclude>**/ScopesTest*</exclude>\n            <exclude>**/TypeConversionTest*</exclude>\n          </excludes>\n        </configuration>\n      </plugin>\n      <!--\n       | Add OSGi manifest\n      -->\n      <plugin>\n        <groupId>org.apache.felix</groupId>\n        <artifactId>maven-bundle-plugin</artifactId>\n        <configuration>\n          <instructions>\n            <Bundle-Name>${project.artifactId}$(if;$(classes;NAMED;*.MethodAspect);; (no_aop))</Bundle-Name>\n            <Import-Package>!net.sf.cglib.*,!org.objectweb.asm.*,!com.google.inject.*,*</Import-Package>\n            <Eclipse-ExtensibleAPI>true</Eclipse-ExtensibleAPI>\n          </instructions>\n        </configuration>\n      </plugin>\n      <!--\n       | Remove duplicate jarjar'd LICENSE and NOTICE\n      -->\n      <plugin>\n        <artifactId>maven-jar-plugin</artifactId>\n        <configuration>\n          <excludes>\n            <exclude>LICENSE</exclude>\n            <exclude>NOTICE</exclude>\n          </excludes>\n        </configuration>\n      </plugin>\n      <!--\n       | Generate sources jar\n      -->\n      <plugin>\n        <artifactId>maven-source-plugin</artifactId>\n      </plugin>\n      <!--\n       | Generate javadoc jar\n      -->\n      <plugin>\n        <artifactId>maven-javadoc-plugin</artifactId>\n      </plugin>\n    </plugins>\n  </build>\n\n  <profiles>\n    <profile>\n      <!--\n       | No-AOP profile: repeat the build lifecycle with munged no-AOP source\n      -->\n      <id>guice.with.no_aop</id>\n      <activation>\n        <property>\n          <name>guice.with.no_aop</name>\n          <value>!false</value>\n        </property>\n      </activation>\n      <build>\n        <plugins>\n          <plugin>\n            <groupId>org.sonatype.plugins</groupId>\n            <artifactId>munge-maven-plugin</artifactId>\n            <version>1.0</version>\n            <executions>\n              <execution>\n                <phase>prepare-package</phase>\n                <goals>\n                  <goal>munge-fork</goal>\n                </goals>\n                <configuration>\n                  <symbols>NO_AOP</symbols>\n                  <excludes>\n                    **/InterceptorBinding.java,\n                    **/InterceptorBindingProcessor.java,\n                    **/InterceptorStackCallback.java,\n                    **/LineNumbers.java,\n                    **/MethodAspect.java,\n                    **/ProxyFactory.java,\n                    **/BytecodeGenTest.java,\n                    **/IntegrationTest.java,\n                    **/MethodInterceptionTest.java,\n                    **/ProxyFactoryTest.java\n                  </excludes>\n                </configuration>\n              </execution>\n            </executions>\n          </plugin>\n          <!--\n           | Package the no-AOP build with its own OSGi manifest and attach using \"no_aop\" classifier\n          -->\n          <plugin>\n            <artifactId>maven-jar-plugin</artifactId>\n            <executions>\n              <execution>\n                <id>no_aop</id>\n                <phase>package</phase>\n                <goals>\n                  <goal>jar</goal>\n                </goals>\n                <configuration>\n                  <classesDirectory>${project.build.directory}/munged/classes</classesDirectory>\n                  <classifier>no_aop</classifier>\n                  <archive>\n                    <manifestFile>${project.build.directory}/munged/classes/META-INF/MANIFEST.MF</manifestFile>\n                  </archive>\n                </configuration>\n              </execution>\n            </executions>\n          </plugin>\n        </plugins>\n      </build>\n    </profile>\n    <profile>\n      <!--\n       | JarJar build profile: Embed CGLIB (and ASM) classes under a Guice namespace\n      -->\n      <id>guice.with.jarjar</id>\n      <activation>\n        <property>\n          <name>guice.with.jarjar</name>\n          <value>!false</value>\n        </property>\n      </activation>\n      <build>\n        <plugins>\n          <plugin>\n            <groupId>org.sonatype.plugins</groupId>\n            <artifactId>jarjar-maven-plugin</artifactId>\n            <version>1.9</version>\n            <executions>\n              <execution>\n                <id>jarjar</id>\n                <goals><goal>jarjar</goal></goals>\n              </execution>\n            </executions>\n            <configuration>\n              <overwrite>true</overwrite>\n              <includes>\n                <include>*:asm*</include>\n                <include>*:cglib</include>\n              </includes>\n              <rules>\n                <rule>\n                  <pattern>net.sf.cglib.*</pattern>\n                  <result>com.google.inject.internal.cglib.$@1</result>\n                </rule>\n                <rule>\n                  <pattern>net.sf.cglib.**.*</pattern>\n                  <result>com.google.inject.internal.cglib.@1.$@2</result>\n                </rule>\n                <rule>\n                  <pattern>org.objectweb.asm.*</pattern>\n                  <result>com.google.inject.internal.asm.$@1</result>\n                </rule>\n                <rule>\n                  <pattern>org.objectweb.asm.**.*</pattern>\n                  <result>com.google.inject.internal.asm.@1.$@2</result>\n                </rule>\n                <keep>\n                  <pattern>com.google.inject.**</pattern>\n                </keep>\n                <keep>\n                  <pattern>com.googlecode.**</pattern>\n                </keep>\n              </rules>\n            </configuration>\n          </plugin>\n          <plugin>\n            <!--\n             | Attach the original non-JarJar'd classes so extensions can compile against them\n            -->\n            <groupId>org.codehaus.mojo</groupId>\n            <artifactId>build-helper-maven-plugin</artifactId>\n            <version>1.8</version>\n            <executions>\n              <execution>\n                <id>classes</id>\n                <phase>package</phase>\n                <goals>\n                  <goal>attach-artifact</goal>\n                </goals>\n                <configuration>\n                  <artifacts>\n                    <artifact>\n                      <file>${project.build.directory}/original-${project.build.finalName}.jar</file>\n                      <classifier>classes</classifier>\n                    </artifact>\n                  </artifacts>\n                </configuration>\n              </execution>\n            </executions>\n          </plugin>\n        </plugins>\n      </build>\n    </profile>\n    <profile>\n      <!--\n       | m2e profile - enable use of JarJar inside Eclipse\n      -->\n      <id>m2e</id>\n      <activation>\n        <property>\n          <name>m2e.version</name>\n        </property>\n      </activation>\n      <build>\n        <pluginManagement>\n          <plugins>\n            <plugin>\n              <groupId>org.eclipse.m2e</groupId>\n              <artifactId>lifecycle-mapping</artifactId>\n              <version>1.0.0</version>\n              <configuration>\n                <lifecycleMappingMetadata>\n                  <pluginExecutions>\n                    <pluginExecution>\n                      <pluginExecutionFilter>\n                        <groupId>org.sonatype.plugins</groupId>\n                        <artifactId>jarjar-maven-plugin</artifactId>\n                        <versionRange>[1.4,)</versionRange>\n                        <goals><goal>jarjar</goal></goals>\n                      </pluginExecutionFilter>\n                      <action><execute /></action>\n                    </pluginExecution>\n                  </pluginExecutions>\n                </lifecycleMappingMetadata>\n              </configuration>\n            </plugin>\n          </plugins>\n        </pluginManagement>\n      </build>\n    </profile>\n  </profiles>\n</project>\n\n"}], "isError": false, "timestamp": 1780971522476}]}
