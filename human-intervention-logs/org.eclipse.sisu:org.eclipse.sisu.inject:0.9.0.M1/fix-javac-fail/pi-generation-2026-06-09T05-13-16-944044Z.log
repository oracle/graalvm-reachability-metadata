              }
          }
          finally
          {
              publisherLock.readLock().unlock();
          }
          // one last round of cleanup in case more was freed
          ( (MildConcurrentValues) cachedBindings ).compact();
          return true;
      }
  
      public Iterable<BindingPublisher> publishers()
      {
          return publishers.snapshot();
      }
  
      public void clear()
