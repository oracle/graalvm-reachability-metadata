          final Provider<T> provider = binding.getProvider();
          return new Provider<T>()
          {
              private volatile Object value = NIL; // NOSONAR
  
              public T get()
              {
                  if ( NIL == value )
                  {
                      synchronized ( this )
                      {
                          if ( NIL == value )
                          {
                              value = provider.get();
                          }
                      }
                  }
                  return (T) value;
              }
          };
      }
