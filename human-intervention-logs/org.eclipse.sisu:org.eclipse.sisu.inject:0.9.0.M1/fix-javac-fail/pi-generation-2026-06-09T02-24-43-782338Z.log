bscribe(BindingSubscriber<T> subscriber) {\n        }\n\n        @Override\n        public <T> void unsubscribe(BindingSubscriber<T> subscriber) {\n        }\n\n        @Override\n        public int maxBindingRank() {\n            return 0;\n        }\n\n        @Override\n        public <T> T adapt(Class<T> type) {\n            return Injector.class == type ? type.cast(injector) : null;\n        }\n\n        private Injector injector() {\n            return injector;\n        }\n    }\n\n    public interface Service {\n    }\n\n    public static final class ServiceImpl implements Service {\n    }\n}\n"}
