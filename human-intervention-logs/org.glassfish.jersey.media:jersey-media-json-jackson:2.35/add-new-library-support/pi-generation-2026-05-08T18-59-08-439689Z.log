NT);\n+\n+        boolean configured = JacksonFeature.withoutExceptionMappers().configure(context);\n+\n+        assertThat(configured).isTrue();\n+        assertThat(context.classesRegisteredWith(MessageBodyReader.class, MessageBodyWriter.class))\n+                .singleElement()\n+                .satisfies(provider -> assertThat(provider.getName()).endsWith(\".DefaultJacksonJaxbJsonProvider\"));\n+        assertThat(context.registeredClassesImplementing(ExceptionMapper.class)).isEmpty();\n+    }\n+\n     @Test\n-    void test() throws Exception {\n-        System.out.println(\"This is just a placeholder, implement your test\");\n+    void honorsRuntimeSpecificJsonFeatureAlreadySelectedByApplication() {\n+        RecordingFeatureContext context = new RecordingFeatureContext(RuntimeType.CLIENT);\n+        context.property(CLIENT_JSON_FEATURE_PROPERTY, \"AnotherJsonFeature\");\n+\n+        boolean configured = new JacksonFeature().configure(context);\n+\n+        assertThat(configured).isFalse();\n+        assertThat(context.properties()).containsEntry(CLIENT_JSON_FEATURE_PROPERTY, \"AnotherJsonFeature\");\n+        assertThat(context.registeredClasses()).isEmpty();\n+    }\n+\n+    @Test\n+    void usesFilteringProviderWhenEntityFilteringIsEnabledOnServerRuntime() {\n+        RecordingFeatureContext context = new RecordingFeatureContext(RuntimeType.SERVER);\n+        context.register(EntityFilteringFeature.class);\n+\n+        boolean configured = JacksonFeature.withoutExceptionMappers().configure(context);\n+\n+        assertThat(configured).isTrue();\n+        assertThat(context.properties()).containsEntry(SERVER_JSON_FEATURE_PROPERTY, JACKSON_FEATURE_NAME);\n+        assertThat(context.classesRegisteredWith(MessageBodyReader.class, MessageBodyWriter.class))\n+                .singleElement()\n+                .satisfies(provider -> assertThat(provider.getName()).endsWith(\".FilteringJacksonJaxbJsonProvider\"));\n+        assertThat(context.registeredClasses())\n+                .anySatisfy(provider -> assertThat(provider.getName()).endsWith(\".JacksonFilteringFeature\"));\n+    }\n+\n+    private static final class RecordingFeatureContext implements FeatureContext, Configuration {\n+        private final RuntimeType runtimeType;\n+        private final Map<String, Object> properties = new LinkedHashMap<>();\n+        private final Set<Class<?>> classes = new LinkedHashSet<>();\n+        private final Set<Object> instances = new LinkedHashSet<>();\n+        private final Map<Class<?>, Set<Class<?>>> contracts = new LinkedHashMap<>();\n+\n+        private RecordingFeatureContext(RuntimeType runtimeType) {\n+            this.runtimeType = runtimeType;\n+        }\n+\n+        private Map<String, Object> properties() {\n+            return Collections.unmodifiableMap(properties);\n+        }\n+\n+        private Set<Class<?>> registeredClasses() {\n+            return Collections.unmodifiableSet(classes);\n+        }\n+\n+        private Set<Class<?>> classesRegisteredWith(Class<?> firstContract, Class<?> secondContract) {\n+            Set<Class<?>> matchingClasses = new LinkedHashSet<>();\n+            for (Map.Entry<Class<?>, Set<Class<?>>> entry : contracts.entrySet()) {\n+                if (entry.getValue().contains(firstContract) && entry.getValue().contains(secondContract)) {\n+                    matchingClasses.add(entry.getKey());\n+                }\n+            }\n+            return matchingClasses;\n+        }\n+\n+        private Set<Class<?>> registeredClassesImplementing(Class<?> contract) {\n+            Set<Class<?>> matchingClasses = new LinkedHashSet<>();\n+            for (Class<?> type : classes) {\n+                if (contract.isAssignableFrom(type)) {\n+                    matchingClasses.add(type);\n+                }\n+            }\n+            return matchingClasses;\n+        }\n+\n+        @Override\n+        public Configuration getConfiguration() {\n+            return this;\n+        }\n+\n+        @Override\n+        public FeatureContext property(String name, Object value) {\n+            properties.put(name, value);\n+            return this;\n+        }\n+\n+        @Override\n+        public FeatureContext register(Class<?> componentClass) {\n+            classes.add(componentClass);\n+            contracts.computeIfAbsent(componentClass, ignored -> new LinkedHashSet<>());\n+            return this;\n+        }\n+\n+        @Override\n+        public FeatureContext register(Class<?> componentClass, int priority) {\n+            return register(componentClass);\n+        }\n+\n+        @Override\n+        public FeatureContext register(Class<?> componentClass, Class<?>... contractClasses) {\n+            classes.add(componentClass);\n+            addContracts(componentClass, contractClasses);\n+            return this;\n+        }\n+\n+        @Override\n+        public FeatureContext register(Class<?> componentClass, Map<Class<?>, Integer> contractMap) {\n+            classes.add(componentClass);\n+            contracts.computeIfAbsent(componentClass, ignored -> new LinkedHashSet<>()).addAll(contractMap.keySet());\n+            return this;\n+        }\n+\n+        @Override\n+        public FeatureContext register(Object component) {\n+            instances.add(component);\n+            classes.add(component.getClass());\n+            contracts.computeIfAbsent(component.getClass(), ignored -> new LinkedHashSet<>());\n+            return this;\n+        }\n+\n+        @Override\n+        public FeatureContext register(Object component, int priority) {\n+            return register(component);\n+        }\n+\n+        @Override\n+        public FeatureContext register(Object component, Class<?>... contractClasses) {\n+            instances.add(component);\n+            classes.add(component.getClass());\n+            addContracts(component.getClass(), contractClasses);\n+            return this;\n+        }\n+\n+        @Override\n+        publi