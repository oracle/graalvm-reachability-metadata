          CCharPointer ldLibraryPath;
          try (CCharPointerHolder name = CTypeConversion.toCString("LD_LIBRARY_PATH")) {
              ldLibraryPath = Stdlib.getenv(name.get());
          }
  
          if (ldLibraryPath.isNull()) {
              return DEFAULT_LIBPATH;
  
