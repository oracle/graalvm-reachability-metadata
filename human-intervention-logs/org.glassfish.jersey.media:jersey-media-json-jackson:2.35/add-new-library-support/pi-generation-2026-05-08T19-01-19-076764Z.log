      @Test
      void registeredJacksonFeatureWritesJsonRequestEntities() throws Exception {
          AtomicReference<String> requestBody = new AtomicReference<>();
          AtomicReference<String> requestContentType = new AtomicReference<>();
          HttpHandler handler = exchange -> {
              requestContentType.set(exchange.getRequestHeaders().getFirst("Content-Type"));
              requestBody.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));
              sendJson(exchange, 201, """
                      {"accepted": true, "message": "created"}
                      """);
          };
  
          try (TestServer server = TestServer.start(handler);
                  Client client = newJacksonClient()) {
              Order order = new Order("book-1", 3, true);
  
              Acknowledgement acknowledgement = client.target(server.uri())
                      .path("orders")
                      .request(MediaType.APPLICATION_JSON_TYPE)
                      .post(Entity.entity(order, MediaType.APPLICATION_JSON_TYPE), Acknowledgement.class);
  
              assertThat(acknowledgement.isAccepted()).isTrue();
              assertThat(acknowledgement.getMessage()).isEqualTo("created");
              assertThat(requestContentType.get()).contains(MediaType.APPLICATION_JSON);
              assertThat(requestBody.get())
                      .contains("\"sku\":\"book-1\"")
                      .contains("\"quantity\":3")
                      .contains("\"gift\":true");
          }
      }
  
      @Test
      void contextResolverCustomizesJacksonObjectMapper() throws Exception {
          AtomicReference<String> requestBody = new AtomicReference<>();
          HttpHandler handler = exchange -> {
              requestBody.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));
              sendJson(exchange, 200, """
                      {"first_name": "Response", "last_name": "Entity"}
                      """);
          };
  
          try (TestServer server = TestServer.start(handler);
                  Client client = newJacksonClient(new SnakeCaseObjectMapperResolver())) {
              NamingBean response = client.target(server.uri())
                      .path("names")
                      .request(MediaType.APPLICATION_JSON_TYPE)
                      .post(Entity.entity(new NamingBean("Request", "Entity"), MediaType.APPLICATION_JSON_TYPE),
                              NamingBean.class);
  
              assertThat(response.getFirstName()).isEqualTo("Response");
              assertThat(response.getLastName()).isEqualTo("Entity");
              assertThat(requestBody.get())
                      .contains("\"first_name\":\"Request\"")
                      .contains("\"last_name\":\"Entity\"");
          }
      }
  
      @Test
      void jacksonJaxbProviderHonorsJaxbElementNames() throws Exception {
          HttpHandler handler = exchange -> sendJson(exchange, 200, """
                  {"external_name": "jaxb-name", "count": 4}
                  """);
  
          try (TestServer server = TestServer.start(handler);
                  Client client = newJacksonClient()) {
              JaxbNamedEntity entity = client.target(server.uri())
                      .path("jaxb")
                      .request(MediaType.APPLICATION_JSON_TYPE)
                      .get(JaxbNamedEntity.class);
  
              assertThat(entity.getInternalName()).isEqualTo("jaxb-name");
              assertThat(entity.getCount()).isEqualTo(4);
          }
      }
  
      @Test
      void jacksonFeatureIsAutoDiscoveredByJerseyClient() throws Exception {
          HttpHandler handler = exchange -> sendJson(exchange, 200, """
                  {"id": 7, "display_name": "Auto Discovered", "roles": ["json"], "metadata": {"feature": "service"}}
                  """);
  
          try (TestServer server = TestServer.start(handler);
                  Client client = newBaseClient()) {
              Person person = client.target(server.uri())
                      .path("auto")
                      .request(MediaType.APPLICATION_JSON_TYPE)
                      .get(Person.class);
  
              assertThat(person.getId()).isEqualTo(7);
              assertThat(person.getDisplayName()).isEqualTo("Auto Discovered");
              assertThat(person.getMetadata()).containsEntry("feature", "service");
          }
      }
  
