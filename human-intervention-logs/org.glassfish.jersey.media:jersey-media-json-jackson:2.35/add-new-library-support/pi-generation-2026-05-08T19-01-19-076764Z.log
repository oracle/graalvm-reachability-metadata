st {\n    private static final int CLIENT_TIMEOUT_MILLIS = 2_000;\n\n    @Test\n    void registeredJacksonFeatureReadsGenericJsonCollections() throws Exception {\n        HttpHandler handler = exchange -> sendJson(exchange, 200, \"\"\"\n                [\n                  {\n                    \"id\": 1,\n                    \"display_name\": \"Ada Lovelace\",\n                    \"roles\": [\"author\", \"mathematician\"],\n                    \"metadata\": {\"language\": \"analytical\"}\n                  },\n                  {\n                    \"id\": 2,\n                    \"display_name\": \"Grace Hopper\",\n                    \"roles\": [\"compiler\", \"admiral\"],\n                    \"metadata\": {\"language\": \"COBOL\"}\n                  }\n                ]\n                \"\"\");\n\n        try (TestServer server = TestServer.start(handler);\n                Client client = newJacksonClient()) {\n            Response response = client.target(server.uri()).path(\"people\").request(MediaType.APPLICATION_JSON_TYPE).get();\n            List<Person> people = response.readEntity(new GenericType<List<Person>>() {\n            });\n            response.close();\n\n            assertThat(people).extracting(Person::getDisplayName).containsExactly(\"Ada Lovelace\", \"Grace Hopper\");\n            assertThat(people.get(0).getRoles()).containsExactly(\"author\", \"mathematician\");\n            assertThat(people.get(1).getMetadata()).containsEntry(\"language\", \"COBOL\");\n        }\n    }\n\n    @Test\n    void registeredJacksonFeatureWritesJsonRequestEntities() throws Exception {\n        AtomicReference<String> requestBody = new AtomicReference<>();\n        AtomicReference<String> requestContentType = new AtomicReference<>();\n        HttpHandler handler = exchange -> {\n            requestContentType.set(exchange.getRequestHeaders().getFirst(\"Content-Type\"));\n            requestBody.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n            sendJson(exchange, 201, \"\"\"\n                    {\"accepted\": true, \"message\": \"created\"}\n                    \"\"\");\n        };\n\n        try (TestServer server = TestServer.start(handler);\n                Client client = newJacksonClient()) {\n            Order order = new Order(\"book-1\", 3, true);\n\n            Acknowledgement acknowledgement = client.target(server.uri())\n                    .path(\"orders\")\n                    .request(MediaType.APPLICATION_JSON_TYPE)\n                    .post(Entity.entity(order, MediaType.APPLICATION_JSON_TYPE), Acknowledgement.class);\n\n            assertThat(acknowledgement.isAccepted()).isTrue();\n            assertThat(acknowledgement.getMessage()).isEqualTo(\"created\");\n            assertThat(requestContentType.get()).contains(MediaType.APPLICATION_JSON);\n            assertThat(requestBody.get())\n                    .contains(\"\\\"sku\\\":\\\"book-1\\\"\")\n                    .contains(\"\\\"quantity\\\":3\")\n                    .contains(\"\\\"gift\\\":true\");\n        }\n    }\n\n    @Test\n    void contextResolverCustomizesJacksonObjectMapper() throws Exception {\n        AtomicReference<String> requestBody = new AtomicReference<>();\n        HttpHandler handler = exchange -> {\n            requestBody.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n            sendJson(exchange, 200, \"\"\"\n                    {\"first_name\": \"Response\", \"last_name\": \"Entity\"}\n                    \"\"\");\n        };\n\n        try (TestServer server = TestServer.start(handler);\n                Client client = newJacksonClient(new SnakeCaseObjectMapperResolver())) {\n            NamingBean response = client.target(server.uri())\n                    .path(\"names\")\n                    .request(MediaType.APPLICATION_JSON_TYPE)\n                    .post(Entity.entity(new NamingBean(\"Request\", \"Entity\"), MediaType.APPLICATION_JSON_TYPE),\n                            NamingBean.class);\n\n            assertThat(response.getFirstName()).isEqualTo(\"Response\");\n            assertThat(response.getLastName()).isEqualTo(\"Entity\");\n            assertThat(requestBody.get())\n                    .contains(\"\\\"first_name\\\":\\\"Request\\\"\")\n                    .contains(\"\\\"last_name\\\":\\\"Entity\\\"\");\n        }\n    }\n\n    @Test\n    void jacksonJaxbProviderHonorsJaxbElementNames() throws Exception {\n        HttpHandler handler = exchange -> sendJson(exchange, 200, \"\"\"\n                {\"external_name\": \"jaxb-name\", \"count\": 4}\n                \"\"\");\n\n        try (TestServer server = TestServer.start(handler);\n                Client client = newJacksonClient()) {\n            JaxbNamedEntity entity = client.target(server.uri())\n                    .path(\"jaxb\")\n                    .request(MediaType.APPLICATION_JSON_TYPE)\n                    .get(JaxbNamedEntity.class);\n\n            assertThat(entity.getInternalName()).isEqualTo(\"jaxb-name\");\n            assertThat(entity.getCount()).isEqualTo(4);\n        }\n    }\n\n    @Test\n    void jacksonFeatureIsAutoDiscoveredByJerseyClient() throws Exception {\n        HttpHandler handler = exchange -> sendJson(exchange, 200, \"\"\"\n                {\"id\": 7, \"display_name\": \"Auto Discovered\", \"roles\": [\"json\"], \"metadata\": {\"feature\": \"service\"}}\n                \"\"\");\n\n        try (TestServer server = TestServer.start(handler);\n                Client client = newBaseClient()) {\n            Person person = client.target(server.uri())\n                    .path(\"auto\")\n                    .request(MediaType.APPLICATION_JSON_TYPE)\n                    .get(Person.class);\n\n            assertThat(person.getId()).isEqualTo(7);\n            assertThat(person.getDisplayName()).isEqualTo(\"Auto Discovered\");\n            assertThat(person.getMetadata()).containsEntry(\"feature\", \"service\");\n        }\n    }\n\n    private static Client newJacksonClient(Object... providers) {\n        ClientConfig config = newClientConfig().register(JacksonFeature.class);\n        for (Object provider : providers) {\n            config.register(provider);\n        }\n        return ClientBuilder.newClient(config);\n    }\n\n    private static Client newBaseClient() {\n        return ClientBuilder.newClient(newClientConfig());\n    }\n\n    private static ClientConfig newClientConfig() {\n        return new ClientConfig()\n                .property(ClientProperties.CONNECT_TIMEOUT, CLIENT_TIMEOUT_MILLIS)\n                .property(ClientProperties.READ_TIMEOUT, CLIENT_TIMEOUT_MILLIS);\n    }\n\n    private static void sendJson(HttpExchange exchange, int status, String json) throws IOException {\n        byte[] payload = json.getBytes(StandardCharsets.UTF_8);\n        exchange.getResponseHeaders().set(\"Content-Type\", MediaType.APPLICATION_JSON);\n        exchange.sendResponseHeaders(status, payload.length);\n        try (OutputStream responseBody = exchange.getResponseBody()) {\n            responseBody.write(payload);\n        }\n    }\n\n    public static class Person {\n        private int id;\n        @JsonProperty(\"display_name\")\n        private String displayName;\n        private List<String> roles;\n        private Map<String, String> metadata;\n\n        public Person() {\n        }\n\n        public int getId() {\n            return id;\n        }\n\n        public void setId(int id) {\n            this.id = id;\n        }\n\n        public String getDisplayName() {\n            return displayName;\n        }\n\n        public void setDisplayName(String displayName) {\n            this.displayName = displayName;\n        }\n\n        public List<String> getRoles() {\n            return roles;\n        }\n\n        public void setRoles(List<String> roles) {\n            this.roles = roles;\n        }\n\n        public Map<String, String> getMetadata() {\n            return metadata;\n        }\n\n        public void setMetadata(Map<String, String> metadata) {\n            this.metadata = metadata;\n        }\n    }\n\n    public static class Order {\n        private String sku;\n        private int quantity;\n        private boolean gift;\n\n        public Order() {\n        }\n\n        Order(String sku, int quantity, boolean gift) {\n            this.sku = sku;\n            this.quantity = quantity;\n            this.gift = gift;\n        }\n\n        public String getSku() {\n            return sku;\n        }\n\n        public void setSku(String sku) {\n            this.sku = sku;\n        }\n\n        public int getQuantity() {\n            return quantity;\n        }\n\n        public void setQuantity(int quantity) {\n            this.quantity = quantity;\n        }\n\n        public boolean isGift() {\n            return gift;\n        }\n\n        public void setGift(boolean gift) {\n            this.gift = gift;\n        }\n    }\n\n    public static class Acknowledgement {\n        private boolean accepted;\n        private String message;\n\n        public Acknowledgement() {\n        }\n\n        public boolean isAccepted() {\n            return accepted;\n        }\n\n        public void setAccepted(boolean accepted) {\n            this.accepted = accepted;\n        }\n\n        public String getMessage() {\n            return message;\n        }\n\n        public void setMessage(String message) {\n            this.message = message;\n        }\n    }\n\n    public static class NamingBean {\n        private String firstName;\n        private String lastName;\n\n        public NamingBean() {\n        }\n\n        NamingBean(String firstName, String lastName) {\n            this.firstName = firstName;\n            this.lastName = lastName;\n        }\n\n        public String getFirstName() {\n            return firstName;\n        }\n\n        public void setFirstName(String firstName) {\n            this.firstName = firstName;\n        }\n\n        public String getLastName() {\n            return lastName;\n        }\n\n        public void setLastName(String lastName) {\n            this.lastName = lastName;\n        }\n    }\n\n    @XmlRootElement\n    @XmlAccessorType(XmlAccessType.FIELD)\n    public static class JaxbNamedEntity {\n        @XmlElement(name = \"external_name\")\n        private String internalName;\n        private int count;\n\n        public JaxbNamedEntity() {\n        }\n\n        public String getInternalName() {\n            return internalName;\n        }\n\n        public void setInternalName(String internalName) {\n            this.internalName = internalName;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n    }\n\n    @Provider\n    public static class SnakeCaseObjectMapperResolver implements ContextResolver<ObjectMapper> {\n        private final ObjectMapper mapper;\n\n        public SnakeCaseObjectMapperResolver() {\n            mapper = new ObjectMapper();\n            mapper.setPropertyNamingStrategy(PropertyNamingStrategies.SNAKE_CASE);\n        }\n\n        @Override\n        public ObjectMapper getContext(Class<?> type) {\n            return mapper;\n        }\n    }\n\n    private static final class TestServer implements AutoCloseable {\n        private final HttpServer server;\n        private final ExecutorService executor;\n\n        private TestServer(HttpServer server, ExecutorService executor) {\n            this.server = server;\n            this.executor = executor;\n        }\n\n        static TestServer start(HttpHandler handler) throws IOException {\n            HttpServer server = HttpServer.create(new InetSocketAddress(InetAddress.getLoopbackAddress(), 0), 0);\n            ExecutorService executor = Executors.newSingleThreadExecutor(new DaemonThreadFactory());\n            server.createContext(\"/\", handler);\n            server.setExecutor(executor);\n            server.start();\n            return new TestServer(server, executor);\n        }\n\n        URI uri() {\n            return URI.create(\"http://\" + server.getAddress().getHostString() + \":\" + server.getAddress().getPort() + \"/\");\n        }\n\n        @Override\n        public void close() {\n            server.stop(0);\n            executor.shutdownNow();\n        }\n    }\n\n    private static final class DaemonThreadFactory implements ThreadFactory {\n        @Override\n        public Thread newThread(Runnable runnable) {\n            Thread thread = new Thread(runnable, \"jersey-jackson-test-server\");\n            thread.setDaemon(true);\n            return thread;\n        }\n    }\n}\n"}
