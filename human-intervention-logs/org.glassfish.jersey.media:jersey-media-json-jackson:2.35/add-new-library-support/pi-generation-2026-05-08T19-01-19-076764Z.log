  import org.junit.jupiter.api.Test;
  
  public class Jersey_media_json_jacksonTest {
      private static final int CLIENT_TIMEOUT_MILLIS = 2_000;
  
      @Test
      void registeredJacksonFeatureReadsGenericJsonCollections() throws Exception {
          HttpHandler handler = exchange -> sendJson(exchange, 200, """
                  [
                    {
                      "id": 1,
                      "display_name": "Ada Lovelace",
                      "roles": ["author", "mathematician"],
                      "metadata": {"language": "analytical"}
                    },
                    {
                      "id": 2,
                      "display_name": "Grace Hopper",
                      "roles": ["compiler", "admiral"],
                      "metadata": {"language": "COBOL"}
                    }
                  ]
                  """);
  
          try (TestServer server = TestServer.start(handler);
                  Client client = newJacksonClient()) {
              Response response = client.target(server.uri()).path("people").request(MediaType.APPLICATION_JSON_TYPE).get();
              List<Person> people = response.readEntity(new GenericType<List<Person>>() {
              });
              response.close();
  
              assertThat(people).extracting(Person::getDisplayName).containsExactly("Ada Lovelace", "Grace Hopper");
              assertThat(people.get(0).getRoles()).containsExactly("author", "mathematician");
              assertThat(people.get(1).getMetadata()).containsEntry("language", "COBOL");
          }
  
