  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  File nativeImageTempDir = layout.buildDirectory.dir("tmp/native-image").get().asFile
  nativeImageTempDir.mkdirs()
  
  dependencies {
      testImplementation "org.glassfish.jersey.media:jersey-media-json-jackson:$libraryVersion"
      testImplementation "org.glassfish.jersey.core:jersey-client:$libraryVersion"
      testImplementation "org.glassfish.jersey.inject:jersey-hk2:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add("-J-Djava.io.tmpdir=${nativeImageTempDir.absolutePath}")
          }
      }
  
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
