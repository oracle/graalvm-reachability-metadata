  package org_jacoco.org_jacoco_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.instrument.ClassDefinition;
  import java.lang.instrument.ClassFileTransformer;
  import java.lang.instrument.Instrumentation;
  import java.lang.instrument.UnmodifiableClassException;
  import java.util.List;
  import java.util.Map;
  import java.util.Set;
  import java.util.jar.JarFile;
  
  import org.jacoco.core.runtime.IRuntime;
  import org.jacoco.core.runtime.ModifiedSystemClassRuntime;
  import org.jacoco.core.runtime.RuntimeData;
  import org.junit.jupiter.api.Test;
  
  public class ModifiedSystemClassRuntimeTest {
      private static final String ACCESS_FIELD_NAME = "jacocoAccess";
  
      public static Object jacocoAccess;
  
      @Test
      void createForLoadsContainerClassAndStartupPublishesRuntimeData() throws Exception {
          jacocoAccess = null;
          RecordingInstrumentation instrumentation = new RecordingInstrumentation();
          String className = ModifiedSystemClassRuntimeTest.class.getName().replace('.', '/');
  
          IRuntime runtime = ModifiedSystemClassRuntime.createFor(
                  instrumentation, className, ACCESS_FIELD_NAME);
  
          assertThat(runtime).isInstanceOf(ModifiedSystemClassRuntime.class);
          assertThat(instrumentation.addedTransformer).isNotNull();
          assertThat(instrumentation.removedTransformer)
                  .isSameAs(instrumentation.addedTransformer);
  
          RuntimeData data = new RuntimeData();
          try {
              runtime.startup(data);
  
              assertThat(jacocoAccess).isSameAs(data);
          } finally {
              runtime.shutdown();
              jacocoAccess = null;
          }
      }
  
  }
  
