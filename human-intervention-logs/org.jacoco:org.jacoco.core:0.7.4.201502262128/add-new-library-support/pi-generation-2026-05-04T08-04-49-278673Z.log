              assertThat(WebAppClassLoading.getProtectedClasses(server)).isSameAs(protectedMatcher);
              assertThat(WebAppClassLoading.getHiddenClasses(server)).isSameAs(hiddenMatcher);
              assertThat(server.getAttributeNameSet())
