  package org_jacoco.org_jacoco_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.instrument.ClassDefinition;
  import java.lang.instrument.ClassFileTransformer;
  import java.lang.instrument.Instrumentation;
  import java.lang.instrument.UnmodifiableClassException;
  import java.util.List;
  import java.util.Map;
  import java.util.Set;
  import java.util.jar.JarFile;
  
  import org.jacoco.core.runtime.IRuntime;
  import org.jacoco.core.runtime.ModifiedSystemClassRuntime;
  import org.jacoco.core.runtime.RuntimeData;
  import org.junit.jupiter.api.Test;
  
  public class ModifiedSystemClassRuntimeTest {
      private static final String ACCESS_FIELD_NAME = "jacocoAccess";
  
      public static Object jacocoAccess;
  
      @Test
      void createForLoadsContainerClassAndStartupPublishesRuntimeData() throws Exception {
          jacocoAccess = null;
          RecordingInstrumentation instrumentation = new RecordingInstrumentation();
          String className = ModifiedSystemClassRuntimeTest.class.getName().replace('.', '/');
  
          IRuntime runtime = ModifiedSystemClassRuntime.createFor(
                  instrumentation, className, ACCESS_FIELD_NAME);
  
          assertThat(runtime).isInstanceOf(ModifiedSystemClassRuntime.class);
          assertThat(instrumentation.addedTransformer).isNotNull();
          assertThat(instrumentation.removedTransformer)
                  .isSameAs(instrumentation.addedTransformer);
  
          RuntimeData data = new RuntimeData();
          try {
              runtime.startup(data);
  
              assertThat(jacocoAccess).isSameAs(data);
          } finally {
              runtime.shutdown();
              jacocoAccess = null;
          }
      }
  
      private static final class RecordingInstrumentation implements Instrumentation {
          private ClassFileTransformer addedTransformer;
          private ClassFileTransformer removedTransformer;
  
          @Override
          public void addTransformer(ClassFileTransformer transformer, boolean canRetransform) {
              addedTransformer = transformer;
          }
  
          @Override
          public void addTransformer(ClassFileTransformer transformer) {
              addedTransformer = transformer;
          }
  
          @Override
          public boolean removeTransformer(ClassFileTransformer transformer) {
              removedTransformer = transformer;
              return transformer == addedTransformer;
          }
  
          @Override
          public boolean isRetransformClassesSupported() {
              return false;
          }
  
          @Override
          public void retransformClasses(Class<?>... classes) throws UnmodifiableClassException {
              throw new UnsupportedOperationException("Retransformation is not used by this test.");
          }
  
          @Override
          public boolean isRedefineClassesSupported() {
              return false;
          }
  
          @Override
          public void redefineClasses(ClassDefinition... definitions)
                  throws ClassNotFoundException, UnmodifiableClassException {
              throw new UnsupportedOperationException("Redefinition is not used by this test.");
          }
  
          @Override
          public boolean isModifiableClass(Class<?> clazz) {
              return false;
          }
  
          @Override
          public Class[] getAllLoadedClasses() {
              return new Class[0];
          }
  
          @Override
          public Class[] getInitiatedClasses(ClassLoader loader) {
              return new Class[0];
          }
  
          @Override
          public long getObjectSize(Object objectToSize) {
              return 0L;
          }
  
          @Override
          public void appendToBootstrapClassLoaderSearch(JarFile jarfile) {
              throw new UnsupportedOperationException("Bootstrap search is not used by this test.");
          }
  
          @Override
          public void appendToSystemClassLoaderSearch(JarFile jarfile) {
              throw new UnsupportedOperationException("System class loader search is not used by this test.");
          }
  
          @Override
          public boolean isNativeMethodPrefixSupported() {
              return false;
          }
  
          @Override
          public void setNativeMethodPrefix(ClassFileTransformer transformer, String prefix) {
              throw new UnsupportedOperationException("Native method prefixes are not used by this test.");
          }
  
          @Override
          public void redefineModule(Module module, Set<Module> extraReads,
                  Map<String, Set<Module>> extraExports,
                  Map<String, Set<Module>> extraOpens, Set<Class<?>> extraUses,
                  Map<Class<?>, List<Class<?>>> extraProvides) {
              throw new UnsupportedOperationException("Module redefinition is not used by this test.");
          }
  
          @Override
          public boolean isModifiableModule(Module module) {
              return false;
