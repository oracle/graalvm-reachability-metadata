      {
          this(httpConfiguration, "h2");
      }
  
      protected AbstractHTTP2ServerConnectionFactory(@Name("config") HttpConfiguration httpConfiguration, @Name("protocols") String... protocols)
      {
          super(protocols);
          for (String p : protocols)
          {
