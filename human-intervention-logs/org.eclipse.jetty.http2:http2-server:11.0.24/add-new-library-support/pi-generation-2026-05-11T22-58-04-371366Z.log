          }
  
          @Override
          public void onHeaders(Stream stream, HeadersFrame frame)
          {
              if (frame.isEndStream())
                  getConnection().onTrailers((IStream)stream, frame);
              else
                  close(stream, "invalid_trailers");
          }
  
