          {
              String reason = frame.tryConvertPayload();
              if (!StringUtil.isEmpty(reason))
                  reason = " (" + reason + ")";
              EofException failure = new EofException(String.format("Close %s/%s", ErrorCode.toString(frame.getError(), null), reason));
