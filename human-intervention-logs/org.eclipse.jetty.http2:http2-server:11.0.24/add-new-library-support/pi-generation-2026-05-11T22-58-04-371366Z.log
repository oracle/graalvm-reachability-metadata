          addBean(sessionContainer);
          this.httpConfiguration = Objects.requireNonNull(httpConfiguration);
          addBean(httpConfiguration);
          setInputBufferSize(Frame.DEFAULT_MAX_LENGTH + Frame.HEADER_LENGTH);
