    @Override
    public Set<Dependency<?>> getDependencies() {
      Set<Dependency<?>> combinedDeps = new HashSet<>();
      for (AssistData data : assistDataByMethod.values()) {
        combinedDeps.addAll(data.dependencies);
      }
      return ImmutableSet.copyOf(combinedDeps);
    }
  
