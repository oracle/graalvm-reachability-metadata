ectionFor(section)\n    Object maxLibraries = sec[\"max-libraries\"]\n    if (maxLibraries == null) {\n        return Integer.MAX_VALUE\n    }\n    int value = Integer.parseInt(maxLibraries.toString())\n    if (value <= 0) {\n        throw new GradleException(\"'${section}.max-libraries' must be greater than zero\")\n    }\n    value\n}\n\nList<Map<String, Object>> expandMatrixEntries(List<Map<String, Object>> entries, String section) {\n    def defaults = matrixDefaultsFor(section)\n    List<String> nativeImageModes = nativeImageModesForMatrix()\n","exit_code":0,"status":"completed"}}
