  +    @Test
  +    public void builderTracerConfiguratorConditionControlsMatchingTracer() {
  +        SdkTracerProviderBuilder builder = SdkTracerProvider.builder();
  +
  +        SdkTracerProviderUtil.addTracerConfiguratorCondition(
  +                builder, scopeNameEquals("disabled-scope"), TracerConfig.disabled());
  +
  +        SdkTracerProvider provider = builder.build();
  +        assertTracerDoesNotRecord(provider, "disabled-scope");
  +        assertTracerRecords(provider, "enabled-scope");
  +        provider.close();
  +    }
  +
  +    @Test
  +    public void providerTracerConfiguratorUpdatesExistingTracer() {
  +        SdkTracerProvider provider = SdkTracerProvider.builder().build();
  +        Tracer tracer = provider.get("mutable-scope");
  +        Span initialSpan = tracer.spanBuilder("initial-span").startSpan();
  +        Assertions.assertTrue(initialSpan.isRecording());
