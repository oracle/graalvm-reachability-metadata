lic void builderTracerConfiguratorControlsTracerRecording() {\n        ScopeConfigurator<TracerConfig> configurator = TracerConfig.configuratorBuilder()\n                .setDefault(TracerConfig.disabled())\n                .addCondition(scopeNameEquals(\"configured-scope\"), TracerConfig.enabled())\n                .build();\n        SdkTracerProviderBuilder builder = SdkTracerProvider.builder();\n\n        SdkTracerProviderUtil.setTracerConfigurator(builder, configurator);\n\n        SdkTracerProvider provider = builder.build();\n        assertTracerRecords(provider, \"configured-scope\");\n        assertTracerDoesNotRecord(provider, \"default-scope\");\n        provider.close();\n    }\n\n    @Test\n    public void builderTracerConfiguratorConditionControlsMatchingTracer() {\n        SdkTracerProviderBuilder builder = SdkTracerProvider.builder();\n\n        SdkTracerProviderUtil.addTracerConfiguratorCondition(builder, scopeNameEquals(\"disabled-scope\"), TracerConfig.disabled());\n\n        SdkTracerProvider provider = builder.build();\n        assertTracerDoesNotRecord(provider, \"disabled-scope\");\n        assertTracerRecords(provider, \"enabled-scope\");\n        provider.close();\n    }\n\n    @Test\n    public void providerTracerConfiguratorUpdatesExistingTracer() {\n        SdkTracerProvider provider = SdkTracerProvider.builder().build();\n        Tracer tracer = provider.get(\"mutable-scope\");\n        Span initialSpan = tracer.spanBuilder(\"initial-span\").startSpan();\n        Assertions.assertTrue(initialSpan.isRecording());\n        initialSpan.end();\n\n        SdkTracerProviderUtil.setTracerConfigurator(provider, scopeInfo -> TracerConfig.disabled());\n\n        Span updatedSpan = tracer.spanBuilder(\"updated-span\").startSpan();\n        Assertions.assertFalse(updatedSpan.isRecording());\n        updatedSpan.end();\n        provider.close();\n    }\n\n    @Test\n    public void exceptionAttributeResolverCustomizesRecordedExceptionEvent() {\n        CollectingSpanExporter exporter = new CollectingSpanExporter();\n        SdkTracerProviderBuilder builder = SdkTracerProvider.builder()\n                .addSpanProcessor(SimpleSpanProcessor.create(exporter));\n        ExceptionAttributeResolver resolver = (attributeSetter, throwable, maxAttributeLength) -> attributeSetter.setAttribute(\n                ExceptionAttributeResolver.EXCEPTION_MESSAGE, \"resolved \" + throwable.getMessage());\n\n        SdkTracerProviderUtil.setExceptionAttributeResolver(builder, resolver);\n\n        SdkTracerProvider provider = builder.build();\n        Span span = provider.get(\"resolver-scope\").spanBuilder(\"exception-span\").startSpan();\n        span.recordException(new IllegalStateException(\"failure\"), Attributes.empty());\n        span.end();\n\n        Assertions.assertEquals(1, exporter.exportedSpans.size());\n        SpanData spanData = exporter.exportedSpans.get(0);\n        Assertions.assertEquals(1, spanData.getEvents().size());\n        Assertions.assertEquals(\n                \"resolved failure\",\n                spanData.getEvents().get(0).getAttributes().get(ExceptionAttributeResolver.EXCEPTION_MESSAGE));\n        provider.close();\n    }\n\n    private static Predicate<InstrumentationScopeInfo> scopeNameEquals(String expectedName) {\n        return scopeInfo -> expectedName.equals(scopeInfo.getName());\n    }\n\n    private static void assertTracerRecords(SdkTracerProvider provider, String scopeName) {\n        Span span = provider.get(scopeName).spanBuilder(\"recording-span\").startSpan();\n        Assertions.assertTrue(span.isRecording());\n        span.end();\n    }\n\n    private static void assertTracerDoesNotRecord(SdkTracerProvider provider, String scopeName) {\n        Span span = provider.get(scopeName).spanBuilder(\"non-recording-span\").startSpan();\n        Assertions.assertFalse(span.isRecording());\n        span.end();\n    }\n\n    private static final class CollectingSpanExporter implements Span