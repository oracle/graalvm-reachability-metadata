ion\" : \"Provides OpenTelemetry exporters that send traces and metrics to OTLP-compatible backends. This artifact packages the OTLP gRPC exporters used by Java applications to emit telemetry data to collectors and observability platforms.\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/opentelemetry/opentelemetry-api-events/$version$/opentelemetry-api-events-$version$-sources.jar\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:6:    \"repository-url\" : \"https://github.com/open-telemetry/opentelemetry-java\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:7:    \"test-code-url\" : \"https://github.com/open-telemetry/opentelemetry-java/tree/v1.32.0/api/events/src/test\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/opentelemetry/opentelemetry-api-events/$version$/opentelemetry-api-events-$version$-javadoc.jar\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:9:    \"description\" : \"OpenTelemetry API Events provides the experimental Java API surface for creating and recording OpenTelemetry event telemetry. It supplies event-related interfaces and builders that integrate with the broader OpenTelemetry Java API so applications and instrumentation can emit structured events consistently.\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:20:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/opentelemetry/opentelemetry-api-events/$version$/opentelemetry-api-events-$version$-sources.jar\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:21:    \"repository-url\" : \"https://github.com/open-telemetry/opentelemetry-java\",\nmetadata/io.opentelemetry/opentelemetry-api-events/index.json:22:    \"test-code-url\" : \"https://github.com/open-telemetry/opentelemetry-java/tree/v1.25.0/api/events/src/test\",\