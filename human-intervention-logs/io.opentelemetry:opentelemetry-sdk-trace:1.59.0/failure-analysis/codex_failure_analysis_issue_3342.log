etry/opentelemetry-java\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:7:    \\\"test-code-url\\\" : \\\"N/A\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:8:    \\\"documentation-url\\\" : \\\"https://repo1.maven.org/maven2/io/opentelemetry/opentelemetry-semconv/$version$/opentelemetry-semconv-$version$-javadoc.jar\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:9:    \\\"description\\\" : \\\"OpenTelemetry Semantic Conventions provides generated Java constants for the attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to trace and resource semantic attributes consistently when producing telemetry.\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:24:    \\\"source-code-url\\\" : \\\"https://repo1.maven.org/maven2/io/opentelemetry/opentelemetry-semconv/$version$/opentelemetry-semconv-$version$-sources.jar\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:25:    \\\"repository-url\\\" : \\\"https://github.com/open-telemetry/opentelemetry-java\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:26:    \\\"test-code-url\\\" : \\\"N/A\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:27:    \\\"documentation-url\\\" : \\\"https://repo1.maven.org/maven2/io/opentelemetry/opentelemetry-semconv/$version$/opentelemetry-semconv-$version$-javadoc.jar\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:28:    \\\"description\\\" : \\\"OpenTelemetry Semantic Conventions provides generated Java constants for the attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to trace and resource semantic attributes consistently when producing telemetry.\\\",\\nmetadata/io.opentelemetry/opentelemetry-semconv/index.json:40:    \\\"source-code-url\\\" : \\\"https://repo1.maven.org/maven2/io/opentelemetry/opentelemetry-semconv/$version$/open