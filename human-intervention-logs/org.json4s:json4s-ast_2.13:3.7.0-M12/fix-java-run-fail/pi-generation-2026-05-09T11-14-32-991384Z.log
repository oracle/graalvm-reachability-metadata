        case (Nil, ys) => Diff(JNothing, if (ys.isEmpty) JNothing else JArray(ys), JNothing)
        case (x :: xs, y :: ys) =>
          val Diff(c1, a1, d1) = diff(x, y)
          val Diff(c2, a2, d2) = diffRec(xs, ys)
          Diff(c1 ++ c2, a1 ++ a2, d1 ++ d2)
