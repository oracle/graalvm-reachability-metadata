  package org.json4s
  
  import JsonAST._
  
  /**
   * Basic implicit conversions from primitive types into JSON.
   * Example:<pre>
   * import org.json4s.Implicits._
   * JObject(JField("name", "joe") :: Nil) == JObject(JField("name", JString("joe")) :: Nil)
