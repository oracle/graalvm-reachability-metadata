              val Diff(c2, a2, d2) = diffRec(xs, yleft filterNot (_ == y))
              Diff(c1 merge c2, a1 merge a2, d1 merge d2)
            case None =>
              val Diff(c, a, d) = diffRec(xs, yleft)
              Diff(c, a, JObject(x :: Nil) merge d)
