  package org.jboss.shrinkwrap.descriptor.api;
  
  /**
   * Main entry point into the ShrinkWrap Descriptors project.
   *
   * @author Dan Allen
   * @author <a href="mailto:aslak@redhat.com">Aslak Knutsen</a>
