t(notServingCause).hasValue(null);\n            assertThatThrownBy(builder::build)\n                    .isInstanceOf(IllegalStateException.class)\n                    .hasMessageContaining(\"Server already built\");\n        } finally {\n            server.shutdownNow();\n        }\n    }\n\n    @Test\n    void orcaReportingConfigPreservesIntervalUnits() {\n"}]}
