ats(java.lang.String, java.lang.String, io.grpc.xds.client.Locality);\\n  public synchronized java.util.List<io.grpc.xds.client.Stats$ClusterStats> getClusterStatsReports(java.lang.String);\\n}\\n===io.grpc.xds.client.Bootstrapper===\\nCompiled from \\\"Bootstrapper.java\\\"\\npublic abstract class io.grpc.xds.client.Bootstrapper {\\n  public static final java.lang.String XDSTP_SCHEME;\\n  public io.grpc.xds.client.Bootstrapper();\\n  public abstract io.grpc.xds.client.Bootstrapper$BootstrapInfo bootstrap() throws io.grpc.xds.client.XdsInitializationException;\\n  public io.grpc.xds.client.Bootstrapper$BootstrapInfo bootstrap(java.util.Map<java.lang.String, ?>) throws io.grpc.xds.client.XdsInitializationException;\\n}\\n===io.grpc.xds.client.Stats===\\nCompiled from \\\"Stats.java\\\"\\npublic final class io.grpc.xds.client.Stats {\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777801104073}]}\n13361:[tool-exec] end id=call_1ESAH1MEXFVCyhRUXveC5i1W|fc_05818f165da1bd7c0169f7179194dc819ebc5787e972f2af60 name=bash status=success\n14466:[tool-exec] end id=call_V6JigwJBFt4Z9jwqFwKzMNCL|fc_05818f165da1bd7c0169f71795de84819eb8c5b8362c0a29be name=bash status=success\n19240:[tool-exec] end id=call_ytI52flY7FXQEYAKjMHfqFs1|fc_05818f165da1bd7c0169f7179ba73c819ea0f40009bb3d42c2 name=bash status=success\n19359:[tool-exec] end id=call_u9vBGZ0I20wkXAxkTrLzSx5U|fc_05818f165da1bd7c0169f717a26d58819ebc01089737acbb0a name=bash status=success\n19444:[tool-exec] end id=call_WTw1Wi7zNZDTMUb77eIPOcS3|fc_05818f165da1bd7c0169f717a5cdd8819e88c3f8080e1551d9 name=bash status=success\n22698:[tool-exec] end id=call_TtgZfDzhQL9cQsiZJWMkb5Si|fc_05818f165da1bd7c0169f717aaa0e4819ebe6af30f5e411dc8 name=bash status=success\n23451:[tool-exec] end id=call_QIT2mjjziSM690PeOYyfWEmq|fc_05818f165da1bd7c0169f717b24dcc819e9b163a112abe2e4e name=bash status=success\n24175:[tool-exec] end id=call_irhCdAyKj20lS4hAeL1FlfbT|fc_05818f165da1bd7c0169f717b766ac819e89f98d0a219bd93b name=bash status=success\n25209:[tool