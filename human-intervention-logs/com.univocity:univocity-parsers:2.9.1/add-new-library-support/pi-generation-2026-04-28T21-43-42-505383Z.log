      52	 *
      53	 *     {@literal @}MyReplacement
      54	 *     public String id;
      55	 *
      56	 *     {@literal @}MyReplacementUpperCase(field = "client_name")
      57	 *     public String name;
      58	 *
      59	 *     {@literal @}MyReplacementUpperCase(myIndex = 4)
