\" instead of boolean.\");\n   159\t\t\t\t\t\t}\n   160\t\t\t\t\t}\n   161\t\t\t\t\tBooleanString boolString = ((BooleanString) annotation);\n   162\t\t\t\t\tString[] falseStrings = AnnotationRegistry.getValue(target, boolString, \"falseStrings\", boolString.falseStrings());\n   163\t\t\t\t\tString[] trueStrings = AnnotationRegistry.getValue(target, boolString, \"trueStrings\", boolString.trueStrings());\n   164\t\t\t\t\tBoolean valueForNull = nullRead == null ? null : BooleanConversion.getBoolean(nullRead, trueStrings, falseStrings);\n   165\t\n   166\t\t\t\t\tif (valueForNull == null && fieldType == boolean.class) {\n   167\t\t\t\t\t\tvalueForNull = Boolean.FALSE;\n   168\t\t\t\t\t}\n   169\t\n   170\t\t\t\t\treturn Conversions.toBoolean(valueForNull, nullWrite, trueStrings, falseStrings);\n   171\t\t\t\t} else if (annType == Format.class) {\n   172\t\t\t\t\tFormat format = ((Format) annotation);\n   173\t\t\t\t\tString[] formats = AnnotationRegistry.getValue(target, format, \"formats\", format.formats());\n   174\t\t\t\t\tString[] options = AnnotationRegistry.getValue(target, format, \"options\", format.options());\n   175\t\n   176\t\t\t\t\tLocale locale = extractLocale(options);\n   177\t\t\t\t\tTimeZone timezone = extractTimeZone(options);\n   178\t\n   179\t\t\t\t\tConversion conversion = null;\n   180\t\n   181\t\t\t\t\tif (fieldType == BigDecimal.class) {\n   182\t\t\t\t\t\tBigDecimal defaultForNull = nullRead == null ? null : new BigDecimal(nullRead);\n   183\t\t\t\t\t\tconversion = Conversions.formatToBigDecimal(defaultForNull, nullWrite, formats);\n   184\t\t\t\t\t} else if (Number.class.isAssignableFrom(fieldType) || (fieldType.isPrimitive()) && fieldType != boolean.class && fieldType != char.class) {\n   185\t\t\t\t\t\tconversion = Conversions.formatToNumber(formats);\n   186\t\t\t\t\t\t((NumericConversion) conversion).setNumberType(fieldType);\n   187\t\t\t\t\t} else {\n   188\t\t\t\t\t\tDate dateIfNull = null;\n   189\t\t\t\t\t\tif (nullRead != null)