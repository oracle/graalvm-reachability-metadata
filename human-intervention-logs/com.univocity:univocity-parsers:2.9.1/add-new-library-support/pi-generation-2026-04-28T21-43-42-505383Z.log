      98		@SuppressWarnings({"rawtypes", "unchecked"})
      99		public static Conversion getConversion(Class fieldType, AnnotatedElement target, Annotation annotation, String nullRead, String nullWrite) {
     100			try {
     101				Class annType = annotation.annotationType();
     102	
     103				if (annType == NullString.class) {
     104					NullString nullString = (NullString) annotation;
     105					String[] nulls = AnnotationRegistry.getValue(target, nullString, "nulls", nullString.nulls());
     106					return Conversions.toNull(nulls);
     107				} else if (annType == Validate.class) {
     108					Validate validate = (Validate) annotation;
     109	
     110					boolean nullable = AnnotationRegistry.getValue(target, validate, "nullable", validate.nullable());
     111					boolean allowBlanks = AnnotationRegistry.getValue(target, validate, "allowBlanks", validate.allowBlanks());
     112					String[] oneOf = AnnotationRegistry.getValue(target, validate, "oneOf", validate.oneOf());
     113					String[] noneOf = AnnotationRegistry.getValue(target, validate, "noneOf", validate.noneOf());
     114					String matches = AnnotationRegistry.getValue(target, validate, "matches", validate.matches());
     115	
     116					Class[] validators = AnnotationRegistry.getValue(target, validate, "validators", validate.validators());
     117					return new ValidatedConversion(nullable, allowBlanks, oneOf, noneOf, matches, validators);
     118				} else if (annType == EnumOptions.class) {
     119					if (!fieldType.isEnum()) {
     120						if (target == null) {
     121							throw new IllegalStateException("Invalid " + EnumOptions.class.getName() + " instance for converting class " + fieldType.getName() + ". Not an enum type.");
     122						} else {
     123							throw new IllegalStateException("Invalid " + EnumOptions.class.getName() + " annotation on " + describeElement(target) + ". Attribute must be an enum type.");
     124						}
     125					}
     126					EnumOptions enumOptions = ((EnumOptions) annotation);
     127					String customElement = AnnotationRegistry.getValue(target, enumOptions, "customElement", enumOptions.customElement());
     128					String element = customElement.trim();
     129					if (element.isEmpty()) {
     130						element = null;
     131					}
     132	
     133					Enum nullReadValue = nullRead == null ? null : Enum.valueOf(fieldType, nullRead);
     134					EnumSelector[] selectors = AnnotationRegistry.getValue(target, enumOptions, "selectors", enumOptions.selectors());
     135					return new EnumConversion(fieldType, nullReadValue, nullWrite, element, selectors);
     136				} else if (annType == Trim.class) {
     137					Trim trim = ((Trim) annotation);
     138					int length = AnnotationRegistry.getValue(target, trim, "length", trim.length());
     139					if (length == -1) {
     140						return Conversions.trim();
     141					} else {
     142						return Conversions.trim(length);
     143					}
     144				} else if (annType == LowerCase.class) {
     145					return Conversions.toLowerCase();
     146				} else if (annType == UpperCase.class) {
     147					return Conversions.toUpperCase();
     148				} else if (annType == Replace.class) {
     149					Replace replace = ((Replace) annotation);
     150					String expression = AnnotationRegistry.getValue(target, replace, "expression", replace.expression());
     151					String replacement = AnnotationRegistry.getValue(target, replace, "replacement", replace.replacement());
     152					return Conversions.replace(expression, replacement);
     153				} else if (annType == BooleanString.class) {
     154					if (fieldType != boolean.class && fieldType != Boolean.class) {
     155						if (target == null) {
     156							throw new DataProcessingException("Invalid  usage of " + BooleanString.class.getName() + ". Got type " + fieldType.getName() + " instead of boolean.");
     157						} else {
     158							throw new DataProcessingException("Invalid annotation: " + describeElement(target) + " has type " + fieldType.getName() + " instead of boolean.");
     159						}
     160					}
     161					BooleanString boolString = ((BooleanString) annotation);
     162					String[] falseStrings = AnnotationRegistry.getValue(target, boolString, "falseStrings", boolString.falseStrings());
     163					String[] trueStrings = AnnotationRegistry.getValue(target, boolString, "trueStrings", boolString.trueStrings());
     164					Boolean valueForNull = nullRead == null ? null : BooleanConversion.getBoolean(nullRead, trueStrings, falseStrings);
     165	
     166					if (valueForNull == null && fieldType == boolean.class) {
     167						valueForNull = Boolean.FALSE;
     168					}
     169	
     170					return Conversions.toBoolean(valueForNull, nullWrite, trueStrings, falseStrings);
     171				} else if (annType == Format.class) {
     172					Format format = ((Format) annotation);
     173					String[] formats = AnnotationRegistry.getValue(target, format, "formats", format.formats());
     174					String[] options = AnnotationRegistry.getValue(target, format, "options", format.options());
     175	
     176					Locale locale = extractLocale(options);
     177					TimeZone timezone = extractTimeZone(options);
     178	
     179					Conversion conversion = null;
     180	
     181					if (fieldType == BigDecimal.class) {
     182						BigDecimal defaultForNull = nullRead == null ? null : new BigDecimal(nullRead);
     183						conversion = Conversions.formatToBigDecimal(defaultForNull, nullWrite, formats);
     184					} else if (Number.class.isAssignableFrom(fieldType) || (fieldType.isPrimitive()) && fieldType != boolean.class && fieldType != char.class) {
     185						conversion = Conversions.formatToNumber(formats);
     186						((NumericConversion) conversion).setNumberType(fieldType);
     187					} else {
     188						Date dateIfNull = null;
     189						if (nullRead != null) {
     190							if ("now".equalsIgnoreCase(nullRead)) {
     191								dateIfNull = new Date();
     192							} else {
     193								if (formats.length == 0) {
     194									throw new DataProcessingException("No format defined");
     195								}
     196								SimpleDateFormat sdf = new SimpleDateFormat(formats[0], locale);
     197								sdf.setTimeZone(timezone);
     198								dateIfNull = sdf.parse(nullRead);
     199							}
     200						}
     201	
     202						if (Date.class == fieldType) {
     203							conversion = Conversions.toDate(timezone, locale, dateIfNull, nullWrite, formats);
     204						} else if (Calendar.class == fieldType) {
     205							Calendar calendarIfNull = null;
     206							if (dateIfNull != null) {
     207								calendarIfNull = Calendar.getInstance();
     208								calendarIfNull.setTime(dateIfNull);
     209								calendarIfNull.setTimeZone(timezone);
     210							}
     211							conversion = Conversions.toCalendar(timezone, locale, calendarIfNull, nullWrite, formats);
     212						}
     213					}
     214	
     215					if (conversion != null) {
     216						if (options.length > 0) {
     217							if (conversion instanceof FormattedConversion) {
     218								Object[] formatters = ((FormattedConversion) conversion).getFormatterObjects();
     219								for (Object formatter : formatters) {
     220									applyFormatSettings(formatter, options);
     221								}
     222							} else {
     223								throw new DataProcessingException("Options '" + Arrays.toString(options) + "' not supported by conversion of type '" + conversion.getClass() + "'. It must implement " + FormattedConversion.class);
     224							}
     225						}
     226						return conversion;
     227					}
     228	
     229				} else if (annType == Convert.class) {
     230					Convert convert = ((Convert) annotation);
     231					String[] args = AnnotationRegistry.getValue(target, convert, "args", convert.args());
     232					Class conversionClass = AnnotationRegistry.getValue(target, convert, "conversionClass", convert.conversionClass());
     233					return (Conversion) newInstance(Conversion.class, conversionClass, args);
     234				}
     235	
     236				if (fieldType == String.class && (nullRead != null || nullWrite != null)) {
     237					return new ToStringConversion(nullRead, nullWrite);
     238				}
     239	
     240				return null;
     241			} catch (DataProcessingException ex) {
     242				throw ex;
     243			} catch (Throwable ex) {
     244				if (target == null) {
     245					throw new DataProcessingException("Unexpected error identifying conversions to apply over type " + fieldType, ex);
     246				} else {
     247					throw new DataProcessingException("Unexpected error identifying conversions to apply over " + describeElement(target), ex);
     248				}
     249			}
     250		}
