 996\t\t\t\treturn (A) lastAnnotationFound;\n   997\t\t\t}\n   998\t\n   999\t\t\tlastProcessedElement = annotatedElement;\n  1000\t\t\tlastProcessedAnnotationType = annotationType;\n  1001\t\n  1002\t\t\tStack<Annotation> path = new Stack<Annotation>();\n  1003\t\n  1004\t\t\tA annotation = findAnnotation(annotatedElement, annotationType, new HashSet<Annotation>(), path);\n  1005\t\t\tif (annotation == null || path.isEmpty()) {\n  1006\t\t\t\tlastAnnotationFound = annotation;\n  1007\t\t\t\treturn annotation;\n  1008\t\t\t}\n  1009\t\n  1010\t\t\twhile (!path.isEmpty()) {\n  1011\t\t\t\tAnnotation parent = path.pop();\n  1012\t\t\t\tAnnotation target = path.isEmpty() ? annotation : path.peek();\n  1013\t\n  1014\t\t\t\tfor (Method method : parent.annotationType().getDeclaredMethods()) {\n  1015\t\t\t\t\tCopy copy = method.getAnnotation(Copy.class);\n  1016\t\t\t\t\tif (copy != null) {\n  1017\t\t\t\t\t\tClass targetClass = copy.to();\n  1018\t\n  1019\t\t\t\t\t\tString targetProperty = copy.property();\n  1020\t\t\t\t\t\tif (targetProperty.trim().isEmpty()) {\n  1021\t\t\t\t\t\t\ttargetProperty = method.getName();\n  1022\t\t\t\t\t\t}\n  1023\t\n  1024\t\t\t\t\t\tObject value;\n  1025\t\n  1026\t\t\t\t\t\tObject existingValue = AnnotationRegistry.getValue(annotatedElement, target, method.getName());\n  1027\t\t\t\t\t\tif (existingValue != null) {\n  1028\t\t\t\t\t\t\tvalue = existingValue;\n  1029\t\t\t\t\t\t} else {\n  1030\t\t\t\t\t\t\tvalue = invoke(parent, method);\n  1031\t\t\t\t\t\t}\n  1032\t\n  1033\t\t\t\t\t\tClass sourceValueType = method.getReturnType();\n  1034\t\t\t\t\t\tClass<?> targetPropertyType = findAnnotationMethodType(targetClass, targetProperty);\n  1035\t\t\t\t\t\tif (targetPropertyType != null && targetPropertyType.isArray() && !value.getClass().isArray()) {\n  1036\t\t\t\t\t\t\tObject array = Array.newInstance(sourceValueType, 1);\n  1037\t\t\t\t\t\t\tArray.set(array, 0, value);\n  1038\t\t\t\t\t\t\tvalue = array;\n  1039\t\t\t\t\t\t}\n  1040\t\n  1041\t\t\t\t\t\tif (targetClass == target.annotationType()) {\n  1042\t\t\t\t\t\t\tAnnotationRegistry.setValue(annotatedElement, annotation, targetProperty, value);\n  1043\t\t\t\t\t\t} else {\n  1044\t\t\t\t\t\t\tA ann = (A) findAnnotation(annotatedElement, targetClass, new HashSet<Annotation>(), new Stack<Annotation>());\n  1045\t\t\t\t\t\t\tif (ann != null) {\n  1046\t\t\t\t\t\t\t\tAnnotationRegistry.setValue(annotatedElement, ann, targetProperty, value);\n  1047\t\t\t\t\t\t\t} else {\n  1048\t\t\t\t\t\t\t\tthrow new IllegalStateException(\"Can't process @Copy annotation on '\" + method + \"'. \" +\n  1049\t\t\t\t\t\t\t\t\t\t\"Annotation '\" + targetClass.getName() + \"' not used in \" + parent.annotationType().getName() + \". Unable to process field \" + annotatedElement + \"'\");\n  1050\t\t\t\t\t\t\t}\n  1051\t\t\t\t\t\t}\n  1052\t\n  1053\t\t\t\t\t}\n  1054\t\t\t\t}\n  1055\t\t\t}\n  1056\t\t\tlastAnnotationFound = annotation;\n  1057\t\t\treturn annotation;\n  1058\t\t}\n  1059\t\n  1060\t\tprivate static Class<?> findAnnotationMethodType(Class<? extends Annotation> type, String methodName) {\n  1061\t\t\tfor (Method method : type.getDeclaredMethods()) {\n  1062\t\t\t\tif (method.getName().equals(methodName)) {\n  1063\t\t\t\t\treturn method.getReturnType();\n  1064\t\t\t\t}\n  1065\t\t\t}\n  1066\t\t\treturn null;\n  1067\t\t}\n  1068\t\n  1069\t\tprivate static Object invoke(Annotation annotation, Method method) {\n  1070\t\t\ttry {\n     1\t/*******************************************************************************\n     2\t * Copyright 2016 Univocity Software Pty Ltd\n     3\t *\n     4\t * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5\t * you may not use this file except in compliance with the License.\n     6\t * You may obtain a copy of the License at\n     7\t *\n     8\t * http://www.apache.org/licenses/LICENSE-2.0\n     9\t *\n    10\t * Unless required by applicable law or agreed to in writing, software\n   