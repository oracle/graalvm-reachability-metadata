      31		/**
      32		 * Associates a value to a given annotation attribute
      33		 * @param annotatedElement a method or field that has an annotation whose properties are changed by a {@link com.univocity.parsers.annotations.Copy} annotation
      34		 * @param annotation the altered annotation of the given annotatedElement
      35		 * @param attribute the attribute of the altered annotation
      36		 * @param newValue the value of the given attribute of the altered annotation.
      37		 */
      38		static synchronized final void setValue(AnnotatedElement annotatedElement, Annotation annotation, String attribute, Object newValue) {
      39			FieldAnnotations attributes = modifiedAnnotations.get(annotatedElement);
      40			if (attributes == null) {
      41				attributes = new FieldAnnotations();
      42				modifiedAnnotations.put(annotatedElement, attributes);
      43			}
      44			attributes.setValue(annotation, attribute, newValue);
      45		}
      46	
      47		/**
      48		 * Returns the a value to a given annotation attribute that might have been modified by a {@link com.univocity.parsers.annotations.Copy} annotation
      49		 *
      50		 * @param annotatedElement a method or field that has an annotation whose properties might have been changed by a {@link com.univocity.parsers.annotations.Copy} annotation
      51		 * @param annotation the possibly altered annotation of the given annotatedElement
      52		 * @param attribute the attribute of the possibly altered annotation
      53		 * @param valueIfNull the value to return from the unmodified annotation, if it has not been changed by a {@link com.univocity.parsers.annotations.Copy}
      54		 *
      55		 * @param <T> the expected value type to be returned by this method.
      56		 *
      57		 * @return the value associated with the given annotation property.
      58		 */
      59		public static synchronized final <T> T getValue(AnnotatedElement annotatedElement, Annotation annotation, String attribute, T valueIfNull) {
      60			if (annotatedElement == null) {
      61				return valueIfNull;
      62			}
      63			Object value = getValue(annotatedElement, annotation, attribute);
      64			if (value == null) {
      65				return valueIfNull;
      66			}
      67			return (T) value;
