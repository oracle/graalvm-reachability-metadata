      46		/**
      47		 * Converts the special "null" strings that might be provided by {@link Parsed#defaultNullRead() and  Parsed#defaultNullWrite()}
      48		 *
      49		 * @param defaultValue The string returned by {@link Parsed#defaultNullRead() and  Parsed#defaultNullWrite()}
      50		 *
      51		 * @return the default value if it is not the String literal "null" or "'null'".
      52		 * <p> If "null" was provided, then null will be returned.
      53		 * <p> If "'null'" was provided, then "null" will be returned.
      54		 */
      55		private static String getNullValue(String defaultValue) {
      56			if ("null".equals(defaultValue)) {
      57				return null;
      58			}
      59			if ("'null'".equals(defaultValue)) {
      60				return "null";
      61			}
      62	
      63			return defaultValue;
      64		}
