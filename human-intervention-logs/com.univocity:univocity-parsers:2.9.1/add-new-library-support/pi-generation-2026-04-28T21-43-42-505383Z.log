lueWhenLaterCopiedArrayUsesSameAttribute() throws NoSuchFieldException {\n        Field field = AliasedBean.class.getDeclaredField(\"code\");\n\n        TargetNames targetNames = AnnotationHelper.findAnnotation(field, TargetNames.class);\n        String[] names = AnnotationRegistry.getValue(field, targetNames, \"names\", new String[0]);\n\n        assertThat(targetNames).isNotNull();\n        assertThat(names).containsExactly(\"primary\");\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.ANNOTATION_TYPE)\n    public @interface TargetNames {\n        String names() default \"\";\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target({ElementType.FIELD, ElementType.ANNOTATION_TYPE})\n    @ArrayNameAlias({\"secondary\", \"backup\"})\n    public @interface SingleNameAlias {\n        @Copy(to = TargetNames.class, property = \"names\")\n        String value();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.ANNOTATION_TYPE)\n    @TargetNames\n    public @interface ArrayNameAlias {\n        @Copy(to = TargetNames.class, property = \"names\")\n        String[] value();\n    }\n\n    public static class AliasedBean {\n        @SingleNameAlias(\"primary\")\n        private String code;\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.univocity/univocity-parsers/2.9.1/src/test/java/com_univocity/univocity_parsers/AnnotationRegistryInnerAnnotationAttributesTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_univocity.univocity_parsers;\\n\\nimport com.univocity.parsers.annotations.Copy;\\nimport com.univocity.parsers.annotations.helpers.AnnotationHelper;\\nimport com.univocity.parsers.annotations.helpers.AnnotationRegistry;\\n\\nimport org.junit.jupiter.api.AfterEach;\\nimport org.junit.jupiter.api.Test;\\n\\nimp