     252		private static String extractOption(String[] options, String key) {
     253			for (int i = 0; i < options.length; i++) {
     254				if (options[i] != null && options[i].trim().toLowerCase().startsWith(key)) {
     255					String out = options[i].split("=")[1].trim();
     256					options[i] = null;
     257					return out;
     258				}
     259			}
     260			return null;
