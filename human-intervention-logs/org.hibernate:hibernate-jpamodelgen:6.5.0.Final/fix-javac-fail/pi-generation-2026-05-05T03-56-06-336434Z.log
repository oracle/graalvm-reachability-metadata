  			throw new IllegalArgumentException( "Couldn't find schema on classpath: " + schemaName );
  		}
  
  		SchemaFactory sf = SchemaFactory.newInstance( javax.xml.XMLConstants.W3C_XML_SCHEMA_NS_URI );
  		try {
