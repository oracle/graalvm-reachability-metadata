  ConcurrentReferenceHashMap<String, String> map = new ConcurrentReferenceHashMap<String, String>(\n                4,\n                0.75f,\n                1,\n                ReferenceType.STRONG,\n                ReferenceType.STRONG,\n                EnumSet.noneOf(Option.class)\n        );\n        map.put(\"first\", \"one\");\n        map.put(\"second\", \"two\");\n\n        ConcurrentReferenceHashMap<String, String> restored = deserialize(serialize(map));\n\n        assertThat(restored)\n                .hasSize(2)\n                .containsEntry(\"first\", \"one\")\n                .containsEntry(\"second\", \"two\");\n    }\n\n    private static byte[] serialize(ConcurrentReferenceHashMap<String, String> map) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(map);\n        }\n        return bytes.toByteArray();\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static ConcurrentReferenceHashMap<String, String> deserialize(byte[] bytes)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (ConcurrentReferenceHashMap<String, String>) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 929, "output": 655, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 31792, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781021939714, "responseId": "resp_0ab0897900d778dc016a283cf44a548193a93708443da753a0"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_kDuAQVk83wwqm9L7fWGJwEX9|fc_0ab0897900d778dc016a283cf8e8188193bda5f065d197bb56", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2233 bytes to tests/