rt static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConcurrentReferenceHashMapTest {\n    @Test\n    void serializesAndDeserializesEntries() throws Exception {\n        final ConcurrentReferenceHashMap<String, String> map = new ConcurrentReferenceHashMap<String, String>(\n                4,\n                0.75f,\n                1,\n                ReferenceType.STRONG,\n                ReferenceType.STRONG,\n                EnumSet.noneOf(Option.class)\n        );\n        map.put(\"first\", \"one\");\n        map.put(\"second\", \"two\");\n\n        final ConcurrentReferenceHashMap<String, String> restored = deserialize(serialize(map));\n\n        assertThat(restored)\n                .hasSize(2)\n                .containsEntry(\"first\", \"one\")\n                .containsEntry(\"second\", \"two\");\n    }\n\n    private static byte[] serialize(ConcurrentReferenceHashMap<String, String> map) throws IOException {\n        final ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(map);\n        }\n        return bytes.toByteArray();\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static ConcurrentReferenceHashMap<String, String> deserialize(byte[] bytes)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (ConcurrentReferenceHashMap<String, String>) input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781023127719}, {"role": "toolResult", "toolCallId": "call_JrjORM5bp7IEmEAYxm9njjOD|fc_08e5e562abfd0f16016a28419783d88196a4c7d1e973f1c5fc", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hibernate.hibernate_validator;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Base64;\nimport java.util.Locale;\n\nimport javax.validation.MessageInterpolator;\nimport javax.validation.Validation;\nimport javax.validation.ValidationException;\nimport javax.validation.ValidatorFactory;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.hibernate.validator.HibernateValidator;\nimport org.hibernate.validator.HibernateValidatorConfiguration;\nimport org.hibernate.validator.messageinterpolation.ParameterMessageInterpolator;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class LoadClassTest {\n    private static final String VALIDATION_XML_RESOURCE = \"META-INF/validation.xml\";\n    private static final String TCCL_ONLY_PROVIDER = \"org.hibernate.validatorcustom.TcclOnlyProvider\";\n    private static final byte[] TCCL_ONLY_PROVIDER_BYTES = Base64.getDecoder().decode(\n            \"yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClWBwA\"\n                    + \"IAQAub3JnL2hpYmVybmF0ZS92YWxpZGF0b3JjdXN0b20vVGNjbE9ubHlQcm92aWRlcgEABENvZG\"\n                    + \"UBAA9MaW5lTnVtYmVyVGFibGUBAApTb3VyY2VGaWxlAQAVVGNjbE9ubHlQcm92aWRlci5qYXZhA\"\n                    + \"CEABwACAAAAAAABAAEABQAGAAEACQAAAB0AAQABAAAABSq3AAGxAAAAAQAKAAAABgABAAAAAgA\"\n                    + \"BAAsAAAACAAw=\"\n    );\n    private static final String XML_MESSAGE_INTERPOLATOR = XmlMessageInterpolator.class.getName();\n\n    @Test\n    void bootstrapLoadsHibernateValidatorProviderDeclaredInXml() {\n        String validationXml = validationXmlWithProvider(HibernateValidator.class.getName());\n        ClassLoader classLoader = validationXmlClassLoader(validationXml);\n\n        withContextClassLoader(classLoader, () -> {\n            ValidatorFactory factory = Validation.byDefaultProvider().configure().buildValidatorFactory();\n            try {\n                assertThat(factory).isNotNull();\n            }\n            finally {\n                factory.close();\n            }\n        });\n    }\n\n    @Test\n    void bootstrapReportsInvalidHibernateValidatorProviderDeclaredInXml() {\n        withContextClassLoader(\n                validationXmlClassLoader(validationXmlWithProvider(\"org.hibernate.validator.DoesNotExist\")),\n                () -> assertThatThrownBy(() -> Validation.byDefaultProvider().configure().buildValidatorFactory())\n                        .isInstanceOf(ValidationException.class)\n        );\n    }\n\n    @Test\n    void bootstrapLoadsHibernateValidatorNamespaceClassFromThreadContextClassLoader() {\n        ClassLoader classLoader = validationXmlClassLoaderWithTcclOnlyProvider(\n                validationXmlWithProvider(TCCL_ONLY_PROVIDER)\n        );\n\n        withContextClassLoader(classLoader, () -> {\n            try {\n                ValidatorFactory factory = Validation.byDefaultProvider().configure().buildValidatorFactory();\n                factory.close();\n                throw new AssertionError(\"Expected configured provider lookup to fail\");\n            }\n            catch (ValidationException expected) {\n                assertThat(expected).hasMessageContaining(TCCL_ONLY_PROVIDER);\n            }\n            catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        });\n    }\n\n    @Test\n    void bootstrapLoadsConfiguredClassFromExternalClassLoader() {\n        HibernateValidatorConfiguration configuration = Validation.byProvider(HibernateValidator.class).configure();\n        String validationXml = validationXmlWithMessageInterpolator(XML_MESSAGE_INTERPOLATOR);\n        ClassLoader classLoader = validationXmlClassLoader(validationXml);\n        configuration.externalClassLoader(classLoader);\n\n        ValidatorFactory factory = configuration.buildValidatorFactory();\n        try {\n            assertThat(factory.getMessageInterpolator()).isInstanceOf(XmlMessageInterpolator.class);\n        }\n        finally {\n            factory.close();\n        }\n    }\n\n    @Test\n    void bootstrapLoadsConfiguredClassFromThreadContextClassLoader() {\n        String validationXml = validationXmlWithMessageInterpolator(XML_MESSAGE_INTERPOLATOR);\n        ClassLoader classLoader = validationXmlClassLoader(validationXml);\n\n        withContextClassLoader(classLoader, () -> {\n            ValidatorFactory factory = Validation.byProvider(HibernateValidator.class)\n                    .configure()\n                    .buildValidatorFactory();\n            try {\n                assertThat(factory.getMessageInterpolator()).isInstanceOf(XmlMessageInterpolator.class);\n            }\n            finally {\n                factory.close();\n            }\n        });\n    }\n\n    @Test\n    void bootstrapFallsBackToHibernateValidatorClassLoaderWhenThreadContextClassLoaderCannotLoadClass() {\n        ClassLoader classLoader = validationXmlClassLoader(\n                validationXmlWithMessageInterpolator(XML_MESSAGE_INTERPOLATOR),\n                XML_MESSAGE_INTERPOLATOR\n        );\n\n        withContextClassLoader(classLoader, () -> {\n            ValidatorFactory factory = Validation.byProvider(HibernateValidator.class)\n                    .configure()\n                    .buildValidatorFactory();\n            try {\n                assertThat(factory.getMessageInterpolator()).isInstanceOf(XmlMessageInterpolator.class);\n            }\n            finally {\n                factory.close();\n            }\n        });\n    }\n\n    @Test\n    void defaultConfigurationChecksOptionalClasspathIntegrations() {\n        ValidatorFactory factory = Validation.byProvider(HibernateValidator.class)\n                .configure()\n                .ignoreXmlConfiguration()\n                .messageInterpolator(new ParameterMessageInterpolator())\n                .buildValidatorFactory();\n        try {\n            assertThat(factory.getValidator()).isNotNull();\n        }\n        finally {\n            factory.close();\n        }\n    }\n\n    private static ClassLoader validationXmlClassLoader(String validationXml) {\n        return validationXmlClassLoader(validationXml, null);\n    }\n\n    private static ClassLoader validationXmlClassLoader(String validationXml, String blockedClassName) {\n        return new ValidationXmlClassLoader(validationXml, blockedClassName);\n    }\n\n    private static ClassLoader validationXmlClassLoaderWithTcclOnlyProvider(String validationXml) {\n        return new ValidationXmlClassLoader(validationXml, null) {\n            @Override\n            protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n                if (TCCL_ONLY_PROVIDER.equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = defineClass(name, TCCL_ONLY_PROVIDER_BYTES, 0, TCCL_ONLY_PROVIDER_BYTES.length);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                return super.loadClass(name, resolve);\n            }\n        };\n    }\n\n    private static void withContextClassLoader(ClassLoader classLoader, Runnable action) {\n        Thread thread = Thread.currentThread();\n        ClassLoader originalClassLoader = thread.getContextClassLoader();\n        thread.setContextClassLoader(classLoader);\n        try {\n            action.run();\n        }\n        finally {\n            thread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static String validationXmlWithProvider(String providerClassName) {\n        return validationXml(\"<default-provider>\" + providerClassName + \"</default-provider>\");\n    }\n\n    private static String validationXmlWithMessageInterpolator(String interpolatorClassName) {\n        return validationXml(\"<message-interpolator>\" + interpolatorClassName + \"</message-interpolator>\");\n    }\n\n    private static String validationXml(String content) {\n        return \"\"\"\n                <validation-config\n                    xmlns=\"http://jboss.org/xml/ns/javax/validation/configuration\"\n                    version=\"1.1\">\n                    %s\n                </validation-config>\n                \"\"\".formatted(content);\n    }\n\n    public static class XmlMessageInterpolator implements MessageInterpolator {\n        @Override\n        public String interpolate(String messageTemplate, Context context) {\n            return messageTemplate;\n        }\n\n        @Override\n        public String interpolate(String messageTemplate, Context context, Locale locale) {\n            return messageTemplate;\n        }\n    }\n\n    private static class ValidationXmlClassLoader extends ClassLoader {\n        private final byte[] validationXml;\n        private final String blockedClassName;\n\n        private ValidationXmlClassLoader(String validationXml, String blockedClassName) {\n            super(LoadClassTest.class.getClassLoader());\n            this.validationXml = validationXml.getBytes(StandardCharsets.UTF_8);\n            this.blockedClassName = blockedClassName;\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (VALIDATION_XML_RESOURCE.equals(name)) {\n                return new ByteArrayInputStream(validationXml);\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) thro