er classLoader = validationXmlClassLoader(validationXml);\\n\\n        withContextClassLoader(classLoader, () -> {\\n            ValidatorFactory factory = Validation.byDefaultProvider().configure().buildValidatorFactory();\\n            try {\\n                assertThat(factory).isNotNull();\\n            }\\n            finally {\\n                factory.close();\\n            }\\n        });\\n    }\\n\\n    @Test\\n    void bootstrapReportsInvalidHibernateValidatorProviderDeclaredInXml() {\\n        withContextClassLoader(\\n                validationXmlClassLoader(validationXmlWithProvider(\\\"org.hibernate.validator.DoesNotExist\\\")),\\n                () -> assertThatThrownBy(() -> Validation.byDefaultProvider().configure().buildValidatorFactory())\\n                        .isInstanceOf(ValidationException.class)\\n        );\\n    }\\n\\n    @Test\\n    void bootstrapLoadsHibernateValidatorNamespaceClassFromThreadContextClassLoader() {\\n        ClassLoader classLoader = validationXmlClassLoaderWithTcclOnlyProvider(\\n                validationXmlWithProvider(TCCL_ONLY_PROVIDER)\\n        );\\n\\n        withContextClassLoader(classLoader, () -> {\\n            try {\\n                ValidatorFactory factory = Validation.byDefaultProvider().configure().buildValidatorFactory();\\n                factory.close();\\n                throw new AssertionError(\\\"Expected configured provider lookup to fail\\\");\\n            }\\n            catch (ValidationException expected) {\\n                assertThat(expected).hasMessageContaining(TCCL_ONLY_PROVIDER);\\n            }\\n            catch (Error error) {\\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                    throw error;\\n                }\\n            }\\n        });\\n    }\\n\\n    @Test\\n    void bootstrapLoadsConfiguredClassFromExternalClassLoader() {\\n        HibernateValidatorConfiguration configuration = Validation.byProvider(HibernateValidator.cl