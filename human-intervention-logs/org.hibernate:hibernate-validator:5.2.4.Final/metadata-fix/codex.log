{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/org.hibernate/hibernate-validator/5.2.4.Final/src/test/java/org_hibernate/hibernate_validator/AnnotationProxyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hibernate.hibernate_validator;\n\nimport java.lang.annotation.Annotation;\nimport java.lang.annotation.ElementType;\nimport java.util.Set;\n\nimport javax.validation.ConstraintViolation;\nimport javax.validation.Validation;\nimport javax.validation.Validator;\nimport javax.validation.ValidatorFactory;\nimport javax.validation.constraints.NotNull;\nimport javax.validation.metadata.ConstraintDescriptor;\nimport javax.validation.metadata.PropertyDescriptor;\n\nimport org.hibernate.validator.HibernateValidator;\nimport org.hibernate.validator.HibernateValidatorConfiguration;\nimport org.hibernate.validator.cfg.ConstraintMapping;\nimport org.hibernate.validator.cfg.defs.NotNullDef;\nimport org.hibernate.validator.messageinterpolation.ParameterMessageInterpolator;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationProxyTest {\n    @Test\n    void programmaticConstraintAnnotationBehavesLikeDeclaredConstraintAnnotation() {\n        ValidatorFactory factory = validatorFactoryWithProgrammaticNotNullConstraint();\n        try {\n            Validator validator = factory.getValidator();\n            Annotation programmaticAnnotation = constraintAnnotation(validator, ProgrammaticBean.class, \"name\");\n            Annotation declaredAnnotation = constraintAnnotation(validator, DeclaredBean.class, \"name\");\n\n            assertThat(programmaticAnnotation.annotationType()).isEqualTo(NotNull.class);\n            assertThat(programmaticAnnotation).isEqualTo(declaredAnnotation);\n            assertThat(programmaticAnnotation.toString())\n                    .contains(\"@javax.validation.constraints.NotNull\")\n                    .contains(\"message=required\");\n\n            Set<ConstraintViolation<ProgrammaticBean>> violations = validator.validate(new ProgrammaticBean(null));\n            assertThat(violations)\n                    .hasSize(1)\n                    .extracting(ConstraintViolation::getMessage)\n                    .containsExactly(\"required\");\n        }\n        finally {\n            factory.close();\n        }\n    }\n\n    private static ValidatorFactory validatorFactoryWithProgrammaticNotNullConstraint() {\n        HibernateValidatorConfiguration configuration = Validation.byProvider(HibernateValidator.class)\n                .configure()\n                .ignoreXmlConfiguration()\n                .messageInterpolator(new ParameterMessageInterpolator());\n        ConstraintMapping mapping = configuration.createConstraintMapping();\n        mapping.type(ProgrammaticBean.class)\n                .property(\"name\", ElementType.FIELD)\n                .constraint(new NotNullDef().message(\"required\"));\n        return configuration.addMapping(mapping).buildValidatorFactory();\n    }\n\n    private static Annotation constraintAnnotation(Validator validator, Class<?> beanClass, String propertyName) {\n        PropertyDescriptor propertyDescriptor = validator.getConstraintsForClass(beanClass)\n                .getConstraintsForProperty(propertyName);\n        assertThat(propertyDescriptor).isNotNull();\n\n        Set<ConstraintDescriptor<?>> descriptors = propertyDescriptor.getConstraintDescriptors();\n        assertThat(descriptors).hasSize(1);\n        return descriptors.iterator().next().getAnnotation();\n    }\n\n    public static class ProgrammaticBean {\n        private final String name;\n\n        public ProgrammaticBean(String name) {\n            this.name = name;\n        }\n    }\n\n    public static class DeclaredBean {\n        @NotNull(message = \"required\")\n        private final String name;\n\n        public DeclaredBean(String name) {\n            this.name = name;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
