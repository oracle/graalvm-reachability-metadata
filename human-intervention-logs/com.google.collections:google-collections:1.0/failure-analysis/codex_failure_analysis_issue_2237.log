ond\\\", \\\"two\\\");\\n    }\\n\\n    @Test\\n    void serializesAndDeserializesHashMultisetCounts() throws Exception {\\n        HashMultiset<String> multiset = HashMultiset.create();\\n        multiset.add(\\\"alpha\\\", 3);\\n        multiset.add(\\\"bravo\\\", 2);\\n\\n        HashMultiset<String> deserialized = roundTrip(multiset);\\n\\n        assertThat(deserialized.count(\\\"alpha\\\")).isEqualTo(3);\\n        assertThat(deserialized.count(\\\"bravo\\\")).isEqualTo(2);\\n        assertThat(deserialized.elementSet()).containsExactlyInAnyOrder(\\\"alpha\\\", \\\"bravo\\\");\\n    }\\n\\n    @Test\\n    void serializesAndDeserializesArrayListMultimapKeysAndValues() throws Exception {\\n        ArrayListMultimap<String, String> multimap = ArrayListMultimap.create();\\n        multimap.put(\\\"fruit\\\", \\\"apple\\\");\\n        multimap.put(\\\"fruit\\\", \\\"pear\\\");\\n        multimap.put(\\\"color\\\", \\\"blue\\\");\\n\\n        ArrayListMultimap<String, String> deserialized = roundTrip(multimap);\\n\\n        assertThat(deserialized.get(\\\"fruit\\\")).containsExactly(\\\"apple\\\", \\\"pear\\\");\\n        assertThat(deserialized.get(\\\"color\\\")).containsExactly(\\\"blue\\\");\\n        assertThat(deserialized.size()).isEqualTo(3);\\n    }\\n\\n    @Test\\n    void deserializesImmutableCollectionsWithFinalFields() throws Exception {\\n        ImmutableListMultimap<String, String> multimap = ImmutableListMultimap.of(\\n                \\\"fruit\\\", \\\"apple\\\", \\\"fruit\\\", \\\"pear\\\", \\\"color\\\", \\\"blue\\\");\\n        ImmutableMultiset<String> multiset = ImmutableMultiset.of(\\n                \\\"alpha\\\", \\\"alpha\\\", \\\"bravo\\\", \\\"charlie\\\", \\\"charlie\\\", \\\"charlie\\\");\\n\\n        ImmutableListMultimap<String, String> deserializedMultimap = roundTrip(multimap);\\n        ImmutableMultiset<String> deserializedMultiset = roundTrip(multiset);\\n\\n        assertThat(deserializedMultimap.get(\\\"fruit\\\")).containsExa