  package com_google_collections.google_collections;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.base.Function;
  import com.google.common.collect.MapMaker;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  import java.util.concurrent.ConcurrentMap;
  
  import org.junit.jupiter.api.Test;
  
  public class MapMakerInnerStrategyImplTest {
      @Test
      void serializesAndDeserializesCustomMapStrategy() throws Exception {
          ConcurrentMap<String, String> map = new MapMaker()
                  .makeComputingMap(new PrefixingFunction());
          assertThat(map.get("alpha")).isEqualTo("computed-alpha");
          assertThat(map.get("bravo")).isEqualTo("computed-bravo");
  
          ConcurrentMap<String, String> deserialized = deserialize(serialize(map));
  
          assertThat(deserialized).hasSize(2);
          assertThat(deserialized.get("alpha")).isEqualTo("computed-alpha");
          assertThat(deserialized.get("bravo")).isEqualTo("computed-bravo");
          assertThat(deserialized.get("charlie")).isEqualTo("computed-charlie");
          assertThat(deserialized).isInstanceOf(map.getClass());
      }
  
      private static byte[] serialize(Object object) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(object);
          }
          return bytes.toByteArray();
      }
  
      @SuppressWarnings("unchecked")
      private static ConcurrentMap<String, String> deserialize(byte[] bytes) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return (ConcurrentMap<String, String>) input.readObject();
          }
      }
  
      private static final class PrefixingFunction implements Function<String, String>, Serializable {
          private static final long serialVersionUID = 1L;
  
          @Override
          public String apply(String input) {
              return "computed-" + input;
          }
      }
  }
