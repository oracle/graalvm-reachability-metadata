x.json:    \"description\": \"The jjwt-orgjson module provides JJWT's org.json-based JSON serializer and deserializer implementation for processing JWT content at runtime. It is the recommended JSON backend for Android use cases and supports simple claim marshaling without POJO unmarshalling.\",\nmetadata/io.jsonwebtoken/jjwt-gson/0.12.0/reachability-metadata.json:      \"glob\": \"META-INF/services/io.jsonwebtoken.io.Deserializer\"\nmetadata/io.jsonwebtoken/jjwt-gson/0.11.5/reachability-metadata.json:      \"glob\": \"META-INF/services/io.jsonwebtoken.io.Deserializer\"\nmetadata/io.jsonwebtoken/jjwt-gson/index.json:    \"description\" : \"Provides Gson-based JSON serialization and deserialization support for the JJWT library. When present on the runtime classpath, it lets JJWT automatically use Gson to process JWT headers and claims.\",\nmetadata/io.jsonwebtoken/jjwt-gson/index.json:    \"description\" : \"Provides Gson-based JSON serialization and deserialization support for the JJWT library. When present on the runtime classpath, it lets JJWT automatically use Gson to process JWT headers and claims.\",\nmetadata/org.yaml/snakeyaml/index.json:    \"description\" : \"SnakeYAML is a Java library for parsing and emitting YAML 1.1 documents. It lets applications load YAML into Java objects and serialize Java data structures back to YAML.\",\nmetadata/io.jsonwebtoken/jjwt-jackson/0.11.5/reachability-metadata.json:      \"glob\": \"META-INF/services/io.jsonwebtoken.io.Deserializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/index.json:    \"description\": \"jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back using Jackson.\",\nmetadata/io.jsonwebtoken/jjwt-jackson/index.json:    \"description\": \"jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back 