      public void setValueReference(
          ValueReference<K, V> valueReference) {
        this.valueReference = valueReference;
      }
      public void valueReclaimed() {
        internals.removeEntry(this, null);
      }
      public ReferenceEntry<K, V> getNext() {
        return null;
      }
      public int getHash() {
        return hash;
      }
    }
  
