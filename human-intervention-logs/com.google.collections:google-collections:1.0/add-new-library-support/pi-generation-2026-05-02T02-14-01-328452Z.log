[tool-call] delta {"path":"tests/src/com.google.collections/google-collections/1.0/src/test/java/com_google_collections/google_collections/FinalizableReferenceQueueInnerSystemLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_collections.google_collections;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.base.FinalizableReferenceQueue;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class FinalizableReferenceQueueInnerSystemLoaderTest {\n    @Test\n    void finalizableReferenceQueueUsesSystemLoaderWhenFinalizerIsOnSystemClasspath() {\n        try {\n            FinalizableReferenceQueue queue = new FinalizableReferenceQueue();\n\n            assertThat(queue).isNotNull();\n            if (ClassLoader.getSystemClassLoader() instanceof FinalizerHidingSystemClassLoader) {\n                assertThat(FinalizerHidingSystemClassLoader.resolvedFinalizerLookup()).isTrue();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n}\n"}
