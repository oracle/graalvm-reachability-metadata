  package com_google_collections.google_collections;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.base.FinalizableReferenceQueue;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class FinalizableReferenceQueueInnerSystemLoaderTest {
      @Test
      void finalizableReferenceQueueUsesSystemLoaderWhenFinalizerIsOnSystemClasspath() {
          try {
              FinalizableReferenceQueue queue = new FinalizableReferenceQueue();
  
              assertThat(queue).isNotNull();
              if (ClassLoader.getSystemClassLoader() instanceof FinalizerHidingSystemClassLoader) {
                  assertThat(FinalizerHidingSystemClassLoader.resolvedFinalizerLookup()).isTrue();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  }
