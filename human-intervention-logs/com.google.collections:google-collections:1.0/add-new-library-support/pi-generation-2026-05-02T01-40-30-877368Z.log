  @GwtCompatible
  public final class HashBiMap<K, V> extends AbstractBiMap<K, V> {
  
    /**
     * Returns a new, empty {@code HashBiMap} with the default initial capacity
     * (16).
     */
    public static <K, V> HashBiMap<K, V> create() {
