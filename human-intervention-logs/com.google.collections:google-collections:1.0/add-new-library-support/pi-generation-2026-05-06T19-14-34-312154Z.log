  package com_google_collections.google_collections;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.common.collect.ArrayListMultimap;
  import com.google.common.collect.HashBiMap;
  import com.google.common.collect.HashMultiset;
  import com.google.common.collect.ImmutableListMultimap;
  import com.google.common.collect.ImmutableMultiset;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.junit.jupiter.api.Test;
  
  public class SerializationTest {
      @Test
      void serializesAndDeserializesHashBiMapEntries() throws Exception {
          HashBiMap<String, String> map = HashBiMap.create();
          map.put("one", "first");
          map.put("two", "second");
  
          HashBiMap<String, String> deserialized = roundTrip(map);
  
          assertThat(deserialized).containsEntry("one", "first");
          assertThat(deserialized).containsEntry("two", "second");
          assertThat(deserialized.inverse()).containsEntry("first", "one");
          assertThat(deserialized.inverse()).containsEntry("second", "two");
      }
  
      @Test
      void serializesAndDeserializesHashMultisetCounts() throws Exception {
          HashMultiset<String> multiset = HashMultiset.create();
          multiset.add("alpha", 3);
          multiset.add("bravo", 2);
  
          HashMultiset<String> deserialized = roundTrip(multiset);
  
          assertThat(deserialized.count("alpha")).isEqualTo(3);
          assertThat(deserialized.count("bravo")).isEqualTo(2);
          assertThat(deserialized.elementSet()).containsExactlyInAnyOrder("alpha", "bravo");
      }
  
      @Test
      void serializesAndDeserializesArrayListMultimapKeysAndValues() throws Exception {
          ArrayListMultimap<String, String> multimap = ArrayListMultimap.create();
          multimap.put("fruit", "apple");
          multimap.put("fruit", "pear");
          multimap.put("color", "blue");
  
          ArrayListMultimap<String, String> deserialized = roundTrip(multimap);
  
          assertThat(deserialized.get("fruit")).containsExactly("apple", "pear");
          assertThat(deserialized.get("color")).containsExactly("blue");
          assertThat(deserialized.size()).isEqualTo(3);
      }
  
      @Test
      void deserializesImmutableCollectionsWithFinalFields() throws Exception {
