          = ImmutableMap.builder();
      int tmpSize = 0;
  
      for (int i = 0; i < keyCount; i++) {
        Object key = stream.readObject();
        int valueCount = stream.readInt();
        if (valueCount <= 0) {
          throw new InvalidObjectException("Invalid value count " + valueCount);
