      testImplementation sourceSets.testSystemClassLoader.output
  }
  
  tasks.withType(Test).configureEach {
      dependsOn(tasks.named("compileTestSystemClassLoaderJava"))
      jvmArgs += [
          "--add-opens=java.base/java.lang=ALL-UNNAMED",
          '-Djava.system.class.loader=com_google_collections.google_collections.FinalizerHidingSystemClassLoader'
      ]
  }
  
