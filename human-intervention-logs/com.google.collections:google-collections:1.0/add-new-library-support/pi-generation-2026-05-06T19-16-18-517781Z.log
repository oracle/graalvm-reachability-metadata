(\n                \"fruit=1\",\n                \"color=10\",\n                \"fruit=2\",\n                \"null=99\",\n                \"fruit=null\");\n        assertThat(copy.get(\"fruit\")).containsExactly(1, 2, null);\n        assertThat(copy.get(\"color\")).containsExactly(10);\n        assertThat(copy.get(null)).containsExactly(99);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n\n    private static List<String> entryDescriptions(ListMultimap<String, Integer> multimap) {\n        List<String> descriptions = new ArrayList<String>();\n        for (Map.Entry<String, Integer> entry : multimap.entries()) {\n            descriptions.add(entry.getKey() + \"=\" + entry.getValue());\n        }\n        return descriptions;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2077, "output": 819, "cacheRead": 11776, "cacheWrite": 0, "totalTokens": 14672, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778094961546, "responseId": "resp_00e345c1c305eff40169fb937253e8819796d19f4e3e2f45bc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_EPKSVu3P13iLzGW8kXhDIGHx|fc_00e345c1c305eff40169fb9375e8d0819783df3b62b1735fc1", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2468 bytes to tests/src/com.google.collections/google-collections/1.0/src/test/java/com_google_collections/google_collections/LinkedListMulti