eReferenceQueueInnerDecoupledLoaderTest {\n    private static final String FINALIZABLE_REFERENCE_QUEUE_CLASS =\n            \"com.google.common.base.FinalizableReferenceQueue\";\n    private static final String GOOGLE_COLLECTIONS_PACKAGE = \"com.google.common.base.\";\n    private static final String REFERENCE_QUEUE_RESOURCE =\n            \"com/google/common/base/FinalizableReferenceQueue.class\";\n    private static final String SYSTEM_LOADER_CLASS =\n            \"com.google.common.base.FinalizableReferenceQueue$SystemLoader\";\n\n    @Test\n    void childLoadedReferenceQueueFallsBackToDecoupledFinalizerLoader() throws Exception {\n        try {\n            instantiateReferenceQueueWithSystemLoaderDenied();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void instantiateReferenceQueueWithSystemLoaderDenied() throws Exception {\n        URL libraryLocation = googleCollectionsLocation();\n        try (IsolatedGoogleCollectionsClassLoader classLoader =\n                new IsolatedGoogleCollectionsClassLoader(new URL[] {libraryLocation})) {\n            Class<?> queueClass = classLoader.loadClass(FINALIZABLE_REFERENCE_QUEUE_CLASS);\n            SecurityManager previousSecurityManager = System.getSecurityManager();\n            SystemLoaderDenyingSecurityManager securityManager =\n                    new SystemLoaderDenyingSecurityManager();\n            boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);\n            try {\n                Object queue = queueClass.getConstructor().newInstance();\n\n                assertThat(queue).isNotNull();\n                assertThat(queue.getClass().getClassLoader()).isSameAs(classLoader);\n                if (securityManagerInstalled) {\n                    assertThat(securityManager.deniedSystemLoaderLookup()).isTrue();\n                }\n            } finally {\n                if (securityManagerInstalled) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n            }\n        }\n    }\n\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n        try {\n            System.setSecurityManager(securityManager);\n            return true;\n        } catch (UnsupportedOperationException unsupportedOperationException) {\n            return false;\n        }\n    }\n\n    private static URL googleCollectionsLocation() throws IOException {\n        ClassLoader classLoader =\n                FinalizableReferenceQueueInnerDecoupledLoaderTest.class.getClassLoader();\n        URL resource = classLoader.getResource(REFERENCE_QUEUE_RESOURCE);\n        assertThat(resource).isNotNull();\n        if (\"jar\".equals(resource.getProtocol())) {\n            JarURLConnection connection = (JarURLConnection) resource.openConnection();\n            return connection.getJarFileURL();\n        }\n        if (\"file\".equals(resource.getProtocol())) {\n            String resourceFile = resource.getFile();\n            String rootFile = resourceFile.substring(\n                    0, resourceFile.length() - REFERENCE_QUEUE_RESOURCE.length());\n            return new File(rootFile).toURI().toURL();\n        }\n        throw new IOException(\"Unsupported class path resource URL: \" + resource);\n    }\n\n    private static final class IsolatedGoogleCollectionsClassLoader extends URLClassLoader {\n        private IsolatedGoogleCollectionsClassLoader(URL[] urls) {\n            super(urls,\n                    FinalizableReferenceQueueInnerDecoupledLoaderTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && name.startsWith(GOOGLE_COLLECTIONS_PACKAGE)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        // Delegate to the parent class loader below.\n                    }\n                }\n                if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n    }\n\n    private static final class SystemLoaderDenyingSecurityManager extends SecurityManager {\n        private boolean deniedSystemLoaderLookup;\n\n        @Override\n        public void checkPermission(Permission permission) {\n            if (isGetClassLoaderPermission(permission)\n                    && isCalledFromGoogleCollectionsSystemLoader()) {\n                deniedSystemLoaderLookup = true;\n                throw new SecurityException(\"System loader lookup intentionally denied\");\n            }\n        }\n\n        private boolean deniedSystemLoaderLookup() {\n            return deniedSystemLoaderLookup;\n        }\n\n        private static boolean isGetClassLoaderPermission(Permission permission) {\n            return permission instanceof RuntimePermission\n                    && \"getClassLoader\".equals(permission.getName());\n        }\n\n        private boolean isCalledFromGoogleCollectionsSystemLoader() {\n            for (Class<?> contextClass : getClassContext()) {\n                if (SYSTEM_LOADER_CLASS.equals(contextClass.getName())) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777685368790}]}
