ows ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && name.startsWith(GOOGLE_COLLECTIONS_PACKAGE)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        // Delegate to the parent class loader below.\n                    }\n                }\n                if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n    }\n\n    private static final class SystemLoaderDenyingSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            if (isGetClassLoaderPermission(permission) && isCalledFromGoogleCollectionsSystemLoader()) {\n                throw new SecurityException(\"System loader lookup intentionally denied\");\n            }\n        }\n\n        private static boolean isGetClassLoaderPermission(Permission permission) {\n            return permission instanceof RuntimePermission && \"getClassLoader\".equals(permission.getName());\n        }\n\n        private boolean isCalledFromGoogleCollectionsSystemLoader() {\n            for (Class<?> contextClass : getClassContext()) {\n                if (SYSTEM_LOADER_CLASS.equals(contextClass.getName())) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n}\n"}
