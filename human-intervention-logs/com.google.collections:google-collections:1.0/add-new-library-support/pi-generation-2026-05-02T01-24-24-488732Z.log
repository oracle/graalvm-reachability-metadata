eturn loadedClass;\n            }\n        }\n    }\n\n    private static final class SystemLoaderDenyingSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            if (isGetClassLoaderPermission(permission) && isCalledFromGoogleCollectionsSystemLoader()) {\n                throw new SecurityException(\"System loader lookup intentionally denied\");\n            }\n        }\n\n        private static boolean isGetClassLoaderPermission(Permission permission) {\n            return permission instanceof RuntimePermission && \"getClassLoader\".equals(permission.getName());\n        }\n\n        private boolean isCalledFromGoogleCollectionsSystemLoader() {\n            for (Class<?> contextClass : getClassContext()) {\n                if (SYSTEM_LOADER_CLASS.equals(contextClass.getName())) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.google.collections/google-collections/1.0/src/test/java/com_google_collections/google_collections/FinalizableReferenceQueueInnerDecoupledLoaderTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_google_collections.google_collections;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.File;\\nimport java.io.IOException;\\nimport java.net.JarURLConnection;\\nimport java.net.URL;\\nimport java.net.URLClassLoader;\\nimport java.security.Permission;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class FinalizableReferenceQueueInnerDecoupledLoaderTest {\\n    private static final String FINALIZABLE_REFERENCE_QUEUE_CLASS =\\n            \\\"com.google.common.base.Finalizabl