text\\\", \\\"text\\\": \\\"     1\\\\t/*\\\\n     2\\\\t * Copyright (c) 2023-2025, the original author(s).\\\\n     3\\\\t *\\\\n     4\\\\t * This software is distributable under the BSD license. See the terms of the\\\\n     5\\\\t * BSD license in the documentation provided with this software.\\\\n     6\\\\t *\\\\n     7\\\\t * https://opensource.org/licenses/BSD-3-Clause\\\\n     8\\\\t */\\\\n     9\\\\tpackage org.jline.terminal.impl;\\\\n    10\\\\t\\\\n    11\\\\timport java.io.FileDescriptor;\\\\n    12\\\\timport java.io.FileInputStream;\\\\n    13\\\\timport java.io.FileOutputStream;\\\\n    14\\\\timport java.io.IOException;\\\\n    15\\\\timport java.io.InputStream;\\\\n    16\\\\timport java.io.OutputStream;\\\\n    17\\\\timport java.nio.charset.Charset;\\\\n    18\\\\t\\\\n    19\\\\timport org.jline.terminal.Attributes;\\\\n    20\\\\timport org.jline.terminal.Size;\\\\n    21\\\\timport org.jline.terminal.Terminal;\\\\n    22\\\\timport org.jline.terminal.TerminalBuilder;\\\\n    23\\\\timport org.jline.terminal.spi.SystemStream;\\\\n    24\\\\timport org.jline.terminal.spi.TerminalProvider;\\\\n    25\\\\t\\\\n    26\\\\t/**\\\\n    27\\\\t * Terminal provider implementation for dumb terminals.\\\\n    28\\\\t *\\\\n    29\\\\t * <p>\\\\n    30\\\\t * The DumbTerminalProvider class provides a TerminalProvider implementation that\\\\n    31\\\\t * creates DumbTerminal instances. Dumb terminals have minimal capabilities and\\\\n    32\\\\t * are used as a fallback when more capable terminal implementations cannot be\\\\n    33\\\\t * created or when running in environments with limited terminal support.\\\\n    34\\\\t * </p>\\\\n    35\\\\t *\\\\n    36\\\\t * <p>\\\\n    37\\\\t * This provider supports two types of dumb terminals:\\\\n    38\\\\t * </p>\\\\n    39\\\\t * <ul>\\\\n    40\\\\t *   <li>Standard dumb terminal ({@link Terminal#TYPE_DUMB}) - No color support</li>\\\\n    41\\\\t *   <li>Color dumb terminal ({@link Terminal#TYPE_DUMB_COLOR}) - Basic color support</li>\\\\n    42\\\\t * </ul>\\\\n    43\\\\t *\\\\n    44\\\\t * <p>\\\\n    45\\\\t * The provider name is \\\\\\\"dumb\\\\\\\", which can be specified in the {@code org.jline.terminal.provider}\\\\n    46\\\\t * system property to force the use of this provider. This is useful in environments\\\\n    47\\\\t * where other terminal providers might not work correctly or when terminal capabilities\\\\n    48\\\\t * are not needed.\\\\n    49\\\\t * </p>\\\\n    50\\\\t *\\\\n    51\\\\t * @see org.jline.terminal.spi.TerminalProvider\\\\n    52\\\\t * @see org.jline.terminal.impl.DumbTerminal\\\\n    53\\\\t */\\\\n    54\\\\tpublic class DumbTerminalProvider implements TerminalProvider {\\\\n    55\\\\t\\\\n    56\\\\t    @Override\\\\n    57\\\\t    public String name() {\\\\n    58\\\\t        return TerminalBuilder.PROP_PROVIDER_DUMB;\\\\n    59\\\\t    }\\\\n    60\\\\t\\\\n    61\\\\t    @Override\\\\n    62\\\\t    public Terminal sysTerminal(\\\\n    63\\\\t            String name,\\\\n    64\\\\t            String type,\\\\n    65\\\\t            boolean ansiPassThrough,\\\\n    66\\\\t            Charset encoding,\\\\n    67\\\\t            Charset inputEncoding,\\\\n    68\\\\t            Charset outputEncoding,\\\\n    69\\\\t            boolean nativeSignals,\\\\n    70\\\\t            Terminal.SignalHandler signalHandler,\\\\n    71\\\\t            boolean paused,\\\\n    72\\\\t            SystemStream systemStream)\\\\n    73\\\\t            throws IOException {\\\\n    74\\\\t        return new DumbTerminal(\\\\n    75\\\\t                this,\\\\n    76\\\\t                systemStream,\\\\n    77\\\\t                name,\\\\n    78\\\\t                type,\\\\n    79\\\\t                new FileInputStream(FileDescriptor.in),\\\\n    80\\\\t                new FileOutputStream(systemStream == SystemStream.Error ? FileDescriptor.err : FileDescriptor.out),\\\\n    81\\\\t                encoding,\\\\n    82\\\\t                inputEncoding,\\\\n    83\\\\t                outputEncoding,\\\\n    84\\\\t                signalHandler);\\\\n    85\\\\t    }\\\\n    86\\\\t\\\\n    87\\\\t    @SuppressWarnings(\\\\\\\"deprecation\\\\\\\")\\\\n    88\\\\t    @Override\\\\n    89\\\\t    public Terminal sysTerminal(\\\\n    90\\\\t            String name,\\\\n    91\\\\t            String type,\\\\n    92\\\\t            boolean ansiPassThrough,\\\\n    93\\\\t            Charset encoding,\\\\n    94\\\\t            Charset stdinEncoding,\\\\n    95\\\\t            Charset stdoutEncoding,\\\\n    96\\\\t            Charset stderrEncoding,\\\\n    97\\\\t            boolean nativeSignals,\\\\n    98\\\\t            Terminal.SignalHandler signalHandler,\\\\n    99\\\\t            boolean paused,\\\\n   100\\\\t            SystemStream systemStream)\\\\n   101\\\\t            throws IOException {\\\\n   102\\\\t        // Use the appropriate output encoding based on the system stream\\\\n   103\\\\t        Charset outputEncoding = systemStream == SystemStream.Error ? stderrEncoding : stdoutEncoding;\\\\n   104\\\\t        return sysTerminal(\\\\n   105\\\\t                name,\\\\n   106\\\\t                type,\\\\n   107\\\\t                ansiPassThrough,\\\\n   108\\\\t                encoding,\\\\n   109\\\\t                stdinEncoding,\\\\n   110\\\\t                outputEncoding,\\\\n   111\\\\t                nativeSignals,\\\\n   112\\\\t                signalHandler,\\\\n   113\\\\t                paused,\\\\n   114\\\\t                systemStream);\\\\n   115\\\\t    }\\\\n   116\\\\t\\\\n   117\\\\t    @Override\\\\n   118\\\\t    public Terminal newTerminal(\\\\n   119\\\\t            String name,\\\\n   120\\\\t            String type,\\\\n   121\\\\t            InputStream masterInput,\\\\n   122\\\\t            OutputStream masterOutput,\\\\n   123\\\\t            Charset encoding,\\\\n   124\\\\t            Charset inputEncoding,\\\\n   125\\\\t            Charset