er implementation that\n    31\t * creates DumbTerminal instances. Dumb terminals have minimal capabilities and\n    32\t * are used as a fallback when more capable terminal implementations cannot be\n    33\t * created or when running in environments with limited terminal support.\n    34\t * </p>\n    35\t *\n    36\t * <p>\n    37\t * This provider supports two types of dumb terminals:\n    38\t * </p>\n    39\t * <ul>\n    40\t *   <li>Standard dumb terminal ({@link Terminal#TYPE_DUMB}) - No color support</li>\n    41\t *   <li>Color dumb terminal ({@link Terminal#TYPE_DUMB_COLOR}) - Basic color support</li>\n    42\t * </ul>\n    43\t *\n    44\t * <p>\n    45\t * The provider name is \"dumb\", which can be specified in the {@code org.jline.terminal.provider}\n    46\t * system property to force the use of this provider. This is useful in environments\n    47\t * where other terminal providers might not work correctly or when terminal capabilities\n    48\t * are not needed.\n    49\t * </p>\n    50\t *\n    51\t * @see org.jline.terminal.spi.TerminalProvider\n    52\t * @see org.jline.terminal.impl.DumbTerminal\n    53\t */\n    54\tpublic class DumbTerminalProvider implements TerminalProvider {\n    55\t\n    56\t    @Override\n    57\t    public String name() {\n    58\t        return TerminalBuilder.PROP_PROVIDER_DUMB;\n    59\t    }\n    60\t\n    61\t    @Override\n    62\t    public Terminal sysTerminal(\n    63\t            String name,\n    64\t            String type,\n    65\t            boolean ansiPassThrough,\n    66\t            Charset encoding,\n    67\t            Charset inputEncoding,\n    68\t            Charset outputEncoding,\n    69\t            boolean nativeSignals,\n    70\t            Terminal.SignalHandler signalHandler,\n    71\t            boolean paused,\n    72\t            SystemStream systemStream)\n    73\t            throws IOException {\n    74\t        return new DumbTerminal(\n    75\t                this,\n    76\t                systemStream,\n    77\t                name,\n    78\t                type,\n    79\t                new FileInputStream(FileDescriptor.in),\n    80\t                new FileOutputStream(systemStream == SystemStream.Error ? FileDescriptor.err : FileDescriptor.out),\n    81\t                encoding,\n    82\t                inputEncoding,\n    83\t                outputEncoding,\n    84\t                signalHandler);\n    85\t    }\n    86\t\n    87\t    @SuppressWarnings(\"deprecation\")\n    88\t    @Override\n    89\t    public Terminal sysTerminal(\n    90\t            String name,\n    91\t            String type,\n    92\t            boolean ansiPassThrough,\n    93\t            Charset encoding,\n    94\t            Charset stdinEncoding,\n    95\t            Charset stdoutEncoding,\n    96\t            Charset stderrEncoding,\n    97\t            boolean nativeSignals,\n    98\t            Terminal.SignalHandler signalHandler,\n    99\t            boolean paused,\n   100\t            SystemStream systemStream)\n   101\t            throws IOException {\n   102\t        // Use the appropriate output encoding based on the system stream\n   103\t        Charset outputEncoding = systemStream == SystemStream.Error ? stderrEncoding : stdoutEncoding;\n   104\t        return sysTerminal(\n   105\t                name,\n   106\t                type,\n   107\t                ansiPassThrough,\n   108\t                encoding,\n   109\t                stdinEncoding,\n   110\t                outputEncoding,\n   111\t                nativeSignals,\n   112\t                signalHandler,\n   113\t                paused,\n   114\t                systemStream);\n   115\t    }\n   116\t\n   117\t    @Override\n   118\t    public Terminal newTerminal(\n   119\t            String name,\n   120\t            String type,\n   121\t            InputStream masterInput,\n   122\t            OutputStream masterOutput,\n   123\t            Charset encoding,\n   124\t            Charset inputEncoding,\n   125\t            Charset outputEncoding,\n   126\t            Terminal.SignalHandler signalHandler,\n   127\t            boolean paused,\n   128\t            Attributes attributes,\n   129\t            Size size)\n   130\t            throws IOException {\n   131\t        throw new UnsupportedOperationException();\n   132\t    }\n   133\t\n   134\t    @SuppressWarnings(\"deprecation\")\n   135\t    @Override\n   136\t    public Terminal newTerminal(\n   137\t            String name,\n   138\t            String type,\n   139\t            InputStream masterInput,\n   140\t            OutputStream masterOutput,\n   141\t            Charset encoding,\n   142\t            Charset stdinEncoding,\n   143\t            Charset stdoutEncoding,\n   144\t            Charset stderrEncoding,\n   145\t            Terminal.SignalHandler signalHandler,\n   146\t            boolean paused,\n   147\t            Attributes attributes,\n   148\t            Size size)\n   149\t            throws IOException {\n   150\t        return newTerminal(\n   151\t                name,\n   152\t                type,\n   153\t                masterInput,\n   154\t                masterOutput,\n   155\t                encoding,\n   156\t                stdinEncoding,\n   157\t                stdoutEncoding,\n   158\t                signalHandler,\n   159\t                paused,\n   160\t                attributes,\n   161\t                size);\n   162\t    }\n   163\t\n   164\t    @Override\n   165\t    public boolean isSystemStream(SystemStream stream) {\n   166\t        return false;\n   167\t    }\n   168\t\n   169\t    @Override\n   170\t    public String systemStreamName(SystemStream stream) {\n   171\t        return null;\n   172\t    }\n   173\t\n   174\t    @Override\n   175\t    public int systemStreamWidth(SystemStream stream) {\n   176\t        return 0;\n   177\t    }\n   178\t\n   179\t    @Override\n   180\t    public String toString() {\n"}], "isError