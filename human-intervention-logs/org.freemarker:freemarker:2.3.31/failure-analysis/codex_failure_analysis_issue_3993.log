hat(wrapJythonStringWithIsolatedFreemarker(\\\"2.1.0\\\"))\\n                    .startsWith(\\\"freemarker.ext.jython.\\\");\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    private static String wrapJythonStringWithIsolatedFreemarker(String jythonVersion) throws Exception {\\n        try (VersionedJythonClassLoader classLoader = new VersionedJythonClassLoader(classpathUrls(), jythonVersion)) {\\n            Class<?> wrapperClass = classLoader.loadClass(JYTHON_WRAPPER_CLASS);\\n            ObjectWrapper wrapper = (ObjectWrapper) wrapperClass.getConstructor().newInstance();\\n\\n            Object templateModel = wrapper.wrap(\\\"value\\\");\\n\\n            Assertions.assertThat(templateModel).isNotNull();\\n            return templateModel.getClass().getName();\\n        }\\n    }\\n\\n    private static URL[] classpathUrls() {\\n        String classPath = System.getProperty(\\\"java.class.path\\\");\\n        return Arrays.stream(classPath.split(File.pathSeparator))\\n                .filter(entry -> !entry.isEmpty())\\n                .map(entry -> new File(entry).toURI())\\n                .map(uri -> {\\n                    try {\\n                        return uri.toURL();\\n                    } catch (Exception exception) {\\n                        throw new IllegalArgumentException(\\\"Invalid classpath entry\\\", exception);\\n                    }\\n                })\\n                .toArray(URL[]::new);\\n    }\\n\\n    private static final class VersionedJythonClassLoader extends URLClassLoader {\\n        private final String jythonVersion;\\n\\n        private VersionedJythonClassLoader(URL[] urls, String jythonVersion) {\\n            super(urls, FreemarkerExtJythonJythonVersionAdapterHolderTest.class.getClassLoader());\\n            this.jythonVersion = jythonVersion;\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            synchronized (getClassLoadingLock(name)) {\\n                Class<?> loadedClass = findLoadedClass(name);\\n                if (loadedClass == null) {\\n                    loadedClass = loadClassFromThisLoaderFirst(name);\\n                }\\n                if (resolve) {\\n                    resolveClass(loadedClass);\\n                }\\n                return loadedClass;\\n            }\\n        }\\n\\n        private Class<?> loadClassFromThisLoaderFirst(String name) throws ClassNotFoundException {\\n            if (PY_SYSTEM_STATE_CLASS.equals(name)) {\\n                return defineVersionedPySystemState();\\n            }\\n            if (PY_JAVA_INSTANCE_CLASS.equals(name)) {\\n                return defineClass(name, PY_JAVA_INSTANCE_CLASS_BYTES, 0, PY_JAVA_INSTANCE_CLASS_BYTES.length);\\n            }\\n            if (name.startsWith(\\\"freemarker.ext.jython.\\\")) {\\n                try {\\n                    return findClass(name);\\n                } catch (ClassNotFoundException exception) {\\n                    return super.loadClass(name, false);\\n                }\\n            }\\n            return super.loadClass(name, false);\\n        }\\n\\n        private Class<?> defineVersionedPySystemState() {\\n            byte[] classBytes = Arrays.copyOf(PY_SYSTEM_STATE_CLASS_BYTES, PY_SYSTEM_STATE_CLASS_BYTES.length);\\n            byte[] originalVersionBytes = \\\"2.7.3\\\".getBytes(StandardCharsets.UTF_8);\\n            byte[] replacementVersionBytes = jythonVersion.getBytes(StandardCharsets.UTF_8);\\n            Assertions.assertThat(replacementVersionBytes).hasSize(originalVersionBytes.length);\\n            for (int index = 0; index <= classBytes.length - originalVersionBytes.length; index++) {\\n                if (matchesAt(classBytes, originalVersionBytes, index)) {\\n                    System.arraycopy(replacementVersionBytes