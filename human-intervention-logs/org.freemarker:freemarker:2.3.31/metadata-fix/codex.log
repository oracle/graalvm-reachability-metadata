{"type":"item.completed","item":{"id":"item_51","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,220p' tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtJythonJythonVersionAdapterHolderTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.File;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Arrays;\nimport java.util.Base64;\n\nimport freemarker.template.ObjectWrapper;\nimport org.assertj.core.api.Assertions;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtJythonJythonVersionAdapterHolderTest {\n    private static final String JYTHON_WRAPPER_CLASS = \"freemarker.ext.jython.JythonWrapper\";\n    private static final String PY_SYSTEM_STATE_CLASS = \"org.python.core.PySystemState\";\n    private static final String PY_JAVA_INSTANCE_CLASS = \"org.python.core.PyJavaInstance\";\n    private static final byte[] PY_SYSTEM_STATE_CLASS_BYTES = Base64.getDecoder().decode(\n            \"yv66vgAAAEUAFAoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW\"\n                    + \"CAAIAQAFMi43LjMJAAoACwcADAwADQAOAQAdb3JnL3B5dGhvbi9jb3JlL1B5U3lzdGVtU3RhdGUB\"\n                    + \"AAd2ZXJzaW9uAQASTGphdmEvbGFuZy9TdHJpbmc7AQAEQ29kZQEAD0xpbmVOdW1iZXJUYWJsZQEA\"\n                    + \"CDxjbGluaXQ+AQAKU291cmNlRmlsZQEAElB5U3lzdGVtU3RhdGUuamF2YQAxAAoAAgAAAAEACQAN\"\n                    + \"AA4AAAACAAIABQAGAAEADwAAACEAAQABAAAABSq3AAGxAAAAAQAQAAAACgACAAAABgAEAAcACAAR\"\n                    + \"AAYAAQAPAAAAHgABAAAAAAAGEgezAAmxAAAAAQAQAAAABgABAAAABAABABIAAAACABM=\");\n    private static final byte[] PY_JAVA_INSTANCE_CLASS_BYTES = Base64.getDecoder().decode(\n            \"yv66vgAAAEUADQoAAgADBwAEDAAFAAYBABhvcmcvcHl0aG9uL2NvcmUvUHlPYmplY3QBAAY8aW5p\"\n                    + \"dD4BAAMoKVYHAAgBAB5vcmcvcHl0aG9uL2NvcmUvUHlKYXZhSW5zdGFuY2UBAARDb2RlAQAPTGlu\"\n                    + \"ZU51bWJlclRhYmxlAQAKU291cmNlRmlsZQEAE1B5SmF2YUluc3RhbmNlLmphdmEAIQAHAAIAAAAA\"\n                    + \"AAEAAQAFAAYAAQAJAAAAHQABAAEAAAAFKrcAAbEAAAABAAoAAAAGAAEAAAADAAEACwAAAAIADA==\");\n\n    @Test\n    void selectsJythonVersionAdaptersForAllSupportedVersionRanges() throws Exception {\n        try {\n            Assertions.assertThat(wrapJythonStringWithIsolatedFreemarker(\"2.5.0\"))\n                    .startsWith(\"freemarker.ext.jython.\");\n            Assertions.assertThat(wrapJythonStringWithIsolatedFreemarker(\"2.2.0\"))\n                    .startsWith(\"freemarker.ext.jython.\");\n            Assertions.assertThat(wrapJythonStringWithIsolatedFreemarker(\"2.1.0\"))\n                    .startsWith(\"freemarker.ext.jython.\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static String wrapJythonStringWithIsolatedFreemarker(String jythonVersion) throws Exception {\n        try (VersionedJythonClassLoader classLoader = new VersionedJythonClassLoader(classpathUrls(), jythonVersion)) {\n            Class<?> wrapperClass = classLoader.loadClass(JYTHON_WRAPPER_CLASS);\n            ObjectWrapper wrapper = (ObjectWrapper) wrapperClass.getConstructor().newInstance();\n\n            Object templateModel = wrapper.wrap(\"value\");\n\n            Assertions.assertThat(templateModel).isNotNull();\n            return templateModel.getClass().getName();\n        }\n    }\n\n    private static URL[] classpathUrls() {\n        String classPath = System.getProperty(\"java.class.path\");\n        return Arrays.stream(classPath.split(File.pathSeparator))\n                .filter(entry -> !entry.isEmpty())\n                .map(entry -> new File(entry).toURI())\n                .map(uri -> {\n                    try {\n                        return uri.toURL();\n                    } catch (Exception exception) {\n                        throw new IllegalArgumentException(\"Invalid classpath entry\", exception);\n                    }\n                })\n                .toArray(URL[]::new);\n    }\n\n    private static final class VersionedJythonClassLoader extends URLClassLoader {\n        private final String jythonVersion;\n\n        private VersionedJythonClassLoader(URL[] urls, String jythonVersion) {\n            super(urls, FreemarkerExtJythonJythonVersionAdapterHolderTest.class.getClassLoader());\n            this.jythonVersion = jythonVersion;\n        }\n\n        @Override\n        public Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = loadClassFromThisLoaderFirst(name);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> loadClassFromThisLoaderFirst(String name) throws ClassNotFoundException {\n            if (PY_SYSTEM_STATE_CLASS.equals(name)) {\n                return defineVersionedPySystemState();\n            }\n            if (PY_JAVA_INSTANCE_CLASS.equals(name)) {\n                return defineClass(name, PY_JAVA_INSTANCE_CLASS_BYTES, 0, PY_JAVA_INSTANCE_CLASS_BYTES.length);\n            }\n            if (name.startsWith(\"freemarker.ext.jython.\")) {\n                try {\n                    return findClass(name);\n                } catch (ClassNotFoundException exception) {\n                    return super.loadClass(name, false);\n                }\n            }\n            return super.loadClass(name, false);\n        }\n\n        private Class<?> defineVersionedPySystemState() {\n            byte[] classBytes = Arrays.copyOf(PY_SYSTEM_STATE_CLASS_BYTES, PY_SYSTEM_STATE_CLASS_BYTES.length);\n            byte[] originalVersionBytes = \"2.7.3\".getBytes(StandardCharsets.UTF_8);\n            byte[] replacementVersionBytes = jythonVersion.getBytes(StandardCharsets.UTF_8);\n            Assertions.assertThat(replacementVersionBytes).hasSize(originalVersionBytes.length);\n            for (int index = 0; index <= classBytes.length - originalVersionBytes.length; index++) {\n                if (matchesAt(classBytes, originalVersionBytes, index)) {\n                    System.arraycopy(replacementVersionBytes, 0, classBytes, index, replacementVersionBytes.length);\n                    return defineClass(PY_SYSTEM_STATE_CLASS, classBytes, 0, classBytes.length);\n                }\n            }\n            throw new IllegalStateException(\"Unable to patch Jython version stub\");\n        }\n\n        private static boolean matchesAt(byte[] classBytes, byte[] expectedBytes, int offset) {\n            for (int index = 0; index < expectedBytes.length; index++) {\n                if (classBytes[offset + index] != expectedBytes[index]) {\n                    return false;\n                }\n            }\n            return true;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
