Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        wrapper.setExposeFields(true);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new FieldBackedBean(\"visible\"));\n\n        TemplateScalarModel value = (TemplateScalarModel) model.get(\"label\");\n\n        Assertions.assertThat(value.getAsString())\n                .isEqualTo(\"visible\");\n    }\n\n    public static class FineTuningBeansWrapper extends BeansWrapper {\n        public FineTuningBeansWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n\n        @Override\n        @SuppressWarnings(\"deprecation\")\n        protected void finetuneMethodAppearance(\n                Class<?> clazz, Method method, MethodAppearanceDecision decision) {\n            super.finetuneMethodAppearance(clazz, method, decision);\n        }\n    }\n\n    public static class OverloadedArrayConsumer {\n        public String join(String[] values) {\n            return String.join(\"|\", values);\n        }\n\n        public String join(Integer value) {\n            return String.valueOf(value);\n        }\n    }\n\n    public static class SingleConstructorBean {\n        private final String name;\n\n        public SingleConstructorBean(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    public static class FieldBackedBean {\n        public String label;\n\n        public FieldBackedBean(String label) {\n            this.label = label;\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1777635739732}]}
