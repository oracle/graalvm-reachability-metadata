993976e800169f4a2ad4b4c819294b4c0caa587e77a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\nimport java.util.Collections;\nimport java.util.List;\n\nimport freemarker.ext.beans.BeansWrapper;\nimport freemarker.template.Configuration;\nimport freemarker.template.SimpleScalar;\nimport freemarker.template.TemplateHashModel;\nimport freemarker.template.TemplateMethodModelEx;\nimport freemarker.template.TemplateModel;\nimport freemarker.template.TemplateScalarModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtBeansBeansWrapperTest {\n\n    @Test\n    void subclassConstructionDetectsLegacyMethodAppearanceOverride() {\n        FineTuningBeansWrapper wrapper = new FineTuningBeansWrapper();\n\n        Assertions.assertThat(wrapper.getIncompatibleImprovements())\n                .isEqualTo(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n    }\n\n    @Test\n    void unwrapsTemplateSequenceToJavaArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        TemplateModel sequence = wrapper.wrap(Arrays.asList(\"north\", \"south\"));\n\n        Object unwrapped = wrapper.unwrap(sequence, String[].class);\n\n        Assertions.assertThat((String[]) unwrapped)\n                .containsExactly(\"north\", \"south\");\n    }\n\n    @Test\n    void overloadedMethodConvertsListArgumentToArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.VERSION_2_3_21);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new OverloadedArrayConsumer());\n        TemplateMethodModelEx join = (TemplateMethodModelEx) model.get(\"join\");\n        List<TemplateModel> arguments = Collections.singletonList(wrapper.wrap(Arrays.asList(\"red\", \"blue\")));\n\n        TemplateScalarModel result = (TemplateScalarModel) join.exec(arguments);\n\n        Assertions.assertThat(result.getAsString())\n                .isEqualTo(\"red|blue\");\n    }\n\n    @Test\n    void createsInstanceThroughBeansWrapperConstructorSupport() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        List<TemplateModel> arguments = Collections.singletonList(new SimpleScalar(\"created\"));\n\n        Object instance = wrapper.newInstance(SingleConstructorBean.class, arguments);\n\n        Assertions.assertThat(instance)\n                .isInstanceOfSatisfying(SingleConstructorBean.class, bean -> Assertions.assertThat(bean.getName())\n                        .isEqualTo(\"created\"));\n    }\n\n    @Test\n    void readsExposedPublicInstanceField() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        wrapper.setExposeFields(true);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new FieldBackedBean(\"visible\"));\n\n        TemplateScalarModel value = (TemplateScalarModel) model.get(\"label\");\n\n        Assertions.assertThat(value.getAsString())\n                .isEqualTo(\"visible\");\n    }\n\n    public static class FineTuningBeansWrapper extends BeansWrapper {\n        public FineTuningBeansWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n\n        @Override\n        @SuppressWarnings(\"deprecation\")\n        protected void finetuneMethodAppearance(\n                Class<?> clazz, Method method, MethodAppearanceDecision decision) {\n            super.finetuneMethodAppearance(clazz, method, decision);\n        }\n    }\n\n    public static class OverloadedArrayConsumer {\n        public String join(String[] values) {\n            return String.join(\"|\", values);\n        }\n\n        public String join(Integer value) {\n            return String.valueOf(value);\n        }\n    }\n\n    public static class SingleConstructorBean {\n        private final String name;\n\n        public SingleConstructorBean(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    public static class FieldBackedBean {\n        public String label;\n\n        public FieldBackedBean(String label) {\n            this.label = label;\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1777640109620}, {"role": "toolResult", "toolCallId": "call_7hvIE7UklfHHL6FXCHaQgsmT|fc_0b8696a993976e800169f4a2ad4b5c81928311f0a942d02e5b", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.util.Collections;\n\nimport freemarker.ext.beans.BeansWrapper;\nimport freemarker.ext.beans.TemplateAccessible;\nimport freemarker.ext.beans.WhitelistMemberAccessPolicy;\nimport freemarker.template.Configuration;\nimport freemarker.template.SimpleScalar;\nimport freemarker.template.TemplateHashModel;\nimport freemarker.template.TemplateMethodModelEx;\nimport freemarker.template.TemplateModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtBeansMethodUtilTest {\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleMethodOnSuperclass() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new SuperclassMethodBean());\n\n        TemplateMethodModelEx method = (TemplateMethodModelEx) model.get(\"superclassMessage\");\n        TemplateModel result = (TemplateModel) method.exec(Collections.emptyList());\n\n        Assertions.assertThat(wrapper.unwrap(result))\n                .isEqualTo(\"method from subclass\");\n    }\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleMethodOnInterface() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new InterfaceMethodBean());\n\n        TemplateMethodModelEx method = (TemplateMethodModelEx) model.get(\"interfaceMessage\");\n        TemplateModel result = (TemplateModel) method.exec(Collections.emptyList());\n\n        Assertions.assertThat(wrapper.unwrap(result))\n                .isEqualTo(\"method from implementation\");\n    }\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleConstructorOnSuperclass() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\n        TemplateModel argument = new SimpleScalar(\"constructed through subclass\");\n\n        Object instance = wrapper.newInstance(ConstructorBean.class, Collections.singletonList(argument));\n\n        Assertions.assertThat(instance)\n                .isInstanceOfSatisfying(ConstructorBean.class, bean -> Assertions.assertThat(bean.getValue())\n                        .isEqualTo(\"constructed through subclass\"));\n    }\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleFieldsOnSuperclassAndInterface() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(true);\n        TemplateHashModel superclassModel = (TemplateHashModel) wrapper.wrap(new SuperclassFieldBean());\n        TemplateHashModel interfaceModel = (TemplateHashModel) wrapper.wrap(new InterfaceFieldBean());\n\n        TemplateModel superclassField = superclassModel.get(\"superclassField\");\n        TemplateModel interfaceField = interfaceModel.get(\"interfaceField\");\n\n        Assertions.assertThat(wrapper.unwrap(superclassField))\n                .isIn(\"field from subclass\", \"field from superclass\");\n        Assertions.assertThat(wrapper.unwrap(interfaceField))\n                .isEqualTo(\"field from implementation\");\n    }\n\n    private BeansWrapper newAnnotationOnlyWrapper(boolean exposeFields) {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        wrapper.setExposeFields(exposeFields);\n        wrapper.setMemberAccessPolicy(new WhitelistMemberAccessPolicy(Collections.emptyList()));\n        return wrapper;\n    }\n\n    public static class AnnotatedMethodBase {\n        @TemplateAccessible\n        public String superclassMessage() {\n            return \"method from superclass\";\n        }\n    }\n\n    public static class SuperclassMethodBean extends AnnotatedMethodBase {\n        @Override\n        public String superclassMessage() {\n            return \"method from subclass\";\n        }\n    }\n\n    public interface AnnotatedMethodContract {\n        @TemplateAccessible\n        String interfaceMessage();\n    }\n\n    public static class InterfaceMethodBean implements AnnotatedMethodContract {\n        @Override\n        public String interfaceMessage() {\n            return \"method from implementation\";\n        }\n    }\n\n    public static class AnnotatedConstructorBase {\n        private final String value;\n\n        @TemplateAccessible\n        public AnnotatedConstructorBase(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n\n    public static class ConstructorBean extends AnnotatedConstructorBase {\n        public ConstructorBean(String value) {\n            super(value);\n        }\n    }\n\n    public static class AnnotatedFieldBase {\n        @TemplateAccessible\n        public String superclassField = \"field from superclass\";\n    }\n\n    public static class SuperclassFieldBean extends AnnotatedFieldBase {\n        public String superclassField = \"field from subclass\";\n    }\n\n    public interface AnnotatedFieldContract {\n        @TemplateAccessible\n        String interfaceField = \"field from interface\";\n    }\n\n    public static class InterfaceFieldBean implements AnnotatedFieldContract {\n        public String interfaceField = \"field from implementation\";\n    }\n\n}\n"}], "isError": false, "timestamp": 1777640109624}, {"role": "toolResult", "toolCallId": "call_6P2iKrMWABvYBRO3MNxUzNWt|fc_0b8696a993976e800169f4a2ad4b648192a3edb2f6dc2973c1", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classes\" : [ {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"freemarker.debug.impl.RmiDebugModelImpl_Stub.class$(Unknown Source)\",\n      \"line\" : null,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#forName(java.lang.String)\"\n    }, {\n      \"covered\" : false,\n      \"frame\" : \"freemarker.debug.impl.RmiDebugModelImpl_Stub.<clinit>(Unknown Source)\",\n      \"line\" : null,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#getMethod(java.lang.String, java.lang.Class[])\"\n    } ],\n    \"className\" : \"freemarker.debug.impl.RmiDebugModelImpl_Stub\",\n    \"coveredCalls\" : 0,\n    \"sourceFile\" : \"Unknown Source\",\n    \"totalCalls\" : 2\n  }, {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"freemarker.debug.impl.RmiDebuggedEnvironmentImpl_Stub.class$(Unknown Source)\",\n      \"line\" : null,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#forName(java.lang.String)\"\n    }, {\n      \"covered\" : false,\n      \"frame\" : \"freemarker.debug.impl.RmiDebuggedEnvironmentImpl_Stub.<clinit>(Unknown Source)\",\n      \"line\" : null,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#getMethod(java.lang.String, java.lang.Class[])\"\n    } ],\n    \"className\" : \"freemarker.debug.