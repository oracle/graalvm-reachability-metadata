domain/zero/1.0/>.\n */\npackage fm;\n\nimport java.util.Arrays;\nimport java.util.List;\n\nimport freemarker.ext.beans.BeansWrapper;\nimport freemarker.template.Configuration;\nimport freemarker.template.TemplateHashModel;\nimport freemarker.template.TemplateMethodModelEx;\nimport freemarker.template.TemplateModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtBeansOverloadedVarArgsMethodsTest {\n\n    @Test\n    void overloadedVarArgsPacksMultipleTrailingArgumentsIntoArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        TemplateMethodModelEx method = getMethod(wrapper);\n        List<TemplateModel> arguments = Arrays.asList(\n                wrapper.wrap(\"prefix\"),\n                wrapper.wrap(\"alpha\"),\n                wrapper.wrap(\"beta\"));\n\n        Object result = wrapper.unwrap((TemplateModel) method.exec(arguments));\n\n        Assertions.assertThat(result)\n                .isEqualTo(\"prefix:alpha|beta\");\n    }\n\n    @Test\n    void overloadedVarArgsPacksSingleTrailingArgumentIntoArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        TemplateMethodModelEx method = getMethod(wrapper);\n        List<TemplateModel> arguments = Arrays.asList(\n                wrapper.wrap(\"prefix\"),\n                wrapper.wrap(\"solo\"));\n\n        Object result = wrapper.unwrap((TemplateModel) method.exec(arguments));\n\n        Assertions.assertThat(result)\n                .isEqualTo(\"prefix:solo\");\n    }\n\n    private TemplateMethodModelEx getMethod(BeansWrapper wrapper) throws Exception {\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new VarArgsTarget());\n        return (TemplateMethodModelEx) model.get(\"format\");\n    }\n\n    public static class VarArgsTarget {\n        public String format(String prefix, String... values) {\n            return prefix + \":\" + String.join(\"|\", values);\n        }\n\n        public String format(Integer value) {\n            return \"number:\" + value;\n        }\n    }\n\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtBeansOverloadedVarArgsMethodsTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage fm;\\n\\nimport java.util.Arrays;\\nimport java.util.List;\\n\\nimport freemarker.ext.beans.BeansWrapper;\\nimport freemarker.template.Configuration;\\nimport freemarker.template.TemplateHashModel;\\nimport freemarker.template.TemplateMethodModelEx;\\nimport freemarker.template.TemplateModel;\\nimport org.assertj.core.api.Assertions;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class FreemarkerExtBeansOverloadedVarArgsMethodsTest {\\n\\n    @Test\\n    void overloadedVarArgsPacksMultipleTrailingArgumentsIntoArray() throws Exception {\\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\\n        TemplateMethodModelEx method = getMethod(wrapper);\\n        List<TemplateModel> arguments = Arrays.asList(\\n                wrapper.wrap(\\\"prefix\\\"),\\n                wrapper.wrap(\\\"alpha\\\"),\\n                wrapper.wrap(\\\"beta\\\"));\\n\\n        Object result = wrapper.unwrap((TemplateModel) method.exec(arguments));\\n\\n        Assertions.assertThat(result)\\n                .isEqualTo(\\\"prefix:alpha|beta\\\");\\n    }\\n\\n    @Test\\n    void overloadedVarArgsPacksSingleTrailingArgumentIntoArray() throws Exception {\\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\\n        TemplateMethodModelEx method = getMethod(wrapper);\\n        List<TemplateModel> arguments = Arrays.asList(\\n                wrapper.wrap(\\\"prefix\\\"),\\n                wrapper.wrap(\\\"solo\\\"));\\n\\n        Object result = wrapper.unwrap((TemplateModel) method.exec(arguments));\\n\\n        Assertions.assertThat(result)\\n                .isEqualTo(\\\"prefix:solo\\\");\\n    }\\n\\n    private TemplateMethodModelEx getMethod(BeansWrapper wrapper) throws Exception {\\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new VarArgsTarget());\\n        return (TemplateMethodModelEx) model.get(\\\"format\\\");\\n    }\\n\\n    public static class VarArgsTarget {\\n        public String format(String prefix, String... values) {\\n            return prefix + \\\":\\\" + String.join(\\\"|\\\", values);\\n        }\\n\\n        public String format(Integer value) {\\n            return \\\"number:\\\" + value;\\n        }\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1937, "output": 1117, "cacheRead": 31232, "cacheWrite": 0, "totalTokens": 34286, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777640121941, "responseId": "resp_0b8696a993976e800169f4a2ba9db481928973994c493f769c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tym9HoDAMnd6300sdDJ587OK|fc_0b8696a993976e800169f4a2c5e3e88192a3c14cc1980321c6", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2303 bytes to tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtBeansOverloadedVarArgsMethodsTest.java"}], "isError": false, "timestamp": 1777640136528}]}
