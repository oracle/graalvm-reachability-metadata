  package fm;
  
  import freemarker.template.Configuration;
  import freemarker.template.ObjectWrapper;
  import freemarker.template.SimpleObjectWrapper;
  import freemarker.template.TemplateExceptionHandler;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerCoreObjectBuilderSettingEvaluatorInnerBuilderCallExpressionTest {
  
      @Test
      void legacySettingSyntaxConstructsObjectWrapperWithoutParentheses() throws Exception {
          Configuration configuration = newConfiguration();
  
          configuration.setSetting("object_wrapper", LegacyConstructedObjectWrapper.class.getName());
  
          Assertions.assertThat(configuration.getObjectWrapper())
                  .isInstanceOf(LegacyConstructedObjectWrapper.class);
      }
  
      @Test
      void objectWrapperPseudoConstructorUsesPublicInstanceFieldWhenPresent() throws Exception {
          Configuration configuration = newConfiguration();
  
          configuration.setSetting("object_wrapper", SingletonObjectWrapper.class.getName() + "()");
  
          Assertions.assertThat(configuration.getObjectWrapper())
                  .isSameAs(SingletonObjectWrapper.INSTANCE);
      }
  
      @Test
      void objectWrapperPseudoConstructorCallsPublicNoArgumentConstructor() throws Exception {
          Configuration configuration = newConfiguration();
  
          configuration.setSetting("object_wrapper", ConstructorObjectWrapper.class.getName() + "()");
  
          Assertions.assertThat(configuration.getObjectWrapper())
                  .isInstanceOf(ConstructorObjectWrapper.class);
      }
  
      @Test
      void staticFieldSettingResolvesFieldValueFromDottedExpression() throws Exception {
          Configuration configuration = newConfiguration();
  
          configuration.setSetting("template_exception_handler", StaticTemplateExceptionHandlers.class.getName()
                  + ".HANDLER");
  
          Assertions.assertThat(configuration.getTemplateExceptionHandler())
                  .isSameAs(StaticTemplateExceptionHandlers.HANDLER);
      }
  
      @Test
      void builderClassBuildMethodProvidesObjectWrapper() throws Exception {
          Configuration configuration = newConfiguration();
  
          configuration.setSetting("object_wrapper", BuiltObjectWrapper.class.getName() + "()");
  
          Assertions.assertThat(configuration.getObjectWrapper())
                  .isInstanceOf(BuiltObjectWrapper.class);
      }
  
      private static Configuration newConfiguration() {
          return new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
      }
  
      public static class LegacyConstructedObjectWrapper extends SimpleObjectWrapper {
          public LegacyConstructedObjectWrapper() {
              super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          }
      }
  
      public static class SingletonObjectWrapper extends SimpleObjectWrapper {
          public static final SingletonObjectWrapper INSTANCE = new SingletonObjectWrapper();
  
          public SingletonObjectWrapper() {
              super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          }
      }
  
      public static class ConstructorObjectWrapper extends SimpleObjectWrapper {
          public ConstructorObjectWrapper() {
              super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          }
      }
  
      public static class StaticTemplateExceptionHandlers {
          public static final TemplateExceptionHandler HANDLER = TemplateExceptionHandler.RETHROW_HANDLER;
  
          public StaticTemplateExceptionHandlers() {
          }
      }
  
      public static class BuiltObjectWrapper extends SimpleObjectWrapper {
          public BuiltObjectWrapper() {
              super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          }
      }
  
      public static class BuiltObjectWrapperBuilder {
          public BuiltObjectWrapperBuilder() {
          }
  
          public ObjectWrapper build() {
              return new BuiltObjectWrapper();
          }
      }
  
  }
