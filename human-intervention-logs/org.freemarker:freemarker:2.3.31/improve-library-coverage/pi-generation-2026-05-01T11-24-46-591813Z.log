[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerDebugImplDebuggerServerInnerDebuggerAuthProtocolTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.IOException;\nimport java.net.ConnectException;\nimport java.net.InetAddress;\nimport java.net.ServerSocket;\nimport java.util.List;\n\nimport freemarker.debug.Debugger;\nimport freemarker.debug.DebuggerClient;\nimport freemarker.debug.impl.DebuggerService;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerDebugImplDebuggerServerInnerDebuggerAuthProtocolTest {\n    private static final String PASSWORD = \"debugger-password\";\n\n    @Test\n    void authenticatesDebuggerClientAndRejectsWrongPassword() throws Exception {\n        int port = findAvailablePort();\n        System.setProperty(\"freemarker.debug.password\", PASSWORD);\n        System.setProperty(\"freemarker.debug.port\", String.valueOf(port));\n\n        try {\n            DebuggerService.getBreakpoints(\"template.ftlh\");\n\n            Debugger debugger = connectWithRetry(port, PASSWORD);\n            List breakpoints = debugger.getBreakpoints();\n            Assertions.assertThat(breakpoints)\n                    .isEmpty();\n\n            Debugger rejectedDebugger = DebuggerClient.getDebugger(\n                    InetAddress.getLoopbackAddress(), port, \"wrong-password\");\n            Assertions.assertThatThrownBy(rejectedDebugger::getBreakpoints)\n                    .isInstanceOf(NullPointerException.class);\n        } finally {\n            DebuggerService.shutdown();\n            System.clearProperty(\"freemarker.debug.password\");\n            System.clearProperty(\"freemarker.debug.port\");\n        }\n    }\n\n    private static Debugger connectWithRetry(int port, String password) throws Exception {\n        IOException lastFailure = null;\n        for (int attempt = 0; attempt < 20; attempt++) {\n            try {\n                return DebuggerClient.getDebugger(InetAddress.getLoopbackAddress(), port, password);\n            } catch (ConnectException e) {\n                lastFailure = e;\n                Thread.sleep(50L);\n            }\n        }\n        throw lastFailure;\n    }\n\n    private static int findAvailablePort() throws IOException {\n        try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\n            return serverSocket.getLocalPort();\n        }\n    }\n\n}\n"}
