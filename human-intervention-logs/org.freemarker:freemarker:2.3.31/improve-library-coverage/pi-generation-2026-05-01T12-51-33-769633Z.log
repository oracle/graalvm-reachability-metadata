util.Collections;\n\nimport freemarker.ext.beans.BeansWrapper;\nimport freemarker.template.Configuration;\nimport freemarker.template.TemplateHashModel;\nimport freemarker.template.TemplateMethodModelEx;\nimport freemarker.template.TemplateModel;\nimport freemarker.template.TemplateScalarModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtBeansClassIntrospectorTest {\n\n    @Test\n    void exposesDefaultInterfaceMethodsAsBeanPropertiesAndMethods() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        wrapper.setTreatDefaultMethodsAsBeanMembers(true);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new DefaultMethodBean());\n\n        TemplateScalarModel status = (TemplateScalarModel) model.get(\"status\");\n        TemplateMethodModelEx describe = (TemplateMethodModelEx) model.get(\"describe\");\n        TemplateModel description = describe.exec(Collections.emptyList());\n\n        Assertions.assertThat(status.getAsString()).isEqualTo(\"ready\");\n        Assertions.assertThat(((TemplateScalarModel) description).getAsString()).isEqualTo(\"default method\");\n    }\n\n    public interface DefaultMethodSource {\n        default String getStatus() {\n            return \"ready\";\n        }\n\n        default String describe() {\n            return \"default method\";\n        }\n    }\n\n    public static class DefaultMethodBean implements DefaultMethodSource {\n    }\n\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtBeansClassIntrospectorTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage fm;\\n\\nimport java.util.Collections;\\n\\nimport freemarker.ext.beans.BeansWrapper;\\nimport freemarker.template.Configuration;\\nimport freemarker.template.TemplateHashModel;\\nimport freemarker.template.TemplateMethodModelEx;\\nimport freemarker.template.TemplateModel;\\nimport freemarker.template.TemplateScalarModel;\\nimport org.assertj.core.api.Assertions;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class FreemarkerExtBeansClassIntrospectorTest {\\n\\n    @Test\\n    void exposesDefaultInterfaceMethodsAsBeanPropertiesAndMethods() throws Exception {\\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\\n        wrapper.setTreatDefaultMethodsAsBeanMembers(true);\\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new DefaultMethodBean());\\n\\n        TemplateScalarModel status = (TemplateScalarModel) model.get(\\\"status\\\");\\n        TemplateMethodModelEx describe = (TemplateMethodModelEx) model.get(\\\"describe\\\");\\n        TemplateModel description = describe.exec(Collections.emptyList());\\n\\n        Assertions.assertThat(status.getAsString()).isEqualTo(\\\"ready\\\");\\n        Assertions.assertThat(((TemplateScalarModel) description).getAsString()).isEqualTo(\\\"default method\\\");\\n    }\\n\\n    public interface DefaultMethodSource {\\n        default String getStatus() {\\n            return \\\"ready\\\";\\n        }\\n\\n        default String describe() {\\n            return \\\"default method\\\";\\n        }\\n    }\\n\\n    public static class DefaultMethodBean implements DefaultMethodSource {\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 730, "output": 1001, "cacheRead": 32256, "cacheWrite": 0, "totalTokens": 33987, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777639826987, "responseId": "resp_09654d8ec897c7110169f4a193c2dc819dbb6dc18976edbb91"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_