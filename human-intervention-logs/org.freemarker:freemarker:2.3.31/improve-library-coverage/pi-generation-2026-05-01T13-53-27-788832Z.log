  package fm;
  
  import freemarker.ext.beans.BeansWrapper;
  import freemarker.ext.beans.LegacyDefaultMemberAccessPolicy;
  import freemarker.template.Configuration;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerExtBeansLegacyDefaultMemberAccessPolicyTest {
  
      @Test
      void legacyDefaultPolicyLoadsAndCanBeInstalledOnBeansWrapper() {
          LegacyDefaultMemberAccessPolicy policy = LegacyDefaultMemberAccessPolicy.INSTANCE;
          BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
  
          wrapper.setMemberAccessPolicy(policy);
  
          Assertions.assertThat(wrapper.getMemberAccessPolicy()).isSameAs(policy);
          Assertions.assertThat(policy.isToStringAlwaysExposed()).isTrue();
      }
  
  }
