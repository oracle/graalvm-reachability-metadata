      private static boolean isWellFormedClassName(String s) {
          if (s.length() == 0) {
              return false;
          }
          int identifierStartIdx = 0;
          for (int i = 0; i < s.length(); i++) {
              char c = s.charAt(i);
              if (i == identifierStartIdx) {
                  if (!Character.isJavaIdentifierStart(c)) {
