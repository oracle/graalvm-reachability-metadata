      @Test
      void forNameFallsBackWhenContextClassLoaderIsUnavailable() throws ClassNotFoundException {
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
  
          try {
              currentThread.setContextClassLoader(null);
  
              Class<?> loadedClass = ClassUtil.forName(String.class.getName());
  
              Assertions.assertThat(loadedClass).isSameAs(String.class);
          } finally {
