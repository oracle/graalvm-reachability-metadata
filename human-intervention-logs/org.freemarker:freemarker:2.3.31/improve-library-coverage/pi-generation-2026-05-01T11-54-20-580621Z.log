[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerDebugImplRmiDebugModelImplStubTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.IOException;\nimport java.io.InputStream;\n\nimport org.assertj.core.api.Assertions;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerDebugImplRmiDebugModelImplStubTest {\n    private static final String STUB_CLASS_NAME = \"freemarker.debug.impl.RmiDebugModelImpl_Stub\";\n    private static final String STUB_CLASS_RESOURCE = \"freemarker/debug/impl/RmiDebugModelImpl_Stub.class\";\n\n    @Test\n    void initializesGeneratedRmiStubWithFreshClassLoader() throws Exception {\n        try {\n            ClassLoader parentClassLoader = FreemarkerDebugImplRmiDebugModelImplStubTest.class.getClassLoader();\n            ClassLoader stubClassLoader = new StubOnlyClassLoader(parentClassLoader);\n\n            Class<?> stubClass = Class.forName(STUB_CLASS_NAME, true, stubClassLoader);\n\n            Assertions.assertThat(stubClass.getName()).isEqualTo(STUB_CLASS_NAME);\n            Assertions.assertThat(stubClass.getClassLoader()).isSameAs(stubClassLoader);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static final class StubOnlyClassLoader extends ClassLoader {\n        StubOnlyClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!STUB_CLASS_NAME.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n\n            Class<?> loadedClass = findLoadedClass(name);\n            if (loadedClass == null) {\n                loadedClass = findClass(name);\n            }\n            if (resolve) {\n                resolveClass(loadedClass);\n            }\n            return loadedClass;\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (!STUB_CLASS_NAME.equals(name)) {\n                return super.findClass(name);\n            }\n\n            byte[] classBytes = readStubClassBytes();\n            return defineClass(name, classBytes, 0, classBytes.length);\n        }\n\n        private byte[] readStubClassBytes() throws ClassNotFoundException {\n            try (InputStream inputStream = getParent().getResourceAsStream(STUB_CLASS_RESOURCE)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(STUB_CLASS_NAME);\n                }\n                return inputStream.readAllBytes();\n            } catch (IOException e) {\n                throw new ClassNotFoundException(STUB_CLASS_NAME, e);\n            }\n        }\n    }\n}\n"}
