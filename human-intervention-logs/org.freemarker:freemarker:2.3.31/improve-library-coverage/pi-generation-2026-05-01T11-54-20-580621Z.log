  package fm;
  
  import java.io.IOException;
  import java.io.ObjectInput;
  import java.io.ObjectOutput;
  import java.lang.reflect.Method;
  import java.rmi.Remote;
  import java.rmi.RemoteException;
  import java.rmi.server.Operation;
  import java.rmi.server.RemoteCall;
  import java.rmi.server.RemoteObject;
  import java.rmi.server.RemoteRef;
  import java.util.ArrayList;
  import java.util.List;
  
  import freemarker.debug.DebugModel;
  import freemarker.debug.impl.RmiDebugModelImpl_Stub;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerDebugImplRmiDebugModelImplStubTest {
  
      @Test
      void forwardsDebugModelCallsThroughGeneratedRmiStub() throws Exception {
          Class<?> initializedStubClass = Class.forName(
                  RmiDebugModelImpl_Stub.class.getName(),
                  true,
                  RmiDebugModelImpl_Stub.class.getClassLoader());
          Assertions.assertThat(initializedStubClass).isSameAs(RmiDebugModelImpl_Stub.class);
  
          RecordingRemoteRef remoteRef = new RecordingRemoteRef();
          DebugModel debugModel = new RmiDebugModelImpl_Stub(remoteRef);
  
          String stringValue = debugModel.getAsString();
          int modelTypes = debugModel.getModelTypes();
  
          Assertions.assertThat(stringValue).isEqualTo("debug-value");
          Assertions.assertThat(modelTypes).isEqualTo(DebugModel.TYPE_SCALAR);
          Assertions.assertThat(remoteRef.invokedMethodNames())
                  .containsExactly("getAsString", "getModelTypes");
      }
  
      private static final class RecordingRemoteRef implements RemoteRef {
          private final List<String> invokedMethodNames = new ArrayList<>();
  
          @Override
          public Object invoke(Remote obj, Method method, Object[] params, long opnum) {
              String methodName = method.getName();
              invokedMethodNames.add(methodName);
              if ("getAsString".equals(methodName)) {
                  return "debug-value";
              }
              if ("getModelTypes".equals(methodName)) {
                  return Integer.valueOf(DebugModel.TYPE_SCALAR);
              }
              throw new AssertionError("Unexpected method: " + methodName);
          }
  
          List<String> invokedMethodNames() {
              return invokedMethodNames;
          }
  
          @Override
          public RemoteCall newCall(RemoteObject obj, Operation[] op, int opnum, long hash) throws RemoteException {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public void invoke(RemoteCall call) {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public void done(RemoteCall call) throws RemoteException {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public String getRefClass(ObjectOutput out) {
              return "recording";
          }
  
          @Override
          public int remoteHashCode() {
              return System.identityHashCode(this);
          }
  
          @Override
          public boolean remoteEquals(RemoteRef obj) {
              return this == obj;
          }
  
          @Override
          public String remoteToString() {
              return getClass().getName();
          }
  
          @Override
          public void writeExternal(ObjectOutput out) throws IOException {
              throw new UnsupportedOperationException();
          }
  
          @Override
          public void readExternal(ObjectInput in) throws IOException, ClassNotFoundException {
              throw new UnsupportedOperationException();
          }
      }
  }
