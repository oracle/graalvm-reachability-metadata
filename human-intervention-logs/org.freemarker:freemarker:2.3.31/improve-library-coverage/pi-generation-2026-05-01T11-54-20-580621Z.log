  package fm;
  
  import java.io.IOException;
  import java.net.ConnectException;
  import java.net.InetAddress;
  import java.net.ServerSocket;
  import java.util.List;
  
  import freemarker.debug.Debugger;
  import freemarker.debug.DebuggerClient;
  import freemarker.debug.impl.DebuggerService;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerDebugImplDebuggerServerInnerDebuggerAuthProtocolTest {
      private static final String PASSWORD = "debugger-password";
  
      @Test
      void authenticatesDebuggerClientAndRejectsWrongPassword() throws Exception {
          int port = findAvailablePort();
          System.setProperty("freemarker.debug.password", PASSWORD);
          System.setProperty("freemarker.debug.port", String.valueOf(port));
  
          try {
              DebuggerService.getBreakpoints("template.ftlh");
  
              Debugger debugger = connectWithRetry(port, PASSWORD);
              List breakpoints = debugger.getBreakpoints();
              Assertions.assertThat(breakpoints)
                      .isEmpty();
  
              Debugger rejectedDebugger = DebuggerClient.getDebugger(
                      InetAddress.getLoopbackAddress(), port, "wrong-password");
              Assertions.assertThatThrownBy(rejectedDebugger::getBreakpoints)
                      .isInstanceOf(NullPointerException.class);
          } finally {
              DebuggerService.shutdown();
              System.clearProperty("freemarker.debug.password");
              System.clearProperty("freemarker.debug.port");
          }
      }
  
      private static Debugger connectWithRetry(int port, String password) throws Exception {
          IOException lastFailure = null;
          for (int attempt = 0; attempt < 20; attempt++) {
              try {
                  return DebuggerClient.getDebugger(InetAddress.getLoopbackAddress(), port, password);
              } catch (ConnectException e) {
                  lastFailure = e;
                  Thread.sleep(50L);
              }
          }
          throw lastFailure;
      }
  
      private static int findAvailablePort() throws IOException {
          try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {
              return serverSocket.getLocalPort();
          }
      }
  
  }
