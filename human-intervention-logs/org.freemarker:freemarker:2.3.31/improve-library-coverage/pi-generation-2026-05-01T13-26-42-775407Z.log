  package fm;
  
  import freemarker.cache.WebappTemplateLoader;
  import freemarker.template.Configuration;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerTemplateConfigurationTest {
      @Test
      void setsServletContextTemplateLoaderWithCustomPath() {
          Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext servletContext = servletContext();
  
          configuration.setServletContextForTemplateLoading(servletContext, "WEB-INF/templates");
  
          Assertions.assertThat(configuration.getTemplateLoader()).isInstanceOf(WebappTemplateLoader.class);
      }
  
      @Test
      void setsServletContextTemplateLoaderWithDefaultPath() {
          Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext servletContext = servletContext();
  
          configuration.setServletContextForTemplateLoading(servletContext, null);
  
          Assertions.assertThat(configuration.getTemplateLoader()).isInstanceOf(WebappTemplateLoader.class);
      }
  
      private static FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext servletContext() {
          return new FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext(
                  "/freemarker-test", "FreeMarker Configuration Test");
      }
  }
