          return memberDesc.getParamTypes();
      }
      
      @Override
      void afterWideningUnwrappingHints(Class[] paramTypes, int[] paramNumericalTypes) {
          // Do nothing
      }
  
      @Override
      MaybeEmptyMemberAndArguments getMemberAndArguments(List tmArgs, BeansWrapper unwrapper) 
