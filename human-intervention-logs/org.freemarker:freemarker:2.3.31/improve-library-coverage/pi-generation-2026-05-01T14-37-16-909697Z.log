  import freemarker.template.Configuration;
  import freemarker.template.ObjectWrapper;
  import freemarker.template.TemplateException;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerCoreConfigurableTest {
      @Test
      void setSettingSelectsDeprecatedJythonObjectWrapper() throws TemplateException {
          Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
  
          configuration.setSetting("object_wrapper", "jython");
  
          ObjectWrapper objectWrapper = configuration.getObjectWrapper();
          Assertions.assertThat(objectWrapper.getClass().getName())
                  .isEqualTo("freemarker.ext.jython.JythonWrapper");
      }
  }
