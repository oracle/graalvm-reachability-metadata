 of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.IOException;\nimport java.io.StringWriter;\nimport java.util.HashMap;\nimport java.util.Map;\n\nimport freemarker.template.Configuration;\nimport freemarker.template.Template;\nimport freemarker.template.TemplateException;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerTest {\n\n    @Test\n    void test() throws IOException, TemplateException {\n        Map<String, Object> root = new HashMap<>();\n        root.put(\"user\", \"Big Joe\");\n        Product latest = new Product();\n        latest.setUrl(\"products/greenmouse.html\");\n        latest.setName(\"green mouse\");\n        root.put(\"latestProduct\", latest);\n\n        Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        configuration.setClassForTemplateLoading(this.getClass(), \"/\");\n        Template template = configuration.getTemplate(\"test.ftlh\");\n        StringWriter writer = new StringWriter();\n        template.process(root, writer);\n\n        Assertions.assertThat(writer.toString()).isNotEmpty();\n    }\n\n}\n"}], "isError": false, "timestamp": 1777646155765}, {"role": "toolResult", "toolCallId": "call_5J3sXAwh5UDhSfyaDtn9M9IJ|fc_094e12d6408531900169f4ba4b798881968e2a9edf0a21372e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport freemarker.cache.WebappTemplateLoader;\nimport freemarker.template.Configuration;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerTemplateConfigurationTest {\n    @Test\n    void setsServletContextTemplateLoaderWithCustomPath() {\n        Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext servletContext = servletContext();\n\n        configuration.setServletContextForTemplateLoading(servletContext, \"WEB-INF/templates\");\n\n        Assertions.assertThat(configuration.getTemplateLoader()).isInstanceOf(WebappTemplateLoader.class);\n    }\n\n    @Test\n    void setsServletContextTemplateLoaderWithDefaultPath() {\n        Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext servletContext = servletContext();\n\n        configuration.setServletContextForTemplateLoading(servletContext, null);\n\n        Assertions.assertThat(configuration.getTemplateLoader()).isInstanceOf(WebappTemplateLoader.class);\n    }\n\n    private static FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext servletContext() {\n        return new FreemarkerCacheWebappTemplateLoaderTest.ContextPathServletContext(\n                \"/freemarker-test\", \"FreeMarker Configuration Test\");\n    }\n}\n"}], "isError": false, "timestamp": 1777646155765}, {"role": "toolResult", "toolCallId": "call_t1UBCkLNKCTwcufJKfuG2B6r|fc_094e12d6408531900169f4ba4b79948196a36be51a91eacc9f", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"reflection\": [\n    {\n      \"condition\": {\n        \"typeReached\": \"javax.servlet.ServletContext\"\n      },\n      \"type\": \"freemarker.cache.WebappTemplateLoader\",\n      \"methods\": [\n        {\n          \"name\": \"<init>\",\n          \"parameterTypes\": [\n            \"javax.servlet.ServletContext\"\n          ]\n        },\n        {\n          \"name\": \"<init>\",\n          \"parameterTypes\": [\n            \"javax.servlet.ServletContext\",\n            \"java.lang.String\"\n          ]\n        }\n      ]\n    },\