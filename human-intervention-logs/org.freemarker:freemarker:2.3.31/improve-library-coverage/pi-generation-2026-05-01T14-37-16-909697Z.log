  package fm;
  
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.HashMap;
  import java.util.Map;
  
  import javax.servlet.ServletConfig;
  import javax.servlet.ServletContext;
  
  import freemarker.ext.servlet.FreemarkerServlet;
  import freemarker.template.ObjectWrapper;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerExtServletFreemarkerServletTest {
      @Test
      void deprecatedJythonObjectWrapperInitParamCreatesWrapper() {
          ExposedFreemarkerServlet servlet = new ExposedFreemarkerServlet(new ObjectWrapperServletConfig());
  
          ObjectWrapper objectWrapper = servlet.createObjectWrapperFromInitParams();
  
          Assertions.assertThat(objectWrapper.getClass().getName())
                  .isEqualTo("freemarker.ext.jython.JythonWrapper");
      }
  
      static class ExposedFreemarkerServlet extends FreemarkerServlet {
          private static final long serialVersionUID = 1L;
  
          private final ServletConfig servletConfig;
  
          ExposedFreemarkerServlet(ServletConfig servletConfig) {
              this.servletConfig = servletConfig;
          }
  
          @Override
          public ServletConfig getServletConfig() {
              return servletConfig;
          }
  
          ObjectWrapper createObjectWrapperFromInitParams() {
              return createObjectWrapper();
          }
      }
  
      static class ObjectWrapperServletConfig implements ServletConfig {
          private final Map<String, String> initParameters = new HashMap<>();
  
          ObjectWrapperServletConfig() {
              initParameters.put("ObjectWrapper", "jython");
          }
  
          @Override
          public String getServletName() {
              return "freemarker-servlet-test";
          }
  
          @Override
          public ServletContext getServletContext() {
              return null;
          }
  
          @Override
          public String getInitParameter(String name) {
              return initParameters.get(name);
          }
  
          @Override
          public Enumeration<String> getInitParameterNames() {
              return Collections.enumeration(initParameters.keySet());
          }
      }
  }
