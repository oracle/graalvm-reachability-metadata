eemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtJspTaglibFactoryTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.util.Collections;\nimport java.util.regex.Pattern;\n\nimport freemarker.ext.jsp.TaglibFactory;\nimport freemarker.template.TemplateModelException;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtJspTaglibFactoryTest {\n    private static final String UNMAPPED_TAGLIB_URI = \"http://example.test/freemarker/unmapped-taglib\";\n\n    @Test\n    void classpathMetaInfDiscoveryAsksClassLoaderForMetaInfResources() {\n        TaglibFactory taglibFactory = new TaglibFactory(\n                new FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext());\n        taglibFactory.setMetaInfTldSources(Collections.singletonList(\n                new TaglibFactory.ClasspathMetaInfTldSource(Pattern.compile(\"a^\"))));\n\n        Assertions.assertThatThrownBy(() -> taglibFactory.get(UNMAPPED_TAGLIB_URI))\n                .isInstanceOf(TemplateModelException.class)\n                .hasMessageContaining(\"Error while looking for TLD file\")\n                .hasRootCauseMessage(\"No TLD was found for the \\\"\" + UNMAPPED_TAGLIB_URI + \"\\\" JSP taglib URI. \"\n                        + \"(TLD-s are searched according the JSP 2.2 specification. In development- and \"\n                        + \"embedded-servlet-container setups you may also need the \\\"MetaInfTldSources\\\" and \"\n                        + \"\\\"ClasspathTlds\\\" freemarker.ext.servlet.FreemarkerServlet init-params or the similar \"\n                        + \"system properites.)\");\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtJspTaglibFactoryTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage fm;\\n\\nimport java.util.Collections;\\nimport java.util.regex.Pattern;\\n\\nimport freemarker.ext.jsp.TaglibFactory;\\nimport freemarker.template.TemplateModelException;\\nimport org.assertj.core.api.Assertions;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class FreemarkerExtJspTaglibFactoryTest {\\n    private static final String UNMAPPED_TAGLIB_URI = \\\"http://example.test/freemarker/unmapped-taglib\\\";\\n\\n    @Test\\n    void classpathMetaInfDiscoveryAsksClassLoaderForMetaInfResources() {\\n        TaglibFactory taglibFactory = new TaglibFactory(\\n                new FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext());\\n        taglibFactory.setMetaInfTldSources(Collections.singletonList(\\n                new TaglibFactory.ClasspathMetaInfTldSource(Pattern.compile(\\\"a^\\\"))));\\n\\n        Assertions.assertThatThrownBy(() -> taglibFactory.get(UNMAPPED_TAGLIB_URI))\\n                .isInstanceOf(TemplateModelException.class)\\n                .hasMessageContaining(\\\"Error while looking for TLD file\\\")\\n                .hasRootCauseMessage(\\\"No TLD was found for the \\\\\\\"\\\" + UNMAPPED_TAGLIB_URI + \\\"\\\\\\\" JSP taglib URI. \\\"\\n                        + \\\"(TLD-s are searched according the JSP 2.2 specification. In development- and \\\"\\n                        + \\\"embedded-servlet-container setups you may also need the \\\\\\\"MetaInfTldSources\\\\\\\" and \\\"\\n                        + \\\"\\\\\\\"ClasspathTlds\\\\\\\" freemarker.ext.servlet.FreemarkerServlet init-params or the similar \\\"\\n                        + \\\"system properites.)\\\");\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1353, "output": 1164, "cacheRead"