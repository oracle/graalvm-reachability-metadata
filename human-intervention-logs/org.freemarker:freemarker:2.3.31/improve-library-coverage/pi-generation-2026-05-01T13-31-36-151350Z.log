r\\\")\\n                .contains(\\\"ServletException root cause:\\\")\\n                .contains(\\\"legacy-root-cause-marker\\\");\\n    }\\n\\n    public static final class LegacyRootCauseException extends Exception {\\n        private final Throwable rootCause;\\n\\n        public LegacyRootCauseException(Throwable rootCause) {\\n            super(\\\"legacy wrapper without standard cause\\\");\\n            this.rootCause = rootCause;\\n        }\\n\\n        public Throwable getRootCause() {\\n            return rootCause;\\n        }\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 944, "output": 1149, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 21549, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777642256710, "responseId": "resp_0da3036442c48bdb0169f4ab11177c8197a69f1b1301dc71c4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_lDNKHVuIdS481a0FcHjxc1re|fc_0da3036442c48bdb0169f4ab1e01708197845c55264cd15735", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1610 bytes to tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerTemplateTemplateExceptionTest.java"}], "isError": false, "timestamp": 1777642272178}]}
