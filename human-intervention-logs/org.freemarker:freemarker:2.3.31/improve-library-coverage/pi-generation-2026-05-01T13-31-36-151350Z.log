[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerTemplateTemplateExceptionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.PrintWriter;\nimport java.io.StringWriter;\n\nimport freemarker.template.TemplateException;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerTemplateTemplateExceptionTest {\n\n    @Test\n    void printStackTraceIncludesLegacyRootCause() {\n        RuntimeException rootCause = new RuntimeException(\"legacy-root-cause-marker\");\n        TemplateException exception = new TemplateException(\n                \"template failure with legacy wrapper\",\n                new LegacyRootCauseException(rootCause),\n                null);\n        StringWriter output = new StringWriter();\n        PrintWriter writer = new PrintWriter(output);\n\n        exception.printStackTrace(writer, false, false, true);\n        writer.flush();\n\n        Assertions.assertThat(output.toString())\n                .contains(\"template failure with legacy wrapper\")\n                .contains(\"ServletException root cause:\")\n                .contains(\"legacy-root-cause-marker\");\n    }\n\n    public static final class LegacyRootCauseException extends Exception {\n        private final Throwable rootCause;\n\n        public LegacyRootCauseException(Throwable rootCause) {\n            super(\"legacy wrapper without standard cause\");\n            this.rootCause = rootCause;\n        }\n\n        public Throwable getRootCause() {\n            return rootCause;\n        }\n    }\n\n}\n"}
