;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!STUB_CLASS_NAME.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n\n            Class<?> loadedClass = findLoadedClass(name);\n            if (loadedClass == null) {\n                loadedClass = findClass(name);\n            }\n            if (resolve) {\n                resolveClass(loadedClass);\n            }\n            return loadedClass;\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (!STUB_CLASS_NAME.equals(name)) {\n                return super.findClass(name);\n            }\n\n            byte[] classBytes = readStubClassBytes();\n            byte[] debuggableClassBytes = ClassFileDebugInfoPatcher.addDebugInfo(classBytes);\n            return defineClass(name, debuggableClassBytes, 0, debuggableClassBytes.length);\n        }\n\n        private byte[] readStubClassBytes() throws ClassNotFoundException {\n            try (InputStream inputStream = getParent().getResourceAsStream(STUB_CLASS_RESOURCE)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(STUB_CLASS_NAME);\n                }\n                return inputStream.readAllBytes();\n            } catch (IOException e) {\n                throw new ClassNotFoundException(STUB_CLASS_NAME, e);\n            }\n        }\n    }\n\n    private static final class ClassFileDebugInfoPatcher {\n        private static final int CLASS_INITIALIZER_LINE = 1;\n        private static final int CLASS_RESOLUTION_HELPER_LINE = 2;\n\n        private ClassFileDebugInfoPatcher() {\n        }\n\n        static byte[] addDebugInfo(byte[] classBytes) throws ClassNotFoundException {\n            try {\n                ClassReader reader = new ClassReader(classBytes);\n                ByteArrayOutputStream output = new ByteArrayOutputStream(classBytes.length + 128);\n                ClassWriter writer = new ClassWriter(output);\n\n                writer.writeInt(reader.readInt());\n                writer.writeShort(reader.readUnsignedShort());\n                writer.writeShort(reader.readUnsignedShort());\n\n                int constantPoolCount = reader.readUnsignedShort();\n                String[] constantPoolUtf8 = new String[constantPoolCount + 3];\n                writer.writeShort(constantPoolCount + 3);\n                copyConstantPool(reader, writer, constantPoolCount, constantPoolUtf8);\n                int sourceFileAttributeNameIndex = constantPoolCount;\n                int lineNumberTableAttributeNameIndex = constantPoolCount + 1;\n                int sourceFileNameIndex = constantPoolCount + 2;\n                writer.writeUtf8Constant(\"SourceFile\");\n                writer.writeUtf8Constant(\"LineNumberTable\");\n                writer.writeUtf8Constant(STUB_SOURCE_FILE);\n\n                writer.writeBytes(reader.readBytes(6));\n                int interfacesCount = reader.readUnsignedShort();\n                writer.writeShort(interfacesCount);\n                writer.writeBytes(reader.readBytes(interfacesCount * 2));\n\n                int fieldsCount = reader.readUnsignedShort();\n                writer.writeShort(fieldsCount);\n                copyMembers(reader, writer, fieldsCount);\n\n                int methodsCount = reader.readUnsignedShort();\n                writer.writeShort(methodsCount);\n                for (int methodIndex = 0; methodIndex < methodsCount; methodIndex++) {\n                    copyMethod(reader, writer, constantPoolUtf8, lineNumberTableAttributeNameIndex);\n                }\n\n                int classAttributesCount = reader.readUnsignedShort();\n                writer.writeShort(classAttributesCount + 1);\n                copyAttributes(reader, writer, classAttributesCount);\n                writer.writeShort(sourceFileAttributeNameIndex);\n                writer.writeInt(2);\n                writer.writeShort(sourceFileNameIndex);\n\n                Assertions.assertThat(reader.isAtEnd()).isTrue();\n                return output.toByteArray();\n            } catch (IOException e) {\n                throw new ClassNotFoundException(STUB_CLASS_NAME, e);\n            }\n        }\n\n        private static void copyConstantPool(\n                ClassReader reader,\n                ClassWriter writer,\n                int constantPoolCount,\n                String[] constantPoolUtf8\n        ) throws IOException {\n            for (int index = 1; index < constantPoolCount; index++) {\n                int tag = reader.readUnsignedByte();\n                writer.writeByte(tag);\n                switch (tag) {\n                    case 1:\n                        int length = reader.readUnsignedShort();\n                        byte[] value = reader.readBytes(length);\n                        writer.writeShort(length);\n                        writer.writeBytes(value);\n                        constantPoolUtf8[index] = new String(value, StandardCharsets.UTF_8);\n                        break;\n                    case 3:\n                    case 4:\n                        writer.writeBytes(reader.readBytes(4));\n                        break;\n                    case 5:\n                    case 6:\n                        writer.writeBytes(reader.readBytes(8));\n                        index++;\n                        break;\n                    case 7:\n                    case 8:\n                    case 16:\n                    case 19:\n                    case 20:\n                        writer.writeBytes(reader.readBytes(2));\n                        break;\n                    case 9:\n                    case 10:\n                    case 11:\n                    case 12:\n                    case 18:\n                        writer.writeBytes(reader.readBytes(4));\n                        break;\n                    case 15:\n                        writer.writeBytes(reader.readBytes(3));\n                        break;\n                    default:\n                        throw new IOException(\"Unsupported constant-pool tag: \" + tag);\n                }\n            }\n        }\n\n        private static void copyMembers(ClassReader reader, ClassWriter writer, int membersCount) throws IOException {\n            for (int memberIndex = 0; memberIndex < membersCount; memberIndex++) {\n                writer.writeBytes(reader.readBytes(6));\n                int attributesCount = reader.readUnsignedShort();\n                writer.writeShort(attributesCount);\n                copyAttributes(reader, writer, attributesCount);\n            }\n        }\n\n        private static void copyMethod(\n                ClassReader reader,\n                ClassWriter writer,\n                String[] constantPoolUtf8,\n                int lineNumberTableAttributeNameIndex\n        ) throws IOException {\n            writer.writeShort(reader.readUnsignedShort());\n            int nameIndex = reader.readUnsignedShort();\n            writer.writeShort(nameIndex);\n            writer.writeShort(reader.readUnsignedShort());\n            String methodName = constantPoolUtf8[nameIndex];\n            int attributesCount = reader.readUnsignedShort();\n            writer.writeShort(attributesCount);\n            for (int attributeIndex = 0; attributeIndex < attributesCount; attributeIndex++) {\n                int attributeNameIndex = reader.readUnsignedShort();\n                int attributeLength = reader.readInt();\n                byte[] attributeBytes = reader.readBytes(attributeLength);\n                if (\"Code\".equals(constantPoolUtf8[attributeNameIndex]) && lineForMethod(methodName) > 0) {\n                    writer.writeShort(attributeNameIndex);\n                    writer.writePatchedCodeAttribute(\n                            attributeBytes,\n                            lineNumberTableAttributeNameIndex,\n                            lineForMethod(methodName)\n                    );\n                } else {\n                    writer.writeShort(attributeNameIndex);\n                    writer.writeInt(attributeLength);\n                    writer.writeBytes(attributeBytes);\n                }\n            }\n        }\n\n        private static int lineForMethod(String methodName) {\n            if (\"<clinit>\".equals(methodName)) {\n                return CLASS_INITIALIZER_LINE;\n            }\n            if (\"class$\".equals(methodName)) {\n                return CLASS_RESOLUTION_HELPER_LINE;\n            }\n            return -1;\n        }\n\n        private static void copyAttributes(ClassReader reader, ClassWriter writer, int attributesCount) throws IOException {\n            for (int attributeIndex = 0; attributeIndex < attributesCount; attributeIndex++) {\n                writer.writeBytes(reader.readBytes(2));\n                int attributeLength = reader.readInt();\n                writer.writeInt(attributeLength);\n                writer.writeBytes(reader.readBytes(attributeLength));\n            }\n        }\n    }\n\n    private static final class ClassReader {\n        private final byte[] bytes;\n        private int offset;\n\n        ClassReader(byte[] bytes) {\n            this.bytes = Arrays.copyOf(bytes, bytes.length);\n        }\n\n        int readUnsignedByte() throws IOException {\n            requireAvailable(1);\n            return bytes[offset++] & 0xff;\n        }\n\n        int readUnsignedShort() throws IOException {\n            requireAvailable(2);\n            int value = ((bytes[offset] & 0xff) << 8) | (bytes[offset + 1] & 0xff);\n            offset += 2;\n            return value;\n        }\n\n        int readInt() throws IOException {\n            requireAvailable(4);\n            int value = ((bytes[offset] & 0xff) << 24)\n                    | ((bytes[offset + 1] & 0xff) << 16)\n                    | ((bytes[offset + 2] & 0xff) << 8)\n                    | (bytes[offset + 3] & 0xff);\n            offset += 4;\n            return value;\n        }\n\n        byte[] readBytes(int length) throws IOException {\n            requireAvailable(length);\n            byte[] value = Arrays.copyOfRange(bytes, offset, offset + length);\n            offset += length;\n            return value;\n        }\n\n        boolean isAtEnd() {\n            return offset == bytes.length;\n        }\n\n        private void requireAvailable(int length) throws IOException {\n            if (length < 0 || offset + length > bytes.length) {\n                throw new IOException(\"Unexpected end of class file\");\n            }\n        }\n    }\n\n    private static final class ClassWriter {\n        private final ByteArrayOutputStream output;\n\n        ClassWriter(ByteArrayOutputStream output) {\n            this.output = output;\n        }\n\n        void writeByte(int value) {\n            output.write(value & 0xff);\n        }\n\n        void writeShort(int value) {\n            output.write((value >>> 8) & 0xff);\n            output.write(value & 0xff);\n        }\n\n        void writeInt(int value) {\n            output.write((value >>> 24) & 0xff);\n            output.write((value >>> 16) & 0xff);\n            output.write((value >>> 8) & 0xff);\n            output.write(value & 0xff);\n        }\n\n        void writeBytes(byte[] value) {\n            output.writeBytes(value);\n        }\n\n        void writeUtf8Constant(String value) {\n            byte[] bytes = value.getBytes(StandardCharsets.UTF_8);\n            writeByte(1);\n            writeShort(bytes.length);\n            writeBytes(bytes);\n        }\n\n        void writePatchedCodeAttribute(byte[] codeAttribute, int lineNumberTableAttributeNameIndex, int lineNumber)\n                throws IOException {\n            ClassReader reader = new ClassReader(codeAttribute);\n   