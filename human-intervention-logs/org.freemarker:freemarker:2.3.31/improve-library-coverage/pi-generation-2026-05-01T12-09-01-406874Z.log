      private final long id;
      
      private RmiDebuggedEnvironmentImpl(Environment env) throws RemoteException {
          super(new DebugEnvironmentModel(env), DebugModel.TYPE_ENVIRONMENT);
          synchronized (idLock) {
              id = nextId++;
          }
