[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerDebugImplRmiDebuggedEnvironmentImplStubTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.ObjectOutput;\nimport java.lang.reflect.Method;\nimport java.rmi.Remote;\nimport java.rmi.RemoteException;\nimport java.rmi.server.Operation;\nimport java.rmi.server.RemoteCall;\nimport java.rmi.server.RemoteObject;\nimport java.rmi.server.RemoteRef;\n\nimport freemarker.debug.DebuggedEnvironment;\nimport freemarker.debug.impl.RmiDebuggedEnvironmentImpl_Stub;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerDebugImplRmiDebuggedEnvironmentImplStubTest {\n\n    @Test\n    void initializesGeneratedRmiDebuggedEnvironmentStub() {\n        DebuggedEnvironment environment = new RmiDebuggedEnvironmentImpl_Stub(new RecordingRemoteRef());\n\n        Assertions.assertThat(environment)\n                .isInstanceOf(RmiDebuggedEnvironmentImpl_Stub.class);\n    }\n\n    private static final class RecordingRemoteRef implements RemoteRef {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Remote remote, Method method, Object[] parameters, long operation)\n                throws RemoteException {\n            throw new RemoteException(\"No remote endpoint is configured for this test stub\");\n        }\n\n        @Override\n        public RemoteCall newCall(RemoteObject object, Operation[] operations, int operation, long hash)\n                throws RemoteException {\n            throw new RemoteException(\"No remote endpoint is configured for this test stub\");\n        }\n\n        @Override\n        public void invoke(RemoteCall call) throws RemoteException {\n            throw new RemoteException(\"No remote endpoint is configured for this test stub\");\n        }\n\n        @Override\n        public void done(RemoteCall call) {\n        }\n\n        @Override\n        public String getRefClass(ObjectOutput output) {\n            return \"recording\";\n        }\n\n        @Override\n        public int remoteHashCode() {\n            return System.identityHashCode(this);\n        }\n\n        @Override\n        public boolean remoteEquals(RemoteRef remoteRef) {\n            return this == remoteRef;\n        }\n\n        @Override\n        public String remoteToString() {\n            return \"RecordingRemoteRef\";\n        }\n    }\n}\n"}
