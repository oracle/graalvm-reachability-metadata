  package fm;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.Map;
  
  import freemarker.ext.util.IdentityHashMap;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  @SuppressWarnings("deprecation")
  public class FreemarkerExtUtilIdentityHashMapTest {
  
      @Test
      @SuppressWarnings("unchecked")
      void serializesAndDeserializesIdentityBasedEntries() throws Exception {
          IdentityHashMap map = new IdentityHashMap();
          String firstKey = new String("shared-name");
          String secondKey = new String("shared-name");
          Assertions.assertThat(firstKey).isNotSameAs(secondKey);
  
          map.put(firstKey, "first");
          map.put(secondKey, "second");
          map.put(null, "null-key");
          map.put("null-value", null);
  
          IdentityHashMap restored = roundTrip(map);
  
          String equivalentLookupKey = new String("shared-name");
          Assertions.assertThat(restored).hasSize(4);
          Assertions.assertThat(restored.get(null)).isEqualTo("null-key");
          Assertions.assertThat(restored.containsKey(equivalentLookupKey)).isFalse();
          Assertions.assertThat(restored.entrySet())
                  .anySatisfy(entry -> Assertions.assertThat((Map.Entry<?, ?>) entry)
                          .satisfies(mapEntry -> {
                              Assertions.assertThat(mapEntry.getKey()).isEqualTo("shared-name");
                              Assertions.assertThat(mapEntry.getValue()).isEqualTo("first");
                          }))
                  .anySatisfy(entry -> Assertions.assertThat((Map.Entry<?, ?>) entry)
                          .satisfies(mapEntry -> {
                              Assertions.assertThat(mapEntry.getKey()).isEqualTo("shared-name");
                              Assertions.assertThat(mapEntry.getValue()).isEqualTo("second");
                          }))
                  .anySatisfy(entry -> Assertions.assertThat((Map.Entry<?, ?>) entry)
                          .satisfies(mapEntry -> {
                              Assertions.assertThat(mapEntry.getKey()).isEqualTo("null-value");
                              Assertions.assertThat(mapEntry.getValue()).isNull();
                          }));
      }
  
      private IdentityHashMap roundTrip(IdentityHashMap map) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {
              outputStream.writeObject(map);
          }
  
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (IdentityHashMap) inputStream.readObject();
          }
