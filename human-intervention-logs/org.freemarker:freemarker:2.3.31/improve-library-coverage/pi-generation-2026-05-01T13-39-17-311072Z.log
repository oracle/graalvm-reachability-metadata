[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerCacheSoftCacheStorageTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.lang.ref.Reference;\nimport java.util.concurrent.ConcurrentHashMap;\nimport java.util.concurrent.ConcurrentMap;\n\nimport freemarker.cache.SoftCacheStorage;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerCacheSoftCacheStorageTest {\n\n    @Test\n    void removesQueuedSoftReferenceFromConcurrentBackingMap() {\n        ConcurrentMap<Object, Object> backingMap = new ConcurrentHashMap<>();\n        SoftCacheStorage cacheStorage = new SoftCacheStorage(backingMap);\n        String key = \"template-key\";\n        String value = \"cached-template\";\n\n        cacheStorage.put(key, value);\n        Object storedReference = backingMap.get(key);\n        Assertions.assertThat(storedReference).isInstanceOf(Reference.class);\n        Assertions.assertThat(cacheStorage.isConcurrent()).isTrue();\n        Assertions.assertThat(cacheStorage.get(key)).isEqualTo(value);\n\n        Reference<?> reference = (Reference<?>) storedReference;\n        Assertions.assertThat(reference.enqueue()).isTrue();\n\n        Assertions.assertThat(cacheStorage.getSize()).isZero();\n        Assertions.assertThat(backingMap).doesNotContainKey(key);\n    }\n}\n"}
