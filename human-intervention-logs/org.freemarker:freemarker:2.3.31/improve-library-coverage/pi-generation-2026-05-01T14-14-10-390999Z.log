                      if (replacedTagOrFunction != null) {
                          if (CustomTagAndELFunctionCombiner.canBeCombinedAsCustomTag(replacedTagOrFunction)) {
                              tagsAndFunctions.put(functionNameCData, CustomTagAndELFunctionCombiner.combine(
