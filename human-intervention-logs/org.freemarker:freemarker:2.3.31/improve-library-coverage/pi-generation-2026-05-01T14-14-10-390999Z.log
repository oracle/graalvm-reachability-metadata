  package fm;
  
  import java.util.Collections;
  import java.util.regex.Pattern;
  
  import freemarker.ext.jsp.TaglibFactory;
  import freemarker.template.TemplateModelException;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerExtJspTaglibFactoryTest {
      private static final String UNMAPPED_TAGLIB_URI = "http://example.test/freemarker/unmapped-taglib";
  
      @Test
      void classpathMetaInfDiscoveryAsksClassLoaderForMetaInfResources() {
          TaglibFactory taglibFactory = new TaglibFactory(
                  new FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext());
          taglibFactory.setMetaInfTldSources(Collections.singletonList(
                  new TaglibFactory.ClasspathMetaInfTldSource(Pattern.compile("a^"))));
  
          Assertions.assertThatThrownBy(() -> taglibFactory.get(UNMAPPED_TAGLIB_URI))
                  .isInstanceOf(TemplateModelException.class)
                  .hasMessageContaining("Error while looking for TLD file")
                  .hasRootCauseMessage("No TLD was found for the \"" + UNMAPPED_TAGLIB_URI + "\" JSP taglib URI. "
                          + "(TLD-s are searched according the JSP 2.2 specification. In development- and "
                          + "embedded-servlet-container setups you may also need the \"MetaInfTldSources\" and "
                          + "\"ClasspathTlds\" freemarker.ext.servlet.FreemarkerServlet init-params or the similar "
                          + "system properites.)");
      }
  }
