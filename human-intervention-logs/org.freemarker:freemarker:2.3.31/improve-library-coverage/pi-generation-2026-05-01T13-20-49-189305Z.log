  +package fm;
  +
  +import java.io.StringWriter;
  +import java.util.HashMap;
  +import java.util.Map;
  +
  +import javax.servlet.jsp.el.ExpressionEvaluator;
  +
  +import fm.FreemarkerExtJspJspTagModelBaseTest.MinimalHttpServletRequest;
  +import fm.FreemarkerExtJspJspTagModelBaseTest.MinimalHttpServletResponse;
  +import fm.FreemarkerExtJspJspTagModelBaseTest.MinimalServletConfig;
  +import fm.FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext;
  +import fm.FreemarkerExtJspJspTagModelBaseTest.NoopServlet;
  +import freemarker.core.Environment;
  +import freemarker.ext.jsp._FreeMarkerPageContext21;
  +import freemarker.ext.servlet.FreemarkerServlet;
  +import freemarker.ext.servlet.HttpRequestHashModel;
  +import freemarker.ext.servlet.ServletContextHashModel;
  +import freemarker.template.Configuration;
  +import freemarker.template.Template;
  +import freemarker.template.TemplateDirectiveBody;
  +import freemarker.template.TemplateDirectiveModel;
  +import freemarker.template.TemplateException;
  +import freemarker.template.TemplateModel;
  +import org.assertj.core.api.Assertions;
  +import org.junit.jupiter.api.Test;
  +
  +public class FreemarkerExtJspFreeMarkerPageContext21Test {
  +    @Test
  +    void expressionEvaluatorIsLoadedFromCommonsElByJsp21PageContext() throws Exception {
  +        Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
  +        MinimalServletContext servletContext = new MinimalServletContext();
  +        NoopServlet servlet = new NoopServlet();
  +        servlet.init(new MinimalServletConfig(servletContext));
  +
  +        Map<String, Object> model = new HashMap<>();
  +        ServletContextHashModel applicationModel = new ServletContextHashModel(
  +                servlet, configuration.getObjectWrapper());
  +        model.put(FreemarkerServlet.KEY_APPLICATION, applicationModel);
  +        model.put(FreemarkerServlet.KEY_APPLICATION_PRIVATE, applicationModel);
  +        HttpRequestHashModel requestModel = new HttpRequestHashModel(
  +                new MinimalHttpServletRequest(),
  +                new MinimalHttpServletResponse(),
  +                configuration.getObjectWrapper());
  +        model.put(FreemarkerServlet.KEY_REQUEST, requestModel);
  +        model.put(FreemarkerServlet.KEY_REQUEST_PRIVATE, requestModel);
  +        model.put("exercisePageContext", new PageContext21ExpressionEvaluatorDirective());
  +
  +        Template template = new Template(
  +                "freemarker-page-context21-expression-evaluator",
  +                "<@exercisePageContext />",
  +                configuration);
  +
  +        template.process(model, new StringWriter());
  +    }
  +
  +    private static final class PageContext21ExpressionEvaluatorDirective implements TemplateDirectiveModel {
  +        @Override
  +        @SuppressWarnings("rawtypes")
  +        public void execute(
  +                Environment environment,
  +                Map parameters,
  +                TemplateModel[] loopVariables,
  +                TemplateDirectiveBody body) throws TemplateException {
  +            _FreeMarkerPageContext21 pageContext = new _FreeMarkerPageContext21();
  +            ExpressionEvaluator evaluator = pageContext.getExpressionEvaluator();
  +
  +            Assertions.assertThat(evaluator).isNotNull();
  +        }
  +    }
  +}
