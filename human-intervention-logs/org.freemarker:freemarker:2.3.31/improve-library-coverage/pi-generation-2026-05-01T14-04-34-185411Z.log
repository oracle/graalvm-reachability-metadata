[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtJspFreeMarkerJspApplicationContextTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.StringWriter;\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport javax.el.ELContext;\nimport javax.el.ELContextEvent;\nimport javax.el.ExpressionFactory;\nimport javax.el.ValueExpression;\nimport javax.servlet.jsp.JspApplicationContext;\nimport javax.servlet.jsp.JspFactory;\n\nimport fm.FreemarkerExtJspJspTagModelBaseTest.MinimalHttpServletRequest;\nimport fm.FreemarkerExtJspJspTagModelBaseTest.MinimalHttpServletResponse;\nimport fm.FreemarkerExtJspJspTagModelBaseTest.MinimalServletConfig;\nimport fm.FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext;\nimport fm.FreemarkerExtJspJspTagModelBaseTest.NoopServlet;\nimport freemarker.core.Environment;\nimport freemarker.ext.jsp._FreeMarkerPageContext21;\nimport freemarker.ext.servlet.FreemarkerServlet;\nimport freemarker.ext.servlet.HttpRequestHashModel;\nimport freemarker.ext.servlet.ServletContextHashModel;\nimport freemarker.template.Configuration;\nimport freemarker.template.Template;\nimport freemarker.template.TemplateDirectiveBody;\nimport freemarker.template.TemplateDirectiveModel;\nimport freemarker.template.TemplateException;\nimport freemarker.template.TemplateModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtJspFreeMarkerJspApplicationContextTest {\n    @Test\n    void jspApplicationContextCreatesExpressionFactoryForELContext() throws Exception {\n        Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        MinimalServletContext servletContext = new MinimalServletContext();\n        NoopServlet servlet = new NoopServlet();\n        servlet.init(new MinimalServletConfig(servletContext));\n\n        Map<String, Object> model = new HashMap<>();\n        ServletContextHashModel applicationModel = new ServletContextHashModel(\n                servlet, configuration.getObjectWrapper());\n        model.put(FreemarkerServlet.KEY_APPLICATION, applicationModel);\n        model.put(FreemarkerServlet.KEY_APPLICATION_PRIVATE, applicationModel);\n        HttpRequestHashModel requestModel = new HttpRequestHashModel(\n                new MinimalHttpServletRequest(),\n                new MinimalHttpServletResponse(),\n                configuration.getObjectWrapper());\n        model.put(FreemarkerServlet.KEY_REQUEST, requestModel);\n        model.put(FreemarkerServlet.KEY_REQUEST_PRIVATE, requestModel);\n        model.put(\"exerciseJspApplicationContext\", new JspApplicationContextDirective());\n\n        Template template = new Template(\n                \"freemarker-jsp-application-context\",\n                \"<@exerciseJspApplicationContext />\",\n                configuration);\n\n        template.process(model, new StringWriter());\n    }\n\n    private static final class JspApplicationContextDirective implements TemplateDirectiveModel {\n        @Override\n        @SuppressWarnings(\"rawtypes\")\n        public void execute(\n                Environment environment,\n                Map parameters,\n                TemplateModel[] loopVariables,\n                TemplateDirectiveBody body) throws TemplateException {\n            _FreeMarkerPageContext21 pageContext = new _FreeMarkerPageContext21();\n            JspApplicationContext applicationContext = JspFactory.getDefaultFactory()\n                    .getJspApplicationContext(pageContext.getServletContext());\n            AtomicReference<ELContext> listenerContext = new AtomicReference<>();\n            applicationContext.addELContextListener((ELContextEvent event) -> listenerContext.set(event.getELContext()));\n\n            ExpressionFactory expressionFactory = applicationContext.getExpressionFactory();\n            pageContext.setAttribute(\"message\", \"resolved from page scope\");\n            ELContext elContext = pageContext.getELContext();\n            ValueExpression valueExpression = elContext.getVariableMapper().resolveVariable(\"message\");\n\n            Assertions.assertThat(expressionFactory).isNotNull();\n            Assertions.assertThat(listenerContext).hasValue(elContext);\n            Assertions.assertThat(valueExpression.getValue(elContext)).isEqualTo(\"resolved from page scope\");\n        }\n    }\n}\n"}
