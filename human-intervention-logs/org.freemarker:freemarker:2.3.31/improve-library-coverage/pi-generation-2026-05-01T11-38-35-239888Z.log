ght and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\nimport java.util.Collections;\nimport java.util.List;\n\nimport freemarker.ext.beans.BeansWrapper;\nimport freemarker.template.Configuration;\nimport freemarker.template.SimpleScalar;\nimport freemarker.template.TemplateHashModel;\nimport freemarker.template.TemplateMethodModelEx;\nimport freemarker.template.TemplateModel;\nimport freemarker.template.TemplateScalarModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtBeansBeansWrapperTest {\n\n    @Test\n    void subclassConstructionDetectsLegacyMethodAppearanceOverride() {\n        FineTuningBeansWrapper wrapper = new FineTuningBeansWrapper();\n\n        Assertions.assertThat(wrapper.getIncompatibleImprovements())\n                .isEqualTo(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n    }\n\n    @Test\n    void unwrapsTemplateSequenceToJavaArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        TemplateModel sequence = wrapper.wrap(Arrays.asList(\"north\", \"south\"));\n\n        Object unwrapped = wrapper.unwrap(sequence, String[].class);\n\n        Assertions.assertThat((String[]) unwrapped)\n                .containsExactly(\"north\", \"south\");\n    }\n\n    @Test\n    void overloadedMethodConvertsListArgumentToArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.VERSION_2_3_21);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new OverloadedArrayConsumer());\n        TemplateMethodModelEx join = (TemplateMethodModelEx) model.get(\"join\");\n        List<TemplateModel> arguments = Collections.singletonList(wrapper.wrap(Arrays.asList(\"red\", \"blue\")));\n\n        TemplateScalarModel result = (TemplateScalarModel) join.exec(arguments);\n\n        Assertions.assertThat(result.getAsString())\n                .isEqualTo(\"red|blue\");\n    }\n\n    @Test\n    void createsInstanceThroughBeansWrapperConstructorSupport() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        List<TemplateModel> arguments = Collections.singletonList(new SimpleScalar(\"created\"));\n\n        Object instance = wrapper.newInstance(SingleConstructorBean.class, arguments);\n\n        Assertions.assertThat(instance)\n                .isInstanceOfSatisfying(SingleConstructorBean.class, bean -> Assertions.assertThat(bean.getName())\n                        .isEqualTo(\"created\"));\n    }\n\n    @Test\n    void readsExposedPublicInstanceField() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        wrapper.setExposeFields(true);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new FieldBackedBean(\"visible\"));\n\n        TemplateScalarModel value = (TemplateScalarModel) model.get(\"label\");\n\n        Assertions.assertThat(value.getAsString())\n                .isEqualTo(\"visible\");\n    }\n\n    public static class FineTuningBeansWrapper extends BeansWrapper {\n        public FineTuningBeansWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n\n        @Override\n        @SuppressWarnings(\"deprecation\")\n        protected void finetuneMethodAppearance(\n                Class<?> clazz, Method method, MethodAppearanceDecision decision) {\n            super.finetuneMethodAppearance(clazz, method, decision);\n        }\n    }\n\n    public static class OverloadedArrayConsumer {\n        public String join(String[] values) {\n            return String.join(\"|\", values);\n        }\n\n        public String join(Integer value) {\n            return String.valueOf(value);\n        }\n    }\n\n    public static class SingleConstructorBean {\n        private final String name;\n\n        public SingleConstructorBean(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    public static class FieldBackedBean {\n        public String label;\n\n        public FieldBackedBean(String label) {\n            this.label = label;\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1777634868372}, {"role": "toolResult", "toolCallId": "call_EjQffh41J026GppzRK1Zar1r|fc_080c8c2358c2bed40169f48e33f29081a0bbb03407a48e6ffb", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.util.Base64;\nimport java.util.Properties;\n\nimport freemarker.template.utility.ClassUtil;\nimport org.assertj.core.api.Assertions;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerTemplateUtilityClassUtilTest {\n    private static final String RESOURCE_ANCHOR_CLASS = \"fm.ClassUtilResourceAnchor\";\n    private static final byte[] RESOURCE_ANCHOR_CLASS_BYTES = Base64.getDecoder().decode(\n            \"yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW\"\n                    + \"BwAIAQAaZm0vQ2xhc3NVdGlsUmVzb3VyY2VBbmNob3IBAARDb2RlAQAPTGluZU51bWJl\"\n                    + \"clRhYmxlAQAKU291cmNlRmlsZQEAHENsYXNzVXRpbFJlc291cmNlQW5jaG9yLmphdmEA\"\n                    + \"IQAHAAIAAAAAAAEAAQAFAAYAAQAJAAAAIQABAAEAAAAFKrcAAbEAAAABAAoAAAAKAAIA\"\n                    + \"AAAEAAQABQABAAsAAAACAAw=\");\n\n    @Test\n    void forNameFallsBackWhenContextClassLoaderIsUnavailable() throws ClassNotFoundException {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n\n        try {\n            currentThread.setContextClassLoader(null);\n\n            Class<?> loadedClass = ClassUtil.forName(String.class.getName());\n\n            Assertions.assertThat(loadedClass).isSameAs(String.class);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void classBasedResourceStreamFindsPropertiesResource() throws IOException {\n        try (InputStream inputStream = ClassUtil.getReasourceAsStream(\n                FreemarkerTemplateUtilityClassUtilTest.class,\n                \"/fm/class-util.properties\",\n                false)) {\n            Properties properties = new Properties();\n            properties.load(inputStream);\n\n            Assertions.assertThat(properties).containsEntry(\"template.engine\", \"freemarker\");\n        }\n    }\n\n    @Test\n    void classBasedResourceFallbackUsesResourceUrlLookupAfterStreamLookupFailure() throws Exception {\n        try {\n            ClassLoader classLoader = new FailingStreamClassResourceClassLoader(\n                    FreemarkerTemplateUtilityClassUtilTest.class.getClassLoader());\n            Class<?> resourceAnchorClass = classLoader.loadClass(RESOURCE_ANCHOR_CLASS);\n\n            try (InputStream inputStream = ClassUtil.getReasourceAsStream(\n                    resourceAnchorClass,\n                    \"/fm/class-util.properties\",\n                    false)) {\n                Properties properties = new Properties();\n                properties.load(inputStream);\n\n                Assertions.assertThat(properties).containsEntry(\"template.engine\", \"freemarker\");\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void classLoaderBasedResourceStreamFindsPropertiesResource() throws IOException {\n        ClassLoader classLoader = FreemarkerTemplateUtilityClassUtilTest.class.getClassLoader();\n\n        try (InputStream inputStream = ClassUtil.getReasourceAsStream(\n                classLoader,\n                \"fm/class-util.properties\",\n                false)) {\n            Properties properties = new Properties();\n            properties.load(inputStream);\n\n            Assertions.assertThat(properties).containsEntry(\"template.engine\", \"freemarker\");\n        }\n    }\n\n    @Test\n    void classLoaderBasedResourceFallbackUsesResourceUrlLookupAfterStreamLookupFailure() throws IOException {\n        ClassLoader classLoader = new FailingStreamResourceClassLoader(\n                FreemarkerTemplateUtilityClassUtilTest.class.getClassLoader());\n\n        try (InputStream inputStream = ClassUtil.getReasourceAsStream(\n                classLoader,\n                \"fm/class-util.properties\",\n                false)) {\n            Properties properties = new Properties();\n            properties.load(inputStream);\n\n            Assertions.assertThat(properties).containsEntry(\"template.engine\", \"freemarker\");\n        }\n    }\n\n    @Test\n    void loadPropertiesUsesResourceUrlLookupAfterPropertiesLoadingFailure() {\n        Assertions.assertThatThrownBy(() -> ClassUtil.loadProperties(\n                FreemarkerTemplateUtilityClassUtilTest.class,\n                \"/fm/malformed-class-util.properties\"))\n                .isInstanceOf(IllegalArgumentException.class);\n    }\n\n    public static class FailingStreamResourceClassLoader extends ClassLoader {\n        public FailingStreamResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            throw new IllegalStateException(\"stream lookup failed\");\n        }\n\n        @Override\n        public URL getResource(String name) {\n            return getParent().getResource(name);\n        }\n    }\n\n    public static class FailingStreamClassResourceClassLoader extends FailingStreamResourceClassLoader {\n        public FailingStreamClassResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (RESOURCE_ANCHOR_CLASS.equals(name)) {\n                return defineClass(name, RESOURCE_ANCHOR_CLASS_BYTES, 0, RESOURCE_ANCHOR_CLASS_BYTES.length);\n            }\n            return super.findClass(name);\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1777634868373}]}
