  public class FreemarkerExtJspJspTagModelBaseTest {
      private static final String TAGLIB_URI = "http://example.test/freemarker/jsp-tag-model-base";
  
      @Test
      void simpleTagReceivesBeanAndDynamicAttributes() throws Exception {
          Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          MinimalServletContext servletContext = new MinimalServletContext();
          NoopServlet servlet = new NoopServlet();
          servlet.init(new MinimalServletConfig(servletContext));
  
          TaglibFactory taglibFactory = new TaglibFactory(servletContext);
          taglibFactory.setObjectWrapper(configuration.getObjectWrapper());
          taglibFactory.setClasspathTlds(Collections.singletonList("/fm/jsp-tag-model-base.tld"));
          TemplateModel tagLibrary = taglibFactory.get(TAGLIB_URI);
  
          Map<String, Object> model = new HashMap<>();
          model.put("tags", tagLibrary);
          ServletContextHashModel applicationModel = new ServletContextHashModel(
                  servlet, configuration.getObjectWrapper());
          model.put(FreemarkerServlet.KEY_APPLICATION, applicationModel);
          model.put(FreemarkerServlet.KEY_APPLICATION_PRIVATE, applicationModel);
          HttpRequestHashModel requestModel = new HttpRequestHashModel(
                  new MinimalHttpServletRequest(), new MinimalHttpServletResponse(), configuration.getObjectWrapper());
          model.put(FreemarkerServlet.KEY_REQUEST, requestModel);
          model.put(FreemarkerServlet.KEY_REQUEST_PRIVATE, requestModel);
  
          Template template = new Template(
                  "jsp-tag-model-base",
                  "<@tags.capture label='bean-value' dynamic='dynamic-value' number=7 />",
                  configuration);
          StringWriter output = new StringWriter();
  
          template.process(model, output);
  
          Assertions.assertThat(output.toString())
                  .isEqualTo("label=bean-value;number=7;dynamic=dynamic-value");
      }
  
      public static class CapturingSimpleTag extends SimpleTagSupport implements DynamicAttributes {
          private final Map<String, Object> dynamicAttributes = new HashMap<>();
          private String label;
          private int number;
  
          public void setLabel(String label) {
              this.label = label;
          }
  
          public void setNumber(int number) {
              this.number = number;
          }
  
          @Override
          public void setDynamicAttribute(String uri, String localName, Object value) {
              dynamicAttributes.put(localName, value);
          }
  
          @Override
          public void doTag() throws JspException, IOException {
              getJspContext().getOut().write("label=" + label
                      + ";number=" + number
                      + ";dynamic=" + dynamicAttributes.get("dynamic"));
          }
      }
  
