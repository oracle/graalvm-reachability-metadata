[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerLogLoggerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport freemarker.log.Logger;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerLogLoggerTest {\n\n    @Test\n    void explicitAndAutomaticLoggerSelectionCreateReflectiveFactories() throws ClassNotFoundException {\n        Logger.selectLoggerLibrary(Logger.LIBRARY_SLF4J);\n        Logger explicitLogger = Logger.getLogger(\"fm.logger.explicit-slf4j\");\n\n        explicitLogger.info(\"FreeMarker explicit SLF4J logger is available\");\n\n        Logger.selectLoggerLibrary(Logger.LIBRARY_AUTO);\n        Logger autoDetectedLogger = Logger.getLogger(\"fm.logger.auto-log4j-over-slf4j\");\n\n        autoDetectedLogger.warn(\"FreeMarker automatic logger is available\");\n        Assertions.assertThat(explicitLogger).isNotNull();\n        Assertions.assertThat(autoDetectedLogger).isNotNull();\n    }\n\n}\n"}
