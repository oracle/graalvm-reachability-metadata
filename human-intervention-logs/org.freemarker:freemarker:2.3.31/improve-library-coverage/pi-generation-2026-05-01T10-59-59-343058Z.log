dler())\n                .isSameAs(StaticTemplateExceptionHandlers.HANDLER);\n    }\n\n    @Test\n    void builderClassBuildMethodProvidesObjectWrapper() throws Exception {\n        Configuration configuration = newConfiguration();\n\n        configuration.setSetting(\"object_wrapper\", BuiltObjectWrapper.class.getName() + \"()\");\n\n        Assertions.assertThat(configuration.getObjectWrapper())\n                .isInstanceOf(BuiltObjectWrapper.class);\n    }\n\n    private static Configuration newConfiguration() {\n        return new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n    }\n\n    public static class LegacyConstructedObjectWrapper extends SimpleObjectWrapper {\n        public LegacyConstructedObjectWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n    }\n\n    public static class SingletonObjectWrapper extends SimpleObjectWrapper {\n        public static final SingletonObjectWrapper INSTANCE = new SingletonObjectWrapper();\n\n        public SingletonObjectWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n    }\n\n    public static class ConstructorObjectWrapper extends SimpleObjectWrapper {\n        public ConstructorObjectWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n    }\n\n    public static class StaticTemplateExceptionHandlers {\n        public static final TemplateExceptionHandler HANDLER = TemplateExceptionHandler.RETHROW_HANDLER;\n\n        public StaticTemplateExceptionHandlers() {\n        }\n    }\n\n    public static class BuiltObjectWrapper extends SimpleObjectWrapper {\n        public BuiltObjectWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n    }\n\n    public static class BuiltObjectWrapperBuilder {\n        public BuiltObjectWrapperBuilder() {\n        }\n\n        public ObjectWrapper build() {\n            return new BuiltObjectWrapper();\