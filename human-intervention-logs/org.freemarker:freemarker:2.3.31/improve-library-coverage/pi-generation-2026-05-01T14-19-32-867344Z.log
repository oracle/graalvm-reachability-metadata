  package fm;
  
  import java.util.Collections;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import javax.servlet.ServletContextEvent;
  import javax.servlet.ServletContextListener;
  
  import freemarker.ext.jsp.EventForwarding;
  import freemarker.ext.jsp.TaglibFactory;
  import freemarker.template.TemplateHashModel;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerExtJspTaglibFactoryInnerTldParserForTaglibBuildingTest {
      private static final String TAGLIB_URI = "http://example.test/freemarker/tld-parser-listener";
  
      @Test
      void tldListenerEntryIsInstantiatedWhileBuildingTaglib() throws Exception {
          TrackingServletContextListener.instances.set(0);
          FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext servletContext =
                  new FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext();
          EventForwarding eventForwarding = new EventForwarding();
          eventForwarding.contextInitialized(new ServletContextEvent(servletContext));
  
          TaglibFactory taglibFactory = new TaglibFactory(servletContext);
          taglibFactory.setClasspathTlds(Collections.singletonList("/fm/tld-parser-listener.tld"));
  
          TemplateHashModel taglib = (TemplateHashModel) taglibFactory.get(TAGLIB_URI);
  
          Assertions.assertThat(taglib.isEmpty()).isTrue();
          Assertions.assertThat(TrackingServletContextListener.instances).hasValue(1);
      }
  
      public static class TrackingServletContextListener implements ServletContextListener {
          private static final AtomicInteger instances = new AtomicInteger();
  
          public TrackingServletContextListener() {
              instances.incrementAndGet();
          }
  
          @Override
          public void contextInitialized(ServletContextEvent servletContextEvent) {
          }
  
          @Override
          public void contextDestroyed(ServletContextEvent servletContextEvent) {
          }
      }
  }
