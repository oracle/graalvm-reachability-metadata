  package fm;
  
  import java.io.StringWriter;
  import java.util.Collections;
  import java.util.HashMap;
  import java.util.Map;
  
  import freemarker.ext.jsp.TaglibFactory;
  import freemarker.template.Configuration;
  import freemarker.template.Template;
  import freemarker.template.TemplateHashModel;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerExtJspTaglibMethodUtilTest {
      private static final String TAGLIB_URI = "http://example.test/freemarker/taglib-method-util";
  
      @Test
      void jspElFunctionSignatureResolvesPublicStaticMethod() throws Exception {
          Configuration configuration = new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          TaglibFactory taglibFactory = new TaglibFactory(
                  new FreemarkerExtJspJspTagModelBaseTest.MinimalServletContext());
          taglibFactory.setObjectWrapper(configuration.getObjectWrapper());
          taglibFactory.setClasspathTlds(Collections.singletonList("/fm/taglib-method-util.tld"));
  
          TemplateHashModel taglib = (TemplateHashModel) taglibFactory.get(TAGLIB_URI);
          Map<String, Object> model = new HashMap<>();
          model.put("functions", taglib);
          Template template = new Template(
                  "taglib-method-util",
                  "${functions.describe('item', 2)}",
                  configuration);
          StringWriter output = new StringWriter();
  
          template.process(model, output);
  
          Assertions.assertThat(output.toString()).isEqualTo("item:item");
      }
  
      public static class FunctionLibrary {
          public static String describe(String value, int count) {
              return String.join(":", Collections.nCopies(count, value));
          }
      }
  }
