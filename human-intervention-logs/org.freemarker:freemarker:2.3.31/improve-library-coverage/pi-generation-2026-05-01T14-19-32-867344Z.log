  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation("org.slf4j:slf4j-api:1.7.36")
      testImplementation("org.slf4j:slf4j-simple:1.7.36")
      testImplementation("org.slf4j:log4j-over-slf4j:1.7.36")
      testImplementation("org.freemarker:freemarker:$libraryVersion")
      testImplementation("commons-el:commons-el:1.0") {
          exclude group: "javax.servlet", module: "servlet-api"
          exclude group: "javax.servlet.jsp", module: "jsp-api"
          exclude group: "jspapi", module: "jsp-api"
          exclude group: "servletapi", module: "servletapi"
      }
      testImplementation("javax.servlet:servlet-api:2.5")
      testImplementation("javax.servlet.jsp:javax.servlet.jsp-api:2.3.3") {
          exclude group: "javax.servlet", module: "javax.servlet-api"
      }
      testImplementation("org.apache.tomcat.embed:tomcat-embed-el:9.0.83")
      testImplementation('org.assertj:assertj-core:3.22.0')
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add('--no-fallback')
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
