TuningBeansWrapper();\n\n        Assertions.assertThat(wrapper.getIncompatibleImprovements())\n                .isEqualTo(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n    }\n\n    @Test\n    void unwrapsTemplateSequenceToJavaArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        TemplateModel sequence = wrapper.wrap(Arrays.asList(\"north\", \"south\"));\n\n        Object unwrapped = wrapper.unwrap(sequence, String[].class);\n\n        Assertions.assertThat((String[]) unwrapped)\n                .containsExactly(\"north\", \"south\");\n    }\n\n    @Test\n    void overloadedMethodConvertsListArgumentToArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.VERSION_2_3_21);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new OverloadedArrayConsumer());\n        TemplateMethodModelEx join = (TemplateMethodModelEx) model.get(\"join\");\n        List<TemplateModel> arguments = Collections.singletonList(wrapper.wrap(Arrays.asList(\"red\", \"blue\")));\n\n        TemplateScalarModel result = (TemplateScalarModel) join.exec(arguments);\n\n        Assertions.assertThat(result.getAsString())\n                .isEqualTo(\"red|blue\");\n    }\n\n    @Test\n    void createsInstanceThroughBeansWrapperConstructorSupport() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        List<TemplateModel> arguments = Collections.singletonList(new SimpleScalar(\"created\"));\n\n        Object instance = wrapper.newInstance(SingleConstructorBean.class, arguments);\n\n        Assertions.assertThat(instance)\n                .isInstanceOfSatisfying(SingleConstructorBean.class, bean -> Assertions.assertThat(bean.getName())\n                        .isEqualTo(\"created\"));\n    }\n\n    @Test\n    void readsExposedPublicInstanceField() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        wrapper.setExposeFields(true);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new FieldBackedBean(\"visible\"));\n\n        TemplateScalarModel value = (TemplateScalarModel) model.get(\"label\");\n\n        Assertions.assertThat(value.getAsString())\n                .isEqualTo(\"visible\");\n    }\n\n    public static class FineTuningBeansWrapper extends BeansWrapper {\n        public FineTuningBeansWrapper() {\n            super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        }\n\n        @Override\n        @SuppressWarnings(\"deprecation\")\n        protected void finetuneMethodAppearance(\n                Class<?> clazz, Method method, MethodAppearanceDecision decision) {\n            super.finetuneMethodAppearance(clazz, method, decision);\n        }\n    }\n\n    public static class OverloadedArrayConsumer {\n        public String join(String[] values) {\n            return String.join(\"|\", values);\n        }\n\n        public String join(Integer value) {\n            return String.valueOf(value);\n        }\n    }\n\n    public static class SingleConstructorBean {\n        private final String name;\n\n        public SingleConstructorBean(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    public static class FieldBackedBean {\n        public String label;\n\n        public FieldBackedBean(String label) {\n            this.label = label;\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1777634192798}]}
