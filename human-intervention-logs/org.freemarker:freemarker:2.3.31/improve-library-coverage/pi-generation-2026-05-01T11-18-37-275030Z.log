lateMethodModelEx;\nimport freemarker.template.TemplateModel;\nimport freemarker.template.TemplateScalarModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtBeansMethodUtilTest {\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleMethodOnSuperclass() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new SuperclassMethodBean());\n\n        TemplateMethodModelEx method = (TemplateMethodModelEx) model.get(\"superclassMessage\");\n        TemplateScalarModel result = (TemplateScalarModel) method.exec(Collections.emptyList());\n\n        Assertions.assertThat(result.getAsString())\n                .isEqualTo(\"method from subclass\");\n    }\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleMethodOnInterface() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new InterfaceMethodBean());\n\n        TemplateMethodModelEx method = (TemplateMethodModelEx) model.get(\"interfaceMessage\");\n        TemplateScalarModel result = (TemplateScalarModel) method.exec(Collections.emptyList());\n\n        Assertions.assertThat(result.getAsString())\n                .isEqualTo(\"method from implementation\");\n    }\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleConstructorOnSuperclass() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\n        TemplateModel argument = new SimpleScalar(\"constructed through subclass\");\n\n        Object instance = wrapper.newInstance(ConstructorBean.class, Collections.singletonList(argument));\n\n        Assertions.assertThat(instance)\n                .isInstanceOfSatisfying(ConstructorBean.class, bean -> Assertions.assertThat(bean.getValue())\n                        .isEqualTo(\"constructed through subclass\"));\n    }\n\n    @Test\n    void whitelistPolicyFindsTemplateAccessibleFieldsOnSuperclassAndInterface() throws Exception {\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(true);\n        TemplateHashModel superclassModel = (TemplateHashModel) wrapper.wrap(new SuperclassFieldBean());\n        TemplateHashModel interfaceModel = (TemplateHashModel) wrapper.wrap(new InterfaceFieldBean());\n\n        TemplateScalarModel superclassField = (TemplateScalarModel) superclassModel.get(\"superclassField\");\n        TemplateScalarModel interfaceField = (TemplateScalarModel) interfaceModel.get(\"interfaceField\");\n\n        Assertions.assertThat(superclassField.getAsString())\n                .isIn(\"field from subclass\", \"field from superclass\");\n        Assertions.assertThat(interfaceField.getAsString())\n                .isEqualTo(\"field from implementation\");\n    }\n\n    private BeansWrapper newAnnotationOnlyWrapper(boolean exposeFields) {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        wrapper.setExposeFields(exposeFields);\n        wrapper.setMemberAccessPolicy(new WhitelistMemberAccessPolicy(Collections.emptyList()));\n        return wrapper;\n    }\n\n    public static class AnnotatedMethodBase {\n        @TemplateAccessible\n        public String superclassMessage() {\n            return \"method from superclass\";\n        }\n    }\n\n    public static class SuperclassMethodBean extends AnnotatedMethodBase {\n        @Override\n        public String superclassMessage() {\n            return \"method from subclass\";\n        }\n    }\n\n    public interface AnnotatedMethodContract {\n        @TemplateAccessible\n        String interfaceMessage();\n    }\n\n    public static class InterfaceMethodBean implements AnnotatedMethodContract {\n        @Override\n        public String interfaceMessage() {\n            return \"method from implementation\";\n        }\n    }\n\n    public static class AnnotatedConstructorBase {\n        private final String value;\n\n        @TemplateAccessible\n        public AnnotatedConstructorBase(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n\n    public static class ConstructorBean extends AnnotatedConstructorBase {\n        public ConstructorBean(String value) {\n            super(value);\n        }\n    }\n\n    public static class AnnotatedFieldBase {\n        @TemplateAccessible\n        public String superclassField = \"field from superclass\";\n    }\n\n    public static class SuperclassFieldBean extends AnnotatedFieldBase {\n        public String superclassField = \"field from subclass\";\n    }\n\n    public interface AnnotatedFieldContract {\n        @TemplateAccessible\n        String interfaceField = \"field from interface\";\n    }\n\n    public static class InterfaceFieldBean implements AnnotatedFieldContract {\n        public String interfaceField = \"field from implementation\";\n    }\n\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtBeansMethodUtilTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage fm;\\n\\nimport java.util.Collections;\\n\\nimport freemarker.ext.beans.BeansWrapper;\\nimport freemarker.ext.beans.TemplateAccessible;\\nimport freemarker.ext.beans.WhitelistMemberAccessPolicy;\\nimport freemarker.template.Configuration;\\nimport freemarker.template.SimpleScalar;\\nimport freemarker.template.TemplateHashModel;\\nimport freemarker.template.TemplateMethodModelEx;\\nimport freemarker.template.TemplateModel;\\nimport freemarker.template.TemplateScalarModel;\\nimport org.assertj.core.api.Assertions;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class FreemarkerExtBeansMethodUtilTest {\\n\\n    @Test\\n    void whitelistPolicyFindsTemplateAccessibleMethodOnSuperclass() throws Exception {\\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new SuperclassMethodBean());\\n\\n        TemplateMethodModelEx method = (TemplateMethodModelEx) model.get(\\\"superclassMessage\\\");\\n        TemplateScalarModel result = (TemplateScalarModel) method.exec(Collections.emptyList());\\n\\n        Assertions.assertThat(result.getAsString())\\n                .isEqualTo(\\\"method from subclass\\\");\\n    }\\n\\n    @Test\\n    void whitelistPolicyFindsTemplateAccessibleMethodOnInterface() throws Exception {\\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new InterfaceMethodBean());\\n\\n        TemplateMethodModelEx method = (TemplateMethodModelEx) model.get(\\\"interfaceMessage\\\");\\n        TemplateScalarModel result = (TemplateScalarModel) method.exec(Collections.emptyList());\\n\\n        Assertions.assertThat(result.getAsString())\\n                .isEqualTo(\\\"method from implementation\\\");\\n    }\\n\\n    @Test\\n    void whitelistPolicyFindsTemplateAccessibleConstructorOnSuperclass() throws Exception {\\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(false);\\n        TemplateModel argument = new SimpleScalar(\\\"constructed through subclass\\\");\\n\\n        Object instance = wrapper.newInstance(ConstructorBean.class, Collections.singletonList(argument));\\n\\n        Assertions.assertThat(instance)\\n                .isInstanceOfSatisfying(ConstructorBean.class, bean -> Assertions.assertThat(bean.getValue())\\n                        .isEqualTo(\\\"constructed through subclass\\\"));\\n    }\\n\\n    @Test\\n    void whitelistPolicyFindsTemplateAccessibleFieldsOnSuperclassAndInterface() throws Exception {\\n        BeansWrapper wrapper = newAnnotationOnlyWrapper(true);\\n        TemplateHashModel superclassModel = (TemplateHashModel) wrapper.wrap(new SuperclassFieldBean());\\n        TemplateHashModel interfaceModel = (TemplateHashModel) wrapper.wrap(new InterfaceFieldBean());\\n\\n        TemplateScalarModel superclassField = (TemplateScalarModel) superclassModel.get(\\\"superclassField\\\");\\n        TemplateScalarModel interfaceField = (TemplateScalarModel) interfaceModel.get(\\\"interfaceField\\\");\\n\\n        Assertions.assertThat(superclassField.getAsString())\\n                .isIn(\\\"field from subclass\\\", \\\"field from superclass\\\");\\n        Assertions.assertThat(interfaceField.getAsString())\\n                .isEqualTo(\\\"field from implementation\\\");\\n    }\\n\\n    private BeansWrapper newAnnotationOnlyWrapper(boolean exposeFields) {\\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\\n        wrapper.setExposeFields(exposeFields);\\n        wrapper.setMemberAccessPolicy(new WhitelistMemberAccessPolicy(Collections.emptyList()));\\n        return wrapper;\\n    }\\n\\n    public static class AnnotatedMethodBase {\\n        @TemplateAccessible\\n        public String superclassMessage() {\\n            return \\\"method from superclass\\\";\\n        }\\n    }\\n\\n    public static class SuperclassMethodBean extends AnnotatedMethodBase {\\n        @Override\\n        public String superclassMessage() {\\n            return \\\"method from subclass\\\";\\n        }\\n    }\\n\\n    public interface AnnotatedMethodContract {\\n        @TemplateAccessible\\n        String interfaceMessage();\\n    }\\n\\n    public static class InterfaceMethodBean implements AnnotatedMethodContract {\\n        @Override\\n        public String interfaceMessage() {\\n            return \\\"method from implementation\\\";\\n        }\\n    }\\n\\n    public static class AnnotatedConstructorBase {\\n        private final String value;\\n\\n        @TemplateAccessible\\n        public AnnotatedConstructorBase(String value) {\\n            this.value = value;\\n        }\\n\\n        public String getValue() {\\n            return value;\\n        }\\n    }\\n\\n    public static class ConstructorBean extends AnnotatedConstructorBase {\\n        public ConstructorBean(String value) {\\n            super(value);\\n        }\\n    }\\n\\n    public static class AnnotatedFieldBase {\\n        @TemplateAccessible\\n        public String superclassField = \\\"field from superclass\\\";\\n    }\\n\\n    public static class SuperclassFieldBean extends AnnotatedFieldBase {\\n        public String superclassField = \\\"field from subclass\\\";\\n    }\\n\\n    public interface AnnotatedFieldContract {\\n        @TemplateAccessible\\n        String interfaceField = \\\"field from interface\\\";\\n    }\\n\\n    public static class InterfaceFieldBean implements AnnotatedFieldContract {\\n        public String interfaceField = \\\"field from implementation\\\";\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 443, "output": 2739, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 33390, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777634265613, "responseId": "resp_095a5758946b44c70169f48bda3bc081a0bc501b341527fe5e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_DB8w2pJTTgP9Yu4wkL0hYvj6|fc_095a5758946b44c70169f48bf180e881a0b43e2aded7aa31e8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5438 bytes to tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtBeansMethodUtilTest.java"}], "isError": false, "timestamp": 1777634295516}]}
