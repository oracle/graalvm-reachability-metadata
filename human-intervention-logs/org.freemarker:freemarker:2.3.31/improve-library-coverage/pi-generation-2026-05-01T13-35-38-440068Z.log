[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerCacheClassTemplateLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.IOException;\nimport java.io.Reader;\n\nimport freemarker.cache.ClassTemplateLoader;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerCacheClassTemplateLoaderTest {\n    @Test\n    void loadsTemplateResourceWithClassLoader() throws IOException {\n        ClassLoader testClassLoader = FreemarkerCacheClassTemplateLoaderTest.class.getClassLoader();\n        ClassTemplateLoader loader = new ClassTemplateLoader(testClassLoader, \"/\");\n\n        Object templateSource = loader.findTemplateSource(\"test.ftlh\");\n\n        Assertions.assertThat(templateSource).isNotNull();\n        try {\n            String templateText = readTemplate(loader, templateSource);\n            Assertions.assertThat(templateText)\n                    .contains(\"Welcome ${user}!\")\n                    .contains(\"${latestProduct.name}\");\n        } finally {\n            loader.closeTemplateSource(templateSource);\n        }\n        Assertions.assertThat(loader.getClassLoader()).isSameAs(testClassLoader);\n        Assertions.assertThat(loader.getResourceLoaderClass()).isNull();\n        Assertions.assertThat(loader.getBasePackagePath()).isEmpty();\n        Assertions.assertThat(loader.toString())\n                .contains(\"ClassTemplateLoader\")\n                .contains(\"classLoader=\")\n                .contains(\"basePackagePath=\\\"\\\"\");\n    }\n\n    private static String readTemplate(ClassTemplateLoader loader, Object templateSource) throws IOException {\n        try (Reader reader = loader.getReader(templateSource, \"UTF-8\")) {\n            StringBuilder content = new StringBuilder();\n            char[] buffer = new char[256];\n            int read;\n            while ((read = reader.read(buffer)) != -1) {\n                content.append(buffer, 0, read);\n            }\n            return content.toString();\n        }\n    }\n}\n"}
