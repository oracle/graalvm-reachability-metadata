  public class FreemarkerCacheWebappTemplateLoaderTest {
      @Test
      void toStringIncludesServletContextDetails() {
          String contextPath = "/freemarker-test";
          String displayName = "FreeMarker Webapp Loader Test";
          WebappTemplateLoader loader = new WebappTemplateLoader(
                  new ContextPathServletContext(contextPath, displayName), "WEB-INF/templates");
  
          String description = loader.toString();
  
          Assertions.assertThat(description)
                  .contains("WebappTemplateLoader")
                  .contains("/WEB-INF/templates/")
                  .contains(contextPath)
                  .contains(displayName);
      }
  
