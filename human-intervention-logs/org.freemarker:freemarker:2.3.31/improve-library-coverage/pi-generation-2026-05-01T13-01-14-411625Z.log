  package fm;
  
  import java.util.Arrays;
  import java.util.List;
  
  import freemarker.ext.beans.BeansWrapper;
  import freemarker.template.Configuration;
  import freemarker.template.TemplateHashModel;
  import freemarker.template.TemplateMethodModelEx;
  import freemarker.template.TemplateModel;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerExtBeansOverloadedVarArgsMethodsTest {
  
      @Test
      void overloadedVarArgsPacksMultipleTrailingArgumentsIntoArray() throws Exception {
          BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          TemplateMethodModelEx method = getMethod(wrapper);
          List<TemplateModel> arguments = Arrays.asList(
                  wrapper.wrap("prefix"),
                  wrapper.wrap("alpha"),
                  wrapper.wrap("beta"));
  
          Object result = wrapper.unwrap((TemplateModel) method.exec(arguments));
  
          Assertions.assertThat(result)
                  .isEqualTo("prefix:alpha|beta");
      }
  
      @Test
      void overloadedVarArgsPacksSingleTrailingArgumentIntoArray() throws Exception {
          BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          TemplateMethodModelEx method = getMethod(wrapper);
          List<TemplateModel> arguments = Arrays.asList(
                  wrapper.wrap("prefix"),
                  wrapper.wrap("solo"));
  
          Object result = wrapper.unwrap((TemplateModel) method.exec(arguments));
  
          Assertions.assertThat(result)
                  .isEqualTo("prefix:solo");
      }
  
      private TemplateMethodModelEx getMethod(BeansWrapper wrapper) throws Exception {
          TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new VarArgsTarget());
          return (TemplateMethodModelEx) model.get("format");
      }
  
      public static class VarArgsTarget {
          public String format(String prefix, String... values) {
              return prefix + ":" + String.join("|", values);
          }
  
          public String format(Integer value) {
              return "number:" + value;
          }
      }
  
  }
