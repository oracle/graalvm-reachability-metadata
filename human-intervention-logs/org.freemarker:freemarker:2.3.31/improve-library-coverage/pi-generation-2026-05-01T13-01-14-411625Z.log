[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtBeansSimpleMethodTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.util.Arrays;\nimport java.util.Collections;\nimport java.util.List;\n\nimport freemarker.ext.beans.BeansWrapper;\nimport freemarker.template.Configuration;\nimport freemarker.template.TemplateHashModel;\nimport freemarker.template.TemplateMethodModelEx;\nimport freemarker.template.TemplateModel;\nimport freemarker.template.TemplateScalarModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\n\npublic class FreemarkerExtBeansSimpleMethodTest {\n\n    @Test\n    void simpleVarArgsMethodCreatesEmptyArrayWhenNoTrailingArgumentsArePassed() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        TemplateMethodModelEx method = getMethod(wrapper);\n        List<TemplateModel> arguments = Collections.singletonList(wrapper.wrap(\"prefix\"));\n\n        TemplateScalarModel result = (TemplateScalarModel) method.exec(arguments);\n\n        Assertions.assertThat(result.getAsString())\n                .isEqualTo(\"prefix:\");\n    }\n\n    @Test\n    void simpleVarArgsMethodPacksTrailingArgumentsIntoArray() throws Exception {\n        BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);\n        TemplateMethodModelEx method = getMethod(wrapper);\n        List<TemplateModel> arguments = Arrays.asList(\n                wrapper.wrap(\"prefix\"),\n                wrapper.wrap(\"alpha\"),\n                wrapper.wrap(\"beta\"));\n\n        TemplateScalarModel result = (TemplateScalarModel) method.exec(arguments);\n\n        Assertions.assertThat(result.getAsString())\n                .isEqualTo(\"prefix:alpha|beta\");\n    }\n\n    private TemplateMethodModelEx getMethod(BeansWrapper wrapper) throws Exception {\n        TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new SimpleVarArgsTarget());\n        return (TemplateMethodModelEx) model.get(\"format\");\n    }\n\n    public static class SimpleVarArgsTarget {\n        public String format(String prefix, String... values) {\n            return prefix + \":\" + String.join(\"|\", values);\n        }\n    }\n\n}\n"}
