       * {@link StatefulTemplateLoader#resetState()} method is invoked as well.
       */
      public void clear() {
          synchronized (storage) {
              storage.clear();
              if (templateLoader instanceof StatefulTemplateLoader) {
                  ((StatefulTemplateLoader) templateLoader).resetState();
              }
          }
      }
  
