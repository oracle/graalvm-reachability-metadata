  package fm;
  
  import java.io.IOException;
  import java.io.Reader;
  import java.util.Locale;
  
  import freemarker.cache.StrongCacheStorage;
  import freemarker.cache.TemplateCache;
  import freemarker.cache.TemplateLoader;
  import freemarker.template.Configuration;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerCacheTemplateCacheTest {
  
      @Test
      void cachedTemplateLoadingIOExceptionIsRethrownWithOriginalCause() {
          IOException loadingFailure = new IOException("template storage unavailable");
          TemplateCache cache = new TemplateCache(
                  new FailingTemplateLoader(loadingFailure),
                  new StrongCacheStorage(),
                  new Configuration(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS));
          cache.setDelay(Long.MAX_VALUE);
          cache.setLocalizedLookup(false);
  
          IOException firstFailure = Assertions.catchThrowableOfType(
                  () -> cache.getTemplate("broken.ftl", Locale.ROOT, "UTF-8", true),
                  IOException.class);
          Assertions.assertThat(firstFailure).isSameAs(loadingFailure);
  
          IOException cachedFailure = Assertions.catchThrowableOfType(
                  () -> cache.getTemplate("broken.ftl", Locale.ROOT, "UTF-8", true),
                  IOException.class);
          Assertions.assertThat(cachedFailure)
                  .isNotSameAs(loadingFailure)
                  .hasMessageContaining("error loading the template on an earlier attempt")
                  .hasCause(loadingFailure);
      }
  
      private static final class FailingTemplateLoader implements TemplateLoader {
          private static final Object TEMPLATE_SOURCE = "broken-template-source";
  
          private final IOException loadingFailure;
  
          private FailingTemplateLoader(IOException loadingFailure) {
              this.loadingFailure = loadingFailure;
          }
  
          @Override
          public Object findTemplateSource(String name) {
              return TEMPLATE_SOURCE;
          }
  
          @Override
          public long getLastModified(Object templateSource) {
              return 0L;
          }
  
          @Override
          public Reader getReader(Object templateSource, String encoding) throws IOException {
              throw loadingFailure;
          }
  
          @Override
          public void closeTemplateSource(Object templateSource) {
          }
      }
  }
