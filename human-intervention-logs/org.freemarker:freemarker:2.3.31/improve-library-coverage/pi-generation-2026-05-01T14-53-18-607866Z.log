  package fm;
  
  import java.util.Locale;
  
  import freemarker.template.ResourceBundleLocalizedString;
  import freemarker.template.TemplateModelException;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerTemplateResourceBundleLocalizedStringTest {
      private static final String BUNDLE_NAME = "fm.ResourceBundleLocalizedStringMessages";
  
      @Test
      void getLocalizedStringLoadsResourceBundleForRequestedLocale() throws TemplateModelException {
          ResourceBundleLocalizedString localizedString = new ResourceBundleLocalizedString(BUNDLE_NAME, "localized.message");
  
          String message = localizedString.getLocalizedString(Locale.FRANCE);
  
          Assertions.assertThat(message).isEqualTo("Bonjour depuis FreeMarker");
      }
  }
