[tool-call] delta {"path":"tests/src/org.freemarker/freemarker/2.3.31/src/test/java/fm/FreemarkerExtDomNodeModelTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage fm;\n\nimport java.io.StringReader;\n\nimport freemarker.ext.dom.NodeModel;\nimport freemarker.ext.dom.XPathSupport;\nimport freemarker.template.SimpleScalar;\nimport freemarker.template.TemplateModel;\nimport freemarker.template.TemplateModelException;\nimport freemarker.template.TemplateScalarModel;\nimport org.assertj.core.api.Assertions;\nimport org.junit.jupiter.api.Test;\nimport org.w3c.dom.Document;\nimport org.xml.sax.InputSource;\n\npublic class FreemarkerExtDomNodeModelTest {\n\n    @Test\n    void evaluatesXmlQueryWithConfiguredXPathSupport() throws Exception {\n        CapturingXPathSupport.reset();\n        try {\n            NodeModel.setXPathSupportClass(CapturingXPathSupport.class);\n            NodeModel documentModel = NodeModel.parse(new InputSource(new StringReader(\"\"\"\n                    <inventory>\n                        <book id=\"native-image\">Native Image</book>\n                    </inventory>\n                    \"\"\")));\n\n            TemplateModel result = documentModel.get(\"/inventory/book/text()\");\n\n            Assertions.assertThat(result).isInstanceOf(TemplateScalarModel.class);\n            Assertions.assertThat(((TemplateScalarModel) result).getAsString()).isEqualTo(\"Native Image\");\n            Assertions.assertThat(CapturingXPathSupport.getInstantiationCount()).isEqualTo(1);\n        } finally {\n            NodeModel.useDefaultXPathSupport();\n        }\n    }\n\n    public static final class CapturingXPathSupport implements XPathSupport {\n        private static int instantiationCount;\n\n        public CapturingXPathSupport() {\n            instantiationCount++;\n        }\n\n        @Override\n        public TemplateModel executeQuery(Object context, String xpathQuery) throws TemplateModelException {\n            if (!(context instanceof Document)) {\n                throw new TemplateModelException(\"Expected document context for XPath query\");\n            }\n            if (!\"/inventory/book/text()\".equals(xpathQuery)) {\n                throw new TemplateModelException(\"Unexpected XPath query: \" + xpathQuery);\n            }\n            Document document = (Document) context;\n            return new SimpleScalar(document.getDocumentElement().getElementsByTagName(\"book\").item(0).getTextContent());\n        }\n\n        static int getInstantiationCount() {\n            return instantiationCount;\n        }\n\n        static void reset() {\n            instantiationCount = 0;\n        }\n    }\n}\n"}
