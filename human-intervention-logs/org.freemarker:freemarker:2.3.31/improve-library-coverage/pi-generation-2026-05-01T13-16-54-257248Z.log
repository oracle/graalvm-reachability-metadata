ut(FreemarkerServlet.KEY_APPLICATION_PRIVATE, applicationModel);\n        HttpRequestHashModel requestModel = new HttpRequestHashModel(\n                new FreemarkerExtJspJspTagModelBaseTest.MinimalHttpServletRequest(),\n                new FreemarkerExtJspJspTagModelBaseTest.MinimalHttpServletResponse(),\n                configuration.getObjectWrapper());\n        model.put(FreemarkerServlet.KEY_REQUEST, requestModel);\n        model.put(FreemarkerServlet.KEY_REQUEST_PRIVATE, requestModel);\n        model.put(\"exercisePageContext\", new PageContext2ExpressionEvaluatorDirective());\n\n        Template template = new Template(\n                \"freemarker-page-context2-expression-evaluator\",\n                \"<@exercisePageContext />\",\n                configuration);\n\n        template.process(model, new StringWriter());\n    }\n\n    private static final class PageContext2ExpressionEvaluatorDirective implements TemplateDirectiveModel {\n        @Override\n        @SuppressWarnings(\"rawtypes\")\n        public void execute(\n                Environment environment,\n                Map parameters,\n                TemplateModel[] loopVariables,\n                TemplateDirectiveBody body) throws freemarker.template.TemplateException {\n            _FreeMarkerPageContext2 pageContext = new _FreeMarkerPageContext2();\n            ExpressionEvaluator evaluator = pageContext.getExpressionEvaluator();\n\n            Assertions.assertThat(evaluator).isNotNull();\n        }\n    }\n}\n"}
