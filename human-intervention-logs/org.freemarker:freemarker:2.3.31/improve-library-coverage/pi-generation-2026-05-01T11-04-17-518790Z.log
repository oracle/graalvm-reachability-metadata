                      + "AAAEAAQABQABAAsAAAACAAw=");
  
      @Test
      void forNameFallsBackWhenContextClassLoaderIsUnavailable() throws ClassNotFoundException {
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
  
          try {
              currentThread.setContextClassLoader(null);
  
              Class<?> loadedClass = ClassUtil.forName(String.class.getName());
  
              Assertions.assertThat(loadedClass).isSameAs(String.class);
          } finally {
              currentThread.setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void classBasedResourceStreamFindsPropertiesResource() throws IOException {
          try (InputStream inputStream = ClassUtil.getReasourceAsStream(
                  FreemarkerTemplateUtilityClassUtilTest.class,
                  "/fm/class-util.properties",
                  false)) {
              Properties properties = new Properties();
              properties.load(inputStream);
  
              Assertions.assertThat(properties).containsEntry("template.engine", "freemarker");
          }
      }
  
      @Test
      void classBasedResourceFallbackUsesResourceUrlLookupAfterStreamLookupFailure() throws Exception {
          try {
              ClassLoader classLoader = new FailingStreamClassResourceClassLoader(
                      FreemarkerTemplateUtilityClassUtilTest.class.getClassLoader());
              Class<?> resourceAnchorClass = classLoader.loadClass(RESOURCE_ANCHOR_CLASS);
  
              try (InputStream inputStream = ClassUtil.getReasourceAsStream(
                      resourceAnchorClass,
                      "/fm/class-util.properties",
                      false)) {
                  Properties properties = new Properties();
                  properties.load(inputStream);
  
                  Assertions.assertThat(properties).containsEntry("template.engine", "freemarker");
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void classLoaderBasedResourceStreamFindsPropertiesResource() throws IOException {
          ClassLoader classLoader = FreemarkerTemplateUtilityClassUtilTest.class.getClassLoader();
  
          try (InputStream inputStream = ClassUtil.getReasourceAsStream(
                  classLoader,
                  "fm/class-util.properties",
                  false)) {
              Properties properties = new Properties();
              properties.load(inputStream);
  
              Assertions.assertThat(properties).containsEntry("template.engine", "freemarker");
          }
      }
  
      @Test
      void classLoaderBasedResourceFallbackUsesResourceUrlLookupAfterStreamLookupFailure() throws IOException {
          ClassLoader classLoader = new FailingStreamResourceClassLoader(
                  FreemarkerTemplateUtilityClassUtilTest.class.getClassLoader());
  
          try (InputStream inputStream = ClassUtil.getReasourceAsStream(
                  classLoader,
                  "fm/class-util.properties",
                  false)) {
              Properties properties = new Properties();
              properties.load(inputStream);
  
              Assertions.assertThat(properties).containsEntry("template.engine", "freemarker");
          }
      }
  
      @Test
      void loadPropertiesUsesResourceUrlLookupAfterPropertiesLoadingFailure() {
          Assertions.assertThatThrownBy(() -> ClassUtil.loadProperties(
                  FreemarkerTemplateUtilityClassUtilTest.class,
                  "/fm/malformed-class-util.properties"))
                  .isInstanceOf(IllegalArgumentException.class);
      }
  
      public static class FailingStreamResourceClassLoader extends ClassLoader {
          public FailingStreamResourceClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public InputStream getResourceAsStream(String name) {
              throw new IllegalStateException("stream lookup failed");
          }
  
          @Override
          public URL getResource(String name) {
              return getParent().getResource(name);
          }
      }
  
      public static class FailingStreamClassResourceClassLoader extends FailingStreamResourceClassLoader {
          public FailingStreamClassResourceClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          protected Class<?> findClass(String name) throws ClassNotFoundException {
              if (RESOURCE_ANCHOR_CLASS.equals(name)) {
                  return defineClass(name, RESOURCE_ANCHOR_CLASS_BYTES, 0, RESOURCE_ANCHOR_CLASS_BYTES.length);
              }
              return super.findClass(name);
          }
      }
  
  }
