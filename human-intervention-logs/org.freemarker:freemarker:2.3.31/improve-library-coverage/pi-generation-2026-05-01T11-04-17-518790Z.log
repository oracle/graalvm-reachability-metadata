  package fm;
  
  import freemarker.log.Logger;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerLogLoggerTest {
  
      @Test
      void explicitAndAutomaticLoggerSelectionCreateReflectiveFactories() throws ClassNotFoundException {
          Logger.selectLoggerLibrary(Logger.LIBRARY_SLF4J);
          Logger explicitLogger = Logger.getLogger("fm.logger.explicit-slf4j");
  
          explicitLogger.info("FreeMarker explicit SLF4J logger is available");
  
          Logger.selectLoggerLibrary(Logger.LIBRARY_AUTO);
          Logger autoDetectedLogger = Logger.getLogger("fm.logger.auto-log4j-over-slf4j");
  
          autoDetectedLogger.warn("FreeMarker automatic logger is available");
          Assertions.assertThat(explicitLogger).isNotNull();
          Assertions.assertThat(autoDetectedLogger).isNotNull();
      }
  
  }
