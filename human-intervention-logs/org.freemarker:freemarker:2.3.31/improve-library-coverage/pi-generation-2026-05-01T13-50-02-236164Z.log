  package fm;
  
  import java.lang.reflect.Method;
  import java.util.Arrays;
  import java.util.Collections;
  import java.util.List;
  
  import freemarker.ext.beans.BeansWrapper;
  import freemarker.template.Configuration;
  import freemarker.template.SimpleScalar;
  import freemarker.template.TemplateHashModel;
  import freemarker.template.TemplateMethodModelEx;
  import freemarker.template.TemplateModel;
  import freemarker.template.TemplateScalarModel;
  import org.assertj.core.api.Assertions;
  import org.junit.jupiter.api.Test;
  
  public class FreemarkerExtBeansBeansWrapperTest {
  
      @Test
      void subclassConstructionDetectsLegacyMethodAppearanceOverride() {
          FineTuningBeansWrapper wrapper = new FineTuningBeansWrapper();
  
          Assertions.assertThat(wrapper.getIncompatibleImprovements())
                  .isEqualTo(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
      }
  
      @Test
      void unwrapsTemplateSequenceToJavaArray() throws Exception {
          BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          TemplateModel sequence = wrapper.wrap(Arrays.asList("north", "south"));
  
          Object unwrapped = wrapper.unwrap(sequence, String[].class);
  
          Assertions.assertThat((String[]) unwrapped)
                  .containsExactly("north", "south");
      }
  
      @Test
      void overloadedMethodConvertsListArgumentToArray() throws Exception {
          BeansWrapper wrapper = new BeansWrapper(Configuration.VERSION_2_3_21);
          TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new OverloadedArrayConsumer());
          TemplateMethodModelEx join = (TemplateMethodModelEx) model.get("join");
          List<TemplateModel> arguments = Collections.singletonList(wrapper.wrap(Arrays.asList("red", "blue")));
  
          TemplateScalarModel result = (TemplateScalarModel) join.exec(arguments);
  
          Assertions.assertThat(result.getAsString())
                  .isEqualTo("red|blue");
      }
  
      @Test
      void createsInstanceThroughBeansWrapperConstructorSupport() throws Exception {
          BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          List<TemplateModel> arguments = Collections.singletonList(new SimpleScalar("created"));
  
          Object instance = wrapper.newInstance(SingleConstructorBean.class, arguments);
  
          Assertions.assertThat(instance)
                  .isInstanceOfSatisfying(SingleConstructorBean.class, bean -> Assertions.assertThat(bean.getName())
                          .isEqualTo("created"));
      }
  
      @Test
      void readsExposedPublicInstanceField() throws Exception {
          BeansWrapper wrapper = new BeansWrapper(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          wrapper.setExposeFields(true);
          TemplateHashModel model = (TemplateHashModel) wrapper.wrap(new FieldBackedBean("visible"));
  
          TemplateScalarModel value = (TemplateScalarModel) model.get("label");
  
          Assertions.assertThat(value.getAsString())
                  .isEqualTo("visible");
      }
  
      public static class FineTuningBeansWrapper extends BeansWrapper {
          public FineTuningBeansWrapper() {
              super(Configuration.DEFAULT_INCOMPATIBLE_IMPROVEMENTS);
          }
  
          @Override
          @SuppressWarnings("deprecation")
          protected void finetuneMethodAppearance(
                  Class<?> clazz, Method method, MethodAppearanceDecision decision) {
              super.finetuneMethodAppearance(clazz, method, decision);
          }
      }
  
      public static class OverloadedArrayConsumer {
          public String join(String[] values) {
              return String.join("|", values);
          }
  
          public String join(Integer value) {
              return String.valueOf(value);
          }
      }
  
      public static class SingleConstructorBean {
          private final String name;
  
          public SingleConstructorBean(String name) {
              this.name = name;
          }
  
          public String getName() {
              return name;
          }
      }
  
      public static class FieldBackedBean {
          public String label;
  
          public FieldBackedBean(String label) {
              this.label = label;
          }
      }
  
  }
