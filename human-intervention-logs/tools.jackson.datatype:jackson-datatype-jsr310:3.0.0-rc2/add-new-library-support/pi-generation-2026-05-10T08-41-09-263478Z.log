                  LocalTime.of(4, 5, 6, 123456789),
                  LocalDateTime.of(2024, 2, 3, 4, 5, 6, 123456789),
                  Instant.parse("2024-02-03T04:05:06.123456789Z"),
                  Duration.ofHours(2).plusMinutes(3).plusSeconds(4).plusMillis(500));
  
