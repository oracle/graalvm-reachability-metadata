  import kotlin.coroutines.CoroutineContext
  import kotlinx.coroutines.InternalCoroutinesApi
  import kotlinx.coroutines.MainCoroutineDispatcher
  import kotlinx.coroutines.internal.ANDROID_DETECTED
  import kotlinx.coroutines.internal.FastServiceLoader
  import kotlinx.coroutines.internal.MainDispatcherFactory
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class FastServiceLoaderTest {
      @Test
      @OptIn(InternalCoroutinesApi::class)
      public fun loadProvidersReadsServiceResourcesAndInstantiatesFactories() {
          val loader: ClassLoader = checkNotNull(
              Thread.currentThread().contextClassLoader ?: MainDispatcherFactory::class.java.classLoader
          )
  
          val providers: List<MainDispatcherFactory> =
              FastServiceLoader.loadProviders(MainDispatcherFactory::class.java, loader)
  
          assertThat(providers.map { provider: MainDispatcherFactory -> provider::class.java.name })
              .contains(RecordingMainDispatcherFactory::class.java.name)
          assertThat(RecordingMainDispatcherFactory.instancesCreated.get()).isGreaterThanOrEqualTo(1)
      }
  
      @Test
      @OptIn(InternalCoroutinesApi::class)
      public fun loadMainDispatcherFactoryUsesAndroidSpecificClassNameLookups() {
          assertThat(ANDROID_DETECTED).isTrue()
  
          val factories: List<MainDispatcherFactory> = FastServiceLoader.loadMainDispatcherFactory()
  
          assertThat(factories.map { factory: MainDispatcherFactory -> factory::class.java.name })
              .contains(
                  "kotlinx.coroutines.android.AndroidDispatcherFactory",
                  "kotlinx.coroutines.test.internal.TestMainDispatcherFactory"
              )
      }
  }
  
  @OptIn(InternalCoroutinesApi::class)
  public class RecordingMainDispatcherFactory : MainDispatcherFactory {
      public companion object {
          public val instancesCreated: AtomicInteger = AtomicInteger()
      }
  
      init {
          instancesCreated.incrementAndGet()
      }
  
      override val loadPriority: Int = -10
  
      override fun createDispatcher(allFactories: List<MainDispatcherFactory>): MainCoroutineDispatcher =
          RecordingMainDispatcher
  
      override fun hintOnError(): String = "test dispatcher factory"
  }
  
  public object RecordingMainDispatcher : MainCoroutineDispatcher() {
      override val immediate: MainCoroutineDispatcher
          get() = this
  
      override fun isDispatchNeeded(context: CoroutineContext): Boolean = false
  
      override fun dispatch(context: CoroutineContext, block: Runnable) {
          block.run()
      }
  
      override fun toString(): String = "RecordingMainDispatcher"
  }
