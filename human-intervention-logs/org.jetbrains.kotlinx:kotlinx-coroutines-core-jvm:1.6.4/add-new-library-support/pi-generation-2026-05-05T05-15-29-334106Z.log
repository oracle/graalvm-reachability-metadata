  package org_jetbrains_kotlinx.kotlinx_coroutines_core_jvm
  
  import java.util.concurrent.ScheduledThreadPoolExecutor
  import kotlinx.coroutines.ExecutorCoroutineDispatcher
  import kotlinx.coroutines.asCoroutineDispatcher
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class ConcurrentKtTest {
      @Test
      public fun scheduledThreadPoolDispatcherEnablesRemoveOnCancelPolicy(): Unit {
          val executor: ScheduledThreadPoolExecutor = ScheduledThreadPoolExecutor(1)
          val dispatcher: ExecutorCoroutineDispatcher = executor.asCoroutineDispatcher()
          try {
              assertThat(executor.removeOnCancelPolicy).isTrue()
          } finally {
              dispatcher.close()
              executor.shutdownNow()
          }
      }
  }
