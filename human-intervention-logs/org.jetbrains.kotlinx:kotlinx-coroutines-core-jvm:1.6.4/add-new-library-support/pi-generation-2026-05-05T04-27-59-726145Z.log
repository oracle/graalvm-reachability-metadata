              return block(this)
          } catch (e: Throwable) {
              cause = e
              throw e
          } finally {
              try {
                  close()
              } catch (closeException: Throwable) {
                  if (cause === null) throw closeException
                  cause.addSuppressed(closeException)
                  throw cause
              }
          }
      }
  
      private fun parseFile(r: BufferedReader): List<String> {
