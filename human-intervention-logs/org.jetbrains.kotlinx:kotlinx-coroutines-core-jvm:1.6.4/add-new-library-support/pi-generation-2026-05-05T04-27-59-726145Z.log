fc_076ef2accb1798df0169f97160eff0819c813c477e484cdeae", "name": "write", "arguments": {"path": "tests/src/org.jetbrains.kotlinx/kotlinx-coroutines-core-jvm/1.6.4/src/test/kotlin/org_jetbrains_kotlinx/kotlinx_coroutines_core_jvm/FastServiceLoaderTest.kt", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\n@file:Suppress(\"INVISIBLE_MEMBER\", \"INVISIBLE_REFERENCE\")\n\npackage org_jetbrains_kotlinx.kotlinx_coroutines_core_jvm\n\nimport java.util.concurrent.atomic.AtomicInteger\nimport kotlin.coroutines.CoroutineContext\nimport kotlinx.coroutines.InternalCoroutinesApi\nimport kotlinx.coroutines.MainCoroutineDispatcher\nimport kotlinx.coroutines.internal.FastServiceLoader\nimport kotlinx.coroutines.internal.MainDispatcherFactory\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class FastServiceLoaderTest {\n    @Test\n    @OptIn(InternalCoroutinesApi::class)\n    public fun loadProvidersReadsServiceResourcesAndInstantiatesFactories() {\n        val loader: ClassLoader = Thread.currentThread().contextClassLoader\n            ?: MainDispatcherFactory::class.java.classLoader\n\n        val providers: List<MainDispatcherFactory> =\n            FastServiceLoader.loadProviders(MainDispatcherFactory::class.java, loader)\n\n        assertThat(providers.map { provider: MainDispatcherFactory -> provider::class.java.name })\n            .contains(RecordingMainDispatcherFactory::class.java.name)\n        assertThat(RecordingMainDispatcherFactory.instancesCreated.get()).isGreaterThanOrEqualTo(1)\n    }\n\n    @Test\n    @OptIn(InternalCoroutinesApi::class)\n    public fun loadMainDispatcherFactoryUsesAndroidSpecificClassNameLookups() {\n        val factories: List<MainDispatcherFactory> = FastServiceLoader.loadMainDispatcherFactory()\n\n        assertThat(factories.map { factory: MainDispatcherFactory -> factory::class.java.name })\n            .contains(\"kotlinx.coroutines.test.internal.TestMainDispatcherFactory\")\n    }\n}\n\n@OptIn(InternalCoroutinesApi::class)\npublic class RecordingMainDispatcherFactory : MainDispatcherFactory {\n    public companion object {\n        public val instancesCreated: AtomicInteger = AtomicInteger()\n    }\n\n    init {\n        instancesCreated.incrementAndGet()\n    }\n\n    override val loadPriority: Int = -10\n\n    override fun createDispatcher(allFactories: List<MainDispatcherFactory>): MainCoroutineDispatcher =\n        RecordingMainDispatcher\n\n    override fun hintOnError(): String = \"test dispatcher factory\"\n}\n\npublic object RecordingMainDispatcher : MainCoroutineDispatcher() {\n    override val immediate: MainCoroutineDispatcher\n        get() = this\n\n    override fun isDispatchNeeded(context: CoroutineContext): Boolean = false\n\n    override fun dispatch(context: CoroutineContext, block: Runnable) {\n        block.run()\n    }\n\n    override fun toString(): String = \"RecordingMainDispatcher\"\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 474, "output": 2028, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 20934, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777955152384, "responseId": "resp_076ef2accb1798df0169f97150df94819cb4ddd717e7171fe1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_SgoHiJsEhZ3TuTVHta2Amsvz|fc_076ef2accb1798df0169f97160eff0819c813c477e484cdeae", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2757 bytes to tests/src/org.jetbrains.kotlinx/kotlinx-coroutines-core-jvm/1.6.4/src/test/kotlin/org_jetbrains_kotlinx/kotlinx_coroutines_core_jvm/FastServiceLoaderTest.kt"}], "isError": false, "timestamp": 1777955171627}]}
