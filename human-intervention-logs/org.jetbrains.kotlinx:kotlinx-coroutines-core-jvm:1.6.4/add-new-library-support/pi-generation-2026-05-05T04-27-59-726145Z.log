              val clz = Class.forName(serviceClass, true, baseClass.classLoader)
              baseClass.cast(clz.getDeclaredConstructor().newInstance())
          } catch (e: ClassNotFoundException) { // Do not fail if TestMainDispatcherFactory is not found
              null
          }
