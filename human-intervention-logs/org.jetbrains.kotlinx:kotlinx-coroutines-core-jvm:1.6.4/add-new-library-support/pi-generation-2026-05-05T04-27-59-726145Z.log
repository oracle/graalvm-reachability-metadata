[tool-call] delta {"path":"tests/src/org.jetbrains.kotlinx/kotlinx-coroutines-core-jvm/1.6.4/src/test/kotlin/org_jetbrains_kotlinx/kotlinx_coroutines_core_jvm/FastServiceLoaderTest.kt","edits":[{"oldText":"import kotlinx.coroutines.internal.FastServiceLoader\nimport kotlinx.coroutines.internal.MainDispatcherFactory\n","newText":"import kotlinx.coroutines.internal.ANDROID_DETECTED\nimport kotlinx.coroutines.internal.FastServiceLoader\nimport kotlinx.coroutines.internal.MainDispatcherFactory\nimport kotlinx.coroutines.test.internal.TestMainDispatcherFactory\n"},{"oldText":"    public fun loadMainDispatcherFactoryUsesAndroidSpecificClassNameLookups() {\n        val factories: List<MainDispatcherFactory> = FastServiceLoader.loadMainDispatcherFactory()\n\n        assertThat(factories.map { factory: MainDispatcherFactory -> factory::class.java.name })\n            .contains(\"kotlinx.coroutines.test.internal.TestMainDispatcherFactory\")\n    }\n","newText":"    public fun loadMainDispatcherFactoryUsesAndroidSpecificClassNameLookups() {\n        assertThat(ANDROID_DETECTED).isTrue()\n\n        val factories: List<MainDispatcherFactory> = FastServiceLoader.loadMainDispatcherFactory()\n\n        assertThat(factories.map { factory: MainDispatcherFactory -> factory::class.java.name })\n            .contains(TestMainDispatcherFactory::class.java.name)\n        assertThat(TestMainDispatcherFactory.instancesCreated.get()).isGreaterThanOrEqualTo(1)\n    }\n"}]}
