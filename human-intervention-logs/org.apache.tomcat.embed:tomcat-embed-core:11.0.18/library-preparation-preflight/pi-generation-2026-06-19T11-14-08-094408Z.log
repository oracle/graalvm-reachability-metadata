  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
  	testImplementation "org.apache.tomcat.embed:tomcat-embed-core:$libraryVersion"
  	testImplementation 'jakarta.annotation:jakarta.annotation-api:3.0.0'
  	testImplementation 'jakarta.servlet:jakarta.servlet-api:5.0.0'
  	testImplementation 'org.assertj:assertj-core:3.22.0'
  	testRuntimeOnly 'org.apache.tomcat:jakartaee-migration:1.0.6'
  }
  
  tasks.withType(Test).configureEach {
      jvmArgs '--add-opens=java.base/java.lang=ALL-UNNAMED'
      jvmArgs '--add-opens=java.base/java.util=ALL-UNNAMED'
      jvmArgs '--add-opens=java.rmi/sun.rmi.transport=ALL-UNNAMED'
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add('--allow-incomplete-classpath')
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
