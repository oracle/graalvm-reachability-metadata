n\\n            assertThat(instance).isInstanceOf(PublicComponent.class);\\n            assertThat(((PublicComponent) instance).message()).isEqualTo(\\\"created\\\");\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void createsInstanceFromClassNameUsingProvidedClassLoader() throws Exception {\\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\\n\\n        Object instance = instanceManager.newInstance(PublicComponent.class.getName(), PublicComponent.class.getClassLoader());\\n\\n        assertThat(instance).isInstanceOf(PublicComponent.class);\\n        assertThat(((PublicComponent) instance).message()).isEqualTo(\\\"created\\\");\\n    }\\n\\n    @Test\\n    void existingInstanceLifecycleCallbacksAreNoOps() throws NamingException, InvocationTargetException,\\n            IllegalAccessException {\\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\\n        PublicComponent instance = new PublicComponent();\\n\\n        instanceManager.newInstance(instance);\\n        instanceManager.destroyInstance(instance);\\n\\n        assertThat(instance.message()).isEqualTo(\\\"created\\\");\\n    }\\n\\n    public static class PublicComponent {\\n\\n        public PublicComponent() {\\n        }\\n\\n        String message() {\\n            return \\\"created\\\";\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 1065, \"output\": 1236, \"cacheRead\": 16384, \"cacheWrite\": 0, \"totalTokens\": 18685, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1781873280771, \"responseId\": \"resp_0a2c21690d238812016a353a8134f0819598dc5db9bca40fc5\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_og4ITfoqP08GSm7pZgJ7cBWV|fc_0a2c21690d238812