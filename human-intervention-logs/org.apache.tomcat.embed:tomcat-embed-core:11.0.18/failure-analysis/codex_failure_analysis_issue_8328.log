eatedComponent.class);\\n        assertThat(((ProvidedLoaderCreatedComponent) instance).getMessage()).isEqualTo(\\\"provided-loader-created\\\");\\n    }\\n\\n    public static final class ClassCreatedComponent {\\n        public ClassCreatedComponent() {\\n        }\\n\\n        public String getMessage() {\\n            return \\\"class-created\\\";\\n        }\\n    }\\n\\n    public static final class ContextLoaderCreatedComponent {\\n        public ContextLoaderCreatedComponent() {\\n        }\\n\\n        public String getMessage() {\\n            return \\\"context-loader-created\\\";\\n        }\\n    }\\n\\n    public static final class ProvidedLoaderCreatedComponent {\\n        public ProvidedLoaderCreatedComponent() {\\n        }\\n\\n        public String getMessage() {\\n            return \\\"provided-loader-created\\\";\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 889, \"output\": 1104, \"cacheRead\": 17920, \"cacheWrite\": 0, \"totalTokens\": 19913, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1781794941337, \"responseId\": \"resp_0725c9048ec1beb3016a34087e27648195aa9b16a803ed15ff\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_Gq2NyFM8nIZq6oi7xMJzNM3M|fc_0725c9048ec1beb3016a340887142c8195be8020bdf98f0349\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 2765 bytes to tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/SimpleInstanceManagerTest.java\"}], \"isError\": false, \"timestamp\": 1781794956714}]}\n[recv] {\"type\": \"turn_start\"}\n[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"assistant\", \"content\": [], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"c