teWar(appBase.resolve(\\\\\\\"warapp.war\\\\\\\"));\\\\n        createWebappDirectory(appBase.resolve(\\\\\\\"directoryapp\\\\\\\"));\\\\n\\\\n        HostConfig hostConfig = new HostConfig();\\\\n        Tomcat tomcat = new Tomcat();\\\\n        tomcat.setBaseDir(temporaryDirectory.resolve(\\\\\\\"base\\\\\\\").toString());\\\\n        StandardHost host = (StandardHost) tomcat.getHost();\\\\n        host.setAppBase(appBase.toString());\\\\n        host.setXmlBase(configBase.toString());\\\\n        host.setDeployOnStartup(true);\\\\n        host.setAutoDeploy(false);\\\\n        host.setDeployXML(true);\\\\n        host.setCopyXML(false);\\\\n        host.setUnpackWARs(false);\\\\n        host.addLifecycleListener(hostConfig);\\\\n\\\\n        try {\\\\n            tomcat.start();\\\\n\\\\n            assertDeployed(hostConfig, host, \\\\\\\"/descriptor\\\\\\\");\\\\n            assertDeployed(hostConfig, host, \\\\\\\"/warapp\\\\\\\");\\\\n            assertDeployed(hostConfig, host, \\\\\\\"/directoryapp\\\\\\\");\\\\n        } finally {\\\\n            stopAndDestroy(tomcat);\\\\n        }\\\\n    }\\\\n\\\\n    private static Path createWebappDirectory(Path webappDirectory) throws IOException {\\\\n        Files.createDirectories(webappDirectory.resolve(\\\\\\\"WEB-INF\\\\\\\"));\\\\n        Files.writeString(webappDirectory.resolve(\\\\\\\"index.html\\\\\\\"), \\\\\\\"ready\\\\\\\");\\\\n        return webappDirectory;\\\\n    }\\\\n\\\\n    private static void createDescriptor(Path descriptor, Path docBase) throws IOException {\\\\n        Files.writeString(descriptor, \\\\\\\"\\\\\\\"\\\\\\\"\\\\n                <?xml version=\\\\\\\"1.0\\\\\\\" encoding=\\\\\\\"UTF-8\\\\\\\"?>\\\\n                <Context docBase=\\\\\\\"%s\\\\\\\" />\\\\n                \\\\\\\"\\\\\\\"\\\\\\\".formatted(docBase));\\\\n    }\\\\n\\\\n    private static void createWar(Path war) throws IOException {\\\\n        try (OutputStream output = Files.newOutputStream(war); JarOutput