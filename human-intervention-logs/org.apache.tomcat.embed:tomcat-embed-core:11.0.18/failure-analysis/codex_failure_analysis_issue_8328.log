xtDescriptorOnStartup() throws Exception {\\n        Path appBase = Files.createDirectories(temporaryDirectory.resolve(\\\"descriptor-app-base\\\"));\\n        Path configBase = Files.createDirectories(temporaryDirectory.resolve(\\\"descriptor-config-base\\\"));\\n        Path webapp = createExpandedWebapp(temporaryDirectory.resolve(\\\"descriptor-doc-base\\\"));\\n        Files.writeString(configBase.resolve(\\\"descriptor-app.xml\\\"),\\n                \\\"\\\"\\\"\\n                <Context docBase=\\\"%s\\\" />\\n                \\\"\\\"\\\".formatted(webapp), StandardCharsets.UTF_8);\\n\\n        Tomcat tomcat = createTomcat(appBase, configBase);\\n        try {\\n            tomcat.start();\\n\\n            assertDeployed(tomcat.getHost(), \\\"/descriptor-app\\\");\\n        } finally {\\n            stopAndDestroy(tomcat);\\n        }\\n    }\\n\\n    @Test\\n    void deploysWarOnStartup() throws Exception {\\n        Path appBase = Files.createDirectories(temporaryDirectory.resolve(\\\"war-app-base\\\"));\\n        Path configBase = Files.createDirectories(temporaryDirectory.resolve(\\\"war-config-base\\\"));\\n        createWar(appBase.resolve(\\\"war-app.war\\\"));\\n\\n        Tomcat tomcat = createTomcat(appBase, configBase);\\n        try {\\n            tomcat.start();\\n\\n            assertDeployed(tomcat.getHost(), \\\"/war-app\\\");\\n        } finally {\\n            stopAndDestroy(tomcat);\\n        }\\n    }\\n\\n    @Test\\n    void deploysExpandedDirectoryOnStartup() throws Exception {\\n        Path appBase = Files.createDirectories(temporaryDirectory.resolve(\\\"directory-app-base\\\"));\\n        Path configBase = Files.createDirectories(temporaryDirectory.resolve(\\\"directory-config-base\\\"));\\n        createExpandedWebapp(appBase.resolve(\\\"directory-app\\\"));\\n\\n        Tomcat tomcat = createTomcat(appBase, configBase);\\n        try {\\n            tomcat.start();\\n\\n            assertDeployed(tomcat.getHost(), \\\"/directory-app\\\");\\n        } finally {\\n            stopAndDestroy(tomcat);\\n        }\\n    }\\n\\n    private Tomcat createTomcat(Path appBase, Path configBase) {\\n        Path baseDirectory = temporaryDirectory.resolve(\\\"tomcat-base-\\\" + appBase.getFileName());\\n        Tomcat tomcat = new Tomcat();\\n        tomcat.setBaseDir(baseDirectory.toString());\\n        Host host = tomcat.getHost();\\n        host.setAppBase(appBase.toString());\\n        host.setXmlBase(configBase.toString());\\n        host.setDeployOnStartup(true);\\n        host.setAutoDeploy(false);\\n        ((StandardHost) host).setUnpackWARs(false);\\n        host.addLifecycleListener(new HostConfig());\\n        return tomcat;\\n    }\\n\\n    private static Path createExpandedWebapp(Path directory) throws IOException {\\n        Files.createDirectories(directory.resolve(\\\"WEB-INF\\\"));\\n        Files.writeString(directory.resolve(\\\"index.html\\\"), \\\"host config deployment\\\", StandardCharsets.UTF_8);\\n        return directory;\\n    }\\n\\n    private static void createWar(Path war) throws IOException {\\n        try (OutputStream outputStream = Files.newOutputStream(war);\\n                JarOutputStream jar = new JarOutputStream(outputStream)) {\\n            jar.putNextEntry(new JarEntry(\\\"index.html\\\"));\\n            jar.write(\\\"host config deployment\\\".getBytes(StandardCharsets.UTF_8));\\n            jar.closeEntry();\\n            jar.putNextEntry(new JarEntry(\\\"WEB-INF/\\\"));\\n            jar.closeEntry();\\n        }\\n    }\\n\\n    private static void assertDeployed(Host host, String contextName) {\\n        Container child = host.findChild(contextName);\\n        assertThat(child).isNotNull();\\n        assertThat(child.getName()).isEqualTo(contextName);\\n    }\\n\\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\\n        try {\\n            if (tomcat.getServer().getState().isAvailable()) {\\n                tomcat.stop(