[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/UserConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collections;\nimport java.util.Enumeration;\n\nimport org.apache.catalina.Context;\nimport org.apache.catalina.Host;\nimport org.apache.catalina.startup.UserConfig;\nimport org.apache.catalina.startup.UserDatabase;\nimport org.apache.catalina.startup.Tomcat;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UserConfigTest {\n\n    private static final String USER_NAME = \"alice\";\n    private static final String USER_HOME_PROPERTY = UserConfigTest.class.getName() + \".userHome\";\n\n    @TempDir\n    Path catalinaBase;\n\n    @Test\n    void deploysUserWebApplicationFromConfiguredUserDatabase() throws Exception {\n        Path userHome = catalinaBase.resolve(\"home\").resolve(USER_NAME);\n        Path userWebApplication = userHome.resolve(\"public_html\");\n        Files.createDirectories(userWebApplication.resolve(\"WEB-INF\"));\n        Files.createDirectories(catalinaBase.resolve(\"webapps\"));\n        System.setProperty(USER_HOME_PROPERTY, userHome.toString());\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(catalinaBase.toString());\n        Host host = tomcat.getHost();\n        UserConfig userConfig = new UserConfig();\n        userConfig.setUserClass(InMemoryUserDatabase.class.getName());\n        host.addLifecycleListener(userConfig);\n\n        boolean started = false;\n        try {\n            tomcat.start();\n            started = true;\n\n            Context context = (Context) host.findChild(