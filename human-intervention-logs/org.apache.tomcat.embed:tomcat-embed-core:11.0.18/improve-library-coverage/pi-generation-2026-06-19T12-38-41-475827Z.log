  package tomcat;
  
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  
  import org.apache.catalina.Host;
  import org.apache.catalina.core.StandardHost;
  import org.apache.catalina.startup.HostConfig;
  import org.apache.catalina.startup.Tomcat;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class HostConfigTest {
  
      @TempDir
      Path catalinaBase;
  
      @Test
      void deploysDescriptorWarAndDirectoryFromHostAppBase() throws Exception {
          Path appBase = catalinaBase.resolve("webapps");
          Path configBase = catalinaBase.resolve("conf").resolve("Tomcat").resolve("localhost");
          Files.createDirectories(appBase);
          Files.createDirectories(configBase);
          createDescriptorDeployment(configBase, catalinaBase.resolve("descriptorDocBase"));
          createWarDeployment(appBase.resolve("archive.war"));
          createDirectoryDeployment(appBase.resolve("expanded"));
  
          Tomcat tomcat = new Tomcat();
          tomcat.setBaseDir(catalinaBase.toString());
          Host host = tomcat.getHost();
          StandardHost standardHost = (StandardHost) host;
          standardHost.setAppBase(appBase.toString());
          standardHost.setXmlBase(configBase.toString());
          standardHost.setAutoDeploy(false);
          standardHost.setDeployOnStartup(true);
          standardHost.setUnpackWARs(false);
          HostConfig hostConfig = new HostConfig();
          standardHost.addLifecycleListener(hostConfig);
  
          boolean started = false;
          try {
              tomcat.start();
              started = true;
  
              assertThat(hostConfig.isDeployed("/descriptor")).isTrue();
              assertThat(hostConfig.isDeployed("/archive")).isTrue();
              assertThat(hostConfig.isDeployed("/expanded")).isTrue();
              assertThat(host.findChild("/descriptor")).isNotNull();
              assertThat(host.findChild("/archive")).isNotNull();
              assertThat(host.findChild("/expanded")).isNotNull();
          } finally {
              if (started) {
                  tomcat.stop();
              }
              tomcat.destroy();
          }
      }
  
      private void createDescriptorDeployment(Path configBase, Path docBase) throws IOException {
          Files.createDirectories(docBase.resolve("WEB-INF"));
          Files.writeString(configBase.resolve("descriptor.xml"), """
                  <Context docBase=\"%s\" />
                  """.formatted(docBase));
      }
  
      private void createDirectoryDeployment(Path docBase) throws IOException {
          Files.createDirectories(docBase.resolve("WEB-INF"));
      }
  
      private void createWarDeployment(Path war) throws IOException {
          try (JarOutputStream jar = new JarOutputStream(Files.newOutputStream(war))) {
              jar.putNextEntry(new JarEntry("WEB-INF/"));
              jar.closeEntry();
          }
      }
  }
