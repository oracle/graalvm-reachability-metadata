  package tomcat;
  
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Arrays;
  
  import org.apache.catalina.Container;
  import org.apache.catalina.Context;
  import org.apache.catalina.Host;
  import org.apache.catalina.LifecycleException;
  import org.apache.catalina.LifecycleListener;
  import org.apache.catalina.startup.Tomcat;
  import org.apache.catalina.startup.UserConfig;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UserConfigTest {
  
      @TempDir
      Path baseDir;
  
      @Test
      void deploysUserDirectoryThroughConfiguredUserDatabase() throws Exception {
          Path homeBase = Files.createDirectories(baseDir.resolve("users"));
          Path webapp = Files.createDirectories(homeBase.resolve("alice").resolve("public_html"));
          createWebXml(webapp);
  
          Tomcat tomcat = new Tomcat();
          tomcat.setBaseDir(baseDir.toString());
          Host host = tomcat.getHost();
          host.setAppBase(Files.createDirectories(baseDir.resolve("webapps")).toString());
          host.setAutoDeploy(false);
          host.setDeployOnStartup(false);
          host.addLifecycleListener(userConfig(homeBase));
  
          try {
              tomcat.start();
  
              Container child = host.findChild("/~alice");
              assertThat(child).isInstanceOf(Context.class);
              Context context = (Context) child;
              assertThat(context.getPath()).isEqualTo("/~alice");
              assertThat(context.getDocBase()).isEqualTo(webapp.toString());
              assertThat(context.getState().isAvailable()).isTrue();
              assertThat(Arrays.stream(context.findLifecycleListeners()).map(LifecycleListener::getClass).map(Class::getName))
                      .contains("org.apache.catalina.startup.ContextConfig");
          } finally {
              stopAndDestroy(tomcat);
          }
      }
  
      private static UserConfig userConfig(Path homeBase) {
          UserConfig userConfig = new UserConfig();
          userConfig.setHomeBase(homeBase.toString());
          userConfig.setUserClass("org.apache.catalina.startup.HomesUserDatabase");
          return userConfig;
      }
  
      private static void createWebXml(Path webapp) throws IOException {
          Path webInf = Files.createDirectories(webapp.resolve("WEB-INF"));
          Files.writeString(webInf.resolve("web.xml"), """
                  <?xml version="1.0" encoding="UTF-8"?>
                  <web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="6.1">
                  </web-app>
                  """);
      }
  
      private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {
          try {
              tomcat.stop();
          } finally {
              tomcat.destroy();
          }
      }
  }
