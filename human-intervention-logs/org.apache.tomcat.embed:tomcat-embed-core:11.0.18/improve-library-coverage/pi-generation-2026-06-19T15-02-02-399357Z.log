      private void reconfigureStartStopExecutor(int threads) {
          if (threads == 1) {
              // Use a fake executor
              if (!(startStopExecutor instanceof InlineExecutorService)) {
                  startStopExecutor = new InlineExecutorService();
              }
          } else {
              // Delegate utility execution to the Service
