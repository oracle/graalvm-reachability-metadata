  package tomcat;
  
  import java.io.IOException;
  import java.io.OutputStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  
  import org.apache.catalina.Container;
  import org.apache.catalina.Host;
  import org.apache.catalina.LifecycleException;
  import org.apache.catalina.startup.HostConfig;
  import org.apache.catalina.startup.Tomcat;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class HostConfigTest {
  
      @TempDir
      Path baseDir;
  
      @Test
      void deploysDescriptorWarAndExplodedDirectoryFromHostApplicationBases() throws Exception {
          Path appBase = Files.createDirectories(baseDir.resolve("webapps"));
          Path configBase = Files.createDirectories(baseDir.resolve("conf").resolve("Tomcat").resolve("localhost"));
          Files.createDirectories(baseDir.resolve("logs"));
          Files.createDirectories(baseDir.resolve("temp"));
          Files.createDirectories(baseDir.resolve("work"));
          createDescriptor(configBase.resolve("descriptor-app.xml"));
          createExplodedWebapp(appBase.resolve("descriptor-app"));
          createExplodedWebapp(appBase.resolve("directory-app"));
          createWar(appBase.resolve("war-app.war"));
  
          Tomcat tomcat = new Tomcat();
          tomcat.setBaseDir(baseDir.toString());
          Host host = tomcat.getHost();
          host.setAppBase(appBase.toString());
          host.setAutoDeploy(false);
          host.setDeployOnStartup(true);
          host.addLifecycleListener(new HostConfig());
  
          try {
              tomcat.start();
  
              assertDeployed(host, "/descriptor-app");
              assertDeployed(host, "/directory-app");
              assertDeployed(host, "/war-app");
          } finally {
              stopAndDestroy(tomcat);
          }
      }
  
      private static void createDescriptor(Path descriptor) throws IOException {
          Files.writeString(descriptor, """
                  <?xml version="1.0" encoding="UTF-8"?>
                  <Context />
                  """);
      }
  
      private static void createExplodedWebapp(Path directory) throws IOException {
          Path webInf = Files.createDirectories(directory.resolve("WEB-INF"));
          Files.writeString(webInf.resolve("web.xml"), webXml());
      }
  
      private static void createWar(Path war) throws IOException {
          try (OutputStream output = Files.newOutputStream(war); JarOutputStream jar = new JarOutputStream(output)) {
              jar.putNextEntry(new JarEntry("WEB-INF/"));
              jar.closeEntry();
              jar.putNextEntry(new JarEntry("WEB-INF/web.xml"));
              jar.write(webXml().getBytes(StandardCharsets.UTF_8));
              jar.closeEntry();
          }
      }
  
      private static String webXml() {
          return """
                  <?xml version="1.0" encoding="UTF-8"?>
                  <web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="6.1">
                  </web-app>
                  """;
      }
  
      private static void assertDeployed(Host host, String contextName) {
          Container child = host.findChild(contextName);
          assertThat(child).as(contextName).isNotNull();
          assertThat(child.getName()).isEqualTo(contextName);
          assertThat(child.getState().isAvailable()).isTrue();
      }
  
      private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {
          try {
              tomcat.stop();
          } finally {
              tomcat.destroy();
          }
      }
  }
[tool-exec] end id=call_JkgYbVm5rODi0hFxHLGnu2wY|fc_021a1d4a0d1a4a72016a355959c82c819792b71f06d44f2961 name=read status=success
  /*
