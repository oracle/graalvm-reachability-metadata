[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/SimpleInstanceManagerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.tomcat.SimpleInstanceManager;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SimpleInstanceManagerTest {\n\n    @Test\n    void createsInstanceFromClass() throws Exception {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n\n        Object instance = instanceManager.newInstance(SimpleInstanceManager.class);\n\n        assertThat(instance).isInstanceOf(SimpleInstanceManager.class);\n        assertThat(instance).isNotSameAs(instanceManager);\n    }\n\n    @Test\n    void createsInstanceFromContextClassLoader() throws Exception {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\n        ClassLoader testClassLoader = SimpleInstanceManagerTest.class.getClassLoader();\n        currentThread.setContextClassLoader(testClassLoader);\n\n        try {\n            Object instance = instanceManager.newInstance(SimpleInstanceManager.class.getName());\n\n            assertThat(instance).isInstanceOf(SimpleInstanceManager.class);\n        } finally {\n            currentThread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void createsInstanceFromProvidedClassLoader() throws Exception {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n        ClassLoader classLoader = SimpleInstanceManagerTest.class.getClassLoader();\n\n        Object instance = instanceManager.newInstance(SimpleInstanceManager.class.getName(), classLoader);\n\n        assertThat(instance).isInstanceOf(SimpleInstanceManager.class);\n    }\n}\n"}
