impleInstanceManagerTest.class.getClassLoader();\n\n        Object instance = instanceManager.newInstance(SimpleInstanceManager.class.getName(), classLoader);\n\n        assertThat(instance).isInstanceOf(SimpleInstanceManager.class);\n    }\n}\n"}
