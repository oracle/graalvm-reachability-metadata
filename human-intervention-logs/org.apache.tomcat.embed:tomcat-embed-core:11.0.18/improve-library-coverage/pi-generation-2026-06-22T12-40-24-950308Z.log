[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/RealmBaseTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\nimport java.security.Principal;\nimport java.security.cert.X509Certificate;\n\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.realm.MessageDigestCredentialHandler;\nimport org.apache.catalina.realm.RealmBase;\nimport org.apache.catalina.realm.X509UsernameRetriever;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RealmBaseTest {\n\n    private static final Object SYSTEM_OUT_LOCK = new Object();\n\n    @Test\n    void commandLineCredentialMutationUsesDefaultDigestCredentialHandler() throws Exception {\n        String output = runRealmBaseMain(\"secret\");\n\n        assertThat(output).startsWith(\"secret:\");\n        assertThat(output).hasLineCount(1);\n        assertThat(output).doesNotEndWith(\"secret:\" + System.lineSeparator());\n    }\n\n    @Test\n    void commandLineCredentialMutationInstantiatesConfiguredCredentialHandler() throws Exception {\n        String output = runRealmBaseMain(\"-h\", MessageDigestCredentialHandler.class.getName(), \"-a\", \"SHA-256\",\n                \"secret\");\n\n        assertThat(output).startsWith(\"secret:\");\n        assertThat(output).hasLineCount(1);\n        assertThat(output).doesNotEndWith(\"secret:\" + System.lineSeparator());\n    }\n\n    @Test\n    void realmInitializationInstantiatesConfiguredX509UsernameRetriever() throws Exception {\n        TestRealm realm = new TestRealm();\n        realm.setValidate(false);\n        realm.setX509UsernameRetrieverClassName(CertificateUsernameRetriever.class.getName());\n\n        try {\n            realm.init();\n\n            Principal principal = realm.authenticate(new X509Certificate[] { null });\n\n            assertThat(realm.getX509UsernameRetrieverClassName())\n                    .isEqualTo(CertificateUsernameRetriever.class.getName());\n            assertThat(principal).isNotNull();\n            assertThat(principal.getName()).isEqualTo(\"certificate-user\");\n        } finally {\n            realm.destroy();\n        }\n    }\n\n    private static String runRealmBaseMain(String... args) throws IOException {\n        synchronized (SYSTEM_OUT_LOCK) {\n            PrintStream originalOut = System.out;\n            ByteArrayOutputStream output = new ByteArrayOutputStream();\n            try (PrintStream printStream = new PrintStream(output, true, StandardCharsets.UTF_8)) {\n                System.setOut(printStream);\n                RealmBase.main(args);\n            } finally {\n                System.setOut(originalOut);\n            }\n            return output.toString(StandardCharsets.UTF_8);\n        }\n    }\n\n    public static final class CertificateUsernameRetriever implements X509UsernameRetriever {\n\n        public CertificateUsernameRetriever() {\n        }\n\n        @Override\n        public String getUsername(X509Certificate cert) {\n            return \"certificate-user\";\n        }\n    }\n\n    public static final class TestRealm extends RealmBase {\n\n        @Override\n        protected String getPassword(String username) {\n            return null;\n        }\n\n        @Override\n        protected Principal getPrincipal(String username) {\n            return new TestPrincipal(username);\n        }\n\n        @Override\n        public String getObjectNameKeyProperties() {\n            return \"type=Realm,name=RealmBaseTest\";\n        }\n\n        @Override\n        public String getDomainInternal() {\n            retur