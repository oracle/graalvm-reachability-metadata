                          ExceptionUtils.handleThrowable(t);
                          removeServiced(cn.getName());
                          throw t;
                      }
                  }
              }
          }
  
          for (Future<?> result : results) {
              try {
                  result.get();
              } catch (Exception e) {
                  log.error(sm.getString("hostConfig.deployWar.threaded.error"), e);
              }
          }
