.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\n\nimport org.apache.catalina.Container;\nimport org.apache.catalina.Host;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.core.StandardHost;\nimport org.apache.catalina.startup.HostConfig;\nimport org.apache.catalina.startup.Tomcat;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class HostConfigTest {\n\n    @TempDir\n    Path catalinaBase;\n\n    @Test\n    void autoDeploysDescriptorsWarsAndDirectoriesOnHostStartup() throws Exception {\n        Path appBase = catalinaBase.resolve(\"webapps\");\n        Path configBase = catalinaBase.resolve(\"conf\").resolve(\"Tomcat\").resolve(\"localhost\");\n        Files.createDirectories(appBase);\n        Files.createDirectories(configBase);\n\n        Path descriptorDocBase = Files.createDirectories(catalinaBase.resolve(\"descriptor-docbase\"));\n        writeContextDescriptor(configBase.resolve(\"descriptor.xml\"), descriptorDocBase);\n        writeWar(appBase.resolve(\"archive.war\"));\n        writeDirectoryWebapp(appBase.resolve(\"directory\"));\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(catalinaBase.toString());\n        Host host = tomcat.getHost();\n        host.setAppBase(appBase.toString());\n        configureAutodeployingHost((StandardHost) host);\n\n        try {\n            tomcat.start();\n\n            assertDeployed(host, \"/descriptor\");\n            assertDeployed(host, \"/archive\");\n            assertDeployed(host, \"/directory\");\n        } finally {\n            tomcat.stop();\n            tomcat.destroy();\n        }\n    }\n\n    private static void configureAutodeployingHost(StandardHost host) {\n        host.addLifecycleListener(new HostConfig());\n        host.setDeployOnStartup(true);\n        host.setAutoDeploy(false);\n        host.setUnpackWARs(false);\n    }\n\n    private static void writeContextDescriptor(Path descriptor, Path docBase) throws IOException {\n        Files.writeString(descriptor, \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <Context docBase=\"%s\" />\n                \"\"\".formatted(docBase));\n    }\n\n    private static void writeWar(Path war) throws IOException {\n        try (OutputStream outputStream = Files.newOutputStream(war);\n                JarOutputStream jar = new JarOutputStream(outputStream)) {\n            jar.putNextEntry(new JarEntry(\"index.html\"));\n            jar.write(\"archive webapp\".getBytes());\n            jar.closeEntry();\n        }\n    }\n\n    private static void writeDirectoryWebapp(Path directory) throws IOException {\n        Files.createDirectories(directory);\n        Files.writeString(directory.resolve(\"index.html\"), \"directory webapp\");\n    }\n\n    private static void assertDeployed(Host host, String name) {\n        Container child = host.findChild(name);\n        assertThat(child).isNotNull();\n        assertThat(child.getState()).isNotEqualTo(LifecycleState.FAILED);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 731, "output": 1262, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 43977, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781868140780, "responseId": "resp_0096c08b4fdabe82016a35266e5d50819789dd9dec10f5c558"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_e15cbzoZmfbvI38p8thgxF3P|fc_0096c08b4fdabe82016a3526780ff481979b28c31f09d3229e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3340 bytes to tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/