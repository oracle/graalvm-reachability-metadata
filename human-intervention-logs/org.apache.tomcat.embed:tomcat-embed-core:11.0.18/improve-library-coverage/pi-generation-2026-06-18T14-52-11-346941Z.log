[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/UserConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.apache.catalina.Container;\nimport org.apache.catalina.Context;\nimport org.apache.catalina.Host;\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.startup.HomesUserDatabase;\nimport org.apache.catalina.startup.UserConfig;\nimport org.apache.catalina.startup.Tomcat;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UserConfigTest {\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void deploysUserWebApplicationOnHostStartup() throws Exception {\n        Path homeBase = Files.createDirectories(temporaryDirectory.resolve(\"home-base\"));\n        Path userWebapp = createExpandedWebapp(homeBase.resolve(\"alice\").resolve(\"public_html\"));\n\n        Tomcat tomcat = createTomcat(homeBase);\n        try {\n            tomcat.start();\n\n            Container child = tomcat.getHost().findChild(\"/~alice\");\n            assertThat(child).isInstanceOf(Context.class);\n            Context context = (Context) child;\n            assertThat(context.getPath()).isEqualTo(\"/~alice\");\n            assertThat(context.getDocBase()).isEqualTo(userWebapp.toString());\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private Tomcat createTomcat(Path homeBase) {\n        Path baseDirectory = temporaryDirectory.resolve(\"tomcat-base\");\n        Path appBase = temporaryDirectory.resolve(\"app-base\");\n        Path configBase = temporaryDirectory.resolve(\"config-base\");\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(baseDirectory.toString());\n        Host host = tomcat.getHost();\n        host.setAppBase(appBase.toString());\n        host.setXmlBase(configBase.toString());\n        host.setDeployOnStartup(false);\n        host.setAutoDeploy(false);\n\n        UserConfig userConfig = new UserConfig();\n        userConfig.setUserClass(HomesUserDatabase.class.getName());\n        userConfig.setHomeBase(homeBase.toString());\n        host.addLifecycleListener(userConfig);\n        return tomcat;\n    }\n\n    private static Path createExpandedWebapp(Path directory) throws IOException {\n        Files.createDirectories(directory.resolve(\"WEB-INF\"));\n        Files.writeString(directory.resolve(\"index.html\"), \"user config deployment\", StandardCharsets.UTF_8);\n        return directory;\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        try {\n            if (tomcat.getServer().getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (tomcat.getServer().getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n}\n"}
