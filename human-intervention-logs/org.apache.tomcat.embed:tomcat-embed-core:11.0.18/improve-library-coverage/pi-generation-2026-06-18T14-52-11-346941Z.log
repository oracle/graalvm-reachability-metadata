   }\n\n    @Test\n    void deploysExpandedDirectoryOnStartup() throws Exception {\n        Path appBase = Files.createDirectories(temporaryDirectory.resolve(\"directory-app-base\"));\n        Path configBase = Files.createDirectories(temporaryDirectory.resolve(\"directory-config-base\"));\n        createExpandedWebapp(appBase.resolve(\"directory-app\"));\n\n        Tomcat tomcat = createTomcat(appBase, configBase);\n        try {\n            tomcat.start();\n\n            assertDeployed(tomcat.getHost(), \"/directory-app\");\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private Tomcat createTomcat(Path appBase, Path configBase) {\n        Path baseDirectory = temporaryDirectory.resolve(\"tomcat-base-\" + appBase.getFileName());\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(baseDirectory.toString());\n        Host host = tomcat.getHost();\n        host.setAppBase(appBase.toString());\n        host.setXmlBase(configBase.toString());\n        host.setDeployOnStartup(true);\n        host.setAutoDeploy(false);\n        ((StandardHost) host).setUnpackWARs(false);\n        host.addLifecycleListener(new HostConfig());\n        return tomcat;\n    }\n\n    private static Path createExpandedWebapp(Path directory) throws IOException {\n        Files.createDirectories(directory.resolve(\"WEB-INF\"));\n        Files.writeString(directory.resolve(\"index.html\"), \"host config deployment\", StandardCharsets.UTF_8);\n        return directory;\n    }\n\n    private static void createWar(Path war) throws IOException {\n        try (OutputStream outputStream = Files.newOutputStream(war);\n                JarOutputStream jar = new JarOutputStream(outputStream)) {\n            jar.putNextEntry(new JarEntry(\"index.html\"));\n            jar.write(\"host config deployment\".getBytes(StandardCharsets.UTF_8));\n            jar.closeEntry();\n            jar.putNextEntry(new JarEntry(\"WEB-INF/\"));\n            jar.closeEntry();\n        }\n    }\n\n    private static void assertDeployed(Host host, String contextName) {\n        Container child = host.findChild(contextName);\n        assertThat(child).isNotNull();\n        assertThat(child.getName()).isEqualTo(contextName);\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        try {\n            if (tomcat.getServer().getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (tomcat.getServer().getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781794239333}, {"role": "toolResult", "toolCallId": "call_ngqj3KIqApZtTvCDlLq23BSe|fc_0dcb00b818401827016a3405bf124481958543684002240657", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.connector.Connector;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.ValueSource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConnectorProtocolIntrospectionTest {\n\n    @ParameterizedTest\n    @ValueSource(strings = {\"HTTP/1.1\", \"org.apache.coyote.http11.Http11NioProtocol\",\n            \"org.apache.coyote.http11.Http11Nio2Protocol\"})\n    void connectorReadsProtocolHandlerPropertiesThroughPublicApi(String protocol) throws Exception {\n        Connector connector = new Connector(protocol);\n        connector.setPort(0);\n        Object initialBindOnInit = connector.getProperty(\"bindOnInit\");\n        boolean updatedBindOnInit = connector.setProperty(\"bindOnInit\", \"false\");\n        Object changedBindOnInit = connector.getProperty(\"bindOnInit\");\n\n        try {\n            connector.init();\n            connector.start();\n\n            Object protocolName = connector.getProperty(\"name\");\n            Object bindOnInitAfterStart = connector.getProperty(\"bindOnInit\");\n            Object missingProtocolProperty = connector.getProperty(\"missingPropertyForReachabilityMetadata\");\n            Object sslEnabled = connector.getProperty(\"SSLEnabled\");\n\n            assertThat(protocolName).isInstanceOf(String.class);\n            assertThat(protocolName.toString()).isNotBlank();\n            assertThat(initialBindOnInit).isNull();\n            assertThat(updatedBindOnInit).isTrue();\n            assertThat(changedBindOnInit).isEqualTo(\"false\");\n            assertThat(bindOnInitAfterStart).isEqualTo(\"false\");\n            assertThat(missingProtocolProperty).isNull();\n            assertThat(sslEnabled).isEqualTo(Boolean.FALSE);\n        } finally {\n            stopAndDestroy(connector);\n        }\n    }\n\n    private static void stopAndDestroy(Connector connector) throws LifecycleException {\n        try {\n            if (connector.getState().isAvailable()) {\n                connector.stop();\n            }\n        } finally {\n            if (connector.getState() != LifecycleState.DESTROYED) {\n                connector.destroy();\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781794239333}, {"role": "toolResult", "toolCallId": "call_UeK6YepqFkIGDS0buqXg1EC1|fc_0dcb00b818401827016a3405bf124c81959c28487f96befdc5", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n