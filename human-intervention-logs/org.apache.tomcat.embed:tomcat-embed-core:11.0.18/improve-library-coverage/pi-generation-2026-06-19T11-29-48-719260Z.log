[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/StandardContextTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.catalina.ContainerListener;\nimport org.apache.catalina.LifecycleListener;\nimport org.apache.catalina.Wrapper;\nimport org.apache.catalina.core.StandardContext;\nimport org.apache.catalina.core.StandardEngine;\nimport org.apache.catalina.core.StandardWrapper;\nimport org.apache.catalina.security.SecurityListener;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class StandardContextTest {\n\n    @Test\n    void createWrapperInstantiatesConfiguredWrapperAndListeners() {\n        StandardContext context = new StandardContext();\n        context.setWrapperClass(StandardWrapper.class.getName());\n        context.addWrapperLifecycle(SecurityListener.class.getName());\n        context.addWrapperListener(StandardEngine.class.getName());\n\n        Wrapper wrapper = context.createWrapper();\n\n        assertThat(wrapper).isInstanceOf(StandardWrapper.class);\n        assertThat(wrapper.findLifecycleListeners()).extracting(LifecycleListener::getClass)\n                .contains(SecurityListener.class);\n        assertThat(wrapper.findContainerListeners()).extracting(ContainerListener::getClass)\n                .contains(StandardEngine.class);\n    }\n}\n"}
