t.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.apache.catalina.Context;\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.Server;\nimport org.apache.catalina.core.StandardHost;\nimport org.apache.catalina.startup.HomesUserDatabase;\nimport org.apache.catalina.startup.Tomcat;\nimport org.apache.catalina.startup.UserConfig;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UserConfigTest {\n\n    @TempDir\n    Path catalinaBase;\n\n    @TempDir\n    Path homeBase;\n\n    @Test\n    void deploysUserWebApplicationDuringHostStartup() throws Exception {\n        createUserWebApplication(\"alice\");\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(catalinaBase.toString());\n        StandardHost host = (StandardHost) tomcat.getHost();\n        host.setAppBase(Files.createDirectories(catalinaBase.resolve(\"webapps\")).toString());\n        host.setAutoDeploy(false);\n        host.setDeployOnStartup(false);\n\n        UserConfig userConfig = new UserConfig();\n        userConfig.setHomeBase(homeBase.toString());\n        userConfig.setUserClass(HomesUserDatabase.class.getName());\n        host.addLifecycleListener(userConfig);\n\n        try {\n            tomcat.start();\n\n            Context context = (Context) host.findChild(\"/~alice\");\n            assertThat(context).isNotNull();\n            assertThat(context.getDocBase()).endsWith(\"public_html\");\n            assertThat(context.getState().isAvailable()).isTrue();\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private void createUserWebApplication(String user) throws IOException {\n        Path documentRoot = Files.createDirectories(homeBase.resolve(user).resolve(\"public_html\"));\n        Files.createDirectories(documentRoot.resolve(\"WEB-INF\"));\n        Files.writeString(documentRoot.resolve(\"index.txt\"), \"user web application\\n\");\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        Server server = tomcat.getServer();\n        try {\n            if (server.getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (server.getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 739, "output": 1236, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 24503, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782131411909, "responseId": "resp_04c163693957a9c7016a392ad47754819489ee2652b0e5c735"}}
[tool-exec] start id=call_Y98ieDZHarR6L9HKP8LLijs2|fc_04c163693957a9c7016a392ae03e4c819497825ff6e72543bf name=write args={"path": "tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/UserConfigTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.apache.catalina.Context;\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.Server;\nimport org.apache.catalina.core.StandardHost;\nimport org.apache.catalina.startup.HomesUserDatabase;\nimport org.apache.catalina.startup.Tomcat;\nimport org.apache.catalina.startup.UserConfig;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class UserConfigTest {\n\n    @TempDir\n    Path catalinaBase;\n\n    @TempDir\n    Path homeBase;\n\n    @Test\n    void deploysUserWebApplicationDuringHostStartup() throws Exception {\n        createUserWebApplication(\"alice\");\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(catalinaBase.toString());\n        StandardHost host = (StandardHost) tomcat.getHost();\n        host.setAppBase(Files.createDirectories(catalinaBase.resolve(\"webapps\")).toString());\n        host.setAutoDeploy(false);\n        host.setDeployOnStartup(false);\n\n        UserConfig userConfig = new UserConfig();\n        userConfig.setHomeBase(homeBase.toString());\n        userConfig.setUserClass(HomesUserDatabase.class.getName());\n        host.addLifecycleListener(userConfig);\n\n        try {\n            tomcat.start();\n\n            Context context = (Context) host.findChild(\"/~alice\");\n            assertThat(context).isNotNull();\n            assertThat(context.getDocBase()).endsWith(\"public_html\");\n            assertThat(context.getState().isAvailable()).isTrue();\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private void createUserWebApplication(String user) throws IOException {\n        Path documentRoot = Files.createDirectories(homeBase.resolve(user).resolve(\"public_html\"));\n        Files.createDirectories(documentRoot.resolve(\"WEB-INF\"));\n        Files.writeString(documentRoot.resolve(\"index.txt\"), \"user web application\\n\");\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        Server server = tomcat.getServer();\n        try {\n            if (server.getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (server.getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n}\n"}
