xt).isNotNull();\n            assertThat(context.getDocBase()).endsWith(\"public_html\");\n            assertThat(context.getState().isAvailable()).isTrue();\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private void createUserWebApplication(String user) throws IOException {\n        Path documentRoot = Files.createDirectories(homeBase.resolve(user).resolve(\"public_html\"));\n        Files.createDirectories(documentRoot.resolve(\"WEB-INF\"));\n        Files.writeString(documentRoot.resolve(\"index.txt\"), \"user web application\\n\");\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        Server server = tomcat.getServer();\n        try {\n            if (server.getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (server.getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n}\n"}
