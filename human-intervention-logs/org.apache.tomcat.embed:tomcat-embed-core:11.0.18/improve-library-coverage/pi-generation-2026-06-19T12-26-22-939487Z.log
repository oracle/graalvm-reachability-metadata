[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/HostConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\n\nimport org.apache.catalina.Host;\nimport org.apache.catalina.core.StandardHost;\nimport org.apache.catalina.startup.HostConfig;\nimport org.apache.catalina.startup.Tomcat;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class HostConfigTest {\n\n    @TempDir\n    Path catalinaBase;\n\n    @Test\n    void deploysDescriptorWarAndDirectoryFromHostAppBase() throws Exception {\n        Path appBase = catalinaBase.resolve(\"webapps\");\n        Path configBase = catalinaBase.resolve(\"conf\").resolve(\"Tomcat\").resolve(\"localhost\");\n        Files.createDirectories(appBase);\n        Files.createDirectories(configBase);\n        createDescriptorDeployment(configBase, catalinaBase.resolve(\"descriptorDocBase\"));\n        createWarDeployment(appBase.resolve(\"archive.war\"));\n        createDirectoryDeployment(appBase.resolve(\"expanded\"));\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(catalinaBase.toString());\n        Host host = tomcat.getHost();\n        StandardHost standardHost = (StandardHost) host;\n        standardHost.setAppBase(appBase.toString());\n        standardHost.setXmlBase(configBase.toString());\n        standardHost.setAutoDeploy(false);\n        standardHost.setDeployOnStartup(true);\n        standardHost.setUnpackWARs(false);\n        HostConfig hostConfig = new HostConfig();\n        standardHost.addLifecycl