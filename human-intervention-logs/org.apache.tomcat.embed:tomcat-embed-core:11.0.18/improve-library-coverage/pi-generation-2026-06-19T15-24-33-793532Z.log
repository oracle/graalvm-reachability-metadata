ateManagedBean();\n        return managedBean.createMBean(resource);\n    }\n\n    private static SelfManagedMBean createSelfManagedMBean() {\n        SelfManagedMBean mbean = new SelfManagedMBean();\n        mbean.setManagedBean(createManagedBean());\n        return mbean;\n    }\n\n    private static ManagedBean createManagedBean() {\n        ManagedBean managedBean = new ManagedBean();\n        managedBean.setName(\"reachabilityTestBean\");\n        managedBean.setDescription(\"Bean used by BaseModelMBean reachability tests\");\n        managedBean.addAttribute(createValueAttribute());\n        managedBean.addOperation(createAppendValueOperation());\n        return managedBean;\n    }\n\n    private static AttributeInfo createValueAttribute() {\n        AttributeInfo attribute = new AttributeInfo();\n        attribute.setName(\"value\");\n        attribute.setDescription(\"A mutable string value\");\n        attribute.setType(String.class.getName());\n        attribute.setGetMethod(\"getValue\");\n        attribute.setSetMethod(\"setValue\");\n        return attribute;\n    }\n\n    private static OperationInfo createAppendValueOperation() {\n        ParameterInfo suffix = new ParameterInfo();\n        suffix.setName(\"suffix\");\n        suffix.setDescription(\"Text appended to the current value\");\n        suffix.setType(String.class.getName());\n\n        OperationInfo operation = new OperationInfo();\n        operation.setName(\"appendValue\");\n        operation.setDescription(\"Append text to the current value\");\n        operation.setReturnType(String.class.getName());\n        operation.addParameter(suffix);\n        return operation;\n    }\n\n    public static class ManagedResource {\n        private String value = \"initial\";\n\n        public String getValue() {\n            return value;\n        }\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n\n        public String appendValue(String suffix) {\n            value = value + suffix;\n            return value;\n        }\n    }\n\n    public static class SelfManagedMBean extends BaseModelMBean {\n        private String value = \"initial\";\n\n        public String getValue() {\n            return value;\n        }\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n\n        public String appendValue(String suffix) {\n            value = value + suffix;\n            return value;\n        }\n    }\n}\n"}
