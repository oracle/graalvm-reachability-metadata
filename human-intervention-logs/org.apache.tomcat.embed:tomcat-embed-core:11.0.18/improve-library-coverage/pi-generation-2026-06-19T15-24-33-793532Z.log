"updated-resource-value\");\n    }\n\n    @Test\n    void setAttributeLoadsAttributeClassWithClassForNameAndInvokesSetterOnMBeanItself() throws Exception {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        SelfManagedMBean mbean = createSelfManagedMBean();\n\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n            mbean.setAttribute(new Attribute(\"value\", \"updated-mbean-value\"));\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n\n        assertThat(mbean.getValue()).isEqualTo(\"updated-mbean-value\");\n        assertThat(mbean.getAttribute(\"value\")).isEqualTo(\"updated-mbean-value\");\n    }\n\n    @Test\n    void invokeCallsOperationOnManagedResource() throws Exception {\n        ManagedResource resource = new ManagedResource();\n        resource.setValue(\"resource\");\n        DynamicMBean mbean = createMBean(resource);\n\n        Object result = mbean.invoke(\"appendValue\", new Object[] { \"-operation\" },\n                new String[] { String.class.getName() });\n\n        assertThat(result).isEqualTo(\"resource-operation\");\n        assertThat(resource.getValue()).isEqualTo(\"resource-operation\");\n    }\n\n    @Test\n    void invokeCallsOperationOnMBeanItself() throws Exception {\n        SelfManagedMBean mbean = createSelfManagedMBean();\n        mbean.setValue(\"mbean\");\n\n        Object result = mbean.invoke(\"appendValue\", new Object[] { \"-operation\" },\n                new String[] { String.class.getName() });\n\n        assertThat(result).isEqualTo(\"mbean-operation\");\n        assertThat(mbean.getValue()).isEqualTo(\"mbean-operation\");\n    }\n\n    private static DynamicMBean createMBean(ManagedResource resource) throws Exception {\n        ManagedBean managedBean = createManagedBean();\n        return managedBean.createMBean(resource);\n    }\n\n    private static SelfMana