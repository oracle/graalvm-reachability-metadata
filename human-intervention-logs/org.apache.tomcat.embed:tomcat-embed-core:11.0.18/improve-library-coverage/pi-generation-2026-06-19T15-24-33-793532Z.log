lfManagedMBean extends BaseModelMBean {\n        private String value = \"initial\";\n\n        public String getValue() {\n            return value;\n        }\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n\n        public String appendValue(String suffix) {\n            value = value + suffix;\n            return value;\n        }\n    }\n}\n"}
