\nimport java.io.IOException;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\nimport java.security.Principal;\nimport java.security.cert.X509Certificate;\n\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.realm.CredentialHandler;\nimport org.apache.catalina.realm.MessageDigestCredentialHandler;\nimport org.apache.catalina.realm.RealmBase;\nimport org.apache.catalina.realm.X509UsernameRetriever;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RealmBaseTest {\n\n    @Test\n    void commandLineCredentialMutationUsesDefaultCredentialHandler() throws IOException {\n        String output = runRealmBaseMain(\"tomcat\");\n\n        assertThat(output).containsPattern(\"(?m)^tomcat:.+\");\n    }\n\n    @Test\n    void commandLineCredentialMutationUsesConfiguredCredentialHandlerClass() throws IOException {\n        String output = runRealmBaseMain(\"-h\", MessageDigestCredentialHandler.class.getName(), \"-a\", \"SHA-256\",\n                \"tomcat\");\n\n        assertThat(output).containsPattern(\"(?m)^tomcat:.+\");\n    }\n\n    @Test\n    void realmInitialisationCreatesConfiguredX509UsernameRetriever() throws LifecycleException {\n        TestRealm realm = new TestRealm();\n        realm.setX509UsernameRetrieverClassName(TestX509UsernameRetriever.class.getName());\n\n        try {\n            realm.init();\n\n            Principal principal = realm.principalFromCertificate(null);\n\n            assertThat(principal).isNotNull();\n            assertThat(principal.getName()).isEqualTo(\"certificate-user\");\n        } finally {\n            realm.destroy();\n        }\n    }\n\n    private static String runRealmBaseMain(String... args) throws IOException {\n        PrintStream originalOut = System.out;\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (PrintStream capturedOut = new PrintStream(output, true, StandardCharsets.UTF_8)) {\n            System.setOut(capturedOut);\n            RealmBase.main(args);\n        } finally {\n            System.setOut(originalOut);\n        }\n        return output.toString(StandardCharsets.UTF_8);\n    }\n\n    public static class TestX509UsernameRetriever implements X509UsernameRetriever {\n\n        @Override\n        public String getUsername(X509Certificate cert) {\n            return \"certificate-user\";\n        }\n    }\n\n    public static class TestRealm extends RealmBase {\n\n        @Override\n        protected String getPassword(String username) {\n            return null;\n        }\n\n        @Override\n        protected Principal getPrincipal(String username) {\n            return () -> username;\n        }\n\n        @Override\n        protected CredentialHandler getCredentialHandler() {\n            return super.getCredentialHandler();\n        }\n\n        private Principal principalFromCertificate(X509Certificate certificate) {\n            return getPrincipal(certificate);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1011, "output": 1309, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 22800, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781881592239, "responseId": "resp_0d81e5a6b3a2e6fc016a355af8f09c8197938cb7bef4f30964"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_1V90UVYRJdIWcsk7MVhKYQZQ|fc_0d81e5a6b3a2e6fc016a355b0ea3488197873f97dc4bb24013", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3194 bytes to tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/RealmBaseTest.java"}], "isError": false, "timestamp": 1781881625060}]}
