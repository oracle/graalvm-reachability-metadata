  package tomcat;
  
  import java.util.Arrays;
  
  import org.apache.catalina.ContainerEvent;
  import org.apache.catalina.ContainerListener;
  import org.apache.catalina.LifecycleEvent;
  import org.apache.catalina.LifecycleListener;
  import org.apache.catalina.Wrapper;
  import org.apache.catalina.core.StandardContext;
  import org.apache.catalina.core.StandardWrapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class StandardContextTest {
  
      @Test
      void createsConfiguredWrapperAndListenersFromClassNames() {
          StandardContext context = new StandardContext();
          context.setWrapperClass(RecordingWrapper.class.getName());
          context.addWrapperLifecycle(RecordingLifecycleListener.class.getName());
          context.addWrapperListener(RecordingContainerListener.class.getName());
  
          Wrapper wrapper = context.createWrapper();
  
          assertThat(wrapper).isInstanceOf(RecordingWrapper.class);
          assertThat(Arrays.stream(wrapper.findLifecycleListeners())
                  .anyMatch(RecordingLifecycleListener.class::isInstance)).isTrue();
          assertThat(Arrays.stream(wrapper.findContainerListeners())
                  .anyMatch(RecordingContainerListener.class::isInstance)).isTrue();
      }
  
      public static class RecordingWrapper extends StandardWrapper {
          public RecordingWrapper() {
          }
      }
  
      public static class RecordingLifecycleListener implements LifecycleListener {
          public RecordingLifecycleListener() {
          }
  
          @Override
          public void lifecycleEvent(LifecycleEvent event) {
              event.getType();
          }
      }
  
      public static class RecordingContainerListener implements ContainerListener {
          public RecordingContainerListener() {
          }
  
          @Override
          public void containerEvent(ContainerEvent event) {
              event.getType();
          }
      }
  }
