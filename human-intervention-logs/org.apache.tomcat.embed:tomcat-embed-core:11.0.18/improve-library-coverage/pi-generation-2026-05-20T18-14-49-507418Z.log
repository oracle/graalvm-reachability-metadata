[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/ConnectorProtocolIntrospectionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.connector.Connector;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.ValueSource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConnectorProtocolIntrospectionTest {\n\n    @ParameterizedTest\n    @ValueSource(strings = {\"HTTP/1.1\", \"org.apache.coyote.http11.Http11NioProtocol\",\n            \"org.apache.coyote.http11.Http11Nio2Protocol\"})\n    void connectorReadsProtocolHandlerPropertiesThroughPublicApi(String protocol) throws Exception {\n        Connector connector = new Connector(protocol);\n        connector.setPort(0);\n\n        try {\n            connector.init();\n            connector.start();\n\n            Object protocolName = connector.getProperty(\"name\");\n            Object missingProtocolProperty = connector.getProperty(\"missingPropertyForReachabilityMetadata\");\n            Object sslEnabled = connector.getProperty(\"SSLEnabled\");\n\n            assertThat(protocolName).isInstanceOf(String.class).asString().isNotBlank();\n            assertThat(missingProtocolProperty).isNull();\n            assertThat(sslEnabled).isEqualTo(Boolean.FALSE);\n        } finally {\n            stopAndDestroy(connector);\n        }\n    }\n\n    private static void stopAndDestroy(Connector connector) throws LifecycleException {\n        try {\n            if (connector.getState().isAvailable()) {\n                connector.stop();\n            }\n        } finally {\n            if (connector.getState() != LifecycleState.DESTROYED) {\n                connector.destroy();\n            }\n        }\n    }\n}\n"}
[tool-call] end id=call_IDMcoyghr2AkI2y4mSm9TekD|fc_020c30035824428e016a0df9a7aba08191b36ee68caa7a6191 name=write args={"path": "tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/ConnectorProtocolIntrospectionTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.connector.Connector;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.ValueSource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConnectorProtocolIntrospectionTest {\n\n    @ParameterizedTest\n    @ValueSource(strings = {\"HTTP/1.1\", \"org.apache.coyote.http11.Http11NioProtocol\",\n            \"org.apache.coyote.http11.Http11Nio2Protocol\"})\n    void connectorReadsProtocolHandlerPropertiesThroughPublicApi(String protocol) throws Exception {\n        Connector connector = new Connector(protocol);\n        connector.setPort(0);\n\n        try {\n            connector.init();\n            connector.start();\n\n            Object protocolName = connector.getProperty(\"name\");\n            Object missingProtocolProperty = connector.getProperty(\"missingPropertyForReachabilityMetadata\");\n            Object sslEnabled = connector.getProperty(\"SSLEnabled\");\n\n            assertThat(protocolName).isInstanceOf(String.class).asString().isNotBlank();\n            assertThat(missingProtocolProperty).isNull();\n            assertThat(sslEnabled).isEqualTo(Boolean.FALSE);\n        } finally {\n            stopAndDestroy(connector);\n        }\n    }\n\n    private static void stopAndDestroy(Connector connector) throws LifecycleException {\n        try {\n            if (connector.getState().isAvail