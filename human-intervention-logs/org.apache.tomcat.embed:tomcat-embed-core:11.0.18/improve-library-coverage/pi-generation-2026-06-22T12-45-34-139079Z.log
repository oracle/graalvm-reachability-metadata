[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/SimpleInstanceManagerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.tomcat.SimpleInstanceManager;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SimpleInstanceManagerTest {\n\n    @Test\n    void constructsClassInstancesUsingPublicNoArgumentConstructor() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n\n        Object instance = manager.newInstance(ClassConstructedComponent.class);\n\n        assertThat(instance).isInstanceOf(ClassConstructedComponent.class);\n        assertThat(((ClassConstructedComponent) instance).message()).isEqualTo(\"constructed from class\");\n    }\n\n    @Test\n    void loadsAndConstructsClassNameWithThreadContextClassLoader() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n        RecordingClassLoader classLoader = new RecordingClassLoader(SimpleInstanceManagerTest.class.getClassLoader());\n        Thread thread = Thread.currentThread();\n        ClassLoader originalClassLoader = thread.getContextClassLoader();\n        thread.setContextClassLoader(classLoader);\n        try {\n            Object instance = manager.newInstance(ThreadContextLoadedComponent.class.getName());\n\n            assertThat(instance).isInstanceOf(ThreadContextLoadedComponent.class);\n            assertThat(((ThreadContextLoadedComponent) instance).message()).isEqualTo(\"loaded from context loader\");\n            assertThat(classLoader.loadedClassName()).isEqualTo(ThreadContextLoadedComponent.class.getName());\n        } finally {\n            thread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void loadsAndConstructsClassNameWithExplicitClassLoader() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n        RecordingClassLoader classLoader = new RecordingClassLoader(SimpleInstanceManagerTest.class.getClassLoader());\n\n        Object instance = manager.newInstance(ExplicitlyLoadedComponent.class.getName(), classLoader);\n\n        assertThat(instance).isInstanceOf(ExplicitlyLoadedComponent.class);\n        assertThat(((ExplicitlyLoadedComponent) instance).message()).isEqualTo(\"loaded from explicit loader\");\n        assertThat(classLoader.loadedClassName()).isEqualTo(ExplicitlyLoadedComponent.class.getName());\n    }\n\n    public static final class ClassConstructedComponent {\n        public ClassConstructedComponent() {\n        }\n\n        public String message() {\n            return \"constructed from class\";\n        }\n    }\n\n    public static final class ThreadContextLoadedComponent {\n        public ThreadContextLoadedComponent() {\n        }\n\n        public String message() {\n            return \"loaded from context loader\";\n        }\n    }\n\n    public static final class ExplicitlyLoadedComponent {\n        public ExplicitlyLoadedComponent() {\n        }\n\n        public String message() {\n            return \"loaded from explicit loader\";\n        }\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private String loadedClassName;\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            loadedClassName = name;\n            return super.loadClass(name);\n        }\n\n        private String loadedClassName() {\n            return loadedClassName;\n        }\n    }\n}\n"}
