[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/SimpleInstanceManagerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.tomcat.SimpleInstanceManager;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SimpleInstanceManagerTest {\n\n    @Test\n    void constructsInstanceFromClass() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n\n        Object instance = manager.newInstance(ClassCreatedComponent.class);\n\n        assertThat(instance).isInstanceOf(ClassCreatedComponent.class);\n        assertThat(((ClassCreatedComponent) instance).getMessage()).isEqualTo(\"class-created\");\n    }\n\n    @Test\n    void constructsInstanceFromThreadContextClassLoader() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n        Thread thread = Thread.currentThread();\n        ClassLoader originalClassLoader = thread.getContextClassLoader();\n        thread.setContextClassLoader(SimpleInstanceManagerTest.class.getClassLoader());\n        try {\n            Object instance = manager.newInstance(ContextLoaderCreatedComponent.class.getName());\n\n            assertThat(instance).isInstanceOf(ContextLoaderCreatedComponent.class);\n            assertThat(((ContextLoaderCreatedComponent) instance).getMessage()).isEqualTo(\"context-loader-created\");\n        } finally {\n            thread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void constructsInstanceFromProvidedClassLoader() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n        ClassLoader classLoader = SimpleInstanceManagerTest.class.getClassLoader();\n\n        Object instance = manager.newInstance(ProvidedLoaderCreatedComponent.class.getName(), classLoader);\n\n        assertThat(instance).isInstanceOf(ProvidedLoaderCreatedComponent.class);\n        assertThat(((ProvidedLoaderCreatedComponent) instance).getMessage()).isEqualTo(\"provided-loader-created\");\n    }\n\n    public static final class ClassCreatedComponent {\n        public ClassCreatedComponent() {\n        }\n\n        public String getMessage() {\n            return \"class-created\";\n        }\n    }\n\n    public static final class ContextLoaderCreatedComponent {\n        public ContextLoaderCreatedComponent() {\n        }\n\n        public String getMessage() {\n            return \"context-loader-created\";\n        }\n    }\n\n    public static final class ProvidedLoaderCreatedComponent {\n        public ProvidedLoaderCreatedComponent() {\n        }\n\n        public String getMessage() {\n            return \"provided-loader-created\";\n        }\n    }\n}\n"}
