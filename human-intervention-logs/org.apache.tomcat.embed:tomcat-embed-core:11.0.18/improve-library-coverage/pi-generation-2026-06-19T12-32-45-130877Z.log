[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/StandardContextTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.catalina.ContainerEvent;\nimport org.apache.catalina.ContainerListener;\nimport org.apache.catalina.LifecycleEvent;\nimport org.apache.catalina.LifecycleListener;\nimport org.apache.catalina.Wrapper;\nimport org.apache.catalina.core.StandardContext;\nimport org.apache.catalina.core.StandardWrapper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class StandardContextTest {\n\n    @Test\n    void createsConfiguredWrapperAndListeners() {\n        StandardContext context = new StandardContext();\n        context.setWrapperClass(StandardWrapper.class.getName());\n        context.addWrapperLifecycle(RecordingLifecycleListener.class.getName());\n        context.addWrapperListener(RecordingContainerListener.class.getName());\n\n        Wrapper wrapper = context.createWrapper();\n\n        assertThat(wrapper).isExactlyInstanceOf(StandardWrapper.class);\n        assertThat(wrapper.findLifecycleListeners()).hasAtLeastOneElementOfType(RecordingLifecycleListener.class);\n        assertThat(wrapper.findContainerListeners()).hasAtLeastOneElementOfType(RecordingContainerListener.class);\n    }\n\n    public static class RecordingLifecycleListener implements LifecycleListener {\n\n        public RecordingLifecycleListener() {\n        }\n\n        @Override\n        public void lifecycleEvent(LifecycleEvent event) {\n        }\n    }\n\n    public static class RecordingContainerListener implements ContainerListener {\n\n        public RecordingContainerListener() {\n        }\n\n        @Override\n        public void containerEvent(ContainerEvent event) {\n        }\n    }\n}\n"}
