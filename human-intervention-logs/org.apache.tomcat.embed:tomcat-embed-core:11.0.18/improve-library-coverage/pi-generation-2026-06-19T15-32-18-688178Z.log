      @Override
      public void setPath(String path) {
          boolean invalid = false;
          if (path == null || path.equals("/")) {
              invalid = true;
              this.path = "";
          } else if (path.isEmpty() || path.startsWith("/")) {
              this.path = path;
          } else {
              invalid = true;
