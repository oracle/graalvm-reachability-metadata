));\n\n            assertThat(context.getPath()).isEqualTo(\"/sample\");\n            assertThat(context.getDocBase()).isEqualTo(temporaryDirectory.toAbsolutePath().toString());\n            assertThat(tomcat.getHost().findChild(\"/sample\")).isSameAs(context);\n        } finally {\n            tomcat.destroy();\n        }\n    }\n\n    @Test\n    void addContextCreatesConfiguredContextClassReflectively() {\n        Tomcat tomcat = new Tomcat();\n        try {\n            StandardHost host = (StandardHost) tomcat.getHost();\n            host.setContextClass(FailedContext.class.getName());\n\n            Context context = tomcat.addContext(\"/custom\", temporaryDirectory.toAbsolutePath().toString());\n\n            assertThat(context).isInstanceOf(FailedContext.class);\n            assertThat(context.getPath()).isEqualTo(\"/custom\");\n            assertThat(context.getDocBase()).isEqualTo(temporaryDirectory.toAbsolutePath().toString());\n            assertThat(host.findChild(\"/custom\")).isSameAs(context);\n        } finally {\n            tomcat.destroy();\n        }\n    }\n\n    private Context addContext(Tomcat tomcat) {\n        Context context = tomcat.addContext(\"\", new File(\".\").getAbsolutePath());\n        Tomcat.addDefaultMimeTypeMappings(context);\n        return context;\n    }\n"},{"oldText":"    private void assertProtocolIntrospection(Connector connector) {\n        assertThat(connector.getProperty(\"name\")).isInstanceOf(String.class);\n        assertThat(connector.getProperty(\"missingPropertyForReachabilityMetadata\")).isNull();\n        assertThat(connector.getProperty(\"SSLEnabled\")).isEqualTo(Boolean.FALSE);\n    }\n","newText":"    private void assertProtocolIntrospection(Connector connector) {\n        assertThat(connector.getProperty(\"name\")).isInstanceOf(String.class);\n        assertThat(connector.getProperty(\"missingPropertyForReachabilityMetadata\")).isNull();\n        assertThat(connector.getProperty(\"SSLEnabled\")).isEqualTo(Boolean.FALSE);\n        assertThat(connector.getProperty(\"bindOnInit\")).isEqualTo(\"true\");\n        assertThat(connector.setProperty(\"bindOnInit\", \"false\")).isTrue();\n        assertThat(connector.getProperty(\"bindOnInit\")).isEqualTo(\"false\");\n    }\n"}]}
