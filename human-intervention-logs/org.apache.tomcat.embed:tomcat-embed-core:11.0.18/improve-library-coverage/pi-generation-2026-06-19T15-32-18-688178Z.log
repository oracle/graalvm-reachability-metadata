      /**
       * Get the server object. You can add listeners and few more customizations. JNDI is disabled by default.
       *
       * @return The Server
       */
      public Server getServer() {
  
          if (server != null) {
              return server;
          }
  
          System.setProperty("catalina.useNaming", "false");
  
          server = new StandardServer();
  
