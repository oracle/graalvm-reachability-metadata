    try {\n            assertProtocolIntrospection(connector);\n            HttpClient client = HttpClient.newBuilder().connectTimeout(Duration.ofSeconds(10)).build();\n            URI uri = URI.create(\"http://localhost:\" + connector.getLocalPort() + \"/hello\");\n            HttpRequest request = HttpRequest.newBuilder(uri).GET().header(\"Accept\", \"text/plain\")\n                    .timeout(Duration.ofSeconds(10)).build();\n            HttpResponse<String> response = client.send(request, BodyHandlers.ofString());\n            assertThat(response.statusCode()).isEqualTo(200);\n            assertThat(response.body()).isEqualTo(\"Hello World\\n\");\n        } finally {\n            tomcat.stop();\n            tomcat.destroy();\n        }\n    }\n\n    @Test\n    void addWebappCreatesDefaultContextConfigReflectively() throws Exception {\n        Tomcat tomcat = new Tomcat();\n        try {\n            Context context = tomcat.addWebapp(\"/sample\", temporaryDirectory.toAbsolutePath().toString());\n\n            assertThat(context.getPath()).isEqualTo(\"/sample\");\n            assertThat(context.getDocBase()).isEqualTo(temporaryDirectory.toAbsolutePath().toString());\n            assertThat(tomcat.getHost().findChild(\"/sample\")).isSameAs(context);\n        } finally {\n            tomcat.destroy();\n        }\n    }\n\n    @Test\n    void addContextCreatesConfiguredContextClassReflectively() throws Exception {\n        Tomcat tomcat = new Tomcat();\n        try {\n            StandardHost host = (StandardHost) tomcat.getHost();\n            host.setContextClass(FailedContext.class.getName());\n\n            Context context = tomcat.addContext(\"/custom\", temporaryDirectory.toAbsolutePath().toString());\n\n            assertThat(context).isInstanceOf(FailedContext.class);\n            assertThat(context.getPath()).isEqualTo(\"/custom\");\n            assertThat(context.getDocBase()).isEqualTo(temporaryDirectory.toAbsolutePath().toString());\n            assertT