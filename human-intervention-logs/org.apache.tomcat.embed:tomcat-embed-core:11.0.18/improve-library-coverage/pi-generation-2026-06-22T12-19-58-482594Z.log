          @Override
          public long getAvailable() {
              return 0;
          }
  
          @Override
          public boolean isUnavailable() {
              return false;
          }
  
          @Override
          public Servlet getServlet() {
              return existing;
          }
  
          @Override
          public String getServletClass() {
              return existing.getClass().getName();
          }
      }
  
