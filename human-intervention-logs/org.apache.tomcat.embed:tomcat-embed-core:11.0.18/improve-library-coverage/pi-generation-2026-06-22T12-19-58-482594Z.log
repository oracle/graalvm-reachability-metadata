[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/HostConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\n\nimport org.apache.catalina.Context;\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.Server;\nimport org.apache.catalina.core.StandardHost;\nimport org.apache.catalina.startup.HostConfig;\nimport org.apache.catalina.startup.Tomcat;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class HostConfigTest {\n\n    @TempDir\n    Path catalinaBase;\n\n    @Test\n    void deploysDescriptorsWarsAndDirectoriesDuringHostStartup() throws Exception {\n        Path appBase = Files.createDirectories(catalinaBase.resolve(\"webapps\"));\n        Path configBase = Files.createDirectories(catalinaBase.resolve(\"conf\").resolve(\"Tomcat\").resolve(\"localhost\"));\n        createContextDescriptor(configBase.resolve(\"descriptor.xml\"));\n        createExplodedWebApplication(appBase.resolve(\"directory\"));\n        createWarWebApplication(appBase.resolve(\"archive.war\"));\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(catalinaBase.toString());\n        StandardHost host = (StandardHost) tomcat.getHost();\n        host.setAppBase(appBase.toString());\n        host.setXmlBase(configBase.toString());\n        host.setDeployOnStartup(true);\n        host.setAutoDeploy(false);\n        host.addLifecycleListener(new HostConfig());\n\n        try {\n            tomcat.start();\n\n            assertDeployed(host, \"/descriptor\");\n            assertDeployed(host, \"/archive\");\n            assertDeployed(host, \"/directory\");\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private static void assertDeployed(StandardHost host, String contextName) {\n        Context context = (Context) host.findChild(contextName);\n\n        assertThat(context).isNotNull();\n        assertThat(context.getState().isAvailable()).isTrue();\n    }\n\n    private static void createContextDescriptor(Path descriptor) throws IOException {\n        Files.writeString(descriptor, \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <Context />\n                \"\"\");\n    }\n\n    private static void createExplodedWebApplication(Path directory) throws IOException {\n        Files.createDirectories(directory.resolve(\"WEB-INF\"));\n        Files.writeString(directory.resolve(\"index.txt\"), \"exploded web application\\n\");\n    }\n\n    private static void createWarWebApplication(Path war) throws IOException {\n        try (OutputStream file = Files.newOutputStream(war); JarOutputStream jar = new JarOutputStream(file)) {\n            addEntry(jar, \"WEB-INF/\", new byte[0]);\n            addEntry(jar, \"index.txt\", \"archived web application\\n\".getBytes(StandardCharsets.UTF_8));\n        }\n    }\n\n    private static void addEntry(JarOutputStream jar, String name, byte[] content) throws IOException {\n        JarEntry entry = new JarEntry(name);\n        jar.putNextEntry(entry);\n        jar.write(content);\n        jar.closeEntry();\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        Server server = tomcat.getServer();\n        try {\n            if (server.getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (server.getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n}\n"}
[tool-call] end id=call_5u28EVcB4W3Ihbgztk2T19Sa|fc_0fa8a80398bd9624016a3928045aec81908466ac553e78853f name=write args={"path": "tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/HostConfigTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\n\nimport org.apache.catalina.Context;\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.Server;\nimport org.apache.catalina.core.StandardHost;\nimport org.apache.catalina.startup.HostConfig;\nimport org.apache.catalina.startup.Tomcat;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class HostConfigTest {\n\n    @TempDir\n    Path catalinaBase;\n\n    @Test\n    void deploysDescriptorsWarsAndDirectoriesDuringHostStartup() throws Exception {\n        Path appBase = Files.createDirectories(catalinaBase.resolve(\"webapps\"));\n        Path configBase = Files.createDirectories(catalinaBase.resolve(\"conf\").resolve(\"Tomcat\").resolve(\"localhost\"));\n        createContextDescriptor(configBase.resolve(\"descriptor.xml\"));\n        createExplodedWebApplication(appBase.resolve(\"directory\"));\n        createWarWebApplication(appBase.resolve(\"archive.war\"));\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(catalinaBase.toString());\n        StandardHost host = (StandardHost) tomcat.getHost();\n        host.setAppBase(appBase.toString());\n        host.setXmlBase(configBase.toString());\n        host.setDeployOnStartup(true);\n        host.setAutoDeploy(false);\n        host.addLifecycleListener(new HostConfig());\n\n        try {\n            tomcat.start();\n\n            assertDeployed(host, \"/descriptor\");\n            assertDeployed(host, \"/archive\");\n            assertDeployed(host, \"/directory\");\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private static void assertDeployed(StandardHost host, String contextName) {\n        Context context = (Context) host.findChild(contextName);\n\n        assertThat(context).isNotNull();\n        assertThat(context.getState().isAvailable()).isTrue();\n    }\n\n    private static void createContextDescriptor(Path descriptor) throws IOException {\n        Files.writeString(descriptor, \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <Context />\n                \"\"\");\n    }\n\n    private static void createExplodedWebApplication(Path directory) throws IOException {\n        Files.createDirectories(directory.resolve(\"WEB-INF\"));\n        Files.writeString(directory.resolve(\"index.txt\"), \"exploded web application\\n\");\n    }\n\n    private static void createWarWebApplication(Path war) throws IOException {\n        try (OutputStream file = Files.newOutputStream(war); JarOutputStream jar = new JarOutputStream(file)) {\n            addEntry(jar, \"WEB-INF/\", new byte[0]);\n            addEntry(jar, \"index.txt\", \"archived web application\\n\".getBytes(StandardCharsets.UTF_8));\n        }\n    }\n\n    private static void addEntry(JarOutputStream jar, String name, byte[] content) throws IOException {\n        JarEntry entry = new JarEntry(name);\n        jar.putNextEntry(entry);\n        jar.write(content);\n        jar.closeEntry();\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        Server server = tomcat.getServer();\n        try {\n            if (server.getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (server.getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n}\n"}
