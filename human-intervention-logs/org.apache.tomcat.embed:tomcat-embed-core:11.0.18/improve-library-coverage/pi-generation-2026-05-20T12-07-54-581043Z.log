[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/DefaultInstanceManagerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage tomcat;\n\nimport java.util.Map;\n\nimport javax.naming.InitialContext;\n\nimport jakarta.annotation.PostConstruct;\nimport jakarta.annotation.PreDestroy;\n\nimport org.apache.catalina.core.DefaultInstanceManager;\nimport org.apache.catalina.core.StandardContext;\nimport org.apache.catalina.loader.WebappLoader;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultInstanceManagerTest {\n\n    @Test\n    void createsInstancesAndInvokesLifecycleAnnotations() throws Exception {\n        StandardContext context = new StandardContext();\n        context.setLoader(new FixedLoader(getClass().getClassLoader()));\n        DefaultInstanceManager manager = new DefaultInstanceManager(new InitialContext(), Map.of(), context,\n                getClass().getClassLoader());\n\n        AnnotatedComponent fromClass = (AnnotatedComponent) manager.newInstance(AnnotatedComponent.class);\n        AnnotatedComponent fromName = (AnnotatedComponent) manager.newInstance(AnnotatedComponent.class.getName());\n        AnnotatedComponent fromLoader = (AnnotatedComponent) manager.newInstance(AnnotatedComponent.class.getName(),\n                getClass().getClassLoader());\n        manager.destroyInstance(fromClass);\n\n        assertThat(fromClass.started).isTrue();\n        assertThat(fromClass.destroyed).isTrue();\n        assertThat(fromName.started).isTrue();\n        assertThat(fromLoader.started).isTrue();\n    }\n\n    public static class FixedLoader extends WebappLoader {\n        private final ClassLoader classLoader;\n\n        FixedLoader(ClassLoader classLoader) {\n            this.classLoader = classLoader;\n        }\n\n        @Override\n        public ClassLoader getClassLoader() {\n            return classLoader;\n        }\n    }\n\n    public static class AnnotatedComponent {\n        boolean started;\n        boolean destroyed;\n\n        @PostConstruct\n        public void start() {\n            started = true;\n        }\n\n        @PreDestroy\n        public void stop() {\n            destroyed = true;\n        }\n    }\n}\n"}
