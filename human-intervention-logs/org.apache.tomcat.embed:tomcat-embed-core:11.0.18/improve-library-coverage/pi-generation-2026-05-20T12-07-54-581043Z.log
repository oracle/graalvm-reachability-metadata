          }
  
          public Object unwrap(Class<?> iface) throws SQLException {
              if (iface == DataSource.class) {
                  return ds;
              } else {
                  throw new SQLException(sm.getString("dataSourceLinkFactory.badWrapper", iface.getName()));
              }
          }
  
      }
  
  
  }
  
