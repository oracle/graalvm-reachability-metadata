  /*
   * Copyright and related rights waived via CC0
   */
  package tomcat;
  
  import java.io.InputStream;
  
  import org.apache.catalina.core.StandardContext;
  import org.apache.catalina.loader.ParallelWebappClassLoader;
  import org.apache.catalina.webresources.StandardRoot;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class WebappClassLoaderBaseTest {
  
      @Test
      void delegatesClassAndResourceLoadingToParent() throws Exception {
          ParallelWebappClassLoader classLoader = new ParallelWebappClassLoader(getClass().getClassLoader());
          classLoader.setDelegate(true);
          classLoader.setResources(new StandardRoot(new StandardContext()));
          classLoader.start();
  
          Class<?> loaded = classLoader.loadClass(getClass().getName());
          try (InputStream stream = classLoader.getResourceAsStream("tomcat/WebappClassLoaderBaseTest.class")) {
              assertThat(loaded).isSameAs(getClass());
              assertThat(classLoader.getResource("tomcat/WebappClassLoaderBaseTest.class")).isNotNull();
              assertThat(stream).isNotNull();
          } finally {
              classLoader.stop();
              classLoader.destroy();
              classLoader.close();
          }
      }
  }
