[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/ResourceFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage tomcat;\n\nimport java.util.Hashtable;\n\nimport javax.naming.Context;\nimport javax.naming.Name;\nimport javax.naming.spi.ObjectFactory;\n\nimport org.apache.naming.ResourceRef;\nimport org.apache.naming.factory.ResourceFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ResourceFactoryTest {\n\n    @Test\n    void createsConfiguredDefaultDataSourceFactory() throws Exception {\n        String property = \"javax.sql.DataSource.Factory\";\n        String previous = System.getProperty(property);\n        System.setProperty(property, DefaultDataSourceFactory.class.getName());\n        try {\n            ResourceRef reference = new ResourceRef(\"javax.sql.DataSource\", null, null, null, true);\n\n            Object result = new ResourceFactory().getObjectInstance(reference, null, null, null);\n\n            assertThat(result).isEqualTo(\"data-source\");\n        } finally {\n            if (previous == null) {\n                System.clearProperty(property);\n            } else {\n                System.setProperty(property, previous);\n            }\n        }\n    }\n\n    public static class DefaultDataSourceFactory implements ObjectFactory {\n        @Override\n        public Object getObjectInstance(Object obj, Name name, Context nameCtx, Hashtable<?,?> environment) {\n            return \"data-source\";\n        }\n    }\n}\n"}
