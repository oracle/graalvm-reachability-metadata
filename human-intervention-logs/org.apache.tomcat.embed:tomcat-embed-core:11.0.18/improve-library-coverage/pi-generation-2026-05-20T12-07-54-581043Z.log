[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/BaseModelMBeanTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage tomcat;\n\nimport javax.management.Attribute;\n\nimport org.apache.tomcat.util.modeler.AttributeInfo;\nimport org.apache.tomcat.util.modeler.BaseModelMBean;\nimport org.apache.tomcat.util.modeler.ManagedBean;\nimport org.apache.tomcat.util.modeler.OperationInfo;\nimport org.apache.tomcat.util.modeler.ParameterInfo;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseModelMBeanTest {\n\n    @Test\n    void invokesManagedResourceAttributeAndOperationMethods() throws Exception {\n        ManagedResource resource = new ManagedResource();\n        BaseModelMBean mbean = (BaseModelMBean) managedBean().createMBean(resource);\n\n        mbean.setAttribute(new Attribute(\"Count\", Integer.valueOf(7)));\n\n        assertThat(mbean.getAttribute(\"Count\")).isEqualTo(Integer.valueOf(7));\n        assertThat(mbean.invoke(\"echo\", new Object[] { \"value\" }, new String[] { String.class.getName() }))\n                .isEqualTo(\"value:7\");\n    }\n\n    private ManagedBean managedBean() {\n        ManagedBean bean = new ManagedBean();\n        bean.setName(\"managed\");\n        bean.setType(ManagedResource.class.getName());\n\n        AttributeInfo attribute = new AttributeInfo();\n        attribute.setName(\"Count\");\n        attribute.setType(Integer.class.getName());\n        bean.addAttribute(attribute);\n\n        OperationInfo operation = new OperationInfo();\n        operation.setName(\"echo\");\n        ParameterInfo parameter = new ParameterInfo();\n        parameter.setName(\"input\");\n        parameter.setType(String.class.getName());\n        operation.addParameter(parameter);\n        bean.addOperation(operation);\n        return bean;\n    }\n\n    public static class ManagedResource {\n        private Integer count;\n\n        public Integer getCount() {\n            return count;\n        }\n\n        public void setCount(Integer count) {\n            this.count = count;\n        }\n\n        public String echo(String value) {\n            return value + ':' + count;\n        }\n    }\n}\n"}
