[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/EjbFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage tomcat;\n\nimport java.util.Hashtable;\n\nimport javax.naming.Context;\nimport javax.naming.Name;\nimport javax.naming.spi.ObjectFactory;\n\nimport org.apache.naming.EjbRef;\nimport org.apache.naming.factory.EjbFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EjbFactoryTest {\n\n    @Test\n    void createsConfiguredDefaultEjbFactory() throws Exception {\n        String property = \"jakarta.ejb.Factory\";\n        String previous = System.getProperty(property);\n        System.setProperty(property, DefaultEjbFactory.class.getName());\n        try {\n            Object result = new EjbFactory().getObjectInstance(new EjbRef(\"Session\", null, null, null), null, null,\n                    null);\n\n            assertThat(result).isEqualTo(\"ejb\");\n        } finally {\n            if (previous == null) {\n                System.clearProperty(property);\n            } else {\n                System.setProperty(property, previous);\n            }\n        }\n    }\n\n    public static class DefaultEjbFactory implements ObjectFactory {\n        @Override\n        public Object getObjectInstance(Object obj, Name name, Context nameCtx, Hashtable<?,?> environment) {\n            return \"ejb\";\n        }\n    }\n}\n"}
