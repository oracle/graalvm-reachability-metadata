  /*
   * Copyright and related rights waived via CC0
   */
  package tomcat;
  
  import java.util.Map;
  
  import javax.security.auth.callback.CallbackHandler;
  
  import jakarta.security.auth.message.AuthException;
  import jakarta.security.auth.message.config.AuthConfigFactory;
  import jakarta.security.auth.message.config.AuthConfigProvider;
  import jakarta.security.auth.message.config.ClientAuthConfig;
  import jakarta.security.auth.message.config.ServerAuthConfig;
  import org.apache.catalina.authenticator.jaspic.AuthConfigFactoryImpl;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AuthConfigFactoryImplTest {
  
      @Test
      void registersProviderByClassName() {
          AuthConfigFactoryImpl factory = new AuthConfigFactoryImpl();
  
          String registration = factory.registerConfigProvider(CustomProvider.class.getName(), Map.of("k", "v"),
                  "HttpServlet", "app", "description");
  
          assertThat(registration).isNotBlank();
          assertThat(factory.getConfigProvider("HttpServlet", "app", null)).isInstanceOf(CustomProvider.class);
      }
  
      public static class CustomProvider implements AuthConfigProvider {
          public CustomProvider(Map<String,String> properties, AuthConfigFactory factory) {
              assertThat(properties).containsEntry("k", "v");
          }
  
          @Override
          public ClientAuthConfig getClientAuthConfig(String layer, String appContext, CallbackHandler handler)
                  throws AuthException {
              return null;
          }
  
          @Override
          public ServerAuthConfig getServerAuthConfig(String layer, String appContext, CallbackHandler handler)
                  throws AuthException {
              return null;
          }
  
          @Override
          public void refresh() {
          }
