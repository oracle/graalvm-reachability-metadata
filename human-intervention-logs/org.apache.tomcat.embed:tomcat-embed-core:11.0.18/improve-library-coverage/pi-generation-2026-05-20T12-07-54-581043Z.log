[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/DataSourceLinkFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n */\npackage tomcat;\n\nimport java.io.PrintWriter;\nimport java.sql.Connection;\nimport java.sql.SQLException;\nimport java.util.Hashtable;\nimport java.util.logging.Logger;\n\nimport javax.naming.Context;\nimport javax.sql.DataSource;\n\nimport org.apache.naming.NamingContext;\nimport org.apache.naming.ResourceLinkRef;\nimport org.apache.naming.factory.DataSourceLinkFactory;\nimport org.apache.naming.factory.ResourceLinkFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DataSourceLinkFactoryTest {\n\n    @Test\n    void wrapsDataSourceAndSuppliesConfiguredCredentials() throws Exception {\n        Context globalContext = new NamingContext(new Hashtable<>(), \"global\");\n        RecordingDataSource dataSource = new RecordingDataSource();\n        globalContext.bind(\"jdbc/global\", dataSource);\n        DataSourceLinkFactory.setGlobalContext(globalContext);\n        ResourceLinkFactory.registerGlobalResourceAccess(globalContext, \"jdbc/local\", \"jdbc/global\");\n        ResourceLinkRef reference = new ResourceLinkRef(DataSource.class.getName(), \"jdbc/global\", null, null);\n        reference.add(new javax.naming.StringRefAddr(\"username\", \"alice\"));\n        reference.add(new javax.naming.StringRefAddr(\"password\", \"secret\"));\n\n        DataSource wrapped = (DataSource) new DataSourceLinkFactory().getObjectInstance(reference, null, null, null);\n        wrapped.getConnection();\n\n        assertThat(dataSource.username).isEqualTo(\"alice\");\n        assertThat(dataSource.password).isEqualTo(\"secret\");\n    }\n\n    public static class RecordingDataSource implements DataSource {\n        String username;\n        String password;\n\n        @Override\n        public Connection getConnection() {\n            return null;\n        }\n\n        @Override\n        public Connection getConnection(String username, String password) {\n            this.username = username;\n            this.password = password;\n            return null;\n        }\n\n        @Override\n        public PrintWriter getLogWriter() {\n            return null;\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) {\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) {\n        }\n\n        @Override\n        public int getLoginTimeout() {\n            return 0;\n        }\n\n        @Override\n        public Logger getParentLogger() {\n            return Logger.getGlobal();\n        }\n\n        @Override\n        public <T> T unwrap(Class<T> iface) throws SQLException {\n            throw new SQLException();\n        }\n\n        @Override\n        public boolean isWrapperFor(Class<?> iface) {\n            return false;\n        }\n    }\n}\n"}
