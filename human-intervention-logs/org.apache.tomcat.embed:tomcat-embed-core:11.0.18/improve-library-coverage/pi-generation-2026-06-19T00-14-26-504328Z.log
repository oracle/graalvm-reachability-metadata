CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.tomcat.SimpleInstanceManager;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SimpleInstanceManagerTest {\n\n    @Test\n    void createsInstancesFromClassNameAndClassLoaders() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        ClassLoader testClassLoader = SimpleInstanceManagerTest.class.getClassLoader();\n\n        try {\n            Thread.currentThread().setContextClassLoader(testClassLoader);\n\n            Object classInstance = manager.newInstance(ClassBasedComponent.class);\n            Object contextClassLoaderInstance = manager.newInstance(ContextClassLoaderComponent.class.getName());\n            Object explicitClassLoaderInstance = manager.newInstance(ExplicitClassLoaderComponent.class.getName(),\n                    testClassLoader);\n\n            assertThat(classInstance).isInstanceOf(ClassBasedComponent.class);\n            assertThat(contextClassLoaderInstance).isInstanceOf(ContextClassLoaderComponent.class);\n            assertThat(explicitClassLoaderInstance).isInstanceOf(ExplicitClassLoaderComponent.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    public static final class ClassBasedComponent {\n        public ClassBasedComponent() {\n        }\n    }\n\n    public static final class ContextClassLoaderComponent {\n        public ContextClassLoaderComponent() {\n        }\n    }\n\n    public static final class ExplicitClassLoaderComponent {\n        public ExplicitClassLoaderComponent() {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 45