              tomcat.start();
  
              assertDeployed(host, "/descriptor");
              assertDeployed(host, "/archive");
              assertDeployed(host, "/directory");
          } finally {
              tomcat.stop();
              tomcat.destroy();
          }
      }
  
      private static void configureAutodeployingHost(StandardHost host) {
          host.addLifecycleListener(new HostConfig());
          host.setDeployOnStartup(true);
          host.setAutoDeploy(false);
          host.setUnpackWARs(false);
      }
  
      private static void writeContextDescriptor(Path descriptor, Path docBase) throws IOException {
          Files.writeString(descriptor, """
                  <?xml version="1.0" encoding="UTF-8"?>
                  <Context docBase="%s" />
                  """.formatted(docBase));
      }
  
      private static void writeWar(Path war) throws IOException {
          try (OutputStream outputStream = Files.newOutputStream(war);
                  JarOutputStream jar = new JarOutputStream(outputStream)) {
              jar.putNextEntry(new JarEntry("index.html"));
              jar.write("archive webapp".getBytes(StandardCharsets.UTF_8));
              jar.closeEntry();
          }
      }
  
      private static void writeDirectoryWebapp(Path directory) throws IOException {
          Files.createDirectories(directory);
          Files.writeString(directory.resolve("index.html"), "directory webapp");
      }
  
      private static void assertDeployed(Host host, String name) {
          Container child = host.findChild(name);
          assertThat(child).isNotNull();
          assertThat(child.getState()).isNotEqualTo(LifecycleState.FAILED);
      }
  }
