[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/HostConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\n\nimport org.apache.catalina.Container;\nimport org.apache.catalina.Host;\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.startup.HostConfig;\nimport org.apache.catalina.startup.Tomcat;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class HostConfigTest {\n\n    @TempDir\n    Path baseDir;\n\n    @Test\n    void deploysDescriptorWarAndExplodedDirectoryFromHostApplicationBases() throws Exception {\n        Path appBase = Files.createDirectories(baseDir.resolve(\"webapps\"));\n        Path configBase = Files.createDirectories(baseDir.resolve(\"conf\").resolve(\"Tomcat\").resolve(\"localhost\"));\n        createDescriptor(configBase.resolve(\"descriptor-app.xml\"));\n        createExplodedWebapp(appBase.resolve(\"directory-app\"));\n        createWar(appBase.resolve(\"war-app.war\"));\n\n        Tomcat tomcat = new Tomcat();\n        tomcat.setBaseDir(baseDir.toString());\n        Host host = tomcat.getHost();\n        host.setAppBase(appBase.toString());\n        host.setAutoDeploy(false);\n        host.setDeployOnStartup(true);\n        host.addLifecycleListener(new HostConfig());\n\n        try {\n            tomcat.start();\n\n            assertDeployed(host, \"/descriptor-app\");\n            assertDeployed(host, \"/directory-app\");\n            assertDeployed(host, \"/war-app\");\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private static void createDescriptor(Path descriptor) throws IOException {\n        Files.writeString(descriptor, \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <Context />\n                \"\"\");\n    }\n\n    private static void createExplodedWebapp(Path directory) throws IOException {\n        Path webInf = Files.createDirectories(directory.resolve(\"WEB-INF\"));\n        Files.writeString(webInf.resolve(\"web.xml\"), webXml());\n    }\n\n    private static void createWar(Path war) throws IOException {\n        try (OutputStream output = Files.newOutputStream(war); JarOutputStream jar = new JarOutputStream(output)) {\n            jar.putNextEntry(new JarEntry(\"WEB-INF/\"));\n            jar.closeEntry();\n            jar.putNextEntry(new JarEntry(\"WEB-INF/web.xml\"));\n            jar.write(webXml().getBytes(java.nio.charset.StandardCharsets.UTF_8));\n            jar.closeEntry();\n        }\n    }\n\n    private static String webXml() {\n        return \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <web-app xmlns=\"https://jakarta.ee/xml/ns/jakartaee\"\n                         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n                         xsi:schemaLocation=\"https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_1.xsd\"\n                         version=\"6.1\">\n                </web-app>\n                \"\"\";\n    }\n\n    private static void assertDeployed(Host host, String contextName) {\n        Container child = host.findChild(contextName);\n        assertThat(child).as(contextName).isNotNull();\n        assertThat(child.getName()).isEqualTo(contextName);\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {\n        try {\n            tomcat.stop();\n        } finally {\n            tomcat.destroy();\n        }\n    }\n}\n"}
