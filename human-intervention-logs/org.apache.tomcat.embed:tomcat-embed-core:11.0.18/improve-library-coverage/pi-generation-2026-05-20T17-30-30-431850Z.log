[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/BootstrapTest.java","edits":[{"oldText":"    @Test\n    void startsAndStopsLoadedCatalinaDaemonThroughBootstrap() throws Exception {\n        Bootstrap bootstrap = newLoadedBootstrap();\n        try {\n            bootstrap.setAwait(false);\n            assertThatExceptionOfType(NoSuchMethodException.class).isThrownBy(bootstrap::getAwait);\n\n            bootstrap.start();\n            assertThat(System.getProperty(\"catalina.base\")).isNotEmpty();\n        } finally {\n            stopQuietly(bootstrap);\n        }\n    }\n\n    @Test\n    void mainStartCommandLoadsStartsAndChecksCatalinaServer() throws Exception {\n        Path serverXml = createServerXml();\n\n        Bootstrap.main(new String[] {\"-config\", serverXml.toString(), \"-nonaming\", \"start\"});\n    }\n\n    @Test\n    void stopServerWithoutArgumentsDelegatesToLoadedCatalinaDaemon() throws Exception {\n        Bootstrap bootstrap = newLoadedBootstrap();\n\n        bootstrap.stopServer();\n    }\n\n    @Test\n    void stopServerWithArgumentsDelegatesToLoadedCatalinaDaemon() throws Exception {\n        Bootstrap bootstrap = newLoadedBootstrap();\n\n        bootstrap.stopServer(new String[] {\"stop\"});\n    }\n\n    private Bootstrap newLoadedBootstrap() throws Exception {\n        Path serverXml = createServerXml();\n        Bootstrap bootstrap = new Bootstrap();\n        bootstrap.init(new String[] {\"-config\", serverXml.toString(), \"-nonaming\", \"start\"});\n        return bootstrap;\n    }\n","newText":"    @Test\n    void delegatesLifecycleCommandsToCatalinaDaemonThroughBootstrap() throws Exception {\n        Path serverXml = createServerXml();\n        Bootstrap bootstrap = new Bootstrap();\n        bootstrap.init(new String[] {\"-config\", serverXml.toString(), \"-nonaming\", \"start\"});\n\n        bootstrap.setAwait(false);\n        assertThatExceptionOfType(NoSuchMethodException.class).isThrownBy(bootstrap::getAwait);\n\n        bootstrap.start();\n        assertThat(System.getProperty(\"catalina.base\")).isNotEmpty();\n        bootstrap.stopServer(new String[] {\"stop\"});\n        bootstrap.stopServer();\n        bootstrap.stop();\n\n        Bootstrap.main(new String[] {\"-config\", serverXml.toString(), \"-nonaming\", \"start\"});\n    }\n"}]}
