[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/FileHandlerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Properties;\nimport java.util.logging.Filter;\nimport java.util.logging.Formatter;\nimport java.util.logging.LogManager;\nimport java.util.logging.LogRecord;\n\nimport org.apache.juli.FileHandler;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FileHandlerTest {\n\n    @TempDir\n    Path logDirectory;\n\n    @Test\n    void configuresFilterAndFormatterFromLogManagerProperties() throws Exception {\n        LogManager logManager = LogManager.getLogManager();\n        configureFileHandler(logManager);\n\n        FileHandler handler = new FileHandler();\n        try {\n            assertThat(handler.getFilter()).isInstanceOf(AcceptingFilter.class);\n            assertThat(handler.getFormatter()).isInstanceOf(PrefixFormatter.class);\n\n            LogRecord record = new LogRecord(java.util.logging.Level.INFO, \"configured message\");\n            handler.publish(record);\n            handler.flush();\n\n            Path logFile = logDirectory.resolve(\"reachability.log\");\n            assertThat(logFile).exists();\n            assertThat(Files.readString(logFile)).contains(\"formatted: configured message\");\n        } finally {\n            handler.close();\n            logManager.readConfiguration(new ByteArrayInputStream(new byte[0]));\n        }\n    }\n\n    private void configureFileHandler(LogManager logManager) throws Exception {\n        Properties properties = new Properties();\n        String handlerName = FileHandler.class.getName();\n        properties.setProperty(handlerName + \".directory\", logDirectory.toAbsolutePath().toString());\n        properties.setProperty(handlerName + \".rotatable\", \"false\");\n        properties.setProperty(handlerName + \".prefix\", \"reachability\");\n        properties.setProperty(handlerName + \".suffix\", \".log\");\n        properties.setProperty(handlerName + \".maxDays\", String.valueOf(FileHandler.DEFAULT_MAX_DAYS));\n        properties.setProperty(handlerName + \".bufferSize\", String.valueOf(FileHandler.DEFAULT_BUFFER_SIZE));\n        properties.setProperty(handlerName + \".level\", \"ALL\");\n        properties.setProperty(handlerName + \".filter\", AcceptingFilter.class.getName());\n        properties.setProperty(handlerName + \".formatter\", PrefixFormatter.class.getName());\n\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        properties.store(output, null);\n        byte[] configuration = output.toString(StandardCharsets.ISO_8859_1).getBytes(StandardCharsets.ISO_8859_1);\n        logManager.readConfiguration(new ByteArrayInputStream(configuration));\n    }\n\n    public static class AcceptingFilter implements Filter {\n        public AcceptingFilter() {\n        }\n\n        @Override\n        public boolean isLoggable(LogRecord record) {\n            return true;\n        }\n    }\n\n    public static class PrefixFormatter extends Formatter {\n        public PrefixFormatter() {\n        }\n\n        @Override\n        public String format(LogRecord record) {\n            return \"formatted: \" + record.getMessage() + System.lineSeparator();\n        }\n    }\n}\n"}
