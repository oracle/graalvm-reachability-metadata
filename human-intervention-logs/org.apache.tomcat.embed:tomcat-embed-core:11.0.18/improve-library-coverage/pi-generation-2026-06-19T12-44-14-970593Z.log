abled = connector.getProperty(\"SSLEnabled\");\n            Object bindOnInit = connector.getProperty(\"bindOnInit\");\n\n            assertThat(protocolName).isInstanceOf(String.class);\n            assertThat(protocolName.toString()).isNotBlank();\n            assertThat(missingProtocolProperty).isNull();\n            assertThat(sslEnabled).isEqualTo(Boolean.FALSE);\n            assertThat(bindOnInit).isNull();\n            assertThat(connector.setProperty(\"bindOnInit\", \"false\")).isTrue();\n            assertThat(connector.getProperty(\"bindOnInit\")).isEqualTo(\"false\");\n        } finally {\n            stopAndDestroy(connector);\n        }\n    }\n\n    private static void stopAndDestroy(Connector connector) throws LifecycleException {\n        try {\n            if (connector.getState().isAvailable()) {\n                connector.stop();\n            }\n        } finally {\n            if (connector.getState() != LifecycleState.DESTROYED) {\n                connector.destroy();\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781872962477}, {"role": "toolResult", "toolCallId": "call_ym72l57oRBKamoe9JjyU9aTP|fc_0899eb03ad9721a7016a353942386c819486eb1affd8ba09c1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n\ttestImplementation \"org.apache.tomcat.embed:tomcat-embed-core:$libraryVersion\"\n\ttestImplementation 'jakarta.annotation:jakarta.annotation-api:3.0.0'\n\ttestImplementation 'jakarta.servlet:jakarta.servlet-api:5.0.0'\n\ttestImplementation 'org.assertj:assertj-core:3.22.0'\n\ttestRuntimeOnly 'org.apache.tomcat:jakartaee-migration:1.0.6'\n}\n\ntasks.withType(Test).configureEach {\n   