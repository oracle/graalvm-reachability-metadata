[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/RealmBaseTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\nimport java.security.Principal;\n\nimport org.apache.catalina.LifecycleException;\nimport org.apache.catalina.realm.MessageDigestCredentialHandler;\nimport org.apache.catalina.realm.RealmBase;\nimport org.apache.catalina.realm.X509SubjectDnRetriever;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RealmBaseTest {\n\n    private final PrintStream originalOut = System.out;\n\n    @AfterEach\n    void restoreStandardStreams() {\n        System.setOut(originalOut);\n    }\n\n    @Test\n    void commandLineMutationCreatesDefaultCredentialHandler() throws Exception {\n        String output = captureStandardOutput(() -> RealmBase.main(new String[] {\"--\", \"secret\"}));\n\n        assertThat(output).contains(\"secret:\");\n        assertThat(output.substring(output.indexOf(':') + 1).trim()).isNotEmpty();\n    }\n\n    @Test\n    void commandLineMutationCreatesConfiguredCredentialHandlerByClassName() throws Exception {\n        String output = captureStandardOutput(() -> RealmBase.main(new String[] {\n                \"-h\", MessageDigestCredentialHandler.class.getName(), \"-a\", \"SHA-256\", \"--\", \"secret\"}));\n\n        assertThat(output).contains(\"secret:\");\n        assertThat(output.substring(output.indexOf(':') + 1).trim()).isNotEmpty();\n    }\n\n    @Test\n    void initCreatesConfiguredX509UsernameRetrieverByClassName() throws Exception {\n        TestRealm realm = new TestRealm();\n        realm.setX509UsernameRetrieverClassName(X509SubjectDnRetriever.class.getName());\n\n        try {\n            realm.init();\n            assertThat(realm.getState().isAvailable()).isFalse();\n        } finally {\n            realm.destroy();\n        }\n    }\n\n    private String captureStandardOutput(ThrowingRunnable runnable) throws Exception {\n        ByteArrayOutputStream out = new ByteArrayOutputStream();\n        System.setOut(new PrintStream(out, true, StandardCharsets.UTF_8));\n        runnable.run();\n        return out.toString(StandardCharsets.UTF_8);\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    private static class TestRealm extends RealmBase {\n        @Override\n        protected String getPassword(String username) {\n            return null;\n        }\n\n        @Override\n        protected Principal getPrincipal(String username) {\n            return null;\n        }\n\n        @Override\n        public String getObjectNameKeyProperties() {\n            return \"type=Realm,realmPath=/test\";\n        }\n\n        @Override\n        public String getDomainInternal() {\n            return \"Tomcat\";\n        }\n\n        @Override\n        protected void destroyInternal() throws LifecycleException {\n            super.destroyInternal();\n        }\n    }\n}\n"}
