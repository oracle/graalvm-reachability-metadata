colName = connector.getProperty(\"name\");\n            Object missingProtocolProperty = connector.getProperty(\"missingPropertyForReachabilityMetadata\");\n            Object sslEnabled = connector.getProperty(\"SSLEnabled\");\n            Object bindOnInit = connector.getProperty(\"bindOnInit\");\n\n            assertThat(protocolName).isInstanceOf(String.class);\n            assertThat(protocolName.toString()).isNotBlank();\n            assertThat(missingProtocolProperty).isNull();\n            assertThat(sslEnabled).isEqualTo(Boolean.FALSE);\n            assertThat(bindOnInit).isNull();\n            assertThat(connector.setProperty(\"bindOnInit\", \"false\")).isTrue();\n            assertThat(connector.getProperty(\"bindOnInit\")).isEqualTo(\"false\");\n        } finally {\n            stopAndDestroy(connector);\n        }\n    }\n\n    private static void stopAndDestroy(Connector connector) throws LifecycleException {\n        try {\n            if (connector.getState().isAvailable()) {\n                connector.stop();\n            }\n        } finally {\n            if (connector.getState() != LifecycleState.DESTROYED) {\n                connector.destroy();\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781873278111}, {"role": "toolResult", "toolCallId": "call_L8VMU5Nvb1HzeJuGOvr1SI3H|fc_0a2c21690d238812016a353a7dbfb081958ae9a006565fd8bb", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n\ttestImplementation \"org.apache.tomcat.embed:tomcat-embed-core:$libraryVersion\"\n\ttestImplementation 'jakarta.annotation:jakarta.annotation-api:3.0.0'\n\ttestImplementation 'jakarta.servlet:jakarta.servle