throws Exception {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n\n        Object instance = instanceManager.newInstance(PublicComponent.class.getName(), PublicComponent.class.getClassLoader());\n\n        assertThat(instance).isInstanceOf(PublicComponent.class);\n        assertThat(((PublicComponent) instance).message()).isEqualTo(\"created\");\n    }\n\n    @Test\n    void existingInstanceLifecycleCallbacksAreNoOps() throws NamingException, InvocationTargetException,\n            IllegalAccessException {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n        PublicComponent instance = new PublicComponent();\n\n        instanceManager.newInstance(instance);\n        instanceManager.destroyInstance(instance);\n\n        assertThat(instance.message()).isEqualTo(\"created\");\n    }\n\n    public static class PublicComponent {\n\n        public PublicComponent() {\n        }\n\n        String message() {\n            return \"created\";\n        }\n    }\n}\n"}
