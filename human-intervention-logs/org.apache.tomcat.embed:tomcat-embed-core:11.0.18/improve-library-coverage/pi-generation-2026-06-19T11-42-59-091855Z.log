[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/RealmBaseTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\n\nimport org.apache.catalina.LifecycleState;\nimport org.apache.catalina.realm.MessageDigestCredentialHandler;\nimport org.apache.catalina.realm.NullRealm;\nimport org.apache.catalina.realm.RealmBase;\nimport org.apache.catalina.realm.X509SubjectDnRetriever;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RealmBaseTest {\n\n    @Test\n    void commandLineCredentialMutationUsesDefaultCredentialHandler() throws Exception {\n        String output = captureStandardOutput(() -> RealmBase.main(new String[] { \"-a\", \"SHA-256\", \"secret\" }));\n\n        assertThat(output).startsWith(\"secret:\");\n        assertThat(output).doesNotContain(\"Usage: RealmBase\");\n    }\n\n    @Test\n    void commandLineCredentialMutationUsesConfiguredCredentialHandlerClass() throws Exception {\n        String output = captureStandardOutput(() -> RealmBase.main(new String[] { \"-a\", \"SHA-256\", \"-h\",\n                MessageDigestCredentialHandler.class.getName(), \"secret\" }));\n\n        assertThat(output).startsWith(\"secret:\");\n        assertThat(output).doesNotContain(\"Usage: RealmBase\");\n    }\n\n    @Test\n    void initializesConfiguredX509UsernameRetrieverClass() throws Exception {\n        NullRealm realm = new NullRealm();\n        realm.setX509UsernameRetrieverClassName(X509SubjectDnRetriever.class.getName());\n\n        try {\n            realm.init();\n\n            assertThat(realm.getState()).isNotEqualTo(LifecycleState.FAILED);\n            assertThat(realm.getX509UsernameRetrieverClassName()).isEqualTo(X509SubjectDnRetriever.class.getName());\n        } finally {\n            if (realm.getState() != LifecycleState.DESTROYED) {\n                realm.destroy();\n            }\n        }\n    }\n\n    private static String captureStandardOutput(ThrowingRunnable runnable) throws Exception {\n        PrintStream originalOut = System.out;\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (PrintStream replacementOut = new PrintStream(output, true, StandardCharsets.UTF_8)) {\n            System.setOut(replacementOut);\n            runnable.run();\n        } finally {\n            System.setOut(originalOut);\n        }\n        return output.toString(StandardCharsets.UTF_8).trim();\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n\n        void run() throws Exception;\n    }\n}\n"}
