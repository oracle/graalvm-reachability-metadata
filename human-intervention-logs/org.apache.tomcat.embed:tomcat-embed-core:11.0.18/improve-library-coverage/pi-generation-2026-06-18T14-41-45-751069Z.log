  package tomcat;
  
  import java.io.IOException;
  import java.io.OutputStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  
  import org.apache.catalina.Container;
  import org.apache.catalina.Host;
  import org.apache.catalina.LifecycleException;
  import org.apache.catalina.core.StandardHost;
  import org.apache.catalina.startup.HostConfig;
  import org.apache.catalina.startup.Tomcat;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class HostConfigTest {
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void deploysContextDescriptorOnStartup() throws Exception {
          Path appBase = Files.createDirectories(temporaryDirectory.resolve("descriptor-app-base"));
          Path configBase = Files.createDirectories(temporaryDirectory.resolve("descriptor-config-base"));
          Path webapp = createExpandedWebapp(temporaryDirectory.resolve("descriptor-doc-base"));
          Files.writeString(configBase.resolve("descriptor-app.xml"),
                  """
                  <Context docBase="%s" />
                  """.formatted(webapp), StandardCharsets.UTF_8);
  
          Tomcat tomcat = createTomcat(appBase, configBase);
          try {
              tomcat.start();
  
              assertDeployed(tomcat.getHost(), "/descriptor-app");
          } finally {
              stopAndDestroy(tomcat);
          }
      }
  
      @Test
      void deploysWarOnStartup() throws Exception {
          Path appBase = Files.createDirectories(temporaryDirectory.resolve("war-app-base"));
          Path configBase = Files.createDirectories(temporaryDirectory.resolve("war-config-base"));
          createWar(appBase.resolve("war-app.war"));
  
          Tomcat tomcat = createTomcat(appBase, configBase);
          try {
              tomcat.start();
  
              assertDeployed(tomcat.getHost(), "/war-app");
          } finally {
              stopAndDestroy(tomcat);
          }
      }
  
      @Test
      void deploysExpandedDirectoryOnStartup() throws Exception {
          Path appBase = Files.createDirectories(temporaryDirectory.resolve("directory-app-base"));
          Path configBase = Files.createDirectories(temporaryDirectory.resolve("directory-config-base"));
          createExpandedWebapp(appBase.resolve("directory-app"));
  
          Tomcat tomcat = createTomcat(appBase, configBase);
          try {
              tomcat.start();
  
              assertDeployed(tomcat.getHost(), "/directory-app");
          } finally {
              stopAndDestroy(tomcat);
          }
      }
  
      private Tomcat createTomcat(Path appBase, Path configBase) {
          Path baseDirectory = temporaryDirectory.resolve("tomcat-base-" + appBase.getFileName());
          Tomcat tomcat = new Tomcat();
          tomcat.setBaseDir(baseDirectory.toString());
          Host host = tomcat.getHost();
          host.setAppBase(appBase.toString());
          host.setXmlBase(configBase.toString());
          host.setDeployOnStartup(true);
          host.setAutoDeploy(false);
          ((StandardHost) host).setUnpackWARs(false);
          host.addLifecycleListener(new HostConfig());
          return tomcat;
      }
  
      private static Path createExpandedWebapp(Path directory) throws IOException {
          Files.createDirectories(directory.resolve("WEB-INF"));
          Files.writeString(directory.resolve("index.html"), "host config deployment", StandardCharsets.UTF_8);
          return directory;
      }
  
      private static void createWar(Path war) throws IOException {
          try (OutputStream outputStream = Files.newOutputStream(war);
                  JarOutputStream jar = new JarOutputStream(outputStream)) {
              jar.putNextEntry(new JarEntry("index.html"));
              jar.write("host config deployment".getBytes(StandardCharsets.UTF_8));
              jar.closeEntry();
              jar.putNextEntry(new JarEntry("WEB-INF/"));
              jar.closeEntry();
          }
      }
  
      private static void assertDeployed(Host host, String contextName) {
          Container child = host.findChild(contextName);
          assertThat(child).isNotNull();
          assertThat(child.getName()).isEqualTo(contextName);
      }
  
      private static void stopAndDestroy(Tomcat tomcat) throws LifecycleException {
          try {
              tomcat.stop();
          } finally {
              tomcat.destroy();
          }
      }
  }
