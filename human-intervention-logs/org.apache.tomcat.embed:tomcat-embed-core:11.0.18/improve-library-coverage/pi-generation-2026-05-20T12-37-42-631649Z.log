[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/IntrospectionUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.tomcat.util.IntrospectionUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class IntrospectionUtilsTest {\n\n    @Test\n    void invokesBeanAccessorsAndGenericPropertyMethods() throws Exception {\n        ConfigurableTarget target = new ConfigurableTarget();\n\n        assertThat(IntrospectionUtils.setProperty(target, \"count\", \"7\")).isTrue();\n        assertThat(IntrospectionUtils.setProperty(target, \"custom\", \"value\")).isTrue();\n        assertThat(IntrospectionUtils.getProperty(target, \"count\")).isEqualTo(7);\n        assertThat(IntrospectionUtils.getProperty(target, \"custom\")).isEqualTo(\"value\");\n        assertThat(IntrospectionUtils.callMethodN(target, \"join\", new Object[] { \"a\", \"b\" },\n                new Class[] { String.class, String.class })).isEqualTo(\"a:b\");\n    }\n\n    public static class ConfigurableTarget {\n        private int count;\n        private String custom;\n\n        public int getCount() {\n            return count;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n\n        public boolean setProperty(String name, String value) {\n            if (\"custom\".equals(name)) {\n                custom = value;\n                return true;\n            }\n            return false;\n        }\n\n        public String getProperty(String name) {\n            if (\"custom\".equals(name)) {\n                return custom;\n            }\n            return null;\n        }\n\n        public String join(String left, String right) {\n            return left + ':' + right;\n        }\n    }\n}\n"}
