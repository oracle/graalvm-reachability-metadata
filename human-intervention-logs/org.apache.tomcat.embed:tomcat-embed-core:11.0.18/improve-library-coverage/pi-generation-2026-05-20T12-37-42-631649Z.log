[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/CatalinaBaseConfigurationSourceTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.nio.file.Path;\n\nimport org.apache.catalina.startup.CatalinaBaseConfigurationSource;\nimport org.apache.tomcat.util.file.ConfigurationSource.Resource;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CatalinaBaseConfigurationSourceTest {\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void locatesConfigurationResourcesFromClassPath() throws Exception {\n        CatalinaBaseConfigurationSource source = new CatalinaBaseConfigurationSource(temporaryDirectory.toFile(), null);\n\n        try (Resource serverXml = source.getServerXml(); Resource resource = source.getResource(\"tomcat-resource.txt\")) {\n            assertThat(serverXml.getURI().toString()).endsWith(\"server-embed.xml\");\n            assertThat(resource.getURI().toString()).endsWith(\"tomcat-resource.txt\");\n            assertThat(source.getURI(\"tomcat-resource.txt\").toString()).endsWith(\"tomcat-resource.txt\");\n        }\n    }\n}\n"}
