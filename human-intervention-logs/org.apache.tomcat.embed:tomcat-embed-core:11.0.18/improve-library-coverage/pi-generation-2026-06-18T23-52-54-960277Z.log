  package tomcat;
  
  import java.io.IOException;
  import java.io.OutputStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  
  import org.apache.catalina.Host;
  import org.apache.catalina.LifecycleState;
  import org.apache.catalina.Server;
  import org.apache.catalina.core.StandardHost;
  import org.apache.catalina.startup.HostConfig;
  import org.apache.catalina.startup.Tomcat;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class HostConfigTest {
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void deploysDescriptorsWarFilesAndExpandedDirectoriesDuringHostStartup() throws Exception {
          Path appBase = Files.createDirectory(temporaryDirectory.resolve("webapps"));
          Path configBase = Files.createDirectory(temporaryDirectory.resolve("conf"));
          Path descriptorDocBase = createWebappDirectory(temporaryDirectory.resolve("descriptor-docbase"));
          createDescriptor(configBase.resolve("descriptor.xml"), descriptorDocBase);
          createWar(appBase.resolve("warapp.war"));
          createWebappDirectory(appBase.resolve("directoryapp"));
  
          HostConfig hostConfig = new HostConfig();
          Tomcat tomcat = new Tomcat();
          tomcat.setBaseDir(temporaryDirectory.resolve("base").toString());
          StandardHost host = (StandardHost) tomcat.getHost();
          host.setAppBase(appBase.toString());
          host.setXmlBase(configBase.toString());
          host.setDeployOnStartup(true);
          host.setAutoDeploy(false);
          host.setDeployXML(true);
          host.setCopyXML(false);
          host.setUnpackWARs(false);
          host.addLifecycleListener(hostConfig);
  
          try {
              tomcat.start();
  
              assertDeployed(hostConfig, host, "/descriptor");
              assertDeployed(hostConfig, host, "/warapp");
              assertDeployed(hostConfig, host, "/directoryapp");
          } finally {
              stopAndDestroy(tomcat);
          }
      }
  
      private static Path createWebappDirectory(Path webappDirectory) throws IOException {
          Files.createDirectories(webappDirectory.resolve("WEB-INF"));
          Files.writeString(webappDirectory.resolve("index.html"), "ready");
          return webappDirectory;
      }
  
      private static void createDescriptor(Path descriptor, Path docBase) throws IOException {
          Files.writeString(descriptor, """
                  <?xml version=\"1.0\" encoding=\"UTF-8\"?>
                  <Context docBase=\"%s\" />
                  """.formatted(docBase));
      }
  
      private static void createWar(Path war) throws IOException {
          try (OutputStream output = Files.newOutputStream(war); JarOutputStream jar = new JarOutputStream(output)) {
              jar.putNextEntry(new JarEntry("WEB-INF/"));
              jar.closeEntry();
              jar.putNextEntry(new JarEntry("index.html"));
              jar.write("ready".getBytes(StandardCharsets.UTF_8));
              jar.closeEntry();
          }
      }
  
      private static void assertDeployed(HostConfig hostConfig, Host host, String name) {
          assertThat(hostConfig.isDeployed(name)).isTrue();
          assertThat(host.findChild(name)).isNotNull();
      }
  
      private static void stopAndDestroy(Tomcat tomcat) throws Exception {
          Server server = tomcat.getServer();
          try {
              if (server.getState().isAvailable()) {
                  tomcat.stop();
              }
          } finally {
              if (server.getState() != LifecycleState.DESTROYED) {
                  tomcat.destroy();
              }
          }
      }
  }
