dEngine;\nimport org.apache.catalina.realm.MessageDigestCredentialHandler;\nimport org.apache.catalina.realm.NullRealm;\nimport org.apache.catalina.realm.RealmBase;\nimport org.apache.catalina.realm.X509UsernameRetriever;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RealmBaseTest {\n\n    private final PrintStream originalOut = System.out;\n\n    @AfterEach\n    void restoreStandardOutput() {\n        System.setOut(originalOut);\n    }\n\n    @Test\n    void commandLineCredentialMutationUsesDefaultDigestCredentialHandler() throws Exception {\n        String output = captureStandardOutput(() -> RealmBase.main(new String[] {\"-a\", \"SHA-512\", \"secret\"}));\n\n        assertThat(output).startsWith(\"secret:\");\n        assertThat(output).doesNotContain(\"Usage: RealmBase\");\n    }\n\n    @Test\n    void commandLineCredentialMutationUsesConfiguredDigestCredentialHandlerClass() throws Exception {\n        String output = captureStandardOutput(() -> RealmBase.main(new String[] {\"-h\",\n                MessageDigestCredentialHandler.class.getName(), \"-a\", \"SHA-512\", \"secret\"}));\n\n        assertThat(output).startsWith(\"secret:\");\n        assertThat(output).doesNotContain(\"Usage: RealmBase\");\n    }\n\n    @Test\n    void initCreatesConfiguredX509UsernameRetrieverByClassName() throws Exception {\n        StandardEngine engine = new StandardEngine();\n        engine.setName(\"Catalina\");\n        PrincipalReturningRealm realm = new PrincipalReturningRealm();\n        realm.setContainer(engine);\n        realm.setValidate(false);\n        realm.setX509UsernameRetrieverClassName(CustomX509UsernameRetriever.class.getName());\n\n        try {\n            realm.init();\n\n            Principal principal = realm.authenticate(new X509Certificate[] {null});\n\n            assertThat(principal).isNotNull();\n            assertThat(principal.getName()).isEqualTo(\"certificate-user\");\n        } finally {\n            destroy(realm);\n        }\n    }\n\n    private String captureStandardOutput(ThrowingRunnable runnable) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        System.setOut(new PrintStream(output, true, StandardCharsets.UTF_8));\n        runnable.run();\n        return output.toString(StandardCharsets.UTF_8);\n    }\n\n    private void destroy(NullRealm realm) throws LifecycleException {\n        if (realm.getState().isAvailable()) {\n            realm.stop();\n        }\n        if (realm.getState() != LifecycleState.DESTROYED) {\n            realm.destroy();\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws IOException;\n    }\n\n    public static class CustomX509UsernameRetriever implements X509UsernameRetriever {\n\n        public CustomX509UsernameRetriever() {\n        }\n\n        @Override\n        public String getUsername(X509Certificate cert) {\n            return \"certificate-user\";\n        }\n    }\n\n    public static class PrincipalReturningRealm extends NullRealm {\n\n        @Override\n        protected Principal getPrincipal(String username) {\n            if (\"certificate-user\".equals(username)) {\n                return () -> username;\n            }\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 716, "output": 1280, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 34764, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781794647374, "responseId": "resp_064092562435914b016a340758134081938d3aa978097b05b5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_szhX0ac0SSuexQ6aEa86pxEV|fc_064092562435914b016a34075fb4f081938983a875b03256b0", "toolName": "write", "content": [{"type": "text", "text": "Succes