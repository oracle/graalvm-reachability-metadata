  package tomcat;
  
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import org.apache.catalina.Container;
  import org.apache.catalina.Context;
  import org.apache.catalina.LifecycleState;
  import org.apache.catalina.Server;
  import org.apache.catalina.core.StandardHost;
  import org.apache.catalina.startup.HomesUserDatabase;
  import org.apache.catalina.startup.Tomcat;
  import org.apache.catalina.startup.UserConfig;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UserConfigTest {
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void deploysConfiguredUserDirectoryDuringHostStartup() throws Exception {
          Path appBase = Files.createDirectory(temporaryDirectory.resolve("webapps"));
          Path homeBase = Files.createDirectory(temporaryDirectory.resolve("users"));
          Path userWebapp = createUserWebapp(homeBase.resolve("alice"));
  
          UserConfig userConfig = new UserConfig();
          userConfig.setHomeBase(homeBase.toString());
          userConfig.setUserClass(HomesUserDatabase.class.getName());
  
          Tomcat tomcat = new Tomcat();
          tomcat.setBaseDir(temporaryDirectory.resolve("base").toString());
          StandardHost host = (StandardHost) tomcat.getHost();
          host.setAppBase(appBase.toString());
          host.addLifecycleListener(userConfig);
  
          try {
              tomcat.start();
  
              Container deployed = host.findChild("/~alice");
              assertThat(deployed).isInstanceOf(Context.class);
              Context context = (Context) deployed;
              assertThat(context.getPath()).isEqualTo("/~alice");
              assertThat(context.getDocBase()).isEqualTo(userWebapp.toString());
          } finally {
              stopAndDestroy(tomcat);
          }
      }
  
      private static Path createUserWebapp(Path userHome) throws IOException {
          Path publicHtml = Files.createDirectories(userHome.resolve("public_html"));
          Files.createDirectories(publicHtml.resolve("WEB-INF"));
          Files.writeString(publicHtml.resolve("index.html"), "ready");
          return publicHtml;
      }
  
      private static void stopAndDestroy(Tomcat tomcat) throws Exception {
          Server server = tomcat.getServer();
          try {
              if (server.getState().isAvailable()) {
                  tomcat.stop();
              }
          } finally {
              if (server.getState() != LifecycleState.DESTROYED) {
                  tomcat.destroy();
              }
          }
      }
  
  }
