    tomcat.start();\n\n            Container deployed = host.findChild(\"/~alice\");\n            assertThat(deployed).isInstanceOf(Context.class);\n            Context context = (Context) deployed;\n            assertThat(context.getPath()).isEqualTo(\"/~alice\");\n            assertThat(context.getDocBase()).isEqualTo(userWebapp.toString());\n        } finally {\n            stopAndDestroy(tomcat);\n        }\n    }\n\n    private static Path createUserWebapp(Path userHome) throws IOException {\n        Path publicHtml = Files.createDirectories(userHome.resolve(\"public_html\"));\n        Files.createDirectories(publicHtml.resolve(\"WEB-INF\"));\n        Files.writeString(publicHtml.resolve(\"index.html\"), \"ready\");\n        return publicHtml;\n    }\n\n    private static void stopAndDestroy(Tomcat tomcat) throws Exception {\n        Server server = tomcat.getServer();\n        try {\n            if (server.getState().isAvailable()) {\n                tomcat.stop();\n            }\n        } finally {\n            if (server.getState() != LifecycleState.DESTROYED) {\n                tomcat.destroy();\n            }\n        }\n    }\n\n    public static class TestUserDatabase implements UserDatabase {\n\n        private UserConfig userConfig;\n\n        @Override\n        public UserConfig getUserConfig() {\n            return userConfig;\n        }\n\n        @Override\n        public void setUserConfig(UserConfig userConfig) {\n            this.userConfig = userConfig;\n        }\n\n        @Override\n        public String getHome(String user) {\n            assertThat(user).isEqualTo(\"alice\");\n            return Path.of(userConfig.getHomeBase(), user).toString();\n        }\n\n        @Override\n        public Enumeration<String> getUsers() {\n            return Collections.enumeration(Collections.singleton(\"alice\"));\n        }\n    }\n}\n"}
