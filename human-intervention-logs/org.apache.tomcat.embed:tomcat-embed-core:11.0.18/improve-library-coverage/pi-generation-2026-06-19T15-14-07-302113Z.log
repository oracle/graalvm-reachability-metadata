r());\n        try {\n            SimpleInstanceManager manager = new SimpleInstanceManager();\n\n            Object component = manager.newInstance(ContextLoadedComponent.class.getName());\n\n            assertThat(component).isInstanceOf(ContextLoadedComponent.class);\n            assertThat(((ContextLoadedComponent) component).message()).isEqualTo(\"created from context class loader\");\n        } finally {\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    @Test\n    void constructsInstanceFromExplicitClassLoaderClassName() throws Exception {\n        SimpleInstanceManager manager = new SimpleInstanceManager();\n\n        Object component = manager.newInstance(ExplicitLoaderComponent.class.getName(), testClassLoader());\n\n        assertThat(component).isInstanceOf(ExplicitLoaderComponent.class);\n        assertThat(((ExplicitLoaderComponent) component).message()).isEqualTo(\"created from explicit class loader\");\n    }\n\n    private static ClassLoader testClassLoader() {\n        return SimpleInstanceManagerTest.class.getClassLoader();\n    }\n\n    public static final class ClassObjectComponent {\n        public ClassObjectComponent() {\n        }\n\n        public String message() {\n            return \"created from class object\";\n        }\n    }\n\n    public static final class ContextLoadedComponent {\n        public ContextLoadedComponent() {\n        }\n\n        public String message() {\n            return \"created from context class loader\";\n        }\n    }\n\n    public static final class ExplicitLoaderComponent {\n        public ExplicitLoaderComponent() {\n        }\n\n        public String message() {\n            return \"created from explicit class loader\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 729, "output": 1167, "cacheRead": 16896, "cacheWrite": 0, "totalTokens": 18792, "cost": {"input": 0, "out