[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/StandardSessionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.apache.catalina.core.StandardContext;\nimport org.apache.catalina.session.StandardManager;\nimport org.apache.catalina.session.StandardSession;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class StandardSessionTest {\n\n    @Test\n    void writesAndReadsSessionData() throws Exception {\n        StandardManager manager = createManager();\n        StandardSession session = new StandardSession(manager);\n        session.setId(\"session-1\");\n        session.setValid(true);\n        session.setAttribute(\"message\", \"hello\");\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            session.writeObjectData(output);\n        }\n\n        StandardSession restored = new StandardSession(manager);\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            restored.readObjectData(input);\n        }\n        assertThat(restored.getId()).isEqualTo(\"session-1\");\n        assertThat(restored.getAttribute(\"message\")).isEqualTo(\"hello\");\n    }\n\n    private StandardManager createManager() {\n        StandardContext context = new StandardContext();\n        StandardManager manager = new StandardManager();\n        manager.setContext(context);\n        context.setManager(manager);\n        return manager;\n    }\n}\n"}
