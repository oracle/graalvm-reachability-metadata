[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/ResourceFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.util.Hashtable;\n\nimport javax.naming.Context;\nimport javax.naming.Name;\nimport javax.naming.Reference;\nimport javax.naming.spi.ObjectFactory;\n\nimport org.apache.naming.ResourceRef;\nimport org.apache.naming.factory.ResourceFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ResourceFactoryTest {\n\n    @Test\n    void createsConfiguredDefaultDataSourceFactory() throws Exception {\n        String property = \"javax.sql.DataSource.Factory\";\n        String original = System.getProperty(property);\n        System.setProperty(property, TestObjectFactory.class.getName());\n        try {\n            Object object = new ResourceFactory().getObjectInstance(\n                    new ResourceRef(\"javax.sql.DataSource\", null, null, null, true), null, null, null);\n\n            assertThat(object).isEqualTo(\"created\");\n        } finally {\n            if (original == null) {\n                System.clearProperty(property);\n            } else {\n                System.setProperty(property, original);\n            }\n        }\n    }\n\n    public static class TestObjectFactory implements ObjectFactory {\n        @Override\n        public Object getObjectInstance(Object obj, Name name, Context nameCtx, Hashtable<?,?> environment) {\n            return \"created\";\n        }\n    }\n}\n"}
