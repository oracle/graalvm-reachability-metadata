  import org.apache.naming.factory.ResourceFactory;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FactoryBaseTest {
  
      @Test
      void createsExplicitFactoryFromReference() throws Exception {
          ResourceRef ref = new ResourceRef(String.class.getName(), null, null, null, true,
                  TestObjectFactory.class.getName(), null);
  
          Object object = new ResourceFactory().getObjectInstance(ref, null, null, null);
  
          assertThat(object).isEqualTo("explicit");
      }
  
      public static class TestObjectFactory implements ObjectFactory {
          @Override
          public Object getObjectInstance(Object obj, Name name, Context nameCtx, Hashtable<?,?> environment) {
              return "explicit";
          }
      }
