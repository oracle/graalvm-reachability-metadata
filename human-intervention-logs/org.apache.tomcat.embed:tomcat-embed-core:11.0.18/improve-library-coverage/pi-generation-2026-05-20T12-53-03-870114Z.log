[tool-call] delta {"path":"tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/IntrospectionUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport org.apache.coyote.http11.Http11NioProtocol;\nimport org.apache.tomcat.util.IntrospectionUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class IntrospectionUtilsTest {\n\n    @Test\n    void invokesTypedAccessorsFallbackPropertiesAndArbitraryMethods() throws Exception {\n        AccessorBean bean = new AccessorBean();\n        assertThat(IntrospectionUtils.setProperty(bean, \"name\", \"tomcat\")).isTrue();\n        assertThat(IntrospectionUtils.setProperty(bean, \"count\", \"7\")).isTrue();\n        assertThat(IntrospectionUtils.setProperty(bean, \"enabled\", \"true\")).isTrue();\n        assertThat(IntrospectionUtils.getProperty(bean, \"name\")).isEqualTo(\"tomcat\");\n        assertThat(IntrospectionUtils.getProperty(bean, \"enabled\")).isEqualTo(Boolean.TRUE);\n        assertThat(IntrospectionUtils.callMethodN(bean, \"join\", new Object[] { \"A\", \"B\" },\n                new Class<?>[] { String.class, String.class })).isEqualTo(\"A:B\");\n\n        BooleanPropertyBean booleanPropertyBean = new BooleanPropertyBean();\n        assertThat(IntrospectionUtils.setProperty(booleanPropertyBean, \"dynamic\", \"value\")).isTrue();\n        assertThat(IntrospectionUtils.getProperty(booleanPropertyBean, \"dynamic\")).isEqualTo(\"value\");\n\n        VoidPropertyBean voidPropertyBean = new VoidPropertyBean();\n        assertThat(IntrospectionUtils.setProperty(voidPropertyBean, \"dynamic\", \"voidValue\")).isTrue();\n        assertThat(IntrospectionUtils.getProperty(voidPropertyBean, \"dynamic\")).isEqualTo(\"voidValue\");\n    }\n\n    @Test\n    void introspectsTomcatProtocolPublicPropertiesRequestedByIssue() {\n        Http11NioProtocol protocol = new Http11NioProtocol();\n        StringBuilder actualMethod = new StringBuilder();\n\n        assertThat(IntrospectionUtils.setProperty(protocol, \"port\", \"0\", true, actualMethod)).isTrue();\n        assertThat(IntrospectionUtils.getProperty(protocol, \"name\")).isInstanceOf(String.class);\n        assertThat(IntrospectionUtils.getProperty(protocol, \"SSLEnabled\")).isEqualTo(Boolean.FALSE);\n    }\n\n    public static class AccessorBean {\n        private String name;\n        private int count;\n        private boolean enabled;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public boolean isEnabled() {\n            return enabled;\n        }\n\n        public void setEnabled(boolean enabled) {\n            this.enabled = enabled;\n        }\n\n        public String join(String first, String second) {\n            return first + ':' + second;\n        }\n    }\n\n    public static class BooleanPropertyBean {\n        private String name;\n        private String value;\n\n        public boolean setProperty(String name, String value) {\n            this.name = name;\n            this.value = value;\n            return true;\n        }\n\n        public String getProperty(String name) {\n            return this.name.equals(name) ? value : null;\n        }\n    }\n\n    public static class VoidPropertyBean {\n        private String name;\n        private String value;\n\n        public void setProperty(String name, String value) {\n            this.name = name;\n            this.value = value;\n        }\n\n        public String getProperty(String name) {\n            return this.name.equals(name) ? value : null;\n        }\n    }\n}\n"}
