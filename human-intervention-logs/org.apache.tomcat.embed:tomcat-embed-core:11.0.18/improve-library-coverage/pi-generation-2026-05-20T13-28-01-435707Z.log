      private String createOperationKey(OperationInfo operation) {
          StringBuilder key = new StringBuilder(operation.getName());
          key.append('(');
          StringUtils.join(operation.getSignature(), ',', FeatureInfo::getType, key);
          key.append(')');
  
          return key.toString().intern();
      }
  
  
