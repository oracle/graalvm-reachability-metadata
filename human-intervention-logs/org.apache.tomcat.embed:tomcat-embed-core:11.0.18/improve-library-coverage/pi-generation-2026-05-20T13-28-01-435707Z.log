      @Override
      public final String getFactoryClassName() {
          String factory = super.getFactoryClassName();
          if (factory != null) {
              return factory;
          } else {
              factory = System.getProperty(Context.OBJECT_FACTORIES);
              if (factory != null) {
                  return null;
