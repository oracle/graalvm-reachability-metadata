{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,220p' tests/src/org.apache.tomcat.embed/tomcat-embed-core/11.0.18/src/test/java/tomcat/SimpleInstanceManagerTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage tomcat;\n\nimport java.lang.reflect.InvocationTargetException;\n\nimport javax.naming.NamingException;\n\nimport org.apache.tomcat.SimpleInstanceManager;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SimpleInstanceManagerTest {\n\n    @Test\n    void createsInstanceFromClassToken() throws Exception {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n\n        Object instance = instanceManager.newInstance(PublicComponent.class);\n\n        assertThat(instance).isInstanceOf(PublicComponent.class);\n        assertThat(((PublicComponent) instance).message()).isEqualTo(\"created\");\n    }\n\n    @Test\n    void createsInstanceFromClassNameUsingContextClassLoader() throws Exception {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(PublicComponent.class.getClassLoader());\n        try {\n            Object instance = instanceManager.newInstance(PublicComponent.class.getName());\n\n            assertThat(instance).isInstanceOf(PublicComponent.class);\n            assertThat(((PublicComponent) instance).message()).isEqualTo(\"created\");\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void createsInstanceFromClassNameUsingProvidedClassLoader() throws Exception {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n\n        Object instance = instanceManager.newInstance(PublicComponent.class.getName(),\n                PublicComponent.class.getClassLoader());\n\n        assertThat(instance).isInstanceOf(PublicComponent.class);\n        assertThat(((PublicComponent) instance).message()).isEqualTo(\"created\");\n    }\n\n    @Test\n    void existingInstanceLifecycleCallbacksAreNoOps() throws NamingException, InvocationTargetException,\n            IllegalAccessException {\n        SimpleInstanceManager instanceManager = new SimpleInstanceManager();\n        PublicComponent instance = new PublicComponent();\n\n        instanceManager.newInstance(instance);\n        instanceManager.destroyInstance(instance);\n\n        assertThat(instance.message()).isEqualTo(\"created\");\n    }\n\n    public static class PublicComponent {\n\n        public PublicComponent() {\n        }\n\n        String message() {\n            return \"created\";\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
