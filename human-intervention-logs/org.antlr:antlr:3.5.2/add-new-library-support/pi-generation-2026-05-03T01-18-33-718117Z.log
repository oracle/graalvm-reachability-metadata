\",\n                \"Output: none\",\n                \"Grammar option k: none\",\n                \"Grammar option backtrack: false\",\n                \"Rules: \",\n                \"Average fixed k: \",\n                \"Vocabulary size: \",\n                \"DFA creation time in ms: \",\n                \"Number of semantic predicates found: \",\n                \"Number of errors: \",\n                \"Number of warnings: \",\n                \"Number of infos: \");\n    }\n", "newText": "    @Test\n    void toStringDecodesNotifyDataIntoReadableReport() {\n        String notifyData = String.join(\"\\t\", Collections.nCopies(64, \"1\"));\n\n        String readableReport = GrammarReport.toString(notifyData);\n\n        assertThat(readableReport).contains(\n                \"ANTLR Grammar Report; Stats Version \",\n                \"Grammar: \",\n                \"Type: \",\n                \"Target language: \",\n                \"Output: \",\n                \"Grammar option k: \",\n                \"Grammar option backtrack: \",\n                \"Rules: \",\n                \"Average fixed k: \",\n                \"Vocabulary size: \",\n                \"DFA creation time in ms: \",\n                \"Number of semantic predicates found: \",\n                \"Number of errors: \",\n                \"Number of warnings: \",\n                \"Number of infos: \");\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1162, "output": 2069, "cacheRead": 34816, "cacheWrite": 0, "totalTokens": 38047, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777771162898, "responseId": "resp_0c900ddf1c4ccbcd0169f6a29b806c8192b2b94e8a7b1fcbe4"}}
