  package org_antlr.antlr;
  
  import org.antlr.tool.Grammar;
  import org.antlr.tool.GrammarReport;
  import org.junit.jupiter.api.Test;
  
  import java.util.Collections;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class GrammarReportTest {
      private static final int REPORT_FIELD_COUNT = 31;
  
      @Test
      void toNotifyStringSerializesGrammarReportData() throws Exception {
          Grammar grammar = new Grammar("""
                  grammar T;
                  s : 'a' | 'b';
                  """);
  
          String notifyData = new GrammarReport(grammar).toNotifyString();
  
          String[] values = notifyData.split("\\t", -1);
          assertThat(values).hasSize(REPORT_FIELD_COUNT);
          assertThat(values[0]).isEqualTo(GrammarReport.Version);
          assertThat(values[1]).isEqualTo("T");
          assertThat(values[2]).isEqualTo("combined");
          assertThat(values[3]).isEqualTo("Java");
          assertThat(values[28]).isEqualTo("none");
          assertThat(values[29]).isEqualTo("none");
          assertThat(values[30]).isEqualTo("false");
      }
  
      @Test
      void toStringDecodesNotifyDataIntoReadableReport() {
          String notifyData = String.join("\t", Collections.nCopies(64, "1"));
  
          String readableReport = GrammarReport.toString(notifyData);
  
          assertThat(readableReport).contains(
                  "ANTLR Grammar Report; Stats Version ",
                  "Grammar: ",
                  "Type: ",
                  "Target language: ",
                  "Output: ",
                  "Grammar option k: ",
                  "Grammar option backtrack: ",
                  "Rules: ",
                  "Average fixed k: ",
                  "Vocabulary size: ",
                  "DFA creation time in ms: ",
                  "Number of semantic predicates found: ",
                  "Number of errors: ",
                  "Number of warnings: ",
                  "Number of infos: ");
      }
  }
