  	public IntSet getAllCharValues() {
  		if ( charVocabulary!=null ) {
  			return charVocabulary;
  		}
  		IntSet allChar = IntervalSet.of(Label.MIN_CHAR_VALUE, getMaxCharValue());
  		return allChar;
  	}
  
