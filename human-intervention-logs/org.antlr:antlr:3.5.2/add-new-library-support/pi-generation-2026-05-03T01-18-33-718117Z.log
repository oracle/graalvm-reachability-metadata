       7	package org_antlr.antlr;
       8	
       9	import org.antlr.tool.Grammar;
      10	import org.antlr.tool.GrammarReport;
      11	import org.junit.jupiter.api.Test;
      12	
      13	import static org.assertj.core.api.Assertions.assertThat;
      14	
      15	public class GrammarReportTest {
      16	    private static final int REPORT_FIELD_COUNT = 31;
      17	
      18	    @Test
      19	    void toNotifyStringSerializesGrammarReportData() throws Exception {
      20	        Grammar grammar = new Grammar("""
      21	                grammar T;
      22	                s : 'a' | 'b';
      23	                """);
      24	
      25	        String notifyData = new GrammarReport(grammar).toNotifyString();
      26	
      27	        String[] values = notifyData.split("\\t", -1);
      28	        assertThat(values).hasSize(REPORT_FIELD_COUNT);
      29	        assertThat(values[0]).isEqualTo(GrammarReport.Version);
      30	        assertThat(values[1]).isEqualTo("T");
      31	        assertThat(values[2]).isEqualTo("combined");
      32	        assertThat(values[3]).isEqualTo("Java");
      33	        assertThat(values[28]).isEqualTo("none");
      34	        assertThat(values[29]).isEqualTo("none");
      35	        assertThat(values[30]).isEqualTo("false");
      36	    }
      37	
      38	    @Test
      39	    void toStringDecodesNotifyDataIntoReadableReport() throws Exception {
      40	        Grammar grammar = new Grammar("""
      41	                grammar T;
      42	                s : 'a' | 'b';
      43	                """);
      44	        String notifyData = new GrammarReport(grammar).toNotifyString();
      45	
      46	        String readableReport = GrammarReport.toString(notifyData);
      47	
      48	        assertThat(readableReport).contains(
      49	                "ANTLR Grammar Report; Stats Version " + GrammarReport.Version,
      50	                "Grammar: T",
      51	                "Type: combined",
      52	                "Target language: Java",
      53	                "Output: none",
      54	                "Grammar option k: none",
      55	                "Grammar option backtrack: false",
      56	                "Rules: ",
