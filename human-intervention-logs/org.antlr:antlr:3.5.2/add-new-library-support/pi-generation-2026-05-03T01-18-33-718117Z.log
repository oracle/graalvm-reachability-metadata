= GrammarReport.toString(notifyData);\n\n        assertThat(readableReport).contains(\n                \"ANTLR Grammar Report; Stats Version 5\",\n                \"Grammar: Example\",\n                \"Type: parser\",\n                \"Target language: Java\",\n                \"Output: AST\",\n                \"Grammar option k: *\",\n                \"Grammar option backtrack: true\",\n                \"Rules: 3\",\n                \"Outer productions: 4\",\n                \"Decisions: 6\",\n                \"Decisions (ignoring decisions in synpreds): 5\",\n                \"Fixed k DFA decisions: 8\",\n                \"Cyclic DFA decisions: 7\",\n                \"LL(1) decisions: 9\",\n                \"Min fixed k: 1\",\n                \"Max fixed k: 3\",\n                \"Average fixed k: 2.5\",\n                \"Vocabulary size: 99\",\n                \"DFA creation time in ms: 123\",\n                \"Number of semantic predicates found: 10\",\n                \"Decisions with semantic predicates: 20\",\n                \"Decision DFAs using semantic predicates: 21\",\n                \"Number of (likely) non-LL(*) decisions: 12\",\n                \"Number of nondeterministic decisions: 13\",\n                \"Number of nondeterministic decisions resolved with predicates: 14\",\n                \"Number of manual or forced fixed lookahead k=value options: 11\",\n                \"Number of errors: 15\",\n                \"Number of warnings: 16\",\n                \"Number of infos: 17\");\n    }\n}\n"}
