  +        String xml = "<!DOCTYPE root ["
  +                + "<!NOTATION plain SYSTEM 'text/plain'>"
  +                + "<!ENTITY logo SYSTEM 'logo.txt' NDATA plain>"
  +                + "<!ENTITY author 'Ada'>"
  +                + "]><root>&author;</root>";
  +        XMLEventReader reader = factory.createXMLEventReader(new StringReader(xml));
