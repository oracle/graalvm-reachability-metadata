  +                dtd = (DTD) event;
  +            } else if (event.isEntityReference()) {
  +                reference = (EntityReference) event;
  +            }
  +        }
  +        reader.close();
  +
  +        assertThat(dtd).isNotNull();
  +        assertThat(dtd.getDocumentTypeDeclaration()).contains("ENTITY author", "NOTATION plain");
