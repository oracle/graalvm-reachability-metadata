  object Responses {
    final class ContinueOps[F[_], G[_]](val status: Continue.type)
        extends AnyVal
        with EmptyResponseGenerator[F, G]
    // TODO support Upgrade header
    final class SwitchingProtocolsOps[F[_], G[_]](val status: SwitchingProtocols.type)
