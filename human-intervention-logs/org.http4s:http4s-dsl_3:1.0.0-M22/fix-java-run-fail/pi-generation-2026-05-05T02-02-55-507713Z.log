a.Kleisli\nimport cats.data.OptionT\n", "newText": ""}, {"oldText": "  private val authedRoutes: AuthedRoutes[String, IO] = Kleisli { request =>\n    toOptionT(authedResponse(request))\n  }\n\n  private val routes: HttpRoutes[IO] = Kleisli { request =>\n    toOptionT(routeResponse(request))\n  }\n\n  private def toOptionT(response: Option[IO[Response[IO]]]): OptionT[IO, Response[IO]] =\n    response match {\n      case Some(value) => OptionT.liftF(value)\n      case None => OptionT.none[IO, Response[IO]]\n    }\n\n", "newText": "  private val authedRoutes: AuthedRoutes[String, IO] = AuthedRoutes.of[String, IO](AuthedRouteMatcher)\n\n  private val routes: HttpRoutes[IO] = HttpRoutes.of[IO](RouteMatcher)\n\n  private object AuthedRouteMatcher extends PartialFunction[AuthedRequest[IO, String], IO[Response[IO]]] {\n    override def isDefinedAt(request: AuthedRequest[IO, String]): Boolean = authedResponse(request).isDefined\n\n    override def apply(request: AuthedRequest[IO, String]): IO[Response[IO]] = authedResponse(request).get\n  }\n\n  private object RouteMatcher extends PartialFunction[Request[IO], IO[Response[IO]]] {\n    override def isDefinedAt(request: Request[IO]): Boolean = routeResponse(request).isDefined\n\n    override def apply(request: Request[IO]): IO[Response[IO]] = routeResponse(request).get\n  }\n\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3568, "output": 1558, "cacheRead": 67584, "cacheWrite": 0, "totalTokens": 72710, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777946730489, "responseId": "resp_08a4777009257f480169f9506b0dbc81a097e36526c122e66d"}}
