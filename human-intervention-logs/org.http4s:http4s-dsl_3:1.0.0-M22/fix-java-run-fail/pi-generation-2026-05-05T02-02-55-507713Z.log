und)).unsafeRunSync()\n\n  def bodyText(response: Response[IO]): String = response.as[String].unsafeRunSync()\n\n  private object AuthedRouteMatcher extends PartialFunction[AuthedRequest[IO, String], IO[Response[IO]]] {\n    override def isDefinedAt(request: AuthedRequest[IO, String]): Boolean = authedResponse(request).isDefined\n\n    override def apply(request: AuthedRequest[IO, String]): IO[Response[IO]] = authedResponse(request).get\n  }\n\n  private object RouteMatcher extends PartialFunction[Request[IO], IO[Response[IO]]] {\n    override def isDefinedAt(request: Request[IO]): Boolean = routeResponse(request).isDefined\n\n    override def apply(request: Request[IO]): IO[Response[IO]] = routeResponse(request).get\n  }\n\n  private def authedResponse(request: AuthedRequest[IO, String]): Option[IO[Response[IO]]] =\n    request match {\n      case GET -> Root / \"profile\" as user =>\n        Some(Ok(s\"authenticated:$user\"))\n      case _ =>\n        None\n    }\n\n  private def routeResponse(request: Request[IO]): Option[IO[Response[IO]]] =\n    request match {\n      case GET -> Root / \"users\" / LongVar(userId) =>\n        Some(Ok(s\"user:$userId\"))\n\n      case GET -> Root / \"audits\" / UUIDVar(requestId) =>\n        Some(Ok(s\"audit:$requestId\"))\n\n      case GET -> Root / \"assets\" / (baseName ~ extension) =>\n        Some(Ok(s\"asset:$baseName:$extension\"))\n\n      case GET -> Root / \"board\" / BoardSquare(IntVar(x), IntVar(y)) =>\n        Some(Ok(s\"square:$x,$y\"))\n\n      case GET -> \"docs\" /: remaining =>\n        Some(Ok(s\"section=docs,remaining=${remaining.segments.map(_.decoded()).mkString(\"/\")}\"))\n\n      case (GET | HEAD) -> Root / \"health\" =>\n        Some(NoContent())\n\n      case GET -> Root / \"items\" :? LimitParam(limit) +& PageParam(page) +& SortParam(sort) +& DetailsFlag(details) +& TagParams(tags) =>\n        Some(tags.fold(\n          failures => BadRequest(failures.toList.map(_.sanitized).mkString(\"\\n\")),\n      