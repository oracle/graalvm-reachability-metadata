[tool-call] delta {"path":"tests/src/org.http4s/http4s-dsl_3/1.0.0-M22/src/test/scala/org_http4s/http4s_dsl_3/Http4s_dsl_3Test.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_http4s.http4s_dsl_3\n\nimport cats.Id\nimport org.http4s.AuthedRequest\nimport org.http4s.Method\nimport org.http4s.Request\nimport org.http4s.Response\nimport org.http4s.Status\nimport org.http4s.Uri\nimport org.http4s.dsl.Http4sDsl\nimport org.http4s.dsl.impl.FlagQueryParamMatcher\nimport org.http4s.dsl.impl.MatrixVar\nimport org.http4s.dsl.impl.OptionalMultiQueryParamDecoderMatcher\nimport org.http4s.dsl.impl.OptionalQueryParamDecoderMatcher\nimport org.http4s.dsl.impl.OptionalValidatingQueryParamDecoderMatcher\nimport org.http4s.dsl.impl.QueryParamDecoderMatcher\nimport org.http4s.dsl.impl.ValidatingQueryParamDecoderMatcher\nimport org.http4s.headers.Allow\nimport org.http4s.headers.Location\nimport org.http4s.implicits.*\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\n\nimport java.util.UUID\n\nclass Http4s_dsl_3Test {\n  import Http4sDsl3Support.*\n\n  @Test\n  def typedPathExtractorsAndFileExtensionRoutesSelectExpectedResponses(): Unit = {\n    val userId: Long = 922337203685477580L\n    val userResult: RouteResult = run(Request[Id](Method.GET, Uri.unsafeFromString(s\"/users/$userId\")))\n    assertEquals(Status.Ok, userResult.status)\n    assertEquals(s\"user:$userId\", userResult.body)\n\n    val requestId: UUID = UUID.fromString(\"123e4567-e89b-12d3-a456-426614174000\")\n    val auditResult: RouteResult = run(Request[Id](Method.GET, Uri.unsafeFromString(s\"/audits/$requestId\")))\n    assertEquals(Status.Ok, auditResult.status)\n    assertEquals(\"audit:123e4567-e89b-12d3-a456-426614174000\", auditResult.body)\n\n    val assetResult: RouteResult = run(Request[Id](Method.GET, uri\"/assets/report.final.json\"))\n    assertEquals(Status.Ok, assetResult.status)\n    assertEquals(\"asset:report.final:json\", assetResult.body)\n\n    val invalidLongResult: RouteResult = run(Request[Id](Method.GET, uri\"/users/not-a-number\"))\n    assertEquals(Status.NotFound, invalidLongResult.status)\n  }\n\n  @Test\n  def matrixVariablesAndHeadGetMethodConcatMatchStructuredPaths(): Unit = {\n    val matrixResult: RouteResult = run(Request[Id](Method.GET, uri\"/board/square;x=5;y=3\"))\n    assertEquals(Status.Ok, matrixResult.status)\n    assertEquals(\"square:5,3\", matrixResult.body)\n\n    val matrixWithReorderedVariables: RouteResult = run(Request[Id](Method.GET, uri\"/board/square;y=7;x=2\"))\n    assertEquals(Status.Ok, matrixWithReorderedVariables.status)\n    assertEquals(\"square:2,7\", matrixWithReorderedVariables.body)\n\n    val badMatrixResult: RouteResult = run(Request[Id](Method.GET, uri\"/board/square;x=bad;y=3\"))\n    assertEquals(Status.NotFound, badMatrixResult.status)\n\n    val getHealthResult: RouteResult = run(Request[Id](Method.GET, uri\"/health\"))\n    assertEquals(Status.NoContent, getHealthResult.status)\n\n    val headHealthResult: RouteResult = run(Request[Id](Method.HEAD, uri\"/health\"))\n    assertEquals(Status.NoContent, headHealthResult.status)\n  }\n\n  @Test\n  def requiredOptionalDefaultFlagAndRepeatedQueryParametersCompose(): Unit = {\n    val result: RouteResult = run(Request[Id](Method.GET, uri\"/items?limit=10&page=3&sort=name&details&tag=scala&tag=native\"))\n    assertEquals(Status.Ok, result.status)\n    assertEquals(\"limit=10,page=3,sort=name,details=true,tags=scala|native\", result.body)\n\n    val defaultedResult: RouteResult = run(Request[Id](Method.GET, uri\"/items?limit=2\"))\n    assertEquals(Status.Ok, defaultedResult.status)\n    assertEquals(\"limit=2,page=1,sort=none,details=false,tags=\", defaultedResult.body)\n\n    val invalidRequiredParameter: RouteResult = run(Request[Id](Method.GET, uri\"/items?limit=abc\"))\n    assertEquals(Status.NotFound, invalidRequiredParameter.status)\n\n    val invalidRepeatedParameter: RouteResult = run(Request[Id](Method.GET, uri\"/numbers?n=1&n=bad&n=3\"))\n    assertEquals(Status.BadRequest, invalidRepeatedParameter.status)\n\n    val repeatedNumbers: RouteResult = run(Request[Id](Method.GET, uri\"/numbers?n=1&n=2&n=3\"))\n    assertEquals(Status.Ok, repeatedNumbers.status)\n    assertEquals(\"sum=6\", repeatedNumbers.body)\n  }\n\n  @Test\n  def validatingQueryParametersExposeParseFailuresWithoutBypassingRoutes(): Unit = {\n    val valid: RouteResult = run(Request[Id](Method.GET, uri\"/validate?age=42&score=98.5\"))\n    assertEquals(Status.Ok, valid.status)\n    assertEquals(\"age=42,score=98.5\", valid.body)\n\n    val missingOptional: RouteResult = run(Request[Id](Method.GET, uri\"/validate?age=42\"))\n    assertEquals(Status.Ok, missingOptional.status)\n    assertEquals(\"age=42,score=missing\", missingOptional.body)\n\n    val invalidAge: RouteResult = run(Request[Id](Method.GET, uri\"/validate?age=old\"))\n    assertEquals(Status.BadRequest, invalidAge.status)\n    assertTrue(invalidAge.body.contains(\"age\"))\n\n    val invalidScore: RouteResult = run(Request[Id](Method.GET, uri\"/validate?age=42&score=excellent\"))\n    assertEquals(Status.BadRequest, invalidScore.status)\n    assertTrue(invalidScore.body.contains(\"score\"))\n\n    val missingRequiredAge: RouteResult = run(Request[Id](Method.GET, uri\"/validate?score=1.0\"))\n    assertEquals(Status.NotFound, missingRequiredAge.status)\n  }\n\n  @Test\n  def prefixPathExtractorCapturesFirstSegmentAndRemainingRelativePath(): Unit = {\n    val nested: RouteResult = run(Request[Id](Method.GET, uri\"/docs/guides/native-image\"))\n    assertEquals(Status.Ok, nested.status)\n    assertEquals(\"section=docs,remaining=guides/native-image\", nested.body)\n\n    val emptyTail: RouteResult = run(Request[Id](Method.GET, uri\"/docs\"))\n    assertEquals(Status.Ok, emptyTail.status)\n    assertEquals(\"section=docs,remaining=\", emptyTail.body)\n\n    val unmatchedPrefix: RouteResult = run(Request[Id](Method.GET, uri\"/articles/guides/native-image\"))\n    assertEquals(Status.NotFound, unmatchedPrefix.status)\n  }\n\n  @Test\n  def responseGeneratorsCreateExpectedStatusHeadersAndEmptyResponses(): Unit = {\n    val generated: GeneratedResponses = generatedResponses()\n    assertEquals(Status.Created, generated.created.status)\n    assertEquals(Status.NoContent, generated.noContent.status)\n    assertEquals(Status.SeeOther, generated.redirect.status)\n    assertEquals(Some(Location(uri\"/target\")), generated.redirect.headers.get[Location])\n    assertEquals(Status.MethodNotAllowed, generated.notAllowed.status)\n    assertEquals(Some(Allow(Set(Method.GET, Method.PUT))), generated.notAllowed.headers.get[Allow])\n\n    val gone: RouteResult = run(Request[Id](Method.DELETE, uri\"/temporary\"))\n    assertEquals(Status.Gone, gone.status)\n    assertEquals(\"removed\", gone.body)\n  }\n\n  @Test\n  def methodResourceExtractorProducesAllowedResponsesAndMethodErrors(): Unit = {\n    val read: RouteResult = run(Request[Id](Method.GET, uri\"/resource\"))\n    assertEquals(Status.Ok, read.status)\n    assertEquals(\"read\", read.body)\n\n    val updated: RouteResult = run(Request[Id](Method.PUT, uri\"/resource\"))\n    assertEquals(Status.Created, updated.status)\n    assertEquals(\"updated\", updated.body)\n\n    val notAllowed: RouteResult = run(Request[Id](Method.POST, uri\"/resource\"))\n    assertEquals(Status.MethodNotAllowed, notAllowed.status)\n    assertEquals(Some(Allow(Set(Method.GET, Method.PUT))), notAllowed.allow)\n  }\n\n  @Test\n  def authedRoutesExtractAuthenticatedContextWithDslAsMatcher(): Unit = {\n    val result: RouteResult = runAuthed(\"test-user\", Request[Id](Method.GET, uri\"/profile\"))\n    assertEquals(Status.Ok, result.status)\n    assertEquals(\"authenticated:test-user\", result.body)\n  }\n}\n\nobject Http4sDsl3Support {\n  final case class RouteResult(\n      status: Status,\n      body: String = \"\",\n      allow: Option[Allow] = None,\n      location: Option[Location] = None)\n\n  final case class GeneratedResponses(\n      created: Response[Id],\n      noContent: Response[Id],\n      redirect: Response[Id],\n      notAllowed: Response[Id])\n\n  private object Dsl extends Http4sDsl[Id]\n  import Dsl.*\n\n  private object LimitParam extends QueryParamDecoderMatcher[Int](\"limit\")\n  private object PageParam extends OptionalQueryParamDecoderMatcher[Int](\"page\")\n  private object SortParam extends OptionalQueryParamDecoderMatcher[String](\"sort\")\n  private object DetailsFlag extends FlagQueryParamMatcher(\"details\")\n  private object TagParams extends OptionalMultiQueryParamDecoderMatcher[String](\"tag\")\n  private object NumbersParam extends OptionalMultiQueryParamDecoderMatcher[Int](\"n\")\n  private object AgeParam extends ValidatingQueryParamDecoderMatcher[Int](\"age\")\n  private object ScoreParam extends OptionalValidatingQueryParamDecoderMatcher[Double](\"score\")\n  private object BoardSquare extends MatrixVar[List](\"square\", List(\"x\", \"y\"))\n\n  def run(request: Request[Id]): RouteResult = routeResult(request).getOrElse(RouteResult(Status.NotFound))\n\n  def runAuthed(user: String, request: Request[Id]): RouteResult =\n    authedResult(AuthedRequest(user, request)).getOrElse(RouteResult(Status.NotFound))\n\n  def generatedResponses(): GeneratedResponses =\n    GeneratedResponses(\n      Created(),\n      NoContent(),\n      SeeOther(Location(uri\"/target\")),\n      MethodNotAllowed(Allow(Set(GET, PUT))))\n\n  private def authedResult(request: AuthedRequest[Id, String]): Option[RouteResult] =\n    request match {\n      case GET -> Root / \"profile\" as user =>\n        Some(RouteResult(Status.Ok, s\"authenticated:$user\"))\n      case _ =>\n        None\n    }\n\n  private def routeResult(request: Request[Id]): Option[RouteResult] =\n    request match {\n      case GET -> Root / \"users\" / LongVar(userId) =>\n        Some(RouteResult(Status.Ok, s\"user:$userId\"))\n\n      case GET -> Root / \"audits\" / UUIDVar(requestId) =>\n        Some(RouteResult(Status.Ok, s\"audit:$requestId\"))\n\n      case GET -> Root / \"assets\" / (baseName ~ extension) =>\n        Some(RouteResult(Status.Ok, s\"asset:$baseName:$extension\"))\n\n      case GET -> Root / \"board\" / BoardSquare(IntVar(x), IntVar(y)) =>\n        Some(RouteResult(Status.Ok, s\"square:$x,$y\"))\n\n      case GET -> \"docs\" /: remaining =>\n        Some(RouteResult(Status.Ok, s\"section=docs,remaining=${remaining.segments.map(_.decoded()).mkString(\"/\")}\"))\n\n      case (GET | HEAD) -> Root / \"health\" =>\n        Some(RouteResult(Status.NoContent))\n\n      case GET -> Root / \"items\" :? LimitParam(limit) +& PageParam(page) +& SortParam(sort) +& DetailsFlag(details) +& TagParams(tags) =>\n        Some(tags.fold(\n          failures => RouteResult(Status.BadRequest, failures.toList.map(_.sanitized).mkString(\"\\n\")),\n          values =>\n            RouteResult(\n              Status.Ok,\n              s\"limit=$limit,page=${page.getOrElse(1)},sort=${sort.getOrElse(\"none\")},details=$details,tags=${values.mkString(\"|\")}\")\n        ))\n\n      case GET -> Root / \"numbers\" :? NumbersParam(numbers) =>\n        Some(numbers.fold(\n          failures => RouteResult(Status.BadRequest, failures.toList.map(_.sanitized).mkString(\"\\n\")),\n          values => RouteResult(Status.Ok, s\"sum=${values.sum}\")\n        ))\n\n      case GET -> Root / \"validate\" :? AgeParam(age) +& ScoreParam(score) =>\n        Some(age.fold(\n          failures => RouteResult(Status.BadRequest, failures.toList.map(failure => s\"age:${failure.sanitized}\").mkString(\"\\n\")),\n          ageValue => score match {\n            case Some(scoreValue) =>\n              scoreValue.fold(\n                failures => RouteResult(Status.BadRequest, failures.toList.map(failure => s\"score:${failure.sanitized}\").mkString(\"\\n\")),\n                value => RouteResult(Status.Ok, s\"age=$ageValue,score=$value\")\n              )\n            case None =>\n              RouteResult(Status.Ok, s\"age=$ageValue,score=missing\")\n          }\n        ))\n\n      case DELETE -> Root / \"temporary\" =>\n        Some(RouteResult(Status.Gone, \"removed\"))\n\n      case method -> Root / \"resource\" =>\n        Some(method match {\n          case GET => RouteResult(Status.Ok, \"read\")\n          case PUT => RouteResult(Status.Created, \"updated\")\n          case _ => RouteResult(Status.MethodNotAllowed, allow = Some(Allow(Set(GET, PUT))))\n        })\n\n      case _ =>\n        None\n    }\n}\n"}
