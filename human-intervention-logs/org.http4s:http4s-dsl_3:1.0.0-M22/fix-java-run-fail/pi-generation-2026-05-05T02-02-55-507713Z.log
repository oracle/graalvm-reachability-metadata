,o); ln,o=u4(data,o); name=cp[nameidx]\n        if name=='EnclosingMethod':\n            ci=struct.unpack('>H',data[o:o+2])[0]; mi=struct.unpack('>H',data[o+2:o+4])[0]\n            if mi==0: encl=True; encl_class=ci\n        if name=='Signature': sig=True\n        o+=ln\n    return encl, sig\n\nfound=[]\nfor jar in sorted(set(jars)):\n    try:\n      with zipfile.ZipFile(jar) as z:\n        for n in z.namelist():\n          if n.endswith('.class'):\n            r=parse(z.read(n))\n            if r and r[0] and r[1]: found.append((jar,n))\n    except Exception as e: pass\nfor jar,n in found[:200]: print(jar, n)\nprint('count',len(found))\nPY","timeout":60}
