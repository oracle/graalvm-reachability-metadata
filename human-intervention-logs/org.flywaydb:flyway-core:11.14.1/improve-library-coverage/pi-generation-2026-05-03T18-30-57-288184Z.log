      public String getLicenseKey() {
          return null;
      }
  
      @Override
      public int getPriority() {
          return -100;
      }
  
      @Override
      public Plugin copy() {
          return this;
      }
  
      @Override
      public boolean isStub() {
          return true;
      }
  }
