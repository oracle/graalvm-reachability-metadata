    @Override
    public boolean equals(Object obj) {
      if (obj instanceof ProviderMethod) {
        ProviderMethod o = (ProviderMethod)obj;
        return method.equals(o.method)
           && instance.equals(o.instance);
      } else {
        return false;
      }
    }
    
    @Override
