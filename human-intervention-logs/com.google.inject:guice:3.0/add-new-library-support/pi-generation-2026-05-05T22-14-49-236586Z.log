[tool-call] delta {"path":"tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerEmitUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport com.google.inject.internal.asm.$ClassReader;\nimport com.google.inject.internal.asm.$ClassWriter;\nimport com.google.inject.internal.asm.$Type;\nimport com.google.inject.internal.cglib.core.$ClassEmitter;\nimport com.google.inject.internal.cglib.core.$Constants;\nimport com.google.inject.internal.cglib.core.$CodeEmitter;\nimport com.google.inject.internal.cglib.core.$EmitUtils;\nimport com.google.inject.internal.cglib.core.$Signature;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InnerEmitUtilsTest {\n    @Test\n    void emitsClassArrayWhenPushingAsmTypeArrayConstant() {\n        $ClassWriter writer = new $ClassWriter($ClassWriter.COMPUTE_MAXS);\n        $ClassEmitter emitter = new $ClassEmitter(writer);\n        emitter.begin_class($Constants.V1_6, $Constants.ACC_PUBLIC,\n                \"com_google_inject/guice/generated/EmitUtilsTypeArrayProbe\", $Constants.TYPE_OBJECT,\n                $Constants.TYPES_EMPTY, \"EmitUtilsTypeArrayProbe.java\");\n\n        $CodeEmitter constructor = emitter.begin_method($Constants.ACC_PUBLIC,\n                new $Signature($Constants.CONSTRUCTOR_NAME, \"()V\"), $Constants.TYPES_EMPTY);\n        constructor.load_this();\n        constructor.super_invoke_constructor();\n        constructor.return_value();\n        constructor.end_method();\n\n        $CodeEmitter method = emitter.begin_method($Constants.ACC_PUBLIC | $Constants.ACC_STATIC,\n                new $Signature(\"constantTypes\", $Constants.TYPE_OBJECT_ARRAY, $Constants.TYPES_EMPTY),\n                $Constants.TYPES_EMPTY);\n        $EmitUtils.push_array(method, new $Type[] {$Type.getType(String.class), $Type.getType(Integer.class)});\n        method.return_value();\n        method.end_method();\n        emitter.end_class();\n\n        byte[] bytecode = writer.toByteArray();\n        $ClassReader reader = new $ClassReader(bytecode);\n\n        assertThat(bytecode).isNotEmpty();\n        assertThat(reader.getClassName()).isEqualTo(\"com_google_inject/guice/generated/EmitUtilsTypeArrayProbe\");\n    }\n}\n"}
