  package com_google_inject.guice;
  
  import com.google.inject.internal.asm.$ClassReader;
  import com.google.inject.internal.asm.$ClassWriter;
  import com.google.inject.internal.asm.$Label;
  import com.google.inject.internal.asm.$MethodVisitor;
  import com.google.inject.internal.asm.$Opcodes;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerClassWriterTest {
      @Test
      void computesFramesForMethodThatMergesSiblingJdkTypes() {
          $ClassWriter writer = new $ClassWriter($ClassWriter.COMPUTE_FRAMES);
          writer.visit($Opcodes.V1_6, $Opcodes.ACC_PUBLIC, "com_google_inject/guice/generated/FrameMergeProbe",
                  null, "java/lang/Object", null);
          writeDefaultConstructor(writer);
          writeChooseImplementationMethod(writer);
          writer.visitEnd();
  
          byte[] bytecode = writer.toByteArray();
          $ClassReader reader = new $ClassReader(bytecode);
  
          assertThat(bytecode).isNotEmpty();
          assertThat(reader.getClassName()).isEqualTo("com_google_inject/guice/generated/FrameMergeProbe");
      }
  
      @Test
      void computesCommonSuperclassForRelatedApplicationTypes() {
          CommonSuperClassWriter writer = new CommonSuperClassWriter();
  
          String commonSuperClass = writer.commonSuperClass(typeName(BaseImplementation.class),
                  typeName(LeftImplementation.class));
  
          assertThat(commonSuperClass).isEqualTo(typeName(BaseImplementation.class));
      }
  
      @Test
      void computesNearestCommonSuperclassForSiblingApplicationTypes() {
          CommonSuperClassWriter writer = new CommonSuperClassWriter();
  
          String commonSuperClass = writer.commonSuperClass(typeName(LeftImplementation.class),
                  typeName(RightImplementation.class));
  
          assertThat(commonSuperClass).isEqualTo(typeName(BaseImplementation.class));
      }
  
      private static void writeDefaultConstructor($ClassWriter writer) {
          $MethodVisitor method = writer.visitMethod($Opcodes.ACC_PUBLIC, "<init>", "()V", null, null);
          method.visitCode();
          method.visitVarInsn($Opcodes.ALOAD, 0);
          method.visitMethodInsn($Opcodes.INVOKESPECIAL, "java/lang/Object", "<init>", "()V");
          method.visitInsn($Opcodes.RETURN);
          method.visitMaxs(0, 0);
          method.visitEnd();
      }
  
      private static void writeChooseImplementationMethod($ClassWriter writer) {
          $MethodVisitor method = writer.visitMethod($Opcodes.ACC_PUBLIC | $Opcodes.ACC_STATIC, "chooseImplementation",
                  "(Z)L" + typeName(BaseImplementation.class) + ";", null, null);
          $Label useRightImplementation = new $Label();
          $Label returnImplementation = new $Label();
  
          method.visitCode();
          method.visitVarInsn($Opcodes.ILOAD, 0);
          method.visitJumpInsn($Opcodes.IFNE, useRightImplementation);
          method.visitTypeInsn($Opcodes.NEW, typeName(LeftImplementation.class));
          method.visitInsn($Opcodes.DUP);
          method.visitMethodInsn($Opcodes.INVOKESPECIAL, typeName(LeftImplementation.class), "<init>", "()V");
          method.visitJumpInsn($Opcodes.GOTO, returnImplementation);
          method.visitLabel(useRightImplementation);
          method.visitTypeInsn($Opcodes.NEW, typeName(RightImplementation.class));
          method.visitInsn($Opcodes.DUP);
          method.visitMethodInsn($Opcodes.INVOKESPECIAL, typeName(RightImplementation.class), "<init>", "()V");
          method.visitLabel(returnImplementation);
          method.visitInsn($Opcodes.ARETURN);
          method.visitMaxs(0, 0);
          method.visitEnd();
      }
  
      private static String typeName(Class<?> type) {
          return type.getName().replace('.', '/');
      }
  
      private static class BaseImplementation {
      }
  
      private static final class LeftImplementation extends BaseImplementation {
      }
  
      private static final class RightImplementation extends BaseImplementation {
      }
  
      private static final class CommonSuperClassWriter extends $ClassWriter {
          private CommonSuperClassWriter() {
              super($ClassWriter.COMPUTE_FRAMES);
          }
  
          private String commonSuperClass(String firstType, String secondType) {
              return getCommonSuperClass(firstType, secondType);
          }
      }
  }
