  package com_google_inject.guice;
  
  import com.google.inject.internal.cglib.proxy.$Enhancer;
  import com.google.inject.internal.cglib.proxy.$MethodInterceptor;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerEnhancerTest {
      @Test
      void createsSubclassProxyAndInstallsCallbacksThroughGeneratedSetters() throws Throwable {
          $MethodInterceptor interceptor = (object, method, arguments, methodProxy) -> {
              if ("greet".equals(method.getName())) {
                  return "proxied " + arguments[0];
              }
              return methodProxy.invokeSuper(object, arguments);
          };
  
          try {
              EnhanceableService proxy = (EnhanceableService) $Enhancer.create(EnhanceableService.class, interceptor);
  
              assertThat($Enhancer.isEnhanced(proxy.getClass())).isTrue();
              assertThat(proxy.greet("Guice")).isEqualTo("proxied Guice");
              assertThat(proxy.callSuper()).isEqualTo("super");
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (RuntimeException exception) {
              rethrowUnlessNativeImageDynamicClassLoadingError(exception);
          }
      }
  
      private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {
          if (hasNativeImageUnsupportedFeatureError(throwable)) {
              return;
          }
          throw throwable;
      }
  
      private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public static class EnhanceableService {
          public String greet(String name) {
              return "hello " + name;
          }
  
          public String callSuper() {
              return "super";
          }
      }
  }
