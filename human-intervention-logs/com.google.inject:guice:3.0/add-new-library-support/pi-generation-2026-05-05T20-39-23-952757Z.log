  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package com_google_inject.guice;
  
  import com.google.inject.AbstractModule;
  import com.google.inject.Guice;
  import com.google.inject.Inject;
  import com.google.inject.Injector;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConstructionContextTest {
      @Test
      void createsCircularDependencyProxyForInterfaceConstructorCycle() {
          Injector injector = Guice.createInjector(new AbstractModule() {
              @Override
              protected void configure() {
                  bind(FirstService.class).to(FirstServiceImpl.class);
                  bind(SecondService.class).to(SecondServiceImpl.class);
              }
          });
  
          FirstService firstService = injector.getInstance(FirstService.class);
  
          assertThat(firstService.name()).isEqualTo("first");
          assertThat(firstService.secondName()).isEqualTo("second");
          assertThat(firstService.nameThroughCircularReference()).isEqualTo("first");
      }
  
      public interface FirstService {
          String name();
  
          String secondName();
  
          String nameThroughCircularReference();
      }
  
      public interface SecondService {
          String name();
  
          String firstName();
      }
  
      public static class FirstServiceImpl implements FirstService {
          private final SecondService secondService;
  
          @Inject
          public FirstServiceImpl(SecondService secondService) {
              this.secondService = secondService;
          }
  
          @Override
          public String name() {
              return "first";
          }
  
          @Override
          public String secondName() {
              return secondService.name();
          }
  
          @Override
          public String nameThroughCircularReference() {
              return secondService.firstName();
          }
      }
  
      public static class SecondServiceImpl implements SecondService {
          private final FirstService firstService;
  
          @Inject
          public SecondServiceImpl(FirstService firstService) {
              this.firstService = firstService;
          }
  
          @Override
          public String name() {
              return "second";
          }
  
          @Override
          public String firstName() {
              return firstService.name();
          }
      }
  }
