ect.spi.InjectionPoint;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InjectionPointTest {\n    @Test\n    void discoversInjectAnnotatedAndImplicitNoArgumentConstructors() {\n        InjectionPoint annotatedConstructor = InjectionPoint.forConstructorOf(\n                TypeLiteral.get(AnnotatedConstructorService.class)\n        );\n\n        assertThat(annotatedConstructor.getMember().getDeclaringClass())\n                .isSameAs(AnnotatedConstructorService.class);\n        assertThat(annotatedConstructor.getDependencies()).hasSize(1);\n        Dependency<?> constructorDependency = annotatedConstructor.getDependencies().get(0);\n        assertThat(constructorDependency.getKey().getTypeLiteral().getRawType())\n                .isSameAs(String.class);\n\n        InjectionPoint defaultConstructor = InjectionPoint.forConstructorOf(\n                DefaultConstructorService.class\n        );\n\n        assertThat(defaultConstructor.getMember().getDeclaringClass())\n                .isSameAs(DefaultConstructorService.class);\n        assertThat(defaultConstructor.getDependencies()).isEmpty();\n    }\n\n    @Test\n    void discoversFieldAndMethodInjectionPointsIncludingScalaStyleAccessor() {\n        Set<InjectionPoint> instanceInjectionPoints = InjectionPoint.forInstanceMethodsAndFields(\n                MemberInjectionTarget.class\n        );\n\n        assertThat(instanceInjectionPoints)\n                .extracting(InjectionPointTest::memberName)\n                .contains(\"baseDependency\", \"instanceDependency\", \"initialize\", \"accessor\");\n        assertThat(instanceInjectionPoints)\n                .filteredOn(injectionPoint -> \"accessor\".equals(memberName(injectionPoint)))\n                .singleElement()\n                .satisfies(injectionPoint -> assertThat(injectionPoint.getDependencies())\n                        .isEmpty());\n\n        Set<InjectionPoint> staticInjectionPoints = InjectionPoint.forStaticMethodsAndFields(\n                MemberInjectionTarget.class\n        );\n\n        assertThat(staticInjectionPoints)\n                .extracting(InjectionPointTest::memberName)\n                .contains(\"staticDependency\", \"configure\");\n    }\n\n    private static String memberName(InjectionPoint injectionPoint) {\n        Member member = injectionPoint.getMember();\n        return member.getName();\n    }\n\n    public static class AnnotatedConstructorService {\n        @Inject\n        public AnnotatedConstructorService(@Named(\"constructor\") String value) {\n        }\n    }\n\n    public static class DefaultConstructorService {\n        public DefaultConstructorService() {\n        }\n    }\n\n    public static class BaseMemberInjectionTarget {\n        @Inject\n        String baseDependency;\n    }\n\n    public static class MemberInjectionTarget extends BaseMemberInjectionTarget {\n        @Inject\n        String instanceDependency;\n\n        @Inject\n        static Integer staticDependency;\n\n        private String accessor;\n\n        @Inject\n        void initialize(@Named(\"method\") String value) {\n        }\n\n        @Inject\n        @Named(\"scala-style-accessor\")\n        void accessor() {\n        }\n\n        @Inject\n        static void configure(Double value) {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778015779722}, {"role": "toolResult", "toolCallId": "call_4fEuTabkzIOKMiewp5lLk9He|fc_028ddac22068f50b0169fa5e233f44819ebb1fb446e3a6bf9c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"com.google.inject:guice:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.register('systemClassLoaderJar', Jar) {\n    dependsOn tasks.named('compileTestJava')\n    archiveClassifier = 'system-class-loader'\n    from(sourceSets.test.output.classesDirs) {\n        include 'com_google_inject/guice/DenyGuiceFinalizerSystemClassLoader.class'\n    }\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn tasks.named('systemClassLoaderJar')\n    String systemClassLoader = 'com_google_inject.guice.DenyGuiceFinalizerSystemClassLoader'\n    jvmArgs \"--add-opens=java.base/java.lang=ALL-UNNAMED\"\n    jvmArgs \"-Djava.system.class.loader=$systemClassLoader\"\n    doFirst {\n        File systemClassLoaderJar = tasks.named('systemClassLoaderJar').get().archiveFile.get().asFile\n        jvmArgs \"-Xbootclasspath/a:${systemClassLoaderJar.absolutePath}\"\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n    binaries {\n        all {\n            buildArgs.add(\"--add-opens=java.base/java.lang=ALL-UNNAMED\")\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778015779722}, {"role": "toolResult", "toolCallId": "call_EnO3BntDJIVBBEVRLrZC21VY|fc_028ddac22068f50b0169fa5e233f4c819e87d769fec1519595", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.util.Arrays;\nimport java.util.List;\n\nimport com.google.inject.Key;\nimport com.google.inject.TypeLiteral;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MoreTypesTest {\n    @Test\n    void resolvesRawClassForGenericArrayTypeLiterals() {\n        TypeLiteral<List<String>[]> arrayLiteral = new TypeLiteral<List<String>[]>() {\n        };\n\n        Class<? super List<String>[]> rawType = arrayLiteral.getRawType();\n\n        assertThat(rawType).isSameAs(List[].class);\n        assertThat(rawType.isArray()).isTrue();\n        assertThat(rawType.getComponentType()).isSameAs(List.class);\n    }\n\n    @Test\n    void genericArrayTypeLiteralCanBeUsedAsAGuiceKey() {\n        TypeLiteral<List<String>[]> arrayLiteral = new TypeLiteral<List<String>[]>() {\n        };\n        List<String>[] values = listArray(Arrays.asList(\"alpha\"), Arrays.asList(\"beta\"));\n\n        Key<List<String>[]> key = Key.get(arrayLiteral);\n\n        assertThat(key.getTypeLiteral().getRawType()).isSameAs(List[].class);\n        assertThat(arrayLiteral.getRawType().isInstance(values)).isTrue();\n        assertThat(values[0]).containsExactly(\"alpha\");\n        assertThat(values[1]).containsExactly(\"beta\");\n    }\n\n    @SafeVarargs\n    private static List<String>[] listArray(List<String>... values) {\n        return values;\n    }\n}\n"}], "isError": false, "timestamp": 1778015779722}]}
