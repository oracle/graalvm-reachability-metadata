jectionModule extends AbstractModule {\n        private final Greeting greeting;\n\n        private FieldInjectionModule(Greeting greeting) {\n            this.greeting = greeting;\n        }\n\n        @Override\n        protected void configure() {\n            bind(Greeting.class).toInstance(greeting);\n        }\n    }\n\n    public static final class FieldInjectedService {\n        @Inject\n        private Greeting greeting;\n\n        Greeting greeting() {\n            return greeting;\n        }\n\n        String message() {\n            return greeting.message();\n        }\n    }\n\n    public static final class Greeting {\n        private final String message;\n\n        Greeting(String message) {\n            this.message = message;\n        }\n\n        String message() {\n            return message;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778015786377}]}
