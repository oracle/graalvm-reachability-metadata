static String typeName(Class<?> type) {\n        return type.getName().replace('.', '/');\n    }\n\n    private static class BaseImplementation {\n    }\n\n    private static final class LeftImplementation extends BaseImplementation {\n    }\n\n    private static final class RightImplementation extends BaseImplementation {\n    }\n\n    private static final class CommonSuperClassWriter extends $ClassWriter {\n        private CommonSuperClassWriter() {\n            super($ClassWriter.COMPUTE_FRAMES);\n        }\n\n        private String commonSuperClass(String firstType, String secondType) {\n            return getCommonSuperClass(firstType, secondType);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778018341777}]}
