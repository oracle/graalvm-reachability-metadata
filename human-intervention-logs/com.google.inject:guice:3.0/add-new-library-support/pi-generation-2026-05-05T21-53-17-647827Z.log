  package com_google_inject.guice;
  
  import com.google.inject.internal.asm.$ClassWriter;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerClassWriterTest {
      @Test
      void computesCommonSuperclassForRelatedJdkTypes() {
          CommonSuperClassWriter writer = new CommonSuperClassWriter();
  
          String commonSuperClass = writer.commonSuperClass("java/util/ArrayList", "java/util/List");
  
          assertThat(commonSuperClass).isEqualTo("java/util/List");
      }
  
      @Test
      void computesNearestCommonSuperclassForSiblingJdkTypes() {
          CommonSuperClassWriter writer = new CommonSuperClassWriter();
  
          String commonSuperClass = writer.commonSuperClass("java/util/ArrayList", "java/util/LinkedList");
  
          assertThat(commonSuperClass).isEqualTo("java/util/AbstractList");
      }
  
      private static final class CommonSuperClassWriter extends $ClassWriter {
          private CommonSuperClassWriter() {
              super($ClassWriter.COMPUTE_FRAMES);
          }
  
          private String commonSuperClass(String firstType, String secondType) {
              return getCommonSuperClass(firstType, secondType);
          }
      }
  }
