      void computesCommonSuperclassForRelatedJdkTypes() {
          CommonSuperClassWriter writer = new CommonSuperClassWriter();
  
          String commonSuperClass = writer.commonSuperClass("java/util/ArrayList", "java/util/List");
  
          assertThat(commonSuperClass).isEqualTo("java/util/List");
