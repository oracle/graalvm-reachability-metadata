[tool-call] delta {"path":"tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerFinalizerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\n\nimport com.google.inject.internal.util.$FinalizableReferenceQueue;\nimport com.google.inject.internal.util.$FinalizableWeakReference;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InnerFinalizerTest {\n    @Test\n    void invokesFinalizeReferentForEnqueuedReference() throws InterruptedException {\n        $FinalizableReferenceQueue queue = new $FinalizableReferenceQueue();\n        CountDownLatch finalized = new CountDownLatch(1);\n        Object referent = new Object();\n        TestFinalizableWeakReference reference = new TestFinalizableWeakReference(referent, queue, finalized);\n\n        assertThat(reference.enqueue()).isTrue();\n\n        assertThat(finalized.await(5, TimeUnit.SECONDS)).isTrue();\n    }\n\n    private static final class TestFinalizableWeakReference extends $FinalizableWeakReference<Object> {\n        private final CountDownLatch finalized;\n\n        private TestFinalizableWeakReference(\n                Object referent,\n                $FinalizableReferenceQueue queue,\n                CountDownLatch finalized\n        ) {\n            super(referent, queue);\n            this.finalized = finalized;\n        }\n\n        @Override\n        public void finalizeReferent() {\n            finalized.countDown();\n        }\n    }\n}\n"}
