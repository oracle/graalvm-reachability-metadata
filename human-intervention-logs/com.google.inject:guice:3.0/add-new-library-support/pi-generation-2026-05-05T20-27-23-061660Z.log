  package com_google_inject.guice;
  
  import java.io.File;
  import java.net.MalformedURLException;
  import java.net.URL;
  import java.net.URLClassLoader;
  
  public final class DenyGuiceFinalizerSystemClassLoader extends URLClassLoader {
      private static final String FINALIZER_CLASS_NAME = "com.google.inject.internal.util.$Finalizer";
  
      public DenyGuiceFinalizerSystemClassLoader(ClassLoader parent) {
          super(new URL[0], parent);
      }
  
      @Override
      protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
          if (isGuiceFinalizerClass(name)) {
              throw new ClassNotFoundException(name);
          }
          return super.loadClass(name, resolve);
      }
  
      @SuppressWarnings("unused")
      public void appendToClassPathForInstrumentation(String path) throws MalformedURLException {
          addURL(new File(path).toURI().toURL());
      }
  
      private static boolean isGuiceFinalizerClass(String name) {
          return name.equals(FINALIZER_CLASS_NAME) || name.startsWith(FINALIZER_CLASS_NAME + "$");
      }
