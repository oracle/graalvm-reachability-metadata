  package com_google_inject.guice;
  
  import com.google.inject.internal.cglib.core.$NamingPolicy;
  import com.google.inject.internal.cglib.core.$Predicate;
  import com.google.inject.internal.cglib.proxy.$Enhancer;
  import com.google.inject.internal.cglib.proxy.$NoOp;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import java.net.URL;
  import java.net.URLClassLoader;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerAbstractClassGeneratorTest {
      private static final String GENERATED_CLASS_NAME = "com_google_inject.guice.GeneratedEnhanceableServiceProxy";
  
      @Test
      void attemptLoadChecksClassLoaderForGeneratedEnhancerBeforeDefiningIt() throws Throwable {
          try (URLClassLoader classLoader = new URLClassLoader(new URL[0], EnhanceableService.class.getClassLoader())) {
              try {
                  Class<?> generatedClass = newEnhancer(classLoader, false).createClass();
                  Class<?> loadedClass = newEnhancer(classLoader, true).createClass();
  
                  assertThat($Enhancer.isEnhanced(generatedClass)).isTrue();
                  assertThat(loadedClass).isSameAs(generatedClass);
                  assertThat(loadedClass.getClassLoader()).isSameAs(classLoader);
              } catch (Error error) {
                  rethrowUnlessNativeImageDynamicClassLoadingError(error);
              } catch (RuntimeException exception) {
                  rethrowUnlessNativeImageDynamicClassLoadingError(exception);
              }
          }
      }
  
      private static $Enhancer newEnhancer(ClassLoader classLoader, boolean attemptLoad) {
          $Enhancer enhancer = new $Enhancer();
          enhancer.setSuperclass(EnhanceableService.class);
          enhancer.setCallbackType($NoOp.class);
          enhancer.setClassLoader(classLoader);
          enhancer.setNamingPolicy(new FixedNamingPolicy());
          enhancer.setUseCache(false);
          enhancer.setAttemptLoad(attemptLoad);
          return enhancer;
      }
  
      private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {
          if (hasNativeImageUnsupportedFeatureError(throwable)) {
              return;
          }
          throw throwable;
      }
  
      private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public static class EnhanceableService {
          public String value() {
              return "generated";
          }
      }
  
      private static final class FixedNamingPolicy implements $NamingPolicy {
          @Override
          public String getClassName(String prefix, String source, Object key, $Predicate names) {
              return GENERATED_CLASS_NAME;
          }
      }
  
  }
