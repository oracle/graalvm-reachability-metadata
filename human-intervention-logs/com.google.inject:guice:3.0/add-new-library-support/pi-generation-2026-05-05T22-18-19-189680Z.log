          try {
              ChildFirstClassLoader userClassLoader = new ChildFirstClassLoader(
                      BytecodeGenInnerBridgeClassLoaderTest.class.getClassLoader());
              Class<?> targetClass = userClassLoader.loadClass(TARGET_CLASS_NAME);
  
              assertThat(targetClass.getClassLoader()).isSameAs(userClassLoader);
  
              ClassLoader bridgeClassLoader = BytecodeGen.getClassLoader(targetClass);
              Class<?> bytecodeGenClass = bridgeClassLoader.loadClass(BytecodeGen.class.getName());
  
              assertThat(bytecodeGenClass).isSameAs(BytecodeGen.class);
              assertThat(bridgeClassLoader).isNotSameAs(userClassLoader);
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (RuntimeException exception) {
