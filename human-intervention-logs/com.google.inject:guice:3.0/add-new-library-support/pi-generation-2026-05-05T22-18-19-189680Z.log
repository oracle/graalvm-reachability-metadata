  package com_google_inject.guice;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.Method;
  import java.util.Arrays;
  import java.util.LinkedList;
  import java.util.Set;
  import java.util.TreeSet;
  
  import com.google.inject.internal.cglib.core.$MethodWrapper;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerMethodWrapperTest {
      private static final String METHOD_WRAPPER_KEY_CLASS_NAME =
              "com.google.inject.internal.cglib.core.$MethodWrapper$MethodWrapperKey";
  
      @Test
      void classNameHelperLoadsMethodWrapperKeyType() throws Throwable {
          try {
              MethodHandle classNameHelper = MethodHandles.privateLookupIn($MethodWrapper.class, MethodHandles.lookup())
                      .findStatic($MethodWrapper.class, "class$", MethodType.methodType(Class.class, String.class));
  
              Class<?> keyType = (Class<?>) classNameHelper.invoke(METHOD_WRAPPER_KEY_CLASS_NAME);
  
              assertThat(keyType.getName()).isEqualTo(METHOD_WRAPPER_KEY_CLASS_NAME);
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (RuntimeException exception) {
              rethrowUnlessNativeImageDynamicClassLoadingError(exception);
          }
      }
  
      @Test
      void createsStableKeysForEquivalentMethodSignatures() throws Throwable {
          Method treeSetSize = TreeSet.class.getMethod("size");
          Method linkedListSize = LinkedList.class.getMethod("size");
          Method linkedListGet = LinkedList.class.getMethod("get", int.class);
  
          try {
              Object treeSetSizeKey = $MethodWrapper.create(treeSetSize);
              Object linkedListSizeKey = $MethodWrapper.create(linkedListSize);
              Object linkedListGetKey = $MethodWrapper.create(linkedListGet);
  
              assertThat(treeSetSizeKey).isEqualTo(linkedListSizeKey);
              assertThat(treeSetSizeKey).isNotEqualTo(linkedListGetKey);
  
              Set<Object> methodKeys = $MethodWrapper.createSet(Arrays.asList(treeSetSize, linkedListSize, linkedListGet));
              assertThat(methodKeys).containsExactlyInAnyOrder(treeSetSizeKey, linkedListGetKey);
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (RuntimeException exception) {
              rethrowUnlessNativeImageDynamicClassLoadingError(exception);
          }
      }
  
      private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {
          if (hasNativeImageUnsupportedFeatureError(throwable)) {
              return;
          }
          throw throwable;
      }
  
      private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  }
