  package com_google_inject.guice;
  
  import com.google.inject.internal.cglib.proxy.$Dispatcher;
  import com.google.inject.internal.cglib.proxy.$Enhancer;
  import com.google.inject.internal.cglib.proxy.$FixedValue;
  import com.google.inject.internal.cglib.proxy.$MethodInterceptor;
  import com.google.inject.internal.cglib.proxy.$MethodProxy;
  import com.google.inject.internal.cglib.proxy.$NoOp;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.Method;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatCode;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class InnerCallbackInfoTest {
      private static final String CALLBACK_INFO_CLASS_NAME =
              "com.google.inject.internal.cglib.proxy.$CallbackInfo";
      private static final String METHOD_INTERCEPTOR_CLASS_NAME =
              "com.google.inject.internal.cglib.proxy.$MethodInterceptor";
  
      @Test
      void classNameHelperLoadsCallbackContractType() throws Throwable {
          Class<?> callbackInfoClass = Class.forName(CALLBACK_INFO_CLASS_NAME);
          MethodHandle classNameHelper = MethodHandles.privateLookupIn(callbackInfoClass, MethodHandles.lookup())
                  .findStatic(callbackInfoClass, "class$", MethodType.methodType(Class.class, String.class));
  
          Class<?> callbackType = (Class<?>) classNameHelper.invoke(METHOD_INTERCEPTOR_CLASS_NAME);
  
          assertThat(callbackType).isSameAs($MethodInterceptor.class);
      }
  
      @Test
      void callbackTypeConfigurationAcceptsBuiltInCallbackContracts() {
          $Enhancer enhancer = new $Enhancer();
  
          assertThatCode(() -> enhancer.setCallbackTypes(new Class<?>[] {
              $NoOp.class,
              $MethodInterceptor.class,
              $Dispatcher.class,
              $FixedValue.class
          })).doesNotThrowAnyException();
      }
  
      @Test
      void callbackTypeConfigurationRejectsAmbiguousCallbackContracts() {
          $Enhancer enhancer = new $Enhancer();
  
          assertThatThrownBy(() -> enhancer.setCallbackType(AmbiguousCallback.class))
              .isInstanceOf(IllegalStateException.class)
              .hasMessageContaining("Callback implements both");
      }
  
      private static final class AmbiguousCallback implements $MethodInterceptor, $Dispatcher {
          @Override
          public Object intercept(Object object, Method method, Object[] arguments, $MethodProxy methodProxy) {
              return null;
          }
  
          @Override
          public Object loadObject() {
              return new Object();
          }
      }
  }
