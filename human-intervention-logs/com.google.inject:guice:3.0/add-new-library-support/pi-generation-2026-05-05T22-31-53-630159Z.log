     assertThatCode(() -> enhancer.setCallbackTypes(new Class<?>[] {\n            $NoOp.class,\n            $MethodInterceptor.class,\n            $Dispatcher.class,\n            $FixedValue.class\n        })).doesNotThrowAnyException();\n    }\n\n    @Test\n    void callbackTypeConfigurationRejectsAmbiguousCallbackContracts() {\n        $Enhancer enhancer = new $Enhancer();\n\n        assertThatThrownBy(() -> enhancer.setCallbackType(AmbiguousCallback.class))\n            .isInstanceOf(IllegalStateException.class)\n            .hasMessageContaining(\"Callback implements both\");\n    }\n\n    private static final class AmbiguousCallback implements $MethodInterceptor, $Dispatcher {\n        @Override\n        public Object intercept(Object object, Method method, Object[] arguments, Object methodProxy) {\n            return null;\n        }\n\n        @Override\n        public Object loadObject() {\n            return new Object();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1032, "output": 1249, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 33001, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778020250310, "responseId": "resp_0f9b4183d2d767f90169fa6f9b1be48192a87804f3c024150b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_13GxFoA2EEUTuvOx4OwuTxZX|fc_0f9b4183d2d767f90169fa6fa704d081928ce640fcc53da966", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1833 bytes to tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerCallbackInfoTest.java"}], "isError": false, "timestamp": 1778020265695}]}
