object, arguments);\n        };\n\n        try {\n            GreetingService proxy = (GreetingService) $Enhancer.create(GreetingService.class, interceptor);\n\n            assertThat(proxy.greet(\"Guice\")).isEqualTo(\"proxied Guice\");\n\n            $Signature signature = interceptedSignature.get();\n            assertThat(signature).isNotNull();\n\n            $MethodProxy foundProxy = $MethodProxy.find(proxy.getClass(), signature);\n            assertThat(foundProxy).isNotNull();\n            assertThat(foundProxy.getSignature()).isEqualTo(signature);\n            assertThat(foundProxy.invokeSuper(proxy, new Object[] {\"native image\"})).isEqualTo(\"hello native image\");\n        } catch (Error error) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\n        } catch (RuntimeException exception) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n        }\n    }\n\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\n            return;\n        }\n        throw throwable;\n    }\n\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3201, "output": 1731, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 27460, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUs