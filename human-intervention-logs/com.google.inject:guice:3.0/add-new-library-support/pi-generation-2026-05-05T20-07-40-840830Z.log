[tool-call] delta {"path":"tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/FinalizableReferenceQueueInnerDecoupledLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport com.google.inject.internal.util.$FinalizableReferenceQueue;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FinalizableReferenceQueueInnerDecoupledLoaderTest {\n    private static final String QUEUE_CLASS_NAME = \"com.google.inject.internal.util.$FinalizableReferenceQueue\";\n    private static final String ORIGINAL_FINALIZER_NAME = \"com.google.inject.internal.util.$Finalizer\";\n    private static final String DECOUPLED_FINALIZER_NAME = \"com_google_inject.guice.DecoupledFinalizer\";\n    private static final String ORIGINAL_FINALIZER_PATH = ORIGINAL_FINALIZER_NAME.replace('.', '/') + \".class\";\n    private static final String DECOUPLED_FINALIZER_PATH = DECOUPLED_FINALIZER_NAME.replace('.', '/') + \".class\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void loadsFinalizerFromDecoupledClassLoaderResourceBase() throws Exception {\n        try {\n            assertThat(ORIGINAL_FINALIZER_NAME).hasSize(DECOUPLED_FINALIZER_NAME.length());\n            writeDecoupledFinalizerClass();\n\n            URL[] resourceUrls = {temporaryDirectory.toUri().toURL()};\n            try (DecoupledQueueLoader loader = new DecoupledQueueLoader(resourceUrls)) {\n                Class<?> queueClass = Class.forName(QUEUE_CLASS_NAME, true, loader);\n\n                assertThat(queueClass.getName()).isEqualTo(QUEUE_CLASS_NAME);\n                assertThat(queueClass.getClassLoader()).isSameAs(loader);\n            }\n        } catch (Error error) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\n        } catch (Exception exception) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n        }\n    }\n\n    private void writeDecoupledFinalizerClass() throws IOException {\n        Path finalizerClass = temporaryDirectory.resolve(DECOUPLED_FINALIZER_PATH);\n        Files.createDirectories(finalizerClass.getParent());\n        Files.write(finalizerClass, relocatedFinalizerBytes(readClassBytes(ORIGINAL_FINALIZER_PATH)));\n    }\n\n    private static byte[] relocatedFinalizerBytes(byte[] bytes) {\n        byte[] relocated = replace(bytes, ORIGINAL_FINALIZER_NAME, DECOUPLED_FINALIZER_NAME);\n        return replace(\n                relocated,\n                ORIGINAL_FINALIZER_NAME.replace('.', '/'),\n                DECOUPLED_FINALIZER_NAME.replace('.', '/')\n        );\n    }\n\n    private static byte[] readClassBytes(String resourcePath) throws IOException {\n        ClassLoader loader = $FinalizableReferenceQueue.class.getClassLoader();\n        try (InputStream stream = loader.getResourceAsStream(resourcePath)) {\n            assertThat(stream).as(resourcePath).isNotNull();\n            return stream.readAllBytes();\n        }\n    }\n\n    private static byte[] replace(byte[] bytes, String original, String replacement) {\n        assertThat(original).hasSize(replacement.length());\n        byte[] source = original.getBytes(java.nio.charset.StandardCharsets.UTF_8);\n        byte[] target = replacement.getBytes(java.nio.charset.StandardCharsets.UTF_8);\n        byte[] result = bytes.clone();\n        for (int index = 0; index <= result.length - source.length; index++) {\n            if (matches(result, source, index)) {\n                System.arraycopy(target, 0, result, index, target.length);\n                index += source.length - 1;\n            }\n        }\n        return result;\n    }\n\n    private static boolean matches(byte[] bytes, byte[] pattern, int offset) {\n        for (int index = 0; index < pattern.length; index++) {\n            if (bytes[offset + index] != pattern[index]) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Exception {\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\n            return;\n        }\n        if (throwable instanceof Exception exception) {\n            throw exception;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n    }\n\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static final class DecoupledQueueLoader extends URLClassLoader {\n        DecoupledQueueLoader(URL[] urls) {\n            super(urls, $FinalizableReferenceQueue.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (isQueueClass(name)) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (isQueueClass(name)) {\n                try {\n                    byte[] bytes = relocatedFinalizerBytes(readClassBytes(name.replace('.', '/') + \".class\"));\n                    return defineClass(name, bytes, 0, bytes.length);\n                } catch (IOException exception) {\n                    throw new ClassNotFoundException(name, exception);\n                }\n            }\n            return super.findClass(name);\n        }\n\n        private static boolean isQueueClass(String name) {\n            return name.equals(QUEUE_CLASS_NAME) || name.startsWith(QUEUE_CLASS_NAME + \"$\");\n        }\n    }\n}\n"}
