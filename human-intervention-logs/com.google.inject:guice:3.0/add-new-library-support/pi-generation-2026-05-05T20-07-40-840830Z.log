[tool-call] delta {"path":"tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerFinalizableReferenceQueueInnerDecoupledLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport com.google.inject.internal.util.$FinalizableReferenceQueue;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InnerFinalizableReferenceQueueInnerDecoupledLoaderTest {\n    private static final String FINALIZER_CLASS_NAME = \"com.google.inject.internal.util.$Finalizer\";\n\n    @Test\n    void startsFinalizableReferenceQueueWithDecoupledFinalizerLoader() {\n        $FinalizableReferenceQueue queue = new $FinalizableReferenceQueue();\n\n        assertThat(queue).isNotNull();\n    }\n\n    public static final class DenyGuiceFinalizerSystemClassLoader extends ClassLoader {\n        public DenyGuiceFinalizerSystemClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (isGuiceFinalizerClass(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private static boolean isGuiceFinalizerClass(String name) {\n            return name.equals(FINALIZER_CLASS_NAME) || name.startsWith(FINALIZER_CLASS_NAME + \"$\");\n        }\n    }\n}\n"}
