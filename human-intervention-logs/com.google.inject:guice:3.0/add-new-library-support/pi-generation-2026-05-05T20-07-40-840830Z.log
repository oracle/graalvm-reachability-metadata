.google.inject.spi.InjectionPoint;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InjectionPointTest {\n    @Test\n    void discoversInjectAnnotatedAndImplicitNoArgumentConstructors() {\n        InjectionPoint annotatedConstructor = InjectionPoint.forConstructorOf(\n                TypeLiteral.get(AnnotatedConstructorService.class)\n        );\n\n        assertThat(annotatedConstructor.getMember().getDeclaringClass())\n                .isSameAs(AnnotatedConstructorService.class);\n        assertThat(annotatedConstructor.getDependencies()).hasSize(1);\n        Dependency<?> constructorDependency = annotatedConstructor.getDependencies().get(0);\n        assertThat(constructorDependency.getKey().getTypeLiteral().getRawType())\n                .isSameAs(String.class);\n\n        InjectionPoint defaultConstructor = InjectionPoint.forConstructorOf(\n                DefaultConstructorService.class\n        );\n\n        assertThat(defaultConstructor.getMember().getDeclaringClass())\n                .isSameAs(DefaultConstructorService.class);\n        assertThat(defaultConstructor.getDependencies()).isEmpty();\n    }\n\n    @Test\n    void discoversFieldAndMethodInjectionPointsIncludingScalaStyleAccessor() {\n        Set<InjectionPoint> instanceInjectionPoints = InjectionPoint.forInstanceMethodsAndFields(\n                MemberInjectionTarget.class\n        );\n\n        assertThat(instanceInjectionPoints)\n                .extracting(InjectionPointTest::memberName)\n                .contains(\"baseDependency\", \"instanceDependency\", \"initialize\", \"accessor\");\n        assertThat(instanceInjectionPoints)\n                .filteredOn(injectionPoint -> \"accessor\".equals(memberName(injectionPoint)))\n                .singleElement()\n                .satisfies(injectionPoint -> assertThat(injectionPoint.getDependencies())\n                        .isEmpty());\n\n        Set<InjectionPoint> staticInjectionPoints = InjectionPoint.forStaticMethodsAndFields(\n                MemberInjectionTarget.class\n        );\n\n        assertThat(staticInjectionPoints)\n                .extracting(InjectionPointTest::memberName)\n                .contains(\"staticDependency\", \"configure\");\n    }\n\n    private static String memberName(InjectionPoint injectionPoint) {\n        Member member = injectionPoint.getMember();\n        return member.getName();\n    }\n\n    public static class AnnotatedConstructorService {\n        @Inject\n        public AnnotatedConstructorService(@Named(\"constructor\") String value) {\n        }\n    }\n\n    public static class DefaultConstructorService {\n        public DefaultConstructorService() {\n        }\n    }\n\n    public static class BaseMemberInjectionTarget {\n        @Inject\n        String baseDependency;\n    }\n\n    public static class MemberInjectionTarget extends BaseMemberInjectionTarget {\n        @Inject\n        String instanceDependency;\n\n        @Inject\n        static Integer staticDependency;\n\n        private String accessor;\n\n        @Inject\n        void initialize(@Named(\"method\") String value) {\n        }\n\n        @Inject\n        @Named(\"scala-style-accessor\")\n        void accessor() {\n        }\n\n        @Inject\n        static void configure(Double value) {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778011469880}, {"role": "toolResult", "toolCallId": "call_nzgjBMlQUF6HyI311ATGEQQf|fc_0546e149f87d035b0169fa4d4da34081968c13b1493b0852e1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\nimport java.util.ArrayList;\nimport java.util.Base64;\nimport java.util.List;\n\nimport com.google.inject.internal.cglib.core.$ReflectUtils;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectUtilsTest {\n    private static final String GENERATED_CLASS_NAME = \"com_google_inject.guice.GeneratedByReflectUtils\";\n\n    @Test\n    void resolvesConstructorsAndMethodsFromCglibStyleDescriptors() {\n        Constructor constructor = $ReflectUtils.findConstructor(\"String(byte[])\");\n        assertThat(constructor.getDeclaringClass()).isSameAs(String.class);\n        assertThat(constructor.getParameterTypes()).containsExactly(byte[].class);\n\n        Method substring = $ReflectUtils.findMethod(\"java.lang.String.substring(int, int)\");\n        assertThat(substring.getDeclaringClass()).isSameAs(String.class);\n        assertThat(substring.getName()).isEqualTo(\"substring\");\n        assertThat(substring.getParameterTypes()).containsExactly(int.class, int.class);\n    }\n\n    @Test\n    void instantiatesObjectsAndDiscoversMethodsAcrossClassHierarchy() throws Exception {\n        Constructed instance = (Constructed) $ReflectUtils.newInstance(\n                Constructed.class,\n                new Class[] {String.class},\n                new Object[] {\"created\"}\n        );\n        assertThat(instance.value()).isEqualTo(\"created\");\n\n        Constructor constructor = $ReflectUtils.getConstructor(Constructed.class, new Class[] {String.class});\n        Constructed directInstance = (Constructed) $ReflectUtils.newInstance(constructor, new Object[] {\"direct\"});\n        assertThat(directInstance.value()).isEqualTo(\"direct\");\n\n        Method inherited = $ReflectUtils.findDeclaredMethod(ChildType.class, \"baseValue\", new Class[0]);\n        assertThat(inherited.getDeclaringClass()).isSameAs(BaseType.class);\n\n        List<Method> methods = new ArrayList<>();\n        $ReflectUtils.addAllMethods(ChildType.class, methods);\n        assertThat(methods).extracting(Method::getName)\n                .contains(\"childValue\", \"baseValue\", \"interfaceValue\");\n\n        Method factoryMethod = $ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);\n        assertThat(factoryMethod.getName()).isEqualTo(\"newInstance\");\n    }\n\n    @Test\n    void definesClassBytesWithTargetLoader() throws Exception {\n        try {\n            Class<?> generated = $ReflectUtils.defineClass(\n                    GENERATED_CLASS_NAME,\n                    generatedClassBytes(),\n                    ReflectUtilsTest.class.getClassLoader()\n            );\n\n            assertThat(generated.getName()).isEqualTo(GENERATED_CLASS_NAME);\n            assertThat(generated.getClassLoader()).isSameAs(ReflectUtilsTest.class.getClassLoader());\n        } catch (Error error) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\n        } catch (Exception exception) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n        }\n    }\n\n    private static byte[] generatedClassBytes() {\n        return Base64.getMimeDecoder().decode(\"\"\"\n                yv66vgAAADQACgoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW\n                BwAIAQAvY29tX2dvb2dsZV9pbmplY3QvZ3VpY2UvR2VuZXJhdGVkQnlSZWZsZWN0VXRpbHMBAARD\n                b2RlADEABwACAAAAAAABAAEABQAGAAEACQAAABEAAQABAAAABSq3AAGxAAAAAAAA\n                \"\"\");\n    }\n\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Exception {\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\n            return;\n        }\n        if (throwable instanceof Exception exception) {\n            throw exception;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n    }\n\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public interface SingleMethodFactory {\n        Object newInstance();\n    }\n\n    public interface MarkerInterface {\n        String interfaceValue();\n    }\n\n    public static class BaseType {\n        public String baseValue() {\n            return \"base\";\n        }\n    }\n\n    public static class ChildType extends BaseType implements MarkerInterface {\n        public String childValue() {\n            return \"child\";\n        }\n\n        @Override\n        public String interfaceValue() {\n            return \"interface\";\n        }\n    }\n\n    public static class Constructed {\n        private final String value;\n\n        public Constructed(String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778011469880}, {"role": "toolResult", "toolCallId": "call_wCtG4KwTFCCY8dvSC7eeTg96|fc_0546e149f87d035b0169fa4d4da34881968e2d47a78aeed57a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"com.google.inject:guice:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.withType(Test).configureEach {\n    jvmArgs \"--add-opens=java.base/java.lang=ALL-UNNAMED\"\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n    binaries {\n        all {\n            buildArgs.add(\"--add-opens=java.base/java.lang=ALL-UNNAMED\")\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778011469881}]}
