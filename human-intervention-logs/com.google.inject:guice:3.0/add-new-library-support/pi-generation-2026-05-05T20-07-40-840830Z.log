              return super.loadClass(name, resolve);
          }
  
          @Override
          protected Class<?> findClass(String name) throws ClassNotFoundException {
              if (isQueueClass(name)) {
                  try {
                      byte[] bytes = relocatedFinalizerBytes(readClassBytes(name.replace('.', '/') + ".class"));
                      return defineClass(name, bytes, 0, bytes.length);
                  } catch (IOException exception) {
                      throw new ClassNotFoundException(name, exception);
                  }
              }
              return super.findClass(name);
          }
  
          private static boolean isQueueClass(String name) {
              return name.equals(QUEUE_CLASS_NAME) || name.startsWith(QUEUE_CLASS_NAME + "$");
          }
      }
  }
