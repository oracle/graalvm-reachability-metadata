  package com_google_inject.guice;
  
  import com.google.inject.AbstractModule;
  import com.google.inject.Guice;
  import com.google.inject.Injector;
  import com.google.inject.Key;
  import com.google.inject.Provides;
  import com.google.inject.name.Named;
  import com.google.inject.name.Names;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProviderMethodTest {
      @Test
      void invokesProvidesMethodWhenResolvingBinding() {
          ProviderBackedModule module = new ProviderBackedModule();
          Injector injector = Guice.createInjector(module);
  
          String firstValue = injector.getInstance(Key.get(String.class, Names.named("provided")));
          String secondValue = injector.getInstance(Key.get(String.class, Names.named("provided")));
  
          assertThat(firstValue).isEqualTo("value-7-call-1");
          assertThat(secondValue).isEqualTo("value-7-call-2");
          assertThat(module.invocationCount).isEqualTo(2);
      }
  
      public static class ProviderBackedModule extends AbstractModule {
          private int invocationCount;
  
          @Override
          protected void configure() {
          }
  
          @Provides
          Integer provideNumber() {
              return 7;
          }
  
          @Provides
          @Named("provided")
          String provideString(Integer number) {
              invocationCount++;
              return "value-" + number + "-call-" + invocationCount;
          }
      }
  }
