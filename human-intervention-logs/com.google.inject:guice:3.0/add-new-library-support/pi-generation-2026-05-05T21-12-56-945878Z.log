n\nimport com.google.inject.AbstractModule;\nimport com.google.inject.Guice;\nimport com.google.inject.Inject;\nimport com.google.inject.Injector;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SingleMethodInjectorAnonymous2Test {\n    @Test\n    void injectMembersInvokesPrivateAnnotatedMethod() {\n        Greeting greeting = new Greeting(\"hello from method injection\");\n        Injector injector = Guice.createInjector(new MethodInjectionModule(greeting));\n        MethodInjectedService service = new MethodInjectedService();\n\n        assertThat(service.initialized()).isFalse();\n\n        injector.injectMembers(service);\n\n        assertThat(service.initialized()).isTrue();\n        assertThat(service.message()).isEqualTo(\"hello from method injection\");\n    }\n\n    private static final class MethodInjectionModule extends AbstractModule {\n        private final Greeting greeting;\n\n        private MethodInjectionModule(Greeting greeting) {\n            this.greeting = greeting;\n        }\n\n        @Override\n        protected void configure() {\n            bind(Greeting.class).toInstance(greeting);\n        }\n    }\n\n    public static final class MethodInjectedService {\n        private Greeting greeting;\n        private boolean initialized;\n\n        @Inject\n        private void initialize(Greeting injectedGreeting) {\n            greeting = injectedGreeting;\n            initialized = true;\n        }\n\n        boolean initialized() {\n            return initialized;\n        }\n\n        String message() {\n            return greeting.message();\n        }\n    }\n\n    public static final class Greeting {\n        private final String message;\n\n        private Greeting(String message) {\n            this.message = message;\n        }\n\n        String message() {\n            return message;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt