  package com_google_inject.guice;
  
  import com.google.inject.AbstractModule;
  import com.google.inject.Guice;
  import com.google.inject.Inject;
  import com.google.inject.Injector;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SingleFieldInjectorTest {
      @Test
      void injectMembersSetsAnnotatedInstanceField() {
          Greeting greeting = new Greeting("hello from field injection");
          Injector injector = Guice.createInjector(new FieldInjectionModule(greeting));
          FieldInjectedService service = new FieldInjectedService();
  
          assertThat(service.greeting()).isNull();
  
          injector.injectMembers(service);
  
          assertThat(service.greeting()).isSameAs(greeting);
          assertThat(service.message()).isEqualTo("hello from field injection");
      }
  
      private static final class FieldInjectionModule extends AbstractModule {
          private final Greeting greeting;
  
          private FieldInjectionModule(Greeting greeting) {
              this.greeting = greeting;
          }
  
          @Override
          protected void configure() {
              bind(Greeting.class).toInstance(greeting);
          }
      }
  
      public static final class FieldInjectedService {
          @Inject
          private Greeting greeting;
  
          Greeting greeting() {
              return greeting;
          }
  
          String message() {
              return greeting.message();
          }
      }
  
      public static final class Greeting {
          private final String message;
  
          Greeting(String message) {
              this.message = message;
          }
  
          String message() {
              return message;
          }
      }
  }
