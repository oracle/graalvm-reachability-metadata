  package com_google_inject.guice;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.concurrent.ConcurrentMap;
  import java.util.concurrent.TimeUnit;
  
  import com.google.inject.internal.util.$MapMaker;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerCustomConcurrentHashMapInnerImplTest {
      @Test
      void serializesAndDeserializesCustomMapMadeByMapMaker() throws Exception {
          ConcurrentMap<String, String> map = new $MapMaker()
                  .initialCapacity(4)
                  .concurrencyLevel(2)
                  .expiration(1, TimeUnit.DAYS)
                  .makeMap();
          map.put("alpha", "one");
          map.put("bravo", "two");
  
          ConcurrentMap<String, String> deserialized = deserialize(serialize(map));
  
          assertThat(deserialized).containsEntry("alpha", "one");
          assertThat(deserialized).containsEntry("bravo", "two");
          assertThat(deserialized.putIfAbsent("charlie", "three")).isNull();
          assertThat(deserialized.replace("alpha", "one", "updated")).isTrue();
          assertThat(deserialized).containsEntry("alpha", "updated");
      }
  
      private static byte[] serialize(Object object) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(object);
          }
          return bytes.toByteArray();
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T deserialize(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return (T) input.readObject();
          }
      }
  }
