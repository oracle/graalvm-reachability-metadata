  package com_google_inject.guice;
  
  import com.google.inject.AbstractModule;
  import com.google.inject.Guice;
  import com.google.inject.Injector;
  import com.google.inject.Key;
  import com.google.inject.TypeLiteral;
  import com.google.inject.name.Names;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypeConverterBindingProcessorAnonymous4Test {
      @Test
      void convertsBoundConstantStringToClassLiteral() {
          Injector injector = Guice.createInjector(new AbstractModule() {
              @Override
              protected void configure() {
                  bindConstant().annotatedWith(Names.named("runtimeClass")).to("java.lang.String");
              }
          });
          Key<Class<?>> runtimeClassKey = Key.get(new TypeLiteral<Class<?>>() {
          }, Names.named("runtimeClass"));
  
          Class<?> runtimeClass = injector.getInstance(runtimeClassKey);
  
          assertThat(runtimeClass).isSameAs(String.class);
      }
