[tool-call] delta {"path":"tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerAbstractClassGeneratorTest.java","edits":[{"oldText":"import com.google.inject.internal.cglib.proxy.$Enhancer;\nimport com.google.inject.internal.cglib.proxy.$NoOp;","newText":"import com.google.inject.internal.cglib.core.$NamingPolicy;\nimport com.google.inject.internal.cglib.core.$Predicate;\nimport com.google.inject.internal.cglib.proxy.$Enhancer;\nimport com.google.inject.internal.cglib.proxy.$NoOp;"},{"oldText":"public class InnerAbstractClassGeneratorTest {\n    @Test\n    void attemptLoadChecksClassLoaderForGeneratedEnhancerBeforeDefiningIt() throws Throwable {\n        try (URLClassLoader classLoader = new URLClassLoader(new URL[0], EnhanceableService.class.getClassLoader())) {\n            $Enhancer enhancer = new $Enhancer();\n            enhancer.setSuperclass(EnhanceableService.class);\n            enhancer.setCallbackType($NoOp.class);\n            enhancer.setClassLoader(classLoader);\n            enhancer.setUseCache(false);\n            enhancer.setAttemptLoad(true);\n\n            try {\n                Class<?> proxyClass = enhancer.createClass();\n\n                assertThat($Enhancer.isEnhanced(proxyClass)).isTrue();\n                assertThat(proxyClass.getClassLoader()).isSameAs(classLoader);\n            } catch (Error error) {\n                rethrowUnlessNativeImageDynamicClassLoadingError(error);\n            } catch (RuntimeException exception) {\n                rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n            }\n        }\n    }","newText":"public class InnerAbstractClassGeneratorTest {\n    private static final String GENERATED_CLASS_NAME = \"com_google_inject.guice.GeneratedEnhanceableServiceProxy\";\n\n    @Test\n    void attemptLoadChecksClassLoaderForGeneratedEnhancerBeforeDefiningIt() throws Throwable {\n        try (URLClassLoader classLoader = new URLClassLoader(new URL[0], EnhanceableService.class.getClassLoader())) {\n            try {\n                Class<?> generatedClass = newEnhancer(classLoader, false).createClass();\n                Class<?> loadedClass = newEnhancer(classLoader, true).createClass();\n\n                assertThat($Enhancer.isEnhanced(generatedClass)).isTrue();\n                assertThat(loadedClass).isSameAs(generatedClass);\n                assertThat(loadedClass.getClassLoader()).isSameAs(classLoader);\n            } catch (Error error) {\n                rethrowUnlessNativeImageDynamicClassLoadingError(error);\n            } catch (RuntimeException exception) {\n                rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n            }\n        }\n    }\n\n    private static $Enhancer newEnhancer(ClassLoader classLoader, boolean attemptLoad) {\n        $Enhancer enhancer = new $Enhancer();\n        enhancer.setSuperclass(EnhanceableService.class);\n        enhancer.setCallbackType($NoOp.class);\n        enhancer.setClassLoader(classLoader);\n        enhancer.setNamingPolicy(new FixedNamingPolicy());\n        enhancer.setUseCache(false);\n        enhancer.setAttemptLoad(attemptLoad);\n        return enhancer;\n    }"},{"oldText":"    public static class EnhanceableService {\n        public String value() {\n            return \"generated\";\n        }\n    }","newText":"    public static class EnhanceableService {\n        public String value() {\n            return \"generated\";\n        }\n    }\n\n    private static final class FixedNamingPolicy implements $NamingPolicy {\n        @Override\n        public String getClassName(String prefix, String source, Object key, $Predicate names) {\n            return GENERATED_CLASS_NAME;\n        }\n    }"}]}
