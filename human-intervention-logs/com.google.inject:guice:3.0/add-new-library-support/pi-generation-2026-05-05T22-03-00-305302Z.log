  package com_google_inject.guice;
  
  import com.google.inject.internal.cglib.proxy.$Enhancer;
  import com.google.inject.internal.cglib.proxy.$NoOp;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerAbstractClassGeneratorTest {
      @Test
      void attemptLoadChecksClassLoaderForGeneratedEnhancerBeforeDefiningIt() throws Throwable {
          RecordingClassLoader classLoader = new RecordingClassLoader(EnhanceableService.class.getClassLoader());
          $Enhancer enhancer = new $Enhancer();
          enhancer.setSuperclass(EnhanceableService.class);
          enhancer.setCallbackType($NoOp.class);
          enhancer.setClassLoader(classLoader);
          enhancer.setUseCache(false);
          enhancer.setAttemptLoad(true);
  
          try {
              Class<?> proxyClass = enhancer.createClass();
  
              assertThat($Enhancer.isEnhanced(proxyClass)).isTrue();
              assertThat(classLoader.requestedClassNames())
                      .anyMatch(name -> name.contains("EnhanceableService") && name.contains("EnhancerByCGLIB"));
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (RuntimeException exception) {
              rethrowUnlessNativeImageDynamicClassLoadingError(exception);
          }
      }
  
      private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {
          if (hasNativeImageUnsupportedFeatureError(throwable)) {
              return;
          }
          throw throwable;
      }
  
      private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public static class EnhanceableService {
          public String value() {
              return "generated";
          }
      }
  
      private static final class RecordingClassLoader extends ClassLoader {
          private final List<String> requestedClassNames = new ArrayList<>();
  
          private RecordingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              requestedClassNames.add(name);
              return super.loadClass(name);
          }
  
          private List<String> requestedClassNames() {
              return requestedClassNames;
          }
      }
  }
