getSystemResource(INJECTOR_RESOURCE_NAME)).isNull();\n        }\n    }\n}\n", "newText": "public class InnerClassReaderTest {\n    private static final String INJECTOR_CLASS_NAME = \"com.google.inject.Injector\";\n    private static final String MISSING_CLASS_NAME = \"com.google.inject.DoesNotExist\";\n\n    @Test\n    void loadsClassBytesFromSystemResourceAndReadsClassMetadata() throws IOException {\n        $ClassReader reader = new $ClassReader(INJECTOR_CLASS_NAME);\n\n        assertThat(reader.b).isNotEmpty();\n        assertThat(reader.getClassName()).isEqualTo(\"com/google/inject/Injector\");\n        assertThat(reader.getSuperName()).isEqualTo(\"java/lang/Object\");\n    }\n\n    @Test\n    void reportsMissingClassAfterSystemResourceLookup() {\n        try {\n            new $ClassReader(MISSING_CLASS_NAME);\n        } catch (IOException exception) {\n            assertThat(exception).hasMessage(\"Class not found\");\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 767, "output": 1414, "cacheRead": 47104, "cacheWrite": 0, "totalTokens": 49285, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778017745662, "responseId": "resp_078757deb366cf920169fa65d2744c81939ab72bf1d91d2f87"}}
