  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package com_google_inject.guice;
  
  import java.io.IOException;
  
  import com.google.inject.internal.asm.$ClassReader;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerClassReaderTest {
      private static final String INJECTOR_CLASS_NAME = "com.google.inject.Injector";
      private static final String INJECTOR_RESOURCE_NAME = "com/google/inject/Injector.class";
  
      @Test
      void loadsClassBytesFromSystemResourceAndReadsClassMetadata() throws IOException {
          try {
              $ClassReader reader = new $ClassReader(INJECTOR_CLASS_NAME);
  
              assertThat(reader.b).isNotEmpty();
              assertThat(reader.getClassName()).isEqualTo("com/google/inject/Injector");
              assertThat(reader.getSuperName()).isEqualTo("java/lang/Object");
          } catch (IOException exception) {
              assertThat(exception).hasMessage("Class not found");
              assertThat(ClassLoader.getSystemResource(INJECTOR_RESOURCE_NAME)).isNull();
          }
      }
  }
