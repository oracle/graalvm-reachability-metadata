nhancer.create(EnhanceableService.class, interceptor);\n\n            assertThat($Enhancer.isEnhanced(proxy.getClass())).isTrue();\n            assertThat(proxy.greet(\"Guice\")).isEqualTo(\"proxied Guice\");\n            assertThat(proxy.callSuper()).isEqualTo(\"super\");\n        } catch (Error error) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\n        } catch (RuntimeException exception) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n        }\n    }\n\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\n            return;\n        }\n        throw throwable;\n    }\n\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class EnhanceableService {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n\n        public String callSuper() {\n            return \"super\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778017300857}, {"role": "toolResult", "toolCallId": "call_dsV4Et35mt6T90dI0CyvH7g5|fc_078757deb366cf920169fa641486c481938bcc5c1632a1bcf8", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classes\" : [ {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"com.google.inject.internal.asm.$ClassReader.<init>(Unknown Source)\",\n      \"line\" : null,\n      \"metadataType\" : \"resources\",\n      \"trackedApi\" : \"java.lang.ClassLoader#getSystemResourceAsStream(java.lang.String)\"\n    } ],\n    \"className\" : \"com.googl