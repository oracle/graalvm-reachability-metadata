  package com_google_inject.guice;
  
  import java.util.concurrent.atomic.AtomicReference;
  
  import com.google.inject.internal.cglib.core.$Signature;
  import com.google.inject.internal.cglib.proxy.$Enhancer;
  import com.google.inject.internal.cglib.proxy.$MethodInterceptor;
  import com.google.inject.internal.cglib.proxy.$MethodProxy;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InnerMethodProxyTest {
      @Test
      void findsMethodProxyInstalledOnGeneratedEnhancerClass() throws Throwable {
          if (isNativeImageRuntime()) {
              return;
          }
  
          AtomicReference<$Signature> interceptedSignature = new AtomicReference<>();
          $MethodInterceptor interceptor = (object, method, arguments, methodProxy) -> {
              if ("greet".equals(method.getName())) {
                  interceptedSignature.set(methodProxy.getSignature());
                  return "proxied " + arguments[0];
              }
              return methodProxy.invokeSuper(object, arguments);
          };
  
          try {
              GreetingService proxy = (GreetingService) $Enhancer.create(GreetingService.class, interceptor);
  
              assertThat(proxy.greet("Guice")).isEqualTo("proxied Guice");
  
              $Signature signature = interceptedSignature.get();
              assertThat(signature).isNotNull();
  
              $MethodProxy foundProxy = $MethodProxy.find(proxy.getClass(), signature);
              assertThat(foundProxy).isNotNull();
              assertThat(foundProxy.getSignature()).isEqualTo(signature);
              assertThat(foundProxy.invokeSuper(proxy, new Object[] {"native image"})).isEqualTo("hello native image");
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (RuntimeException exception) {
              rethrowUnlessNativeImageDynamicClassLoadingError(exception);
          }
      }
  
      private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {
          if (hasNativeImageUnsupportedFeatureError(throwable)) {
              return;
          }
          throw throwable;
      }
  
      private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static boolean isNativeImageRuntime() {
          return "runtime".equals(System.getProperty("org.graalvm.nativeimage.imagecode"));
      }
  
      public static class GreetingService {
          public String greet(String name) {
              return "hello " + name;
          }
      }
  }
