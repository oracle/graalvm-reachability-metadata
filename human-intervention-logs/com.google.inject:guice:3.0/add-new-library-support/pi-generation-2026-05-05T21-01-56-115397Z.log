ogle.inject.TypeLiteral;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MoreTypesTest {\n    @Test\n    void resolvesRawClassForGenericArrayTypeLiterals() {\n        TypeLiteral<List<String>[]> arrayLiteral = new TypeLiteral<List<String>[]>() {\n        };\n\n        Class<? super List<String>[]> rawType = arrayLiteral.getRawType();\n\n        assertThat(rawType).isSameAs(List[].class);\n        assertThat(rawType.isArray()).isTrue();\n        assertThat(rawType.getComponentType()).isSameAs(List.class);\n    }\n\n    @Test\n    void genericArrayTypeLiteralCanBeUsedAsAGuiceKey() {\n        TypeLiteral<List<String>[]> arrayLiteral = new TypeLiteral<List<String>[]>() {\n        };\n        List<String>[] values = listArray(Arrays.asList(\"alpha\"), Arrays.asList(\"beta\"));\n\n        assertThat(arrayLiteral.getRawType().isInstance(values)).isTrue();\n        assertThat(values[0]).containsExactly(\"alpha\");\n        assertThat(values[1]).containsExactly(\"beta\");\n    }\n\n    @SafeVarargs\n    private static List<String>[] listArray(List<String>... values) {\n        return values;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 642, "output": 1383, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 19433, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778014878587, "responseId": "resp_034ce67c06e711110169fa5a9ef610819ea906a9fc2e284db2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tQf8RiGqHXCsZT9ZcrhSTY7v|fc_034ce67c06e711110169fa5aac5488819e80508baa5939a3ad", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1433 bytes to tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/MoreTypesTest.java"}], "isError": false, "timestamp": 1778014894985}]}
