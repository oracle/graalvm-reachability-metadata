  package com_google_inject.guice;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.util.ArrayList;
  import java.util.Base64;
  import java.util.List;
  
  import com.google.inject.internal.cglib.core.$ReflectUtils;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectUtilsTest {
      private static final String GENERATED_CLASS_NAME = "com_google_inject.guice.GeneratedByReflectUtils";
  
      @Test
      void resolvesConstructorsAndMethodsFromCglibStyleDescriptors() {
          Constructor constructor = $ReflectUtils.findConstructor("String(byte[])");
          assertThat(constructor.getDeclaringClass()).isSameAs(String.class);
          assertThat(constructor.getParameterTypes()).containsExactly(byte[].class);
  
          Method substring = $ReflectUtils.findMethod("java.lang.String.substring(int, int)");
          assertThat(substring.getDeclaringClass()).isSameAs(String.class);
          assertThat(substring.getName()).isEqualTo("substring");
          assertThat(substring.getParameterTypes()).containsExactly(int.class, int.class);
      }
  
      @Test
      void instantiatesObjectsAndDiscoversMethodsAcrossClassHierarchy() throws Exception {
          Constructed instance = (Constructed) $ReflectUtils.newInstance(
                  Constructed.class,
                  new Class[] {String.class},
                  new Object[] {"created"}
          );
          assertThat(instance.value()).isEqualTo("created");
  
          Constructor constructor = $ReflectUtils.getConstructor(Constructed.class, new Class[] {String.class});
          Constructed directInstance = (Constructed) $ReflectUtils.newInstance(constructor, new Object[] {"direct"});
          assertThat(directInstance.value()).isEqualTo("direct");
  
          Method inherited = $ReflectUtils.findDeclaredMethod(ChildType.class, "baseValue", new Class[0]);
          assertThat(inherited.getDeclaringClass()).isSameAs(BaseType.class);
  
          List<Method> methods = new ArrayList<>();
          $ReflectUtils.addAllMethods(ChildType.class, methods);
          assertThat(methods).extracting(Method::getName)
                  .contains("childValue", "baseValue", "interfaceValue");
  
          Method factoryMethod = $ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);
          assertThat(factoryMethod.getName()).isEqualTo("newInstance");
      }
  
      @Test
      void definesClassBytesWithTargetLoader() throws Exception {
          try {
              Class<?> generated = $ReflectUtils.defineClass(
                      GENERATED_CLASS_NAME,
                      generatedClassBytes(),
                      ReflectUtilsTest.class.getClassLoader()
              );
  
              assertThat(generated.getName()).isEqualTo(GENERATED_CLASS_NAME);
              assertThat(generated.getClassLoader()).isSameAs(ReflectUtilsTest.class.getClassLoader());
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (Exception exception) {
              rethrowUnlessNativeImageDynamicClassLoadingError(exception);
          }
      }
  
      private static byte[] generatedClassBytes() {
          return Base64.getMimeDecoder().decode("""
                  yv66vgAAADQACgoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW
                  BwAIAQAvY29tX2dvb2dsZV9pbmplY3QvZ3VpY2UvR2VuZXJhdGVkQnlSZWZsZWN0VXRpbHMBAARD
                  b2RlADEABwACAAAAAAABAAEABQAGAAEACQAAABEAAQABAAAABSq3AAGxAAAAAAAA
                  """);
      }
  
      private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Exception {
          if (hasNativeImageUnsupportedFeatureError(throwable)) {
              return;
          }
          if (throwable instanceof Exception exception) {
              throw exception;
          }
          if (throwable instanceof Error error) {
              throw error;
          }
      }
  
      private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public interface SingleMethodFactory {
          Object newInstance();
      }
  
      public interface MarkerInterface {
          String interfaceValue();
      }
  
      public static class BaseType {
          public String baseValue() {
              return "base";
          }
      }
  
      public static class ChildType extends BaseType implements MarkerInterface {
          public String childValue() {
              return "child";
          }
  
          @Override
          public String interfaceValue() {
              return "interface";
          }
      }
  
      public static class Constructed {
          private final String value;
  
          public Constructed(String value) {
              this.value = value;
          }
  
          public String value() {
              return value;
          }
      }
  }
