  package com_google_inject.guice;
  
  import java.util.Arrays;
  import java.util.List;
  
  import com.google.inject.Key;
  import com.google.inject.TypeLiteral;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MoreTypesTest {
      @Test
      void resolvesRawClassForGenericArrayTypeLiterals() {
          TypeLiteral<List<String>[]> arrayLiteral = new TypeLiteral<List<String>[]>() {
          };
  
          Class<? super List<String>[]> rawType = arrayLiteral.getRawType();
  
          assertThat(rawType).isSameAs(List[].class);
          assertThat(rawType.isArray()).isTrue();
          assertThat(rawType.getComponentType()).isSameAs(List.class);
      }
  
      @Test
      void genericArrayTypeLiteralCanBeUsedAsAGuiceKey() {
          TypeLiteral<List<String>[]> arrayLiteral = new TypeLiteral<List<String>[]>() {
          };
          List<String>[] values = listArray(Arrays.asList("alpha"), Arrays.asList("beta"));
  
          Key<List<String>[]> key = Key.get(arrayLiteral);
  
          assertThat(key.getTypeLiteral().getRawType()).isSameAs(List[].class);
          assertThat(arrayLiteral.getRawType().isInstance(values)).isTrue();
          assertThat(values[0]).containsExactly("alpha");
          assertThat(values[1]).containsExactly("beta");
      }
  
      @SafeVarargs
      private static List<String>[] listArray(List<String>... values) {
          return values;
      }
  }
