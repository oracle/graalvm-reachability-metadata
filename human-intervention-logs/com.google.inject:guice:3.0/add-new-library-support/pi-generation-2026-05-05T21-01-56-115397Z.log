  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package com_google_inject.guice;
  
  import java.lang.reflect.Member;
  import java.util.Set;
  
  import com.google.inject.Inject;
  import com.google.inject.TypeLiteral;
  import com.google.inject.name.Named;
  import com.google.inject.spi.Dependency;
  import com.google.inject.spi.InjectionPoint;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InjectionPointTest {
      @Test
      void discoversInjectAnnotatedAndImplicitNoArgumentConstructors() {
          InjectionPoint annotatedConstructor = InjectionPoint.forConstructorOf(
                  TypeLiteral.get(AnnotatedConstructorService.class)
          );
  
          assertThat(annotatedConstructor.getMember().getDeclaringClass())
                  .isSameAs(AnnotatedConstructorService.class);
          assertThat(annotatedConstructor.getDependencies()).hasSize(1);
          Dependency<?> constructorDependency = annotatedConstructor.getDependencies().get(0);
          assertThat(constructorDependency.getKey().getTypeLiteral().getRawType())
                  .isSameAs(String.class);
  
          InjectionPoint defaultConstructor = InjectionPoint.forConstructorOf(
                  DefaultConstructorService.class
          );
  
          assertThat(defaultConstructor.getMember().getDeclaringClass())
                  .isSameAs(DefaultConstructorService.class);
          assertThat(defaultConstructor.getDependencies()).isEmpty();
      }
  
      @Test
      void discoversFieldAndMethodInjectionPointsIncludingScalaStyleAccessor() {
          Set<InjectionPoint> instanceInjectionPoints = InjectionPoint.forInstanceMethodsAndFields(
                  MemberInjectionTarget.class
          );
  
          assertThat(instanceInjectionPoints)
                  .extracting(InjectionPointTest::memberName)
                  .contains("baseDependency", "instanceDependency", "initialize", "accessor");
          assertThat(instanceInjectionPoints)
                  .filteredOn(injectionPoint -> "accessor".equals(memberName(injectionPoint)))
                  .singleElement()
                  .satisfies(injectionPoint -> assertThat(injectionPoint.getDependencies())
                          .isEmpty());
  
          Set<InjectionPoint> staticInjectionPoints = InjectionPoint.forStaticMethodsAndFields(
                  MemberInjectionTarget.class
          );
  
          assertThat(staticInjectionPoints)
                  .extracting(InjectionPointTest::memberName)
                  .contains("staticDependency", "configure");
      }
  
      private static String memberName(InjectionPoint injectionPoint) {
          Member member = injectionPoint.getMember();
          return member.getName();
      }
  
      public static class AnnotatedConstructorService {
          @Inject
          public AnnotatedConstructorService(@Named("constructor") String value) {
          }
      }
  
      public static class DefaultConstructorService {
          public DefaultConstructorService() {
          }
      }
  
      public static class BaseMemberInjectionTarget {
          @Inject
          String baseDependency;
      }
  
      public static class MemberInjectionTarget extends BaseMemberInjectionTarget {
          @Inject
          String instanceDependency;
  
          @Inject
          static Integer staticDependency;
  
          private String accessor;
  
          @Inject
          void initialize(@Named("method") String value) {
          }
  
          @Inject
          @Named("scala-style-accessor")
          void accessor() {
          }
  
          @Inject
          static void configure(Double value) {
          }
      }
  }
