  public class MoreTypes {
  
    public static final Type[] EMPTY_TYPE_ARRAY = new Type[] {};
  
    private MoreTypes() {}
  
    private static final Map<TypeLiteral<?>, TypeLiteral<?>> PRIMITIVE_TO_WRAPPER
