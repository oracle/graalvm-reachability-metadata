  package com_google_inject.guice;
  
  import java.util.Base64;
  
  import com.google.inject.internal.BytecodeGen;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BytecodeGenInnerBridgeClassLoaderTest {
      private static final String TARGET_CLASS_NAME = "com_google_inject.guice.BytecodeGenBridgeTarget";
      private static final byte[] TARGET_CLASS_BYTES = Base64.getDecoder().decode("""
              yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClWBwAI
              AQAvY29tX2dvb2dsZV9pbmplY3QvZ3VpY2UvQnl0ZWNvZGVHZW5CcmlkZ2VUYXJnZXQBAARDb2RlAQAP
              TGluZU51bWJlclRhYmxlAQAKU291cmNlRmlsZQEAHEJ5dGVjb2RlR2VuQnJpZGdlVGFyZ2V0LmphdmEA
              IQAHAAIAAAAAAAEAAQAFAAYAAQAJAAAAHQABAAEAAAAFKrcAAbEAAAABAAoAAAAGAAEAAAABAAEACwAA
              AAIADA==
              """);
  
      @Test
      void bridgeClassLoaderLoadsGuiceInternalClassesFromGuiceClassLoader() throws Throwable {
          try {
              ChildFirstClassLoader userClassLoader = new ChildFirstClassLoader(
                      BytecodeGenInnerBridgeClassLoaderTest.class.getClassLoader());
              Class<?> targetClass = userClassLoader.loadClass(TARGET_CLASS_NAME);
  
              assertThat(targetClass.getClassLoader()).isSameAs(userClassLoader);
  
              ClassLoader bridgeClassLoader = BytecodeGen.getClassLoader(targetClass);
              Class<?> bytecodeGenClass = bridgeClassLoader.loadClass(BytecodeGen.class.getName());
  
              assertThat(bytecodeGenClass).isSameAs(BytecodeGen.class);
              assertThat(bridgeClassLoader).isNotSameAs(userClassLoader);
          } catch (Error error) {
              rethrowUnlessNativeImageDynamicClassLoadingError(error);
          } catch (RuntimeException exception) {
              rethrowUnlessNativeImageDynamicClassLoadingError(exception);
          }
      }
  
      private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {
          if (hasNativeImageUnsupportedFeatureError(throwable)) {
              return;
          }
          throw throwable;
      }
  
      private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static final class ChildFirstClassLoader extends ClassLoader {
          private ChildFirstClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!TARGET_CLASS_NAME.equals(name)) {
                  return super.loadClass(name, resolve);
              }
  
              Class<?> loadedClass = findLoadedClass(name);
              if (loadedClass == null) {
                  loadedClass = defineTargetClass(name);
              }
              if (resolve) {
                  resolveClass(loadedClass);
              }
              return loadedClass;
          }
  
          private Class<?> defineTargetClass(String name) {
              return defineClass(name, TARGET_CLASS_BYTES, 0, TARGET_CLASS_BYTES.length);
          }
