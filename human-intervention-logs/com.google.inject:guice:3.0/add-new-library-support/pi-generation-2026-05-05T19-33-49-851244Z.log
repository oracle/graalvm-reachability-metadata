        }
        <K, V> ReferenceEntry<K, V> newEntry(
            Internals<K, V, ReferenceEntry<K, V>> internals, K key,
            int hash, ReferenceEntry<K, V> next) {
          return (next == null)
              ? new SoftEntry<K, V>(internals, key, hash)
              : new LinkedSoftEntry<K, V>(internals, key, hash, next);
