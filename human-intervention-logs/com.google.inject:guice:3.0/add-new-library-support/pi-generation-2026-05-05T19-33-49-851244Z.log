      return setValueStrength(Strength.SOFT);
    }
  
    private MapMaker setValueStrength(Strength strength) {
      if (valueStrength != Strength.STRONG) {
        throw new IllegalStateException("Value strength was already set to "
            + valueStrength + ".");
