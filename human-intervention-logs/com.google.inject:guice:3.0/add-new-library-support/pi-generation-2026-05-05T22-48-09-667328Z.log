[tool-call] delta {"path":"tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerLineNumbersTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.lang.reflect.Method;\n\nimport com.google.inject.internal.util.StackTraceElements;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InnerLineNumbersTest {\n    @Test\n    void createsStackTraceElementForTypeFromClassResource() {\n        Object source = StackTraceElements.forType(LineNumberSubject.class);\n\n        assertThat(source)\n                .isInstanceOfSatisfying(StackTraceElement.class, element -> {\n                    assertThat(element.getClassName()).isEqualTo(LineNumberSubject.class.getName());\n                    assertThat(element.getMethodName()).isEqualTo(\"class\");\n                    assertThat(element.getLineNumber()).isPositive();\n                });\n    }\n\n    @Test\n    void createsStackTraceElementForMemberFromDeclaringClassResource() throws NoSuchMethodException {\n        Method method = LineNumberSubject.class.getDeclaredMethod(\"message\");\n\n        Object source = StackTraceElements.forMember(method);\n\n        assertThat(source)\n                .isInstanceOfSatisfying(StackTraceElement.class, element -> {\n                    assertThat(element.getClassName()).isEqualTo(LineNumberSubject.class.getName());\n                    assertThat(element.getMethodName()).isEqualTo(\"message\");\n                    assertThat(element.getLineNumber()).isPositive();\n                });\n    }\n\n    public static final class LineNumberSubject {\n        public String message() {\n            return \"line-numbers\";\n        }\n    }\n}\n"}
