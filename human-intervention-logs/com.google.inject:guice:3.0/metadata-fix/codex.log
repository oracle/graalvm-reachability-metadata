{"type":"item.completed","item":{"id":"item_64","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,200p' tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerClassReaderTest.java\nsed -n '1,220p' tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerLineNumbersTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.io.IOException;\n\nimport com.google.inject.internal.asm.$ClassReader;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatIOException;\n\npublic class InnerClassReaderTest {\n    private static final String INJECTOR_CLASS_NAME = \"com.google.inject.Injector\";\n    private static final String MISSING_CLASS_NAME = \"com.google.inject.DoesNotExist\";\n\n    @Test\n    void loadsClassBytesFromSystemResourceAndReadsClassMetadata() throws IOException {\n        try {\n            $ClassReader reader = new $ClassReader(INJECTOR_CLASS_NAME);\n\n            assertThat(reader.b).isNotEmpty();\n            assertThat(reader.getClassName()).isEqualTo(\"com/google/inject/Injector\");\n            assertThat(reader.getSuperName()).isEqualTo(\"java/lang/Object\");\n        } catch (IOException exception) {\n            assertThat(exception).hasMessage(\"Class not found\");\n        }\n    }\n\n    @Test\n    void reportsMissingClassAfterSystemResourceLookup() {\n        assertThatIOException()\n                .isThrownBy(() -> new $ClassReader(MISSING_CLASS_NAME))\n                .withMessage(\"Class not found\");\n    }\n}\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.lang.reflect.Method;\n\nimport com.google.inject.Injector;\nimport com.google.inject.internal.util.$StackTraceElements;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InnerLineNumbersTest {\n    @Test\n    void createsStackTraceElementForTypeFromClassResource() {\n        Object source = $StackTraceElements.forType(Injector.class);\n\n        assertThat(source)\n                .isInstanceOfSatisfying(StackTraceElement.class, element -> {\n                    assertThat(element.getClassName()).isEqualTo(Injector.class.getName());\n                    assertThat(element.getMethodName()).isEqualTo(\"class\");\n                    assertThat(element.getLineNumber()).isPositive();\n                });\n    }\n\n    @Test\n    void createsStackTraceElementForMemberFromDeclaringClassResource() throws NoSuchMethodException {\n        Method method = Injector.class.getMethod(\"getInstance\", Class.class);\n\n        Object source = $StackTraceElements.forMember(method);\n\n        assertThat(source)\n                .isInstanceOfSatisfying(StackTraceElement.class, element -> {\n                    assertThat(element.getClassName()).isEqualTo(Injector.class.getName());\n                    assertThat(element.getMethodName()).isEqualTo(\"getInstance\");\n                    assertThat(element.getLineNumber()).isPositive();\n                });\n    }\n}\n","exit_code":0,"status":"completed"}}
