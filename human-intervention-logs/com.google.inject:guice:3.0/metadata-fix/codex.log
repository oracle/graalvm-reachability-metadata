{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerCallbackInfoTest.java\nsed -n '1,220p' tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerMethodWrapperTest.java\nsed -n '1,220p' tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerEnhancerTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport com.google.inject.internal.cglib.proxy.$Dispatcher;\nimport com.google.inject.internal.cglib.proxy.$Enhancer;\nimport com.google.inject.internal.cglib.proxy.$FixedValue;\nimport com.google.inject.internal.cglib.proxy.$MethodInterceptor;\nimport com.google.inject.internal.cglib.proxy.$MethodProxy;\nimport com.google.inject.internal.cglib.proxy.$NoOp;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatCode;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class InnerCallbackInfoTest {\n    private static final String CALLBACK_INFO_CLASS_NAME =\n            \"com.google.inject.internal.cglib.proxy.$CallbackInfo\";\n    private static final String CALLBACK_LOOKUP_TARGET_CLASS_NAME =\n            \"com_google_inject.guice.InnerCallbackInfoTest$CallbackLookupTarget\";\n\n    @Test\n    void classNameHelperLoadsApplicationType() throws Throwable {\n        Class<?> callbackInfoClass = Class.forName(CALLBACK_INFO_CLASS_NAME);\n        MethodHandle classNameHelper = MethodHandles.privateLookupIn(callbackInfoClass, MethodHandles.lookup())\n                .findStatic(callbackInfoClass, \"class$\", MethodType.methodType(Class.class, String.class));\n\n        Class<?> callbackType = (Class<?>) classNameHelper.invoke(CALLBACK_LOOKUP_TARGET_CLASS_NAME);\n\n        assertThat(callbackType.getName()).isEqualTo(CALLBACK_LOOKUP_TARGET_CLASS_NAME);\n    }\n\n    @Test\n    void callbackTypeConfigurationAcceptsBuiltInCallbackContracts() {\n        $Enhancer enhancer = new $Enhancer();\n\n        assertThatCode(() -> enhancer.setCallbackTypes(new Class<?>[] {\n            $NoOp.class,\n            $MethodInterceptor.class,\n            $Dispatcher.class,\n            $FixedValue.class\n        })).doesNotThrowAnyException();\n    }\n\n    @Test\n    void callbackTypeConfigurationRejectsAmbiguousCallbackContracts() {\n        $Enhancer enhancer = new $Enhancer();\n\n        assertThatThrownBy(() -> enhancer.setCallbackType(AmbiguousCallback.class))\n            .isInstanceOf(IllegalStateException.class)\n            .hasMessageContaining(\"Callback implements both\");\n    }\n\n    private static final class CallbackLookupTarget {\n    }\n\n    private static final class AmbiguousCallback implements $MethodInterceptor, $Dispatcher {\n        @Override\n        public Object intercept(Object object, Method method, Object[] arguments, $MethodProxy methodProxy) {\n            return null;\n        }\n\n        @Override\n        public Object loadObject() {\n            return new Object();\n        }\n    }\n}\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\nimport java.util.LinkedList;\nimport java.util.Set;\nimport java.util.TreeSet;\n\nimport com.google.inject.internal.cglib.core.$MethodWrapper;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InnerMethodWrapperTest {\n    private static final String METHOD_WRAPPER_KEY_CLASS_NAME =\n            \"com.google.inject.internal.cglib.core.$MethodWrapper$MethodWrapperKey\";\n\n    @Test\n    void classNameHelperLoadsMethodWrapperKeyType() throws Throwable {\n        try {\n            MethodHandle classNameHelper = MethodHandles.privateLookupIn($MethodWrapper.class, MethodHandles.lookup())\n                    .findStatic($MethodWrapper.class, \"class$\", MethodType.methodType(Class.class, String.class));\n\n            Class<?> keyType = (Class<?>) classNameHelper.invoke(METHOD_WRAPPER_KEY_CLASS_NAME);\n\n            assertThat(keyType.getName()).isEqualTo(METHOD_WRAPPER_KEY_CLASS_NAME);\n        } catch (Error error) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\n        } catch (RuntimeException exception) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n        }\n    }\n\n    @Test\n    void createsStableKeysForEquivalentMethodSignatures() throws Throwable {\n        Method treeSetSize = TreeSet.class.getMethod(\"size\");\n        Method linkedListSize = LinkedList.class.getMethod(\"size\");\n        Method linkedListGet = LinkedList.class.getMethod(\"get\", int.class);\n\n        try {\n            Object treeSetSizeKey = $MethodWrapper.create(treeSetSize);\n            Object linkedListSizeKey = $MethodWrapper.create(linkedListSize);\n            Object linkedListGetKey = $MethodWrapper.create(linkedListGet);\n\n            assertThat(treeSetSizeKey).isEqualTo(linkedListSizeKey);\n            assertThat(treeSetSizeKey).isNotEqualTo(linkedListGetKey);\n\n            Set<Object> methodKeys = $MethodWrapper.createSet(\n                    Arrays.asList(treeSetSize, linkedListSize, linkedListGet));\n            assertThat(methodKeys).containsExactlyInAnyOrder(treeSetSizeKey, linkedListGetKey);\n        } catch (Error error) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\n        } catch (RuntimeException exception) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n        }\n    }\n\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\n            return;\n        }\n        throw throwable;\n    }\n\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n}\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_inject.guice;\n\nimport com.google.inject.internal.cglib.proxy.$Enhancer;\nimport com.google.inject.internal.cglib.proxy.$MethodInterceptor;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InnerEnhancerTest {\n    @Test\n    void createsSubclassProxyAndInstallsCallbacksThroughGeneratedSetters() throws Throwable {\n        $MethodInterceptor interceptor = (object, method, arguments, methodProxy) -> {\n            if (\"greet\".equals(method.getName())) {\n                return \"proxied \" + arguments[0];\n            }\n            return methodProxy.invokeSuper(object, arguments);\n        };\n\n        try {\n            EnhanceableService proxy = (EnhanceableService) $Enhancer.create(EnhanceableService.class, interceptor);\n\n            assertThat($Enhancer.isEnhanced(proxy.getClass())).isTrue();\n            assertThat(proxy.greet(\"Guice\")).isEqualTo(\"proxied Guice\");\n            assertThat(proxy.callSuper()).isEqualTo(\"super\");\n        } catch (Error error) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\n        } catch (RuntimeException exception) {\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\n        }\n    }\n\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\n            return;\n        }\n        throw throwable;\n    }\n\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class EnhanceableService {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n\n        public String callSuper() {\n            return \"super\";\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
