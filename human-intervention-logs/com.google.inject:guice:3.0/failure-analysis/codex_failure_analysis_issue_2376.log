. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_google_inject.guice;\\n\\nimport java.lang.reflect.Method;\\nimport java.util.Arrays;\\nimport java.util.LinkedList;\\nimport java.util.Set;\\nimport java.util.TreeSet;\\n\\nimport com.google.inject.internal.cglib.core.$MethodWrapper;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class InnerMethodWrapperTest {\\n    @Test\\n    void createsStableKeysForEquivalentMethodSignatures() throws Throwable {\\n        Method treeSetSize = TreeSet.class.getMethod(\\\"size\\\");\\n        Method linkedListSize = LinkedList.class.getMethod(\\\"size\\\");\\n        Method linkedListGet = LinkedList.class.getMethod(\\\"get\\\", int.class);\\n\\n        try {\\n            Object treeSetSizeKey = $MethodWrapper.create(treeSetSize);\\n            Object linkedListSizeKey = $MethodWrapper.create(linkedListSize);\\n            Object linkedListGetKey = $MethodWrapper.create(linkedListGet);\\n\\n            assertThat(treeSetSizeKey).isEqualTo(linkedListSizeKey);\\n            assertThat(treeSetSizeKey).isNotEqualTo(linkedListGetKey);\\n\\n            Set<?> methodKeys = $MethodWrapper.createSet(Arrays.asList(treeSetSize, linkedListSize, linkedListGet));\\n            assertThat(methodKeys).containsExactlyInAnyOrder(treeSetSizeKey, linkedListGetKey);\\n        } catch (Error error) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\\n        } catch (RuntimeException exception) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\\n        }\\n    }\\n\\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {\\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\\n            return;\\n        }\\n        throw throwable;\\n    }\\n\\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\\n        Throwable current = throwable;\\n        while (current != null) {\\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                return true;\\n            }\\n            current = current.getCause();\\n        }\\n        return false;\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 2036, \"output\": 1639, \"cacheRead\": 17920, \"cacheWrite\": 0, \"totalTokens\": 21595, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778019476444, \"responseId\": \"resp_0d09153518c040920169fa6c94d24881908cac3a036a3e60a1\"}}\nhuman-intervention-logs/com.google.inject:guice:3.0/add-new-library-support/pi-generation-2026-05-05T22-18-19-189680Z.log:1844:[tool-exec] start id=call_bIcbF5kcxEI48Y6Yp9MF4rvF|fc_0d09153518c040920169fa6ca252b081909b7b06a2bb8ed2d1 name=write args={\"path\": \"tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerMethodWrapperTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_google_inject.guice;\\n\\nimport java.lang.reflect.Method;\\nimport java.util.Arrays;\\nimport java.util.LinkedList;\\nimport java.util.Set;\\nimport java.util.TreeSet;\\n\\nimport com.google.inject.internal.cglib.core.$MethodWrapper;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class InnerMethodWrapperTest {\\n    @Test\\n    void createsStableKeysForEquivalentMethodSignatures() throws Throwable {\\n        Method treeSetSize = TreeSet.class.getMethod(\\\"size\\\");\\n        Method linkedListSize = LinkedList.class.getMethod(\\\"size\\\");\\n        Method linkedListGet = LinkedList.class.getMethod(\\\"get\\\", int.class);\\n\\n        try {\\n            Object treeSetSizeKey = $MethodWrapper.create(treeSetSize);\\n            Object linkedListSizeKey = $MethodWrapper.create(linkedListSize);\\n            Object linkedListGetKey = $MethodWrapper.create(linkedListGet);\\n\\n            assertThat(treeSetSizeKey).isEqualTo(linkedListSizeKey);\\n            assertThat(treeSetSizeKey).isNotEqualTo(linkedListGetKey);\\n\\n            Set<?> methodKeys = $MethodWrapper.createSet(Arrays.asList(treeSetSize, linkedListSize, linkedListGet));\\n            assertThat(methodKeys).containsExactlyInAnyOrder(treeSetSizeKey, linkedListGetKey);\\n        } catch (Error error) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\\n        } catch (RuntimeException exception) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\\n        }\\n    }\\n\\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {\\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\\n            return;\\n        }\\n        throw throwable;\\n    }\\n\\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\\n        Throwable current = throwable;\\n        while (current != null) {\\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                return true;\\n            }\\n            current = current.getCause();\\n        }\\n        return false;\\n    }\\n}\\n\"}\nhuman-intervention-logs/com.google.inject:guice:3.0/add-new-library-support/pi-generation-2026-05-05T22-18-19-189680Z.log:1846:  Successfully wrote 2377 bytes to tests/src/com.google.inject/guice/3.0/src/test/java/com_google_inject/guice/InnerMethodWrapperTest.java\nhuman-intervention-