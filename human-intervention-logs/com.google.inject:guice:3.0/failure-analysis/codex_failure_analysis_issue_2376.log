  @Test\\n    void createsStableKeysForEquivalentMethodSignatures() throws Throwable {\\n        Method treeSetSize = TreeSet.class.getMethod(\\\"size\\\");\\n        Method linkedListSize = LinkedList.class.getMethod(\\\"size\\\");\\n        Method linkedListGet = LinkedList.class.getMethod(\\\"get\\\", int.class);\\n\\n        try {\\n            Object treeSetSizeKey = $MethodWrapper.create(treeSetSize);\\n            Object linkedListSizeKey = $MethodWrapper.create(linkedListSize);\\n            Object linkedListGetKey = $MethodWrapper.create(linkedListGet);\\n\\n            assertThat(treeSetSizeKey).isEqualTo(linkedListSizeKey);\\n            assertThat(treeSetSizeKey).isNotEqualTo(linkedListGetKey);\\n\\n            Set<?> methodKeys = $MethodWrapper.createSet(Arrays.asList(treeSetSize, linkedListSize, linkedListGet));\\n            assertThat(methodKeys).containsExactlyInAnyOrder(treeSetSizeKey, linkedListGetKey);\\n        } catch (Error error) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\\n        } catch (RuntimeException exception) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\\n        }\\n    }\\n\\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Throwable {\\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\\n            return;\\n        }\\n        throw throwable;\\n    }\\n\\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\\n        Throwable current = throwable;\\n        while (current != null) {\\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                return true;\\n            }\\n            current = current.getCause();\\n        }\\n        return false;\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 2036, \"output\": 1639, \"cacheRead\