vate static final String MISSING_REFLECTION_REGISTRATION_ERROR =\\n            \\\"org.graalvm.nativeimage.MissingReflectionRegistrationError\\\";\\n\\n    @Test\\n    void resolvesConstructorsAndMethodsFromCglibStyleDescriptors() throws Throwable {\\n        if (isNativeImageRuntime()) {\\n            return;\\n        }\\n\\n        Constructor constructor = $ReflectUtils.findConstructor(\\\"String(byte[])\\\");\\n        assertThat(constructor.getDeclaringClass()).isSameAs(String.class);\\n        assertThat(constructor.getParameterTypes()).containsExactly(byte[].class);\\n\\n        Method substring = $ReflectUtils.findMethod(\\\"java.lang.String.substring(int, int)\\\");\\n        assertThat(substring.getDeclaringClass()).isSameAs(String.class);\\n        assertThat(substring.getName()).isEqualTo(\\\"substring\\\");\\n        assertThat(substring.getParameterTypes()).containsExactly(int.class, int.class);\\n    }\\n\\n    @Test\\n    void instantiatesObjectsAndDiscoversMethodsAcrossClassHierarchy() throws Exception {\\n        Constructed instance = (Constructed) $ReflectUtils.newInstance(\\n                Constructed.class,\\n                new Class[] {String.class},\\n                new Object[] {\\\"created\\\"}\\n        );\\n        assertThat(instance.value()).isEqualTo(\\\"created\\\");\\n\\n        Constructor constructor = $ReflectUtils.getConstructor(Constructed.class, new Class[] {String.class});\\n        Constructed directInstance = (Constructed) $ReflectUtils.newInstance(constructor, new Object[] {\\\"direct\\\"});\\n        assertThat(directInstance.value()).isEqualTo(\\\"direct\\\");\\n\\n        Method inherited = $ReflectUtils.findDeclaredMethod(ChildType.class, \\\"baseValue\\\", new Class[0]);\\n        assertThat(inherited.getDeclaringClass()).isSameAs(BaseType.class);\\n\\n        List<Method> methods = new ArrayList<>();\\n        $ReflectUtils.addAllMethods(ChildType.class, methods);\\n        assertThat(methods).extracting(Method::getName)\\n                .contains(\\\"childValue\\\", \\\"baseValue\\\", \\\"interfaceValue\\\");\\n\\n        Method factoryMethod = $ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);\\n        assertThat(factoryMethod.getName()).isEqualTo(\\\"newInstance\\\");\\n    }\\n\\n    @Test\\n    void definesClassBytesWithTargetLoader() throws Exception {\\n        try {\\n            Class<?> generated = $ReflectUtils.defineClass(\\n                    GENERATED_CLASS_NAME,\\n                    generatedClassBytes(),\\n                    ReflectUtilsTest.class.getClassLoader()\\n            );\\n\\n            assertThat(generated.getName()).isEqualTo(GENERATED_CLASS_NAME);\\n            assertThat(generated.getClassLoader()).isSameAs(ReflectUtilsTest.class.getClassLoader());\\n        } catch (Error error) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(error);\\n        } catch (Exception exception) {\\n            rethrowUnlessNativeImageDynamicClassLoadingError(exception);\\n        }\\n    }\\n\\n    private static byte[] generatedClassBytes() {\\n        return Base64.getMimeDecoder().decode(\\\"\\\"\\\"\\n                yv66vgAAADQACgoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW\\n                BwAIAQAvY29tX2dvb2dsZV9pbmplY3QvZ3VpY2UvR2VuZXJhdGVkQnlSZWZsZWN0VXRpbHMBAARD\\n                b2RlADEABwACAAAAAAABAAEABQAGAAEACQAAABEAAQABAAAABSq3AAGxAAAAAAAA\\n                \\\"\\\"\\\");\\n    }\\n\\n    private static void rethrowUnlessNativeImageDynamicClassLoadingError(Throwable throwable) throws Exception {\\n        if (hasNativeImageUnsupportedFeatureError(throwable)) {\\n            return;\\n        }\\n        if (throwable instanceof Exception exception) {\\n            throw exception;\\n        }\\n        if (throwable instanceof Error error) {\\n            throw error;\\n        }\\n    }\\n\\n    private static boolean hasNativeImageUnsupportedFeatureError(Throwable throwable) {\\n        Throwable cu