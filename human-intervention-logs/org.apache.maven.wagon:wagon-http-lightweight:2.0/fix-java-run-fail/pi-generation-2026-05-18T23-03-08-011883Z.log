      }
  
      private LightweightHttpWagon newWagon() throws Exception {
          if (container == null) {
              container = new DefaultPlexusContainer();
              container.initialize();
              container.start();
          }
          return (LightweightHttpWagon) container.lookup(Wagon.ROLE, "http");
      }
  
