h", "arguments": {"command": "tmp=$(mktemp -d); cd $tmp; cat >pom.xml <<'EOF'\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\"><modelVersion>4.0.0</modelVersion><groupId>x</groupId><artifactId>x</artifactId><version>1</version><dependencies><dependency><groupId>org.apache.maven.doxia</groupId><artifactId>doxia-site-renderer</artifactId><version>2.0.0</version></dependency><dependency><groupId>com.google.inject</groupId><artifactId>guice</artifactId><version>6.0.0</version></dependency></dependencies></project>\nEOF\nmvn -q dependency:build-classpath -Dmdep.outputFile=cp.txt\nmkdir -p classes/META-INF/maven src\ncat >classes/META-INF/maven/site.vm <<'EOF'\n<html><head><title>$title</title></head><body>$bodyContent</body></html>\nEOF\ncat >src/index.xhtml <<'EOF'\n<html xmlns=\"http://www.w3.org/1999/xhtml\"><head><title>Hello</title></head><body><section><h1>Hi</h1><p>Text</p></section></body></html>\nEOF\ncat >Test.java <<'EOF'\nimport java.io.*; import java.util.*;\nimport org.codehaus.plexus.DefaultPlexusContainer;\nimport org.apache.maven.doxia.siterenderer.*;\nimport org.apache.maven.doxia.site.SiteModel;\npublic class Test { public static void main(String[] args) throws Exception {\n DefaultPlexusContainer c = new DefaultPlexusContainer();\n SiteRenderer r = c.lookup(SiteRenderer.class);\n SiteRenderingContext ctx = new SiteRenderingContext();\n ctx.setTemplateName(\"META-INF/maven/site.vm\"); ctx.setTemplateClassLoader(Test.class.getClassLoader());\n ctx.setSiteModel(new SiteModel()); ctx.setDefaultTitle(\"Default\"); ctx.setLocale(Locale.ROOT);\n StringWriter w = new StringWriter();\n r.renderDocument(w, new DocumentRenderingContext(new File(\"src\"), \"index.xhtml\", \"xhtml5\"), ctx);\n System.out.println(w.toString()); c.dispose();\n}}\nEOF\nCP=$(cat cp.txt):classes\njavac -cp \"$CP\" Test.java && java -cp \"$CP:.\" Test", "timeout": 60}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1100, "output": 649, "c