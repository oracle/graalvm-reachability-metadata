          String inputPath = docRenderingContext.getInputName();
          // Remove .vm suffix
          File outputFile =
                  new File(siteContext.getProcessedContentOutput(), inputPath.substring(0, inputPath.length() - 3));
  
          File outputParent = outputFile.getParentFile();
