          // Data objects
          // ----------------------------------------------------------------------
  
          context.put("relativePath", docRenderingContext.getRelativePath());
  
          String currentFilePath = docRenderingContext.getOutputName();
          context.put("currentFilePath", currentFilePath);
          // TODO Deprecated -- will be removed!
