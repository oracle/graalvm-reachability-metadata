ltSiteRenderer is a Plexus/Sisu component whose rendering paths depend on injected Doxia, VelocityComponent, ParserModuleManager, and PlexusContainer fields. The artifact's resolved dependencies include Sisu but omit Guice as a provided dependency; upstream 2.0.0 tests use plexus-testing to create the injected test container.\"\n    },\n    {\n      \"kind\": \"dependency\",\n      \"coordinate\": \"org.apache.maven.doxia:doxia-module-apt:2.0.0\",\n      \"scope\": \"testImplementation\",\n      \"reason\": \"Doxia parser modules are no longer all in doxia-core; the 2.0.0 POM explicitly notes parser modules must be declared so their component descriptors are picked up. Adding the APT module enables representative site-document rendering rather than only inert context/resource checks.\"\n    }\n  ],\n  \"agent_guidance\": \"No Docker image or environment property appears necessary. Tests should avoid removed 1.x APIs such as RenderingContext, SkinResourceLoader, enableLogging, and setUsingDefaultTemplate. Use the 2.0.0 APIs such as DocumentRenderingContext and SiteRenderingContext, obtain an injected renderer through the Plexus/JUnit test support, and create any skin/template input as temporary test files or a temporary skin jar.\",\n  \"risks\": [\n    \"Adding parser modules broadens the test classpath; keep assertions focused on doxia-site-renderer behavior rather than testing the parser module itself.\",\n    \"Local Gradle and Native Image verification remain authoritative because Sisu/Plexus component discovery can be sensitive to classpath differences.\"\n  ]\n}", "textSignature": "{\"v\":1,\"id\":\"msg_04ba8e8876618ad4016a3f5f2dd6708190b637e0ad14dbf206\",\"phase\":\"final_answer\"}"}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1001, "output": 1471, "cacheRead": 43008, "cacheWrite": 0, "totalTokens": 45480, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "stop", "time