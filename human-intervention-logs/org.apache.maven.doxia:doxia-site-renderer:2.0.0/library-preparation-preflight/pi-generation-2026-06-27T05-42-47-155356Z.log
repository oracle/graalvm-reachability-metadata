  136     private static void deepCopy(Path src, FileSystem zipfs) throws IOException {
  137         try (Stream<Path> stream = Files.walk(src)) {
  138             stream.forEach(source -> {
  139                 try {
  140                     // skip root
  141                     if (!src.equals(source)) {
  142                         Path relativeSrcPath = src.relativize(source);
  143                         if (Files.isDirectory(source)) {
  144                             Files.createDirectories(zipfs.getPath(relativeSrcPath.toString()));
  145                         } else {
  146                             Files.copy(
  147                                     source,
  148                                     zipfs.getPath(relativeSrcPath.toString()),
