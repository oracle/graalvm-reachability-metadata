 "text", "text": "\n--- getSiteRenderingContext\ntputDirectory = getTestFile(OUTPUT);\n236         // Safety\n237         org.apache.commons.io.FileUtils.deleteDirectory(outputDirectory);\n238 \n239         // ----------------------------------------------------------------------\n240         // Render the site from src/test/resources/site to OUTPUT\n241         // ----------------------------------------------------------------------\n242         SiteModel siteModel =\n243                 new SiteXpp3Reader().read(new FileInputStream(getTestFile(\"src/test/resources/site/site.xml\")));\n244 \n245         SiteRenderingContext ctxt =\n246                 getSiteRenderingContext(siteModel, minimalSkinJar, \"src/test/resources/site\", false);\n247         ctxt.setRootDirectory(getTestFile(\"\"));\n248         siteRenderer.render(siteRenderer.locateDocumentFiles(ctxt, true).values(), ctxt, outputDirectory);\n249 \n250         ctxt = getSiteRenderingContext(siteModel, minimalSkinJar, \"src/test/resources/site-validate\", true);\n251         ctxt.setRootDirectory(getTestFile(\"\"));\n252         siteRenderer.render(siteRenderer.locateDocumentFiles(ctxt, true).values(), ctxt, outputDirectory);\n253 \n254         siteRenderer.copyResources(ctxt, outputDirectory);\n255         // ----------------------------------------------------------------------\n256         // Verify specific pages\n257         // ----------------------------------------------------------------------\n258         verifyCdcPage();\n259         verifyNestedItemsPage();\n260         verifyMultipleBlock();\n261         verifyMacro();\n262         verifyEntitiesPage();\n263         verifyJavascriptPag\nresources/site to OUTPUT\n241         // ----------------------------------------------------------------------\n242         SiteModel siteModel =\n243                 new SiteXpp3Reader().read(new FileInputStream(getTestFile(\"src/test/resources/site/site.xml\")));\n244 \n245         SiteRenderingContext ctxt =\n246                 getSiteRenderingContext(siteModel, minimalSkinJar, \"src/test/resources/site\", false);\n247         ctxt.setRootDirectory(getTestFile(\"\"));\n248         siteRenderer.render(siteRenderer.locateDocumentFiles(ctxt, true).values(), ctxt, outputDirectory);\n249 \n250         ctxt = getSiteRenderingContext(siteModel, minimalSkinJar, \"src/test/resources/site-validate\", true);\n251         ctxt.setRootDirectory(getTestFile(\"\"));\n252         siteRenderer.render(siteRenderer.locateDocumentFiles(ctxt, true).values(), ctxt, outputDirectory);\n253 \n254         siteRenderer.copyResources(ctxt, outputDirectory);\n255         // ----------------------------------------------------------------------\n256         // Verify specific pages\n257         // ----------------------------------------------------------------------\n258         verifyCdcPage();\n259         verifyNestedItemsPage();\n260         verifyMultipleBlock();\n261         verifyMacro();\n262         verifyEntitiesPage();\n263         verifyJavascriptPage();\n264         verifyFaqPage();\n265         verifyAttributes();\n266         verifyApt();\n267         verifyExtensionInFilename();\n268         verifyNewlines();\n269         verifyMermaidPage(null);\n270         // -----------------------------------------------------------\n extension, false);\n285         DocumentRenderer docRenderer = new DoxiaDocumentRenderer(docRenderingContext);\n286 \n287         siteRenderer.render(Collections.singletonList(docRenderer), context, outputDirectory);\n288         siteRenderer.copyResources(context, outputDirectory);\n289     }\n290 \n291     @Test\n292     void mermaidWithExternalJs() throws Exception {\n293         SiteModel siteModel = new SiteXpp3Reader()\n294                 .read(new FileInputStream(getTestFile(\"src/test/resources/site-mermaid-externaljs/site.xml\")));\n295         SiteRenderingContext context =\n296                 getSiteRenderingContext(siteModel, minimalSkinJar, \"src/test/resources/site\", false);\n297 \n298         renderDocument(context, \"src/test/resources/site/markdown\", \"mermaid.md\", \"md\", \"markdown\");\n299 \n300         verifyMermaidPage(\n301                 \"<script src=\\\"https://cdn.jsdelivr.net/npm/mermaid@11.12.3/dist/mermaid.min.js\\\" integrity=\\\"sha512-/yppbXbmq0NnMz+OhfzrvQDSePwPAixE8Ywi8U7KayJPv5ZFVYo7bzBgkR5V6OQ/8YHEh/gPMarWD+6ZIuNj5A==\\\" crossorigin=\\\"anonymous\\\" referrerpolicy=\\\"no-referrer\\\" fetchpriority=\\\"high\\\"></script>\");\n302     }\n303 \n304     @Test\n305     void externalReport() throws Exception {\n306         DocumentRenderer docRenderer = mock(DocumentRenderer.class);\n307         when(docRenderer.isExternalReport()).thenReturn(true);\n308         when(docRenderer.getOutputName()).thenReturn(\"external/index\");\n309         when(docRenderer.getRenderingContext())\n310                 .thenReturn(new DocumentRenderingContext(new File(\"\"), \"index.html\", \"generator:external\"));\n311 \n\n423     }\n424 \n425     @Test\n426     void copyResourcesConditionally() throws Exception {\n427         File skinJar = new File(getBasedir(), \"target/test-classes/skin-with-conditional-resources.jar\");\n428         createJarFromDirectory(\n429                 getTestFile(\"src/test/resources/skin-with-conditional-resources\")\n430                         .toPath(),\n431                 skinJar.toPath());\n432 \n433         SiteModel siteModel =\n434                 new SiteXpp3Reader().read(new FileInputStream(getTestFile(\"src/test/resources/site/site.xml\")));\n435         SiteRenderingContext context = getSiteRenderingContext(siteModel, skinJar, \"src/test/resources/site\", false);\n436         File sourceDirectory = getTestFile(\"src/test/resources/site-validate\");\n437         context.setRootDirectory(sourceDirectory);\n438         Path outputDirectory = Files.createTempDirectory(\"site-output-\");\n439         siteRenderer.copyResources(context, outputDirectory.toFile())