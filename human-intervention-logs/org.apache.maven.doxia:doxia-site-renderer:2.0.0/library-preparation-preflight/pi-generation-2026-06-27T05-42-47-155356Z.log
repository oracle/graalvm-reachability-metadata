  128     private static void createJarFromDirectory(Path srcDirectory, Path jarfile) throws IOException {
  129         Map<String, String> env = new HashMap<>();
  130         env.put("create", "true");
  131         try (FileSystem zipfs = FileSystems.newFileSystem(URI.create("jar:" + jarfile.toUri()), env)) {
  132             deepCopy(srcDirectory, zipfs);
  133         }
  134     }
