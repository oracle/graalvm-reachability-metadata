  200                     String excludes = (moduleExcludes == null) ? null : moduleExcludes.get(module.getParserId());
  201 
  202                     addModuleFiles(
  203                             siteRenderingContext.getRootDirectory(),
  204                             siteDirectory,
  205                             moduleBasedir,
  206                             module,
  207                             excludes,
  208                             files);
  209                 }
  210             }
  211         }
  212 
  213         return files;
  214     }
