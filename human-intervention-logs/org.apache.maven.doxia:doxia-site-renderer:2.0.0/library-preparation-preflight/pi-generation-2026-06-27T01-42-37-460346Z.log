  730:                     if (restriction.containsVersion(v)) {
  731:                         matched = true;
  732:                         break;
  733:                     }
  734:                 }
  735:             } else {
  736:                 // only singular versions ever have a recommendedVersion
  737:                 @SuppressWarnings("unchecked")
  738:                 int compareTo = recommendedVersion.compareTo(v);
