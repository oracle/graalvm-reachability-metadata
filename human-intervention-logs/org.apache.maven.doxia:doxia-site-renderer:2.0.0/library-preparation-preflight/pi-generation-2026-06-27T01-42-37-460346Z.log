              jarOS.putNextEntry(new ZipEntry("META-INF/maven/site.vm"));
              IOUtil.copy(skinIS, jarOS);
              jarOS.closeEntry();
          } finally {
              IOUtil.close(skinIS);
              IOUtil.close(jarOS);
          }
      }
  
