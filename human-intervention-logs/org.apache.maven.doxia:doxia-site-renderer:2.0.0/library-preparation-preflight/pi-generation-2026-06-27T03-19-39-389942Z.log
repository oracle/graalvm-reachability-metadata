      // Requirements
      // ----------------------------------------------------------------------
  
      @Inject
      private VelocityComponent velocity;
  
      @Inject
      private ParserModuleManager parserModuleManager;
  
      @Inject
      private Doxia doxia;
  
      @Inject
      private PlexusContainer plexus;
  
      private static final String SKIN_TEMPLATE_LOCATION = "META-INF/maven/site.vm";
  
