              } catch (IOException ioe) {
                  throw new RendererException("IO exception while merging site template.", ioe);
              }
          } finally {
              IOUtil.close(writer);
  
              if (old != null) {
                  Thread.currentThread().setContextClassLoader(old);
              }
          }
      }
  
