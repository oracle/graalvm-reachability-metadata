      static boolean endsWithIgnoreCase(String str, String searchStr) {
          if (str.length() < searchStr.length()) {
              return false;
          }
  
          return str.regionMatches(true, str.length() - searchStr.length(), searchStr, 0, searchStr.length());
      }
  
