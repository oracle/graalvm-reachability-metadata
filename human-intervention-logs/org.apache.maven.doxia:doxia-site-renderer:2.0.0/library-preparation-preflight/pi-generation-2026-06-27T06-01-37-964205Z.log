        <artifactId>slf4j-simple</artifactId>
        <scope>test</scope>
      </dependency>
    </dependencies>
  
    <profiles>
      <profile>
        <id>reporting</id>
        <reporting>
          <plugins>
            <plugin>
              <groupId>org.codehaus.mojo</groupId>
              <artifactId>l10n-maven-plugin</artifactId>
              <version>${l10nPluginVersion}</version>
              <configuration>
                <locales>
                  <locale>de</locale>
                  <locale>en</locale>
                  <locale>es</locale>
                  <locale>fr</locale>
                  <locale>it</locale>
                  <locale>ja</locale>
