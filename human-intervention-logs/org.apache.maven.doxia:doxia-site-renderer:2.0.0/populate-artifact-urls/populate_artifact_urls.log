      <artifactId>doxia-core</artifactId>
      <version>${doxiaVersion}</version>
      <type>test-jar</type>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.htmlunit</groupId>
      <artifactId>htmlunit</artifactId>
      <version>4.4.0</version>
      <scope>test</scope>
      <exclusions>
