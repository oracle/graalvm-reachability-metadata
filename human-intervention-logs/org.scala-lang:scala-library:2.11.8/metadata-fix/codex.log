{"type":"item.completed","item":{"id":"item_175","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ScalaCollectionImmutableListInnerSerializationProxyTest.scala\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass ScalaCollectionImmutableListInnerSerializationProxyTest {\n  @Test\n  def serializesAndDeserializesImmutableListThroughJavaObjectStreams(): Unit = {\n    val original: List[String] = List(\"alpha\", \"beta\", \"gamma\")\n\n    val restored: List[String] = roundTrip[List[String]](original)\n\n    assertThat(restored).isNotSameAs(original)\n    assertThat(restored).isEqualTo(original)\n    assertThat(restored.mkString(\",\")).isEqualTo(\"alpha,beta,gamma\")\n  }\n\n  private def roundTrip[A](value: AnyRef): A = {\n    val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(buffer)\n    try {\n      output.writeObject(value)\n      output.flush()\n    } finally {\n      output.close()\n    }\n\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(buffer.toByteArray))\n    try {\n      input.readObject().asInstanceOf[A]\n    } finally {\n      input.close()\n    }\n  }\n}\n","exit_code":0,"status":"completed"}}
