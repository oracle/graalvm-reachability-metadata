{"type":"item.completed","item":{"id":"item_114","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,200p' tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ScalaEnumerationTest.scala\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\n\nimport scala.Enumeration\nimport scala.math.BigDecimal.RoundingMode\n\nfinal class ScalaEnumerationTest {\n  @Test\n  def derivesValueNamesFromPublicEnumerationAccessors(): Unit = {\n    assertEquals(\"UP\", RoundingMode.UP.toString)\n    assertEquals(\"HALF_EVEN\", RoundingMode.HALF_EVEN.toString)\n    assertEquals(RoundingMode.UP, RoundingMode.withName(\"UP\"))\n  }\n\n  @Test\n  def serializationRestoresEnumerationSingleton(): Unit = {\n    val restored: Enumeration = roundTrip(RoundingMode)\n\n    assertSame(RoundingMode, restored)\n    assertEquals(RoundingMode.values, restored.values)\n  }\n\n  private def roundTrip(enumeration: Enumeration): Enumeration = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val objectOut: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      objectOut.writeObject(enumeration)\n    } finally {\n      objectOut.close()\n    }\n\n    val objectIn: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray))\n    try {\n      objectIn.readObject().asInstanceOf[Enumeration]\n    } finally {\n      objectIn.close()\n    }\n  }\n}\n","exit_code":0,"status":"completed"}}
