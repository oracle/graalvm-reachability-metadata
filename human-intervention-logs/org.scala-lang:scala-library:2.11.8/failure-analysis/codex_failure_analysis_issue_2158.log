work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scala_lang.scala_library\\n\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport java.io.ByteArrayInputStream\\nimport java.io.ByteArrayOutputStream\\nimport java.io.ObjectInputStream\\nimport java.io.ObjectOutputStream\\nimport scala.collection.immutable.{HashMap => ImmutableHashMap}\\n\\nclass HashMapInnerSerializationProxyInnerAnonfunInnerWriteObjectAnonymous2Test {\\n  @Test\\n  def serializationWritesEachKeyAndValueThroughHashMapSerializationProxy(): Unit = {\\n    val original: ImmutableHashMap[String, String] = ImmutableHashMap(\\n      \\\"first-key\\\" -> \\\"first-value\\\",\\n      \\\"second-key\\\" -> \\\"second-value\\\")\\n\\n    val restored: ImmutableHashMap[String, String] = deserializeHashMap(serialize(original))\\n\\n    assertThat(restored.size).isEqualTo(2)\\n    assertThat(restored(\\\"first-key\\\")).isEqualTo(\\\"first-value\\\")\\n    assertThat(restored(\\\"second-key\\\")).isEqualTo(\\\"second-value\\\")\\n  }\\n\\n  private def serialize(value: AnyRef): Array[Byte] = {\\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\\n    try {\\n      output.writeObject(value)\\n    } finally {\\n      output.close()\\n    }\\n    bytes.toByteArray\\n  }\\n\\n  private def deserializeHashMap(bytes: Array[Byte]): ImmutableHashMap[String, String] = {\\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\\n    try {\\n      input.readObject().asInstanceOf[ImmutableHashMap[String, String]]\\n    } finally {\\n      input.close()\\n    }\\n  }\\n}\\n\"}\n1787:[tool-call] end id=call_Rr1QpXGpW06MMQNgSP8LdXpC|fc_07fcf267a7790e780169f91aa7edc08191b3d9b9797c854391 name=write args={\"path\": \"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/HashMapInnerSerializationProxyInnerAnonfunInnerWriteObjectAnonymous2Test.scala\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scala_lang.scala_library\\n\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport java.io.ByteArrayInputStream\\nimport java.io.ByteArrayOutputStream\\nimport java.io.ObjectInputStream\\nimport java.io.ObjectOutputStream\\nimport scala.collection.immutable.{HashMap => ImmutableHashMap}\\n\\nclass HashMapInnerSerializationProxyInnerAnonfunInnerWriteObjectAnonymous2Test {\\n  @Test\\n  def serializationWritesEachKeyAndValueThroughHashMapSerializationProxy(): Unit = {\\n    val original: ImmutableHashMap[String, String] = ImmutableHashMap(\\n      \\\"first-key\\\" -> \\\"first-value\\\",\\n      \\\"second-key\\\" -> \\\"second-value\\\")\\n\\n    val restored: ImmutableHashMap[String, String] = deserializeHashMap(serialize(original))\\n\\n    assertThat(restored.size).isEqualTo(2)\\n    assertThat(restored(\\\"first-key\\\")).isEqualTo(\\\"first-value\\\")\\n    assertThat(restored(\\\"second-key\\\")).isEqualTo(\\\"second-value\\\")\\n  }\\n\\n  private def serialize(value: AnyRef): Array[Byte] = {\\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\\n    try {\\n      output.writeObject(value)\\n    } finally {\\n      output.close()\\n    }\\n    bytes.toByteArray\\n  }\\n\\n  private def deserializeHashMap(bytes: Array[Byte]): ImmutableHashMap[String, String] = {\\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\\n    try {\\n      input.readObject().asInstanceOf[ImmutableHashMap[String, String]]\\n    } finally {\\n      input.close()\\n    }\\n  }\\n}\\n\"}\n1788:[recv] {\"type\": \"message_e