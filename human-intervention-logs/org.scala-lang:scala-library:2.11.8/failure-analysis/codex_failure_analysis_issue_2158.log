ntent\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scala_lang.scala_library\\n\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport java.io.ByteArrayInputStream\\nimport java.io.ByteArrayOutputStream\\nimport java.io.ObjectInputStream\\nimport java.io.ObjectOutputStream\\nimport scala.collection.concurrent.TrieMap\\n\\nclass TrieMapTest {\\n  @Test\\n  def serializesAndDeserializesEntries(): Unit = {\\n    val source: TrieMap[String, String] = new TrieMap[String, String]()\\n    source.put(\\\"alpha\\\", \\\"one\\\")\\n    source.put(\\\"beta\\\", \\\"two\\\")\\n\\n    val bytes: Array[Byte] = serialize(source)\\n    val restored: TrieMap[String, String] = deserializeTrieMap(bytes)\\n\\n    assertThat(restored.size).isEqualTo(2)\\n    assertThat(restored.get(\\\"alpha\\\")).isEqualTo(Some(\\\"one\\\"))\\n    assertThat(restored.get(\\\"beta\\\")).isEqualTo(Some(\\\"two\\\"))\\n    assertThat(restored.putIfAbsent(\\\"gamma\\\", \\\"three\\\")).isEqualTo(None)\\n    assertThat(restored.get(\\\"gamma\\\")).isEqualTo(Some(\\\"three\\\"))\\n  }\\n\\n  private def serialize(map: TrieMap[String, String]): Array[Byte] = {\\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\\n    try {\\n      output.writeObject(map)\\n    } finally {\\n      output.close()\\n    }\\n    bytes.toByteArray\\n  }\\n\\n  private def deserializeTrieMap(bytes: Array[Byte]): TrieMap[String, String] = {\\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\\n    try {\\n      input.readObject().asInstanceOf[TrieMap[String, String]]\\n    } finally {\\n      input.close()\\n    }\\n  }\\n}\\n\"}], \"isError\": false,