  package org_scala_lang.scala_library;
  
  import java.util.concurrent.CountDownLatch;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicReference;
  
  import scala.concurrent.forkjoin.ForkJoinPool;
  
  public final class ForkJoinPoolTestSupport {
      public static final String THREAD_FACTORY_PROPERTY = "java.util.concurrent.ForkJoinPool.common.threadFactory";
      public static final String EXCEPTION_HANDLER_PROPERTY = "java.util.concurrent.ForkJoinPool.common.exceptionHandler";
      public static final String CONFIGURED_WORKER_THREAD_FACTORY_CLASS_NAME =
              ForkJoinPoolConfiguredWorkerThreadFactory.class.getName();
      public static final String CONFIGURED_EXCEPTION_HANDLER_CLASS_NAME =
              ForkJoinPoolConfiguredExceptionHandler.class.getName();
      public static final String CONFIGURED_WORKER_THREAD_CLASS_NAME =
              ForkJoinPoolConfiguredWorkerThread.class.getName();
  
      private ForkJoinPoolTestSupport() {
      }
  
      public static String runInConfiguredCommonPool() throws InterruptedException {
          ForkJoinPool pool = ForkJoinPool.commonPool();
          AtomicReference<String> workerThreadClassName = new AtomicReference<>();
          CountDownLatch completed = new CountDownLatch(1);
  
          try {
              pool.execute(new ThreadNameRunnable(workerThreadClassName, completed));
              if (!completed.await(10L, TimeUnit.SECONDS)) {
                  throw new AssertionError("Timed out waiting for ForkJoinPool worker");
              }
              return workerThreadClassName.get();
          } finally {
              pool.awaitQuiescence(10L, TimeUnit.SECONDS);
          }
      }
  
      private static final class ThreadNameRunnable implements Runnable {
          private final AtomicReference<String> workerThreadClassName;
          private final CountDownLatch completed;
  
          private ThreadNameRunnable(AtomicReference<String> workerThreadClassName, CountDownLatch completed) {
              this.workerThreadClassName = workerThreadClassName;
              this.completed = completed;
          }
  
          @Override
          public void run() {
              workerThreadClassName.set(Thread.currentThread().getClass().getName());
              completed.countDown();
          }
      }
  }
