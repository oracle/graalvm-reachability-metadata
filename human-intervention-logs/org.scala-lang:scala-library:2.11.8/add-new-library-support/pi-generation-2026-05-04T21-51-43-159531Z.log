[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/LinkedTransferQueueTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.concurrent.forkjoin.LinkedTransferQueue\n\nclass LinkedTransferQueueTest {\n  @Test\n  def serializesAndDeserializesQueuedElements(): Unit = {\n    val original: LinkedTransferQueue[String] = new LinkedTransferQueue[String]()\n    original.add(\"first\")\n    original.add(\"second\")\n\n    val restored: LinkedTransferQueue[String] = deserialize(serialize(original))\n\n    assertThat(restored.poll()).isEqualTo(\"first\")\n    assertThat(restored.poll()).isEqualTo(\"second\")\n    assertThat(restored.isEmpty).isTrue()\n  }\n\n  private def serialize(queue: LinkedTransferQueue[String]): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(queue)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserialize(bytes: Array[Byte]): LinkedTransferQueue[String] = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[LinkedTransferQueue[String]]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}
