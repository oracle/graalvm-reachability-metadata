  package org_scala_lang.scala_library
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class ForkJoinPoolTest {
    @Test
    def configuresCommonPoolFromSystemProperties(): Unit = {
      assertThat(System.getProperty(ForkJoinPoolTestSupport.THREAD_FACTORY_PROPERTY))
        .isEqualTo(ForkJoinPoolTestSupport.CONFIGURED_WORKER_THREAD_FACTORY_CLASS_NAME)
      assertThat(System.getProperty(ForkJoinPoolTestSupport.EXCEPTION_HANDLER_PROPERTY))
        .isEqualTo(ForkJoinPoolTestSupport.CONFIGURED_EXCEPTION_HANDLER_CLASS_NAME)
  
      assertThat(ForkJoinPoolTestSupport.runInConfiguredCommonPool())
        .isEqualTo(ForkJoinPoolTestSupport.CONFIGURED_WORKER_THREAD_CLASS_NAME)
    }
  }
