  diff --git 1/tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/UnrolledBufferTest.scala 2/tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/UnrolledBufferTest.scala
  new file mode 100644
