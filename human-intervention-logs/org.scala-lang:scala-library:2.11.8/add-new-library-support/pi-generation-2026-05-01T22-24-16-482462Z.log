= 0.until(75)\n    original.update(0, 42)\n    original.remove(5)\n    original.insertAll(10, Seq(-3, -2, -1))\n\n    val restored: UnrolledBuffer[Int] = deserializeBuffer[Int](serialize(original))\n\n    assertThat(restored).isNotSameAs(original)\n    assertThat(restored.length).isEqualTo(original.length)\n    assertThat(restored.toList.asJava).containsExactlyElementsOf(original.toList.asJava)\n\n    restored += 99\n    assertThat(restored.last).isEqualTo(99)\n  }\n\n  private def serialize(value: UnrolledBuffer[Int]): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val out: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      out.writeObject(value)\n      out.flush()\n      bytes.toByteArray\n    } finally {\n      out.close()\n    }\n  }\n\n  private def deserializeBuffer[A](bytes: Array[Byte]): UnrolledBuffer[A] = {\n    val in: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      in.readObject().asInstanceOf[UnrolledBuffer[A]]\n    } finally {\n      in.close()\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 424, "output": 1163, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 29747, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777674142546, "responseId": "resp_0ab3df24a8af6ee70169f5279efd58819fb91a174a3dae8198"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FWwS4UnIssU2YHRi4EpnP2qu|fc_0ab3df24a8af6ee70169f527a81ce8819fb4a53087e48ac8f8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1802 bytes to tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/UnrolledBufferTest.scala"}], "isError": false, "timestamp": 1777674155310}]}
