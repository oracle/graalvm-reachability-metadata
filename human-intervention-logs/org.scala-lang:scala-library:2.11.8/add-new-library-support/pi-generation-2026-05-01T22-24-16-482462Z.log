[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/UnrolledBufferTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport scala.collection.JavaConverters._\nimport scala.collection.mutable.UnrolledBuffer\n\nfinal class UnrolledBufferTest {\n  @Test\n  def serializesAndRestoresElementsAcrossUnrolledNodes(): Unit = {\n    val original: UnrolledBuffer[Int] = new UnrolledBuffer[Int]()\n    original ++= 0.until(75)\n    original.update(0, 42)\n    original.remove(5)\n    original.insertAll(10, Seq(-3, -2, -1))\n\n    val restored: UnrolledBuffer[Int] = deserializeBuffer[Int](serialize(original))\n\n    assertThat(restored).isNotSameAs(original)\n    assertThat(restored.length).isEqualTo(original.length)\n    assertThat(restored.toList.asJava).containsExactlyElementsOf(original.toList.asJava)\n\n    restored += 99\n    assertThat(restored.last).isEqualTo(99)\n  }\n\n  private def serialize(value: UnrolledBuffer[Int]): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val out: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      out.writeObject(value)\n      out.flush()\n      bytes.toByteArray\n    } finally {\n      out.close()\n    }\n  }\n\n  private def deserializeBuffer[A](bytes: Array[Byte]): UnrolledBuffer[A] = {\n    val in: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      in.readObject().asInstanceOf[UnrolledBuffer[A]]\n    } finally {\n      in.close()\n    }\n  }\n}\n"}
