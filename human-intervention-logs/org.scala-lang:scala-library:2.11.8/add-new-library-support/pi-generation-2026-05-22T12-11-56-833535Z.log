  package org_scala_lang.scala_library
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import scala.math.BigDecimal.RoundingMode
  
  class ScalaEnumerationTest {
    @Test
    def discoversValueNamesFromPublicEnumerationFields(): Unit = {
      val valueNames: String = RoundingMode.values.toList.map(_.toString).mkString(",")
  
      assertThat(valueNames).isEqualTo("UP,DOWN,CEILING,FLOOR,HALF_UP,HALF_DOWN,HALF_EVEN,UNNECESSARY")
      assertThat(RoundingMode.withName("HALF_EVEN")).isSameAs(RoundingMode.HALF_EVEN)
    }
  
    @Test
    def preservesEnumerationSingletonAndValuesThroughJavaSerialization(): Unit = {
      val restoredEnumeration: Enumeration = roundTrip[Enumeration](RoundingMode)
      val restoredValue: RoundingMode.Value = roundTrip[RoundingMode.Value](RoundingMode.HALF_UP)
  
      assertThat(restoredEnumeration).isSameAs(RoundingMode)
      assertThat(restoredValue).isSameAs(RoundingMode.HALF_UP)
    }
  
    private def roundTrip[A](value: AnyRef): A = {
      val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()
      val output: ObjectOutputStream = new ObjectOutputStream(buffer)
      try {
        output.writeObject(value)
        output.flush()
      } finally {
        output.close()
      }
  
      val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(buffer.toByteArray))
      try {
        input.readObject().asInstanceOf[A]
      } finally {
        input.close()
      }
    }
  }
