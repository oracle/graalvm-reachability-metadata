  package org_scala_lang.scala_library
  
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Assertions.assertNull
  import org.junit.jupiter.api.Test
  
  import scala.reflect.ClassManifestFactory
  
  final class ScalaReflectClassManifestDeprecatedApisInnerclassTest {
    @Test
    def deprecatedClassManifestAllocatesArraysOfEverySupportedRank(): Unit = {
      val manifest = ClassManifestFactory.classType[String](classOf[String])
  
      val arrayManifest = manifest.arrayManifest
      assertEquals(classOf[Array[String]], arrayManifest.runtimeClass)
  
      val oneDimensional: Array[String] = manifest.newArray(2)
      assertEquals(classOf[Array[String]], oneDimensional.getClass)
      assertEquals(2, oneDimensional.length)
      assertNull(oneDimensional(0))
  
      val twoDimensional: Array[Array[String]] = manifest.newArray2(3)
      assertEquals(classOf[Array[Array[String]]], twoDimensional.getClass)
      assertEquals(3, twoDimensional.length)
      assertNull(twoDimensional(0))
  
      val threeDimensional: Array[Array[Array[String]]] = manifest.newArray3(4)
      assertEquals(classOf[Array[Array[Array[String]]]], threeDimensional.getClass)
      assertEquals(4, threeDimensional.length)
      assertNull(threeDimensional(0))
  
      val fourDimensional: Array[Array[Array[Array[String]]]] = manifest.newArray4(5)
      assertEquals(classOf[Array[Array[Array[Array[String]]]]], fourDimensional.getClass)
      assertEquals(5, fourDimensional.length)
      assertNull(fourDimensional(0))
  
      val fiveDimensional: Array[Array[Array[Array[Array[String]]]]] = manifest.newArray5(6)
      assertEquals(classOf[Array[Array[Array[Array[Array[String]]]]]], fiveDimensional.getClass)
      assertEquals(6, fiveDimensional.length)
      assertNull(fiveDimensional(0))
    }
  }
