  package org_scala_lang.scala_library
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Assertions.assertNotSame
  import org.junit.jupiter.api.Assertions.assertTrue
  import org.junit.jupiter.api.Test
  
  import scala.collection.concurrent.TrieMap
  
  final class ScalaCollectionConcurrentTrieMapTest {
    @Test
    def serializesEntriesAndRestoresConcurrentMap(): Unit = {
      val original: TrieMap[String, Integer] = new TrieMap[String, Integer]()
      original.put("alpha", Integer.valueOf(1))
      original.put("beta", Integer.valueOf(2))
  
      val restored: TrieMap[String, Integer] = roundTrip(original)
  
      assertNotSame(original, restored)
      assertEquals(2, restored.size)
      assertTrue(restored.get("alpha").contains(Integer.valueOf(1)))
      assertTrue(restored.get("beta").contains(Integer.valueOf(2)))
  
      restored.put("gamma", Integer.valueOf(3))
      assertTrue(restored.get("gamma").contains(Integer.valueOf(3)))
    }
  
    private def roundTrip(map: TrieMap[String, Integer]): TrieMap[String, Integer] = {
      val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()
      val objectOut: ObjectOutputStream = new ObjectOutputStream(bytes)
      try {
        objectOut.writeObject(map)
      } finally {
        objectOut.close()
      }
  
      val objectIn: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray))
      try {
        objectIn.readObject().asInstanceOf[TrieMap[String, Integer]]
      } finally {
        objectIn.close()
      }
    }
  }
