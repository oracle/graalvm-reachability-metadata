  package org_scala_lang.scala_library
  
  import java.io.ByteArrayOutputStream
  import java.io.ObjectOutputStream
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import scala.collection.immutable.HashMap
  
  class ScalaCollectionImmutableHashMapInnerSerializationProxyInnerAnonfunInnerWriteObjectAnonymous2Test {
    @Test
    def serializesEachImmutableHashMapKeyAndValueThroughJavaObjectStreams(): Unit = {
      val original: HashMap[String, Integer] = HashMap(
        "first" -> Integer.valueOf(1),
        "second" -> Integer.valueOf(2),
        "third" -> Integer.valueOf(3))
  
      val serialized: Array[Byte] = serialize(original)
  
      assertThat(serialized.length).isGreaterThan(0)
    }
  
    private def serialize(value: AnyRef): Array[Byte] = {
      val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()
      val output: ObjectOutputStream = new ObjectOutputStream(buffer)
      try {
        output.writeObject(value)
        output.flush()
      } finally {
        output.close()
      }
      buffer.toByteArray
    }
  }
