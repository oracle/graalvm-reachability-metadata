      private def readObject(in: java.io.ObjectInputStream) {
        orig = empty
        val s = in.readInt()
        for (i <- 0 until s) {
          val key = in.readObject().asInstanceOf[A]
          val value = in.readObject().asInstanceOf[B]
          orig = orig.updated(key, value)
        }
      }
  
      private def readResolve(): AnyRef = orig
    }
  }
