  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_scala_lang.scala_library
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  import scala.collection.JavaConverters._
  import scala.collection.mutable.UnrolledBuffer
  
  final class UnrolledBufferTest {
    @Test
    def serializesAndRestoresElementsAcrossUnrolledNodes(): Unit = {
      val original: UnrolledBufferDirectSerializationBuffer = new UnrolledBufferDirectSerializationBuffer()
      original ++= (0 until 75).map(index => s"element-$index")
      original.update(0, "updated-first")
      original.remove(5)
      original.insertAll(10, Seq("inserted-a", "inserted-b", "inserted-c"))
  
      val restored: UnrolledBuffer[AnyRef] = deserializeBuffer[AnyRef](serialize(original))
  
      assertThat(restored).isNotSameAs(original)
      assertThat(restored.length).isEqualTo(original.length)
      assertThat(restored.toList.asJava).containsExactlyElementsOf(original.toList.asJava)
  
      restored += "appended-after-deserialization"
      assertThat(restored.last).isEqualTo("appended-after-deserialization")
    }
  
    private def serialize(value: UnrolledBufferDirectSerializationBuffer): Array[Byte] = {
      val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()
      val out: ObjectOutputStream = new ObjectOutputStream(bytes)
      try {
        out.writeObject(value)
        out.flush()
        bytes.toByteArray
      } finally {
        out.close()
      }
    }
  
    private def deserializeBuffer[A](bytes: Array[Byte]): UnrolledBuffer[A] = {
      val in: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))
      try {
        in.readObject().asInstanceOf[UnrolledBuffer[A]]
      } finally {
        in.close()
      }
    }
  }
