              } else RDCSS_Complete(abort)
            } else {
              if (CAS_ROOT(desc, ov)) ov
              else RDCSS_Complete(abort)
            }
          }
      }
    }
  
    private def RDCSS_ROOT(ov: INode[K, V], expectedmain: MainNode[K, V], nv: INode[K, V]): Boolean = {
