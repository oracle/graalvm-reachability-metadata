[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ListBufferTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport scala.collection.mutable.ListBuffer\n\nclass ListBufferTest {\n  @Test\n  def serializesAndDeserializesMultipleElements(): Unit = {\n    val source: ListBuffer[String] = ListBuffer.empty[String]\n    source += \"alpha\"\n    source += \"beta\"\n    source += \"gamma\"\n\n    val bytes: Array[Byte] = serialize(source)\n    val restored: ListBuffer[String] = deserializeListBuffer(bytes)\n    restored += \"delta\"\n\n    assertThat(restored.length).isEqualTo(4)\n    assertThat(restored(0)).isEqualTo(\"alpha\")\n    assertThat(restored(1)).isEqualTo(\"beta\")\n    assertThat(restored(2)).isEqualTo(\"gamma\")\n    assertThat(restored(3)).isEqualTo(\"delta\")\n  }\n\n  private def serialize(buffer: ListBuffer[String]): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(buffer)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserializeListBuffer(bytes: Array[Byte]): ListBuffer[String] = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[ListBuffer[String]]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}
