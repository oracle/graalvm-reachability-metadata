  import org.junit.jupiter.api.Test
  
  import java.lang.reflect.Method
  import scala.reflect.ClassTag
  
  class ClassManifestDeprecatedApisInnerclassTest {
    @Test
    def createsArraysWithDeprecatedClassManifestApis(): Unit = {
      val tag: ClassTag[String] = ClassTag(classOf[String])
  
