[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ScalaConcurrentForkjoinLinkedTransferQueueTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.concurrent.forkjoin.LinkedTransferQueue\n\nclass ScalaConcurrentForkjoinLinkedTransferQueueTest {\n  @Test\n  def serializesAndDeserializesQueuedElements(): Unit = {\n    val queue: LinkedTransferQueue[String] = new LinkedTransferQueue[String]()\n    queue.add(\"first\")\n    queue.add(\"second\")\n\n    val serializedQueue: Array[Byte] = serialize(queue)\n    val deserializedQueue: LinkedTransferQueue[String] = deserialize(serializedQueue)\n\n    assertThat(deserializedQueue.poll()).isEqualTo(\"first\")\n    assertThat(deserializedQueue.poll()).isEqualTo(\"second\")\n    assertThat(deserializedQueue.isEmpty).isTrue\n  }\n\n  private def serialize(queue: LinkedTransferQueue[String]): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(queue)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserialize(serializedQueue: Array[Byte]): LinkedTransferQueue[String] = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(serializedQueue))\n    try {\n      input.readObject().asInstanceOf[LinkedTransferQueue[String]]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}
[tool-call] end id=call_z7HKqfprjMs9Xjhnlij18e9D|fc_04489e61265d56c7016a104e71dedc81a1a0a11856a195ff09 name=write args={"path": "tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ScalaConcurrentForkjoinLinkedTransferQueueTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.concurrent.forkjoin.LinkedTransferQueue\n\nclass ScalaConcurrentForkjoinLinkedTransferQueueTest {\n  @Test\n  def serializesAndDeserializesQueuedElements(): Unit = {\n    val queue: LinkedTransferQueue[String] = new LinkedTransferQueue[String]()\n    queue.add(\"first\")\n    queue.add(\"second\")\n\n    val serializedQueue: Array[Byte] = serialize(queue)\n    val deserializedQueue: LinkedTransferQueue[String] = deserialize(serializedQueue)\n\n    assertThat(deserializedQueue.poll()).isEqualTo(\"first\")\n    assertThat(deserializedQueue.poll()).isEqualTo(\"second\")\n    assertThat(deserializedQueue.isEmpty).isTrue\n  }\n\n  private def serialize(queue: LinkedTransferQueue[String]): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(queue)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserialize(serializedQueue: Array[Byte]): LinkedTransferQueue[String] = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(serializedQueue))\n    try {\n      input.readObject().asInstanceOf[LinkedTransferQueue[String]]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}
