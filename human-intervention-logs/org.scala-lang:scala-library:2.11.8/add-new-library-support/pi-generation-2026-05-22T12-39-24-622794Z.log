  class ScalaConcurrentForkjoinForkJoinPoolTest {
    @Test
    def initializesForkJoinPoolWithConfiguredCommonPoolClasses(): Unit = {
      val factoryPropertyName: String = "java.util.concurrent.ForkJoinPool.common.threadFactory"
      val handlerPropertyName: String = "java.util.concurrent.ForkJoinPool.common.exceptionHandler"
      val parallelismPropertyName: String = "java.util.concurrent.ForkJoinPool.common.parallelism"
