scala.concurrent.forkjoin.LinkedTransferQueue;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.ArrayList;\nimport java.util.List;\n\npublic final class LinkedTransferQueues {\n    private LinkedTransferQueues() {\n    }\n\n    public static List<String> serializeAndDrain(String first, String second) throws IOException, ClassNotFoundException {\n        LinkedTransferQueue<String> queue = new LinkedTransferQueue<>();\n        queue.add(first);\n        queue.add(second);\n\n        LinkedTransferQueue<String> deserializedQueue = deserialize(serialize(queue));\n        List<String> elements = new ArrayList<>();\n        String element;\n        while ((element = deserializedQueue.poll()) != null) {\n            elements.add(element);\n        }\n        return elements;\n    }\n\n    private static byte[] serialize(LinkedTransferQueue<String> queue) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(queue);\n        }\n        return bytes.toByteArray();\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static LinkedTransferQueue<String> deserialize(byte[] serializedQueue) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedQueue))) {\n            return (LinkedTransferQueue<String>) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 11633, "output": 954, "cacheRead": 7680, "cacheWrite": 0, "totalTokens": 20267, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779453578007, "responseId": "resp_04489e61265d56c7016a104e8ac03081a19c47