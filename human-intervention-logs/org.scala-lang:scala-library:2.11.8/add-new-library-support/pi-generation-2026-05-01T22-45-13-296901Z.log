      def packageOf(x: AnyRef) = x.getClass.getPackage match {
        case null   => ""
        case p      => p.getName
      }
      def isScalaClass(x: AnyRef)         = packageOf(x) startsWith "scala."
      def isScalaCompilerClass(x: AnyRef) = packageOf(x) startsWith "scala.tools.nsc."
  
