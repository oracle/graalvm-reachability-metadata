  package org_scala_lang.scala_library
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.lang.Thread.UncaughtExceptionHandler
  import java.util.concurrent.CountDownLatch
  import java.util.concurrent.TimeUnit
  import java.util.concurrent.atomic.AtomicReference
  import scala.concurrent.forkjoin.ForkJoinPool
  import scala.concurrent.forkjoin.ForkJoinWorkerThread
  
  class ForkJoinPoolTest {
    @Test
    def configuresCommonPoolFromSystemProperties(): Unit = {
      assertThat(System.getProperty("java.util.concurrent.ForkJoinPool.common.threadFactory"))
        .isEqualTo(classOf[ForkJoinPoolConfiguredWorkerThreadFactory].getName)
      assertThat(System.getProperty("java.util.concurrent.ForkJoinPool.common.exceptionHandler"))
        .isEqualTo(classOf[ForkJoinPoolConfiguredExceptionHandler].getName)
  
      val pool: ForkJoinPool = ForkJoinPool.commonPool()
      val workerThreadClassName: AtomicReference[String] = new AtomicReference[String]()
      val completed: CountDownLatch = new CountDownLatch(1)
  
      try {
        pool.execute(new ForkJoinPoolThreadNameRunnable(workerThreadClassName, completed))
  
        assertThat(completed.await(10L, TimeUnit.SECONDS)).isTrue()
        assertThat(workerThreadClassName.get()).isEqualTo(classOf[ForkJoinPoolConfiguredWorkerThread].getName)
      } finally {
        pool.awaitQuiescence(10L, TimeUnit.SECONDS)
      }
    }
  }
  
  class ForkJoinPoolConfiguredWorkerThreadFactory extends ForkJoinPool.ForkJoinWorkerThreadFactory {
    override def newThread(pool: ForkJoinPool): ForkJoinWorkerThread = {
      new ForkJoinPoolConfiguredWorkerThread(pool)
    }
  }
  
  class ForkJoinPoolConfiguredWorkerThread(pool: ForkJoinPool) extends ForkJoinWorkerThread(pool)
  
  class ForkJoinPoolConfiguredExceptionHandler extends UncaughtExceptionHandler {
    override def uncaughtException(thread: Thread, exception: Throwable): Unit = {
      // The test only needs the common pool to instantiate this handler via its public configuration property.
    }
  }
  
  class ForkJoinPoolThreadNameRunnable(
      workerThreadClassName: AtomicReference[String],
      completed: CountDownLatch) extends Runnable {
    override def run(): Unit = {
      workerThreadClassName.set(Thread.currentThread().getClass.getName)
      completed.countDown()
    }
  }
