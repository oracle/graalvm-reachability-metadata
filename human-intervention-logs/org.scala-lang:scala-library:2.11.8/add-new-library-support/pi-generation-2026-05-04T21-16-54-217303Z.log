  String commonPoolExceptionHandlerClass = "org_scala_lang.scala_library.ForkJoinPoolConfiguredExceptionHandler"
  
  configurations {
      scalaLibraryUnderTest
  }
  
  dependencies {
      scalaLibraryUnderTest "org.scala-lang:scala-library:$libraryVersion"
