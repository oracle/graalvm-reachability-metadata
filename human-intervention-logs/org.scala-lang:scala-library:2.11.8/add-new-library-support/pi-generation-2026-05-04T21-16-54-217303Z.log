      testImplementation 'org.assertj:assertj-core:3.22.0'
      testCompileOnly 'org.scala-lang:scala-library:2.13.16'
      testCompileOnly 'org.scala-lang:scala-compiler:2.13.16'
  }
  
  java {
      toolchain {
          languageVersion = JavaLanguageVersion.of(21)
