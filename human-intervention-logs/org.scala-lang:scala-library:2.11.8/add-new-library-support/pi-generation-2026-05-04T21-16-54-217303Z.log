[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ForkJoinPoolTest.scala","edits":[{"oldText":"import java.util.concurrent.Callable\nimport java.util.concurrent.TimeUnit\n","newText":"import java.util.concurrent.CountDownLatch\nimport java.util.concurrent.TimeUnit\nimport java.util.concurrent.atomic.AtomicReference\n"},{"oldText":"import scala.concurrent.forkjoin.ForkJoinTask\n","newText":""},{"oldText":"    val pool: ForkJoinPool = ForkJoinPool.commonPool()\n    val task: ForkJoinTask[String] = pool.submit(new ForkJoinPoolThreadNameCallable())\n\n    try {\n      assertThat(task.get(10L, TimeUnit.SECONDS))\n        .isEqualTo(classOf[ForkJoinPoolConfiguredWorkerThread].getName)\n    } finally {\n      pool.awaitQuiescence(10L, TimeUnit.SECONDS)\n    }\n","newText":"    val pool: ForkJoinPool = ForkJoinPool.commonPool()\n    val workerThreadClassName: AtomicReference[String] = new AtomicReference[String]()\n    val completed: CountDownLatch = new CountDownLatch(1)\n\n    try {\n      pool.execute(new ForkJoinPoolThreadNameRunnable(workerThreadClassName, completed))\n\n      assertThat(completed.await(10L, TimeUnit.SECONDS)).isTrue()\n      assertThat(workerThreadClassName.get()).isEqualTo(classOf[ForkJoinPoolConfiguredWorkerThread].getName)\n    } finally {\n      pool.awaitQuiescence(10L, TimeUnit.SECONDS)\n    }\n"},{"oldText":"class ForkJoinPoolThreadNameCallable extends Callable[String] {\n  override def call(): String = {\n    Thread.currentThread().getClass.getName\n  }\n}\n","newText":"class ForkJoinPoolThreadNameRunnable(\n    workerThreadClassName: AtomicReference[String],\n    completed: CountDownLatch) extends Runnable {\n  override def run(): Unit = {\n    workerThreadClassName.set(Thread.currentThread().getClass.getName)\n    completed.countDown()\n  }\n}\n"}]}
