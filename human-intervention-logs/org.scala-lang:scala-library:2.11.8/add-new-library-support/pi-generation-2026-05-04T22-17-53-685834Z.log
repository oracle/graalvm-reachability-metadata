  package org_scala_lang.scala_library
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  import scala.collection.immutable.{List => ImmutableList}
  
  class ListInnerSerializationProxyTest {
    @Test
    def serializationRoundTripUsesListSerializationProxy(): Unit = {
      val original: ImmutableList[String] = ImmutableList("alpha", "beta", "gamma")
  
      val restored: ImmutableList[String] = deserializeList(serialize(original))
  
      assertThat(restored.length).isEqualTo(3)
      assertThat(restored(0)).isEqualTo("alpha")
      assertThat(restored(1)).isEqualTo("beta")
      assertThat(restored(2)).isEqualTo("gamma")
    }
  
    private def serialize(value: AnyRef): Array[Byte] = {
      val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()
      val output: ObjectOutputStream = new ObjectOutputStream(bytes)
      try {
        output.writeObject(value)
      } finally {
        output.close()
      }
      bytes.toByteArray
    }
  
    private def deserializeList(bytes: Array[Byte]): ImmutableList[String] = {
      val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))
      try {
        input.readObject().asInstanceOf[ImmutableList[String]]
      } finally {
        input.close()
      }
    }
  }
