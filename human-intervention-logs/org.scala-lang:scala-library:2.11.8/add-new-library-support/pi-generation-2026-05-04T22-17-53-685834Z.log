related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport scala.collection.immutable.{HashMap => ImmutableHashMap}\n\nclass HashMapInnerSerializationProxyInnerAnonfunInnerWriteObjectAnonymous2Test {\n  @Test\n  def serializationWritesEachKeyAndValueThroughHashMapSerializationProxy(): Unit = {\n    val original: ImmutableHashMap[String, String] = ImmutableHashMap(\n      \"first-key\" -> \"first-value\",\n      \"second-key\" -> \"second-value\")\n\n    val restored: ImmutableHashMap[String, String] = deserializeHashMap(serialize(original))\n\n    assertThat(restored.size).isEqualTo(2)\n    assertThat(restored(\"first-key\")).isEqualTo(\"first-value\")\n    assertThat(restored(\"second-key\")).isEqualTo(\"second-value\")\n  }\n\n  private def serialize(value: AnyRef): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(value)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserializeHashMap(bytes: Array[Byte]): ImmutableHashMap[String, String] = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[ImmutableHashMap[String, String]]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 321, "output": 1009, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 24882, "cost": {"input": 0, "output": 0, "cacheRead": 0,