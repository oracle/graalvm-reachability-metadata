upiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNotSame\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\n\nimport scala.collection.concurrent.TrieMap\n\nfinal class ScalaCollectionConcurrentTrieMapTest {\n  @Test\n  def serializesEntriesAndRestoresConcurrentMap(): Unit = {\n    val original: TrieMap[String, Integer] = new TrieMap[String, Integer]()\n    original.put(\"alpha\", Integer.valueOf(1))\n    original.put(\"beta\", Integer.valueOf(2))\n\n    val restored: TrieMap[String, Integer] = roundTrip(original)\n\n    assertNotSame(original, restored)\n    assertEquals(2, restored.size)\n    assertTrue(restored.get(\"alpha\").contains(Integer.valueOf(1)))\n    assertTrue(restored.get(\"beta\").contains(Integer.valueOf(2)))\n\n    restored.put(\"gamma\", Integer.valueOf(3))\n    assertTrue(restored.get(\"gamma\").contains(Integer.valueOf(3)))\n  }\n\n  private def roundTrip(map: TrieMap[String, Integer]): TrieMap[String, Integer] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val objectOut: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      objectOut.writeObject(map)\n    } finally {\n      objectOut.close()\n    }\n\n    val objectIn: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray))\n    try {\n      objectIn.readObject().asInstanceOf[TrieMap[String, Integer]]\n    } finally {\n      objectIn.close()\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1780835146078}, {"role": "toolResult", "toolCallId": "call_X0Jk7CjGERveg7NXBkiH9rYh|fc_06f9ca6c9bd391cf016a256349cd98819488156ae23639ecbd", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n    id \"scal