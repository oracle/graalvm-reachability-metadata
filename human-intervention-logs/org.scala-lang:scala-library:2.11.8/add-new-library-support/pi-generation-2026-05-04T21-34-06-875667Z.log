  import java.util.Base64
  import scala.collection.mutable.ListBuffer
  
  class ListBufferTest {
    @Test
    def serializesAndDeserializesMultipleElements(): Unit = {
      val restored: ListBuffer[String] = deserializeListBuffer(serializedScala211ListBuffer)
      val bytes: Array[Byte] = serialize(restored)
  
      assertThat(bytes).isNotEmpty
      assertThat(restored.length).isEqualTo(3)
      assertThat(restored(0)).isEqualTo("alpha")
      assertThat(restored(1)).isEqualTo("beta")
      assertThat(restored(2)).isEqualTo("gamma")
    }
  
