    private def deserializeListBuffer(bytes: Array[Byte]): ListBuffer[String] = {
      val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))
      try {
        input.readObject().asInstanceOf[ListBuffer[String]]
      } finally {
        input.close()
      }
    }
  }
