rc/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ListInnerSerializationProxyTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport scala.collection.immutable.{List => ImmutableList}\n\nclass ListInnerSerializationProxyTest {\n  @Test\n  def serializationRoundTripUsesListSerializationProxy(): Unit = {\n    val original: ImmutableList[String] = ImmutableList(\"alpha\", \"beta\", \"gamma\")\n\n    val restored: ImmutableList[String] = deserializeList(serialize(original))\n\n    assertThat(restored.length).isEqualTo(3)\n    assertThat(restored(0)).isEqualTo(\"alpha\")\n    assertThat(restored(1)).isEqualTo(\"beta\")\n    assertThat(restored(2)).isEqualTo(\"gamma\")\n  }\n\n  private def serialize(value: AnyRef): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(value)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserializeList(bytes: Array[Byte]): ImmutableList[String] = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[ImmutableList[String]]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 679, "output": 568, "cacheRead": 45568, "cacheWrite": 0, "totalTokens": 46815, "cost": {"input": 0, "output": 0, "cacheRead": 0, "c