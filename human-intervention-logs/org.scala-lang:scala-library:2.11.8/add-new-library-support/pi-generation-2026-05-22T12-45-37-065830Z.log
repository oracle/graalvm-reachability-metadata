e.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.collection.mutable.LinkedHashMap\n\nclass ScalaCollectionMutableLinkedHashMapInnerAnonfunInnerWriteObjectAnonymous1Test {\n  @Test\n  def serializesEachMutableLinkedHashMapKeyAndValueThroughJavaObjectStreams(): Unit = {\n    val original: LinkedHashMap[String, Integer] = LinkedHashMap.empty[String, Integer]\n    original += (\"first\" -> Integer.valueOf(1))\n    original += (\"second\" -> Integer.valueOf(2))\n    original += (\"third\" -> Integer.valueOf(3))\n\n    val serialized: Array[Byte] = serialize(original)\n\n    assertThat(serialized.length).isGreaterThan(0)\n  }\n\n  private def serialize(value: AnyRef): Array[Byte] = {\n    val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(buffer)\n    try {\n      output.writeObject(value)\n      output.flush()\n    } finally {\n      output.close()\n    }\n    buffer.toByteArray\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 753, "output": 1082, "cacheRead": 10752, "cacheWrite": 0, "totalTokens": 12587, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779453915501, "responseId": "resp_06b71090a1a2460f016a104fdbd89c8190ae85fca71b53934f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_kGbBMyHttOs3QIdl8KPW3oSN|fc_06b71090a1a2460f016a104fe814a481908b7beefdaf062bad", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1299 bytes to tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ScalaCollectionMutableLinkedHashMapInnerAnonfunInnerWriteObjectAnonymous1Test.scala"}], "isError": false, "timestamp": 1779453929704}]}
