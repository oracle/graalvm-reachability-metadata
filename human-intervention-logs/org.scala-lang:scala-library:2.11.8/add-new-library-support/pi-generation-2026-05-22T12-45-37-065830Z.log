[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/ScalaCollectionMutableLinkedHashMapInnerAnonfunInnerWriteObjectAnonymous1Test.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectOutputStream\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.collection.mutable.LinkedHashMap\n\nclass ScalaCollectionMutableLinkedHashMapInnerAnonfunInnerWriteObjectAnonymous1Test {\n  @Test\n  def serializesEachMutableLinkedHashMapKeyAndValueThroughJavaObjectStreams(): Unit = {\n    val original: LinkedHashMap[String, Integer] = LinkedHashMap.empty[String, Integer]\n    original += (\"first\" -> Integer.valueOf(1))\n    original += (\"second\" -> Integer.valueOf(2))\n    original += (\"third\" -> Integer.valueOf(3))\n\n    val serialized: Array[Byte] = serialize(original)\n\n    assertThat(serialized.length).isGreaterThan(0)\n  }\n\n  private def serialize(value: AnyRef): Array[Byte] = {\n    val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(buffer)\n    try {\n      output.writeObject(value)\n      output.flush()\n    } finally {\n      output.close()\n    }\n    buffer.toByteArray\n  }\n}\n"}
