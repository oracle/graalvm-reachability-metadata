[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/java/org_scala_lang/scala_library/ListBuffers.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport scala.collection.Iterator;\nimport scala.collection.mutable.ListBuffer;\n\npublic final class ListBuffers {\n    private ListBuffers() {\n    }\n\n    public static ListBuffer<String> stringListBuffer(String... values) {\n        ListBuffer<String> buffer = new ListBuffer<>();\n        for (String value : values) {\n            buffer.$plus$eq(value);\n        }\n        return buffer;\n    }\n\n    public static void append(ListBuffer<String> buffer, String value) {\n        buffer.$plus$eq(value);\n    }\n\n    public static List<String> toJavaList(ListBuffer<String> buffer) {\n        List<String> values = new ArrayList<>();\n        Iterator<String> iterator = buffer.iterator();\n        while (iterator.hasNext()) {\n            values.add(iterator.next());\n        }\n        return values;\n    }\n}\n"}
