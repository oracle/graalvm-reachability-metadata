import java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport scala.collection.mutable.ListBuffer\n\nclass ScalaCollectionMutableListBufferTest {\n  @Test\n  def serializesAndDeserializesListBufferElementsThroughJavaObjectStreams(): Unit = {\n    val original: ListBuffer[String] = ListBuffer.empty[String]\n    original += \"alpha\"\n    original += \"beta\"\n    original += \"gamma\"\n\n    val serialized: Array[Byte] = serialize(original)\n    val restored: ListBuffer[String] = deserialize[ListBuffer[String]](serialized)\n\n    assertThat(restored).isNotSameAs(original)\n    assertThat(restored.toList).containsExactly(\"alpha\", \"beta\", \"gamma\")\n\n    restored += \"delta\"\n    assertThat(restored.toList).containsExactly(\"alpha\", \"beta\", \"gamma\", \"delta\")\n  }\n\n  private def serialize(value: AnyRef): Array[Byte] = {\n    val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(buffer)\n    try {\n      output.writeObject(value)\n      output.flush()\n      buffer.toByteArray\n    } finally {\n      output.close()\n    }\n  }\n\n  private def deserialize[A](bytes: Array[Byte]): A = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[A]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2272, "output": 817, "cacheRead": 11264, "cacheWrite": 0, "totalTokens": 14353, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779451591842, "responseId": "resp_02ab03fe9132a203016a1046c8298c819f88b756b4469f945e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_daJ00DOmzl3brEv98QOBznKs|fc_02ab03fe9132a203016a1046cd9fc4819fbf3eaf2529469445