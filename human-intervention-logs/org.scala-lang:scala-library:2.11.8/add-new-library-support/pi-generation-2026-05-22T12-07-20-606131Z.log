  package org_scala_lang.scala_library
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import scala.collection.mutable.ListBuffer
  
  class ScalaCollectionMutableListBufferTest {
    @Test
    def serializesAndDeserializesListBufferElementsThroughJavaObjectStreams(): Unit = {
      val original: ListBuffer[String] = ListBuffer.empty[String]
      original += "alpha"
      original += "beta"
      original += "gamma"
  
      val serialized: Array[Byte] = serialize(original)
      val restored: ListBuffer[String] = deserialize[ListBuffer[String]](serialized)
  
      assertThat(restored).isNotSameAs(original)
      assertThat(restored.toList).isEqualTo(List("alpha", "beta", "gamma"))
  
      restored += "delta"
      assertThat(restored.toList).isEqualTo(List("alpha", "beta", "gamma", "delta"))
    }
  
    private def serialize(value: AnyRef): Array[Byte] = {
      val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()
      val output: ObjectOutputStream = new ObjectOutputStream(buffer)
      try {
        output.writeObject(value)
        output.flush()
        buffer.toByteArray
      } finally {
        output.close()
      }
    }
  
    private def deserialize[A](bytes: Array[Byte]): A = {
      val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))
      try {
        input.readObject().asInstanceOf[A]
      } finally {
        input.close()
      }
    }
  }
