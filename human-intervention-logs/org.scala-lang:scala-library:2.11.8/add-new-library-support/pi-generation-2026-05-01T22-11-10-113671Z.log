      */
    final val BOLD       = "\u001b[1m"
    /** ANSI underlines
      * @group style-control
      */
    final val UNDERLINED = "\u001b[4m"
    /** ANSI blink
      * @group style-control
      */
    final val BLINK      = "\u001b[5m"
    /** ANSI reversed
