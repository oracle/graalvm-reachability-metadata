    final val CYAN_B     = "\u001b[46m"
    /** Background color for ANSI white
      * @group color-white
      */
    final val WHITE_B    = "\u001b[47m"
  
    /** Reset ANSI styles
      * @group style-control
      */
    final val RESET      = "\u001b[0m"
    /** ANSI bold
