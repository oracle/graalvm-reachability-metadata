  package org_scala_lang.scala_library
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import scala.collection.concurrent.TrieMap
  
  class ScalaCollectionConcurrentTrieMapTest {
    @Test
    def serializesAndDeserializesEntriesThroughJavaObjectStreams(): Unit = {
      val original: TrieMap[String, Integer] = new TrieMap[String, Integer]()
      original.update("alpha", Integer.valueOf(1))
      original.update("beta", Integer.valueOf(2))
      original.update("gamma", Integer.valueOf(3))
  
      val serialized: Array[Byte] = serialize(original)
      val restored: TrieMap[String, Integer] = deserialize[TrieMap[String, Integer]](serialized)
  
      assertThat(restored).isNotSameAs(original)
      assertThat(restored.size).isEqualTo(original.size)
      assertThat(restored.apply("alpha")).isEqualTo(Integer.valueOf(1))
      assertThat(restored.apply("beta")).isEqualTo(Integer.valueOf(2))
      assertThat(restored.apply("gamma")).isEqualTo(Integer.valueOf(3))
  
      restored.update("delta", Integer.valueOf(4))
      assertThat(restored.apply("delta")).isEqualTo(Integer.valueOf(4))
    }
  
    private def serialize(value: AnyRef): Array[Byte] = {
      val buffer: ByteArrayOutputStream = new ByteArrayOutputStream()
      val output: ObjectOutputStream = new ObjectOutputStream(buffer)
      try {
        output.writeObject(value)
        output.flush()
        buffer.toByteArray
      } finally {
        output.close()
      }
    }
  
    private def deserialize[A](bytes: Array[Byte]): A = {
      val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))
      try {
        input.readObject().asInstanceOf[A]
      } finally {
        input.close()
      }
    }
  }
