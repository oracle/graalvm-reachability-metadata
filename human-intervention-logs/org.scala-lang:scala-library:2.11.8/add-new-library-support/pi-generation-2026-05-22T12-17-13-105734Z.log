  package org_scala_lang.scala_library;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import scala.collection.Iterator;
  import scala.collection.mutable.ListBuffer;
  
  public final class ListBuffers {
      private ListBuffers() {
      }
  
      public static ListBuffer<String> stringListBuffer(String... values) {
          ListBuffer<String> buffer = new ListBuffer<>();
          for (String value : values) {
              buffer.$plus$eq(value);
          }
          return buffer;
      }
  
      public static void append(ListBuffer<String> buffer, String value) {
          buffer.$plus$eq(value);
      }
  
      public static List<String> toJavaList(ListBuffer<String> buffer) {
          List<String> values = new ArrayList<>();
          Iterator<String> iterator = buffer.iterator();
          while (iterator.hasNext()) {
              values.add(iterator.next());
          }
          return values;
      }
  }
