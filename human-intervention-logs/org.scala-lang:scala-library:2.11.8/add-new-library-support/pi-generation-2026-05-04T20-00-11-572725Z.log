0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport scala.collection.concurrent.TrieMap\n\nclass TrieMapTest {\n  @Test\n  def serializesAndDeserializesEntries(): Unit = {\n    val source: TrieMap[String, String] = TrieMap.empty[String, String]\n    source.put(\"alpha\", \"one\")\n    source.put(\"beta\", \"two\")\n\n    val bytes: Array[Byte] = serialize(source)\n    val restored: TrieMap[String, String] = deserializeTrieMap(bytes)\n\n    assertThat(restored.size).isEqualTo(2)\n    assertThat(restored.get(\"alpha\")).contains(\"one\")\n    assertThat(restored.get(\"beta\")).contains(\"two\")\n    assertThat(restored.putIfAbsent(\"gamma\", \"three\")).isEmpty\n    assertThat(restored.get(\"gamma\")).contains(\"three\")\n  }\n\n  private def serialize(map: TrieMap[String, String]): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(map)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n\n  private def deserializeTrieMap(bytes: Array[Byte]): TrieMap[String, String] = {\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[TrieMap[String, String]]\n    } finally {\n      input.close()\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 359, "output": 1033, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 20336, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 177792469