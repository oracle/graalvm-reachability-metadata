  package org_scala_lang.scala_library
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import scala.reflect.ClassTag
  
  class ClassManifestDeprecatedApisInnerclassTest {
    @Test
    def createsArraysWithDeprecatedClassManifestApis(): Unit = {
      val tag: ClassTag[String] = ClassTag(classOf[String])
  
      val arrayTag: ClassTag[Array[String]] = tag.arrayManifest
      val oneDimensional: Array[String] = tag.newArray(2)
      val twoDimensional: Array[Array[String]] = tag.newArray2(3)
      val threeDimensional: Array[Array[Array[String]]] = tag.newArray3(4)
      val fourDimensional: Array[Array[Array[Array[String]]]] = tag.newArray4(5)
      val fiveDimensional: Array[Array[Array[Array[Array[String]]]]] = tag.newArray5(6)
  
      assertThat(arrayTag.runtimeClass).isEqualTo(classOf[Array[String]])
      assertThat(oneDimensional.getClass).isEqualTo(classOf[Array[String]])
      assertThat(oneDimensional.length).isEqualTo(2)
      assertThat(twoDimensional.getClass).isEqualTo(classOf[Array[Array[String]]])
      assertThat(twoDimensional.length).isEqualTo(3)
      assertThat(threeDimensional.getClass).isEqualTo(classOf[Array[Array[Array[String]]]])
      assertThat(threeDimensional.length).isEqualTo(4)
      assertThat(fourDimensional.getClass).isEqualTo(classOf[Array[Array[Array[Array[String]]]]])
      assertThat(fourDimensional.length).isEqualTo(5)
      assertThat(fiveDimensional.getClass).isEqualTo(classOf[Array[Array[Array[Array[Array[String]]]]]])
      assertThat(fiveDimensional.length).isEqualTo(6)
    }
  }
