    def >:>(that: ClassManifest[_]): Boolean =
      that <:< this
  
    override def canEqual(other: Any) = other match {
      case _: ClassManifest[_] => true
      case _                   => false
    }
  
    protected def arrayClass[T](tp: jClass[_]): jClass[Array[T]] =
