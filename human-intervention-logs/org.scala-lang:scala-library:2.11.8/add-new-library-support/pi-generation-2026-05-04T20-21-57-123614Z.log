  package org_scala_lang.scala_library
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  import scala.collection.concurrent.TrieMap
  
  class TrieMapTest {
    @Test
    def serializesAndDeserializesEntries(): Unit = {
      val source: TrieMap[String, String] = new TrieMap[String, String]()
      source.put("alpha", "one")
      source.put("beta", "two")
  
      val bytes: Array[Byte] = serialize(source)
      val restored: TrieMap[String, String] = deserializeTrieMap(bytes)
  
      assertThat(restored.size).isEqualTo(2)
      assertThat(restored.get("alpha")).isEqualTo(Some("one"))
      assertThat(restored.get("beta")).isEqualTo(Some("two"))
      assertThat(restored.putIfAbsent("gamma", "three")).isEqualTo(None)
      assertThat(restored.get("gamma")).isEqualTo(Some("three"))
    }
  
    private def serialize(map: TrieMap[String, String]): Array[Byte] = {
      val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()
      val output: ObjectOutputStream = new ObjectOutputStream(bytes)
      try {
        output.writeObject(map)
      } finally {
        output.close()
      }
      bytes.toByteArray
    }
  
    private def deserializeTrieMap(bytes: Array[Byte]): TrieMap[String, String] = {
      val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))
      try {
        input.readObject().asInstanceOf[TrieMap[String, String]]
      } finally {
        input.close()
      }
    }
  }
