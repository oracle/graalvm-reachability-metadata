  import scala.math.BigDecimal.RoundingMode
  
  class ScalaEnumerationTest {
    @Test
    def discoversValueNamesFromPublicEnumerationFields(): Unit = {
      assertThat(RoundingMode.UP.toString).isEqualTo("UP")
      assertThat(RoundingMode.DOWN.toString).isEqualTo("DOWN")
      assertThat(RoundingMode.CEILING.toString).isEqualTo("CEILING")
      assertThat(RoundingMode.FLOOR.toString).isEqualTo("FLOOR")
      assertThat(RoundingMode.HALF_UP.toString).isEqualTo("HALF_UP")
      assertThat(RoundingMode.HALF_DOWN.toString).isEqualTo("HALF_DOWN")
