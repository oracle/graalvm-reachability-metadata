  package org_scala_lang.scala_library
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import java.io.ByteArrayInputStream
  import java.io.ByteArrayOutputStream
  import java.io.ObjectInputStream
  import java.io.ObjectOutputStream
  import scala.math.BigDecimal.RoundingMode
  
  class EnumerationTest {
    @Test
    def derivesValueNamesFromPublicValAccessors(): Unit = {
      assertThat(RoundingMode.UP.toString).isEqualTo("UP")
      assertThat(RoundingMode.HALF_EVEN.toString).isEqualTo("HALF_EVEN")
      assertThat(RoundingMode.withName("UP")).isSameAs(RoundingMode.UP)
      assertThat(RoundingMode.withName("HALF_EVEN")).isSameAs(RoundingMode.HALF_EVEN)
    }
  
    @Test
    def resolvesDeserializedValueToSingletonEnumerationInstance(): Unit = {
      val restored: RoundingMode.Value = roundTrip(RoundingMode.HALF_UP)
  
      assertThat(restored).isSameAs(RoundingMode.HALF_UP)
      assertThat(restored.toString).isEqualTo("HALF_UP")
    }
  
    private def roundTrip[T](value: T): T = {
      val bytes: Array[Byte] = serialize(value)
      val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))
      try {
        input.readObject().asInstanceOf[T]
      } finally {
        input.close()
      }
    }
  
    private def serialize(value: Any): Array[Byte] = {
      val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()
      val output: ObjectOutputStream = new ObjectOutputStream(bytes)
      try {
        output.writeObject(value)
      } finally {
        output.close()
      }
      bytes.toByteArray
    }
  }
