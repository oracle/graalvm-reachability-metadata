[tool-call] delta {"path":"tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/EnumerationTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport scala.Enumeration\n\nclass EnumerationTest {\n  @Test\n  def derivesValueNamesFromPublicValAccessors(): Unit = {\n    assertThat(ReflectivelyNamedEnumeration.First.toString).isEqualTo(\"First\")\n    assertThat(ReflectivelyNamedEnumeration.Second.toString).isEqualTo(\"Second\")\n    assertThat(ReflectivelyNamedEnumeration.withName(\"First\")).isSameAs(ReflectivelyNamedEnumeration.First)\n    assertThat(ReflectivelyNamedEnumeration.withName(\"Second\")).isSameAs(ReflectivelyNamedEnumeration.Second)\n  }\n\n  @Test\n  def resolvesDeserializedValueToSingletonEnumerationInstance(): Unit = {\n    val restored: ReflectivelyNamedEnumeration.Value = roundTrip(ReflectivelyNamedEnumeration.First)\n\n    assertThat(restored).isSameAs(ReflectivelyNamedEnumeration.First)\n    assertThat(restored.toString).isEqualTo(\"First\")\n  }\n\n  private def roundTrip[T](value: T): T = {\n    val bytes: Array[Byte] = serialize(value)\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[T]\n    } finally {\n      input.close()\n    }\n  }\n\n  private def serialize(value: Any): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(value)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n}\n\nobject ReflectivelyNamedEnumeration extends Enumeration {\n  val First: Value = new Val(1)\n  val Second: Value = new Val(2)\n}\n"}
[tool-call] end id=call_c6lGPZQeGInHQEj0dOnyOvsu|fc_04b9e75555eccbbd0169f908fd53c88193be086da481c39951 name=write args={"path": "tests/src/org.scala-lang/scala-library/2.11.8/src/test/scala/org_scala_lang/scala_library/EnumerationTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_library\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport java.io.ByteArrayInputStream\nimport java.io.ByteArrayOutputStream\nimport java.io.ObjectInputStream\nimport java.io.ObjectOutputStream\nimport scala.Enumeration\n\nclass EnumerationTest {\n  @Test\n  def derivesValueNamesFromPublicValAccessors(): Unit = {\n    assertThat(ReflectivelyNamedEnumeration.First.toString).isEqualTo(\"First\")\n    assertThat(ReflectivelyNamedEnumeration.Second.toString).isEqualTo(\"Second\")\n    assertThat(ReflectivelyNamedEnumeration.withName(\"First\")).isSameAs(ReflectivelyNamedEnumeration.First)\n    assertThat(ReflectivelyNamedEnumeration.withName(\"Second\")).isSameAs(ReflectivelyNamedEnumeration.Second)\n  }\n\n  @Test\n  def resolvesDeserializedValueToSingletonEnumerationInstance(): Unit = {\n    val restored: ReflectivelyNamedEnumeration.Value = roundTrip(ReflectivelyNamedEnumeration.First)\n\n    assertThat(restored).isSameAs(ReflectivelyNamedEnumeration.First)\n    assertThat(restored.toString).isEqualTo(\"First\")\n  }\n\n  private def roundTrip[T](value: T): T = {\n    val bytes: Array[Byte] = serialize(value)\n    val input: ObjectInputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))\n    try {\n      input.readObject().asInstanceOf[T]\n    } finally {\n      input.close()\n    }\n  }\n\n  private def serialize(value: Any): Array[Byte] = {\n    val bytes: ByteArrayOutputStream = new ByteArrayOutputStream()\n    val output: ObjectOutputStream = new ObjectOutputStream(bytes)\n    try {\n      output.writeObject(value)\n    } finally {\n      output.close()\n    }\n    bytes.toByteArray\n  }\n}\n\nobject ReflectivelyNamedEnumeration extends Enumeration {\n  val First: Value = new Val(1)\n  val Second: Value = new Val(2)\n}\n"}
