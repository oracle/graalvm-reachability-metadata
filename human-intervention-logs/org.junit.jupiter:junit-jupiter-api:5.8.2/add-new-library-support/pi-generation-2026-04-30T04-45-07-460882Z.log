[tool-call] delta {"path":"tests/src/org.junit.jupiter/junit-jupiter-api/5.8.2/src/test/java/org_junit_jupiter/junit_jupiter_api/condition/JRETest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_junit_jupiter.junit_jupiter_api.condition;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.condition.JRE;\n\npublic class JRETest {\n    @Test\n    void currentVersionMatchesRuntimeMajorVersion() {\n        JRE currentVersion = JRE.currentVersion();\n\n        assertThat(currentVersion).isEqualTo(expectedJreFor(Runtime.version().major()));\n        assertThat(currentVersion.isCurrentVersion()).isTrue();\n        assertThat(numberOfCurrentVersions()).isEqualTo(1);\n    }\n\n    private static JRE expectedJreFor(int majorVersion) {\n        switch (majorVersion) {\n            case 8:\n                return JRE.JAVA_8;\n            case 9:\n                return JRE.JAVA_9;\n            case 10:\n                return JRE.JAVA_10;\n            case 11:\n                return JRE.JAVA_11;\n            case 12:\n                return JRE.JAVA_12;\n            case 13:\n                return JRE.JAVA_13;\n            case 14:\n                return JRE.JAVA_14;\n            case 15:\n                return JRE.JAVA_15;\n            case 16:\n                return JRE.JAVA_16;\n            case 17:\n                return JRE.JAVA_17;\n            case 18:\n                return JRE.JAVA_18;\n            default:\n                return JRE.OTHER;\n        }\n    }\n\n    private static int numberOfCurrentVersions() {\n        int currentVersions = 0;\n        for (JRE jre : JRE.values()) {\n            if (jre.isCurrentVersion()) {\n                currentVersions++;\n            }\n        }\n        return currentVersions;\n    }\n}\n"}
