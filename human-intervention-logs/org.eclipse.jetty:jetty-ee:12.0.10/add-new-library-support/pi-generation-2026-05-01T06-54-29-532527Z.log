[tool-call] delta {"path":"tests/src/org.eclipse.jetty/jetty-ee/12.0.10/src/test/java/org_eclipse_jetty/jetty_ee/Jetty_eeTest.java","edits":[{"oldText":"    @Test\n    void attributesAddersCreateStoredMatchersWithoutEnvironmentDefaults() {\n        Attributes attributes = new Attributes.Mapped();\n\n        WebAppClassLoading.addProtectedClasses(attributes, \"attributes.protected.\", \"-attributes.protected.internal.\");\n        WebAppClassLoading.addHiddenClasses(attributes, \"attributes.hidden.\", \"-attributes.hidden.public.\");\n\n        Object protectedAttribute = attributes.getAttribute(PROTECTED_ATTRIBUTE);\n        Object hiddenAttribute = attributes.getAttribute(HIDDEN_ATTRIBUTE);\n        assertThat(protectedAttribute).isInstanceOf(ClassMatcher.class);\n        assertThat(hiddenAttribute).isInstanceOf(ClassMatcher.class);\n\n        ClassMatcher protectedMatcher = (ClassMatcher) protectedAttribute;\n        ClassMatcher hiddenMatcher = (ClassMatcher) hiddenAttribute;\n        assertThat(protectedMatcher).isNotSameAs(hiddenMatcher);\n        assertThat(protectedMatcher.match(\"attributes.protected.Api\")).isTrue();\n        assertThat(protectedMatcher.match(\"attributes.protected.internal.Secret\")).isFalse();\n        assertThat(protectedMatcher.match(String.class.getName())).isFalse();\n        assertThat(hiddenMatcher.match(\"attributes.hidden.Secret\")).isTrue();\n        assertThat(hiddenMatcher.match(\"attributes.hidden.public.Endpoint\")).isFalse();\n        assertThat(hiddenMatcher.match(WebAppClassLoading.class.getName())).isFalse();\n    }\n","newText":"    @Test\n    void attributesAddProtectedClassesCreatesStoredMatcherWithoutEnvironmentDefaults() {\n        Attributes attributes = new Attributes.Mapped();\n\n        WebAppClassLoading.addProtectedClasses(attributes, \"attributes.protected.\", \"-attributes.protected.internal.\");\n\n        Object protectedAttribute = attributes.getAttribute(PROTECTED_ATTRIBUTE);\n        assertThat(protectedAttribute).isInstanceOf(ClassMatcher.class);\n\n        ClassMatcher protectedMatcher = (ClassMatcher) protectedAttribute;\n        assertThat(attributes.getAttribute(HIDDEN_ATTRIBUTE)).isNull();\n        assertThat(protectedMatcher.match(\"attributes.protected.Api\")).isTrue();\n        assertThat(protectedMatcher.match(\"attributes.protected.internal.Secret\")).isFalse();\n        assertThat(protectedMatcher.match(String.class.getName())).isFalse();\n    }\n"}]}
