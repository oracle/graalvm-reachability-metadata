[tool-call] delta {"path":"tests/src/org.apache.poi/poi-ooxml/4.1.2/src/test/java/org_apache_poi/poi_ooxml/SignatureConfigTest.java","edits":[{"oldText":"import java.security.Provider;\n\nimport javax.xml.crypto.dsig.XMLSignatureFactory;\nimport javax.xml.crypto.dsig.keyinfo.KeyInfoFactory;\n\nimport org.apache.poi.poifs.crypt.dsig.SignatureConfig;","newText":"import java.security.Provider;\n\nimport org.apache.poi.poifs.crypt.dsig.SignatureConfig;"},{"oldText":"            SignatureConfig signatureConfig = new SignatureConfig();\n            Provider provider = signatureConfig.getProvider();\n            XMLSignatureFactory signatureFactory = signatureConfig.getSignatureFactory();\n            KeyInfoFactory keyInfoFactory = signatureConfig.getKeyInfoFactory();\n\n            assertThat(provider.getClass().getName()).isEqualTo(SANTUARIO_XML_DSIG_PROVIDER);\n            assertThat(signatureFactory.getMechanismType()).isEqualTo(\"DOM\");\n            assertThat(signatureFactory.getProvider().getClass().getName()).isEqualTo(SANTUARIO_XML_DSIG_PROVIDER);\n            assertThat(keyInfoFactory.getMechanismType()).isEqualTo(\"DOM\");\n            assertThat(keyInfoFactory.getProvider().getClass().getName()).isEqualTo(SANTUARIO_XML_DSIG_PROVIDER);","newText":"            SignatureConfig signatureConfig = new SignatureConfig();\n            Provider provider = signatureConfig.getProvider();\n\n            assertThat(provider.getClass().getName()).isEqualTo(SANTUARIO_XML_DSIG_PROVIDER);\n            assertThat(provider.getServices()).isNotEmpty();"}]}
