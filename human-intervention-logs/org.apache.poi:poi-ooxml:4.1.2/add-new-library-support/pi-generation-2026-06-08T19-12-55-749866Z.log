  package org_apache_poi.poi_ooxml;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Provider;
  
  import javax.xml.crypto.dsig.XMLSignatureFactory;
  import javax.xml.crypto.dsig.keyinfo.KeyInfoFactory;
  
  import org.apache.poi.poifs.crypt.dsig.SignatureConfig;
  import org.junit.jupiter.api.Test;
  
  public class SignatureConfigTest {
      private static final String SANTUARIO_XML_DSIG_PROVIDER = "org.apache.jcp.xml.dsig.internal.dom.XMLDSigRI";
  
      @Test
      public void resolvesConfiguredJsr105Provider() {
          String previousProvider = System.getProperty("jsr105Provider");
          try {
              System.setProperty("jsr105Provider", SANTUARIO_XML_DSIG_PROVIDER);
  
              SignatureConfig signatureConfig = new SignatureConfig();
              Provider provider = signatureConfig.getProvider();
              XMLSignatureFactory signatureFactory = signatureConfig.getSignatureFactory();
              KeyInfoFactory keyInfoFactory = signatureConfig.getKeyInfoFactory();
  
              assertThat(provider.getClass().getName()).isEqualTo(SANTUARIO_XML_DSIG_PROVIDER);
              assertThat(signatureFactory.getMechanismType()).isEqualTo("DOM");
              assertThat(signatureFactory.getProvider().getClass().getName()).isEqualTo(SANTUARIO_XML_DSIG_PROVIDER);
              assertThat(keyInfoFactory.getMechanismType()).isEqualTo("DOM");
              assertThat(keyInfoFactory.getProvider().getClass().getName()).isEqualTo(SANTUARIO_XML_DSIG_PROVIDER);
          } finally {
              if (previousProvider == null) {
                  System.clearProperty("jsr105Provider");
              } else {
                  System.setProperty("jsr105Provider", previousProvider);
              }
          }
      }
  }
