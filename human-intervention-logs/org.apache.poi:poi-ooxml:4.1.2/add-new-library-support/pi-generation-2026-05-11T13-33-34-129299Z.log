          assertThat(connection.getProtocol()).isEqualTo(HTTP_1_1);
          assertThat(rejectedHttp2.checkedProtocols).containsExactly(HTTP_2);
          assertThat(rejectedHttp2.checkedTlsProtocols).containsExactly("TLSv1.3");
