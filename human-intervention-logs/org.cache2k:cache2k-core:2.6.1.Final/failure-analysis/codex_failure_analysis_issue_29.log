\\\\\\\\\\\\\\n                    .entryCapacity(4)\\\\\\\\\\\\\\\\n                    .build();\\\\\\\\\\\\\\\\n            try {\\\\\\\\\\\\\\\\n                cache.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"one\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 1);\\\\\\\\\\\\\\\\n                cache.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"two\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 2);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n                assertThat(cache.getCacheManager()).isSameAs(manager);\\\\\\\\\\\\\\\\n                assertThat(cache.peek(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"one\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).isEqualTo(1);\\\\\\\\\\\\\\\\n                assertThat(cache.containsKey(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"two\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).isTrue();\\\\\\\\\\\\\\\\n                assertThat(manager.getCache(cache.getName())).isSameAs(cache);\\\\\\\\\\\\\\\\n                assertThat(activeCacheNames(manager)).containsExactly(cache.getName());\\\\\\\\\\\\\\\\n            } finally {\\\\\\\\\\\\\\\\n                cache.close();\\\\\\\\\\\\\\\\n            }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            assertThat(activeCacheNames(manager)).isEmpty();\\\\\\\\\\\\\\\\n        } finally {\\\\\\\\\\\\\\\\n            manager.close();\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n        assertThat(manager.isClosed()).isTrue();\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Test\\\\\\\\\\\\\\\\n    void rejectsDuplicateCacheNamesThroughPublicBuilder() {\\\\\\\\\\\\\\\\n        String managerName = uniqueName(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"manager\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        String cacheName = uniqueName(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cache\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        CacheManager manager = CacheManager.getInstance(managerName);\\\\\\\\\\\\\\\\n        Cache<String, String> cache = Cache2kBuilder.of(String.class, String.class)\\\\\\\\\\\\\\\\n                .manager(manager)\\\\\\\\\\\\\\\\n                .name(cacheName)\\\\\\\\\\\\\\\\n                .entryCapacity(2)\\\\\\\\\\\\\\\\n                .build();\\\\\\\\\\\\\\\\n        try {\\\\\\\\\\\\\\\\n            assertThatThrownBy(() -> Cache2kBuilder.of(String.class, String.class)\\\\\\\\\\\\\\\\n                    .manager(manager)\\\\\\\\\\\\\\\\n                    .name(cacheName)\\\\\\\\\\\\\\\\n                    .entryCapacity(2)\\\\\\\\\\\\\\\\n                    .build())\\\\\\\\\\\\\\\\n                    .isInstanceOf(IllegalStateException.class)\\\\\\\\\\\\\\\\n                    .hasMessageContaining(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Cache already created\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        } finally {\\\\\\\\\\\\\\\\n            cache.close();\\\\\\\\\\\\\\\\n            manager.close();\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    private static List<String> activeCacheNames(CacheManager manager) {\\\\\\\\\\\\\\\\n        List<String> names = new ArrayList<>();\\\\\\\\\\\\\\\\n        for (Cache<?, ?> cache : manager.getActiveCaches()) {\\\\\\\\\\\\\\\\n            names.add(cache.getName());\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n        return names;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    private static String uniqueName(String label) {\\\\\\\\\\\\\\\\n        return CacheManagerImplTest.class.getSimpleName() + \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"-\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" + label + \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"-\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n                + Long.toUnsignedString(System.nanoTime(), 36);\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n}\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_13\\