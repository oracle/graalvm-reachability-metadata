{"type":"item.completed","item":{"id":"item_28","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/src/org.cache2k/cache2k-core/2.6.1.Final/src/test/java/org_cache2k/cache2k_core/CacheManagerImplTest.java | sed -n '1,220p'\"","aggregated_output":"     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage org_cache2k.cache2k_core;\n     8\t\n     9\timport org.cache2k.Cache;\n    10\timport org.cache2k.Cache2kBuilder;\n    11\timport org.cache2k.CacheManager;\n    12\timport org.junit.jupiter.api.Test;\n    13\t\n    14\timport java.util.ArrayList;\n    15\timport java.util.List;\n    16\t\n    17\timport static org.assertj.core.api.Assertions.assertThat;\n    18\timport static org.assertj.core.api.Assertions.assertThatThrownBy;\n    19\t\n    20\tpublic class CacheManagerImplTest {\n    21\t\n    22\t    @Test\n    23\t    void createsNamedManagerAndTracksActiveCaches() {\n    24\t        String managerName = uniqueName(\"manager\");\n    25\t        CacheManager manager = CacheManager.getInstance(managerName);\n    26\t        try {\n    27\t            assertThat(manager.getName()).isEqualTo(managerName);\n    28\t            assertThat(manager.isDefaultManager()).isFalse();\n    29\t            assertThat(manager.isClosed()).isFalse();\n    30\t            assertThat(manager.getProperties()).isNotNull();\n    31\t\n    32\t            Cache<String, Integer> cache = Cache2kBuilder.of(String.class, Integer.class)\n    33\t                    .manager(manager)\n    34\t                    .name(uniqueName(\"cache\"))\n    35\t                    .entryCapacity(4)\n    36\t                    .build();\n    37\t            try {\n    38\t                cache.put(\"one\", 1);\n    39\t                cache.put(\"two\", 2);\n    40\t\n    41\t                assertThat(cache.getCacheManager()).isSameAs(manager);\n    42\t                assertThat(cache.peek(\"one\")).isEqualTo(1);\n    43\t                assertThat(cache.containsKey(\"two\")).isTrue();\n    44\t                assertThat(manager.getCache(cache.getName())).isSameAs(cache);\n    45\t                assertThat(activeCacheNames(manager)).containsExactly(cache.getName());\n    46\t            } finally {\n    47\t                cache.close();\n    48\t            }\n    49\t\n    50\t            assertThat(activeCacheNames(manager)).isEmpty();\n    51\t        } finally {\n    52\t            manager.close();\n    53\t        }\n    54\t        assertThat(manager.isClosed()).isTrue();\n    55\t    }\n    56\t\n    57\t    @Test\n    58\t    void rejectsDuplicateCacheNamesThroughPublicBuilder() {\n    59\t        String managerName = uniqueName(\"manager\");\n    60\t        String cacheName = uniqueName(\"cache\");\n    61\t        CacheManager manager = CacheManager.getInstance(managerName);\n    62\t        Cache<String, String> cache = Cache2kBuilder.of(String.class, String.class)\n    63\t                .manager(manager)\n    64\t                .name(cacheName)\n    65\t                .entryCapacity(2)\n    66\t                .build();\n    67\t        try {\n    68\t            assertThatThrownBy(() -> Cache2kBuilder.of(String.class, String.class)\n    69\t                    .manager(manager)\n    70\t                    .name(cacheName)\n    71\t                    .entryCapacity(2)\n    72\t                    .build())\n    73\t                    .isInstanceOf(IllegalStateException.class)\n    74\t                    .hasMessageContaining(\"Cache already created\");\n    75\t        } finally {\n    76\t            cache.close();\n    77\t            manager.close();\n    78\t        }\n    79\t    }\n    80\t\n    81\t    private static List<String> activeCacheNames(CacheManager manager) {\n    82\t        List<String> names = new ArrayList<>();\n    83\t        for (Cache<?, ?> cache : manager.getActiveCaches()) {\n    84\t            names.add(cache.getName());\n    85\t        }\n    86\t        return names;\n    87\t    }\n    88\t\n    89\t    private static String uniqueName(String label) {\n    90\t        return CacheManagerImplTest.class.getSimpleName() + \"-\" + label + \"-\"\n    91\t                + Long.toUnsignedString(System.nanoTime(), 36);\n    92\t    }\n    93\t}\n","exit_code":0,"status":"completed"}}
