  package org_glassfish_jaxb.codemodel;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.codemodel.JAnnotationUse;
  import com.sun.codemodel.JAnnotationWriter;
  import com.sun.codemodel.JCodeModel;
  import com.sun.codemodel.JDefinedClass;
  import com.sun.codemodel.writer.SingleStreamCodeWriter;
  import java.io.ByteArrayOutputStream;
  import java.nio.charset.StandardCharsets;
  import org.junit.jupiter.api.Test;
  
  public class TypedAnnotationWriterTest {
      @Test
      void typedWriterCreatesProxyAndDelegatesBaseWriterMethods() throws Exception {
          JCodeModel codeModel = new JCodeModel();
          JDefinedClass generatedType = codeModel._class("example.ProxyBackedAnnotationTarget");
  
          SampleAnnotationWriter writer = generatedType.annotate2(SampleAnnotationWriter.class);
          JAnnotationUse annotationUse = writer.getAnnotationUse();
  
          assertThat(writer.getAnnotationType()).isEqualTo(SampleAnnotation.class);
          assertThat(annotationUse.getAnnotationClass().fullName()).isEqualTo(SampleAnnotation.class.getName());
          assertThat(generatedType.annotations()).containsExactly(annotationUse);
      }
  
      @Test
      void typedWriterAddsAnnotationMembersFromWriterInterfaceMethods() throws Exception {
          JCodeModel codeModel = new JCodeModel();
          JDefinedClass generatedType = codeModel._class("example.AnnotatedGeneratedType");
  
          SampleAnnotationWriter writer = generatedType.annotate2(SampleAnnotationWriter.class);
          writer.name("generated-value")
                  .count(3)
                  .enabled(true)
                  .type(String.class);
  
          JAnnotationUse annotationUse = writer.getAnnotationUse();
          assertThat(annotationUse.getAnnotationMembers()).containsOnlyKeys("name", "count", "enabled", "type");
  
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          codeModel.build(new SingleStreamCodeWriter(output));
          String generatedSource = output.toString(StandardCharsets.UTF_8);
  
          assertThat(generatedSource)
                  .contains("@TypedAnnotationWriterTest.SampleAnnotation")
                  .contains("name = \"generated-value\"")
                  .contains("count = 3")
                  .contains("enabled = true")
                  .contains("type = String.class");
      }
  
      public @interface SampleAnnotation {
          String name();
  
          int count();
  
          boolean enabled();
  
          Class<?> type();
      }
  
      public interface SampleAnnotationWriter extends JAnnotationWriter<SampleAnnotation> {
          SampleAnnotationWriter name(String value);
  
          SampleAnnotationWriter count(int value);
  
          SampleAnnotationWriter enabled(boolean value);
  
          SampleAnnotationWriter type(Class<?> value);
      }
  }
