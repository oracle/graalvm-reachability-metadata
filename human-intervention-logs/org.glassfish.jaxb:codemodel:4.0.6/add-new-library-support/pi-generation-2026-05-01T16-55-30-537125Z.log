                      if (!first) f.p(',');
                      f.p(mapEntry.getKey()).p('=').g(mapEntry.getValue());
                      first = false;
                  }
              }
              f.p(')');
          }
      }
  
      private boolean isOptimizable() {
          return memberValues.size()==1 && memberValues.containsKey("value");
      }
