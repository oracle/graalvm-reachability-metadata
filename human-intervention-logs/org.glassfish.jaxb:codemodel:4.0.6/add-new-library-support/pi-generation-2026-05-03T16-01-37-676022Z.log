  package org_glassfish_jaxb.codemodel;
  
  import com.sun.codemodel.JAnnotationUse;
  import com.sun.codemodel.JAnnotationWriter;
  import com.sun.codemodel.JCodeModel;
  import com.sun.codemodel.JDefinedClass;
  import com.sun.codemodel.JFormatter;
  import org.junit.jupiter.api.Test;
  
  import java.io.StringWriter;
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypedAnnotationWriterTest {
      @Test
      void typedAnnotationWriterCreatesProxyAndDispatchesAnnotationMembers() throws Exception {
          JCodeModel codeModel = new JCodeModel();
          JDefinedClass generatedType = codeModel._class("example.GeneratedType");
  
          CodeLabelWriter writer = generatedType.annotate2(CodeLabelWriter.class);
          CodeLabelWriter chainedWriter = writer.label("primary").enabled(true).priority(7).type(String.class);
  
          assertThat(chainedWriter).isSameAs(writer);
          assertThat(writer.getAnnotationType()).isEqualTo(CodeLabel.class);
  
          JAnnotationUse annotationUse = writer.getAnnotationUse();
          assertThat(annotationUse.getAnnotationClass().fullName()).isEqualTo(CodeLabel.class.getName());
          assertThat(annotationUse.getAnnotationMembers()).containsOnlyKeys("label", "enabled", "priority", "type");
  
          String renderedAnnotation = render(annotationUse);
          assertThat(renderedAnnotation)
                  .contains("label=\"primary\"")
                  .contains("enabled=true")
                  .contains("priority=7")
                  .contains("type=String.class");
      }
  
      private static String render(JAnnotationUse annotationUse) {
          StringWriter out = new StringWriter();
          JFormatter formatter = new JFormatter(out);
          annotationUse.generate(formatter);
          formatter.close();
          return out.toString();
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface CodeLabel {
          String label();
  
          boolean enabled();
  
          int priority();
  
          Class<?> type();
      }
  
      public interface CodeLabelWriter extends JAnnotationWriter<CodeLabel> {
          @Override
          JAnnotationUse getAnnotationUse();
  
          @Override
          Class<CodeLabel> getAnnotationType();
  
          CodeLabelWriter label(String value);
  
          CodeLabelWriter enabled(boolean value);
  
          CodeLabelWriter priority(int value);
  
          CodeLabelWriter type(Class<?> value);
      }
  }
