      JPackage(String name, JCodeModel cw) {
          this.owner = cw;
          if (name.equals(".")) {
              String msg = "Package name . is not allowed";
              throw new IllegalArgumentException(msg);
          }
  
          if(JCodeModel.isCaseSensitiveFileSystem)
              upperCaseClassMap = null;
          else
