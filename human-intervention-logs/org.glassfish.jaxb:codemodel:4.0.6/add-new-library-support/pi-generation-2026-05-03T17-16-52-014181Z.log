om.sun.codemodel.JAnnotationWriter;\nimport com.sun.codemodel.JCodeModel;\nimport com.sun.codemodel.JDefinedClass;\nimport com.sun.codemodel.writer.SingleStreamCodeWriter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypedAnnotationWriterTest {\n    @Test\n    void typedAnnotationWriterCreatesProxyAndRecordsAnnotationMembers() throws Exception {\n        JCodeModel codeModel = new JCodeModel();\n        JDefinedClass generatedType = codeModel._class(\"example.GeneratedType\");\n\n        DeprecatedAnnotationWriter writer = generatedType.annotate2(DeprecatedAnnotationWriter.class);\n        JAnnotationUse annotationUse = writer.getAnnotationUse();\n\n        assertThat(writer.getAnnotationType()).isEqualTo(Deprecated.class);\n        assertThat(writer.since(\"4.0\")).isSameAs(writer);\n        assertThat(writer.forRemoval(true)).isSameAs(writer);\n        assertThat(annotationUse.getAnnotationClass().fullName()).isEqualTo(Deprecated.class.getName());\n        assertThat(annotationUse.getAnnotationMembers()).containsOnlyKeys(\"since\", \"forRemoval\");\n\n        assertThat(generateSource(codeModel))\n                .contains(\"@Deprecated(since=\\\"4.0\\\",forRemoval=true)\")\n                .contains(\"class GeneratedType\");\n    }\n\n    private static String generateSource(JCodeModel codeModel) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        codeModel.build(new SingleStreamCodeWriter(output));\n        return output.toString(StandardCharsets.UTF_8);\n    }\n\n    public interface DeprecatedAnnotationWriter extends JAnnotationWriter<Deprecated> {\n        @Override\n        JAnnotationUse getAnnotationUse();\n\n        @Override\n        Class<Deprecated> getAnnotationType();\n\n        DeprecatedAnnotationWriter since(String value);\n\n        DeprecatedAnnotationWriter forRemoval(boolean value);\n    }\n}\n"}}], "api": "openai-responses", "pro