  package com_typesafe_slick.slick_3
  
  import com.typesafe.config.ConfigFactory
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Assertions.assertThrows
  import org.junit.jupiter.api.Test
  import slick.SlickException
  import slick.basic.{BasicProfile, DatabaseConfig}
  import slick.compiler.AssignUniqueSymbols
  import slick.memory.MemoryProfile
  
  class DatabaseConfigTest {
    @Test
    def loadsConfiguredProfileObject(): Unit = {
      val config = ConfigFactory.parseString("""
        database {
          profile = "slick.memory.MemoryProfile$"
        }
        """)
  
      val databaseConfig: DatabaseConfig[BasicProfile] = DatabaseConfig.forConfig[BasicProfile]("database", config)
  
      assertThat(databaseConfig.profile).isSameAs(MemoryProfile)
      assertThat(databaseConfig.profileIsObject).isTrue()
      assertThat(databaseConfig.profileName).isEqualTo("slick.memory.MemoryProfile")
      assertThat(databaseConfig.config.getString("profile")).isEqualTo("slick.memory.MemoryProfile$")
    }
  
    @Test
    def instantiatesConfiguredClassBeforeRejectingNonProfileType(): Unit = {
      val configuredClassName: String = classOf[AssignUniqueSymbols].getName
      val config = ConfigFactory.parseString(s"""
        database {
          profile = "$configuredClassName"
        }
        """)
  
      val exception = assertThrows(
        classOf[SlickException],
        () => DatabaseConfig.forConfig[BasicProfile]("database", config)
      )
  
      assertThat(exception).hasMessageContaining(s"Configured profile $configuredClassName does not conform")
    }
  }
