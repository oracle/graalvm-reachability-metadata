sertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport slick.basic.DatabaseConfig\nimport slick.memory.MemoryProfile\n\nclass DatabaseConfigTest {\n  @Test\n  def loadsConfiguredProfileObject(): Unit = {\n    val config = ConfigFactory.parseString(\"\"\"\n      app.profile = \"slick.memory.MemoryProfile$\"\n    \"\"\")\n\n    val databaseConfig: DatabaseConfig[MemoryProfile] = DatabaseConfig.forConfig[MemoryProfile](\"app\", config)\n\n    assertThat(databaseConfig.profile).isSameAs(MemoryProfile)\n    assertThat(databaseConfig.profileIsObject).isTrue()\n    assertThat(databaseConfig.profileName).isEqualTo(\"slick.memory.MemoryProfile\")\n    assertThat(databaseConfig.config.getString(\"profile\")).isEqualTo(\"slick.memory.MemoryProfile$\")\n  }\n\n  @Test\n  def instantiatesConfiguredProfileClass(): Unit = {\n    val profileClassName: String = \"com_typesafe_slick.slick_3.LoadableMemoryProfileForDatabaseConfigTest\"\n    val config = ConfigFactory.parseString(s\"\"\"\n      profile = \"$profileClassName\"\n    \"\"\")\n\n    val databaseConfig: DatabaseConfig[MemoryProfile] = DatabaseConfig.forConfig[MemoryProfile](\"\", config)\n\n    assertThat(databaseConfig.profile).isInstanceOf(classOf[LoadableMemoryProfileForDatabaseConfigTest])\n    assertThat(databaseConfig.profileIsObject).isFalse()\n    assertThat(databaseConfig.profileName).isEqualTo(profileClassName)\n  }\n}\n\nfinal class LoadableMemoryProfileForDatabaseConfigTest extends MemoryProfile\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2327, "output": 1506, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 27385, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778033378339, "responseId": "resp_05412a02d134d88e0169faa2e2d5108193a49152057d36e1f4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0DCWjjSQUeVuKc66x0DLbJZM|fc_05412a02d134d88e0169faa2f0c9b8819