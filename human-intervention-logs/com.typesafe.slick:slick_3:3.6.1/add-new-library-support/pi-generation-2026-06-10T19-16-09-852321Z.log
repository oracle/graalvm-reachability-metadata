[tool-call] delta {"path":"tests/src/com.typesafe.slick/slick_3/3.6.1/src/test/scala/com_typesafe_slick/slick_3/DataSourceJdbcDataSourceTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_slick.slick_3\n\nimport com.typesafe.config.Config\nimport com.typesafe.config.ConfigFactory\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport slick.jdbc.H2Profile\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nclass DataSourceJdbcDataSourceTest {\n  @Test\n  def createsDatabaseFromConfiguredDataSourceClass(): Unit = {\n    import H2Profile.api.*\n\n    val databaseName: String = \"datasource_jdbc_datasource_test_\" + System.nanoTime()\n    val config: Config = ConfigFactory.parseString(s\"\"\"\n      db {\n        connectionPool = \"disabled\"\n        dataSourceClassName = \"org.h2.jdbcx.JdbcDataSource\"\n        properties {\n          URL = \"jdbc:h2:mem:$databaseName;DB_CLOSE_DELAY=-1\"\n          user = \"sa\"\n          password = \"\"\n        }\n        keepAliveConnection = true\n        maxConnections = 1\n        numThreads = 1\n        queueSize = 10\n      }\n      \"\"\")\n\n    val db: Database = Database.forConfig(\"db\", config)\n    try {\n      val selectedValue: Int = Await.result(db.run(sql\"select 42\".as[Int].head), 10.seconds)\n      assertThat(selectedValue).isEqualTo(42)\n    } finally {\n      db.close()\n    }\n  }\n}\n"}
