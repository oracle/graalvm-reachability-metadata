  package com_typesafe_slick.slick_3
  
  import com.typesafe.config.{Config, ConfigFactory}
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import slick.jdbc.{DataSourceJdbcDataSource, DriverDataSource}
  
  class DataSourceJdbcDataSourceTest {
    @Test
    def instantiatesConfiguredDataSourceClass(): Unit = {
      val config: Config = ConfigFactory.parseString("""
        dataSourceClassName = "slick.jdbc.DriverDataSource"
        maxConnections = 3
        properties {
          url = "jdbc:slick:configured"
          user = "configured-user"
          password = "configured-password"
          deregisterDriver = true
        }
      """)
  
      val jdbcDataSource: DataSourceJdbcDataSource = DataSourceJdbcDataSource.forConfig(
        config,
        null,
        "configuredDataSource",
        getClass.getClassLoader
      )
  
      assertThat(jdbcDataSource.maxConnections).isEqualTo(Some(3))
      assertThat(jdbcDataSource.keepAliveConnection).isFalse()
  
      val driverDataSource: DriverDataSource = jdbcDataSource.ds.asInstanceOf[DriverDataSource]
