vd6CJ7mhUyWtBB5fJO6GvqZ|fc_01536cd153000bb70169faa803ae24819286b3d9e666a4530c", "name": "write", "arguments": {"path": "tests/src/com.typesafe.slick/slick_3/3.6.1/src/test/scala/com_typesafe_slick/slick_3/DataSourceJdbcDataSourceTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_slick.slick_3\n\nimport com.typesafe.config.{Config, ConfigFactory}\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport slick.jdbc.{DataSourceJdbcDataSource, DriverDataSource}\n\nclass DataSourceJdbcDataSourceTest {\n  @Test\n  def instantiatesConfiguredDataSourceClass(): Unit = {\n    val config: Config = ConfigFactory.parseString(\"\"\"\n      dataSourceClassName = \"slick.jdbc.DriverDataSource\"\n      maxConnections = 3\n      properties {\n        url = \"jdbc:slick:configured\"\n        user = \"configured-user\"\n        password = \"configured-password\"\n        deregisterDriver = true\n      }\n    \"\"\")\n\n    val jdbcDataSource: DataSourceJdbcDataSource = DataSourceJdbcDataSource.forConfig(\n      config,\n      null,\n      \"configuredDataSource\",\n      getClass.getClassLoader\n    )\n\n    assertThat(jdbcDataSource.maxConnections).contains(3)\n    assertThat(jdbcDataSource.keepAliveConnection).isFalse()\n\n    val driverDataSource: DriverDataSource = jdbcDataSource.ds.asInstanceOf[DriverDataSource]\n    assertThat(driverDataSource.getUrl()).isEqualTo(\"jdbc:slick:configured\")\n    assertThat(driverDataSource.getUser()).isEqualTo(\"configured-user\")\n    assertThat(driverDataSource.getPassword()).isEqualTo(\"configured-password\")\n    assertThat(driverDataSource.isDeregisterDriver()).isTrue()\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 935, "output": 740, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 17035, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778034685979, "responseId": "resp_01536cd153000bb70169faa7fe7b3481929d0ff6586fa58ce2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Hvd6CJ7mhUyWtBB5fJO6GvqZ|fc_01536cd153000bb70169faa803ae24819286b3d9e666a4530c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1550 bytes to tests/src/com.typesafe.slick/slick_3/3.6.1/src/test/scala/com_typesafe_slick/slick_3/DataSourceJdbcDataSourceTest.scala"}], "isError": false, "timestamp": 1778034694095}]}
