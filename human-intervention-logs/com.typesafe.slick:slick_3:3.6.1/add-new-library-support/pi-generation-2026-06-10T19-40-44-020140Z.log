  package com_typesafe_slick.slick_3
  
  import java.sql.Blob
  import java.sql.Connection
  import java.sql.PreparedStatement
  import java.sql.ResultSet
  import java.util.Properties
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import slick.jdbc.PositionedParameters
  import slick.util.BeanConfigurator
  
  class BeanConfiguratorTest {
    @Test
    def configuresSlickBeanPropertiesWithSupportedTypes(): Unit = {
      val databaseName: String = "bean_configurator_test_" + System.nanoTime()
      val connectionProperties: Properties = new Properties
      val connection: Connection = new org.h2.Driver()
        .connect(s"jdbc:h2:mem:$databaseName;DB_CLOSE_DELAY=-1", connectionProperties)
  
      try {
        val statement: PreparedStatement = connection.prepareStatement("select ?, ?, ?, ?, ?")
        val blob: Blob = connection.createBlob()
        try {
          blob.setBytes(1L, Array[Byte](1, 2, 3))
  
          val beanProperties: Properties = new Properties
          beanProperties.setProperty("int", "42")
          beanProperties.setProperty("long", "9223372036854775806")
          beanProperties.setProperty("boolean", "true")
          beanProperties.setProperty("string", "configured")
          beanProperties.put("blob", blob)
  
          val parameters: PositionedParameters = new PositionedParameters(statement)
          BeanConfigurator.configure(parameters, beanProperties)
  
          assertThat(parameters.pos).isEqualTo(5)
          val resultSet: ResultSet = statement.executeQuery()
          try {
            assertThat(resultSet.next()).isTrue
            (1 to 5).foreach { index =>
              assertThat(resultSet.getObject(index)).isNotNull
            }
            assertThat(resultSet.next()).isFalse
          } finally {
            resultSet.close()
          }
        } finally {
          blob.free()
          statement.close()
        }
      } finally {
        connection.close()
      }
    }
  }
