  package com_typesafe_slick.slick_3
  
  import com.typesafe.config.Config
  import com.typesafe.config.ConfigFactory
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import slick.basic.DatabaseConfig
  import slick.jdbc.H2Profile
  import slick.memory.MemoryProfile
  
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  
  class ConfiguredMemoryProfile extends MemoryProfile
  
  class DatabaseConfigTest {
    @Test
    def loadsConfiguredProfileObjectAndCreatesDatabase(): Unit = {
      import H2Profile.api.*
  
      val databaseName: String = "database_config_test_" + System.nanoTime()
      val config: Config = ConfigFactory.parseString(s"""
        slick {
          profile = "slick.jdbc.H2Profile$$"
          db {
            connectionPool = "disabled"
            driver = "org.h2.Driver"
            url = "jdbc:h2:mem:$databaseName;DB_CLOSE_DELAY=-1"
            keepAliveConnection = true
            numThreads = 1
            queueSize = 10
          }
        }
        """)
  
      val databaseConfig: DatabaseConfig[H2Profile] = DatabaseConfig.forConfig[H2Profile]("slick", config)
  
      assertThat(databaseConfig.profile).isSameAs(H2Profile)
      assertThat(databaseConfig.profileName).isEqualTo("slick.jdbc.H2Profile")
      assertThat(databaseConfig.profileIsObject).isTrue
      assertThat(databaseConfig.config.getString("profile")).isEqualTo("slick.jdbc.H2Profile$")
  
      val db: databaseConfig.profile.backend.Database = databaseConfig.db
      try {
        val selectedValue: Int = Await.result(db.run(sql"select 42".as[Int].head), 10.seconds)
        assertThat(selectedValue).isEqualTo(42)
      } finally {
        db.close
      }
    }
  
    @Test
    def instantiatesConfiguredProfileClass(): Unit = {
      val profileClassName: String = classOf[ConfiguredMemoryProfile].getName
      val config: Config = ConfigFactory.parseString(s"""
        slick.profile = "$profileClassName"
        """)
  
      val databaseConfig: DatabaseConfig[MemoryProfile] = DatabaseConfig.forConfig[MemoryProfile]("slick", config)
  
      assertThat(databaseConfig.profile).isInstanceOf(classOf[ConfiguredMemoryProfile])
      assertThat(databaseConfig.profileName).isEqualTo(profileClassName)
      assertThat(databaseConfig.profileIsObject).isFalse
      assertThat(databaseConfig.config.getString("profile")).isEqualTo(profileClassName)
    }
  }
