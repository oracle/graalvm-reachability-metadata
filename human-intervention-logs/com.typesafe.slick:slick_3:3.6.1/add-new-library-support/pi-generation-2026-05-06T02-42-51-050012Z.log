  package com_typesafe_slick.slick_3
  
  import java.sql.{Connection, Driver, DriverPropertyInfo}
  import java.util.Properties
  import java.util.logging.Logger
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import slick.jdbc.DriverDataSource
  
  class DriverDataSourceTest {
    @Test
    def loadsAndInstantiatesConfiguredDriverClass(): Unit = {
      val dataSource: DriverDataSource = new DriverDataSource(
        "jdbc:slick-driver-data-source:direct",
        null,
        null,
        null,
        classOf[DriverDataSourceTestDriver].getName,
        false,
        null,
        getClass.getClassLoader
      )
  
      try {
        assertThat(dataSource.getConnection).isNull()
        assertThat(dataSource.getParentLogger.getName).isEqualTo("com_typesafe_slick.slick_3.DriverDataSourceTestDriver")
      } finally {
        dataSource.close()
      }
    }
  }
  
  class DriverDataSourceTestDriver extends Driver {
    override def connect(url: String, info: Properties): Connection = null
  
    override def acceptsURL(url: String): Boolean = url.startsWith("jdbc:slick-driver-data-source:")
  
    override def getPropertyInfo(url: String, info: Properties): Array[DriverPropertyInfo] = Array.empty[DriverPropertyInfo]
  
    override def getMajorVersion(): Int = 1
  
    override def getMinorVersion(): Int = 0
  
    override def jdbcCompliant(): Boolean = false
  
    override def getParentLogger(): Logger = Logger.getLogger("com_typesafe_slick.slick_3.DriverDataSourceTestDriver")
  }
