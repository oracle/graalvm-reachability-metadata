  package com_typesafe_slick.slick_3
  
  import java.sql.{Connection, Driver}
  
  import com.typesafe.config.{Config, ConfigFactory}
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import slick.jdbc.{JdbcDataSource, JdbcDataSourceFactory}
  
  class JdbcDataSourceTest {
    @Test
    def loadsConfiguredConnectionPoolFactoryObject(): Unit = {
      val factoryClassName: String = LoadableJdbcDataSourceFactoryForJdbcDataSourceTest.getClass.getName
      val config: Config = ConfigFactory.parseString(s"""
        connectionPool = "$factoryClassName"
        maxConnections = 7
      """)
      val classLoader: ClassLoader = getClass.getClassLoader
  
      val jdbcDataSource: JdbcDataSource = JdbcDataSource.forConfig(config, null, "configuredPool", classLoader)
  
      assertThat(jdbcDataSource).isInstanceOf(classOf[LoadableJdbcDataSourceForJdbcDataSourceTest])
      val loadedDataSource: LoadableJdbcDataSourceForJdbcDataSourceTest =
        jdbcDataSource.asInstanceOf[LoadableJdbcDataSourceForJdbcDataSourceTest]
      assertThat(loadedDataSource.name).isEqualTo("configuredPool")
      assertThat(loadedDataSource.factoryClassLoader).isSameAs(classLoader)
      assertThat(loadedDataSource.maxConnections).isEqualTo(Some(7))
    }
  }
  
  final class LoadableJdbcDataSourceForJdbcDataSourceTest(
      val name: String,
      val factoryClassLoader: ClassLoader,
      val maxConnections: Option[Int]
  ) extends JdbcDataSource {
    override def createConnection(): Connection = null
  
    override def close(): Unit = ()
  }
  
  object LoadableJdbcDataSourceFactoryForJdbcDataSourceTest extends JdbcDataSourceFactory {
    override def forConfig(c: Config, driver: Driver, name: String, classLoader: ClassLoader): JdbcDataSource =
      new LoadableJdbcDataSourceForJdbcDataSourceTest(name, classLoader, Some(c.getInt("maxConnections")))
  }
