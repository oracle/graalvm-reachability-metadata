      val previousLoginTimeout: Int = DriverManager.getLoginTimeout()
      val dataSource: DriverDataSource = new DriverDataSource()
      val connectionProperties: Properties = new Properties()
      connectionProperties.setProperty("applicationName", "bean-configurator-test")
      val dataSourceProperties: Properties = new Properties()
      dataSourceProperties.setProperty("loginTimeout", "7")
      dataSourceProperties.setProperty("deregisterDriver", "true")
      dataSourceProperties.setProperty("url", "jdbc:slick:test")
      dataSourceProperties.put("properties", connectionProperties)
  
      try {
        BeanConfigurator.configure(dataSource, dataSourceProperties)
  
        assertThat(DriverManager.getLoginTimeout()).isEqualTo(7)
        assertThat(dataSource.isDeregisterDriver()).isTrue()
        assertThat(dataSource.getUrl()).isEqualTo("jdbc:slick:test")
        assertThat(dataSource.getProperties()).isSameAs(connectionProperties)
      } finally {
        DriverManager.setLoginTimeout(previousLoginTimeout)
      }
  
      val positionedParameters: PositionedParameters = new PositionedParameters(null)
      val longProperties: Properties = new Properties()
      longProperties.setProperty("long", "9876543210")
  
      val thrown: SlickException = assertThrows(
        classOf[SlickException],
        () => BeanConfigurator.configure(positionedParameters, longProperties)
      )
  
      assertThat(thrown).hasMessageContaining("long")
    }
  }
