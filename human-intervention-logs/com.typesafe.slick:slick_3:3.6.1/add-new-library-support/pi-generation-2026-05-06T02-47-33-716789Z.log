[tool-call] delta {"path":"tests/src/com.typesafe.slick/slick_3/3.6.1/src/test/scala/com_typesafe_slick/slick_3/PGUtilsTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_slick.slick_3\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.postgresql.util.PGobject\nimport slick.jdbc.PGUtils\n\nclass PGUtilsTest {\n  @Test\n  def createsPostgresObjectWithConfiguredTypeAndValue(): Unit = {\n    val value: String = \"2026-05-06 12:34:56.123456\"\n    val dbType: String = \"TIMESTAMP\"\n\n    val pgObject: PGobject = PGUtils.createPGObject(value, dbType).asInstanceOf[PGobject]\n\n    assertThat(pgObject.getType).isEqualTo(dbType)\n    assertThat(pgObject.getValue).isEqualTo(value)\n  }\n}\n"}
