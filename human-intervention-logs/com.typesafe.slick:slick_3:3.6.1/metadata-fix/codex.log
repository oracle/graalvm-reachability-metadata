meters: PositionedParameters = new PositionedParameters(null)\n    val longProperties: Properties = new Properties()\n    longProperties.setProperty(\"long\", \"9876543210\")\n\n    val thrown: SlickException = assertThrows(\n      classOf[SlickException],\n      () => BeanConfigurator.configure(positionedParameters, longProperties)\n    )\n\n    assertThat(thrown).hasMessageContaining(\"long\")\n  }\n}\n","exit_code":0,"status":"completed"}}
