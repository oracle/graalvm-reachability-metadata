      public void registerCatalogEntry(String publicId,
                                       String resourceName,
                                       ClassLoader loader) {
          if (id2resource == null)
              id2resource = new HashMap<>(17);
          id2resource.put(publicId, resourceName);
  
          if (loader != null) {
              if (id2loader == null)
                  id2loader = new HashMap<>(17);
              id2loader.put(publicId, loader);
          }
      }
