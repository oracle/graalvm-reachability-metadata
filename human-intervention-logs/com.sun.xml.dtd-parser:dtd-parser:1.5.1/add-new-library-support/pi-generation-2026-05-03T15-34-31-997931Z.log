};\n\n        String message = catalog.getMessage(Locale.ENGLISH, \"formatted\", new Object[]{customParameter, 7});\n\n        assertEquals(\"Hello converted, count 7\", message);\n    }\n\n    @Test\n    void chooseLocaleUsesFirstSupportedCanonicalLanguageTag() {\n        TestCatalog catalog = new TestCatalog();\n\n        Locale locale = catalog.chooseLocale(new String[]{\"too-specific-tag\", \"FR-ca\", \"en\"});\n\n        assertEquals(new Locale.Builder().setLanguage(\"fr\").setRegion(\"CA\").build(), locale);\n    }\n\n    @Test\n    void isLocaleSupportedChecksMessageProperties() {\n        TestCatalog catalog = new TestCatalog();\n\n        assertTrue(catalog.isLocaleSupported(\"fr_CA\"));\n        assertTrue(catalog.isLocaleSupported(\"en\"));\n        assertFalse(catalog.isLocaleSupported(\"es_MX\"));\n    }\n\n    private static final class TestCatalog extends MessageCatalog {\n        private TestCatalog() {\n            super(MessageCatalogTest.class);\n        }\n    }\n}\n"}
