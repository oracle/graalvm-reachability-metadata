[tool-call] delta {"path":"tests/src/com.sun.xml.dtd-parser/dtd-parser/1.5.1/src/test/java/com_sun_xml_dtd_parser/dtd_parser/MessageCatalogTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_sun_xml_dtd_parser.dtd_parser;\n\nimport com.sun.xml.dtdparser.MessageCatalog;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Locale;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class MessageCatalogTest {\n    @Test\n    void getMessageLoadsRequestedBundle() {\n        TestCatalog catalog = new TestCatalog();\n\n        assertEquals(\"Hello\", catalog.getMessage(Locale.ENGLISH, \"plain\"));\n        assertEquals(\"Bonjour\", catalog.getMessage(Locale.FRENCH, \"plain\"));\n    }\n\n    @Test\n    void getMessageFallsBackToEnglishBundle() {\n        Locale originalDefault = Locale.getDefault();\n        Locale.setDefault(Locale.ROOT);\n        try {\n            TestCatalog catalog = new TestCatalog();\n\n            assertEquals(\"Hello\", catalog.getMessage(Locale.GERMAN, \"plain\"));\n            assertEquals(\"Hello fallback, count 2\", catalog.getMessage(Locale.GERMAN, \"formatted\",\n                    new Object[]{\"fallback\", 2}));\n        } finally {\n            Locale.setDefault(originalDefault);\n        }\n    }\n\n    @Test\n    void getMessageFormatsParametersAfterConvertingUnexpectedTypes() {\n        TestCatalog catalog = new TestCatalog();\n        Object customParameter = new Object() {\n            @Override\n            public String toString() {\n                return \"converted\";\n            }\n        };\n\n        String message = catalog.getMessage(Locale.ENGLISH, \"formatted\", new Object[]{customParameter, 7});\n\n        assertEquals(\"Hello converted, count 7\", message);\n    }\n\n    @Test\n    void chooseLocaleUsesFirstSupportedCanonicalLanguageTag() {\n        TestCatalog catalog = new TestCatalog();\n\n        Locale locale = catalog.chooseLocale(new String[]{\"too-specific-tag\", \"FR-ca\", \"en\"});\n\n        assertEquals(new Locale.Builder().setLanguage(\"fr\").setRegion(\"CA\").build(), locale);\n    }\n\n    @Test\n    void isLocaleSupportedChecksMessageProperties() {\n        TestCatalog catalog = new TestCatalog();\n\n        assertTrue(catalog.isLocaleSupported(\"fr_CA\"));\n        assertTrue(catalog.isLocaleSupported(\"en\"));\n        assertFalse(catalog.isLocaleSupported(\"es_MX\"));\n    }\n\n    private static final class TestCatalog extends MessageCatalog {\n        private TestCatalog() {\n            super(MessageCatalogTest.class);\n        }\n    }\n}\n"}
[tool-call] end id=call_ma0PsmGPoFkhE2TgMfhQcPWO|fc_02027b253bf081e90169f76acb51c481a3879fa485cecc7d51 name=write args={"path": "tests/src/com.sun.xml.dtd-parser/dtd-parser/1.5.1/src/test/java/com_sun_xml_dtd_parser/dtd_parser/MessageCatalogTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_sun_xml_dtd_parser.dtd_parser;\n\nimport com.sun.xml.dtdparser.MessageCatalog;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Locale;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class MessageCatalogTest {\n    @Test\n    void getMessageLoadsRequestedBundle() {\n        TestCatalog catalog = new TestCatalog();\n\n        assertEquals(\"Hello\", catalog.getMessage(Locale.ENGLISH, \"plain\"));\n        assertEquals(\"Bonjour\", catalog.getMessage(Locale.FRENCH, \"plain\"));\n    }\n\n    @Test\n    void getMessageFallsBackToEnglishBundle() {\n        Locale originalDefault = Locale.getDefault();\n        Locale.setDefault(Locale.ROOT);\n        try {\n            TestCatalog catalog = new TestCatalog();\n\n            assertEquals(\"Hello\", catalog.getMessage(Locale.GERMAN, \"plain\"));\n            assertEquals(\"Hello fallback, count 2\", catalog.getMessage(Locale.GERMAN, \"formatted\",\n                    new Object[]{\"fallback\", 2}));\n        } finally {\n            Locale.setDefault(originalDefault);\n        }\n    }\n\n    @Test\n    void getMessageFormatsParametersAfterConvertingUnexpectedTypes() {\n        TestCatalog catalog = new TestCatalog();\n        Object customParameter = new Object() {\n            @Override\n            public String toString() {\n                return \"converted\";\n            }\n        };\n\n        String message = catalog.getMessage(Locale.ENGLISH, \"formatted\", new Object[]{customParameter, 7});\n\n        assertEquals(\"Hello converted, count 7\", message);\n    }\n\n    @Test\n    void chooseLocaleUsesFirstSupportedCanonicalLanguageTag() {\n        TestCatalog catalog = new TestCatalog();\n\n        Locale locale = catalog.chooseLocale(new String[]{\"too-specific-tag\", \"FR-ca\", \"en\"});\n\n        assertEquals(new Locale.Builder().setLanguage(\"fr\").setRegion(\"CA\").build(), locale);\n    }\n\n    @Test\n    void isLocaleSupportedChecksMessageProperties() {\n        TestCatalog catalog = new TestCatalog();\n\n        assertTrue(catalog.isLocaleSupported(\"fr_CA\"));\n        assertTrue(catalog.isLocaleSupported(\"en\"));\n        assertFalse(catalog.isLocaleSupported(\"es_MX\"));\n    }\n\n    private static final class TestCatalog extends MessageCatalog {\n        private TestCatalog() {\n            super(MessageCatalogTest.class);\n        }\n    }\n}\n"}
