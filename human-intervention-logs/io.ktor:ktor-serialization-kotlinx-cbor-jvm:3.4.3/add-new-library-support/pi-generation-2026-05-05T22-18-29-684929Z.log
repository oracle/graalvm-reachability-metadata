          )
      }
  
      val selected = serializers.singleOrNull() ?: String.serializer()
  
      if (selected.descriptor.isNullable) {
          return selected
      }
  
      @Suppress("UNCHECKED_CAST")
      selected as KSerializer<Any>
  
      if (any { it == null }) {
          return selected.nullable
      }
  
      return selected
  }
