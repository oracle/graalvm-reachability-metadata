NGAdQJub-CA6z59r7dIatgaOL92E8gOmwxawRvuC3BdMqvSiOO4K7MnQRsJciPbloWIqpCwkSxDohLGNvoAIP2N-SsSFrxKVztEhmtYK7BUvnvRsm0i_lDFzLjZtEh5xrlfvTBbmiwXEsMSYznnFy8Olg5YPbLZXYQIp4xrbAcbuZ75WMixlFZdaHD4H8kSzzPAmf4nKcWVnan8Pd2qmR53wor768Oitx8wLIn0HhzaN9XDVgS1pq7aYF_warzHyRh7PsB6piuR6Njbs3-upoWoQzGPsRctn-oZG6Yaex2mc87TBhR_SvRhsvdCs4ITOZCqFDcGlMQUPcJ4meKuQgoOLZQhf2w5hpWpTW7Hcr5FdbZM9eO4c-jbfxFrjthtoA1_Pq1pAJ3T5G9mAcoFIEZSZbyF-E13dupN5JvQkSLlQLY0g0brnqY9K6BqN61YOq1OW2YFRsvQxrLSA5sHcZ4ttNY75jqWVfmK_WMMYaD4elIsLe-sPLLzjTvwuBB9qrCpVQZI5dCjSIumnuA91-oe0XpIdmgvhg9UXRlS_y2krPTJVCMStWdyiV81dKOyk10Hx9W-HSiN9axWqn5vZo4HNBA5iKFOjq4-Ts5Np0c-z0cMyDFfKEyDubj-kYN9-mC3zyGenyH2D8hJarWpjykTQr6Iv69Cq9BFKSoxM5hR1kxzJvj-MZUjjHs4jrtVgUafU1JWnn3yJopyFSGtrKEQigyb3HGr9A7pB40ddsneGofgbgLooV25KR7RcFVuRzI6zzjuKMWmeFsY3H6ClJBsTStHI0OLmMvSgCAUJKQiSSUAV_JC2\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_bIeNPDCXGz9yQNMbHJeoRdTE|fc_032a0cd35e800ca80169fa6b3deff48195be41eb7adedcc5ff", "name": "write", "arguments": {"path": "tests/src/io.ktor/ktor-serialization-kotlinx-cbor-jvm/3.4.3/src/test/kotlin/io_ktor/ktor_serialization_kotlinx_cbor_jvm/Ktor_serialization_kotlinx_cbor_jvmTest.kt", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_ktor.ktor_serialization_kotlinx_cbor_jvm\n\nimport io.ktor.http.ContentType\nimport io.ktor.http.content.OutgoingContent\nimport io.ktor.serialization.Configuration\nimport io.ktor.serialization.ContentConverter\nimport io.ktor.serialization.kotlinx.KotlinxSerializationConverter\nimport io.ktor.serialization.kotlinx.cbor.DefaultCbor\nimport io.ktor.serialization.kotlinx.cbor.cbor\nimport io.ktor.util.reflect.typeInfo\nimport io.ktor.utils.io.ByteReadChannel\nimport kotlinx.coroutines.runBlocking\nimport kotlinx.coroutines.withTimeout\nimport kotlinx.serialization.ExperimentalSerializationApi\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\n@OptIn(ExperimentalSerializationApi::class)\npublic class Ktor_serialization_kotlinx_cbor_jvmTest {\n    @Test\n    fun cborRegistersDefaultConverterForApplicationCbor(): Unit = runBlocking {\n        withTimeout(TEST_TIMEOUT_MILLIS) {\n            val configuration = CapturingConfiguration()\n\n            configuration.cbor()\n\n            val registration = configuration.singleRegistration()\n            assertThat(registration.contentType).isEqualTo(ContentType.Application.Cbor)\n            assertThat(registration.converter).isInstanceOf(KotlinxSerializationConverter::class.java)\n        }\n    }\n\n    @Test\n    fun registeredCborConverterRoundTripsNestedCollectionPayload(): Unit = runBlocking {\n        withTimeout(TEST_TIMEOUT_MILLIS) {\n            val converter = registeredDefaultConverter()\n            val payload: Map<String, List<Int>> = linkedMapOf(\n                \"odds\" to listOf(1, 3, 5),\n                \"evens\" to listOf(2, 4, 6),\n            )\n\n            val bytes = converter.serializeToBytes(payload)\n            val decoded: Map<String, List<Int>> = converter.deserializeFromBytes(bytes)\n\n            assertThat(bytes).isNotEmpty()\n            assertThat(decoded).isEqualTo(payload)\n        }\n    }\n\n    @Test\n    fun cborRegistersExplicitFormatForCustomContentType(): Unit = runBlocking {\n        withTimeout(TEST_TIMEOUT_MILLIS) {\n            val contentType = ContentType.parse(\"application/vnd.ktor.test+cbor\")\n            val configuration = CapturingConfiguration()\n\n            configuration.cbor(DefaultCbor, contentType)\n\n            val registration = configuration.singleRegistration()\n            assertThat(registration.contentType).isEqualTo(contentType)\n\n            val payload: List<String> = listOf(\"alpha\", \"beta\", \"gamma\")\n            val bytes = registration.converter.serializeToBytes(payload, contentType)\n            val decoded: List<String> = registration.converter.deserializeFromBytes(bytes)\n            assertThat(decoded).containsExactlyElementsOf(payload)\n        }\n    }\n\n    private fun registeredDefaultConverter(): ContentConverter {\n        val configuration = CapturingConfiguration()\n        configuration.cbor()\n        return configuration.singleRegistration().converter\n    }\n\n    private suspend inline fun <reified T> ContentConverter.serializeToBytes(\n        value: T,\n        contentType: ContentType = ContentType.Application.Cbor,\n    ): ByteArray {\n        val outgoingContent = serialize(contentType, Charsets.UTF_8, typeInfo<T>(), value)\n        assertThat(outgoingContent).isInstanceOf(OutgoingContent.ByteArrayContent::class.java)\n\n        val byteArrayContent = outgoingContent as OutgoingContent.ByteArrayContent\n        assertThat(byteArrayContent.contentType).isEqualTo(contentType)\n        assertThat(byteArrayContent.contentLength).isEqualTo(byteArrayContent.bytes().size.toLong())\n        return byteArrayContent.bytes()\n    }\n\n    private suspend inline fun <reified T> ContentConverter.deserializeFromBytes(bytes: ByteArray): T {\n        val decoded = deserialize(Charsets.UTF_8, typeInfo<T>(), ByteReadChannel(bytes))\n        return decoded as T\n    }\n\n    private data class ConverterRegistration(\n        val contentType: ContentType,\n        val converter: ContentConverter,\n    )\n\n    private class CapturingConfiguration : Configuration {\n        private val registrations: MutableList<ConverterRegistration> = mutableListOf()\n\n        override fun <T : ContentConverter> register(\n            contentType: ContentType,\n            converter: T,\n            configuration: T.() -> Unit,\n        ) {\n            converter.configuration()\n            registrations += ConverterRegistration(contentType, converter)\n        }\n\n        fun singleRegistration(): ConverterRegistration {\n            assertThat(registrations).hasSize(1)\n            return registrations.single()\n        }\n    }\n\n    private companion object {\n        private const val TEST_TIMEOUT_MILLIS: Long = 5_000L\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/io.ktor/ktor-serialization-kotlinx-cbor-jvm/3.4.3/src/test/kotlin/io_ktor/ktor_serialization_kotlinx_cbor_jvm/Ktor_serialization_kotlinx_cbor_jvmTest.kt\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_ktor.ktor_serialization_kotlinx_cbor_jvm\\n\\nimport io.ktor.http.ContentType\\nimport io.ktor.http.content.OutgoingContent\\nimport io.ktor.serialization.Configuration\\nimport io.ktor.serialization.ContentConverter\\nimport io.ktor.serialization.kotlinx.KotlinxSerializationConverter\\nimport io.ktor.serialization.kotlinx.cbor.DefaultCbor\\nimport io.ktor.serialization.kotlinx.cbor.cbor\\nimport io.ktor.util.reflect.typeInfo\\nimport io.ktor.utils.io.ByteReadChannel\\nimport kotlinx.coroutines.runBlocking\\nimport kotlinx.coroutines.withTimeout\\nimport kotlinx.serialization.ExperimentalSerializationApi\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\n@OptIn(ExperimentalSerializationApi::class)\\npublic class Ktor_serialization_kotlinx_cbor_jvmTest {\\n    @Test\\n    fun cborRegistersDefaultConverterForApplicationCbor(): Unit = runBlocking {\\n        withTimeout(TEST_TIMEOUT_MILLIS) {\\n            val configuration = CapturingConfiguration()\\n\\n            configuration.cbor()\\n\\n            val registration = configuration.singleRegistration()\\n            assertThat(registration.contentType).isEqualTo(ContentType.Application.Cbor)\\n            assertThat(registration.converter).isInstanceOf(KotlinxSerializationConverter::class.java)\\n        }\\n    }\\n\\n    @Test\\n    fun registeredCborConverterRoundTripsNestedCollectionPayload(): Unit = runBlocking {\\n        withTimeout(TEST_TIMEOUT_MILLIS) {\\n            val converter = registeredDefaultConverter()\\n            val payload: Map<String, List<Int>> = linkedMapOf(\\n                \\\"odds\\\" to listOf(1, 3, 5),\\n                \\\"evens\\\" to listOf(2, 4, 6),\\n            )\\n\\n            val bytes = converter.serializeToBytes(payload)\\n            val decoded: Map<String, List<Int>> = converter.deserializeFromBytes(bytes)\\n\\n            assertThat(bytes).isNotEmpty()\\n            assertThat(decoded).isEqualTo(payload)\\n        }\\n    }\\n\\n    @Test\\n    fun cborRegistersExplicitFormatForCustomContentType(): Unit = runBlocking {\\n        withTimeout(TEST_TIMEOUT_MILLIS) {\\n            val contentType = ContentType.parse(\\\"application/vnd.ktor.test+cbor\\\")\\n            val configuration = CapturingConfiguration()\\n\\n            configuration.cbor(DefaultCbor, contentType)\\n\\n            val registration = configuration.singleRegistration()\\n            assertThat(registration.contentType).isEqualTo(contentType)\\n\\n            val payload: List<String> = listOf(\\\"alpha\\\", \\\"beta\\\", \\\"gamma\\\")\\n            val bytes = registration.converter.serializeToBytes(payload, contentType)\\n            val decoded: List<String> = registration.converter.deserializeFromBytes(bytes)\\n            assertThat(decoded).containsExactlyElementsOf(payload)\\n        }\\n    }\\n\\n    private fun registeredDefaultConverter(): ContentConverter {\\n        val configuration = CapturingConfiguration()\\n        configuration.cbor()\\n        return configuration.singleRegistration().converter\\n    }\\n\\n    private suspend inline fun <reified T> ContentConverter.serializeToBytes(\\n        value: T,\\n        contentType: ContentType = ContentType.Application.Cbor,\\n    ): ByteArray {\\n        val outgoingContent = serialize(contentType, Charsets.UTF_8, typeInfo<T>(), value)\\n        assert