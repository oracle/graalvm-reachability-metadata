  package org_wildfly_openssl.wildfly_openssl_java;
  
  import java.io.PrintWriter;
  import java.io.StringWriter;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.wildfly.openssl.SSL;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SSLTest {
      @Test
      void getInstanceAttemptsBundledNativeLoaderFallback() {
          String originalNativeLibraryPath = System.getProperty(SSL.ORG_WILDFLY_LIBWFSSL_PATH);
          System.clearProperty(SSL.ORG_WILDFLY_LIBWFSSL_PATH);
          try {
              SSL ssl = SSL.getInstance();
  
              assertThat(ssl).isNotNull();
          } catch (RuntimeException exception) {
              assertThat(stackTrace(exception)).contains("org.wildfly.openssl.SSL");
          } catch (UnsatisfiedLinkError error) {
              assertThat(stackTrace(error)).contains("org.wildfly.openssl.SSL");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              restoreSystemProperty(SSL.ORG_WILDFLY_LIBWFSSL_PATH, originalNativeLibraryPath);
          }
      }
  
      private static void restoreSystemProperty(String key, String value) {
          if (value == null) {
              System.clearProperty(key);
          } else {
              System.setProperty(key, value);
          }
      }
  
      private static String stackTrace(Throwable throwable) {
          StringWriter stackTrace = new StringWriter();
          throwable.printStackTrace(new PrintWriter(stackTrace));
          return stackTrace.toString();
      }
  }
