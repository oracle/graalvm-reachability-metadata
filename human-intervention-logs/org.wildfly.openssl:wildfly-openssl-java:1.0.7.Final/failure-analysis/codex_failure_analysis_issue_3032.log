read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_wildfly_openssl.wildfly_openssl_java;\\n\\nimport java.io.PrintWriter;\\nimport java.io.StringWriter;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.wildfly.openssl.SSL;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class SSLTest {\\n    @Test\\n    void getInstanceAttemptsBundledNativeLoaderFallback() {\\n        String originalNativeLibraryPath = System.getProperty(SSL.ORG_WILDFLY_LIBWFSSL_PATH);\\n        System.clearProperty(SSL.ORG_WILDFLY_LIBWFSSL_PATH);\\n        try {\\n            SSL ssl = SSL.getInstance();\\n\\n            assertThat(ssl).isNotNull();\\n        } catch (RuntimeException exception) {\\n            assertThat(stackTrace(exception)).contains(\\\"org.wildfly.openssl.SSL\\\");\\n        } catch (UnsatisfiedLinkError error) {\\n            assertThat(stackTrace(error)).contains(\\\"org.wildfly.openssl.SSL\\\");\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        } finally {\\n            restoreSystemProperty(SSL.ORG_WILDFLY_LIBWFSSL_PATH, originalNativeLibraryPath);\\n        }\\n    }\\n\\n    private static void restoreSystemProperty(String key, String value) {\\n        if (value == null) {\\n            System.clearProperty(key);\\n        } else {\\n            System.setProperty(key, value);\\n        }\\n    }\\n\\n    private static String stackTrace(Throwable throwable) {\\n        StringWriter stackTrace = new StringWriter();\\n        throwable.printStackTrace(new PrintWriter(stackTrace));\\n        return stackTrace.toString();\\n    }\\n}\\n\"}], \"isErro