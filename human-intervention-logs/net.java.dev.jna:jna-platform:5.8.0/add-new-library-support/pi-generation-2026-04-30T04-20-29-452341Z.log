      private final com.sun.jna.platform.win32.COM.IDispatch rawDispatch;
  
      @SuppressWarnings("LeakingThisInConstructor")
      public ProxyObject(Class<?> theInterface, IDispatch rawDispatch, ObjectFactory factory) {
