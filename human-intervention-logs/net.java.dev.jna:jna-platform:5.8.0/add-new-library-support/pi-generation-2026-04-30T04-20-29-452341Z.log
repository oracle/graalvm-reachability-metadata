                                                         BufferedImage.TYPE_INT_ARGB);
                  Graphics2D g = clip.createGraphics();
                  g.setComposite(AlphaComposite.Clear);
                  g.fillRect(0, 0, bounds.width, bounds.height);
                  g.setComposite(AlphaComposite.SrcOver);
  
