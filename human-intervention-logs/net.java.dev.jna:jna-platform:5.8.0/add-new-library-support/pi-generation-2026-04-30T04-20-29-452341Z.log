       *
       * @param clsid
       *            the clsid
       * @param useActiveInstance
       *            the use active instance
       */
      public COMLateBindingObject(CLSID clsid, boolean useActiveInstance) {
          super(clsid, useActiveInstance);
      }
  
      /**
       * Instantiates a new cOM object.
       *
       * @param progId
