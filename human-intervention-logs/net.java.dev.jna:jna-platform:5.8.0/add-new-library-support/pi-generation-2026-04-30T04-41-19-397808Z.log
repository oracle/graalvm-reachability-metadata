\n        assertThat(client.getInstanceIdentitifier()).isNull();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 361, "output": 797, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 16006, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777524038149, "responseId": "resp_08eccba520f3ee060169f2dd4682688191bd2fbeb0a2bdc5dd"}}
