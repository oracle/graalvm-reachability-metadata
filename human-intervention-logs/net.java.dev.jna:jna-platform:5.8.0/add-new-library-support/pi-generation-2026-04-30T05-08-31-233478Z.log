  +            }
  +            return new InMemorySafeArray(Variant.VT_I4, dimensions, memory);
  +        }
  +
  +        @Override
  +        public Pointer accessData() {
  +            accessed = true;
  +            return dataPointer;
  +        }
  +
  +        @Override
