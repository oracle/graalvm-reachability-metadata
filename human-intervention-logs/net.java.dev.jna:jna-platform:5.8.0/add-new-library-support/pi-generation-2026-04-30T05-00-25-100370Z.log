yObject\", false);\n    }\n\n    private static TestObjectFactory allocateTestObjectFactory() throws Throwable {\n", "newText": "    private void makeKernel32LoadableOnNonWindows() throws IOException, InterruptedException {\n        if (Platform.isWindows()) {\n            return;\n        }\n\n        Path source = tempDirectory.resolve(\"kernel32.c\");\n        Path library = tempDirectory.resolve(System.mapLibraryName(\"kernel32\"));\n        Files.writeString(source, \"int GetUserDefaultLCID(void) { return 1033; }\\n\", StandardCharsets.UTF_8);\n\n        Process process = new ProcessBuilder(\"gcc\", \"-shared\", \"-fPIC\", \"-o\", library.toString(), source.toString())\n            .redirectErrorStream(true)\n            .start();\n        String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n        boolean exited = process.waitFor(30, TimeUnit.SECONDS);\n        if (!exited || process.exitValue() != 0) {\n            throw new IOException(\"Unable to build test kernel32 library: \" + output);\n        }\n        NativeLibrary.addSearchPath(\"kernel32\", tempDirectory.toString());\n    }\n\n    private static void disableComInitializationAssertions() {\n        ClassLoader classLoader = ObjectFactoryTest.class.getClassLoader();\n        classLoader.setClassAssertionStatus(\"com.sun.jna.platform.win32.COM.util.ObjectFactory\", false);\n        classLoader.setClassAssertionStatus(\"com.sun.jna.platform.win32.COM.util.ProxyObject\", false);\n    }\n\n    private static TestObjectFactory allocateTestObjectFactory() throws Throwable {\n"}]}
