[tool-call] delta {"path":"tests/src/net.java.dev.jna/jna-platform/5.8.0/src/test/java/net_java_dev_jna/jna_platform/ObjectFactoryTest.java","edits":[{"oldText":"import com.sun.jna.Pointer;\nimport com.sun.jna.WString;\nimport com.sun.jna.platform.win32.COM.DispatchListener;\nimport com.sun.jna.platform.win32.COM.IDispatchCallback;\nimport com.sun.jna.platform.win32.COM.util.ObjectFactory;\nimport com.sun.jna.platform.win32.COM.util.ProxyObject;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComInterface;\nimport com.sun.jna.platform.win32.Guid.REFIID;\nimport com.sun.jna.platform.win32.OaIdl.DISPID;\nimport com.sun.jna.platform.win32.OaIdl.DISPIDByReference;\nimport com.sun.jna.platform.win32.OaIdl.EXCEPINFO;\nimport com.sun.jna.platform.win32.OleAuto.DISPPARAMS;\nimport com.sun.jna.platform.win32.Variant.VARIANT;\nimport com.sun.jna.platform.win32.WinDef.LCID;\nimport com.sun.jna.platform.win32.WinDef.UINT;\nimport com.sun.jna.platform.win32.WinDef.UINTByReference;\nimport com.sun.jna.platform.win32.WinDef.WORD;\nimport com.sun.jna.platform.win32.WinError;\nimport com.sun.jna.platform.win32.WinNT.HRESULT;\nimport com.sun.jna.ptr.IntByReference;\nimport com.sun.jna.ptr.PointerByReference;\n","newText":"import com.sun.jna.Pointer;\nimport com.sun.jna.platform.win32.COM.Dispatch;\nimport com.sun.jna.platform.win32.COM.util.ObjectFactory;\nimport com.sun.jna.platform.win32.COM.util.ProxyObject;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComInterface;\n"},{"oldText":"        TestObjectFactory factory = allocateTestObjectFactory();\n        InMemoryDispatch dispatch = new InMemoryDispatch();\n\n        SampleComInterface proxy = factory.createProxy(SampleComInterface.class, dispatch);\n\n        assertNotNull(proxy);\n        assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();\n        assertThat(SampleComInterface.class.isInstance(proxy)).isTrue();\n        assertThat(dispatch.addRefCalls).isEqualTo(1);\n        assertThat(dispatch.queryInterfaceCalls).isEqualTo(1);\n        assertThat(dispatch.releaseCalls).isEqualTo(1);\n","newText":"        TestObjectFactory factory = allocateTestObjectFactory();\n        Dispatch dispatch = newInMemoryDispatch();\n\n        SampleComInterface proxy = factory.createProxy(SampleComInterface.class, dispatch);\n\n        assertNotNull(proxy);\n        assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();\n        assertThat(SampleComInterface.class.isInstance(proxy)).isTrue();\n"},{"oldText":"        Path source = tempDirectory.resolve(\"kernel32.c\");\n        Path library = tempDirectory.resolve(System.mapLibraryName(\"kernel32\"));\n        Files.writeString(source, \"int GetUserDefaultLCID(void) { return 1033; }\\n\", StandardCharsets.UTF_8);\n","newText":"        Path source = tempDirectory.resolve(\"kernel32.c\");\n        Path library = tempDirectory.resolve(System.mapLibraryName(\"kernel32\"));\n        Files.writeString(source, fakeKernel32Source(), StandardCharsets.UTF_8);\n"},{"oldText":"    private static void disableComInitializationAssertions() {\n","newText":"    private Dispatch newInMemoryDispatch() {\n        Function function = NativeLibrary.getInstance(\"kernel32\").getFunction(\"CreateDispatch\");\n        Pointer pointer = function.invokePointer(new Object[0]);\n        return new Dispatch(pointer);\n    }\n\n    private static String fakeKernel32Source() {\n        return \"\"\"\n            #include <stdint.h>\n            #include <stdlib.h>\n\n            typedef struct FakeDispatch {\n                void **vtable;\n                int refs;\n            } FakeDispatch;\n\n            int GetUserDefaultLCID(void) {\n                return 1033;\n            }\n\n            int QueryInterface(void *self, void *riid, void **ppvObject) {\n                *ppvObject = self;\n                return 0;\n            }\n\n            int AddRef(void *self) {\n                FakeDispatch *dispatch = (FakeDispatch *) self;\n                return ++dispatch->refs;\n            }\n\n            int Release(void *self) {\n                FakeDispatch *dispatch = (FakeDispatch *) self;\n                if (dispatch->refs > 0) {\n                    dispatch->refs--;\n                }\n                return dispatch->refs;\n            }\n\n            int NotImplemented(void) {\n                return (int) 0x80004001;\n            }\n\n            void *CreateDispatch(void) {\n                static void *vtable[] = {\n                    QueryInterface,\n                    AddRef,\n                    Release,\n                    NotImplemented,\n                    NotImplemented,\n                    NotImplemented,\n                    NotImplemented\n                };\n                FakeDispatch *dispatch = (FakeDispatch *) calloc(1, sizeof(FakeDispatch));\n                dispatch->vtable = vtable;\n                return dispatch;\n            }\n            \"\"\";\n    }\n\n    private static void disableComInitializationAssertions() {\n"},{"oldText":"\n    private static final class InMemoryDispatch implements IDispatchCallback {\n        private final DispatchListener dispatchListener;\n        private int addRefCalls;\n        private int queryInterfaceCalls;\n        private int releaseCalls;\n\n        private InMemoryDispatch() {\n            this.dispatchListener = new DispatchListener(this);\n        }\n\n        @Override\n        public Pointer getPointer() {\n            return dispatchListener.getPointer();\n        }\n\n        @Override\n        public HRESULT QueryInterface(REFIID riid, PointerByReference ppvObject) {\n            queryInterfaceCalls++;\n            ppvObject.setValue(getPointer());\n            return WinError.S_OK;\n        }\n\n        @Override\n        public int AddRef() {\n            addRefCalls++;\n            return addRefCalls - releaseCalls;\n        }\n\n        @Override\n        public int Release() {\n            releaseCalls++;\n            return addRefCalls - releaseCalls;\n        }\n\n        @Override\n        public HRESULT GetTypeInfoCount(UINTByReference pctinfo) {\n            return new HRESULT(WinError.E_NOTIMPL);\n        }\n\n        @Override\n        public HRESULT GetTypeInfo(UINT iTInfo, LCID lcid, PointerByReference ppTInfo) {\n            return new HRESULT(WinError.E_NOTIMPL);\n        }\n\n        @Override\n        public HRESULT GetIDsOfNames(REFIID riid, WString[] rgszNames, int cNames, LCID lcid,\n                DISPIDByReference rgDispId) {\n            return new HRESULT(WinError.E_NOTIMPL);\n        }\n\n        @Override\n        public HRESULT Invoke(DISPID dispIdMember, REFIID riid, LCID lcid, WORD wFlags,\n                DISPPARAMS.ByReference pDispParams, VARIANT.ByReference pVarResult,\n                EXCEPINFO.ByReference pExcepInfo, IntByReference puArgErr) {\n            return WinError.S_OK;\n        }\n    }\n","newText":""}]}
