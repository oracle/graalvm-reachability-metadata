a.lang.reflect.Proxy;\nimport org.junit.jupiter.api.Test;\nimport sun.misc.Unsafe;\n\npublic class ObjectFactoryTest {\n\n    @Test\n    void createProxyReturnsDynamicProxyForDispatchCallback() throws Throwable {\n        disableComInitializationAssertions();\n        TestObjectFactory factory = allocateTestObjectFactory();\n        InMemoryDispatch dispatch = new InMemoryDispatch();\n\n        SampleComInterface proxy = factory.createProxy(SampleComInterface.class, dispatch);\n\n        assertNotNull(proxy);\n        assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();\n        assertThat(SampleComInterface.class.isInstance(proxy)).isTrue();\n        assertThat(dispatch.addRefCalls).isEqualTo(1);\n        assertThat(dispatch.queryInterfaceCalls).isEqualTo(1);\n        assertThat(dispatch.releaseCalls).isEqualTo(1);\n    }\n\n    private static void disableComInitializationAssertions() {\n        ClassLoader classLoader = ObjectFactoryTest.class.getClassLoader();\n        classLoader.setClassAssertionStatus(\"com.sun.jna.platform.win32.COM.util.ObjectFactory\", false);\n        classLoader.setClassAssertionStatus(\"com.sun.jna.platform.win32.COM.util.ProxyObject\", false);\n    }\n\n    private static TestObjectFactory allocateTestObjectFactory() throws Throwable {\n        return (TestObjectFactory) unsafe().allocateInstance(TestObjectFactory.class);\n    }\n\n    private static Unsafe unsafe() throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Unsafe.class, MethodHandles.lookup());\n        VarHandle varHandle = lookup.findStaticVarHandle(Unsafe.class, \"theUnsafe\", Unsafe.class);\n        return (Unsafe) varHandle.get();\n    }\n\n    @ComInterface(iid = \"00000000-0000-0000-C000-000000000046\")\n    public interface SampleComInterface {\n    }\n\n    private static final class TestObjectFactory extends ObjectFactory {\n        @Override\n        public void register(ProxyObject proxyObject) {\n        }\n\n        @Ove