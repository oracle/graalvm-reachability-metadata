eption, suppressed);\n\n        assertThat(exception.getHR().intValue()).isEqualTo(W32Errors.HRESULT_FROM_WIN32(W32Errors.ERROR_ACCESS_DENIED));\n        assertThat(exception).hasMessage(\"Access denied\");\n        assertThat(exception.getSuppressed()).containsExactly(suppressed);\n    }\n\n    private static final class TestWin32Exception extends Win32Exception {\n        private static final long serialVersionUID = 1L;\n\n        private TestWin32Exception(int code) {\n            super(code, new HRESULT(W32Errors.HRESULT_FROM_WIN32(code)), \"Access denied\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 376, "output": 1473, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 35129, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777525790630, "responseId": "resp_07841e8510e7ab580169f2e41f1d30819d99956eb55cd2eafd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pyTstnfu9Fem1uLahJ6dHTzS|fc_07841e8510e7ab580169f2e42eaed8819d8471b280b91a9c70", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1868 bytes to tests/src/net.java.dev.jna/jna-platform/5.8.0/src/test/java/net_java_dev_jna/jna_platform/Win32ExceptionTest.java"}], "isError": false, "timestamp": 1777525811065}]}
