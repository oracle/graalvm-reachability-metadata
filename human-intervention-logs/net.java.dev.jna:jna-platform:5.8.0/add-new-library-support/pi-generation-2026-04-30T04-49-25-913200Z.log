          VarHandle librariesHandle = lookup.findStaticVarHandle(NativeLibrary.class, "libraries", Map.class);
          Map<String, WeakReference<NativeLibrary>> libraries = (Map<String, WeakReference<NativeLibrary>>) librariesHandle.get();
          libraries.put("kernel32" + options, new WeakReference<>(fakeKernel32));
