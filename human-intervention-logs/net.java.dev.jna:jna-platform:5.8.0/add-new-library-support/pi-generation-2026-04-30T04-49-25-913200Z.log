src/net.java.dev.jna/jna-platform/5.8.0/src/test/java/net_java_dev_jna/jna_platform/FactoryTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_java_dev_jna.jna_platform;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.jna.Callback;\nimport com.sun.jna.CallbackReference;\nimport com.sun.jna.Memory;\nimport com.sun.jna.Native;\nimport com.sun.jna.Pointer;\nimport com.sun.jna.platform.win32.COM.Dispatch;\nimport com.sun.jna.platform.win32.COM.util.Factory;\nimport com.sun.jna.platform.win32.COM.util.ObjectFactory;\nimport com.sun.jna.platform.win32.COM.util.annotation.ComInterface;\nimport com.sun.jna.platform.win32.Guid.REFIID;\nimport com.sun.jna.platform.win32.WinNT.HRESULT;\nimport com.sun.jna.platform.win32.WinNT;\nimport com.sun.jna.ptr.PointerByReference;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.VarHandle;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Proxy;\nimport java.util.LinkedList;\nimport org.junit.jupiter.api.Test;\nimport sun.misc.Unsafe;\nimport sun.reflect.ReflectionFactory;\n\npublic class FactoryTest {\n\n    @Test\n    void createProxyWrapsObjectFactoryProxyWithFactoryProxy() throws Exception {\n        Factory factory = uninitializedFactory();\n        FakeDispatch dispatch = new FakeDispatch();\n\n        SampleComInterface proxy = factory.createProxy(SampleComInterface.class, dispatch);\n\n        assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();\n        assertThat(proxy).isInstanceOf(SampleComInterface.class);\n        factory.disposeAll();\n        assertThat(dispatch.referenceCount).isZero();\n    }\n\n    private static Factory uninitializedFactory() throws Exception {\n        Constructor<Object> objectConstructor = Object.class.getDeclaredConstructor();\n        Constructor<?> factoryConstructor = ReflectionFactory.getReflectionFactory()\n            .newConstructorForSerialization(Factory.class, objectConstructor);\n        factoryConstructor.setAccessible(true);\n        Factory factory = (Factory) factoryConstructor.newInstance();\n        setField(factory, ObjectFactory.class, \"registeredObjects\", new LinkedList<>());\n        return factory;\n    }\n\n    private static void setField(Object target, Class<?> owner, String fieldName, Object value) throws Exception {\n        long fieldOffset = unsafe().objectFieldOffset(owner.getDeclaredField(fieldName));\n        unsafe().putObject(target, fieldOffset, value);\n    }\n\n    private static Unsafe unsafe() throws Exception {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Unsafe.class, MethodHandles.lookup());\n        VarHandle varHandle = lookup.findStaticVarHandle(Unsafe.class, \"theUnsafe\", Unsafe.class);\n        return (Unsafe) varHandle.get();\n    }\n\n    @ComInterface(iid = \"00000000-0000-0000-C000-000000000046\")\n    public interface SampleComInterface {\n    }\n\n    private static final class FakeDispatch extends Dispatch {\n\n        private final FakeComPointer queriedUnknown = new FakeComPointer();\n        private int referenceCount;\n\n        @Override\n        public int AddRef() {\n            referenceCount++;\n            return referenceCount;\n        }\n\n        @Override\n        public HRESULT QueryInterface(REFIID riid, PointerByReference ppvObject) {\n            ppvObject.setValue(queriedUnknown.pointer());\n            return WinNT.S_OK;\n        }\n\n        @Override\n        public int Release() {\n            referenceCount--;\n            return referenceCount;\n        }\n    }\n\n    private static final class FakeComPointer {\n\n        private final Memory object = new Memory(Native.POINTER_SIZE);\n        private final Memory vtable = new Memory(3L * Native.POINTER_SIZE);\n        private final ReleaseCallback releaseCallback = new ReleaseCallback() {\n            @Override\n            public int invoke(Pointer thisPointer) {\n                return 0;\n            }\n        };\n\n        private FakeComPointer() {\n            object.setPointer(0, vtable);\n            vtable.setPointer(2L * Native.POINTER_SIZE, CallbackReference.getFunctionPointer(releaseCallback));\n        }\n\n        private Pointer pointer() {\n            return object;\n        }\n    }\n\n    private interface ReleaseCallback extends Callback {\n        int invoke(Pointer thisPointer);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 447, "output": 2931, "cacheRead": 39424, "cacheWrite": 0, "totalTokens": 42802, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777524492441, "responseId": "resp_03e32479f4cf55c10169f2df0ceba081a2892e4dfa6d5be10a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tRg7qh0JjPLgcOzXaCmUmn1f|fc_03e32479f4cf55c10169f2df24954881a2b7629e3ee448fd9e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4336 bytes to tests/src/net.java.dev.jna/jna-platform/5.8.0/src/test/java/net_java_dev_jna/jna_platform/FactoryTest.java"}], "isError": false, "timestamp": 1777524522467}]}
