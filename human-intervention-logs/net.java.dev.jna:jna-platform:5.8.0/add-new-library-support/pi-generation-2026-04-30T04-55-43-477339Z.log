  package net_java_dev_jna.jna_platform;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.jna.platform.win32.COM.util.ComThread;
  import com.sun.jna.platform.win32.COM.util.Factory;
  import java.lang.Thread.UncaughtExceptionHandler;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Proxy;
  import java.util.concurrent.Callable;
  import java.util.concurrent.ExecutionException;
  import java.util.concurrent.TimeoutException;
  import org.junit.jupiter.api.Test;
  
  public class FactoryInnerProxyObject2Anonymous1Test {
  
      @Test
      void invokesDelegateMethodThroughFactoryProxyObject2Callable() throws Throwable {
          Factory factory = new Factory(new InlineComThread());
          RecordingComInterface delegate = new RecordingComInterface();
          SampleComInterface proxy = createFactoryProxy(factory, delegate);
  
          String result = proxy.describe("native-image");
  
          assertThat(result).isEqualTo("handled native-image");
          assertThat(delegate.lastValue).isEqualTo("native-image");
          assertThat(delegate.invocationCount).isEqualTo(1);
      }
  
      private static SampleComInterface createFactoryProxy(Factory factory, SampleComInterface delegate)
              throws Throwable {
          Class<?> proxyObjectClass = Class.forName("com.sun.jna.platform.win32.COM.util.Factory$ProxyObject2");
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(proxyObjectClass, MethodHandles.lookup());
          MethodType constructorType = MethodType.methodType(void.class, Factory.class, Object.class);
          MethodHandle constructor = lookup.findConstructor(proxyObjectClass, constructorType);
          InvocationHandler handler = (InvocationHandler) constructor.invoke(factory, delegate);
          return (SampleComInterface) Proxy.newProxyInstance(
              SampleComInterface.class.getClassLoader(),
              new Class<?>[] { SampleComInterface.class },
              handler
          );
      }
  
      public interface SampleComInterface {
  
          String describe(String value);
  
      }
  
      public static class RecordingComInterface implements SampleComInterface {
  
          private String lastValue;
          private int invocationCount;
  
          @Override
          public String describe(String value) {
              this.lastValue = value;
              this.invocationCount++;
              return "handled " + value;
          }
      }
  
      public static class InlineComThread extends ComThread {
  
          InlineComThread() {
              super("inline COM test thread", 1000, new RethrowingUncaughtExceptionHandler());
          }
  
          @Override
          public <T> T execute(Callable<T> task) throws TimeoutException, InterruptedException, ExecutionException {
              try {
                  return task.call();
              } catch (Exception exception) {
                  throw new ExecutionException(exception);
              }
          }
      }
  
      private static class RethrowingUncaughtExceptionHandler implements UncaughtExceptionHandler {
  
          @Override
          public void uncaughtException(Thread thread, Throwable exception) {
              throw new AssertionError("Unexpected COM thread initialization failure", exception);
          }
      }
  
  }
