TON_ID, \"stored value\");\n        assertThat(singleton.isSet(SINGLETON_ID)).isTrue();\n        assertThat(singleton.get(SINGLETON_ID)).isEqualTo(\"stored value\");\n        assertThat(singleton.isSet(OTHER_SINGLETON_ID)).isFalse();\n\n        singleton.set(OTHER_SINGLETON_ID, \"other stored value\");\n        assertThat(singleton.get(OTHER_SINGLETON_ID)).isEqualTo(\"other stored value\");\n        assertThat(singleton.get(SINGLETON_ID)).isEqualTo(\"stored value\");\n\n        singleton.clear(SINGLETON_ID);\n        assertThat(singleton.isSet(SINGLETON_ID)).isFalse();\n        assertThat(singleton.isSet(OTHER_SINGLETON_ID)).isTrue();\n    }"}]}
