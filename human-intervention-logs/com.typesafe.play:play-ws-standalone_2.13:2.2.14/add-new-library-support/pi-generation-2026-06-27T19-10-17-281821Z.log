        server.stop(0)
        executor.shutdownNow()
        executor.awaitTermination(10, TimeUnit.SECONDS)
      }
    }
  
    private object TestHttpServer {
      @throws[IOException]
      def apply(handler: HttpExchange => Unit): TestHttpServer = new TestHttpServer(handler)
    }
  }
