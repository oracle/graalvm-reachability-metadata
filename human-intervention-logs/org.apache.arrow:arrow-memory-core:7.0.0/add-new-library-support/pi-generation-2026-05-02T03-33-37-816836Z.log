        Enumeration<URL> paths;
        if (allocatorClassLoader == null) {
          paths = ClassLoader.getSystemResources(ALLOCATOR_PATH);
        } else {
          paths = allocatorClassLoader.getResources(ALLOCATOR_PATH);
