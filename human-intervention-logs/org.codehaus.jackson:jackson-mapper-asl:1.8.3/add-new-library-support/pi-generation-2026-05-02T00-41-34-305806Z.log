[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/ObjectBufferTest.java","edits":[{"oldText":"import org.codehaus.jackson.map.util.ObjectBuffer;\nimport org.junit.jupiter.api.Test;\n","newText":"import java.util.ArrayList;\nimport java.util.List;\n\nimport org.codehaus.jackson.map.util.ObjectBuffer;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"        Object[] firstChunk = buffer.resetAndStart();\n        for (int i = 0; i < firstChunk.length; i++) {\n            firstChunk[i] = \"chunk-\" + i;\n        }\n\n        Object[] lastChunk = buffer.appendCompletedChunk(firstChunk);\n        lastChunk[0] = \"tail-0\";\n        lastChunk[1] = \"tail-1\";\n\n        String[] result = buffer.completeAndClearBuffer(lastChunk, 2, String.class);\n\n        assertThat(result)\n                .isInstanceOf(String[].class)\n                .containsExactly(\n                        \"chunk-0\",\n                        \"chunk-1\",\n                        \"chunk-2\",\n                        \"chunk-3\",\n                        \"chunk-4\",\n                        \"chunk-5\",\n                        \"chunk-6\",\n                        \"chunk-7\",\n                        \"chunk-8\",\n                        \"chunk-9\",\n                        \"chunk-10\",\n                        \"chunk-11\",\n                        \"tail-0\",\n                        \"tail-1\");\n","newText":"        Object[] firstChunk = buffer.resetAndStart();\n        List<String> expectedValues = new ArrayList<>();\n        for (int i = 0; i < firstChunk.length; i++) {\n            String value = \"chunk-\" + i;\n            firstChunk[i] = value;\n            expectedValues.add(value);\n        }\n\n        Object[] lastChunk = buffer.appendCompletedChunk(firstChunk);\n        lastChunk[0] = \"tail-0\";\n        lastChunk[1] = \"tail-1\";\n        expectedValues.add(\"tail-0\");\n        expectedValues.add(\"tail-1\");\n\n        String[] result = buffer.completeAndClearBuffer(lastChunk, 2, String.class);\n\n        assertThat(result)\n                .isInstanceOf(String[].class)\n                .containsExactly(expectedValues.toArray(new String[0]));\n"}]}
