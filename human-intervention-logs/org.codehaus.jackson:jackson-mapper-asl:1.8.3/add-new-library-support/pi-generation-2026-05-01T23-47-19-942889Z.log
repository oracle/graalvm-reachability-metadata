  package org_codehaus_jackson.jackson_mapper_asl;
  
  import java.util.ArrayList;
  import java.util.Collections;
  
  import org.codehaus.jackson.map.DeserializationConfig;
  import org.codehaus.jackson.map.ObjectMapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CollectionDeserializerTest {
      @Test
      void concreteCollectionIsCreatedWithDefaultConstructorForJsonArray() throws Exception {
          ObjectMapper mapper = new ObjectMapper();
  
          DefaultConstructedCollection result = mapper.readValue("[1,{\"nested\":true},null]",
                  DefaultConstructedCollection.class);
  
          assertThat(result.constructionMarker()).isEqualTo("default-constructor");
          assertThat(result).containsExactly(Integer.valueOf(1), Collections.singletonMap("nested", Boolean.TRUE), null);
      }
  
      @Test
      void concreteCollectionIsCreatedBeforeCoercingSingleValueToArray() throws Exception {
          ObjectMapper mapper = new ObjectMapper();
          mapper.configure(DeserializationConfig.Feature.ACCEPT_SINGLE_VALUE_AS_ARRAY, true);
  
          DefaultConstructedCollection result = mapper.readValue("{\"nested\":true}", DefaultConstructedCollection.class);
  
          assertThat(result.constructionMarker()).isEqualTo("default-constructor");
          assertThat(result).containsExactly(Collections.singletonMap("nested", Boolean.TRUE));
      }
  
      public static final class DefaultConstructedCollection extends ArrayList<Object> {
          private static final long serialVersionUID = 1L;
  
          private final String constructionMarker;
  
          public DefaultConstructedCollection() {
              constructionMarker = "default-constructor";
          }
  
          String constructionMarker() {
              return constructionMarker;
          }
      }
  }
