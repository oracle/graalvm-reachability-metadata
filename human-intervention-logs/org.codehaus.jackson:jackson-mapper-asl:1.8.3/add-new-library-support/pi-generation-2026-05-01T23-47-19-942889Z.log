[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/CollectionDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport java.util.Collections;\nimport java.util.LinkedList;\n\nimport org.codehaus.jackson.map.DeserializationConfig;\nimport org.codehaus.jackson.map.ObjectMapper;\nimport org.codehaus.jackson.type.TypeReference;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CollectionDeserializerTest {\n    @Test\n    void concreteCollectionIsCreatedWithDefaultConstructorForJsonArray() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        LinkedList<Object> result = mapper.readValue(\"[1,{\\\"nested\\\":true},null]\",\n                new TypeReference<LinkedList<Object>>() {\n                });\n\n        assertThat(result)\n                .isInstanceOf(LinkedList.class)\n                .containsExactly(Integer.valueOf(1), Collections.singletonMap(\"nested\", Boolean.TRUE), null);\n    }\n\n    @Test\n    void concreteCollectionIsCreatedBeforeCoercingSingleValueToArray() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n        mapper.configure(DeserializationConfig.Feature.ACCEPT_SINGLE_VALUE_AS_ARRAY, true);\n\n        LinkedList<Object> result = mapper.readValue(\"{\\\"nested\\\":true}\",\n                new TypeReference<LinkedList<Object>>() {\n                });\n\n        assertThat(result)\n                .isInstanceOf(LinkedList.class)\n                .containsExactly(Collections.singletonMap(\"nested\", Boolean.TRUE));\n    }\n}\n"}
