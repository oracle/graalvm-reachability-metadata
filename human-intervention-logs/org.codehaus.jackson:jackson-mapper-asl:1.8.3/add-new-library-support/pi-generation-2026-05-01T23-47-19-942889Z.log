per method**\\n\\nI’m looking at creating a helper method: `private static LinkedList<?> readLinkedList(ObjectMapper mapper, String json) throws Exception`. This method uses `mapper.readValue(json, LinkedList.class)` to return the result while asserting that it is indeed an instance of LinkedList. However, I’m realizing that this helper could specify the type directly, which might not be necessary for each test. Using a raw Class here keeps things simple since the content type is an Object. It seems like a solid approach!\"}]}"}, {"type": "toolCall", "id": "call_oqQSVGggamNn2nBwEOgAbRfc|fc_08a7df8d09d2a3ee0169f53b7df73c8191ac72985da17e29c6", "name": "write", "arguments": {"path": "tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/CollectionDeserializerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport java.util.Collections;\nimport java.util.LinkedList;\n\nimport org.codehaus.jackson.map.DeserializationConfig;\nimport org.codehaus.jackson.map.ObjectMapper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CollectionDeserializerTest {\n    @Test\n    void concreteCollectionIsCreatedWithDefaultConstructorForJsonArray() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        Object result = mapper.readValue(\"[1,{\\\"nested\\\":true},null]\", LinkedList.class);\n\n        assertThat(result).isInstanceOf(LinkedList.class);\n        assertThat((LinkedList<?>) result)\n                .containsExactly(Integer.valueOf(1), Collections.singletonMap(\"nested\", Boolean.TRUE), null);\n    }\n\n    @Test\n    void concreteCollectionIsCreatedBeforeCoercingSingleValueToArray() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n        mapper.configure(DeserializationConfig.Feature.ACCEPT_SINGLE_VALUE_AS_ARRAY, true);\n\n        Object result = mapper.readValue(\"{\\\"nested\\\":true}\", LinkedList.class);\n\n        assertThat(result).isInstanceOf(LinkedList.class);\n        assertThat((LinkedList<?>) result)\n                .containsExactly(Collections.singletonMap(\"nested\", Boolean.TRUE));\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/CollectionDeserializerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_codehaus_jackson.jackson_mapper_asl;\\n\\nimport java.util.Collections;\\nimport java.util.LinkedList;\\n\\nimport org.codehaus.jackson.map.DeserializationConfig;\\nimport org.codehaus.jackson.map.ObjectMapper;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class CollectionDeserializerTest {\\n    @Test\\n    void concreteCollectionIsCreatedWithDefaultConstructorForJsonArray() throws Exception {\\n        ObjectMapper mapper = new ObjectMapper();\\n\\n        Object result = mapper.readValue(\\\"[1,{\\\\\\\"nested\\\\\\\":true},null]\\\", LinkedList.class);\\n\\n        assertThat(result).isInstanceOf(LinkedList.class);\\n        assertThat((LinkedList<?>) result)\\n                .containsExactly(Integer.valueOf(1), Collections.singletonMap(\\\"nested\\\", Boolean.TRUE), null);\\n    }\\n\\n    @Test\\n    void concreteCollectionIsCreatedBeforeCoercingSingleValueToArray() throws Exception {\\n        ObjectMapper mapper = new ObjectMapper();\\n        mapper.configure(DeserializationConfig.Feature.ACCEPT_SINGLE_VALUE_AS_ARRAY, true);\\n\\n        Object result = m