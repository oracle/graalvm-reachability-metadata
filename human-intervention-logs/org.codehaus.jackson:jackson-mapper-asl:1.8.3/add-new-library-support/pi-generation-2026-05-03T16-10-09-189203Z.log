          if (_internalSettings != null) {
              removed = _internalSettings.remove(key);
              // to reduce memory usage, let's also drop the Map itself, if empty
              if (_internalSettings.size() == 0) {
                  _internalSettings = null;
              }
          }
          return removed;
      }
      
