[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/JsonValueSerializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport org.codehaus.jackson.annotate.JsonValue;\nimport org.codehaus.jackson.map.ObjectMapper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JsonValueSerializerTest {\n    @Test\n    void serializesJsonValueAccessorAsScalar() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        String json = mapper.writeValueAsString(new JsonValueBacked(\"scalar-value\"));\n\n        assertThat(json).isEqualTo(\"\\\"scalar-value\\\"\");\n    }\n\n    @Test\n    void serializesJsonValueAccessorWithTypeInformation() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n        mapper.enableDefaultTyping(ObjectMapper.DefaultTyping.NON_FINAL);\n\n        String json = mapper.writeValueAsString(new JsonValueBacked(\"typed-value\"));\n\n        assertThat(json).contains(JsonValueBacked.class.getName(), \"typed-value\");\n    }\n\n    public static class JsonValueBacked {\n        private final String value;\n\n        public JsonValueBacked(String value) {\n            this.value = value;\n        }\n\n        @JsonValue\n        public String toJsonValue() {\n            return value;\n        }\n    }\n}\n"}
