haus.jackson.map.util.ArrayBuilders;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ArrayBuildersTest {\n    @Test\n    void insertInListPrependsElementToNewArray() {\n        String[] existingValues = new String[] {\"second\", \"third\"};\n\n        String[] result = ArrayBuilders.insertInList(existingValues, \"first\");\n\n        assertThat(result)\n                .isNotSameAs(existingValues)\n                .containsExactly(\"first\", \"second\", \"third\");\n        assertThat(result.getClass().getComponentType()).isEqualTo(String.class);\n        assertThat(existingValues).containsExactly(\"second\", \"third\");\n    }\n\n    @Test\n    void insertInListNoDupReturnsOriginalWhenElementIsAlreadyFirst() {\n        String firstValue = \"first\";\n        String[] existingValues = new String[] {firstValue, \"second\"};\n\n        String[] result = ArrayBuilders.insertInListNoDup(existingValues, firstValue);\n\n        assertThat(result).isSameAs(existingValues);\n    }\n\n    @Test\n    void insertInListNoDupMovesExistingElementFromLaterPosition() {\n        String promotedValue = \"promoted\";\n        String[] existingValues = new String[] {\"first\", promotedValue, \"third\"};\n\n        String[] result = ArrayBuilders.insertInListNoDup(existingValues, promotedValue);\n\n        assertThat(result)\n                .isNotSameAs(existingValues)\n                .hasSize(existingValues.length);\n        assertThat(result.getClass().getComponentType()).isEqualTo(String.class);\n        assertThat(existingValues[0]).isSameAs(promotedValue);\n    }\n\n    @Test\n    void insertInListNoDupPrependsElementWhenNoDuplicateExists() {\n        String[] existingValues = new String[] {\"second\", \"third\"};\n\n        String[] result = ArrayBuilders.insertInListNoDup(existingValues, \"first\");\n\n        assertThat(result)\n                .isNotSameAs(existingValues)\n                .containsExactly(\"first\", \"second\", \"third\");\n        assertThat(result.getClass().getComponentType()).isEqualTo(String.class);\n        assertThat(existingValues).containsExactly(\"second\", \"third\");\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/ArrayBuildersTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_codehaus_jackson.jackson_mapper_asl;\\n\\nimport org.codehaus.jackson.map.util.ArrayBuilders;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ArrayBuildersTest {\\n    @Test\\n    void insertInListPrependsElementToNewArray() {\\n        String[] existingValues = new String[] {\\\"second\\\", \\\"third\\\"};\\n\\n        String[] result = ArrayBuilders.insertInList(existingValues, \\\"first\\\");\\n\\n        assertThat(result)\\n                .isNotSameAs(existingValues)\\n                .containsExactly(\\\"first\\\", \\\"second\\\", \\\"third\\\");\\n        assertThat(result.getClass().getComponentType()).isEqualTo(String.class);\\n        assertThat(existingValues).containsExactly(\\\"second\\\", \\\"third\\\");\\n    }\\n\\n    @Test\\n    void insertInListNoDupReturnsOriginalWhenElementIsAlreadyFirst() {\\n        String firstValue = \\\"first\\\";\\n        String[] existingValues = new String[] {firstValue, \\\"second\\\"};\\n\\n        String[] result = ArrayBuilders.insertInListNoDup(existingValues, firstValue);\\n\\n        assertThat(result).isSameAs(existingValues);\\n    }\\n\\n    @Test\\n    void insertInListNoDupMovesExistingElementFromLaterPosition() {\\n        String promotedValue = \\\"promoted\\\";\\n        String[] existingValues = new String[] {\\\"first\\\", promotedValue, 