          // related to [JACKSON-569], need contextualization:
          if (deser instanceof ContextualDeserializer<?>) {
              deser = (JsonDeserializer<Object>)((ContextualDeserializer<?>) deser).createContextual(config, property);
          }
          return deser;
      }
  
