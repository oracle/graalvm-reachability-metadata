               * methods
               */
              for (Method m : _class.getDeclaredMethods()) {
                  if (!Modifier.isStatic(m.getModifiers())) {
                      continue;
                  }
                  int argCount = m.getParameterTypes().length;
                  // factory methods take at least one arg:
                  if (argCount < 1) {
                      continue;
                  }
