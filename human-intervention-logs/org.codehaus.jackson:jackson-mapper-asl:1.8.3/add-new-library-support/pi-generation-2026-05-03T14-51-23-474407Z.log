  package org_codehaus_jackson.jackson_mapper_asl;
  
  import org.codehaus.jackson.annotate.JsonCreator;
  import org.codehaus.jackson.annotate.JsonIgnore;
  import org.codehaus.jackson.annotate.JsonProperty;
  import org.codehaus.jackson.map.AnnotationIntrospector;
  import org.codehaus.jackson.map.ClassIntrospector.MixInResolver;
  import org.codehaus.jackson.map.introspect.AnnotatedClass;
  import org.codehaus.jackson.map.introspect.AnnotatedConstructor;
  import org.codehaus.jackson.map.introspect.AnnotatedField;
  import org.codehaus.jackson.map.introspect.AnnotatedMethod;
  import org.codehaus.jackson.map.introspect.JacksonAnnotationIntrospector;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnnotatedClassTest {
      @Test
      void resolvesCreatorsMemberMethodsAndFieldsWithMixIns() {
          AnnotationIntrospector annotationIntrospector = new JacksonAnnotationIntrospector();
          AnnotatedClass annotatedClass = AnnotatedClass.construct(
                  TargetModel.class,
                  annotationIntrospector,
                  new TestMixInResolver());
  
          annotatedClass.resolveCreators(true);
          annotatedClass.resolveMemberMethods(null, true);
          annotatedClass.resolveFields(true);
  
          assertThat(annotatedClass.getDefaultConstructor().getAnnotation(JsonCreator.class)).isNotNull();
          assertThat(annotatedClass.getConstructors()).hasSize(1);
          AnnotatedConstructor constructor = annotatedClass.getConstructors().get(0);
          assertThat(constructor.getAnnotation(JsonCreator.class)).isNotNull();
          assertThat(constructor.getParameterAnnotations(0).get(JsonProperty.class).value()).isEqualTo("value");
  
          AnnotatedMethod factoryMethod = findMethod(annotatedClass.getStaticMethods(), "fromString");
          assertThat(factoryMethod).isNotNull();
          assertThat(factoryMethod.getAnnotation(JsonCreator.class)).isNotNull();
          assertThat(factoryMethod.getParameterAnnotations(0).get(JsonProperty.class).value()).isEqualTo("value");
  
          AnnotatedMethod getter = annotatedClass.findMethod("getName", new Class<?>[0]);
          assertThat(getter).isNotNull();
          assertThat(getter.getAnnotation(JsonProperty.class).value()).isEqualTo("mixedName");
          assertThat(annotatedClass.findMethod("hashCode", new Class<?>[0])).isNotNull();
          assertThat(findMethod(annotatedClass.ignoredMemberMethods(), "ignoredMethod")).isNotNull();
  
          AnnotatedField mixedField = findField(annotatedClass.fields(), "mixedField");
          assertThat(mixedField).isNotNull();
          assertThat(mixedField.getAnnotation(JsonProperty.class).value()).isEqualTo("mixedField");
          assertThat(findField(annotatedClass.fields(), "baseField")).isNotNull();
          assertThat(findField(annotatedClass.ignoredFields(), "ignoredField")).isNotNull();
      }
  
      private static AnnotatedMethod findMethod(Iterable<AnnotatedMethod> methods, String name) {
          for (AnnotatedMethod method : methods) {
              if (name.equals(method.getName())) {
                  return method;
              }
          }
          return null;
      }
  
      private static AnnotatedField findField(Iterable<AnnotatedField> fields, String name) {
          for (AnnotatedField field : fields) {
              if (name.equals(field.getName())) {
                  return field;
              }
          }
          return null;
      }
  
      private static final class TestMixInResolver implements MixInResolver {
          @Override
          public Class<?> findMixInClassFor(Class<?> cls) {
              if (cls == TargetModel.class) {
                  return TargetModelMixIn.class;
              }
              if (cls == BaseModel.class) {
                  return BaseModelMixIn.class;
              }
              if (cls == Object.class) {
                  return ObjectMethodMixIn.class;
              }
              return null;
          }
      }
  
      private static class BaseModel {
          public String baseField;
  
          public String baseAccessor() {
              return baseField;
          }
      }
  
      private static final class TargetModel extends BaseModel {
          public String mixedField;
  
          @JsonIgnore
          public String ignoredField;
  
          TargetModel() {
              this("default");
          }
  
          TargetModel(String mixedField) {
              this.mixedField = mixedField;
          }
  
          public static TargetModel fromString(String value) {
              return new TargetModel(value);
          }
  
          public String getName() {
              return mixedField;
          }
  
          @JsonIgnore
          public String ignoredMethod() {
              return ignoredField;
          }
      }
  
      private static class BaseModelMixIn {
          @JsonProperty("baseField")
          public String baseField;
  
          @JsonProperty("baseAccessor")
          public String baseAccessor() {
              return null;
          }
      }
  
      private static class TargetModelMixIn {
          @JsonProperty("mixedField")
          public String mixedField;
  
          @JsonCreator
          TargetModelMixIn() {
          }
  
          @JsonCreator
          TargetModelMixIn(@JsonProperty("value") String value) {
          }
  
          @JsonCreator
          public static TargetModel fromString(@JsonProperty("value") String value) {
              return null;
          }
  
          @JsonProperty("mixedName")
          public String getName() {
              return null;
          }
      }
  
      private static class ObjectMethodMixIn {
          @Override
          @JsonProperty("objectHash")
          public int hashCode() {
              return 37;
          }
