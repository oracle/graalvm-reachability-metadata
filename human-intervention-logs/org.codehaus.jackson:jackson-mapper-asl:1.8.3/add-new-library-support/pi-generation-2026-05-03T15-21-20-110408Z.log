                      return _ctor.newInstance(value);
                  }
                  // static method, 'obj' can be null
  		return _factoryMethod.invoke(null, value);
              } catch (Exception e) {
                  ClassUtil.unwrapAndThrowAsIAE(e);
  		return null;
              }
