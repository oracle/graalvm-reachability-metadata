  package org_codehaus_jackson.jackson_mapper_asl;
  
  import org.codehaus.jackson.annotate.JsonCreator;
  import org.codehaus.jackson.map.ObjectMapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CreatorInnerDelegatingTest {
      private final ObjectMapper objectMapper = new ObjectMapper();
  
      @Test
      void deserializesObjectUsingDelegatingConstructor() throws Exception {
          DelegatingConstructorValue value = objectMapper.readValue(
                  "{\"name\":\"constructor\",\"quantity\":3}", DelegatingConstructorValue.class);
  
          assertThat(value.payload.name).isEqualTo("constructor");
          assertThat(value.payload.quantity).isEqualTo(3);
      }
  
      @Test
      void deserializesObjectUsingDelegatingFactoryMethod() throws Exception {
          DelegatingFactoryValue value = objectMapper.readValue(
                  "{\"name\":\"factory\",\"quantity\":7}", DelegatingFactoryValue.class);
  
          assertThat(value.payload.name).isEqualTo("factory");
          assertThat(value.payload.quantity).isEqualTo(7);
      }
  
      public static final class DelegatingConstructorValue {
          final Payload payload;
  
          @JsonCreator
          public DelegatingConstructorValue(Payload payload) {
              this.payload = payload;
          }
      }
  
      public static final class DelegatingFactoryValue {
          final Payload payload;
  
          private DelegatingFactoryValue(Payload payload) {
              this.payload = payload;
          }
  
          @JsonCreator
          public static DelegatingFactoryValue fromJson(Payload payload) {
              return new DelegatingFactoryValue(payload);
          }
      }
  
      public static final class Payload {
          public String name;
          public int quantity;
      }
  }
