[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/CreatorInnerPropertyBasedTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport org.codehaus.jackson.annotate.JsonCreator;\nimport org.codehaus.jackson.annotate.JsonProperty;\nimport org.codehaus.jackson.map.ObjectMapper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CreatorInnerPropertyBasedTest {\n    private final ObjectMapper objectMapper = new ObjectMapper();\n\n    @Test\n    void deserializesObjectUsingPropertyBasedConstructor() throws Exception {\n        ConstructorBackedValue value = objectMapper.readValue(\n                \"{\\\"name\\\":\\\"constructor\\\",\\\"quantity\\\":3,\\\"description\\\":\\\"created by constructor\\\"}\",\n                ConstructorBackedValue.class);\n\n        assertThat(value.name).isEqualTo(\"constructor\");\n        assertThat(value.quantity).isEqualTo(3);\n        assertThat(value.description).isEqualTo(\"created by constructor\");\n    }\n\n    @Test\n    void deserializesObjectUsingPropertyBasedFactoryMethod() throws Exception {\n        FactoryBackedValue value = objectMapper.readValue(\n                \"{\\\"name\\\":\\\"factory\\\",\\\"quantity\\\":7,\\\"description\\\":\\\"created by factory\\\"}\",\n                FactoryBackedValue.class);\n\n        assertThat(value.name).isEqualTo(\"factory\");\n        assertThat(value.quantity).isEqualTo(7);\n        assertThat(value.description).isEqualTo(\"created by factory\");\n    }\n\n    public static final class ConstructorBackedValue {\n        final String name;\n        final int quantity;\n        public String description;\n\n        @JsonCreator\n        public ConstructorBackedValue(\n                @JsonProperty(\"name\") String name,\n                @JsonProperty(\"quantity\") int quantity) {\n            this.name = name;\n            this.quantity = quantity;\n        }\n    }\n\n    public static final class FactoryBackedValue {\n        final String name;\n        final int quantity;\n        public String description;\n\n        private FactoryBackedValue(String name, int quantity) {\n            this.name = name;\n            this.quantity = quantity;\n        }\n\n        @JsonCreator\n        public static FactoryBackedValue fromJson(\n                @JsonProperty(\"name\") String name,\n                @JsonProperty(\"quantity\") int quantity) {\n            return new FactoryBackedValue(name, quantity);\n        }\n    }\n}\n"}
