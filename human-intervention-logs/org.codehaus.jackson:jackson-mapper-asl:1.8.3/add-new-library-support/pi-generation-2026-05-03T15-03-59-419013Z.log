[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/ArrayBuildersTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport org.codehaus.jackson.map.util.ArrayBuilders;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ArrayBuildersTest {\n    @Test\n    void insertsElementAtHeadUsingOriginalArrayComponentType() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue second = new NamedValue(\"second\");\n\n        NamedValue[] result = ArrayBuilders.insertInList(new NamedValue[] { first, second }, new NamedValue(\"new\"));\n\n        assertThat(result).isInstanceOf(NamedValue[].class);\n        assertThat(result).extracting(NamedValue::name).containsExactly(\"new\", \"first\", \"second\");\n    }\n\n    @Test\n    void returnsOriginalArrayWhenDuplicateIsAlreadyAtHead() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue[] array = new NamedValue[] { first, new NamedValue(\"second\") };\n\n        NamedValue[] result = ArrayBuilders.insertInListNoDup(array, first);\n\n        assertThat(result).isSameAs(array);\n        assertThat(result).extracting(NamedValue::name).containsExactly(\"first\", \"second\");\n    }\n\n    @Test\n    void allocatesSameSizeArrayWhenDuplicateIsMovedFromLaterPosition() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue duplicate = new NamedValue(\"duplicate\");\n        NamedValue[] array = new NamedValue[] { first, duplicate, new NamedValue(\"third\") };\n\n        NamedValue[] result = ArrayBuilders.insertInListNoDup(array, duplicate);\n\n        assertThat(result).isNotSameAs(array);\n        assertThat(result).isInstanceOf(NamedValue[].class);\n        assertThat(result).hasSize(array.length);\n    }\n\n    @Test\n    void insertsMissingElementAtHeadWithoutDuplicatingExistingElements() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue second = new NamedValue(\"second\");\n        NamedValue[] array = new NamedValue[] { first, second };\n\n        NamedValue[] result = ArrayBuilders.insertInListNoDup(array, new NamedValue(\"new\"));\n\n        assertThat(result).isInstanceOf(NamedValue[].class);\n        assertThat(result).extracting(NamedValue::name).containsExactly(\"new\", \"first\", \"second\");\n        assertThat(array).containsExactly(first, second);\n    }\n\n    private static final class NamedValue {\n        private final String name;\n\n        private NamedValue(String name) {\n            this.name = name;\n        }\n\n        private String name() {\n            return name;\n        }\n    }\n}\n"}
