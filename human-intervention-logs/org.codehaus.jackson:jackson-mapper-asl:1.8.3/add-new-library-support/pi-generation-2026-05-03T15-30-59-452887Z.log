  package org_codehaus_jackson.jackson_mapper_asl;
  
  import org.codehaus.jackson.annotate.JsonCreator;
  import org.codehaus.jackson.map.ObjectMapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CreatorInnerStringBasedTest {
      private final ObjectMapper objectMapper = new ObjectMapper();
  
      @Test
      void deserializesStringUsingSingleArgumentConstructor() throws Exception {
          StringFromConstructor value = objectMapper.readValue("\"constructor value\"", StringFromConstructor.class);
  
          assertThat(value.value).isEqualTo("constructor value");
      }
  
      @Test
      void deserializesStringUsingStaticFactoryMethod() throws Exception {
          StringFromFactory value = objectMapper.readValue("\"factory value\"", StringFromFactory.class);
  
          assertThat(value.value).isEqualTo("factory value");
      }
  
      public static final class StringFromConstructor {
          final String value;
  
          @JsonCreator
          public StringFromConstructor(String value) {
              this.value = value;
          }
      }
  
      public static final class StringFromFactory {
          final String value;
  
          private StringFromFactory(String value) {
              this.value = value;
          }
  
          @JsonCreator
          public static StringFromFactory fromJson(String value) {
              return new StringFromFactory(value);
          }
      }
  }
