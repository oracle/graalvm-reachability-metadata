  package org_codehaus_jackson.jackson_mapper_asl;
  
  import org.codehaus.jackson.annotate.JsonCreator;
  import org.codehaus.jackson.map.ObjectMapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CreatorInnerNumberBasedTest {
      private final ObjectMapper objectMapper = new ObjectMapper();
  
      @Test
      void deserializesIntegerUsingSingleArgumentConstructor() throws Exception {
          NumberFromIntConstructor value = objectMapper.readValue("37", NumberFromIntConstructor.class);
  
          assertThat(value.value).isEqualTo(37);
      }
  
      @Test
      void deserializesIntegerUsingStaticFactoryMethod() throws Exception {
          NumberFromIntFactory value = objectMapper.readValue("41", NumberFromIntFactory.class);
  
          assertThat(value.value).isEqualTo(41);
      }
  
      @Test
      void deserializesLongUsingSingleArgumentConstructor() throws Exception {
          NumberFromLongConstructor value = objectMapper.readValue("4294967296", NumberFromLongConstructor.class);
  
          assertThat(value.value).isEqualTo(4_294_967_296L);
      }
  
      @Test
      void deserializesLongUsingStaticFactoryMethod() throws Exception {
          NumberFromLongFactory value = objectMapper.readValue("4294967297", NumberFromLongFactory.class);
  
          assertThat(value.value).isEqualTo(4_294_967_297L);
      }
  
      public static final class NumberFromIntConstructor {
          final int value;
  
          @JsonCreator
          public NumberFromIntConstructor(int value) {
              this.value = value;
          }
      }
  
      public static final class NumberFromIntFactory {
          int value;
  
          private NumberFromIntFactory() {
          }
  
          @JsonCreator
          public static NumberFromIntFactory fromJson(int value) {
              NumberFromIntFactory result = new NumberFromIntFactory();
              result.value = value;
              return result;
          }
      }
  
      public static final class NumberFromLongConstructor {
          final long value;
  
          @JsonCreator
          public NumberFromLongConstructor(long value) {
              this.value = value;
          }
      }
  
      public static final class NumberFromLongFactory {
          long value;
  
          private NumberFromLongFactory() {
          }
  
          @JsonCreator
          public static NumberFromLongFactory fromJson(long value) {
              NumberFromLongFactory result = new NumberFromLongFactory();
              result.value = value;
              return result;
          }
      }
  }
