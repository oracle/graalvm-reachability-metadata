  package org_codehaus_jackson.jackson_mapper_asl;
  
  import org.codehaus.jackson.annotate.JsonCreator;
  import org.codehaus.jackson.annotate.JsonProperty;
  import org.codehaus.jackson.map.ObjectMapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CreatorInnerPropertyBasedTest {
      private final ObjectMapper objectMapper = new ObjectMapper();
  
      @Test
      void deserializesObjectUsingPropertyBasedConstructor() throws Exception {
          ConstructorBackedValue value = objectMapper.readValue(
                  "{\"description\":\"created by constructor\",\"name\":\"constructor\",\"quantity\":3}",
                  ConstructorBackedValue.class);
  
          assertThat(value.name).isEqualTo("constructor");
          assertThat(value.quantity).isEqualTo(3);
          assertThat(value.description).isEqualTo("created by constructor");
      }
  
      @Test
      void deserializesObjectUsingPropertyBasedFactoryMethod() throws Exception {
          FactoryBackedValue value = objectMapper.readValue(
                  "{\"description\":\"created by factory\",\"name\":\"factory\",\"quantity\":7}",
                  FactoryBackedValue.class);
  
          assertThat(value.name).isEqualTo("factory");
          assertThat(value.quantity).isEqualTo(7);
          assertThat(value.description).isEqualTo("created by factory");
      }
  
      public static final class ConstructorBackedValue {
          final String name;
          final int quantity;
          public String description;
  
          @JsonCreator
          public ConstructorBackedValue(
                  @JsonProperty("name") String name,
                  @JsonProperty("quantity") int quantity) {
              this.name = name;
              this.quantity = quantity;
          }
      }
  
      public static final class FactoryBackedValue {
          final String name;
          final int quantity;
          public String description;
  
          private FactoryBackedValue(String name, int quantity) {
              this.name = name;
              this.quantity = quantity;
          }
  
          @JsonCreator
          public static FactoryBackedValue fromJson(
                  @JsonProperty("name") String name,
                  @JsonProperty("quantity") int quantity) {
              return new FactoryBackedValue(name, quantity);
          }
      }
  }
