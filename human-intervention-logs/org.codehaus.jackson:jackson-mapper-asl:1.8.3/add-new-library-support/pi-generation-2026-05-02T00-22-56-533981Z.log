          throws IOException, JsonProcessingException
      {
          JsonToken t;
          final JsonDeserializer<String> deser = _valueDeserializer;
  
          while ((t = jp.nextToken()) != JsonToken.END_ARRAY) {
              String value;
  
              if (t == JsonToken.VALUE_NULL) {
                  value = null;
              } else {
                  value = deser.deserialize(jp, ctxt);
              }
              result.add(value);
          }
          return result;
      }
      
