  package org_codehaus_jackson.jackson_mapper_asl;
  
  import org.codehaus.jackson.map.ObjectMapper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanPropertyWriterTest {
      @Test
      void serializesFieldBackedProperty() throws Exception {
          ObjectMapper mapper = new ObjectMapper();
  
          String json = mapper.writeValueAsString(new FieldBackedBean("field-value"));
  
          assertThat(json).isEqualTo("{\"visibleField\":\"field-value\"}");
      }
  
      @Test
      void serializesGetterBackedProperty() throws Exception {
          ObjectMapper mapper = new ObjectMapper();
  
          String json = mapper.writeValueAsString(new GetterBackedBean("getter-value"));
  
          assertThat(json).isEqualTo("{\"visibleGetter\":\"getter-value\"}");
      }
  
      public static final class FieldBackedBean {
          public final String visibleField;
  
          public FieldBackedBean(String visibleField) {
              this.visibleField = visibleField;
          }
      }
  
      public static final class GetterBackedBean {
          private final String visibleGetter;
  
          public GetterBackedBean(String visibleGetter) {
              this.visibleGetter = visibleGetter;
          }
  
          public String getVisibleGetter() {
              return visibleGetter;
          }
      }
  }
