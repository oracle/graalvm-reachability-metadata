mapper.readValue(\"\\\"{urn:jackson-test}entry\\\"\", QName.class);\n\n        assertThat(deserializer).isNotNull();\n        assertThat(name).isEqualTo(new QName(\"urn:jackson-test\", \"entry\"));\n    }\n}\n"}
