[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/ClassUtilInnerEnumTypeLocatorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport java.util.EnumMap;\nimport java.util.EnumSet;\nimport java.util.function.Supplier;\n\nimport org.codehaus.jackson.map.util.ClassUtil;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassUtilInnerEnumTypeLocatorTest {\n    @Test\n    void locatesTypeFromEmptyEnumSet() {\n        EnumSet<SampleEnum> values = EnumSet.noneOf(SampleEnum.class);\n\n        assertEnumTypeLookup(() -> ClassUtil.findEnumType(values), \"EnumSet\");\n    }\n\n    @Test\n    void locatesTypeFromEmptyEnumMap() {\n        EnumMap<SampleEnum, String> values = new EnumMap<>(SampleEnum.class);\n\n        assertEnumTypeLookup(() -> ClassUtil.findEnumType(values), \"EnumMap\");\n    }\n\n    private static void assertEnumTypeLookup(Supplier<Class<? extends Enum<?>>> lookup, String containerType) {\n        try {\n            Class<? extends Enum<?>> enumType = lookup.get();\n\n            assertThat(enumType).isEqualTo(SampleEnum.class);\n        } catch (IllegalArgumentException exception) {\n            assertThat(exception).hasCauseInstanceOf(IllegalAccessException.class);\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(containerType);\n        }\n    }\n\n    private enum SampleEnum {\n        FIRST,\n        SECOND\n    }\n}\n"}
