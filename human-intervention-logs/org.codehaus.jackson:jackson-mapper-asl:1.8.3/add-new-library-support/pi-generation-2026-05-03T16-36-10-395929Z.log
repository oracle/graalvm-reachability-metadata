anged-getter\"));\n\n        assertThat(defaultJson).isEqualTo(\"{}\");\n        assertThat(changedJson).isEqualTo(\"{\\\"name\\\":\\\"changed-getter\\\"}\");\n    }\n\n    @JsonSerialize(include = JsonSerialize.Inclusion.NON_DEFAULT)\n    public static final class FieldBackedValue {\n        public String name;\n\n        public FieldBackedValue() {\n            this(\"field-default\");\n        }\n\n        public FieldBackedValue(String name) {\n            this.name = name;\n        }\n    }\n\n    @JsonSerialize(include = JsonSerialize.Inclusion.NON_DEFAULT)\n    public static final class GetterBackedValue {\n        private String name;\n\n        public GetterBackedValue() {\n            this(\"getter-default\");\n        }\n\n        public GetterBackedValue(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 557, "output": 878, "cacheRead": 35328, "cacheWrite": 0, "totalTokens": 36763, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777826142949, "responseId": "resp_079e331aad31d8300169f779601b548195bea759438e4a0186"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_UZqrShuZsCZr9RLDK8dDs4Lh|fc_079e331aad31d8300169f7796695d8819599ccd403aed6c78f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2145 bytes to tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/PropertyBuilderTest.java"}], "isError": false, "timestamp": 1777826152997}]}
