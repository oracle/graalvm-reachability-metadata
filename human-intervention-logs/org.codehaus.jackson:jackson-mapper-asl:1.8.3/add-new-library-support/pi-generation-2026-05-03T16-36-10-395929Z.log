MixInResolver());\n\n        annotatedClass.resolveCreators(true);\n        annotatedClass.resolveMemberMethods(null, true);\n        annotatedClass.resolveFields(true);\n\n        assertThat(annotatedClass.getDefaultConstructor().getAnnotation(JsonCreator.class)).isNotNull();\n        assertThat(annotatedClass.getConstructors()).hasSize(1);\n        AnnotatedConstructor constructor = annotatedClass.getConstructors().get(0);\n        assertThat(constructor.getAnnotation(JsonCreator.class)).isNotNull();\n        assertThat(constructor.getParameterAnnotations(0).get(JsonProperty.class).value()).isEqualTo(\"value\");\n\n        AnnotatedMethod factoryMethod = findMethod(annotatedClass.getStaticMethods(), \"fromString\");\n        assertThat(factoryMethod).isNotNull();\n        assertThat(factoryMethod.getAnnotation(JsonCreator.class)).isNotNull();\n        assertThat(factoryMethod.getParameterAnnotations(0).get(JsonProperty.class).value()).isEqualTo(\"value\");\n\n        AnnotatedMethod getter = annotatedClass.findMethod(\"getName\", new Class<?>[0]);\n        assertThat(getter).isNotNull();\n        assertThat(getter.getAnnotation(JsonProperty.class).value()).isEqualTo(\"mixedName\");\n        assertThat(annotatedClass.findMethod(\"hashCode\", new Class<?>[0])).isNotNull();\n        assertThat(findMethod(annotatedClass.ignoredMemberMethods(), \"ignoredMethod\")).isNotNull();\n\n        AnnotatedField mixedField = findField(annotatedClass.fields(), \"mixedField\");\n        assertThat(mixedField).isNotNull();\n        assertThat(mixedField.getAnnotation(JsonProperty.class).value()).isEqualTo(\"mixedField\");\n        assertThat(findField(annotatedClass.fields(), \"baseField\")).isNotNull();\n        assertThat(findField(annotatedClass.ignoredFields(), \"ignoredField\")).isNotNull();\n    }\n\n    private static AnnotatedMethod findMethod(Iterable<AnnotatedMethod> methods, String name) {\n        for (AnnotatedMethod method : methods) {\n            if (name.equals(method.getName())) {\n                return method;\n            }\n        }\n        return null;\n    }\n\n    private static AnnotatedField findField(Iterable<AnnotatedField> fields, String name) {\n        for (AnnotatedField field : fields) {\n            if (name.equals(field.getName())) {\n                return field;\n            }\n        }\n        return null;\n    }\n\n    private static final class TestMixInResolver implements MixInResolver {\n        @Override\n        public Class<?> findMixInClassFor(Class<?> cls) {\n            if (cls == TargetModel.class) {\n                return TargetModelMixIn.class;\n            }\n            if (cls == BaseModel.class) {\n                return BaseModelMixIn.class;\n            }\n            if (cls == Object.class) {\n                return ObjectMethodMixIn.class;\n            }\n            return null;\n        }\n    }\n\n    private static class BaseModel {\n        public String baseField;\n\n        public String baseAccessor() {\n            return baseField;\n        }\n    }\n\n    private static final class TargetModel extends BaseModel {\n        public String mixedField;\n\n        @JsonIgnore\n        public String ignoredField;\n\n        TargetModel() {\n            this(\"default\");\n        }\n\n        TargetModel(String mixedField) {\n            this.mixedField = mixedField;\n        }\n\n        public static TargetModel fromString(String value) {\n            return new TargetModel(value);\n        }\n\n        public String getName() {\n            return mixedField;\n        }\n\n        @JsonIgnore\n        public String ignoredMethod() {\n            return ignoredField;\n        }\n    }\n\n    private static class BaseModelMixIn {\n        @JsonProperty(\"baseField\")\n        public String baseField;\n\n        @JsonProperty(\"baseAccessor\")\n        public String baseAccessor() {\n            return null;\n        }\n    }\n\n    private static class TargetModelMixIn {\n