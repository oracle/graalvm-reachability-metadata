          FactoryBackedValue value = objectMapper.readValue(
                  "{\"description\":\"created by factory\",\"name\":\"factory\",\"quantity\":7}",
                  FactoryBackedValue.class);
  
          assertThat(value.name).isEqualTo("factory");
          assertThat(value.quantity).isEqualTo(7);
          assertThat(value.description).isEqualTo("created by factory");
      }
  
