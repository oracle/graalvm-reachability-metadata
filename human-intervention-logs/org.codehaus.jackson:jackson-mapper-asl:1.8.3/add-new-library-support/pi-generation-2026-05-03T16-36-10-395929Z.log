          final int quantity;
          public String description;
  
          private FactoryBackedValue(String name, int quantity) {
              this.name = name;
              this.quantity = quantity;
          }
  
          @JsonCreator
          public static FactoryBackedValue fromJson(
                  @JsonProperty("name") String name,
                  @JsonProperty("quantity") int quantity) {
              return new FactoryBackedValue(name, quantity);
          }
      }
  }
