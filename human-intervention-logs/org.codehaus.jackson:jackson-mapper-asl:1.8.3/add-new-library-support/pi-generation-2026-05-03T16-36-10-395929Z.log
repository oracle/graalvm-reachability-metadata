  package org_codehaus_jackson.jackson_mapper_asl;
  
  import org.codehaus.jackson.map.util.ArrayBuilders;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ArrayBuildersTest {
      @Test
      void insertsElementAtHeadUsingOriginalArrayComponentType() {
          NamedValue first = new NamedValue("first");
          NamedValue second = new NamedValue("second");
  
          NamedValue[] result = ArrayBuilders.insertInList(new NamedValue[] { first, second }, new NamedValue("new"));
  
          assertThat(result).isInstanceOf(NamedValue[].class);
          assertThat(result).extracting(NamedValue::name).containsExactly("new", "first", "second");
      }
  
      @Test
      void returnsOriginalArrayWhenDuplicateIsAlreadyAtHead() {
          NamedValue first = new NamedValue("first");
          NamedValue[] array = new NamedValue[] { first, new NamedValue("second") };
  
          NamedValue[] result = ArrayBuilders.insertInListNoDup(array, first);
  
          assertThat(result).isSameAs(array);
          assertThat(result).extracting(NamedValue::name).containsExactly("first", "second");
      }
  
      @Test
      void allocatesSameSizeArrayWhenDuplicateIsMovedFromLaterPosition() {
          NamedValue first = new NamedValue("first");
          NamedValue duplicate = new NamedValue("duplicate");
          NamedValue[] array = new NamedValue[] { first, duplicate, new NamedValue("third") };
  
          NamedValue[] result = ArrayBuilders.insertInListNoDup(array, duplicate);
  
          assertThat(result).isNotSameAs(array);
          assertThat(result).isInstanceOf(NamedValue[].class);
          assertThat(result).hasSize(array.length);
      }
  
      @Test
      void insertsMissingElementAtHeadWithoutDuplicatingExistingElements() {
          NamedValue first = new NamedValue("first");
          NamedValue second = new NamedValue("second");
          NamedValue[] array = new NamedValue[] { first, second };
  
          NamedValue[] result = ArrayBuilders.insertInListNoDup(array, new NamedValue("new"));
  
          assertThat(result).isInstanceOf(NamedValue[].class);
          assertThat(result).extracting(NamedValue::name).containsExactly("new", "first", "second");
          assertThat(array).containsExactly(first, second);
      }
  
      private static final class NamedValue {
          private final String name;
  
          private NamedValue(String name) {
              this.name = name;
          }
  
          private String name() {
              return name;
          }
      }
  }
