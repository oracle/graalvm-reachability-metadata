ertions.assertThat;\n\npublic class OptionalHandlerFactoryTest {\n    @Test\n    void deserializesDomDocumentWithOptionalHandler() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        Document document = mapper.readValue(\"\\\"<root id='test'>value</root>\\\"\", Document.class);\n\n        assertThat(document.getDocumentElement().getNodeName()).isEqualTo(\"root\");\n        assertThat(document.getDocumentElement().getAttribute(\"id\")).isEqualTo(\"test\");\n        assertThat(document.getDocumentElement().getTextContent()).isEqualTo(\"value\");\n    }\n}\n"}], "isError": false, "timestamp": 1777826119954}}
