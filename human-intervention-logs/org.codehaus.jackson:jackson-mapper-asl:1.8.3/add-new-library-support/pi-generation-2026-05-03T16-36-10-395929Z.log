[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/PropertyBuilderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport org.codehaus.jackson.map.ObjectMapper;\nimport org.codehaus.jackson.map.annotate.JsonSerialize;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PropertyBuilderTest {\n    @Test\n    void suppressesDefaultValueDiscoveredFromFieldBackedProperty() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        String defaultJson = mapper.writeValueAsString(new FieldBackedValue(\"field-default\"));\n        String changedJson = mapper.writeValueAsString(new FieldBackedValue(\"changed-field\"));\n\n        assertThat(defaultJson).isEqualTo(\"{}\");\n        assertThat(changedJson).isEqualTo(\"{\\\"name\\\":\\\"changed-field\\\"}\");\n    }\n\n    @Test\n    void suppressesDefaultValueDiscoveredFromGetterBackedProperty() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        String defaultJson = mapper.writeValueAsString(new GetterBackedValue(\"getter-default\"));\n        String changedJson = mapper.writeValueAsString(new GetterBackedValue(\"changed-getter\"));\n\n        assertThat(defaultJson).isEqualTo(\"{}\");\n        assertThat(changedJson).isEqualTo(\"{\\\"name\\\":\\\"changed-getter\\\"}\");\n    }\n\n    @JsonSerialize(include = JsonSerialize.Inclusion.NON_DEFAULT)\n    public static final class FieldBackedValue {\n        public String name;\n\n        public FieldBackedValue() {\n            this(\"field-default\");\n        }\n\n        public FieldBackedValue(String name) {\n            this.name = name;\n        }\n    }\n\n    @JsonSerialize(include = JsonSerialize.Inclusion.NON_DEFAULT)\n    public static final class GetterBackedValue {\n        private String name;\n\n        public GetterBackedValue() {\n            this(\"getter-default\");\n        }\n\n        public GetterBackedValue(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n}\n"}
