ertThat(factoryMethod.getParameterAnnotations(0).get(JsonProperty.class).value()).isEqualTo(\"value\");\n\n        AnnotatedMethod getter = annotatedClass.findMethod(\"getName\", new Class<?>[0]);\n        assertThat(getter).isNotNull();\n        assertThat(getter.getAnnotation(JsonProperty.class).value()).isEqualTo(\"mixedName\");\n        assertThat(annotatedClass.findMethod(\"hashCode\", new Class<?>[0])).isNotNull();\n        assertThat(findMethod(annotatedClass.ignoredMemberMethods(), \"ignoredMethod\")).isNotNull();\n\n        AnnotatedField mixedField = findField(annotatedClass.fields(), \"mixedField\");\n        assertThat(mixedField).isNotNull();\n        assertThat(mixedField.getAnnotation(JsonProperty.class).value()).isEqualTo(\"mixedField\");\n        assertThat(findField(annotatedClass.fields(), \"baseField\")).isNotNull();\n        assertThat(findField(annotatedClass.ignoredFields(), \"ignoredField\")).isNotNull();\n    }\n\n    private static AnnotatedMethod findMethod(Iterable<AnnotatedMethod> methods, String name) {\n        for (AnnotatedMethod method : methods) {\n            if (name.equals(method.getName())) {\n                return method;\n            }\n        }\n        return null;\n    }\n\n    private static AnnotatedField findField(Iterable<AnnotatedField> fields, String name) {\n        for (AnnotatedField field : fields) {\n            if (name.equals(field.getName())) {\n                return field;\n            }\n        }\n        return null;\n    }\n\n    private static final class TestMixInResolver implements MixInResolver {\n        @Override\n        public Class<?> findMixInClassFor(Class<?> cls) {\n            if (cls == TargetModel.class) {\n                return TargetModelMixIn.class;\n            }\n            if (cls == BaseModel.class) {\n                return BaseModelMixIn.class;\n            }\n            if (cls == Object.class) {\n                return ObjectMethodMixIn.class;\n            }\n            return null;\n        }\n    }\n\n    private static class BaseModel {\n        public String baseField;\n\n        public String baseAccessor() {\n            return baseField;\n        }\n    }\n\n    private static final class TargetModel extends BaseModel {\n        public String mixedField;\n\n        @JsonIgnore\n        public String ignoredField;\n\n        TargetModel() {\n            this(\"default\");\n        }\n\n        TargetModel(String mixedField) {\n            this.mixedField = mixedField;\n        }\n\n        public static TargetModel fromString(String value) {\n            return new TargetModel(value);\n        }\n\n        public String getName() {\n            return mixedField;\n        }\n\n        @JsonIgnore\n        public String ignoredMethod() {\n            return ignoredField;\n        }\n    }\n\n    private static class BaseModelMixIn {\n        @JsonProperty(\"baseField\")\n        public String baseField;\n\n        @JsonProperty(\"baseAccessor\")\n        public String baseAccessor() {\n            return null;\n        }\n    }\n\n    private static class TargetModelMixIn {\n        @JsonProperty(\"mixedField\")\n        public String mixedField;\n\n        @JsonCreator\n        TargetModelMixIn() {\n        }\n\n        @JsonCreator\n        TargetModelMixIn(@JsonProperty(\"value\") String value) {\n        }\n\n        @JsonCreator\n        public static TargetModel fromString(@JsonProperty(\"value\") String value) {\n            return null;\n        }\n\n        @JsonProperty(\"mixedName\")\n        public String getName() {\n            return null;\n        }\n    }\n\n    private static class ObjectMethodMixIn {\n        @Override\n        @JsonProperty(\"objectHash\")\n        public int hashCode() {\n            return 37;\n        }\n    }\n}\n==== tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/ArrayBuildersTest.java\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport org.codehaus.jackson.map.util.ArrayBuilders;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ArrayBuildersTest {\n    @Test\n    void insertsElementAtHeadUsingOriginalArrayComponentType() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue second = new NamedValue(\"second\");\n\n        NamedValue[] result = ArrayBuilders.insertInList(new NamedValue[] { first, second }, new NamedValue(\"new\"));\n\n        assertThat(result).isInstanceOf(NamedValue[].class);\n        assertThat(result).extracting(NamedValue::name).containsExactly(\"new\", \"first\", \"second\");\n    }\n\n    @Test\n    void returnsOriginalArrayWhenDuplicateIsAlreadyAtHead() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue[] array = new NamedValue[] { first, new NamedValue(\"second\") };\n\n        NamedValue[] result = ArrayBuilders.insertInListNoDup(array, first);\n\n        assertThat(result).isSameAs(array);\n        assertThat(result).extracting(NamedValue::name).containsExactly(\"first\", \"second\");\n    }\n\n    @Test\n    void allocatesSameSizeArrayWhenDuplicateIsMovedFromLaterPosition() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue duplicate = new NamedValue(\"duplicate\");\n        NamedValue[] array = new NamedValue[] { first, duplicate, new NamedValue(\"third\") };\n\n        NamedValue[] result = ArrayBuilders.insertInListNoDup(array, duplicate);\n\n        assertThat(result).isNotSameAs(array);\n        assertThat(result).isInstanceOf(NamedValue[].class);\n        assertThat(result).hasSize(array.length);\n    }\n\n    @Test\n    void insertsMissingElementAtHeadWithoutDuplicatingExistingElements() {\n        NamedValue first = new NamedValue(\"first\");\n        NamedValue second = new NamedValue(\"second\");\n        NamedValue[] array = new NamedValue[] { first, second };\n\n        NamedValue[] result = ArrayBuilders.insertInListNoDup(array, new NamedValue(\"new\"));\n\n        assertThat(result).isInstanceOf(NamedValue[].class);\n        assertThat(result).extracting(NamedValue::name).containsExactly(\"new\", \"first\", \"second\");\n        assertThat(array).containsExactly(first, second);\n    }\n\n    private static final class NamedValue {\n        private final String name;\n\n        private NamedValue(String name) {\n            this.name = name;\n        }\n\n        private String name() {\n            return name;\n        }\n    }\n}\n==== tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/BeanPropertyWriterTest.java\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport org.codehaus.jackson.map.ObjectMapper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BeanPropertyWriterTest {\n    @Test\n    void serializesFieldBackedProperty() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        String json = mapper.writeValueAsString(new FieldBackedBean(\"field-value\"));\n\n        assertThat(json).isEqualTo(\"{\\\"visibleField\\\":\\\"field-value\\\"}\");\n    }\n\n    @Test\n    void serializesGetterBackedProperty() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n\n        String json = mapper.writeValueAsString(new GetterBackedBean(\"getter-value\"));\n\n        assertThat(json).isEqualTo(\"{\\\"visibleGetter\\\":\\\"getter-value\\\"}\");\n    }\n\n    public static final class Fiel