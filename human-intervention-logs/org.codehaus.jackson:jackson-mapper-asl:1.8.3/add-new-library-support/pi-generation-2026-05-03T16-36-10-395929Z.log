          ObjectMapper mapper = new ObjectMapper();
          mapper.enableDefaultTyping(ObjectMapper.DefaultTyping.NON_FINAL);
  
          String json = mapper.writeValueAsString(new JsonValueBacked("typed-value"));
  
          assertThat(json).contains(JsonValueBacked.class.getName(), "typed-value");
      }
  
