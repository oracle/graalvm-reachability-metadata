[tool-call] delta {"path":"tests/src/org.codehaus.jackson/jackson-mapper-asl/1.8.3/src/test/java/org_codehaus_jackson/jackson_mapper_asl/StdDeserializerInnerClassDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_codehaus_jackson.jackson_mapper_asl;\n\nimport org.codehaus.jackson.map.ObjectMapper;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class StdDeserializerInnerClassDeserializerTest {\n    @Test\n    void resolvesTopLevelClassFromJsonString() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n        String className = runtimeJdkClassName();\n\n        Class<?> resolved = readClassValue(mapper, quoted(className));\n\n        assertThat(resolved.getName()).isEqualTo(className);\n    }\n\n    @Test\n    void resolvesClassTypedBeanPropertyFromJsonString() throws Exception {\n        ObjectMapper mapper = new ObjectMapper();\n        String className = runtimeJdkClassName();\n\n        TypeHolder holder = readHolderValue(mapper, \"{\\\"type\\\":\" + quoted(className) + \"}\");\n\n        assertThat(holder.type.getName()).isEqualTo(className);\n    }\n\n    private static Class<?> readClassValue(ObjectMapper mapper, String json) throws Exception {\n        try {\n            return mapper.readValue(json, Class.class);\n        } catch (Error error) {\n            throwIfUnsupportedFeatureError(error);\n            throw error;\n        }\n    }\n\n    private static TypeHolder readHolderValue(ObjectMapper mapper, String json) throws Exception {\n        try {\n            return mapper.readValue(json, TypeHolder.class);\n        } catch (Error error) {\n            throwIfUnsupportedFeatureError(error);\n            throw error;\n  