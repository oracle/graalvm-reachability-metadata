e] = new AtomicReference[Throwable]()\\n\\n    val serverThread: Thread = new Thread(() => {\\n      try {\\n        val socket: Socket = serverSocket.accept()\\n        acceptedConnection.countDown()\\n        socket.close()\\n      } catch {\\n        case NonFatal(error) => serverFailure.set(error)\\n      }\\n    }, \\\"http2-alpn-support-test-server\\\")\\n    serverThread.setDaemon(true)\\n    serverThread.start()\\n\\n    try {\\n      val request: HttpRequest = HttpRequest(uri = \\\"/\\\")\\n      val response: Future[Done] = Source\\n        .single(request)\\n        .via(Http(system).connectionTo(\\\"127.0.0.1\\\").toPort(serverSocket.getLocalPort).http2())\\n        .runWith(Sink.ignore)(system)\\n\\n      try Await.result(response, 10.seconds)\\n      catch {\\n        case NonFatal(_) => ()\\n      }\\n\\n      assertTrue(acceptedConnection.await(10, TimeUnit.SECONDS), \\\"HTTP/2 TLS client should open a local TCP connection\\\")\\n      val failure: Throwable = serverFailure.get()\\n      if (failure != null) throw failure\\n    } finally {\\n      serverSocket.close()\\n      serverThread.join(TimeUnit.SECONDS.toMillis(10))\\n      Await.result(system.terminate(), 10.seconds)\\n      System.setProperty(\\\"java.specification.version\\\", previousJavaSpecificationVersion)\\n    }\\n  }\\n}\\n\"}\n../5005-ebf0f0b1/human-intervention-logs/com.typesafe.akka:akka-http-core_3:10.6.0-M1/add-new-library-support/pi-generation-2026-05-07T10-46-15-752275Z.log:1811:[tool-call] end id=call_oDfntQsyp4lr0eeqq6zXRjzh|fc_04a73ab565b108c60169fc6d3de0c4819fab206683da6000e9 name=write args={\"path\": \"tests/src/com.typesafe.akka/akka-http-core_3/10.6.0-M1/src/test/scala/com_typesafe_akka/akka_http_core_3/Http2AlpnSupportTest.scala\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage c