[tool-exec] start id=call_oDfntQsyp4lr0eeqq6zXRjzh|fc_04a73ab565b108c60169fc6d3de0c4819fab206683da6000e9 name=write args={"path": "tests/src/com.typesafe.akka/akka-http-core_3/10.6.0-M1/src/test/scala/com_typesafe_akka/akka_http_core_3/Http2AlpnSupportTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_http_core_3\n\nimport akka.Done\nimport akka.actor.ActorSystem\nimport akka.http.scaladsl.Http\nimport akka.http.scaladsl.model.HttpRequest\nimport akka.stream.scaladsl.Sink\nimport akka.stream.scaladsl.Source\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\n\nimport java.net.InetAddress\nimport java.net.ServerSocket\nimport java.net.Socket\nimport java.util.concurrent.CountDownLatch\nimport java.util.concurrent.TimeUnit\nimport java.util.concurrent.atomic.AtomicReference\nimport scala.concurrent.Await\nimport scala.concurrent.Future\nimport scala.concurrent.duration.DurationInt\nimport scala.util.control.NonFatal\n\nclass Http2AlpnSupportTest {\n  @Test\n  def http2TlsClientInitializesJdkAlpnSupport(): Unit = {\n    val previousJavaSpecificationVersion: String = System.getProperty(\"java.specification.version\")\n    System.setProperty(\"java.specification.version\", \"1.8\")\n\n    val system: ActorSystem = ActorSystem(\"http2-alpn-support-test\")\n    val serverSocket: ServerSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress)\n    val acceptedConnection: CountDownLatch = new CountDownLatch(1)\n    val serverFailure: AtomicReference[Throwable] = new AtomicReference[Throwable]()\n\n    val serverThread: Thread = new Thread(() => {\n      try {\n        val socket: Socket = serverSocket.accept()\n        acceptedConnection.countDown()\n        socket.close()\n      } catch {\n        case NonFatal(error) => serverFailure.set(error)\n      }\n    }, \"http2-alpn-support-test-server\")\n    serverThread.setDaemon(true)\n    serverThread.start()\n\n    try {\n      val request: HttpRequest = HttpRequest(uri = \"/\")\n      val response: Future[Done] = Source\n        .single(request)\n        .via(Http(system).connectionTo(\"127.0.0.1\").toPort(serverSocket.getLocalPort).http2())\n        .runWith(Sink.ignore)(system)\n\n      try Await.result(response, 10.seconds)\n      catch {\n        case NonFatal(_) => ()\n      }\n\n      assertTrue(acceptedConnection.await(10, TimeUnit.SECONDS), \"HTTP/2 TLS client should open a local TCP connection\")\n      val failure: Throwable = serverFailure.get()\n      if (failure != null) throw failure\n    } finally {\n      serverSocket.close()\n      serverThread.join(TimeUnit.SECONDS.toMillis(10))\n      Await.result(system.terminate(), 10.seconds)\n      System.setProperty(\"java.specification.version\", previousJavaSpecificationVersion)\n    }\n  }\n}\n"}
