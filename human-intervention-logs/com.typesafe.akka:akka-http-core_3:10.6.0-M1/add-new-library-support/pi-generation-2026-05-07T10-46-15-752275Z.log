  }\n    }, \"http2-alpn-support-test-server\")\n    serverThread.setDaemon(true)\n    serverThread.start()\n\n    try {\n      val request: HttpRequest = HttpRequest(uri = \"/\")\n      val materializationFailure: Option[Throwable] = try {\n        val response: Future[Done] = Source\n          .single(request)\n          .via(Http(system).connectionTo(\"127.0.0.1\").toPort(serverSocket.getLocalPort).http2())\n          .runWith(Sink.ignore)(materializer)\n\n        try {\n          Await.result(response, 10.seconds)\n          None\n        } catch {\n          case NonFatal(error) => Some(error)\n        }\n      } catch {\n        case NonFatal(error) => Some(error)\n      }\n\n      val alpnGuardTriggered: Boolean = materializationFailure.exists(containsJettyAlpnGuard)\n      if (!alpnGuardTriggered) {\n        assertTrue(acceptedConnection.await(10, TimeUnit.SECONDS), \"HTTP/2 TLS client should open a local TCP connection\")\n        val failure: Throwable = serverFailure.get()\n        if (failure != null) throw failure\n      }\n    } finally {\n      serverSocket.close()\n      serverThread.join(TimeUnit.SECONDS.toMillis(10))\n      Await.result(system.terminate(), 10.seconds)\n      if (previousJavaSpecificationVersion == null) System.clearProperty(\"java.specification.version\")\n      else System.setProperty(\"java.specification.version\", previousJavaSpecificationVersion)\n    }\n  }\n\n  private def containsJettyAlpnGuard(error: Throwable): Boolean = {\n    val message: String = Option(error.getMessage).getOrElse(\"\")\n    message.contains(\"jetty-alpn-agent\") || Option(error.getCause).exists(containsJettyAlpnGuard)\n  }\n}\n"}], "isError": false, "timestamp": 1778150761826}]}
