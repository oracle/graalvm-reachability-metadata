ition, Date value, TemporalType temporalType) {\n            parameterValuesByPosition.put(position, value);\n            temporalValuesByPosition.put(position, temporalType);\n            return this;\n        }\n\n        @Override\n        public Set<Parameter<?>> getParameters() {", "newText": "        public Query setParameter(int position, Date value, TemporalType temporalType) {\n            parameterValuesByPosition.put(position, value);\n            temporalValuesByPosition.put(position, temporalType);\n            return this;\n        }\n\n        @Override\n        public Query setParameters(Object... arguments) {\n            parameterValuesByPosition.clear();\n            for (int i = 0; i < arguments.length; i++) {\n                parameterValuesByPosition.put(i + 1, arguments[i]);\n            }\n            return this;\n        }\n\n        @Override\n        public Set<Parameter<?>> getParameters() {"}, {"oldText": "        private final List<T> typedResults;\n        private final T typedSingleResult;\n        private EntityGraph<? super T> entityGraph;\n        private PessimisticLockScope lockScope;", "newText": "        private final List<T> typedResults;\n        private final T typedSingleResult;\n        private final Set<Option> options = new LinkedHashSet<>();\n        private EntityGraph<? super T> entityGraph;\n        private PessimisticLockScope lockScope;"}, {"oldText": "        public TypedQuery<T> setParameter(int position, Date value, TemporalType temporalType) {\n            super.setParameter(position, value, temporalType);\n            return this;\n        }\n\n        @Override\n        public TypedQuery<T> setQueryFlushMode(QueryFlushMode flushMode) {", "newText": "        public TypedQuery<T> setParameter(int position, Date value, TemporalType temporalType) {\n            super.setParameter(position, value, temporalType);\n            return this;\n        }\n\n        @Override\n        public TypedQuery<T> setParameters(