       */
      void usage() {
          printUsage(commandSpec.commandLine() ?: createCommandLine(), writer)
      }
  
      private void printUsage(CommandLine commandLine, PrintWriter pw) {
          commandLine.usage(pw)
          pw.flush()
      }
  
