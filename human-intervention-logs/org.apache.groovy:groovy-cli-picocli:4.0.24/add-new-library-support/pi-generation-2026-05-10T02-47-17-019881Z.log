          commandSpec = CommandSpec.create()
          addOptionsFromAnnotations(optionsClass, cliOptions, true)
          addPositionalsFromAnnotations(optionsClass, cliOptions, true)
          parse(args)
          DefaultGroovyMethods.asType(cliOptions, optionsClass)
