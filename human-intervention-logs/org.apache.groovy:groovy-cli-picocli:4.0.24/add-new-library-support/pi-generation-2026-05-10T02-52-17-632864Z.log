          StringWriter usageBuffer = new StringWriter()
          CliBuilder usageCli = new CliBuilder(
                  name: 'secure-copy',
                  usage: 'secure-copy [options] source target',
                  header: 'Copies files securely.',
                  footer: 'Use responsibly.',
  
