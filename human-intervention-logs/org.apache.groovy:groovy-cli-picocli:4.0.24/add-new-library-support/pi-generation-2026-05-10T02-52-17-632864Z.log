.isEqualTo(15)\n    }\n\n    @Test\n    void expandsArgumentFilesAndCanTreatThemAsLiteralArguments() {\n", "newText": "    @Test\n    void supportsSingleHyphenLongOptionsAndAttachedOptionValues() {\n        CliBuilder cli = new CliBuilder(name: 'runner', acceptLongOptionsWithSingleHyphen: true)\n        cli._(longOpt: 'colour', type: String, argName: 'name', 'selected colour')\n        cli.t(longOpt: 'timeout', type: Integer, argName: 'seconds', 'timeout in seconds')\n\n        OptionAccessor options = cli.parse(['-colour', 'blue', '-t15'] as String[])\n\n        assertThat(options).isNotNull()\n        assertThat(options.hasOption('colour')).isTrue()\n        assertThat(options.colour).isEqualTo('blue')\n        assertThat(options.timeout).isEqualTo(15)\n    }\n\n    @Test\n    void acceptsPicocliOptionSpecsAddedThroughLeftShift() {\n        CliBuilder cli = new CliBuilder(name: 'download')\n        TypedOption<URI> endpoint = cli << OptionSpec.builder('--endpoint')\n                .type(URI)\n                .paramLabel('<uri>')\n                .description('target endpoint')\n                .build()\n        TypedOption<Boolean> quiet = cli << OptionSpec.builder('-q', '--quiet')\n                .type(boolean)\n                .description('suppress progress')\n                .build()\n\n        URI expectedEndpoint = URI.create('https://example.invalid/api')\n        OptionAccessor options = cli.parse([\n                '--endpoint', expectedEndpoint.toString(),\n                '--quiet',\n                'payload.json'\n        ] as String[])\n\n        assertThat(options).isNotNull()\n        assertThat(options.hasOption(endpoint)).isTrue()\n        assertThat(options.getOptionValue(endpoint)).isEqualTo(expectedEndpoint)\n        assertThat(options.endpoint).isEqualTo(expectedEndpoint)\n        assertThat(options.hasOption(quiet)).isTrue()\n        assertThat(options.quiet).isTrue()\n        assertThat(options.arguments()).containsExactly('payload.json')\