              } else if (k == 'valueSeparator') {
                  [[splitRegex: "$v"]]
              } else if (k == 'convert') {
                  [[converters: [v] as ITypeConverter[] ]]
              } else {
                  [[(k): v]]
              }
          }.sum() as Map
