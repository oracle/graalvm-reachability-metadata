st\n    void rejectsUnsupportedDelegateType() {\n        Authenticator authenticator = Collections::emptyMap;\n        DelegateHolder builder = new DelegateHolder(\"unsupported delegate\");\n\n        assertThatThrownBy(() -> Authenticator.setAuthenticatorOnDelegate(builder, authenticator))\n                .isInstanceOf(IllegalArgumentException.class)\n                .hasMessage(\n                        \"Delegate field is not type DefaultGrpcExporterBuilder \"\n                                + \"or OkHttpGrpcExporterBuilder.\");\n    }\n\n    private static final class DelegateHolder {\n        private final Object delegate;\n\n        private DelegateHolder(Object delegate) {\n            this.delegate = delegate;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777815729628}, {"role": "toolResult", "toolCallId": "call_6WCBhZVTTb8VtLdWWCR4zvbw|fc_0c56a61f7d7cc3270169f750b16d508195991303c39a2ba088", "toolName": "read", "content": [{"type": "text", "text": "[\n  {\n    \"name\": \"io_opentelemetry.opentelemetry_exporter_common.AuthenticatorTest$DelegateHolder\",\n    \"fields\": [\n      {\n        \"name\": \"delegate\"\n      }\n    ]\n  }\n]\n"}], "isError": false, "timestamp": 1777815729628}, {"role": "toolResult", "toolCallId": "call_xWjiSuERueZT67FNIyxRmCaY|fc_0c56a61f7d7cc3270169f750b16d5c81958f5e8a99785b204d", "toolName": "bash", "content": [{"type": "text", "text": "tests/src/io.opentelemetry/opentelemetry-exporter-common/1.28.0/src/test/resources/META-INF/native-image/authenticator-test/reflect-config.json\n"}], "isError": false, "timestamp": 1777815729628}]}
