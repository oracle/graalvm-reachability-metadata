  package io_opentelemetry.opentelemetry_exporter_common;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import io.opentelemetry.exporter.internal.grpc.GrpcStatusUtil;
  import io.opentelemetry.exporter.internal.grpc.ManagedChannelUtil;
  import io.opentelemetry.exporter.internal.retry.RetryUtil;
  import io.opentelemetry.sdk.common.export.RetryPolicy;
  import java.util.List;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class RetryUtilTest {
      @Test
      void exposesRetryableStatusCodes() {
          assertThat(RetryUtil.retryableHttpResponseCodes())
                  .containsExactlyInAnyOrder(429, 502, 503, 504);
          assertThat(RetryUtil.retryableGrpcStatusCodes())
                  .containsExactlyInAnyOrder(
                          GrpcStatusUtil.GRPC_STATUS_CANCELLED,
                          GrpcStatusUtil.GRPC_STATUS_DEADLINE_EXCEEDED,
                          GrpcStatusUtil.GRPC_STATUS_RESOURCE_EXHAUSTED,
                          GrpcStatusUtil.GRPC_STATUS_ABORTED,
                          GrpcStatusUtil.GRPC_STATUS_OUT_OF_RANGE,
                          GrpcStatusUtil.GRPC_STATUS_UNAVAILABLE,
                          GrpcStatusUtil.GRPC_STATUS_DATA_LOSS);
      }
  
      @Test
      void convertsRetryPolicyToGrpcServiceConfig() {
          RetryPolicy retryPolicy = RetryPolicy.getDefault();
  
          Map<String, ?> serviceConfig =
                  ManagedChannelUtil.toServiceConfig("otel.collector.trace.v1.TraceService", retryPolicy);
  
          assertThat(serviceConfig).containsOnlyKeys("methodConfig");
  
          List<?> methodConfigs = (List<?>) serviceConfig.get("methodConfig");
          assertThat(methodConfigs).hasSize(1);
  
          Map<?, ?> methodConfig = (Map<?, ?>) methodConfigs.get(0);
          assertThat(methodConfig.get("name"))
                  .isEqualTo(
                          List.of(Map.of("service", "otel.collector.trace.v1.TraceService")));
  
          Map<?, ?> retryConfig = (Map<?, ?>) methodConfig.get("retryPolicy");
          assertThat(retryConfig.get("maxAttempts")).isEqualTo((double) retryPolicy.getMaxAttempts());
          assertThat(retryConfig.get("initialBackoff"))
                  .isEqualTo(retryPolicy.getInitialBackoff().toMillis() / 1000.0 + "s");
          assertThat(retryConfig.get("maxBackoff"))
                  .isEqualTo(retryPolicy.getMaxBackoff().toMillis() / 1000.0 + "s");
          assertThat(retryConfig.get("backoffMultiplier"))
                  .isEqualTo(retryPolicy.getBackoffMultiplier());
          List<?> retryableStatusCodes = (List<?>) retryConfig.get("retryableStatusCodes");
          assertThat(retryableStatusCodes).hasSize(RetryUtil.retryableGrpcStatusCodes().size());
          assertThat(
                          retryableStatusCodes.stream()
                                  .map(statusCode -> String.valueOf(((Double) statusCode).intValue()))
                                  .toList())
                  .containsExactlyInAnyOrderElementsOf(RetryUtil.retryableGrpcStatusCodes());
      }
  }
