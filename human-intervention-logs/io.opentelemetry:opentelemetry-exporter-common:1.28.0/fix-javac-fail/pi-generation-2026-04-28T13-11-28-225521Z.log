      this.type = type;
      this.grpcEndpointPath = grpcEndpointPath;
      timeoutNanos = TimeUnit.SECONDS.toNanos(defaultTimeoutSecs);
      endpoint = defaultEndpoint;
      this.grpcStubFactory = grpcStubFactory;
