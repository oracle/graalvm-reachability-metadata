  package io_opentelemetry.opentelemetry_exporter_common;
  
  import static org.assertj.core.api.Assertions.assertThatCode;
  
  import io.opentelemetry.exporter.internal.auth.Authenticator;
  import io.opentelemetry.exporter.internal.http.HttpExporterBuilder;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class AuthenticatorTest {
      @Test
      void setsAuthenticatorOnHttpExporterDelegate() {
          HttpExporterBuilder<?> delegate =
                  new HttpExporterBuilder<>("otlp", "traces", "http://localhost:4318/v1/traces");
          DelegateHolder holder = new DelegateHolder(delegate);
          Authenticator authenticator = () -> Map.of("Authorization", "Bearer test-token");
  
          assertThatCode(() -> Authenticator.setAuthenticatorOnDelegate(holder, authenticator))
                  .doesNotThrowAnyException();
      }
  
      private static final class DelegateHolder {
          private final Object delegate;
  
          private DelegateHolder(Object delegate) {
              this.delegate = delegate;
          }
      }
  }
