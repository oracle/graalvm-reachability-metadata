ersion: \" + properties.getProperty( \"version\", \"unknown\" )\n539:                     + \" built on \" + properties.getProperty( \"builtOn\" ) );\n540:             }\n541:             else\n542:             {\n543:                 System.out.println( \"Maven version: \" + properties.getProperty( \"version\", \"unknown\" ) );\n544:             }\n545:             \n546:             System.out.println( \"Java version: \" + System.getProperty( \"java.version\", \"<unknown java version>\" ) );\n547: \n548:             /*\n549:              * TODO: when plexus can return the family type, add that here\n550:              * because it will make it easier to know what profile activation\n551:              * settings to use\n552:              */\n553:             System.out.println( \"OS name: \\\"\" + OS_NAME + \"\\\" version: \\\"\" + OS_VERSION + \"\\\" arch: \\\"\" + OS_ARCH\n554:                 + \"\\\"\" );\n555:                                            \n556:         }\n557:         catch ( IOException e )\n558:         {\n559:             System.err.println( \"Unable determine version from JAR file: \" + e.getMessage() );\n560:         }\n"}], "isError": false, "timestamp": 1782697101844}]}
