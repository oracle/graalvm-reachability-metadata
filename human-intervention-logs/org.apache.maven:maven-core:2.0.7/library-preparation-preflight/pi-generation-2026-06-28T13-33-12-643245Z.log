     421	        }
     422	
     423	        if ( commandLine.hasOption( CLIManager.NON_RECURSIVE ) )
     424	        {
     425	            request.setRecursive( false );
     426	        }
     427	
     428	        if ( commandLine.hasOption( CLIManager.FAIL_FAST ) )
     429	        {
     430	            request.setFailureBehavior( ReactorManager.FAIL_FAST );
     431	        }
