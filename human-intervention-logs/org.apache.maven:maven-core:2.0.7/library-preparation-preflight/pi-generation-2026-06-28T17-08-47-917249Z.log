ption e )\n187:        {\n188:            showError( \"Error reading settings.xml: \" + e.getMessage(), e, showErrors );\n189:\n190:            return 1;\n## 300-360\n300:        Settings settings = null;\n301:\n302:        MavenSettingsBuilder settingsBuilder = (MavenSettingsBuilder) embedder.lookup( MavenSettingsBuilder.ROLE );\n303:\n304:        try\n305:        {\n306:            if ( userSettingsPath != null )\n307:            {\n308:                File userSettingsFile = new File( userSettingsPath );\n309:\n310:                if ( userSettingsFile.exists() && !userSettingsFile.isDirectory() )\n311:                {\n312:                    settings = settingsBuilder.buildSettings( userSettingsFile );\n313:                }\n314:                else\n315:                {\n316:                    System.out.println( \"WARNING: Alternate user settings file: \" + userSettingsPath +\n317:                        \" is invalid. Using default path.\" );\n318:                }\n319:            }\n320:\n321:            if ( settings == null )\n322:            {\n323:                settings = settingsBuilder.buildSettings();\n324:            }\n325:        }\n326:        catch ( IOException e )\n327:        {\n328:            throw new SettingsConfigurationException( \"Error reading settings file\", e );\n329:        }\n330:        catch ( XmlPullParserException e )\n331:        {\n332:            throw new SettingsConfigurationException( e.getMessage(), e.getDetail(), e.getLineNumber(),\n333:                                                      e.getColumnNumber() );\n334:        }\n335:\n336:        // why aren't these part of the runtime info? jvz.\n337:\n338:        if ( commandLine.hasOption( CLIManager.BATCH_MODE ) )\n339:        {\n340:            settings.setInteractiveMode( false );\n341:        }\n342:\n343:        if ( commandLine.hasOption( CLIManager.SUPPRESS_PLUGIN_REGISTRY ) )\n344:        {\n345:            settings.setUsePluginRegistry( false );\n346