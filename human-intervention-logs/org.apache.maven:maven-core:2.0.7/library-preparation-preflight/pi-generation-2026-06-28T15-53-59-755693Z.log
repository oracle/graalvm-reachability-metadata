  metadata/org.codehaus.plexus/plexus-interpolation/index.json:9:    "description" : "Plexus Interpolation is a Java utility library for resolving and substituting expression placeholders in strings from pluggable value sources such as maps, properties, objects, and environment variables. It provides interpolator implementations, recursion handling, prefix-aware lookups, and reflection-based value extraction for tools that need Maven or Plexus-style configuration interpolation.",
  metadata/io.smallrye.beanbag/smallrye-beanbag-sisu/index.json:9:    "description" : "SmallRye BeanBag SISU integrates the SmallRye BeanBag programmatic bean container with Eclipse SISU metadata and annotations. It scans SISU and Plexus component resources from class loaders and registers the discovered beans with a BeanBag builder.",
  metadata/org.codehaus.plexus/plexus-archiver/index.json:9:    "description" : "Plexus Archiver is a Java component for creating and extracting archive formats such as ZIP, TAR, JAR, and related compressed variants. It provides archiver and unarchiver abstractions used by Plexus and Maven tooling to add files, directories, resources, permissions, and metadata to archives.",
  metadata/org.codehaus.plexus/plexus-archiver/index.json:23:    "description" : "Plexus Archiver is a Java component for creating and extracting archive formats such as ZIP, TAR, JAR, and related compressed variants. It provides archiver and unarchiver abstractions used by Plexus and Maven tooling to add files, directories, resources, permissions, and metadata to archives.",
  metadata/plexus/plexus-utils/index.json:9:    "description" : "Plexus Utils provides common Java utility classes historically used by Maven and Plexus-based projects. It includes helpers for file and IO handling, string manipulation, command-line execution, directory scanning, graph processing, introspection, and XML utilities.",
