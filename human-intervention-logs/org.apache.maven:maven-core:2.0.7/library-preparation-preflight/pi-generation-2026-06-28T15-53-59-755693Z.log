  metadata/org.sonatype.plexus/plexus-build-api/index.json:9:    "description": "Plexus Build API provides a small Java/Plexus API for build plugins to detect incremental changes, scan changed or deleted files, and refresh generated outputs. It also supplies default and thread-local build context implementations for recording build messages and preserving state across incremental mojo executions.",
  metadata/org.sonatype.plexus/plexus-cipher/1.4/reachability-metadata.json:5:        "typeReached": "org.sonatype.plexus.components.cipher.PlexusCipher$1"
