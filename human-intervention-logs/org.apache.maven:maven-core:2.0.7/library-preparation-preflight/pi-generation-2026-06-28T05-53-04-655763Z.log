    <name>Maven Core</name>
    <build>
      <plugins>
        <plugin>
          <artifactId>maven-assembly-plugin</artifactId>
          <configuration>
            <descriptor>src/assemble/bin.xml</descriptor>
            <finalName>maven-${version}</finalName>
          </configuration>
          <executions>
