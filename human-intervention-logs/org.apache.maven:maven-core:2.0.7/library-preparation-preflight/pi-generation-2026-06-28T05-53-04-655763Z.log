     475	    private static ArtifactRepository createLocalRepository( Embedder embedder, Settings settings,
     476	                                                             CommandLine commandLine )
     477	        throws ComponentLookupException
     478	    {
     479	        // TODO: release
     480	        // TODO: something in plexus to show all active hooks?
     481	        ArtifactRepositoryLayout repositoryLayout =
     482	            (ArtifactRepositoryLayout) embedder.lookup( ArtifactRepositoryLayout.ROLE, "default" );
     483	
     484	        ArtifactRepositoryFactory artifactRepositoryFactory =
     485	            (ArtifactRepositoryFactory) embedder.lookup( ArtifactRepositoryFactory.ROLE );
     486	
     487	        String url = settings.getLocalRepository();
     488	
     489	        if ( !url.startsWith( "file:" ) )
     490	        {
     491	            url = "file://" + url;
     492	        }
     493	
     494	        ArtifactRepository localRepository = new DefaultArtifactRepository( "local", url, repositoryLayout );
     495	
     496	        boolean snapshotPolicySet = false;
     497	
     498	        if ( commandLine.hasOption( CLIManager.OFFLINE ) )
     499	        {
     500	            settings.setOffline( true );
     501	
     502	            snapshotPolicySet = true;
     503	        }
     504	
     505	        if ( !snapshotPolicySet && commandLine.hasOption( CLIManager.UPDATE_SNAPSHOTS ) )
     506	        {
     507	            artifactRepositoryFactory.setGlobalUpdatePolicy( ArtifactRepositoryPolicy.UPDATE_POLICY_ALWAYS );
     508	        }
     509	
     510	        if ( commandLine.hasOption( CLIManager.CHECKSUM_FAILURE_POLICY ) )
     511	        {
     512	            System.out.println( "+ Enabling strict checksum verification on all artifact downloads." );
     513	
     514	            artifactRepositoryFactory.setGlobalChecksumPolicy( ArtifactRepositoryPolicy.CHECKSUM_POLICY_FAIL );
     515	        }
     516	        else if ( commandLine.hasOption( CLIManager.CHECKSUM_WARNING_POLICY ) )
     517	        {
     518	            System.out.println( "+ Disabling strict checksum verification on all artifact downloads." );
     519	
     520	            artifactRepositoryFactory.setGlobalChecksumPolicy( ArtifactRepositoryPolicy.CHECKSUM_POLICY_WARN );
     521	        }
     522	
     523	        return localRepository;
     524	    }
