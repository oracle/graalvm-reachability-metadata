    <modelVersion>4.0.0</modelVersion>
    <artifactId>maven-core</artifactId>
    <name>Maven Core</name>
    <build>
      <plugins>
        <plugin>
          <artifactId>maven-assembly-plugin</artifactId>
          <configuration>
            <descriptor>src/assemble/bin.xml</descriptor>
