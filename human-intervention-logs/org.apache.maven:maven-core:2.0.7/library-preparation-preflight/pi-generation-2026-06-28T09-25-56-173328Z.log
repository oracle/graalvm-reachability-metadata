ut = System.out;\n        PrintStream originalErr = System.err;\n        ByteArrayOutputStream out = new ByteArrayOutputStream();\n        ByteArrayOutputStream err = new ByteArrayOutputStream();\n\n        try (PrintStream capturedOut = new PrintStream(out, true, StandardCharsets.UTF_8);\n                PrintStream capturedErr = new PrintStream(err, true, StandardCharsets.UTF_8)) {\n            System.setOut(capturedOut);\n            System.setErr(capturedErr);\n\n            int exitCode = MavenCli.main(new String[] {\"--version\"}, new ClassWorld());\n\n            assertThat(exitCode).isZero();\n        } finally {\n            System.setOut(originalOut);\n            System.setErr(originalErr);\n        }\n\n        String output = out.toString(StandardCharsets.UTF_8);\n        String errorOutput = err.toString(StandardCharsets.UTF_8);\n\n        assertThat(output).startsWith(\"Maven version: \");\n        assertThat(output).doesNotContain(\"unknown\");\n        assertThat(errorOutput).isEmpty();\n    }\n}\n"}], "isError": false, "timestamp": 1782638605773}, {"role": "toolResult", "toolCallId": "call_60n9u5qR8TP7mockBH51pk6a|fc_0d3fd556f0ed841c016a40e80d95bc819491bc9bdcb316289d", "toolName": "bash", "content": [{"type": "text", "text": "/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.2.5/maven-core-3.2.5.pom.sha1\n/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.2.5/maven-core-3.2.5.jar\n/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.2.5/_remote.repositories\n/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.2.5/maven-core-3.2.5.jar.sha1\n/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.2.5/maven-core-3.2.5.pom\n/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.1.0/maven-core-3.1.0.pom.sha1\n/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.1.0/maven-core-3.1.0.jar\n/home/vjovanov/.m2/repository/org/apache/maven/maven-core/3.1.0/maven-core-3.1.0.jar.sha1\n/home/vjovanov/.m2/repositor