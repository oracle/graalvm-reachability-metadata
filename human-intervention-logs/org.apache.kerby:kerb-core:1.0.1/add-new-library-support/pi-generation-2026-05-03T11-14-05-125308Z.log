  package org_apache_kerby.kerb_core;
  
  import org.apache.kerby.kerberos.kerb.KrbCodec;
  import org.apache.kerby.kerberos.kerb.type.base.Realm;
  import org.junit.jupiter.api.Test;
  
  import java.nio.ByteBuffer;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class KrbCodecTest {
      @Test
      public void decodeFromByteBufferInstantiatesRequestedAsn1Type() throws Exception {
          Realm originalRealm = new Realm("EXAMPLE.COM");
  
          byte[] encodedRealm = KrbCodec.encode(originalRealm);
          Realm decodedRealm = KrbCodec.decode(ByteBuffer.wrap(encodedRealm), Realm.class);
  
          assertThat(decodedRealm).isNotSameAs(originalRealm);
          assertThat(decodedRealm.getValue()).isEqualTo("EXAMPLE.COM");
      }
  }
