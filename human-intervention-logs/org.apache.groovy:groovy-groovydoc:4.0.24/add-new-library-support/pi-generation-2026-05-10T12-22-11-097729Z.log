  29:    "Interface" : { it.isInterface() },
  30:    "Trait" : { it.isTrait() },
  31:    "Class" : { it.isClass() && !it.parentClasses*.qualifiedTypeName().contains('java.lang.Throwable') },
  32:    "Enum" : { it.isEnum() },
  33:    "Exception" : { it.isClass() && it.parentClasses*.qualifiedTypeName().contains('java.lang.Exception') },
  34:    "Error" : { it.isClass() && it.parentClasses*.qualifiedTypeName().contains('java.lang.Error') },
  35:    "Annotation Type" : { it.isAnnotationType() },
  36:    "Script" : { it.isScript() }
  37:]
