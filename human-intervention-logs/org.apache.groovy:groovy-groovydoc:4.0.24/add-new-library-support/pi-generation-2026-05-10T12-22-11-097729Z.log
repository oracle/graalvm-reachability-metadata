      assertThat(capacityField).isNotNull()\n+        assertThat(capacityField.isStatic()).isTrue()\n+        assertThat(capacityField.isFinal()).isTrue()\n+        assertThat(capacityField.type().typeName()).isEqualTo('int')\n+        assertThat(capacityField.commentText()).contains('Default capacity for new stores.')\n+\n+        GroovyConstructorDoc constructorDoc = javaStoreDoc.constructors().find { GroovyConstructorDoc constructor ->\n+            constructor.name() == 'JavaStore'\n+        }\n+        assertThat(constructorDoc).isNotNull()\n+        assertThat(constructorDoc.parameters()).isEmpty()\n+        assertThat(constructorDoc.thrownExceptionTypes()*.simpleTypeName()).containsExactly('IOException')\n+\n+        GroovyMethodDoc addNameMethod = javaStoreDoc.methods().find { GroovyMethodDoc methodDoc ->\n+            methodDoc.name() == 'addName'\n+        }\n+        assertThat(addNameMethod).isNotNull()\n+        assertThat(addNameMethod.returnType().simpleTypeName()).isEqualTo('int')\n+        assertThat(addNameMethod.parameters()*.name()).containsExactly('name')\n+        assertThat(addNameMethod.parameters()*.type()*.simpleTypeName()).containsExactly('String')\n+        assertThat(addNameMethod.thrownExceptionTypes()*.simpleTypeName()).containsExactly('IOException')\n+    }\n }\n"}], "isError": false, "timestamp": 1778415695978}]}
