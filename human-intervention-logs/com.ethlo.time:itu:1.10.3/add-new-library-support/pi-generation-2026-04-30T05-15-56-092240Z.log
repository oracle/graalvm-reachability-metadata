ted rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_ethlo_time.itu;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.time.YearMonth;\n\nimport com.ethlo.time.internal.util.DefaultLeapSecondHandler;\nimport org.junit.jupiter.api.Test;\n\npublic class DefaultLeapSecondHandlerTest {\n    @Test\n    void loadsLeapSecondMonthsFromBundledResource() {\n        DefaultLeapSecondHandler handler = new DefaultLeapSecondHandler();\n\n        assertThat(handler.isValidLeapSecondDate(YearMonth.of(1972, 6))).isTrue();\n        assertThat(handler.isValidLeapSecondDate(YearMonth.of(2015, 6))).isTrue();\n        assertThat(handler.isValidLeapSecondDate(YearMonth.of(2014, 6))).isFalse();\n        assertThat(handler.getLastKnownLeapSecond()).isEqualTo(YearMonth.of(2016, 12));\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.ethlo.time/itu/1.10.3/src/test/java/com_ethlo_time/itu/DefaultLeapSecondHandlerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_ethlo_time.itu;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.time.YearMonth;\\n\\nimport com.ethlo.time.internal.util.DefaultLeapSecondHandler;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class DefaultLeapSecondHandlerTest {\\n    @Test\\n    void loadsLeapSecondMonthsFromBundledResource() {\\n        DefaultLeapSecondHandler handler = new DefaultLeapSecondHandler();\\n\\n        assertThat(handler.isValidLeapSecondDate(YearMonth.of(1972, 6))).isTrue();\\n        assertThat(handler.isValidLeapSecondDate(YearMonth.of(2015, 6))).isTrue();\\n        assertThat(handler.isValidLeapSecondDate(YearMonth.of(2014, 6))).isFalse();\\n  