          {
              return false;
          }
      }
  
      private static boolean isAllowed(TemporalType needle, TemporalType... allowed)
      {
          for (TemporalType t : allowed)
          {
              if (t.equals(needle))
              {
                  return true;
              }
          }
          return false;
      }
