          byte result = 0;
          for (Object arg : args) {
              result += Byte.class.cast(arg);
          }
          return result;
      }
  
      private static Character addChars(final Object[] args) {
          char result = 0;
          for (Object arg : args) {
              result += Character.class.cast(arg);
          }
          return result;
      }
  
      private static Short addShorts(final Object[] args) {
          short result = 0;
          for (Object arg : args) {
