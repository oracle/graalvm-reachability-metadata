nal class FixedCounter implements Counter {\n        private final String name;\n        private final int count;\n\n        private FixedCounter(String name, int count) {\n            this.name = name;\n            this.count = count;\n        }\n\n        @Override\n        public String name() {\n            return name;\n        }\n\n        @Override\n        public int count() {\n            return count;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1676, "output": 1183, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 20267, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777404338392, "responseId": "resp_09ff7793c8fa43650169f109b2bf8c81969bdd421e832cfc55"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_eJgM0BlhCcWR8Mz4Kd4QX7lJ|fc_09ff7793c8fa43650169f109be4a088196ad14481d8aa773a5", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1792 bytes to tests/src/com.thoughtworks.proxytoys/proxytoys/1.0/src/test/java/com_thoughtworks_proxytoys/proxytoys/MulticastingInvokerTest.java"}], "isError": false, "timestamp": 1777404353254}]}
