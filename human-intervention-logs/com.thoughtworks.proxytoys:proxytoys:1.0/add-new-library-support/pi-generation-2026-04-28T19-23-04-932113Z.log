  public class NoOperationResetter<T> implements Resetter<T>, Serializable {
  
      private static final long serialVersionUID = 1L;
  
      /**
       * {@inheritDoc} Returns just <code>true</code>.
       */
      public boolean reset(T object) {
          return true;
      }
  
  }
