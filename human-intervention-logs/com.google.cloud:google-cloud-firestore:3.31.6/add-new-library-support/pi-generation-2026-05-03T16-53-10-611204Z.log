      int maxRandom = AUTO_ID_ALPHABET.length();
      for (int i = 0; i < AUTO_ID_LENGTH; i++) {
        builder.append(AUTO_ID_ALPHABET.charAt(RANDOM.nextInt(maxRandom)));
      }
      return builder.toString();
    }
  
