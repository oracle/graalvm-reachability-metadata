              this.count = count;
              this.ready = ready;
              this.secret = secret;
          }
  
          public String getName() {
              return name;
          }
  
          public int getCount() {
              return count;
          }
  
          public boolean isReady() {
              return ready;
          }
  
          public String getSecret() {
              return secret;
          }
  
          public String description() {
              return name + ':' + count;
          }
