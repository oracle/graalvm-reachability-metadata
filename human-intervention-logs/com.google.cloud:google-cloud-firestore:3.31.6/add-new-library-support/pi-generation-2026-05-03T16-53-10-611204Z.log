t\n    void populatesDocumentIdAnnotatedSetters() throws Exception {\n        try (Firestore firestore = newFirestore()) {\n            DocumentReference documentReference = firestore.document(\"messages/message-one\");\n\n            PojoBeanMapperDocumentIdStringSetterBean stringSetterBean =\n                    CustomClassMapper.convertToCustomClass(\n                            Collections.emptyMap(),\n                            PojoBeanMapperDocumentIdStringSetterBean.class,\n                            documentReference);\n            PojoBeanMapperDocumentIdReferenceSetterBean referenceSetterBean =\n                    CustomClassMapper.convertToCustomClass(\n                            Collections.emptyMap(),\n                            PojoBeanMapperDocumentIdReferenceSetterBean.class,\n                            documentReference);\n\n            assertThat(stringSetterBean.getDocumentId()).isEqualTo(\"message-one\");\n            assertThat(referenceSetterBean.getDocumentReference()).isSameAs(documentReference);\n        }\n    }\n\n    @Test\n    void populatesDocumentIdAnnotatedFields() throws Exception {\n        try (Firestore firestore = newFirestore()) {\n            DocumentReference documentReference = firestore.document(\"messages/message-two\");\n\n            PojoBeanMapperDocumentIdStringFieldBean stringFieldBean =\n                    CustomClassMapper.convertToCustomClass(\n                            Collections.emptyMap(),\n                            PojoBeanMapperDocumentIdStringFieldBean.class,\n                            documentReference);\n            PojoBeanMapperDocumentIdReferenceFieldBean referenceFieldBean =\n                    CustomClassMapper.convertToCustomClass(\n                            Collections.emptyMap(),\n                            PojoBeanMapperDocumentIdReferenceFieldBean.class,\n                            documentReference);\n\n            assertThat(stringFieldBean.documentId).isEqualTo(\"message-two\");\n            assertThat(referenceFieldBean.documentReference).isSameAs(documentReference);\n        }\n    }\n\n    private static Firestore newFirestore() {\n        return FirestoreOptions.newBuilder()\n                .setProjectId(\"native-image-test-project\")\n                .setEmulatorHost(\"localhost:8080\")\n                .build()\n                .getService();\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static Map<String, Object> asMap(Object value) {\n        assertThat(value).isInstanceOf(Map.class);\n        return (Map<String, Object>) value;\n    }\n}\n\nclass PojoBeanMapperSerializationBean {\n    public String fieldValue;\n    private String getterValue;\n\n    public PojoBeanMapperSerializationBean() {\n    }\n\n    PojoBeanMapperSerializationBean(String getterValue, String fieldValue) {\n        this.getterValue = getterValue;\n        this.fieldValue = fieldValue;\n    }\n\n    public String getGetterValue() {\n        return getterValue;\n    }\n}\n\nclass PojoBeanMapperDeserializationBean {\n    public String fieldValue;\n    private String setterValue;\n\n    public PojoBeanMapperDeserializationBean() {\n    }\n\n    public String getSetterValue() {\n        return setterValue;\n    }\n\n    public void setSetterValue(String setterValue) {\n        this.setterValue = setterValue;\n    }\n}\n\nclass PojoBeanMapperDocumentIdStringSetterBean {\n    private String documentId;\n\n    public PojoBeanMapperDocumentIdStringSetterBean() {\n    }\n\n    @DocumentId\n    public String getDocumentId() {\n        return documentId;\n    }\n\n    public void setDocumentId(String documentId) {\n        this.documentId = documentId;\n    }\n}\n\nclass PojoBeanMapperDocumentIdReferenceSetterBean {\n    private DocumentReference documentReference;\n\n    public PojoBeanMapperDocumentIdReferenceSetterBean() {\n    }\n\n    @DocumentId\n    public DocumentReference getDocumentReference() {\n        return documentReference;\n    }\n\n    public void setDocumentReference(DocumentReference documentReference) {\n        this.documentReference = documentReference;\n    }\n}\n\nclass PojoBeanMapperDocumentIdStringFieldBean {\n    @DocumentId public String documentId;\n\n    public PojoBeanMapperDocumentIdStringFieldBean() {\n    }\n}\n\nclass PojoBeanMapperDocumentIdReferenceFieldBean {\n    @DocumentId public DocumentReference documentReference;\n\n    public PojoBeanMapperDocumentIdReferenceFieldBean() {\n    }\n}\n"}
