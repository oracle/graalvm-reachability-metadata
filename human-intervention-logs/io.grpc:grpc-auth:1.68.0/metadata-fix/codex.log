nLatch(1);\n\n        callCredentials.applyRequestMetadata(\n                newRequestInfo(),\n                DIRECT_EXECUTOR,\n                new CallCredentials.MetadataApplier() {\n                    @Override\n                    public void apply(Metadata headers) {\n                        appliedHeaders.set(headers);\n                        completed.countDown();\n                    }\n\n                    @Override\n                    public void fail(Status status) {\n                        failure.set(status);\n                        completed.countDown();\n                    }\n                });\n\n        assertThat(completed.await(5, TimeUnit.SECONDS)).isTrue();\n        assertThat(failure.get()).isNull();\n        assertThat(appliedHeaders.get()).isNotNull();\n        assertThat(appliedHeaders.get().get(AUTHORIZATION)).startsWith(\"Bearer \");\n    }\n\n    private static ServiceAccountCredentials newUnscopedServiceAccountCredentials()\n            throws Exception {\n        return ServiceAccountCredentials.newBuilder()\n                .setClientId(\"client-id\")\n                .setClientEmail(\"service-account@example.iam.gserviceaccount.com\")\n                .setPrivateKey(newPrivateKey())\n                .setPrivateKeyId(\"private-key-id\")\n                .setScopes(Collections.emptyList())\n                .setQuotaProjectId(\"quota-project\")\n                .build();\n    }\n\n    private static PrivateKey newPrivateKey() throws Exception {\n        KeyPairGenerator generator = KeyPairGenerator.getInstance(\"RSA\");\n        generator.initialize(1024);\n        KeyPair keyPair = generator.generateKeyPair();\n        return keyPair.getPrivate();\n    }\n\n    private static CallCredentials.RequestInfo newRequestInfo() {\n        return new CallCredentials.RequestInfo() {\n            @Override\n            public MethodDescriptor<?, ?> getMethodDescriptor() {\n                return MethodDescriptor.<byte[], byte[]>newBuilder()\n                        .setType(MethodDescriptor.MethodType.UNARY)\n                        .setFullMethodName(\"google.example.Example/Unary\")\n                        .setRequestMarshaller(new ByteArrayMarshaller())\n                        .setResponseMarshaller(new ByteArrayMarshaller())\n                        .build();\n            }\n\n            @Override\n            public SecurityLevel getSecurityLevel() {\n                return SecurityLevel.PRIVACY_AND_INTEGRITY;\n            }\n\n            @Override\n            public String getAuthority() {\n                return \"example.googleapis.com:443\";\n            }\n\n            @Override\n            public Attributes getTransportAttrs() {\n                return Attributes.EMPTY;\n            }\n        };\n    }\n\n    private static final class ByteArrayMarshaller implements MethodDescriptor.Marshaller<byte[]> {\n        @Override\n        public InputStream stream(byte[] value) {\n            return new ByteArrayInputStream(value);\n        }\n\n        @Override\n        public byte[] parse(InputStream stream) {\n            return new byte[0];\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
