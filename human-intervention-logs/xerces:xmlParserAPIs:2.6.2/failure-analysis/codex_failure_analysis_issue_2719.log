er = Thread.currentThread().getContextClassLoader();\\n        ResourceTrackingClassLoader serviceClassLoader = new ResourceTrackingClassLoader(\\n                originalContextClassLoader,\\n                DOCUMENT_BUILDER_FACTORY_SERVICE,\\n                \\\"com.example.MissingDocumentBuilderFactory\\\\n\\\");\\n\\n        try {\\n            Thread.currentThread().setContextClassLoader(serviceClassLoader);\\n\\n            assertThatThrownBy(DocumentBuilderFactory::newInstance)\\n                    .isInstanceOf(FactoryConfigurationError.class);\\n            assertThat(serviceClassLoader.wasRequested()).isTrue();\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    public void fallsBackToSystemResourceLookupWithoutContextClassLoader() {\\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\\n        String originalFactoryProperty = System.getProperty(SAXParserFactory.class.getName());\\n\\n        try {\\n            Thread.currentThread().setContextClassLoader(null);\\n            System.clearProperty(SAXParserFactory.class.getName());\\n\\n            try {\\n                SAXParserFactory factory = SAXParserFactory.newInstance();\\n                assertThat(factory).isNotNull();\\n            } catch (FactoryConfigurationError error) {\\n                assertThat(error).isNotNull();\\n            }\\n        } finally {\\n            restoreSystemProperty(SAXParserFactory.class.getName(), originalFactoryProperty);\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n        }\\n    }\\n\\n    private static void restoreSystemProperty(String name, String value) {\\n        if (value == null) {\\n            System.clearProperty(name);\\n        } else {\\n            System.setProperty(name, value);\\n        }\\n    }\\n}\\n\\nclass ResourceTrackingClassLoader extends ClassLoader {\\n    private final String resourceName;\\n    private final String resourceContent;\\n    private boolean requested;\\n\\n    ResourceTrackingClassLoader(ClassLoader parent, String resourceName, String resourceContent) {\\n        super(parent);\\n        this.resourceName = resourceName;\\n        this.resourceContent = resourceContent;\\n    }\\n\\n    @Override\\n    public InputStream getResourceAsStream(String name) {\\n        if (resourceName.equals(name)) {\\n            requested = true;\\n            return new ByteArrayInputStream(resourceContent.getBytes(StandardCharsets.UTF_8));\\n        }\\n        return null;\\n    }\\n\\n    boolean wasRequested() {\\n        return requested;\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777423177883}}\nhuman-intervention-logs/xerces:xmlParserAPIs:2.6.2/add-new-library-support/pi-generation-2026-04-29T00-38-52-263566Z.log:9128:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_LxSrLdHDccARTJdWMMiUb5LZ|fc_0f03f4be8f899e690169f15349300c819fb844c7afc734051b\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage xerces.xmlParserAPIs;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.InputStream;\\nimport java.nio.charset.StandardCharsets;\\nimport javax.xml.parsers.DocumentBuilderFactory;\\nimport javax.xml.parsers.FactoryConfigurationError;\\nimport javax.xml.parsers.SAXParserFactory;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class SecuritySupportTest {\\n    private static final String DOCUMENT_BUILDER_FACTORY_SERVICE =\\n            \\\"META-INF/services/javax.xml.par