der for it.\\n- Wrapped dynamic class loading with the required Native Image unsupported-feature handling via:\\n  - `NativeImageSupport.isUnsupportedFeatureError(error)`\\n\\nThis should resolve the JVM failure while still exercising the two intended dynamic-access resource call sites.\", \"textSignature\": \"{\\\"v\\\":1,\\\"id\\\":\\\"msg_0bb5d39a304e23be0169f8f8d3756481948180f769d85fb412\\\",\\\"phase\\\":\\\"final_answer\\\"}\"}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1267, \"output\": 1253, \"cacheRead\": 46080, \"cacheWrite\": 0, \"totalTokens\": 48600, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"stop\", \"timestamp\": 1777924289380, \"responseId\": \"resp_0bb5d39a304e23be0169f8f8c224148194b7a1253c3315a754\"}, \"toolResults\": []}\ntests/src/xerces/xmlParserAPIs/2.6.2/src/test/resources/xerces/xmlParserAPIs/security-support-resource.txt:1:xmlParserAPIs SecuritySupport resource\ntests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/JavaxXmlParsersSecuritySupportTest.java:21:public class JavaxXmlParsersSecuritySupportTest {\ntests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/JavaxXmlParsersSecuritySupportTest.java:24:    private static final String RESOURCE_CONTENT = \"xmlParserAPIs SecuritySupport resource\";\ntests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/JavaxXmlParsersSecuritySupportTest.java:29:            final Object securitySupport = newSecuritySupport();\ntests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/JavaxXmlParsersSecuritySupportTest.java:30:            final ClassLoader classLoader = JavaxXmlParsersSecuritySupportTest.class.getClassLoader();\ntests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/JavaxXmlParsersSecuritySupportTest.java:46:            final Object securitySupport = newSecuritySupport();\ntests/src/xerc