{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/JavaxXmlParsersSecuritySupportTest.java | sed -n '1,220p'\"","aggregated_output":"     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage xerces.xmlParserAPIs;\n     8\t\n     9\timport java.io.IOException;\n    10\timport java.io.InputStream;\n    11\timport java.lang.reflect.Constructor;\n    12\timport java.lang.reflect.InvocationTargetException;\n    13\timport java.lang.reflect.Method;\n    14\timport java.nio.charset.StandardCharsets;\n    15\t\n    16\timport org.graalvm.internal.tck.NativeImageSupport;\n    17\timport org.junit.jupiter.api.Test;\n    18\t\n    19\timport static org.assertj.core.api.Assertions.assertThat;\n    20\t\n    21\tpublic class JavaxXmlParsersSecuritySupportTest {\n    22\t    private static final String RESOURCE_NAME = \"xerces/xmlParserAPIs/security-support-resource.txt\";\n    23\t    private static final String MISSING_RESOURCE_NAME = \"xerces/xmlParserAPIs/missing-security-support-resource.txt\";\n    24\t    private static final String RESOURCE_CONTENT = \"xmlParserAPIs SecuritySupport resource\";\n    25\t\n    26\t    @Test\n    27\t    void getResourceAsStreamUsesProvidedClassLoader() throws Exception {\n    28\t        try {\n    29\t            final Object securitySupport = newSecuritySupport();\n    30\t            final ClassLoader classLoader = JavaxXmlParsersSecuritySupportTest.class.getClassLoader();\n    31\t\n    32\t            try (InputStream stream = invokeGetResourceAsStream(securitySupport, classLoader, RESOURCE_NAME)) {\n    33\t                assertThat(stream).isNotNull();\n    34\t                assertThat(new String(stream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(RESOURCE_CONTENT);\n    35\t            }\n    36\t        } catch (InvocationTargetException exception) {\n    37\t            rethrowUnlessUnsupportedFeatureError(exception.getCause());\n    38\t        } catch (Error error) {\n    39\t            rethrowUnlessUnsupportedFeatureError(error);\n    40\t        }\n    41\t    }\n    42\t\n    43\t    @Test\n    44\t    void getResourceAsStreamUsesSystemClassLoaderWhenProvidedClassLoaderIsNull() throws Exception {\n    45\t        try {\n    46\t            final Object securitySupport = newSecuritySupport();\n    47\t\n    48\t            try (InputStream stream = invokeGetResourceAsStream(securitySupport, null, MISSING_RESOURCE_NAME)) {\n    49\t                assertThat(stream).isNull();\n    50\t            }\n    51\t        } catch (InvocationTargetException exception) {\n    52\t            rethrowUnlessUnsupportedFeatureError(exception.getCause());\n    53\t        } catch (Error error) {\n    54\t            rethrowUnlessUnsupportedFeatureError(error);\n    55\t        }\n    56\t    }\n    57\t\n    58\t    private static Object newSecuritySupport() throws Exception {\n    59\t        // The active class is package-private and hidden by the JDK's java.xml module on modern JDKs.\n    60\t        final Class<?> securitySupportClass = Class.forName(\"javax.xml.parsers.SecuritySupport\", true,\n    61\t                new XmlParserApisClassLoader());\n    62\t        final Constructor<?> constructor = securitySupportClass.getDeclaredConstructor();\n    63\t        constructor.setAccessible(true);\n    64\t        return constructor.newInstance();\n    65\t    }\n    66\t\n    67\t    private static InputStream invokeGetResourceAsStream(final Object securitySupport, final ClassLoader classLoader,\n    68\t            final String name) throws Exception {\n    69\t        final Method method = securitySupport.getClass().getDeclaredMethod(\"getResourceAsStream\", ClassLoader.class,\n    70\t                String.class);\n    71\t        method.setAccessible(true);\n    72\t        return (InputStream) method.invoke(securitySupport, classLoader, name);\n    73\t    }\n    74\t\n    75\t    private static void rethrowUnlessUnsupportedFeatureError(final Throwable throwable) {\n    76\t        if (throwable instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n    77\t            return;\n    78\t        }\n    79\t        if (throwable instanceof RuntimeException runtimeException) {\n    80\t            throw runtimeException;\n    81\t        }\n    82\t        if (throwable instanceof Error error) {\n    83\t            throw error;\n    84\t        }\n    85\t        throw new IllegalStateException(throwable);\n    86\t    }\n    87\t\n    88\t    private static final class XmlParserApisClassLoader extends ClassLoader {\n    89\t        private static final String SECURITY_SUPPORT_CLASS_NAME = \"javax.xml.parsers.SecuritySupport\";\n    90\t        private static final String SECURITY_SUPPORT_12_CLASS_NAME = \"javax.xml.parsers.SecuritySupport12\";\n    91\t\n    92\t        private XmlParserApisClassLoader() {\n    93\t            super(JavaxXmlParsersSecuritySupportTest.class.getClassLoader());\n    94\t        }\n    95\t\n    96\t        @Override\n    97\t        protected Class<?> findClass(final String name) throws ClassNotFoundException {\n    98\t            if (!name.equals(SECURITY_SUPPORT_CLASS_NAME) && !name.startsWith(SECURITY_SUPPORT_12_CLASS_NAME)) {\n    99\t                return super.findClass(name);\n   100\t            }\n   101\t\n   102\t            final String resourceName = name.replace('.', '/') + \".class\";\n   103\t            try (InputStream stream = getParent().getResourceAsStream(resourceName)) {\n   104\t                if (stream == null) {\n   105\t                    throw new ClassNotFoundException(name);\n   106\t                }\n   107\t                final byte[] bytes = stream.readAllBytes();\n   108\t                return defineClass(name, bytes, 0, bytes.length);\n   109\t            } catch (IOException exception) {\n   110\t                throw new ClassNotFoundException(name, exception);\n   111\t            }\n   112\t        }\n   113\t    }\n   114\t}\n","exit_code":0,"status":"completed"}}
