ary-support/pi-generation-2026-04-29T00-38-52-263566Z.log:10944:[tool-call] delta {\"path\":\"tests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/SecuritySupportTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage xerces.xmlParserAPIs;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.InputStream;\\nimport java.lang.reflect.Constructor;\\nimport java.lang.reflect.Method;\\nimport java.nio.charset.StandardCharsets;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class SecuritySupportTest {\\n    private static final String SECURITY_SUPPORT_CLASS_NAME = \\\"javax.xml.parsers.SecuritySupport\\\";\\n    private static final String SECURITY_SUPPORT_RESOURCE = \\\"javax/xml/parsers/SecuritySupport.class\\\";\\n    private static final String TRACKED_RESOURCE = \\\"security-support-tracked-resource.txt\\\";\\n\\n    @Test\\n    public void getsResourceFromProvidedClassLoader() throws Exception {\\n        ResourceTrackingClassLoader classLoader = new ResourceTrackingClassLoader(\\n                Thread.currentThread().getContextClassLoader(),\\n                TRACKED_RESOURCE,\\n                \\\"tracked resource\\\");\\n\\n        try (InputStream stream = invokeGetResourceAsStream(classLoader, TRACKED_RESOURCE)) {\\n            assertThat(stream).isNotNull();\\n            assertThat(classLoader.wasRequested()).isTrue();\\n        }\\n    }\\n\\n    @Test\\n    public void getsSystemResourceWhenClassLoaderIsNull() throws Exception {\\n        try (InputStream stream = invokeGetResourceAsStream(null, SECURITY_SUPPORT_RESOURCE)) {\\n            assertThat(stream).isNotNull();\\n        }\\n    }\\n\\n    private static InputStream invokeGetResourceAsStream(ClassLoader classLoader, Stri