* Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage xerces.xmlParserAPIs;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\nimport java.nio.charset.StandardCharsets;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgXmlSaxHelpersSecuritySupportTest {\n    private static final String SECURITY_SUPPORT_CLASS_NAME = \"org.xml.sax.helpers.SecuritySupport\";\n    private static final String SECURITY_SUPPORT_RESOURCE = \"org/xml/sax/helpers/SecuritySupport.class\";\n    private static final String TRACKED_RESOURCE = \"org-xml-sax-helpers-security-support-resource.txt\";\n\n    @Test\n    public void getsResourceFromProvidedClassLoader() throws Exception {\n        ResourceTrackingClassLoader classLoader = new ResourceTrackingClassLoader(\n                Thread.currentThread().getContextClassLoader(),\n                TRACKED_RESOURCE,\n                \"tracked SAX helper resource\");\n\n        try (InputStream stream = invokeGetResourceAsStream(classLoader, TRACKED_RESOURCE)) {\n            assertThat(stream).isNotNull();\n            assertThat(classLoader.wasRequested()).isTrue();\n        }\n    }\n\n    @Test\n    public void getsSystemResourceWhenClassLoaderIsNull() throws Exception {\n        try (InputStream stream = invokeGetResourceAsStream(null, SECURITY_SUPPORT_RESOURCE)) {\n            assertThat(stream).isNotNull();\n        }\n    }\n\n    private static InputStream invokeGetResourceAsStream(ClassLoader classLoader, String resourceName) throws Exception {\n        Class<?> securitySupportClass = Class.forName(SECURITY_SUPPORT_CLASS_NAME);\n        Constructor<?> constructor = securitySupportClass.getDeclaredConstructor();\n        constructor.setAccessible(true);\n        Object securitySupport = constructor.newInstance();\n        Method getResourceAsStream = securitySupportClass.getDeclaredMethod(\n                \"getResourceAsStream\", ClassLoader.class, String.class);\n        getResourceAsStream.setAccessible(true);\n        return (InputStream) getResourceAsStream.invoke(securitySupport, classLoader, resourceName);\n    }\n\n    private static final class ResourceTrackingClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final String resourceContent;\n        private boolean requested;\n\n        private ResourceTrackingClassLoader(ClassLoader parent, String resourceName, String resourceContent) {\n            super(parent);\n            this.resourceName = resourceName;\n            this.resourceContent = resourceContent;\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (resourceName.equals(name)) {\n                requested = true;\n                return new ByteArrayInputStream(resourceContent.getBytes(StandardCharsets.UTF_8));\n            }\n            return null;\n        }\n\n        private boolean wasRequested() {\n            return requested;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/OrgXmlSaxHelpersSecuritySupportTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage xerces.xmlParserAPIs;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.InputStream;\\nimport java.lang.reflect.Constructor;\\nimport java.lang.reflect.Method;\\nimport java.nio.charset.StandardCharsets;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class OrgXmlSaxHelpersSecuritySupportTest {\\n    private static final String SECURITY_SUPPORT_CLASS_NAME = \\\"org.xml.sax.helpers.SecuritySupport\\\";\\n    private static final String SECURITY_SUPPORT_RESOURCE = \\\"org/xml/sax/helpers/SecuritySupport.class\\\";\\n    private static final String TRACKED_RESOURCE = \\\"org-xml-sax-helpers-security-support-resource.txt\\\";\\n\\n    @Test\\n    public void getsResourceFromProvidedClassLoader() throws Exception {\\n        ResourceTrackingClassLoader classLoader = new ResourceTrackingClassLoader(\\n                Thread.currentThread().getContextClassLoader(),\\n                TRACKED_RESOURCE,\\n                \\\"tracked SAX helper resource\\\");\\n\\n        try (InputStream stream = invokeGetResourceAsStream(classLoader, TRACKED_RESOURCE)) {\\n            assertThat(stream).isNotNull();\\n            assertThat(classLoader.wasRequested()).isTrue();\\n        }\\n    }\\n\\n    @Test\\n    public void getsSystemResourceWhenClassLoaderIsNull() throws Exception {\\n        try (InputStream stream = invokeGetResourceAsStream(null, SECURITY_SUPPORT_RESOURCE)) {\\n            assertThat(stream).isNotNull();\\n        }\\n    }\\n\\n    private static InputStream invokeGetResourceAsStream(ClassLoader classLoader, String resourceName) throws Exception {\\n        Class<?> securitySupportClass = Class.forName(SECURITY_SUPPORT_CLASS_NAME);\\n        Constructor<?> constructor = securitySupportClass.getDeclaredConstructor();\\n        constructor.setAccessible(true);\\n        Object securitySupport = constructor.newInstance();\\n        Method getResourceAsStream = securitySupportClass.getDeclaredMethod(\\n                \\\"getResourceAsStream\\\", ClassLoader.class, String.class);\\n        getResourceAsStream.setAccessible(true);\\n        return (InputStream) getResourceAsStream.invoke(securitySupport, classLoader, resourceName);\\n    }\\n\\n    private static final class ResourceTrackingClassLoader extends ClassLoader {\\n       