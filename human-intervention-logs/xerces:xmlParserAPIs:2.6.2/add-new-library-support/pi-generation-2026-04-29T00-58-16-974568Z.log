me.endsWith(\".jar\") }\n}\n\nTaskProvider<Sync> extractJavaXmlPatch = tasks.register(\"extractJavaXmlPatch\", Sync) {\n    from(xmlParserApisJar.map { jar -> zipTree(jar) }) {\n        include \"javax/xml/parsers/SecuritySupport*.class\"\n        include \"javax/xml/transform/SecuritySupport*.class\"\n    }\n    into(javaXmlPatchDir)\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn extractJavaXmlPatch\n    doFirst {\n        jvmArgs javaXmlPatchModuleArg.get(),\n                \"--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED\",\n                \"--add-opens=java.xml/javax.xml.transform=ALL-UNNAMED\"\n    }\n}\n\ntasks.withType(org.graalvm.buildtools.gradle.tasks.BuildNativeImageTask).configureEach {\n    dependsOn extractJavaXmlPatch\n}\n\ngraalvmNative {\n    binaries {\n        all {\n            buildArgs.add(nativeJavaXmlPatchModuleArg)\n            buildArgs.add(\"--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED\")\n            buildArgs.add(\"--add-opens=java.xml/javax.xml.transform=ALL-UNNAMED\")\n        }\n    }\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777424183511}]}
