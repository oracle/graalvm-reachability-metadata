[tool-exec] end id=call_50IjQV2qF33E7FOCaPd90Thh|fc_019c11026f7145390169f157d928c08190a7e34183ce2e1c95 name=read status=success
  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "xerces:xmlParserAPIs:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  Provider<Directory> javaXmlPatchDir = layout.buildDirectory.dir("generated/javaXmlPatch")
  Provider<String> javaXmlPatchModuleArg = javaXmlPatchDir.map { directory ->
      "--patch-module=java.xml=${directory.asFile.absolutePath}"
  }
  Provider<String> nativeJavaXmlPatchModuleArg = javaXmlPatchDir.map { directory ->
      "-J--patch-module=java.xml=${directory.asFile.absolutePath}"
  }
  
  Provider<File> xmlParserApisJar = configurations.testRuntimeClasspath.elements.map { elements ->
      elements.collect { it.asFile }.find { it.name.startsWith("xmlParserAPIs-") && it.name.endsWith(".jar") }
  }
  
  TaskProvider<Sync> extractJavaXmlPatch = tasks.register("extractJavaXmlPatch", Sync) {
      from(xmlParserApisJar.map { jar -> zipTree(jar) }) {
          include "javax/xml/parsers/SecuritySupport*.class"
          include "javax/xml/transform/SecuritySupport*.class"
          include "org/xml/sax/helpers/SecuritySupport*.class"
      }
      into(javaXmlPatchDir)
  }
  
  tasks.withType(Test).configureEach {
      dependsOn extractJavaXmlPatch
      doFirst {
          jvmArgs javaXmlPatchModuleArg.get(),
                  "--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED",
                  "--add-opens=java.xml/javax.xml.transform=ALL-UNNAMED",
                  "--add-opens=java.xml/org.xml.sax.helpers=ALL-UNNAMED"
      }
  }
  
  tasks.withType(org.graalvm.buildtools.gradle.tasks.BuildNativeImageTask).configureEach {
      dependsOn extractJavaXmlPatch
  }
  
  graalvmNative {
      binaries {
          all {
              buildArgs.add(nativeJavaXmlPatchModuleArg)
              buildArgs.add("--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED")
              buildArgs.add("--add-opens=java.xml/javax.xml.transform=ALL-UNNAMED")
              buildArgs.add("--add-opens=java.xml/org.xml.sax.helpers=ALL-UNNAMED")
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
