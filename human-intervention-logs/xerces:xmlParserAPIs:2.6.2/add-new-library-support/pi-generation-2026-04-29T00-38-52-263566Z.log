[tool-call] delta {"path":"tests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/SecuritySupportTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage xerces.xmlParserAPIs;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.atomic.AtomicBoolean;\nimport javax.xml.parsers.DocumentBuilderFactory;\nimport javax.xml.parsers.FactoryConfigurationError;\nimport javax.xml.parsers.SAXParserFactory;\nimport org.junit.jupiter.api.Test;\n\npublic class SecuritySupportTest {\n    private static final String DOCUMENT_BUILDER_FACTORY_SERVICE =\n            \"META-INF/services/javax.xml.parsers.DocumentBuilderFactory\";\n\n    @Test\n    public void usesContextClassLoaderWhenLookingForJaxpServices() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        AtomicBoolean requestedDocumentBuilderFactoryService = new AtomicBoolean(false);\n        ClassLoader serviceClassLoader = new ClassLoader(originalContextClassLoader) {\n            @Override\n            public InputStream getResourceAsStream(String name) {\n                if (DOCUMENT_BUILDER_FACTORY_SERVICE.equals(name)) {\n                    requestedDocumentBuilderFactoryService.set(true);\n                    return new ByteArrayInputStream(\"com.example.MissingDocumentBuilderFactory\\n\"\n                            .getBytes(StandardCharsets.UTF_8));\n                }\n                return null;\n            }\n        };\n\n        try {\n            Thread.currentThread().setContextClassLoader(serviceClassLoader);\n\n            assertThatThrownBy(DocumentBuilderFactory::newInstance)\n                    .isInstanceOf(FactoryConfigurationError.class);\n            assertThat(requestedDocumentBuilderFactoryService).isTrue();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    public void fallsBackToSystemResourceLookupWithoutContextClassLoader() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        String originalFactoryProperty = System.getProperty(SAXParserFactory.class.getName());\n\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n            System.clearProperty(SAXParserFactory.class.getName());\n\n            try {\n                SAXParserFactory factory = SAXParserFactory.newInstance();\n                assertThat(factory).isNotNull();\n            } catch (FactoryConfigurationError error) {\n                assertThat(error.getMessage()).contains(SAXParserFactory.class.getName());\n            }\n        } finally {\n            restoreSystemProperty(SAXParserFactory.class.getName(), originalFactoryProperty);\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static void restoreSystemProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}
