CTORY_SERVICE,\n                \"com.example.MissingDocumentBuilderFactory\\n\");\n\n        try {\n            Thread.currentThread().setContextClassLoader(serviceClassLoader);\n\n            assertThatThrownBy(DocumentBuilderFactory::newInstance)\n                    .isInstanceOf(FactoryConfigurationError.class);\n            assertThat(serviceClassLoader.wasRequested()).isTrue();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    public void fallsBackToSystemResourceLookupWithoutContextClassLoader() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        String originalFactoryProperty = System.getProperty(SAXParserFactory.class.getName());\n\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n            System.clearProperty(SAXParserFactory.class.getName());\n\n            try {\n                SAXParserFactory factory = SAXParserFactory.newInstance();\n                assertThat(factory).isNotNull();\n            } catch (FactoryConfigurationError error) {\n                assertThat(error).isNotNull();\n            }\n        } finally {\n            restoreSystemProperty(SAXParserFactory.class.getName(), originalFactoryProperty);\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static void restoreSystemProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n\nclass ResourceTrackingClassLoader extends ClassLoader {\n    private final String resourceName;\n    private final String resourceContent;\n    private boolean requested;\n\n    ResourceTrackingClassLoader(ClassLoader parent, String resourceName, String resourceContent) {\n        super(parent);\n        this.resourceName = resourceName;\n        this.resourceContent = resourceContent;\n    }\n\n    @Override\n    public InputStream getResourceAsStream(String name) {\n        if (resourceName.equals(name)) {\n            requested = true;\n            return new ByteArrayInputStream(resourceContent.getBytes(StandardCharsets.UTF_8));\n        }\n        return null;\n    }\n\n    boolean wasRequested() {\n        return requested;\n    }\n}\n"}], "isError": false, "timestamp": 1777423177883}]}
