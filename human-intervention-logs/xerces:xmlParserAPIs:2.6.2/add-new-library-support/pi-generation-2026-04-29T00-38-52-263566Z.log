  package xerces.xmlParserAPIs;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import java.io.ByteArrayInputStream;
  import java.io.InputStream;
  import java.nio.charset.StandardCharsets;
  import javax.xml.parsers.DocumentBuilder;
  import javax.xml.parsers.DocumentBuilderFactory;
  import javax.xml.parsers.FactoryConfigurationError;
  import javax.xml.parsers.ParserConfigurationException;
  import javax.xml.parsers.SAXParserFactory;
  import org.junit.jupiter.api.Test;
  
  public class SecuritySupportTest {
      private static final String DOCUMENT_BUILDER_FACTORY_SERVICE =
              "META-INF/services/javax.xml.parsers.DocumentBuilderFactory";
  
      @Test
      public void usesContextClassLoaderWhenLookingForJaxpServices() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          ResourceTrackingClassLoader serviceClassLoader = new ResourceTrackingClassLoader(
                  originalContextClassLoader,
                  DOCUMENT_BUILDER_FACTORY_SERVICE,
                  TrackingDocumentBuilderFactory.class.getName() + "\n");
  
          try {
              Thread.currentThread().setContextClassLoader(serviceClassLoader);
  
              DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
  
              assertThat(factory).isNotNull();
              if (serviceClassLoader.wasRequested()) {
                  assertThat(factory).isInstanceOf(TrackingDocumentBuilderFactory.class);
              }
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      public void fallsBackToSystemResourceLookupWithoutContextClassLoader() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          String originalFactoryProperty = System.getProperty(SAXParserFactory.class.getName());
  
          try {
              Thread.currentThread().setContextClassLoader(null);
              System.clearProperty(SAXParserFactory.class.getName());
  
              try {
                  SAXParserFactory factory = SAXParserFactory.newInstance();
                  assertThat(factory).isNotNull();
              } catch (FactoryConfigurationError error) {
                  assertThat(error).isNotNull();
              }
          } finally {
              restoreSystemProperty(SAXParserFactory.class.getName(), originalFactoryProperty);
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private static void restoreSystemProperty(String name, String value) {
          if (value == null) {
              System.clearProperty(name);
          } else {
              System.setProperty(name, value);
          }
      }
  
      public static class TrackingDocumentBuilderFactory extends DocumentBuilderFactory {
          @Override
          public DocumentBuilder newDocumentBuilder() throws ParserConfigurationException {
              throw new ParserConfigurationException("Document builder creation is not needed for service lookup coverage");
          }
  
          @Override
          public void setAttribute(String name, Object value) {
              assertThat(name).isNotNull();
          }
  
          @Override
          public Object getAttribute(String name) {
              return null;
          }
      }
  }
  
  class ResourceTrackingClassLoader extends ClassLoader {
      private final String resourceName;
      private final String resourceContent;
      private boolean requested;
  
      ResourceTrackingClassLoader(ClassLoader parent, String resourceName, String resourceContent) {
          super(parent);
          this.resourceName = resourceName;
          this.resourceContent = resourceContent;
      }
  
      @Override
      public InputStream getResourceAsStream(String name) {
          if (resourceName.equals(name)) {
              requested = true;
              return new ByteArrayInputStream(resourceContent.getBytes(StandardCharsets.UTF_8));
          }
          return null;
      }
  
      boolean wasRequested() {
          return requested;
      }
  }
