  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "xerces:xmlParserAPIs:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  Provider<Directory> javaXmlPatchDir = layout.buildDirectory.dir("generated/javaXmlPatch")
  Provider<String> javaXmlPatchModuleArg = javaXmlPatchDir.map { directory ->
      "--patch-module=java.xml=${directory.asFile.absolutePath}"
  }
  Provider<String> nativeJavaXmlPatchModuleArg = javaXmlPatchDir.map { directory ->
      "-J--patch-module=java.xml=${directory.asFile.absolutePath}"
  }
  
  Provider<File> xmlParserApisJar = configurations.testRuntimeClasspath.elements.map { elements ->
      elements.collect { it.asFile }.find { it.name.startsWith("xmlParserAPIs-") && it.name.endsWith(".jar") }
  }
  
  TaskProvider<Copy> extractJavaXmlPatch = tasks.register("extractJavaXmlPatch", Copy) {
      from(xmlParserApisJar.map { jar -> zipTree(jar) }) {
          include "javax/xml/parsers/SecuritySupport*.class"
      }
      into(javaXmlPatchDir)
  }
  
  tasks.withType(Test).configureEach {
      dependsOn extractJavaXmlPatch
      doFirst {
          jvmArgs javaXmlPatchModuleArg.get(), "--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED"
      }
  }
  
  tasks.withType(org.graalvm.buildtools.gradle.tasks.BuildNativeImageTask).configureEach {
      dependsOn extractJavaXmlPatch
  }
  
  graalvmNative {
