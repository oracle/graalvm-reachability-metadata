   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "xerces:xmlParserAPIs:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  def javaXmlPatchDir = layout.buildDirectory.dir("javaXmlPatch")
  
  def xmlParserApisJar = providers.provider {
      configurations.testRuntimeClasspath.resolvedConfiguration.resolvedArtifacts.find { artifact ->
          artifact.moduleVersion.id.group == "xerces" && artifact.moduleVersion.id.name == "xmlParserAPIs"
      }.file
  }
  
  def extractJavaXmlPatch = tasks.register("extractJavaXmlPatch", Copy) {
      from({ zipTree(xmlParserApisJar.get()) }) {
          include "javax/xml/parsers/SecuritySupport*.class"
      }
      into javaXmlPatchDir
  }
  
  tasks.withType(Test).configureEach {
      dependsOn extractJavaXmlPatch
      jvmArgs += [
              "--patch-module=java.xml=${javaXmlPatchDir.get().asFile.absolutePath}",
              "--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED"
      ]
  }
  
  def isDynamicAccessReportRequested = {
      providers.gradleProperty("tck.generateDynamicAccessReport")
              .map { value -> value.toBoolean() }
              .getOrElse(false) || gradle.startParameter.taskNames.any { taskName ->
          taskName == "generateDynamicAccessReport" || taskName.endsWith(":generateDynamicAccessReport")
      }
  }
  
  tasks.named("nativeTestCompile") {
      dependsOn extractJavaXmlPatch
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add("--patch-module=java.xml=${javaXmlPatchDir.get().asFile.absolutePath}")
              buildArgs.add("--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED")
              if (isDynamicAccessReportRequested()) {
                  buildArgs.add("-H:Preserve=path=${javaXmlPatchDir.get().asFile.absolutePath}")
                  buildArgs.add("-H:TrackDynamicAccess=path=${javaXmlPatchDir.get().asFile.absolutePath}")
              }
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
