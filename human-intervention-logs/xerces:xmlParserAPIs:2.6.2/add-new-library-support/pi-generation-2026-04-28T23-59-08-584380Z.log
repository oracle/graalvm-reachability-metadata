              if (is == null) {
                  cl = FactoryFinder.class.getClassLoader();
                  is = ss.getResourceAsStream(cl, serviceId);
              }
          } else {
              // No Context ClassLoader or JDK 1.1 so try the current
              // ClassLoader
              cl = FactoryFinder.class.getClassLoader();
              is = ss.getResourceAsStream(cl, serviceId);
          }
  
