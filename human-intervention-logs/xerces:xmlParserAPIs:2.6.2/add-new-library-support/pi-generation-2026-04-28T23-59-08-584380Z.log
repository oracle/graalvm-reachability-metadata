  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "xerces:xmlParserAPIs:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  def javaXmlPatchDir = layout.buildDirectory.dir("javaXmlPatch")
  
  def extractJavaXmlPatch = tasks.register("extractJavaXmlPatch", Copy) {
      from({
          def xmlParserApisArtifacts = configurations.testRuntimeClasspath.resolvedConfiguration.resolvedArtifacts
          File xmlParserApisJar = xmlParserApisArtifacts.find { artifact ->
              artifact.moduleVersion.id.group == "xerces" && artifact.moduleVersion.id.name == "xmlParserAPIs"
          }.file
          zipTree(xmlParserApisJar)
      }) {
          include "javax/xml/parsers/SecuritySupport*.class"
      }
      into javaXmlPatchDir
  }
  
  tasks.withType(Test).configureEach {
      dependsOn extractJavaXmlPatch
      jvmArgs += [
              "--patch-module=java.xml=${javaXmlPatchDir.get().asFile.absolutePath}",
              "--add-opens=java.xml/javax.xml.parsers=ALL-UNNAMED"
      ]
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
