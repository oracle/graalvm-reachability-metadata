[tool-call] delta {"path":"tests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/SecuritySupportTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage xerces.xmlParserAPIs;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.InputStream;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\nimport java.nio.charset.StandardCharsets;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SecuritySupportTest {\n    private static final String RESOURCE_NAME = \"xerces/xmlParserAPIs/security-support.resource\";\n    private static final String RESOURCE_CONTENT = \"security-support-resource\\n\";\n\n    @Test\n    void getResourceAsStreamUsesProvidedClassLoader() throws Exception {\n        Object securitySupport = newSecuritySupport();\n\n        try (InputStream stream = getResourceAsStream(\n                securitySupport,\n                SecuritySupportTest.class.getClassLoader(),\n                RESOURCE_NAME)) {\n            assertResourceContent(stream);\n        }\n    }\n\n    @Test\n    void getResourceAsStreamUsesSystemClassLoaderWhenClassLoaderIsNull() throws Exception {\n        Object securitySupport = newSecuritySupport();\n\n        try (InputStream stream = getResourceAsStream(securitySupport, null, RESOURCE_NAME)) {\n            assertResourceContent(stream);\n        }\n    }\n\n    private static Object newSecuritySupport() throws Exception {\n        Class<?> securitySupportClass = Class.forName(\"javax.xml.parsers.SecuritySupport\");\n        Constructor<?> constructor = securitySupportClass.getDeclaredConstructor();\n        constructor.setAccessible(true);\n        return constructor.newInstance();\n    }\n\n    private static InputStream getResourceAsStream(Object securitySupport, ClassLoader classLoader, String name)\n            throws Exception {\n        Method method = securitySupport.getClass().getDeclaredMethod(\n                \"getResourceAsStream\",\n                ClassLoader.class,\n                String.class);\n        method.setAccessible(true);\n        return (InputStream) method.invoke(securitySupport, classLoader, name);\n    }\n\n    private static void assertResourceContent(InputStream stream) throws Exception {\n        assertThat(stream).isNotNull();\n        assertThat(new String(stream.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(RESOURCE_CONTENT);\n    }\n}\n"}
