[tool-call] delta {"path":"tests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/SecuritySupportTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage xerces.xmlParserAPIs;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.HashMap;\nimport java.util.Map;\n\nimport javax.xml.parsers.DocumentBuilder;\nimport javax.xml.parsers.DocumentBuilderFactory;\nimport javax.xml.parsers.ParserConfigurationException;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SecuritySupportTest extends DocumentBuilderFactory {\n    private static final String DOCUMENT_BUILDER_FACTORY_ID = \"javax.xml.parsers.DocumentBuilderFactory\";\n\n    private final Map<String, Object> attributes = new HashMap<>();\n\n    @Test\n    void factoryDiscoveryReadsServiceResourceFromContextClassLoader() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            Thread.currentThread().setContextClassLoader(SecuritySupportTest.class.getClassLoader());\n\n            DocumentBuilderFactory factory = newDocumentBuilderFactoryWithoutSystemProperty();\n\n            assertThat(factory).isInstanceOf(SecuritySupportTest.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void factoryDiscoveryReadsServiceResourceWithoutContextClassLoader() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n\n            DocumentBuilderFactory factory = newDocumentBuilderFactoryWithoutSystemProperty();\n\n            assertThat(factory).isInstanceOf(SecuritySupportTest.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Override\n    public DocumentBuilder newDocumentBuilder() throws ParserConfigurationException {\n        throw new ParserConfigurationException(\"The provider lookup test does not build parsers\");\n    }\n\n    @Override\n    public void setAttribute(String name, Object value) throws IllegalArgumentException {\n        attributes.put(name, value);\n    }\n\n    @Override\n    public Object getAttribute(String name) throws IllegalArgumentException {\n        if (!attributes.containsKey(name)) {\n            throw new IllegalArgumentException(\"Unknown attribute: \" + name);\n        }\n        return attributes.get(name);\n    }\n\n    private static DocumentBuilderFactory newDocumentBuilderFactoryWithoutSystemProperty() {\n        String originalFactoryProperty = System.getProperty(DOCUMENT_BUILDER_FACTORY_ID);\n        try {\n            System.clearProperty(DOCUMENT_BUILDER_FACTORY_ID);\n            return DocumentBuilderFactory.newInstance();\n        } finally {\n            restoreSystemProperty(DOCUMENT_BUILDER_FACTORY_ID, originalFactoryProperty);\n        }\n    }\n\n    private static void restoreSystemProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}
