ed via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage xerces.xmlParserAPIs;\n\nimport static java.nio.charset.StandardCharsets.UTF_8;\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SecuritySupportTest {\n    private static final String SECURITY_SUPPORT_CLASS = \"javax.xml.parsers.SecuritySupport\";\n    private static final String RESOURCE_NAME = \"xerces/xmlParserAPIs/security-support-resource.txt\";\n    private static final String RESOURCE_CONTENT = \"resource loaded through explicit class loader\";\n\n    @Test\n    void getResourceAsStreamUsesProvidedClassLoader() throws Exception {\n        RecordingResourceClassLoader classLoader = new RecordingResourceClassLoader();\n        try (InputStream stream = getResourceAsStream(classLoader, RESOURCE_NAME)) {\n            assertThat(stream).isNotNull();\n            assertThat(new String(stream.readAllBytes(), UTF_8)).isEqualTo(RESOURCE_CONTENT);\n        }\n\n        assertThat(classLoader.requestedResourceName).isEqualTo(RESOURCE_NAME);\n    }\n\n    @Test\n    void getResourceAsStreamUsesSystemResourcesWhenClassLoaderIsNull() throws Exception {\n        try (InputStream stream = getResourceAsStream(null, \"xerces/xmlParserAPIs/missing-resource.txt\")) {\n            assertThat(stream).isNull();\n        }\n    }\n\n    private static InputStream getResourceAsStream(ClassLoader classLoader, String resourceName) throws Exception {\n        Object securitySupport = newSecuritySupport();\n        Method getResourceAsStream = securitySupport.getClass()\n                .getDeclaredMethod(\"getResourceAsStream\", ClassLoader.class, String.class);\n        getResourceAsStream.setAccessible(true);\n        return (InputStream) getResourceAsStream.invoke(securitySupport, classLoader, resourceName);\n    }\n\n    private static Object newSecuritySupport() throws Exception {\n        Class<?> securitySupportClass = Class.forName(SECURITY_SUPPORT_CLASS);\n        Constructor<?> constructor = securitySupportClass.getDeclaredConstructor();\n        constructor.setAccessible(true);\n        return constructor.newInstance();\n    }\n\n    private static final class RecordingResourceClassLoader extends ClassLoader {\n        private String requestedResourceName;\n\n        private RecordingResourceClassLoader() {\n            super(SecuritySupportTest.class.getClassLoader());\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            requestedResourceName = name;\n            if (RESOURCE_NAME.equals(name)) {\n                return new ByteArrayInputStream(RESOURCE_CONTENT.getBytes(UTF_8));\n            }\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 945, "output": 1080, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 44009, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777679855981, "responseId": "resp_0fb42abf585d89e00169f53df09424819eaad744ed7db52c4f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_E2ECw5gOnBWNIdqYscV6T3HE|fc_0fb42abf585d89e00169f53df6ccd0819ebcaf5069e81aa128", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2973 bytes to tests/src/xerces/xmlParserAPIs/2.6.2/src/test/java/xerces/xmlParserAPIs/SecuritySupportTest.java"}], "isError": false, "timestamp": 1777679867849}]}
