  package xerces.xmlParserAPIs;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.InputStream;
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.List;
  
  import javax.xml.parsers.DocumentBuilderFactory;
  import javax.xml.parsers.FactoryConfigurationError;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class SecuritySupportTest {
      private static final String DOCUMENT_BUILDER_FACTORY_ID = "javax.xml.parsers.DocumentBuilderFactory";
      private static final String DOCUMENT_BUILDER_FACTORY_SERVICE = "META-INF/services/"
              + DOCUMENT_BUILDER_FACTORY_ID;
  
      @Test
      void factoryDiscoveryReadsServiceResourceFromContextClassLoader() {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          RecordingResourceClassLoader recordingClassLoader = new RecordingResourceClassLoader(originalClassLoader);
          Thread.currentThread().setContextClassLoader(recordingClassLoader);
          Boolean factoryAvailable;
          try {
              factoryAvailable = lookupDocumentBuilderFactory();
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
  
          assertThat(factoryAvailable == null
                  || factoryAvailable
                  || recordingClassLoader.resourceNames().contains(DOCUMENT_BUILDER_FACTORY_SERVICE))
                  .isTrue();
      }
  
      @Test
      void factoryDiscoveryStillRunsWhenContextClassLoaderIsUnavailable() {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(null);
          try {
              assertThat(lookupDocumentBuilderFactory()).isIn(true, false, null);
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      private static Boolean lookupDocumentBuilderFactory() {
          String originalProvider = System.getProperty(DOCUMENT_BUILDER_FACTORY_ID);
          System.clearProperty(DOCUMENT_BUILDER_FACTORY_ID);
          try {
              DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
              assertThat(factory).isNotNull();
              return true;
          } catch (FactoryConfigurationError error) {
              assertThat(error.getMessage()).isNotBlank();
              return false;
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
              return null;
          } finally {
              restoreProperty(originalProvider);
          }
      }
  
      private static void restoreProperty(String originalProvider) {
          if (originalProvider == null) {
              System.clearProperty(DOCUMENT_BUILDER_FACTORY_ID);
          } else {
              System.setProperty(DOCUMENT_BUILDER_FACTORY_ID, originalProvider);
          }
      }
  
      private static final class RecordingResourceClassLoader extends ClassLoader {
          private final List<String> resourceNames = new ArrayList<>();
  
          private RecordingResourceClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public InputStream getResourceAsStream(String name) {
              resourceNames.add(name);
              return null;
          }
  
          private List<String> resourceNames() {
              return Collections.unmodifiableList(resourceNames);
          }
      }
  }
