  public class SecuritySupport12Anonymous4Test {
      private static final String SECURITY_SUPPORT12_CLASS = "javax.xml.parsers.SecuritySupport12";
      private static final String RESOURCE_NAME = "xerces/xmlParserAPIs/security-support12-resource.txt";
      private static final String MISSING_RESOURCE_NAME = "xerces/xmlParserAPIs/missing-security-support12-resource.txt";
  
      @Test
      void getResourceAsStreamUsesProvidedClassLoader() throws Exception {
          try {
              Object securitySupport = newSecuritySupport12();
              Method getResourceAsStream = getResourceAsStreamMethod(securitySupport);
              ResourceClassLoader classLoader = new ResourceClassLoader();
  
              try (InputStream resource = (InputStream) getResourceAsStream.invoke(
