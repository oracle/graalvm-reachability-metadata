  import jakarta.faces.convert.NumberConverter;
  import jakarta.faces.lifecycle.Lifecycle;
  import jakarta.faces.render.RenderKit;
  
  public class NumberConverterTest {
      @Test
      void formatsCurrencyByCurrencyCode() {
          NumberConverter converter = new NumberConverter();
          converter.setLocale(Locale.US);
          converter.setType("currency");
          converter.setCurrencyCode("EUR");
  
          String formatted = converter.getAsString(new MinimalFacesContext(), new UIOutput(), 1234.56);
  
          assertThat(formatted).contains(Currency.getInstance("EUR").getSymbol(Locale.US));
          assertThat(formatted).contains("1,234.56");
      }
  
