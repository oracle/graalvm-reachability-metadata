t jakarta.faces.render.RenderKit;\n\npublic class MessageFactoryTest {\n    private static final String USER_BUNDLE_NAME = \"jakarta_faces.jakarta_faces_api.UserMessages\";\n    private static final String SELECT_ONE_INVALID = \"jakarta.faces.component.UISelectOne.INVALID\";\n\n    @Test\n    void resolvesComponentMessageFromMojarraBundleAfterUserAndStandardMisses() {\n        Map<String, String> bundles = Map.of(\n                \"jakarta_faces/jakarta_faces_api/UserMessages.properties\", \"unused=User bundle loaded\\n\",\n                \"jakarta/faces/Messages.properties\", \"unused=Standard bundle loaded\\n\",\n                \"com/sun/faces/resources/Messages.properties\",\n                SELECT_ONE_INVALID + \"={0}: Mojarra fallback selection message\\n\");\n\n        try (ResourceBundleClassLoader ignored = new ResourceBundleClassLoader(bundles);\n                TestFacesContext context = new TestFacesContext(new TestApplication(USER_BUNDLE_NAME))) {\n            UISelectOne selectOne = new UISelectOne();\n            selectOne.setId(\"choice\");\n            selectOne.setRendererType(null);\n            selectOne.getAttributes().put(\"label\", \"Choice\");\n            selectOne.setSubmittedValue(\"not-an-option\");\n\n            selectOne.validate(context);\n\n            assertThat(selectOne.isValid()).isFalse();\n            assertThat(context.messages()).hasSize(1);\n            assertThat(context.messages().get(0).getSummary()).isEqualTo(\"Choice: Mojarra fallback selection message\");\n        }\n    }\n\n    private static final class TestApplication extends ApplicationWrapper {\n        private final String messageBundle;\n\n        private TestApplication(String messageBundle) {\n            this.messageBundle = messageBundle;\n        }\n\n        @Override\n        public String getMessageBundle() {\n            return messageBundle;\n        }\n    }\n\n    private static final class TestFacesContext extends FacesContext implements AutoCloseable {\n        private final Application application;\n        private final ExternalContext externalContext = new TestExternalContext();\n        private final UIViewRoot viewRoot = new UIViewRoot();\n        private final List<FacesMessage> messages = new ArrayList<>();\n\n        private TestFacesContext(Application application) {\n            this.application = application;\n            viewRoot.setLocale(Locale.ROOT);\n            setCurrentInstance(this);\n        }\n\n        private List<FacesMessage> messages() {\n            return messages;\n        }\n\n        @Override\n        public Application getApplication() {\n            return application;\n        }\n\n        @Override\n        public Iterator<String> getClientIdsWithMessages() {\n            return Collections.emptyIterator();\n        }\n\n        @Override\n        public Lifecycle getLifecycle() {\n            return null;\n        }\n\n        @Override\n        public ExternalContext getExternalContext() {\n            return externalContext;\n        }\n\n        @Override\n        public Severity getMaximumSeverity() {\n            return FacesMessage.SEVERITY_ERROR;\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages() {\n            return messages.iterator();\n        }\n\n        @Override\n        public Iterator<FacesMessage> getMessages(String clientId) {\n            return messages.iterator();\n        }\n\n        @Override\n        public RenderKit getRenderKit() {\n            return null;\n        }\n\n        @Override\n        public boolean getRenderResponse() {\n            return false;\n        }\n\n        @Override\n        public boolean getResponseComplete() {\n            return false;\n        }\n\n        @Override\n        public ResponseStream getResponseStream() {\n            return null;\n        }\n\n        @Override\n        public void setResponseStream(ResponseStream responseStream) {\n        }\n\n        @Override\n        public ResponseWriter getResponseWriter() {\n            return null;\n        }\n\n        @Override\n        public void setResponseWriter(ResponseWriter responseWriter) {\n        }\n\n        @Override\n        public UIViewRoot getViewRoot() {\n            return viewRoot;\n        }\n\n        @Override\n        public void setViewRoot(UIViewRoot root) {\n        }\n\n        @Override\n        public void addMessage(String clientId, FacesMessage message) {\n            messages.add(message);\n        }\n\n        @Override\n        public void release() {\n            setCurrentInstance(null);\n        }\n\n        @Override\n        public void renderResponse() {\n        }\n\n        @Override\n        public void responseComplete() {\n        }\n\n        @Override\n        public void close() {\n            release();\n        }\n    }\n\n    private static final class TestExternalContext extends ExternalContextWrapper {\n        @Override\n        public String getInitParameter(String name) {\n            return null;\n        }\n\n        @Override\n        public Map<String, Object> getApplicationMap() {\n            return Collections.emptyMap();\n        }\n    }\n\n    private static final class ResourceBundleClassLoader extends ClassLoader implements AutoCloseable {\n        private final ClassLoader previousContextClassLoader;\n        private final Map<String, byte[]> resources;\n\n        private ResourceBundleClassLoader(Map<String, String> resources) {\n            super(MessageFactoryTest.class.getClassLoader());\n            previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n            this.resources = encode(resources);\n            Thread.currentThread().setContextClassLoader(this);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            URL resource = inMemoryResource(name);\n            if (resource != null) {\n                return resource;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            URL resource = inMemoryResource(name);\n            if (resource != null) {\n                return Collections.enumeration(List.of(resource));\n            }\n            return super.getResources(name);\n        }\n\n        @Override\n        public void close() {\n            ResourceBundle.clearCache(this);\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n\n        private static Map<String, byte[]> encode(Map<String, String> resources) {\n            return resources.entrySet().stream()\n                    .collect(Collectors.toUnmodifiableMap(\n                            Map.Entry::getKey,\n                            entry -> entry.getValue().getBytes(StandardCharsets.UTF_8)));\n        }\n\n        private URL inMemoryResource(String name) {\n            byte[] bytes = resources.get(name);\n            if (bytes == null) {\n                return null;\n            }\n\n[31 more lines in file. Use offset=261 to continue.]"}], "isError": false, "timestamp": 1778330559148}]}
