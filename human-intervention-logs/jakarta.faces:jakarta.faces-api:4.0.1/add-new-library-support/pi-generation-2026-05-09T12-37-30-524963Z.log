ull;\n        ZeroArgumentLifecycleFactory.created = 0;\n    }\n\n    public static class ConfiguredLifecycleFactory extends TestLifecycleFactory {\n        static int created;\n\n        public ConfiguredLifecycleFactory() {\n            created++;\n        }\n    }\n\n    public static class ServiceLifecycleFactory extends TestLifecycleFactory {\n        static int created;\n        static LifecycleFactory previous;\n\n        public ServiceLifecycleFactory(LifecycleFactory previous) {\n            created++;\n            ServiceLifecycleFactory.previous = previous;\n        }\n    }\n\n    public static class ZeroArgumentLifecycleFactory extends TestLifecycleFactory {\n        static int created;\n\n        public ZeroArgumentLifecycleFactory() {\n            created++;\n        }\n    }\n\n    public abstract static class TestLifecycleFactory extends LifecycleFactory {\n        @Override\n        public void addLifecycle(String lifecycleId, Lifecycle lifecycle) {\n            throw new UnsupportedOperationException(\"The test only exercises factory discovery.\");\n        }\n\n        @Override\n        public Lifecycle getLifecycle(String lifecycleId) {\n            throw new UnsupportedOperationException(\"The test only exercises factory discovery.\");\n        }\n\n        @Override\n        public Iterator<String> getLifecycleIds() {\n            return Collections.singletonList(LifecycleFactory.DEFAULT_LIFECYCLE).iterator();\n        }\n    }\n}\n"}
