[tool-call] delta {"path":"tests/src/jakarta.faces/jakarta.faces-api/4.0.1/src/test/java/jakarta_faces/jakarta_faces_api/FactoryFinderInstanceTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_faces.jakarta_faces_api;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Collections;\nimport java.util.Iterator;\n\nimport org.junit.jupiter.api.Test;\n\nimport jakarta.faces.FactoryFinder;\nimport jakarta.faces.lifecycle.Lifecycle;\nimport jakarta.faces.lifecycle.LifecycleFactory;\n\npublic class FactoryFinderInstanceTest {\n    @Test\n    void buildsConfiguredServiceAndDecoratorLifecycleFactories() {\n        resetFactoryCounters();\n\n        try {\n            FactoryFinder.setFactory(FactoryFinder.LIFECYCLE_FACTORY, ConfiguredLifecycleFactory.class.getName());\n            FactoryFinder.setFactory(FactoryFinder.LIFECYCLE_FACTORY, ZeroArgumentLifecycleFactory.class.getName());\n\n            Object factory = FactoryFinder.getFactory(FactoryFinder.LIFECYCLE_FACTORY);\n\n            assertThat(factory).isInstanceOf(ZeroArgumentLifecycleFactory.class);\n            assertThat(ConfiguredLifecycleFactory.created).isEqualTo(1);\n            assertThat(ServiceLifecycleFactory.created).isEqualTo(1);\n            assertThat(ServiceLifecycleFactory.previous).isInstanceOf(ConfiguredLifecycleFactory.class);\n            assertThat(ZeroArgumentLifecycleFactory.created).isEqualTo(1);\n        } finally {\n            FactoryFinder.releaseFactories();\n        }\n    }\n\n    private static void resetFactoryCounters() {\n        ConfiguredLifecycleFactory.created = 0;\n        ServiceLifecycleFactory.created = 0;\n        ServiceLifecycleFactory.previous = null;\n        ZeroArgumentLifecycleFactory.created = 0;\n    }\n\n    public static class ConfiguredLifecycleFactory extends TestLifecycleFactory {\n        static int created;\n\n        public ConfiguredLifecycleFactory() {\n            created++;\n        }\n    }\n\n    public static class ServiceLifecycleFactory extends TestLifecycleFactory {\n        static int created;\n        static LifecycleFactory previous;\n\n        public ServiceLifecycleFactory(LifecycleFactory previous) {\n            created++;\n            ServiceLifecycleFactory.previous = previous;\n        }\n    }\n\n    public static class ZeroArgumentLifecycleFactory extends TestLifecycleFactory {\n        static int created;\n\n        public ZeroArgumentLifecycleFactory() {\n            created++;\n        }\n    }\n\n    public abstract static class TestLifecycleFactory extends LifecycleFactory {\n        @Override\n        public void addLifecycle(String lifecycleId, Lifecycle lifecycle) {\n            throw new UnsupportedOperationException(\"The test only exercises factory discovery.\");\n        }\n\n        @Override\n        public Lifecycle getLifecycle(String lifecycleId) {\n            throw new UnsupportedOperationException(\"The test only exercises factory discovery.\");\n        }\n\n        @Override\n        public Iterator<String> getLifecycleIds() {\n            return Collections.singletonList(LifecycleFactory.DEFAULT_LIFECYCLE).iterator();\n        }\n    }\n}\n"}
