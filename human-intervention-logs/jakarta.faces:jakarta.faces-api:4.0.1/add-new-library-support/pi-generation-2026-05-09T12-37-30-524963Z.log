  import jakarta.faces.context.FacesContext;
  
  public class ServletContextFacesContextFactoryTest {
      @Test
      void currentInstanceConsultsServletContextAwareFactoryWhenNoFacesContextIsBound() {
          assertThat(Thread.currentThread().getContextClassLoader()).isNotNull();
  
          FacesContext currentInstance = FacesContext.getCurrentInstance();
  
          assertThat(currentInstance).isNull();
      }
  }
