  +            contentType = contentType,
  +            charset = StandardCharsets.UTF_16,
  +            typeInfo = typeInfo<Message>(),
  +            value = Message("encoded", 7),
  +        )
  +
  +        assertThat(outgoingContent).isInstanceOf(TextContent::class.java)
