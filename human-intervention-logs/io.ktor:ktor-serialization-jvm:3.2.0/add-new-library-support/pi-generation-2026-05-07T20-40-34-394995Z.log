pes).containsExactly(Message::class)\n        assertThat(messageConverter.deserializationCharsets).containsExactly(StandardCharsets.UTF_8)\n        assertThat(converterAfterMatch.deserializeCalls).isZero()\n    }\n\n    @Test\n    public fun contentConvertersReturnUnreadBodyWhenNoConverterHandlesPayload(): Unit = runSuspendTest {\n        val converter = SkippingContentConverter()\n        val payload = \"unconverted-body\"\n        val body = ByteReadChannel(payload.toByteArray(StandardCharsets.UTF_8))\n\n        val result = listOf(converter).deserialize(\n            body,\n            typeInfo<Message>(),\n            StandardCharsets.UTF_8,\n        )\n\n        assertThat(result).isSameAs(body)\n        assertThat(String((result as ByteReadChannel).toByteArray(), StandardCharsets.UTF_8)).isEqualTo(payload)\n        assertThat(converter.deserializeCalls).isEqualTo(1)\n    }\n", "newText": "\n"}, {"oldText": "\nprivate class SkippingContentConverter : ContentConverter {\n    var deserializeCalls: Int = 0\n        private set\n\n    override suspend fun serialize(\n        contentType: ContentType,\n        charset: Charset,\n        typeInfo: TypeInfo,\n        value: Any?,\n    ): OutgoingContent? = null\n\n    override suspend fun deserialize(\n        charset: Charset,\n        typeInfo: TypeInfo,\n        content: ByteReadChannel,\n    ): Any? {\n        deserializeCalls++\n        return null\n    }\n}\n", "newText": "\n"}]}
