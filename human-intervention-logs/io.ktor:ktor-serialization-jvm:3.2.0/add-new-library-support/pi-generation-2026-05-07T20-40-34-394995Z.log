[tool-call] delta {"path":"tests/src/io.ktor/ktor-serialization-jvm/3.2.0/src/test/kotlin/io_ktor/ktor_serialization_jvm/Ktor_serialization_jvmTest.kt","edits":[{"oldText":"    @Test\n    public fun contentConverterDeserializesChannelWithRequestedCharset(): Unit = runSuspendTest {\n        val converter = MessageContentConverter()\n        val payload = \"name=decoded;count=11\"\n\n        val decoded = converter.deserialize(\n            charset = StandardCharsets.UTF_16,\n            typeInfo = typeInfo<Message>(),\n            content = ByteReadChannel(payload.toByteArray(StandardCharsets.UTF_16)),\n        )\n\n        assertThat(decoded).isEqualTo(Message(\"decoded\", 11))\n        assertThat(converter.deserializedTypes).containsExactly(Message::class)\n        assertThat(converter.deserializationCharsets).containsExactly(StandardCharsets.UTF_16)\n    }\n\n    @Test\n    public fun websocketConverterReifiedExtensionsRoundTripTextFrame(): Unit = runSuspendTest {","newText":"    @Test\n    public fun contentConverterDeserializesChannelWithRequestedCharset(): Unit = runSuspendTest {\n        val converter = MessageContentConverter()\n        val payload = \"name=decoded;count=11\"\n\n        val decoded = converter.deserialize(\n            charset = StandardCharsets.UTF_16,\n            typeInfo = typeInfo<Message>(),\n            content = ByteReadChannel(payload.toByteArray(StandardCharsets.UTF_16)),\n        )\n\n        assertThat(decoded).isEqualTo(Message(\"decoded\", 11))\n        assertThat(converter.deserializedTypes).containsExactly(Message::class)\n        assertThat(converter.deserializationCharsets).containsExactly(StandardCharsets.UTF_16)\n    }\n\n    @Test\n    public fun contentConvertersDeserializeWithFirstConverterThatHandlesPayload(): Unit = runSuspendTest {\n        val skippedConverter = SkippingContentConverter()\n        val messageConverter = MessageContentConverter()\n        val converterAfterMatch = SkippingContentConverter()\n        val payload = \"name=selected;count=23\"\n        val converters = listOf(skippedConverter, messageConverter, converterAfterMatch)\n\n        val decoded = converters.deserialize(\n            ByteReadChannel(payload.toByteArray(StandardCharsets.UTF_8)),\n            typeInfo<Message>(),\n            StandardCharsets.UTF_8,\n        )\n\n        assertThat(decoded).isEqualTo(Message(\"selected\", 23))\n        assertThat(skippedConverter.deserializeCalls).isEqualTo(1)\n        assertThat(messageConverter.deserializedTypes).containsExactly(Message::class)\n        assertThat(messageConverter.deserializationCharsets).containsExactly(StandardCharsets.UTF_8)\n        assertThat(converterAfterMatch.deserializeCalls).isZero()\n    }\n\n    @Test\n    public fun contentConvertersReturnUnreadBodyWhenNoConverterHandlesPayload(): Unit = runSuspendTest {\n        val converter = SkippingContentConverter()\n        val payload = \"unconverted-body\"\n        val body = ByteReadChannel(payload.toByteArray(StandardCharsets.UTF_8))\n\n        val result = listOf(converter).deserialize(\n            body,\n            typeInfo<Message>(),\n            StandardCharsets.UTF_8,\n        )\n\n        assertThat(result).isSameAs(body)\n        assertThat(String((result as ByteReadChannel).toByteArray(), StandardCharsets.UTF_8)).isEqualTo(payload)\n        assertThat(converter.deserializeCalls).isEqualTo(1)\n    }\n\n    @Test\n    public fun websocketConverterReifiedExtensionsRoundTripTextFrame(): Unit = runSuspendTest {"},{"oldText":"private class ConfigurableContentConverter : ContentConverter {\n    var prefix: String = \"unset\"\n\n    override suspend fun serialize(\n        contentType: ContentType,\n        charset: Charset,\n        typeInfo: TypeInfo,\n        value: Any?,\n    ): OutgoingContent? = null\n\n    override suspend fun deserialize(\n        charset: Charset,\n        typeInfo: TypeInfo,\n        content: ByteReadChannel,\n    ): Any? = null\n}\n\nprivate class MessageContentConverter : ContentConverter {","newText":"private class ConfigurableContentConverter : ContentConverter {\n    var prefix: String = \"unset\"\n\n    override suspend fun serialize(\n        contentType: ContentType,\n        charset: Charset,\n        typeInfo: TypeInfo,\n        value: Any?,\n    ): OutgoingContent? = null\n\n    override suspend fun deserialize(\n        charset: Charset,\n        typeInfo: TypeInfo,\n        content: ByteReadChannel,\n    ): Any? = null\n}\n\nprivate class SkippingContentConverter : ContentConverter {\n    var deserializeCalls: Int = 0\n        private set\n\n    override suspend fun serialize(\n        contentType: ContentType,\n        charset: Charset,\n        typeInfo: TypeInfo,\n        value: Any?,\n    ): OutgoingContent? = null\n\n    override suspend fun deserialize(\n        charset: Charset,\n        typeInfo: TypeInfo,\n        content: ByteReadChannel,\n    ): Any? {\n        deserializeCalls++\n        return null\n    }\n}\n\nprivate class MessageContentConverter : ContentConverter {"}]}
