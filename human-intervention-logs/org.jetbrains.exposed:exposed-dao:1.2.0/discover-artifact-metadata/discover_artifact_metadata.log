              "name": {
                "const": "kotlin"
              }
            },
            "required": [ "name" ]
          },
          "then": {
            "properties": {
              "version": {
                "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
              }
            }
          }
        }
      ]
    }
  },
  "examples": [
    [
