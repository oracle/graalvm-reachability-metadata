    "libraryLanguage": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "name", "version" ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [ "kotlin", "scala" ]
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
