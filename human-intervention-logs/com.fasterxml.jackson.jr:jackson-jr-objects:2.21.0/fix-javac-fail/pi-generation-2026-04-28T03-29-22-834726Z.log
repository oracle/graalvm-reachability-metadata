[tool-call] delta {"path":"tests/src/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/src/test/java/com_fasterxml_jackson_jr/jackson_jr_objects/MapBuilderDefaultDynamicAccessTest.java","edits":[{"oldText":"import com.fasterxml.jackson.jr.ob.JSON;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MapBuilderDefaultDynamicAccessTest {\n    @Test\n    void readsEmptyObjectsIntoConfiguredTypedMapImplementations() throws Exception {\n        CountsMap counts = JSON.std.beanFrom(CountsMap.class, \"{}\");\n\n        assertThat(counts).isInstanceOf(CountsMap.class).isEmpty();\n    }\n\n    @Test\n    void readsSingletonObjectsIntoConfiguredTypedMapImplementations() throws Exception {\n        CountsMap counts = JSON.std.beanFrom(CountsMap.class, \"{\\\"only\\\":99}\");\n\n        assertThat(counts).isInstanceOf(CountsMap.class);\n        assertThat(counts).containsEntry(\"only\", 99);\n    }\n\n    @Test\n    void readsMultiEntryObjectsIntoConfiguredTypedMapImplementations() throws Exception {\n        CountsMap counts = JSON.std.beanFrom(CountsMap.class, \"{\\\"alpha\\\":1,\\\"beta\\\":2}\");\n\n        assertThat(counts).isInstanceOf(CountsMap.class);\n        assertThat(counts).containsEntry(\"alpha\", 1).containsEntry(\"beta\", 2);\n    }\n","newText":"import com.fasterxml.jackson.jr.ob.JSON;\nimport com.fasterxml.jackson.jr.ob.api.MapBuilder;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MapBuilderDefaultDynamicAccessTest {\n    private static final JSON JSON_WITH_COUNTS_MAPS = JSON.std.with(MapBuilder.defaultImpl().newBuilder(CountsMap.class));\n\n    @Test\n    void readsEmptyObjectsIntoConfiguredMapImplementations() throws Exception {\n        Object counts = JSON_WITH_COUNTS_MAPS.mapFrom(\"{}\");\n\n        assertThat(counts).isInstanceOf(CountsMap.class).asInstanceOf(org.assertj.core.api.InstanceOfAssertFactories.MAP).isEmpty();\n    }\n\n    @Test\n    void readsSingletonObjectsIntoConfiguredMapImplementations() throws Exception {\n        Object counts = JSON_WITH_COUNTS_MAPS.mapFrom(\"{\\\"only\\\":99}\");\n\n        assertThat(counts).isInstanceOf(CountsMap.class);\n        assertThat((CountsMap) counts).containsEntry(\"only\", 99);\n    }\n\n    @Test\n    void readsMultiEntryObjectsIntoConfiguredMapImplementations() throws Exception {\n        Object counts = JSON_WITH_COUNTS_MAPS.mapFrom(\"{\\\"alpha\\\":1,\\\"beta\\\":2}\");\n\n        assertThat(counts).isInstanceOf(CountsMap.class);\n        assertThat((CountsMap) counts).containsEntry(\"alpha\", 1).containsEntry(\"beta\", 2);\n    }\n"}]}
