jr-objects/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/jr/jackson-jr-objects/$version$/jackson-jr-objects-$version$-sources.jar\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/jr/jackson-jr-objects/$version$/jackson-jr-objects-$version$-javadoc.jar\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:9:    \"description\" : \"Jackson Jr Objects is a lightweight data-binding module for reading JSON into maps, lists, strings, wrapper types, arrays, and Java beans, and for writing those values back as JSON. It builds on jackson-core with minimal dependencies and provides immutable JSON entry points plus builder-style composer APIs for direct JSON output.\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:19:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/jr/jackson-jr-objects/$version$/jackson-jr-objects-$version$-sources.jar\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:22:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/jr/jackson-jr-objects/$version$/jackson-jr-objects-$version$-javadoc.jar\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:23:    \"description\" : \"Jackson Jr Objects is a lightweight data-binding module for reading JSON into maps, lists, strings, wrapper types, arrays, and Java beans, and for writing those values back as JSON. It builds on jackson-core with minimal dependencies and provides immutable JSON entry points plus builder-style composer APIs for direct JSON output.\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:52:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/jr/jackson-jr-objects/$version$/jackson-jr-objects-$version$-sources.jar\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:55:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/fasterxml/jackson/jr/jackson-jr-objects/$version$/jackson-jr-objects-$version$-javadoc.jar\",\nmetadata/com.fasterxml.jackson.jr/jackson-jr-objects/index.json:56:    \"description\" : \"Jackson Jr Objects is a lightweight data-binding module for reading JSON into maps, lists, strings, wrappers, and Java beans, and for writing those values back as JSON. It builds directly on jackson-core with minimal dependencies and also includes builder-style APIs for composing JSON output.\",\nmetadata/org.codehaus.jackson/jackson-core-asl/index.json:9:    \"description\" : \"Jackson Core ASL 1.x provides the streaming JSON parser and generator APIs used by the original Jackson JSON processor. It lets Java applications read and write JSON content efficiently and forms the lower-level core used by Jackson's data-binding modules.\",\nmetadata/ch.qos.logback.contrib/logback-jackson/0.1.5/reachability-metadata.json:7:      \"type\": \"ch.qos.logback.contrib.jackson.JacksonJsonFormatter\",\nmetadata/ch.qos.logback.contrib/logback-jackson/index.json:12:    \"description\": \"logback-jackson provides a Jackson-based implementation of Logback Contrib's JSON formatter API. It converts log event data maps into JSON strings and supports optional pretty-printing through Jackson.\",\nmetadata/io.dropwizard.metrics/metrics-json/index.json:9:    \"description\" : \"Metrics JSON provides Jackson integration for Dropwizard Metrics. It serializes metric registries, gauges, counters, histograms, meters, timers, and health-check results into JSON-friendly structures.\",\nmetadata/com.fasterxml.jackson.datatype/jackson-datatype-jdk8/index.json:9:    \"description\" : \"Jackson Datatype JDK8 is an add-on module for Jackson Databind that adds serialization and deserialization support for Java 8 types such as Optional, OptionalInt, OptionalLong, and OptionalDouble. It lets ObjectMapper handle those JDK 8 container types through Jackson's standard module registration mechanism.\",\nmetadata/com.fasterxml.jackson.datatype/jackson-datatype-jsr310/index.json:9:    \"description\" : \"Jackson Datatype JSR310 is an add-on module for Jackson that adds serialization and deserialization support for Java 8 Date and Time API types. It lets ObjectMapper handle java.time classes such as LocalDate, LocalDateTime, OffsetDateTime, and Instant using Jackson's standard module registration mechanism.\",\nmetadata/com.fasterxml.jackson.core/jackson-databind/index.json:9:    \"description\" : \"Jackson Databind provides general-purpose data binding and tree-model APIs for Jackson on top of the core streaming API. It converts between JSON and Java objects and can also work with other data formats when compatible parsers and generators are available.\",\nmetadata/com.fasterxml.jackson.core/jackson-annotations/index.json:9:    \"description\" : \"Jackson Annotations provides core Java annotation types used by Jackson data-binding and related modules to configure JSON serialization, deserialization, type handling, and property naming. It is a small companion artifact that contains annotation APIs rather than runtime data-binding logic.\",\nmetadata/com.fasterxml.jackson.core/jackson-core/index.json:9:    \"description\" : \"Jackson Core provides the core abstractions and streaming JSON parser and generator implementation for Jackson. It lets Java applications read and write JSON incrementally with a low-level token-based API.\",\nmetadata/com.fasterxml.jackson.core/jackson-core/index.json:132:    \"description\" : \"Jackson Core provides the core abstractions and streaming JSON parser and generator implementation for Jackson. It lets Java applications read and write JSON incrementally with a low-level token-based API.\",\nmetadata/com.fasterxml.jackson.module/jackson-module-parameter-names/index.json:9:    \"description\" : \"Jackson Module Parameter Names is an add-on module for Jackson that lets databind inspect Java constructor and method parameter names without requiring explicit property-name annotations. It is intended for classes compiled with Java 8 parameter metadata so JSON creators and immutable types can be bound using their real parameter names.\",\nmetadata/com.fasterxml.jackson.module/jackson-module-kotlin/index.json:9:    \"description\" : \"Jackson module that adds support for serializing and deserializing Kotlin classes and data classes. It lets Jackson infer constructor parameter names and work with single-constructor classes without requiring explicit property name annotations or default constructors.\",\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.0/reachability-metadata.json:5:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.0/reachability-metadata.json:17:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.0/reachability-metadata.json:189:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.0/reachability-metadata.json:208:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.0/reachability-metadata.json:214:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.0/reachability-metadata.json:369:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/index.json:9:    \"description\" : \"jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back using Jackson.\",\nmetadata/io.jsonwebtoken/jjwt-jackson/index.json:24:    \"description\" : \"jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back using Jackson.\",\nmetadata/io.jsonwebtoken/jjwt-jackson/index.json:44:    \"description\" : \"jjwt-jackson provides Jackson-based JSON serializer and deserializer implementations for JJWT. It lets JJWT encode JWT headers and claims to JSON and parse them back using Jackson.\",\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.7/reachability-metadata.json:5:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.7/reachability-metadata.json:17:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.7/reachability-metadata.json:197:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.7/reachability-metadata.json:215:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.7/reachability-metadata.json:221:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.7/reachability-metadata.json:307:      \"type\": \"io.jsonwebtoken.jackson.io.JacksonDeserializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.12.7/reachability-metadata.json:365:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.11.5/reachability-metadata.json:5:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.11.5/reachability-metadata.json:89:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.11.5/reachability-metadata.json:95:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.11.5/reachability-metadata.json:107:        \"typeReached\": \"io.jsonwebtoken.jackson.io.JacksonSerializer\"\nmetadata/io.jsonwebtoken/jjwt-jackson/0.11.5/reacha