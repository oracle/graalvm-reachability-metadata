  package com_fasterxml_jackson_jr.jackson_jr_objects;
  
  import java.util.LinkedHashMap;
  
  import com.fasterxml.jackson.jr.ob.JSON;
  import com.fasterxml.jackson.jr.ob.impl.BeanPropertyIntrospector;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RecordsHelpersDynamicAccessTest {
      @Test
      void derivesRecordPropertiesFromCanonicalConstructor() {
          LinkedHashMap<String, String> propertiesByName = new LinkedHashMap<>();
  
          BeanPropertyIntrospector.derivePropertiesFromRecordConstructor(SampleRecord.class,
                  propertiesByName, name -> name);
  
          assertThat(propertiesByName.keySet()).containsExactly("id", "name", "active");
      }
  
      @Test
      void deserializesRecordThroughItsCanonicalConstructor() throws Exception {
          SampleRecord record = JSON.std.beanFrom(SampleRecord.class,
                  "{\"name\":\"Ada\"}");
  
          assertThat(record).isEqualTo(new SampleRecord(0, "Ada", false));
      }
  
      public record SampleRecord(int id, String name, boolean active) {
          public SampleRecord(String name) {
              this(-1, name, true);
          }
      }
  }
