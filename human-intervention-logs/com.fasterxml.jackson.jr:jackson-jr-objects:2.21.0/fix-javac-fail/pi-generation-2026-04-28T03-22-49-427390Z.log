lean active) {\n+    }\n+}\ndiff --git c/tests/src/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/src/test/resources/META-INF/native-image/reachability-metadata.json i/tests/src/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/src/test/resources/META-INF/native-image/reachability-metadata.json\nindex 880b21c1bf..aeaf5e9f9e 100644\n--- c/tests/src/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/src/test/resources/META-INF/native-image/reachability-metadata.json\n+++ i/tests/src/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/src/test/resources/META-INF/native-image/reachability-metadata.json\n@@ -291,6 +291,45 @@\n           \"name\" : \"SOUTH\"\n         }\n       ]\n+    },\n+    {\n+      \"condition\" : {\n+        \"typeReached\" : \"com.fasterxml.jackson.jr.ob.impl.BeanPropertyReader\"\n+      },\n+      \"type\" : \"com_fasterxml_jackson_jr.jackson_jr_objects.RecordsHelpersDynamicAccessTest$SampleRecord\",\n+      \"fields\" : [\n+        {\n+          \"name\" : \"id\"\n+        },\n+        {\n+          \"name\" : \"name\"\n+        },\n+        {\n+          \"name\" : \"active\"\n+        }\n+      ]\n+    },\n+    {\n+      \"condition\" : {\n+        \"typeReached\" : \"com.fasterxml.jackson.jr.ob.impl.BeanReader\"\n+      },\n+      \"type\" : \"com_fasterxml_jackson_jr.jackson_jr_objects.RecordsHelpersDynamicAccessTest$SampleRecord\",\n+      \"methods\" : [\n+        {\n+          \"name\" : \"<init>\",\n+          \"parameterTypes\" : [\n+            \"int\",\n+            \"java.lang.String\",\n+            \"boolean\"\n+          ]\n+        }\n+      ]\n+    },\n+    {\n+      \"condition\" : {\n+        \"typeReached\" : \"com.fasterxml.jackson.jr.ob.impl.ValueReaderLocator\"\n+      },\n+      \"type\" : \"com_fasterxml_jackson_jr.jackson_jr_objects.RecordsHelpersDynamicAccessTest$SampleRecord\"\n     }\n   ]\n }\n"}], "isError": false, "timestamp": 1777346550779}, {"role": "toolResult", "toolCallId": "call_2gn9ZRhTTY5saUT4Vig4xqN3|