      /**********************************************************************
      /* Public API: writer lookup
      /**********************************************************************
       */
  
      public ValueWriter getValueWriter(int index) {
          // for simplicity, let's allow caller to pass negative id as is
          if (index < 0) {
              index = -(index+1);
