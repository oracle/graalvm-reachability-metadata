[tool-call] delta {"path":"tests/src/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/src/test/java/com_fasterxml_jackson_jr/jackson_jr_objects/ValueReaderLocatorDynamicAccessTest.java","edits":[{"oldText":"import com.fasterxml.jackson.jr.ob.api.ExtensionContext;\nimport com.fasterxml.jackson.jr.ob.api.ReaderWriterModifier;\nimport com.fasterxml.jackson.jr.ob.impl.BeanConstructors;\nimport com.fasterxml.jackson.jr.ob.impl.JSONReader;\nimport com.fasterxml.jackson.jr.ob.impl.POJODefinition;\n","newText":"import com.fasterxml.jackson.jr.ob.api.CollectionBuilder;\nimport com.fasterxml.jackson.jr.ob.api.ExtensionContext;\nimport com.fasterxml.jackson.jr.ob.api.MapBuilder;\nimport com.fasterxml.jackson.jr.ob.api.ReaderWriterModifier;\nimport com.fasterxml.jackson.jr.ob.api.ValueReader;\nimport com.fasterxml.jackson.jr.ob.impl.BeanConstructors;\nimport com.fasterxml.jackson.jr.ob.impl.JSONReader;\nimport com.fasterxml.jackson.jr.ob.impl.POJODefinition;\nimport com.fasterxml.jackson.jr.ob.impl.ValueReaderLocator;\n"},{"oldText":"public class ValueReaderLocatorDynamicAccessTest {\n    @Test\n    void readsRecordPropertiesViaDeclaredFields() throws Exception {\n        RecordsHelpersDynamicAccessTest.SampleRecord record = JSON.std.beanFrom(\n                RecordsHelpersDynamicAccessTest.SampleRecord.class,\n                \"{\\\"id\\\":7,\\\"name\\\":\\\"Ada\\\",\\\"active\\\":true}\");\n\n        assertThat(record).isEqualTo(new RecordsHelpersDynamicAccessTest.SampleRecord(7, \"Ada\", true));\n    }\n\n    @Test\n    void readsEnumsFromModifierProvidedDefinitions() throws Exception {\n        Direction direction = enumAwareJson().beanFrom(Direction.class, \"\\\"go-north\\\"\");\n\n        assertThat(direction).isEqualTo(Direction.NORTH);\n    }\n\n    @Test\n    void readsModifierProvidedEnumDefinitionsCaseInsensitively() throws Exception {\n        Direction direction = enumAwareJson(JSON.Feature.ACCEPT_CASE_INSENSITIVE_ENUMS)\n                .beanFrom(Direction.class, \"\\\"GO-SOUTH\\\"\");\n\n        assertThat(direction).isEqualTo(Direction.SOUTH);\n    }\n\n    private static JSON enumAwareJson(JSON.Feature... features) {\n        return JSON.builder()\n                .enable(features)\n                .register(new EnumDefinitionExtension())\n                .build();\n    }\n","newText":"public class ValueReaderLocatorDynamicAccessTest {\n    @Test\n    void resolvesRecordReadersUsingDeclaredRecordFields() {\n        ValueReader reader = readerLocator(null)\n                .findReader(RecordsHelpersDynamicAccessTest.SampleRecord.class);\n\n        assertThat(reader).isNotNull();\n    }\n\n    @Test\n    void resolvesEnumReadersFromModifierProvidedDefinitions() {\n        ValueReader reader = readerLocator(new EnumDefinitionModifier())\n                .findReader(Direction.class);\n\n        assertThat(reader).isNotNull();\n    }\n\n    @Test\n    void resolvesEnumReadersFromModifierProvidedDefinitionsCaseInsensitively() {\n        ValueReader reader = readerLocator(new EnumDefinitionModifier(), JSON.Feature.ACCEPT_CASE_INSENSITIVE_ENUMS)\n                .findReader(Direction.class);\n\n        assertThat(reader).isNotNull();\n    }\n\n    private static ValueReaderLocator readerLocator(ReaderWriterModifier modifier, JSON.Feature... features) {\n        int flags = 0;\n        for (JSON.Feature feature : features) {\n            flags |= feature.mask();\n        }\n        return ValueReaderLocator.blueprint(null, modifier)\n                .perOperationInstance(new JSONReader(CollectionBuilder.defaultImpl(), MapBuilder.defaultImpl()), flags);\n    }\n"}]}
