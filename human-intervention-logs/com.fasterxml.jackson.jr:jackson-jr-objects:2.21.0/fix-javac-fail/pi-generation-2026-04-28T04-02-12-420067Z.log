      public JSONReader(CollectionBuilder lb, MapBuilder mb)
      {
          _features = 0;
          _readerLocator = null;
          _treeCodec = null;
          _collectionBuilder = lb;
          _mapBuilder = mb;
          _parser = null;
          _setterBuffer = null; // should NOT  be used on blueprint
