      @Deprecated
      public JSON with(ReaderWriterProvider rwp) {
          ValueReaderLocator rloc = _valueReaderLocator.with(rwp);
          ValueWriterLocator wloc = _valueWriterLocator.with(rwp);
          if ((rloc == _valueReaderLocator) && (wloc == _valueWriterLocator))  {
