  package com_fasterxml_jackson_jr.jackson_jr_objects;
  
  import com.fasterxml.jackson.jr.ob.JSON;
  import com.fasterxml.jackson.jr.type.ResolvedType;
  import com.fasterxml.jackson.jr.type.TypeBindings;
  import com.fasterxml.jackson.jr.type.TypeResolver;
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.GenericArrayType;
  import java.lang.reflect.Type;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypeResolverDynamicAccessTest {
      @Test
      void resolvesSyntheticGenericArrayTypes() {
          ResolvedType resolvedArrayType = new TypeResolver().resolve(TypeBindings.emptyBindings(), genericArrayType(String.class));
  
          assertThat(resolvedArrayType.isArray()).isTrue();
          assertThat(resolvedArrayType.erasedType()).isEqualTo(String[].class);
          assertThat(resolvedArrayType.elementType().erasedType()).isEqualTo(String.class);
      }
  
      @Test
      void deserializesCollectionPropertiesWithGenericArrayElements() throws Exception {
          StringArrayListBean bean = JSON.std.beanFrom(StringArrayListBean.class,
                  "{" +
                          "\"values\":[[\"alpha\",\"beta\"],[\"gamma\"]]" +
                          "}");
  
          List<?> values = bean.values;
  
          assertThat(values).hasSize(2);
          assertThat((Object[]) values.get(0)).containsExactly("alpha", "beta");
          assertThat((Object[]) values.get(1)).containsExactly("gamma");
      }
  
      private static GenericArrayType genericArrayType(Type componentType) {
          return new SimpleGenericArrayType(componentType);
      }
  
      static final class SimpleGenericArrayType implements GenericArrayType {
          private final Type componentType;
  
          SimpleGenericArrayType(Type componentType) {
              this.componentType = componentType;
          }
  
          @Override
          public Type getGenericComponentType() {
              return componentType;
          }
      }
  
      static class GenericArrayListBean<T> {
          public List<T[]> values;
      }
  
      static final class StringArrayListBean extends GenericArrayListBean<String> {
      }
  }
