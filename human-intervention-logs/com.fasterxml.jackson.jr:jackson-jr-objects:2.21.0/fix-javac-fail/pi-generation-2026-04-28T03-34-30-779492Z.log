  package com_fasterxml_jackson_jr.jackson_jr_objects;
  
  import com.fasterxml.jackson.jr.ob.JSON;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanConstructorsDynamicAccessTest {
      @Test
      void createsBeansThroughDefaultConstructorsBeforePopulatingProperties() throws Exception {
          DefaultConstructorBean bean = JSON.std.beanFrom(DefaultConstructorBean.class,
                  "{\"id\":7,\"name\":\"Ada\"}");
  
          assertThat(bean.id).isEqualTo(7);
          assertThat(bean.name).isEqualTo("Ada");
      }
  
      @Test
      void createsRecordsThroughCanonicalConstructorsUsingMappedComponentOrder() throws Exception {
          ConstructorRecord record = JSON.std.beanFrom(ConstructorRecord.class,
                  "{\"active\":true,\"name\":\"Ada\",\"id\":7}");
  
          assertThat(record).isEqualTo(new ConstructorRecord(7, "Ada", true));
      }
  
      public static final class DefaultConstructorBean {
          public int id;
          public String name;
  
          public DefaultConstructorBean() {
          }
      }
  
      public record ConstructorRecord(int id, String name, boolean active) {
      }
  }
