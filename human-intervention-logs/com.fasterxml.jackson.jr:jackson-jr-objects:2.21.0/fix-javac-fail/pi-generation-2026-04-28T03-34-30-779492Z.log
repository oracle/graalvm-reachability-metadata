                          prop.setValueFor(bean, valueBuf);
                      }
                      // also verify we are not confused...
                      if (!p.hasToken(JsonToken.END_OBJECT)) {
                          throw _reportProblem(p);
                      }
                      return bean;
                  }
              default:
              }
          } catch (IOException e) {
              throw e;
