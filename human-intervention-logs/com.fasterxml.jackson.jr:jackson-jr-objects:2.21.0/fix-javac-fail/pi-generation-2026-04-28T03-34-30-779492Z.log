  package com_fasterxml_jackson_jr.jackson_jr_objects;
  
  import java.lang.reflect.Constructor;
  
  import com.fasterxml.jackson.jr.ob.impl.BeanConstructors;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanConstructorsDynamicAccessTest {
      @Test
      void createsBeansThroughConfiguredDefaultConstructors() throws Exception {
          DefaultConstructorBean bean = (DefaultConstructorBean) new TestableBeanConstructors(DefaultConstructorBean.class)
                  .addNoArgs(DefaultConstructorBean.class.getDeclaredConstructor())
                  .createBean();
  
          assertThat(bean).isNotNull();
          assertThat(bean.id).isZero();
          assertThat(bean.name).isNull();
      }
  
      @Test
      void createsRecordsThroughConfiguredCanonicalConstructors() throws Exception {
          ConstructorRecord record = (ConstructorRecord) new TestableBeanConstructors(ConstructorRecord.class)
                  .addRecord(ConstructorRecord.class.getDeclaredConstructor(int.class, String.class, boolean.class))
                  .createRecordBean(new Object[] {7, "Ada", true});
  
          assertThat(record).isEqualTo(new ConstructorRecord(7, "Ada", true));
      }
  
      public static final class DefaultConstructorBean {
          public int id;
          public String name;
  
          public DefaultConstructorBean() {
          }
      }
  
      public record ConstructorRecord(int id, String name, boolean active) {
      }
  
      public static final class TestableBeanConstructors extends BeanConstructors {
          public TestableBeanConstructors(Class<?> valueType) {
              super(valueType);
          }
  
          public TestableBeanConstructors addNoArgs(Constructor<?> ctor) {
              addNoArgsConstructor(ctor);
              return this;
          }
  
          public TestableBeanConstructors addRecord(Constructor<?> ctor) {
              addRecordConstructor(ctor);
              return this;
          }
  
          public Object createBean() throws Exception {
              return create();
          }
  
          public Object createRecordBean(Object[] components) throws Exception {
              return createRecord(components);
          }
