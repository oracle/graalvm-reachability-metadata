solvesClassesInsideTypedMapsAndLists() throws Exception {\n        String className = resolvableClassName();\n\n        Map<String, Class> classesByName = JSON.std.mapOfFrom(Class.class,\n                \"{\\\"primary\\\":\" + quotedClassName(className) + \"}\");\n        List<Class> classes = JSON.std.listOfFrom(Class.class,\n                \"[\" + quotedClassName(className) + \"]\");\n\n        assertThat(classesByName.get(\"primary\").getName()).isEqualTo(className);\n        assertThat(classes).singleElement().satisfies(type -> assertThat(type.getName()).isEqualTo(className));\n    }\n"},{"oldText":"    void failsAfterTryingToResolveMissingClassesByName() {\n        String missingClassName = TypeHolder.class.getName() + \"Missing\";\n\n        assertThatThrownBy(() -> JSON.std.beanFrom(Class.class, '\"' + missingClassName + '\"'))\n                .isInstanceOf(JSONObjectException.class)\n                .hasMessageContaining(\"Failed to bind `java.lang.Class`\");\n    }\n\n    private static String quotedClassName(Class<?> type) {\n        return '\"' + type.getName() + '\"';\n    }\n","newText":"    void failsAfterTryingToResolveMissingClassesByName() {\n        String missingClassName = resolvableClassName() + \"Missing\";\n\n        assertThatThrownBy(() -> JSON.std.beanFrom(Class.class, quotedClassName(missingClassName)))\n                .isInstanceOf(JSONObjectException.class)\n                .hasMessageContaining(\"Failed to bind `java.lang.Class`\");\n    }\n\n    private static String resolvableClassName() {\n        return new ResolvableType().getClass().getName();\n    }\n\n    private static String quotedClassName(String className) {\n        return '\"' + className + '\"';\n    }\n"}]}
