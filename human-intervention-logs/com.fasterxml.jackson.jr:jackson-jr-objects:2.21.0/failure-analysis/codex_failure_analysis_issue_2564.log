ects/2.21.0/main/extracted/com/fasterxml/jackson/jr/type/ResolvedType.java\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/NOTICE\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/LICENSE\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/maven\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/maven/com.fasterxml.jackson.jr\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/maven/com.fasterxml.jackson.jr/jackson-jr-objects\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/maven/com.fasterxml.jackson.jr/jackson-jr-objects/pom.properties\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/maven/com.fasterxml.jackson.jr/jackson-jr-objects/pom.xml\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/source_context/com.fasterxml.jackson.jr/jackson-jr-objects/2.21.0/main/extracted/META-INF/MANIFEST.MF\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/graalvm-reachability-metadata/.git/logs/refs/remotes/origin/ai/vjovanov/human-intervention/issue-2564-fails-javac-compile-com.fasterxml.jackson.jr-jackson-jr-objects-2.21.0-eddbdf97\n/home/vjovanov/c/forge1/metadata-forge/local_repositories/graalvm-reachability-metadata/.git/logs/refs/he