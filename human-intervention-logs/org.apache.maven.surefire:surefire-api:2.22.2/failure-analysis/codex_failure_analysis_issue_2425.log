ort.delete(linkFile);\n        assertThat(Java7Support.exists(linkFile)).isFalse();\n\n        Java7Support.delete(targetFile);\n        assertThat(Java7Support.exists(targetFile)).isFalse();\n    }\n}\n","exit_code":0,"status":"completed"}}
