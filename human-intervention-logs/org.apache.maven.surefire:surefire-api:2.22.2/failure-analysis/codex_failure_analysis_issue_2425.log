ata/io.dropwizard.metrics/metrics-json/4.2.0\n./metadata/io.dropwizard.metrics/metrics-jmx\n./metadata/io.dropwizard.metrics/metrics-jmx/4.2.0\n./metadata/io.dropwizard.metrics5\n./metadata/io.dropwizard.metrics5/metrics-core\n./metadata/io.dropwizard.metrics5/metrics-core/5.0.0\n./metadata/io.dropwizard.metrics5/metrics-core/5.0.1\n./metadata/io.opentelemetry/opentelemetry-sdk-metrics\n./metadata/io.opentelemetry/opentelemetry-sdk-metrics/1.19.0\n./metadata/io.opentelemetry/opentelemetry-sdk-metrics/1.56.0\n./metadata/io.opentelemetry/opentelemetry-sdk-metrics/1.59.0\n./metadata/org.apache.maven.surefire/surefire-api\n./metadata/org.apache.maven.surefire/surefire-api/2.22.2\n./build/tests/org.apache.maven.surefire:surefire-api:2.22.2\n./forge/benchmark_run_metrics\n./forge/script_run_metrics\n./tests/src/io.dropwizard.metrics\n./tests/src/io.dropwizard.metrics/metrics-graphite\n./tests/src/io.dropwizard.metrics/metrics-graphite/4.2.0\n./tests/src/io.dropwizard.metrics/metrics-core\n./tests/src/io.dropwizard.metrics/metrics-core/4.1.12.1\n./tests/src/io.dropwizard.metrics/metrics-jvm\n./tests/src/io.dropwizard.metrics/metrics-jvm/4.2.0\n./tests/src/io.dropwizard.metrics/metrics-json\n./tests/src/io.dropwizard.metrics/metrics-json/4.2.0\n./tests/src/io.dropwizard.metrics/metrics-jmx\n./tests/src/io.dropwizard.metrics/metrics-jmx/4.2.0\n./tests/src/io.dropwizard.metrics5\n./tests/src/io.dropwizard.metrics5/metrics-core\n./tests/src/io.dropwizard.metrics5/metrics-core/5.0.0\n./tests/src/io.dropwizard.metrics5/metrics-core/5.0.1\n./tests/src/io.opentelemetry/opentelemetry-sdk-metrics\n./tests/src/io.opentelemetry/opentelemetry-sdk-metrics/1.19.0\n./tests/src/io.opentelemetry/opentelemetry-sdk-metrics/1.56.0\n./tests/src/io.opentelemetry/opentelemetry-sdk-metrics/1.59.0\n./tests/src/org.apache.maven.surefire/surefire-api\n./tests/src/org.apache.maven.surefire/surefire-api/2.22.2\n","exit_code":0,"status":"completed"}}
