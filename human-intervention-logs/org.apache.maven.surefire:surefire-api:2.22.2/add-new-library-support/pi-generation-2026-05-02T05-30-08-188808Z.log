ass = RejectedScanTarget.class;\n        DefaultScanResult scanResult = new DefaultScanResult(Collections.singletonList(skippedClass.getName()));\n        ScannerFilter rejectingFilter = testClass -> false;\n\n        try {\n            List<Class<?>> skippedClasses = scanResult.getClassesSkippedByValidation(\n                    rejectingFilter,\n                    skippedClass.getClassLoader()\n            );\n\n            assertThat(skippedClasses).containsExactly(skippedClass);\n        } catch (Error e) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(e)) {\n                throw e;\n            }\n        }\n    }\n\n    public static final class RejectedScanTarget {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 636, "output": 970, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 22086, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777699768420, "responseId": "resp_0734cee365ea0f5b0169f58bb8ded08190ad3ffb96cd0f3774"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FIYhIHe6UGRgCEfZpr0kIdjS|fc_0734cee365ea0f5b0169f58bc30cb08190a90e38b78cabaa73", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2226 bytes to tests/src/org.apache.maven.surefire/surefire-api/2.22.2/src/test/java/org_apache_maven_surefire/surefire_api/DefaultScanResultTest.java"}], "isError": false, "timestamp": 1777699780478}]}
