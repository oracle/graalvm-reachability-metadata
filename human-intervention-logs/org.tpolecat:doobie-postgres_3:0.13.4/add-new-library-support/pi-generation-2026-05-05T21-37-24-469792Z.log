sb.append('\"')\n   116\t        ()\n   117\t      }\n   118\t    }\n   119\t\n   120\t  //Char\n   121\t  implicit val charInstance:    Text[Char]    = instance((n, sb) => {sb.append(n.toString); ()})\n   122\t\n   123\t  // Primitive Numerics\n   124\t  implicit val intInstance:    Text[Int]    = instance((n, sb) => {sb.append(n); ()})\n   125\t  implicit val shortInstance:  Text[Short]  = instance((n, sb) => {sb.append(n); ()})\n   126\t  implicit val longInstance:   Text[Long]   = instance((n, sb) => {sb.append(n); ()})\n   127\t  implicit val floatInstance:  Text[Float]  = instance((n, sb) => {sb.append(n); ()})\n   128\t  implicit val doubleInstance: Text[Double] = instance((n, sb) => {sb.append(n); ()})\n   129\t\n   130\t  // Big Numerics\n   131\t  implicit val bigDecimalInstance: Text[BigDecimal] = instance { (n, sb) => {sb.append(n.toString); ()} }\n   132\t\n   133\t  // Boolean\n   134\t  implicit val booleanInstance: Text[Boolean] =\n   135\t    instance((b, sb) => {sb.append(b); ()})\n   136\t\n   137\t  // Date, Time, etc.\n   138\t\n   139\t  // Byte arrays in \\\\x01A3DD.. format.\n   140\t  @SuppressWarnings(Array(\"org.wartremover.warts.NonUnitStatements\"))\n   141\t  implicit val byteArrayInstance: Text[Array[Byte]] =\n   142\t    instance { (bs, sb) =>\n   143\t      sb.append(\"\\\\\\\\x\")\n   144\t      if (bs.length > 0) {\n   145\t        val hex = BigInt(1, bs).toString(16)\n   146\t        val pad = bs.length * 2 - hex.length\n   147\t        (0 until pad).foreach(_ => sb.append(\"0\"))\n   148\t        sb.append(hex)\n   149\t        ()\n   150\t      }\n   151\t    }\n   152\t\n   153\t  // Any non-option Text can be lifted to Option\n   154\t  implicit def option[A](\n   155\t    implicit csv: Text[A]\n   156\t  ): Text[Option[A]] =\n   157\t    instance {\n   158\t      case (Some(a), sb) => {csv.unsafeEncode(a, sb); ()}\n   159\t      case (None, sb)    => {sb.append(Text.NULL); ()}\n   160\t    }\n   161\t\n   162\t}\n   163\t\n  