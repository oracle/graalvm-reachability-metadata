  object KleisliInterpreter {
  
    def apply[M[_]](b: Blocker)(
      implicit am: Async[M],
               cs: ContextShift[M]
    ): KleisliInterpreter[M] =
      new KleisliInterpreter[M] {
        val asyncM = am
        val contextShiftM = cs
        val blocker = b
