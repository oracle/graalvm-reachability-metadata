    def onSuccessfulCompletion(handler: => M[A]): M[A] =
      exceptSomeSqlState(ma) { case class00.SUCCESSFUL_COMPLETION => handler }
  
    def onWarning(handler: => M[A]): M[A] =
      exceptSomeSqlState(ma) { case class01.WARNING => handler }
  
