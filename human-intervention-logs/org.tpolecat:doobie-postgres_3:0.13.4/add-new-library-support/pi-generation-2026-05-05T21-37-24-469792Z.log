     125	  implicit val shortInstance:  Text[Short]  = instance((n, sb) => {sb.append(n); ()})
     126	  implicit val longInstance:   Text[Long]   = instance((n, sb) => {sb.append(n); ()})
     127	  implicit val floatInstance:  Text[Float]  = instance((n, sb) => {sb.append(n); ()})
     128	  implicit val doubleInstance: Text[Double] = instance((n, sb) => {sb.append(n); ()})
     129	
