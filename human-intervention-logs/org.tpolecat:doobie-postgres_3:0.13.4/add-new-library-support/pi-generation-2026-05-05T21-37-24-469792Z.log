        def pure[A](x: A): LargeObjectIO[A] = asyncM.pure(x)
        def handleErrorWith[A](fa: LargeObjectIO[A])(f: Throwable => LargeObjectIO[A]): LargeObjectIO[A] = module.handleErrorWith(fa, f)
