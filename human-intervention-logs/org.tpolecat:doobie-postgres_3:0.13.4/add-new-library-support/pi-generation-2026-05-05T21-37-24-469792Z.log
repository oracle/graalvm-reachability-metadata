      10	/**
      11	 * Typeclass for types that can be written as Postgres literal text, using the default DELIMETER
      12	 * and NULL values, for use with `COPY`. If you wish to implement an instance it's worth reading
      13	 * the documentation at the link below.
      14	 * @see [[https://www.postgresql.org/docs/9.6/static/sql-copy.html Postgres `COPY` command]]
      15	 */
      16	
      17	trait Text[A] { outer =>
      18	
      19	  /**
      20	   * Construct an encoder for `A` that appends to the provided `StringBuilder.
      21	   * @param a the value to encode
      22	   */
      23	  def unsafeEncode(a: A, sb: StringBuilder): Unit
      24	
      25	  /**
      26	   * Variant of unsafeEncode, called for array members which require more escaping. Same as
      27	   * unsafeEncode unless overridden.
      28	   */
      29	  def unsafeArrayEncode(a: A, sb: StringBuilder): Unit =
      30	    unsafeEncode(a, sb)
      31	
      32	  /** Encode `a`. */
      33	  final def encode(a: A): String = {
      34	    val sb = new StringBuilder
      35	    unsafeEncode(a, sb)
      36	    sb.toString
      37	  }
      38	
      39	  /** `Text` is a contravariant functor. */
      40	  final def contramap[B](f: B => A): Text[B] =
      41	    Text.instance((b, sb) => outer.unsafeEncode(f(b), sb))
      42	
      43	  /** `Text` is semigroupal. */
      44	  @SuppressWarnings(Array("org.wartremover.warts.NonUnitStatements"))
      45	  def product[B](fb: Text[B]): Text[(A, B)] =
      46	    new Text[(A, B)] {
      47	      def unsafeEncode(ab: (A, B), sb: StringBuilder) = {
      48	        outer.unsafeEncode(ab._1, sb)
      49	        sb.append(Text.DELIMETER)
      50	        fb.unsafeEncode(ab._2, sb)
      51	      }
      52	    }
      53	
      54	}
      55	object Text extends TextInstances with TextPlatform {
      56	  def apply[A](implicit ev: Text[A]): ev.type = ev
      57	
      58	  val DELIMETER: Char = '\t'
      59	  val NULL: String = "\\N"
      60	
      61	  /**
      62	   * Construct an instance, given a function matching the `unsafeEncode` signature.
      63	   * @param f a function from `(A, DELIMETER, NULL) => StringBuilder => StringBuilder`
      64	   */
      65	  def instance[A](f: (A, StringBuilder) => Unit): Text[A] =
      66	    new Text[A] {
      67	      def unsafeEncode(a: A, sb: StringBuilder) = f(a, sb)
      68	    }
      69	
      70	}
