    implicit val MultiPointType: Meta[MultiPoint]                 = geometryType[MultiPoint]
    implicit val PolygonType: Meta[Polygon]                       = geometryType[Polygon]
    implicit val PointType: Meta[Point]                           = geometryType[Point]
  }
