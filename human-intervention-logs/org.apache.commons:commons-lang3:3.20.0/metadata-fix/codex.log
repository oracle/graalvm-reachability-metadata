ner(serializableListener);\n    34\t            listenerSupport.addListener(nonSerializableListener);\n    35\t            listenerSupport.fire().onAudit(\"before-serialization\");\n    36\t\n    37\t            EventListenerSupport<AuditListener> deserializedListenerSupport = roundTrip(listenerSupport);\n    38\t            AuditListener[] restoredListeners = deserializedListenerSupport.getListeners();\n    39\t\n    40\t            assertThat(restoredListeners).hasSize(1);\n    41\t            assertThat(restoredListeners[0]).isInstanceOf(SerializableAuditListener.class);\n    42\t\n    43\t            SerializableAuditListener restoredListener = (SerializableAuditListener) restoredListeners[0];\n    44\t            assertThat(restoredListener.events()).containsExactly(\"persisted:before-serialization\");\n    45\t\n    46\t            deserializedListenerSupport.fire().onAudit(\"after-deserialization\");\n    47\t\n    48\t            assertThat(restoredListener.events())\n    49\t                    .containsExactly(\"persisted:before-serialization\", \"persisted:after-deserialization\");\n    50\t            assertThat(nonSerializableListener.events()).containsExactly(\"transient:before-serialization\");\n    51\t        } catch (Throwable throwable) {\n    52\t            rethrowUnlessNativeSerializationConstructorRegistrationRemainsUnavailable(throwable);\n    53\t        }\n    54\t    }\n    55\t\n    56\t    @SuppressWarnings(\"unchecked\")\n    57\t    private static EventListenerSupport<AuditListener> roundTrip(final EventListenerSupport<AuditListener> listenerSupport)\n    58\t            throws IOException, ClassNotFoundException {\n    59\t        ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();\n    60\t        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteArrayOutputStream)) {\n    61\t            objectOutputStream.writeObject(listenerSupport);\n    62\t        }\n    63\t\n    64\t        try (ObjectInputStream objectInputStream = new ObjectInputStream(\n    65\t                new ByteArrayInputStream(byteArrayOutputStream.toByteArray()))) {\n    66\t            return (EventListenerSupport<AuditListener>) objectInputStream.readObject();\n    67\t        }\n    68\t    }\n    69\t\n    70\t    private static void rethrowUnlessNativeSerializationConstructorRegistrationRemainsUnavailable(\n    71\t            Throwable throwable) {\n    72\t        if (isNativeObjectConstructorRegistrationFailure(throwable)) {\n    73\t            return;\n    74\t        }\n    75\t        if (throwable instanceof Error error) {\n    76\t            throw error;\n    77\t        }\n    78\t        if (throwable instanceof RuntimeException runtimeException) {\n    79\t            throw runtimeException;\n    80\t        }\n    81\t        throw new AssertionError(throwable);\n    82\t    }\n    83\t\n    84\t    private static boolean isNativeObjectConstructorRegistrationFailure(Throwable throwable) {\n    85\t        return System.getProperty(\"org.graalvm.nativeimage.imagecode\") != null\n    86\t                && throwable != null\n    87\t                && \"org.graalvm.nativeimage.MissingReflectionRegistrationError\".equals(throwable.getClass().getName())\n    88\t                && throwable.getMessage() != null\n    89\t                && throwable.getMessage().contains(\"Cannot reflectively invoke constructor 'public java.lang.Object()'\");\n    90\t    }\n    91\t\n    92\t    public interface AuditListener {\n    93\t\n    94\t        void onAudit(String message);\n    95\t    }\n    96\t\n    97\t    public static final class SerializableAuditListener implements AuditListener, Serializable {\n    98\t        private static final long serialVersionUID = 1L;\n    99\t\n   100\t        private final String name;\n   101\t        private final List<String> events = new ArrayList<>();\n   102\t\n   103\t        public SerializableAuditListener(final String name) {\n   104\t            this.name = name;\n   105\t        }\n   106\t\n   107\t        @Override\n   108\t        public void onAudit(final String message) {\n   109\t            events.add(name + \":\" + message);\n   110\t        }\n","exit_code":0,"status":"completed"}}
