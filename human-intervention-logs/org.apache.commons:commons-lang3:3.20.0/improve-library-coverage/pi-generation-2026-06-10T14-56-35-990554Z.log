[tool-call] delta {"path":"tests/src/org.apache.commons/commons-lang3/3.20.0/src/test/java/org_apache_commons/commons_lang3/ArrayUtilsTest.java","edits":[{"oldText":"    @Test\n    public void addCreatesTypedArrayWhenAppendingToNullArray() {\n        String[] result = ArrayUtils.add((String[]) null, \"alpha\");\n\n        assertThat(result).isInstanceOf(String[].class).containsExactly(\"alpha\");\n    }\n\n    @Test\n    public void insertCreatesExpandedArrayForObjectValues() {","newText":"    @Test\n    public void addCreatesTypedArrayWhenAppendingToNullArray() {\n        String[] result = ArrayUtils.add((String[]) null, \"alpha\");\n\n        assertThat(result).isInstanceOf(String[].class).containsExactly(\"alpha\");\n    }\n\n    @Test\n    public void addAllCreatesTypedArrayForConcatenatedObjectArrays() {\n        String[] result = ArrayUtils.addAll(new String[]{\"alpha\", \"beta\"}, \"gamma\", \"delta\");\n\n        assertThat(result).isInstanceOf(String[].class).containsExactly(\"alpha\", \"beta\", \"gamma\", \"delta\");\n    }\n\n    @Test\n    public void insertCreatesExpandedArrayForObjectValues() {"},{"oldText":"    @Test\n    public void subarrayCopiesRequestedObjectRange() {\n        String[] result = ArrayUtils.subarray(new String[]{\"alpha\", \"beta\", \"gamma\"}, 1, 3);\n\n        assertThat(result).containsExactly(\"beta\", \"gamma\");\n    }","newText":"    @Test\n    public void subarrayCopiesRequestedObjectRange() {\n        String[] result = ArrayUtils.subarray(new String[]{\"alpha\", \"beta\", \"gamma\"}, 1, 3);\n\n        assertThat(result).containsExactly(\"beta\", \"gamma\");\n    }\n\n    @Test\n    public void toStringArrayCreatesTypedStringArrayForMappedValues() {\n        String[] result = ArrayUtils.toStringArray(new Object[]{\"alpha\", 3, null}, \"missing\");\n\n        assertThat(result).isInstanceOf(String[].class).containsExactly(\"alpha\", \"3\", \"missing\");\n    }"}]}
