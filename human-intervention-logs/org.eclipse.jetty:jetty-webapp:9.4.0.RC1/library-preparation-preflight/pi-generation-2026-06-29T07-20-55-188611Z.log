  metadata/javax.el/el-api/index.json:9:    "description" : "The Java Unified Expression Language API defines interfaces and base classes for parsing and evaluating value and method expressions used by JSP 2.1 and JSF 1.2. It provides pluggable contexts, resolvers, function mapping, and variable mapping so web frameworks and applications can access and manipulate model data through EL expressions.",
  metadata/tomcat/jasper-compiler/index.json:9:    "description" : "Apache Tomcat Jasper Compiler contains the compiler portion of Tomcat's Jasper JSP engine, including classes that translate JSP pages into Java servlet source and drive compilation. It is used by Tomcat 5.5 to prepare JSP pages for execution against the servlet and JSP APIs.",
  metadata/tomcat/jasper-compiler/index.json:14:      "org.apache.jasper"
  metadata/org.apache.tomcat.embed/tomcat-embed-el/index.json:9:    "description" : "Tomcat Embed EL provides Apache Tomcat's embeddable implementation of the Java Unified Expression Language used by Tomcat 9. It parses and evaluates EL expressions for JSP and servlet-based applications running with embedded Tomcat.",
  metadata/tomcat/jasper-runtime/index.json:9:    "description" : "Apache Tomcat Jasper Runtime provides the runtime support classes used by Tomcat's Jasper JSP engine for generated JSP servlets, page contexts, tag handler pooling, and expression/function support. It is part of the Tomcat 5.5 server stack and lets JSP pages compiled by Jasper execute against the servlet and JSP APIs.",
  metadata/tomcat/jasper-runtime/index.json:14:      "org.apache.jasper"
  metadata/jakarta.servlet.jsp.jstl/jakarta.servlet.jsp.jstl-api/index.json:8:    "description" : "Jakarta Standard Tag Library API defines the standard tag interfaces, support classes, validators, and utility APIs used by JSP tag libraries. It provides the API surface for core, formatting, SQL, XML, and tag-library validation features that application servers and JSTL implementations expose to Jakarta Servlet and JSP applications.",
  metadata/jakarta.servlet.jsp.jstl/jakarta.servlet.jsp.jstl-api/index.json:25:    "description" : "Jakarta Standard Tag Library API defines the standard tag interfaces, support classes, validators, and utility APIs used by JSP tag libraries. It provides the API surface for core, formatting, SQL, XML, and tag-library validation features that application servers and JSTL implementations expose to Jakarta Servlet and JSP applications.",
  metadata/javax.servlet.jsp/jsp-api/index.json:9:    "description" : "This artifact provides the JavaServer Pages 2.1 API contracts, including core JSP, tag extension, and expression language interfaces used by JSP containers and applications. It defines standard types that JSP engines and custom tag libraries implement at compile time and runtime.",
  metadata/javax.servlet/servlet-api/index.json:40:    "description" : "Provides the Java Servlet 2.3 and JSP 1.2 API interfaces and classes used by Java web applications and servlet containers to model requests, responses, sessions, filters, and JSP pages. It lets applications compile against the standard javax.servlet and javax.servlet.jsp contracts without bundling a servlet container implementation.",
  metadata/javax.servlet/javax.servlet-api/index.json:5:    "source-code-url" : "https://repo.maven.apache.org/maven2/javax/servlet/javax.servlet-api/$version$/javax.servlet-api-$version$-sources.jar",
  metadata/javax.servlet/javax.servlet-api/index.json:8:    "documentation-url" : "https://repo.maven.apache.org/maven2/javax/servlet/javax.servlet-api/$version$/javax.servlet-api-$version$-javadoc.jar",
  metadata/commons-el/commons-el/index.json:9:    "description" : "Apache Commons EL is an implementation of the JSP 2.0 Expression Language interpreter. It evaluates JSP EL expressions against servlet and JSP data using the standard javax.servlet.jsp.el APIs.",
