          _loader.addJars(webapp.addPath("WEB-INF/lib"));
          _loader.addClassPath(webapp.addPath("WEB-INF/classes"));
          _loader.setName("test");
          
          _context.loadSystemClasses();
          _context.loadServerClasses();
      }
      
