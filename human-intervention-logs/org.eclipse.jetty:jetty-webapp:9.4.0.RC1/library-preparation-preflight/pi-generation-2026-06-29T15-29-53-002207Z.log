        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>org.eclipse.jetty</groupId>
        <artifactId>jetty-jmx</artifactId>
        <version>${project.version}</version>
        <optional>true</optional>
      </dependency>
    </dependencies>
  </project>
