          if(extensions!=null)
          {
              StringTokenizer tokenizer = new StringTokenizer(extensions, ",;");
              while(tokenizer.hasMoreTokens())
                  _extensions.add(tokenizer.nextToken().trim());
          }
          
          if (context.getExtraClasspath()!=null)
              addClassPath(context.getExtraClasspath());
      }
      
