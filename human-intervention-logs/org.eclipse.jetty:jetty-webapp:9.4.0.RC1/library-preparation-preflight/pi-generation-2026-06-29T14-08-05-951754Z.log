Parser.Node;\n\n/**\n * StandardDescriptorProcessor.\n * <p>\n * Process the web.xml, web-defaults.xml, web-overrides.xml, and web-fragment.xml descriptors.\n */\npublic class StandardDescriptorProcessor extends IterativeDescriptorProcessor\n{\n    private static final Logger LOG = Log.getLogger(StandardDescriptorProcessor.class);\n\n    public static final String STANDARD_PROCESSOR = \"org.eclipse.jetty.standardDescriptorProcessor\";\n\n    final Map<String,FilterHolder> _filterHolderMap = new HashMap<>();\n    final List<FilterHolder> _filterHolders = new ArrayList<>();\n    final List<FilterMapping> _filterMappings = new ArrayList<>();\n    final Map<String,ServletHolder> _servletHolderMap = new HashMap<>();\n    final List<ServletHolder> _servletHolders = new ArrayList<>();\n    final List<ServletMapping> _servletMappings = new ArrayList<>();\n\n    public StandardDescriptorProcessor ()\njavadoc.jar ['org/eclipse/jetty/webapp/CachingWebAppClassLoader.html', 'org/eclipse/jetty/webapp/class-use/CachingWebAppClassLoader.html', 'org/eclipse/jetty/webapp/class-use/StandardDescriptorProcessor.html', 'org/eclipse/jetty/webapp/class-use/WebAppClassLoader.Context.html', 'org/eclipse/jetty/webapp/class-use/WebAppClassLoader.html', 'org/eclipse/jetty/webapp/class-use/WebAppContext.Context.html', 'org/eclipse/jetty/webapp/class-use/WebAppContext.html', 'org/eclipse/jetty/webapp/StandardDescriptorProcessor.html', 'org/eclipse/jetty/webapp/WebAppClassLoader.Context.html', 'org/eclipse/jetty/webapp/WebAppClassLoader.html', 'org/eclipse/jetty/webapp/WebAppContext.Context.html', 'org/eclipse/jetty/webapp/WebAppContext.html']\n--- org/eclipse/jetty/webapp/CachingWebAppClassLoader.html ---\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n<!-- NewPage -->\n<html lang=\"en\">\n<head>\n<!-- Generated by javadoc (1.8.0_65) on Fri Oct 21 13:07:17 MST 2016 -->\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-