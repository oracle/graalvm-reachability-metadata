t": "\nURL https://javadoc.jetty.org/jetty-9/org/eclipse/jetty/webapp/WebAppContext.html\n<!DOCTYPE HTML>\n<!-- NewPage -->\n<html lang=\"en\">\n<head>\n<!-- Generated by javadoc (11.0.23) on Mon Nov 11 12:29:27 CST 2024 -->\n<title>WebAppContext (Jetty :: Project 9.4.56.v20240826 API)</title>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<meta name=\"dc.created\" content=\"2024-11-11\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../../../../stylesheet.css\" title=\"Style\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../../../../jquery/jquery-ui.min.css\" title=\"Style\">\n<l\n---snippet---\nation\">@ManagedObject</a>(\"Web Application ContextHandler\")\npublic class <span class=\"typeNameLabel\">WebAppContext</span>\nextends <a href=\"../servlet/ServletContextHandler.html\" title=\"class in org.eclipse.jetty.servlet\">ServletContextHandler</a>\nimplements <a href=\"WebAppClassLoader.Context.html\" title=\"interface in org.eclipse.jetty.webapp\">WebAppClassLoader.Context</a></pre>\n<div class=\"block\">Web Application Context Handler.\n <p>\n The WebAppContext handler is an extension of ContextHandler that\n coordinates the construction and configuration of nested handlers:\n <a href=\"../security/ConstraintSecurityHandler.html\" title=\"class in org.eclipse.jetty.security\"><code>ConstraintSecurityHandler</code></a>, <a href=\"../server/session/SessionHandler.html\" title=\"class in org.eclipse.jetty.server.session\"><code>SessionHandler</code></a>\n and <a href=\"../servlet/ServletHandler.html\" title=\"class in org.eclipse.jetty.servlet\"><code>ServletHandler</code></a>.\n The handlers are configured by pluggable configuration classes, with\n the default being  <a href=\"WebXmlConfiguration.html\" title=\"class in org.eclipse.jetty.webapp\"><code>WebXmlConfiguration</code></a> and\n <a href=\"JettyWebXmlConfiguration.html\" title=\"class in org.eclipse.jetty.webapp\"><code>JettyWebXmlConfiguration</code></a>.</div>\n</li>\n</ul>\n</div>\n<div class=\"summary\">\n<ul class=\"blockList\">\n<li class=\"blockList\">\n<!-- ======== NESTED CLASS SUMMARY ======== -->\n<section>\n<ul class=\"blockList\">\n<li class=\"blockList\"><a id=\"nested.class.summary\">\n<!--   -->\n</a>\n<h3>Nested Class Summary</h3>\n<table class=\"memberSummary\"\n\nURL https://javadoc.jetty.org/jetty-9/org/eclipse/jetty/webapp/WebAppClassLoader.Context.html\n<!DOCTYPE HTML>\n<!-- NewPage -->\n<html lang=\"en\">\n<head>\n<!-- Generated by javadoc (11.0.23) on Mon Nov 11 12:29:27 CST 2024 -->\n<title>WebAppClassLoader.Context (Jetty :: Project 9.4.56.v20240826 API)</title>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n<meta name=\"dc.created\" content=\"2024-11-11\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../../../../stylesheet.css\" title=\"Style\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"../../../../jquery/jquery-ui.min.css\" title\n---snippet---\npan class=\"memberNameLink\"><a href=\"#isServerResource(java.lang.String,java.net.URL)\">isServerResource</a></span>&#8203;(java.lang.String&nbsp;name,\n                java.net.URL&nbsp;parentUrl)</code></th>\n<td class=\"colLast\">&nbsp;</td>\n</tr>\n<tr id=\"i4\" class=\"altColor\">\n<td class=\"colFirst\"><code>boolean</code></td>\n<th class=\"colSecond\" scope=\"row\"><code><span class=\"memberNameLink\"><a href=\"#isSystemResource(java.lang.String,java.net.URL)\">isSystemResource</a></span>&#8203;(java.lang.String&nbsp;name,\n                java.net.URL&nbsp;webappUrl)</code></th>\n<td class=\"colLast\">&nbsp;</td>\n</tr>\n<tr id=\"i5\" class=\"rowColor\">\n<td class=\"colFirst\"><code><a href=\"../util/resource/Resource.html\" title=\"class in org.eclipse.jetty.util.resource\">Resource</a></code></td>\n<th class=\"colSecond\" scope=\"row\"><code><span class=\"memberNameLink\"><a href=\"#newResource(java.lang.String)\">newResource</a></span>&#8203;(java.lang.String&nbsp;urlOrPath)</code></th>\n<td class=\"colL