s, queues, caches, and counters. It builds on Curator Framework to make these distributed-system recipes easier to use safely from JVM applications.\",\n    \"tested-versions\" : [\n      \"2.6.0\",\n      \"2.7.0\",\n      \"2.7.1\",\n      \"2.8.0\",\n      \"2.9.0\",\n      \"2.9.1\",\n      \"2.10.0\",\n      \"2.11.0\",\n      \"2.11.1\",\n      \"2.12.0\",\n      \"2.13.0\",\n      \"3.0.0\",\n      \"3.1.0\",\n      \"3.2.0\",\n      \"3.2.1\",\n      \"3.3.0\",\n      \"4.0.0\",\n      \"4.0.1\",\n      \"4.1.0\",\n      \"4.2.0\",\n      \"4.3.0\"\n    ],\n    \"allowed-packages\" : [\n      \"org.apache.curator.framework.recipes\",\n      \"org.apache.curator.utils\"\n    ]\n  }\n]\n","exit_code":0,"status":"completed"}}
