[tool-call] delta {"path":"tests/src/it.unimi.dsi/fastutil/8.1.1/src/test/java/it_unimi_dsi/fastutil/FastutilTest.java","edits":[{"oldText":"import it.unimi.dsi.fastutil.ints.IntSortedSet;\nimport it.unimi.dsi.fastutil.objects.Object2IntMap;","newText":"import it.unimi.dsi.fastutil.ints.IntSortedSet;\nimport it.unimi.dsi.fastutil.Hash.Strategy;\nimport it.unimi.dsi.fastutil.objects.Object2IntMap;"},{"oldText":"import it.unimi.dsi.fastutil.objects.Object2IntOpenHashMap;\nimport it.unimi.dsi.fastutil.objects.ObjectIterator;\nimport java.util.HashMap;","newText":"import it.unimi.dsi.fastutil.objects.Object2IntOpenHashMap;\nimport it.unimi.dsi.fastutil.objects.ObjectIterator;\nimport it.unimi.dsi.fastutil.objects.ObjectOpenCustomHashSet;\nimport java.util.HashMap;\nimport java.util.Locale;"},{"oldText":"    @Test\n    void sortedSetAndPriorityQueueProvidePrimitiveOrderedContainers() {","newText":"    @Test\n    void objectOpenCustomHashSetUsesCallerProvidedHashStrategy() {\n        Strategy<String> caseInsensitiveStrategy = new Strategy<>() {\n            @Override\n            public int hashCode(String value) {\n                return value.toLowerCase(Locale.ROOT).hashCode();\n            }\n\n            @Override\n            public boolean equals(String left, String right) {\n                return left.equalsIgnoreCase(right);\n            }\n        };\n        ObjectOpenCustomHashSet<String> headers = new ObjectOpenCustomHashSet<>(caseInsensitiveStrategy);\n        String canonicalContentType = \"Content-Type\";\n\n        assertThat(headers.add(canonicalContentType)).isTrue();\n        assertThat(headers.add(\"content-type\")).isFalse();\n        assertThat(headers.addOrGet(\"CONTENT-TYPE\")).isSameAs(canonicalContentType);\n        assertThat(headers.contains(\"CoNtEnT-TyPe\")).isTrue();\n        assertThat(headers.size()).isEqualTo(1);\n\n        assertThat(headers.addOrGet(\"Accept\")).isEqualTo(\"Accept\");\n        assertThat(headers).containsExactlyInAny