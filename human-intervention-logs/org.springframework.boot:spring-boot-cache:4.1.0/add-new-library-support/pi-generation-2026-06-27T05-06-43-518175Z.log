  	}
  
  	public Caffeine getCaffeine() {
  		return this.caffeine;
  	}
  
  	public Couchbase getCouchbase() {
  		return this.couchbase;
  	}
  
  	public Infinispan getInfinispan() {
  		return this.infinispan;
  	}
  
