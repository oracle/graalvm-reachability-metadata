      @Test
      void cachesEndpointDescribesAndClearsCachesAcrossCacheManagers() {
          ConcurrentMapCacheManager applicationCacheManager = new ConcurrentMapCacheManager("books", "authors");
          ConcurrentMapCacheManager sessionCacheManager = new ConcurrentMapCacheManager("sessions");
          Cache books = applicationCacheManager.getCache("books");
          Cache sessions = sessionCacheManager.getCache("sessions");
          assertThat(books).isNotNull();
          assertThat(sessions).isNotNull();
          books.put("isbn", "Spring Boot in Action");
          sessions.put("id", "session-1");
          CachesEndpoint endpoint = new CachesEndpoint(
                  Map.of("application", applicationCacheManager, "session", sessionCacheManager));
  
          CachesEndpoint.CachesDescriptor caches = endpoint.caches();
  
          assertThat(caches.getCacheManagers()).containsOnlyKeys("application", "session");
          assertThat(caches.getCacheManagers().get("application").getCaches()).containsOnlyKeys("books", "authors");
          assertThat(caches.getCacheManagers().get("session").getCaches()).containsOnlyKeys("sessions");
          CachesEndpoint.CacheEntryDescriptor booksEntry = endpoint.cache("books", "application");
          assertThat(booksEntry.getName()).isEqualTo("books");
          assertThat(booksEntry.getCacheManager()).isEqualTo("application");
          assertThat(booksEntry.getTarget()).isNotBlank();
  
          assertThat(endpoint.clearCache("books", "application")).isTrue();
          assertThat(books.get("isbn")).isNull();
          assertThat(sessions.get("id", String.class)).isEqualTo("session-1");
          assertThat(endpoint.clearCache("missing", "application")).isFalse();
  
          endpoint.clearCaches();
          assertThat(sessions.get("id")).isNull();
      }
  
