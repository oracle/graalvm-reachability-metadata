[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot-cache/4.1.0/src/test/java/org_springframework_boot/spring_boot_cache/Spring_boot_cacheTest.java","edits":[{"oldText":"import java.util.List;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;","newText":"import java.util.List;\nimport org.junit.jupiter.api.Test;"},{"oldText":"import org.springframework.boot.autoconfigure.cache.CacheType;\nimport org.springframework.boot.cache.actuate.endpoint.CachesEndpoint;\nimport org.springframework.boot.cache.autoconfigure.CacheAutoConfiguration;","newText":"import org.springframework.boot.autoconfigure.cache.CacheType;\nimport org.springframework.boot.cache.autoconfigure.CacheAutoConfiguration;"},{"oldText":"    @Test\n    void cachesEndpointClearsCachesAcrossCacheManagers() {\n        ConcurrentMapCacheManager applicationCacheManager = new ConcurrentMapCacheManager(\"books\", \"authors\");\n        ConcurrentMapCacheManager sessionCacheManager = new ConcurrentMapCacheManager(\"sessions\");\n        Cache books = applicationCacheManager.getCache(\"books\");\n        Cache authors = applicationCacheManager.getCache(\"authors\");\n        Cache sessions = sessionCacheManager.getCache(\"sessions\");\n        assertThat(books).isNotNull();\n        assertThat(authors).isNotNull();\n        assertThat(sessions).isNotNull();\n        books.put(\"isbn\", \"Spring Boot in Action\");\n        authors.put(\"name\", \"Author\");\n        sessions.put(\"id\", \"session-1\");\n        CachesEndpoint endpoint = new CachesEndpoint(\n                Map.of(\"application\", applicationCacheManager, \"session\", sessionCacheManager));\n\n        assertThat(endpoint.clearCache(\"books\", \"application\")).isTrue();\n        assertThat(books.get(\"isbn\")).isNull();\n        assertThat(authors.get(\"name\", String.class)).isEqualTo(\"Author\");\n        assertThat(sessions.get(\"id\", String.class)).isEqualTo(\"session-1\");\n        assertThat(endpoint.clearCache(\"missing\", \"application\")).isFalse();\n\n        endpoint.clearCaches();\n        assertThat(authors.get(\"name\")).isNull();\n        assertThat(sessions.get(\"id\")).isNull();\n    }\n","newText":"    @Test\n    void simpleCacheAutoConfigurationCreatesDynamicCachesWhenNamesAreNotConfigured() {\n        this.contextRunner.withPropertyValues(\"spring.cache.type=simple\").run((context) -> {\n            assertThat(context).hasSingleBean(CacheManager.class);\n            CacheManager cacheManager = context.getBean(CacheManager.class);\n\n            assertThat(cacheManager).isInstanceOf(ConcurrentMapCacheManager.class);\n            assertThat(cacheManager.getCacheNames()).isEmpty();\n            Cache dynamic = cacheManager.getCache(\"dynamic\");\n            assertThat(dynamic).isNotNull();\n            dynamic.put(\"key\", \"value\");\n            assertThat(dynamic.get(\"key\", String.class)).isEqualTo(\"value\");\n            assertThat(cacheManager.getCacheNames()).containsExactly(\"dynamic\");\n            assertThat(cacheManager.getCache(\"dynamic\")).isSameAs(dynamic);\n        });\n    }\n"}]}
