[tool-call] delta {"path":"tests/src/org.seleniumhq.selenium/selenium-ie-driver/4.4.0/src/test/java/org_seleniumhq_selenium/selenium_ie_driver/Selenium_ie_driverTest.java","edits":[{"oldText":"        MutableCapabilities nestedCapabilities = new MutableCapabilities();\n        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:tabs\");\n        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);\n        options.setCapability(IE_OPTIONS, nestedCapabilities);\n\n        Object nestedIeOptions = options.getCapability(IE_OPTIONS);\n        assertThat(nestedIeOptions).isInstanceOf(Capabilities.class);\n        Capabilities nestedOptionCapabilities = (Capabilities) nestedIeOptions;\n        assertThat(nestedOptionCapabilities.getCapability(INITIAL_BROWSER_URL)).isEqualTo(\"about:tabs\");\n        assertThat(nestedOptionCapabilities.getCapability(REQUIRE_WINDOW_FOCUS)).isEqualTo(true);\n","newText":"        MutableCapabilities nestedCapabilities = new MutableCapabilities();\n        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:tabs\");\n        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);\n        InternetExplorerOptions capabilitiesOptions = new InternetExplorerOptions();\n        capabilitiesOptions.setCapability(IE_OPTIONS, nestedCapabilities);\n\n        assertThat(ieOptionsFrom(capabilitiesOptions)).containsEntry(INITIAL_BROWSER_URL, \"about:tabs\");\n        assertThat(ieOptionsFrom(capabilitiesOptions)).containsEntry(REQUIRE_WINDOW_FOCUS, true);\n"}]}
