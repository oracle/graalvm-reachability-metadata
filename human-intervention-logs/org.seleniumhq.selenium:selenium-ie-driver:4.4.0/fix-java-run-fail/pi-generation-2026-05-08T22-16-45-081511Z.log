.ie.option\");\n   124\t        assertThat(options.getCapability(\"unknown.ie.option\")).isNull();\n   125\t\n   126\t        MutableCapabilities nestedCapabilities = new MutableCapabilities();\n   127\t        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:tabs\");\n   128\t        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);\n   129\t        options.setCapability(IE_OPTIONS, nestedCapabilities);\n   130\t\n   131\t        ieOptions = ieOptionsFrom(options);\n   132\t        assertThat(ieOptions).containsEntry(INITIAL_BROWSER_URL, \"about:tabs\");\n   133\t        assertThat(ieOptions).containsEntry(REQUIRE_WINDOW_FOCUS, true);\n   134\t    }\n   135\t\n   136\t    @Test\n   137\t    void settingInvalidIeOptionsCapabilityFailsFast() {\n   138\t        InternetExplorerOptions options = new InternetExplorerOptions();\n   139\t\n   140\t        assertThatThrownBy(() -> options.setCapability(IE_OPTIONS, \"not-a-map\"))\n   141\t                .isInstanceOf(IllegalArgumentException.class)\n   142\t                .hasMessageContaining(IE_OPTIONS);\n   143\t    }\n   144\t\n   145\t    @Test\n   146\t    void constructedAndMergedOptionsKeepInternetExplorerSpecificCapabilities() {\n   147\t        MutableCapabilities sourceCapabilities = new MutableCapabilities();\n   148\t        sourceCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:blank\");\n   149\t        sourceCapabilities.setCapability(IGNORE_ZOOM_SETTING, true);\n   150\t\n   151\t        InternetExplorerOptions constructed = new InternetExplorerOptions(sourceCapabilities);\n   152\t        InternetExplorerOptions merged = new InternetExplorerOptions().merge(sourceCapabilities);\n   153\t\n   154\t        assertThat(constructed.getBrowserName()).isEqualTo(IE_BROWSER_NAME);\n   155\t        assertThat(ieOptionsFrom(constructed)).containsEntry(INITIAL_BROWSER_URL, \"about:blank\");\n   156\t        assertThat(ieOptionsFrom(constructed)).containsEntry(IGNORE_ZOOM_SETTING, true);\n   157\t        assertThat(merged.getBrowserName()).isEqualTo(IE_BROWSER_NAME);\n   158\t        assertThat(ieOptionsFrom(merged)).containsEntry(INITIAL_BROWSER_URL, \"about:blank\");\n   159\t        assertThat(ieOptionsFrom(merged)).containsEntry(IGNORE_ZOOM_SETTING, true);\n   160\t    }\n   161\t\n   162\t    @Test\n   163\t    void elementScrollBehaviorConvertsBetweenEnumAndDriverWireValues() {\n   164\t        assertThat(ElementScrollBehavior.TOP.getValue()).isZero();\n   165\t        assertThat(ElementScrollBehavior.TOP.toString()).isEqualTo(\"0\");\n   166\t        assertThat(ElementScrollBehavior.BOTTOM.getValue()).isOne();\n   167\t        assertThat(ElementScrollBehavior.BOTTOM.toString()).isEqualTo(\"1\");\n   168\t        assertThat(ElementScrollBehavior.fromString(\"0\")).isSameAs(ElementScrollBehavior.TOP);\n   169\t        assertThat(ElementScrollBehavior.fromString(\"1\")).isSameAs(ElementScrollBehavior.BOTTOM);\n   170\t        assertThat(ElementScrollBehavior.fromString(\"missing\")).isNull();\n"}], "isError": false, "timestamp": 1778278633105}]}
