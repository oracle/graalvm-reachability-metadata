     110	
     111	    @Test
     112	    void settingIeOptionsCapabilityAcceptsMapsAndCapabilities() {
     113	        InternetExplorerOptions options = new InternetExplorerOptions();
     114	
     115	        options.setCapability(IE_OPTIONS, Map.of(
     116	                IGNORE_ZOOM_SETTING, true,
     117	                NATIVE_EVENTS, false,
     118	                "unknown.ie.option", "ignored"));
     119	
     120	        Map<String, Object> ieOptions = ieOptionsFrom(options);
     121	        assertThat(ieOptions).containsEntry(IGNORE_ZOOM_SETTING, true);
     122	        assertThat(ieOptions).containsEntry(NATIVE_EVENTS, false);
     123	        assertThat(ieOptions).containsEntry("unknown.ie.option", "ignored");
     124	        assertThat(options.getCapability("unknown.ie.option")).isNull();
     125	
     126	        MutableCapabilities nestedCapabilities = new MutableCapabilities();
     127	        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, "about:tabs");
     128	        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);
     129	        options.setCapability(IE_OPTIONS, nestedCapabilities);
     130	
     131	        assertThat(options.getCapability(IE_OPTIONS)).isSameAs(nestedCapabilities);
     132	        assertThat(nestedCapabilities.getCapability(INITIAL_BROWSER_URL)).isEqualTo("about:tabs");
     133	        assertThat(nestedCapabilities.getCapability(REQUIRE_WINDOW_FOCUS)).isEqualTo(true);
     134	    }
     135	
     136	    @Test
     137	    void settingInvalidIeOptionsCapabilityFailsFast() {
     138	        InternetExplorerOptions options = new InternetExplorerOptions();
     139	
     140	        assertThatThrownBy(() -> options.setCapability(IE_OPTIONS, "not-a-map"))
     141	                .isInstanceOf(IllegalArgumentException.class)
     142	                .hasMessageContaining(IE_OPTIONS);
     143	    }
     144	
     145	    @Test
     146	    void constructedAndMergedOptionsKeepInternetExplorerSpecificCapabilities() {
     147	        MutableCapabilities sourceCapabilities = new MutableCapabilities();
     148	        sourceCapabilities.setCapability(INITIAL_BROWSER_URL, "about:blank");
     149	        sourceCapabilities.setCapability(IGNORE_ZOOM_SETTING, true);
     150	
     151	        InternetExplorerOptions constructed = new InternetExplorerOptions(sourceCapabilities);
     152	        InternetExplorerOptions sourceOptions = new InternetExplorerOptions()
     153	                .withInitialBrowserUrl("about:blank")
     154	                .ignoreZoomSettings();
     155	        InternetExplorerOptions merged = new InternetExplorerOptions().merge(sourceOptions);
     156	
     157	        assertThat(constructed.getBrowserName()).isEqualTo(IE_BROWSER_NAME);
     158	        assertThat(ieOptionsFrom(constructed)).containsEntry(INITIAL_BROWSER_URL, "about:blank");
     159	        assertThat(ieOptionsFrom(constructed)).containsEntry(IGNORE_ZOOM_SETTING, true);
     160	        assertThat(merged.getBrowserName()).isEqualTo(IE_BROWSER_NAME);
     161	        assertThat(ieOptionsFrom(merged)).containsEntry(INITIAL_BROWSER_URL, "about:blank");
     162	        assertThat(ieOptionsFrom(merged)).containsEntry(IGNORE_ZOOM_SETTING, true);
     163	    }
     164	
     165	    @Test
     166	    void elementScrollBehaviorConvertsBetweenEnumAndDriverWireValues() {
     167	        assertThat(ElementScrollBehavior.TOP.getValue()).isZero();
     168	        assertThat(ElementScrollBehavior.TOP.toString()).isEqualTo("0");
     169	        assertThat(ElementScrollBehavior.BOTTOM.getValue()).isOne();
     170	        assertThat(ElementScrollBehavior.BOTTOM.toString()).isEqualTo("1");
