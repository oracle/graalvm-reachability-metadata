[tool-call] delta {"path":"tests/src/org.seleniumhq.selenium/selenium-ie-driver/4.4.0/src/test/java/org_seleniumhq_selenium/selenium_ie_driver/Selenium_ie_driverTest.java","edits":[{"oldText":"                .destructivelyEnsureCleanSession()\n                .addCommandSwitches(\"-private\", \"-extoff\")\n                .addCommandSwitches(\"-k\")\n                .usePerProcessProxy()\n","newText":"                .destructivelyEnsureCleanSession()\n                .addCommandSwitches(\"-private\", \"-extoff\", \"-k\")\n                .usePerProcessProxy()\n"},{"oldText":"    void settingIeOptionsCapabilityExpandsKnownNonNullEntries() {\n        InternetExplorerOptions options = new InternetExplorerOptions();\n\n        options.setCapability(IE_OPTIONS, Map.of(\n                IGNORE_ZOOM_SETTING, true,\n                NATIVE_EVENTS, false,\n                \"unknown.ie.option\", \"ignored\"));\n\n        Map<String, Object> firstIeOptions = ieOptionsFrom(options);\n        assertThat(firstIeOptions).containsEntry(IGNORE_ZOOM_SETTING, true);\n        assertThat(firstIeOptions).containsEntry(NATIVE_EVENTS, false);\n        assertThat(firstIeOptions).doesNotContainKey(\"unknown.ie.option\");\n        assertThat(options.getCapability(\"unknown.ie.option\")).isNull();\n\n        MutableCapabilities nestedCapabilities = new MutableCapabilities();\n        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:tabs\");\n        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);\n        options.setCapability(IE_OPTIONS, nestedCapabilities);\n\n        Map<String, Object> secondIeOptions = ieOptionsFrom(options);\n        assertThat(secondIeOptions).containsEntry(INITIAL_BROWSER_URL, \"about:tabs\");\n        assertThat(secondIeOptions).containsEntry(REQUIRE_WINDOW_FOCUS, true);\n        assertThat(secondIeOptions).doesNotContainKeys(IGNORE_ZOOM_SETTING, NATIVE_EVENTS);\n    }\n","newText":"    void settingIeOptionsCapabilityAcceptsMapAndCapabilitiesValues() {\n        InternetExplorerOptions options = new InternetExplorerOptions();\n        Map<String, Object> configuredOptions = Map.of(\n                IGNORE_ZOOM_SETTING, true,\n                NATIVE_EVENTS, false,\n                \"custom.ie.option\", \"preserved\");\n\n        options.setCapability(IE_OPTIONS, configuredOptions);\n\n        assertThat(options.getCapability(IE_OPTIONS)).isEqualTo(configuredOptions);\n        assertThat(options.getCapability(\"custom.ie.option\")).isNull();\n\n        MutableCapabilities nestedCapabilities = new MutableCapabilities();\n        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:tabs\");\n        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);\n        options.setCapability(IE_OPTIONS, nestedCapabilities);\n\n        assertThat(options.getCapability(IE_OPTIONS)).isSameAs(nestedCapabilities);\n    }\n"}]}
[tool-call] end id=call_6bXr6vXl4g89klM3mkHqC03n|fc_04d24da11956a1df016a23ca4e0fc481969cb287f17f9fb0ea name=edit args={"path": "tests/src/org.seleniumhq.selenium/selenium-ie-driver/4.4.0/src/test/java/org_seleniumhq_selenium/selenium_ie_driver/Selenium_ie_driverTest.java", "edits": [{"oldText": "                .destructivelyEnsureCleanSession()\n                .addCommandSwitches(\"-private\", \"-extoff\")\n                .addCommandSwitches(\"-k\")\n                .usePerProcessProxy()\n", "newText": "                .destructivelyEnsureCleanSession()\n                .addCommandSwitches(\"-private\", \"-extoff\", \"-k\")\n                .usePerProcessProxy()\n"}, {"oldText": "    void settingIeOptionsCapabilityExpandsKnownNonNullEntries() {\n        InternetExplorerOptions options = new InternetExplorerOptions();\n\n        options.setCapability(IE_OPTIONS, Map.of(\n                IGNORE_ZOOM_SETTING, true,\n                NATIVE_EVENTS, false,\n                \"unknown.ie.option\", \"ignored\"));\n\n        Map<String, Object> firstIeOptions = ieOptionsFrom(options);\n        assertThat(firstIeOptions).containsEntry(IGNORE_ZOOM_SETTING, true);\n        assertThat(firstIeOptions).containsEntry(NATIVE_EVENTS, false);\n        assertThat(firstIeOptions).doesNotContainKey(\"unknown.ie.option\");\n        assertThat(options.getCapability(\"unknown.ie.option\")).isNull();\n\n        MutableCapabilities nestedCapabilities = new MutableCapabilities();\n        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:tabs\");\n        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);\n        options.setCapability(IE_OPTIONS, nestedCapabilities);\n\n        Map<String, Object> secondIeOptions = ieOptionsFrom(options);\n        assertThat(secondIeOptions).containsEntry(INITIAL_BROWSER_URL, \"about:tabs\");\n        assertThat(secondIeOptions).containsEntry(REQUIRE_WINDOW_FOCUS, true);\n        assertThat(secondIeOptions).doesNotContainKeys(IGNORE_ZOOM_SETTING, NATIVE_EVENTS);\n    }\n", "newText": "    void settingIeOptionsCapabilityAcceptsMapAndCapabilitiesValues() {\n        InternetExplorerOptions options = new InternetExplorerOptions();\n        Map<String, Object> configuredOptions = Map.of(\n                IGNORE_ZOOM_SETTING, true,\n                NATIVE_EVENTS, false,\n                \"custom.ie.option\", \"preserved\");\n\n        options.setCapability(IE_OPTIONS, configuredOptions);\n\n        assertThat(options.getCapability(IE_OPTIONS)).isEqualTo(configuredOptions);\n        assertThat(options.getCapability(\"custom.ie.option\")).isNull();\n\n        MutableCapabilities nestedCapabilities = new MutableCapabilities();\n        nestedCapabilities.setCapability(INITIAL_BROWSER_URL, \"about:tabs\");\n        nestedCapabilities.setCapability(REQUIRE_WINDOW_FOCUS, true);\n        options.setCapability(IE_OPTIONS, nestedCapabilities);\n\n        assertThat(options.getCapability(IE_OPTIONS)).isSameAs(nestedCapabilities);\n    }\n"}]}
