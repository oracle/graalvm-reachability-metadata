e = 123L;\n    }\n\n    private static class ParsedLayoutTarget extends BaseLayoutTarget {\n        private static final String STATIC_LABEL = \"ignored\";\n\n        private final String label = \"layout\";\n        private final int count = 7;\n    }\n}\n"}
