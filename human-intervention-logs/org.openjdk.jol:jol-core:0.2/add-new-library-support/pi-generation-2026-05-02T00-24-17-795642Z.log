  package org.openjdk.jol.info;
  
  /**
   * Object path in object graph.
   *
   * @author Aleksey Shipilev
   */
  public class GraphPathRecord {
      private final String path;
      private final Object obj;
      private final int depth;
  
      public GraphPathRecord(String path, Object obj, int depth) {
          this.path = path;
          this.obj = obj;
          this.depth = depth;
      }
  
      @Override
      public boolean equals(Object o) {
          if (this == o) return true;
          if (o == null || getClass() != o.getClass()) return false;
  
          GraphPathRecord that = (GraphPathRecord) o;
  
          if (!obj.equals(that.obj)) return false;
  
          return true;
      }
  
      @Override
      public int hashCode() {
          return obj.hashCode();
      }
  
      @Override
      public String toString() {
          return "GraphPathRecord{" +
                  "path='" + path + '\'' +
                  ", obj=" + obj +
                  '}';
      }
  
      public String path() {
          return path;
      }
  
      public Object obj() {
          return obj;
      }
  
      public int depth() {
          return depth;
      }
  }
