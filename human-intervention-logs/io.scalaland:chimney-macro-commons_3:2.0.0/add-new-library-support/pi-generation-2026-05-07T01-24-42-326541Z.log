  package io_scalaland.chimney_macro_commons_3
  
  import io.scalaland.chimney.internal.compiletime.DefinitionsPlatform
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Test
  
  import scala.quoted.Quotes
  import scala.quoted.staging.Compiler
  import scala.quoted.staging.run
  
  class TypesInnerModuleSingletonAnonymous2Test {
    @Test
    def extractsTopLevelAndNestedModuleSingletons(): Unit = {
      try {
        assertEquals(
          List("top-level singleton", "nested singleton"),
          TypesInnerModuleSingletonAnonymous2Staging.extractSingletonNames()
        )
      } catch {
        case error: Error =>
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
            throw error
          }
      }
    }
  }
  
  object TypesInnerModuleSingletonAnonymous2Fixtures {
    object TopLevelSingleton {
      val name: String = "top-level singleton"
    }
  
    object Outer {
      object NestedSingleton {
        val name: String = "nested singleton"
      }
    }
  }
  
  object TypesInnerModuleSingletonAnonymous2Staging {
    private given Compiler = Compiler.make(getClass.getClassLoader)
  
    def extractSingletonNames(): List[String] = run {
      new SingletonExtractor().extractNames
    }
  
    private final class SingletonExtractor(using Quotes) extends DefinitionsPlatform {
      def extractNames: _root_.scala.quoted.Expr[List[String]] = {
        val names: List[String] = List(
          Type
            .extractObjectSingleton[TypesInnerModuleSingletonAnonymous2Fixtures.TopLevelSingleton.type]
            .map(_.name)
            .getOrElse("missing top-level singleton"),
          Type
            .extractObjectSingleton[TypesInnerModuleSingletonAnonymous2Fixtures.Outer.NestedSingleton.type]
            .map(_.name)
            .getOrElse("missing nested singleton")
        )
  
        _root_.scala.quoted.Expr.ofList(names.map(_root_.scala.quoted.Expr(_)))
      }
    }
  }
