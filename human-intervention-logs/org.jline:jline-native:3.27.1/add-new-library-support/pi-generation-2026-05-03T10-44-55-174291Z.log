[tool-call] delta {"path":"tests/src/org.jline/jline-native/3.27.1/src/test/java/org_jline/jline_native/JLineNativeLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jline.jline_native;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.jline.nativ.JLineNativeLoader;\nimport org.jline.nativ.OSInfo;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JLineNativeLoaderTest {\n\n    @Test\n    void initializeExtractsAndLoadsBundledNativeLibrary(@TempDir final Path tempDirectory) throws IOException {\n        Path extractionDirectory = tempDirectory.resolve(\"jline-native-extraction\");\n        Files.createDirectories(extractionDirectory);\n        String mappedLibraryName = mapLibraryName(\"jlinenative\");\n        String nativeResourcePath = \"/org/jline/nativ/\" + OSInfo.getNativeLibFolderPathForCurrentOS()\n                + \"/\" + mappedLibraryName;\n        URL nativeResource = JLineNativeLoader.class.getResource(nativeResourcePath);\n\n        assertThat(nativeResource).isNotNull();\n\n        String previousTempDirectory = setSystemProperty(\"jline.tmpdir\", extractionDirectory.toString());\n        String previousLibraryPath = clearSystemProperty(\"library.jline.path\");\n        String previousLibraryName = clearSystemProperty(\"library.jline.name\");\n        try {\n            assertThat(JLineNativeLoader.initialize()).isTrue();\n        } finally {\n            restoreSystemProperty(\"jline.tmpdir\", previousTempDirectory);\n            restoreSystemProperty(\"library.jline.path\", previousLibraryPath);\n            restoreSystemProperty(\"library.jline.name\", previousLibraryName);\n        }\n\n        assertThat(JLineNativeLoader.getNativeLibrarySourceUrl()).contains(nativeResourcePath.substring(1));\n        Path extractedLibrary = Path.of(JLineNativeLoader.getNativeLibraryPath());\n        assertThat(extractedLibrary).exists().isRegularFile();\n        assertThat(extractedLibrary.getParent()).isEqualTo(extractionDirectory);\n        assertThat(extractedLibrary.getFileName().toString())\n                .startsWith(\"jlinenative-\" + JLineNativeLoader.getVersion())\n                .endsWith(mappedLibraryName);\n        assertThat(Files.readAllBytes(extractedLibrary)).isEqualTo(resourceBytes(nativeResource));\n        if (!OSInfo.getOSName().equals(\"Windows\")) {\n            assertThat(Files.isExecutable(extractedLibrary)).isTrue();\n        }\n    }\n\n    private static byte[] resourceBytes(final URL resource) throws IOException {\n        try (InputStream inputStream = resource.openStream()) {\n            return inputStream.readAllBytes();\n        }\n    }\n\n    private static String mapLibraryName(final String libraryName) {\n        String mappedLibraryName = System.mapLibraryName(libraryName);\n        if (mappedLibraryName.endsWith(\".dylib\")) {\n            return mappedLibraryName.substring(0, mappedLibraryName.length() - \".dylib\".length()) + \".jnilib\";\n        }\n        return mappedLibraryName;\n    }\n\n    private static String setSystemProperty(final String key, final String value) {\n        String previousValue = System.getProperty(key);\n        System.setProperty(key, value);\n        return previousValue;\n    }\n\n    private static String clearSystemProperty(final String key) {\n        String previousValue = System.getProperty(key);\n        System.clearProperty(key);\n        return previousValue;\n    }\n\n    private static void restoreSystemProperty(final String key, final String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(key);\n        } else {\n            System.setProperty(key, previousValue);\n        }\n    }\n}\n"}
