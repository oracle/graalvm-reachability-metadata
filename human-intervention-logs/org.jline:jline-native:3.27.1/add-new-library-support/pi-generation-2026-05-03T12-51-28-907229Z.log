[tool-call] delta {"path":"tests/src/org.jline/jline-native/3.27.1/src/test/java/org_jline/jline_native/JLineNativeLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jline.jline_native;\n\nimport java.nio.file.Path;\n\nimport org.jline.nativ.JLineNativeLoader;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JLineNativeLoaderTest {\n    @Test\n    void initializeExtractsAndLoadsBundledNativeLibrary() {\n        String originalLibraryPath = System.clearProperty(\"library.jline.path\");\n        String originalLibraryName = System.clearProperty(\"library.jline.name\");\n        try {\n            assertThat(JLineNativeLoader.initialize()).isTrue();\n\n            String nativeLibraryPath = JLineNativeLoader.getNativeLibraryPath();\n            assertThat(nativeLibraryPath).isNotBlank();\n            assertThat(Path.of(nativeLibraryPath)).exists();\n            assertThat(JLineNativeLoader.getNativeLibrarySourceUrl())\n                    .contains(\"/org/jline/nativ/\")\n                    .contains(\"jlinenative\");\n        } finally {\n            restoreProperty(\"library.jline.path\", originalLibraryPath);\n            restoreProperty(\"library.jline.name\", originalLibraryName);\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}
[tool-call] end id=call_TDlKfj8LkV4NVsp3vZjC1U8C|fc_0756f404e31947770169f744b59b08819f9ce79d3c09173460 name=write args={"path": "tests/src/org.jline/jline-native/3.27.1/src/test/java/org_jline/jline_native/JLineNativeLoaderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jline.jline_native;\n\nimport java.nio.file.Path;\n\nimport org.jline.nativ.JLineNativeLoader;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JLineNativeLoaderTest {\n    @Test\n    void initializeExtractsAndLoadsBundledNativeLibrary() {\n        String originalLibraryPath = System.clearProperty(\"library.jline.path\");\n        String originalLibraryName = System.clearProperty(\"library.jline.name\");\n        try {\n            assertThat(JLineNativeLoader.initialize()).isTrue();\n\n            String nativeLibraryPath = JLineNativeLoader.getNativeLibraryPath();\n            assertThat(nativeLibraryPath).isNotBlank();\n            assertThat(Path.of(nativeLibraryPath)).exists();\n            assertThat(JLineNativeLoader.getNativeLibrarySourceUrl())\n                    .contains(\"/org/jline/nativ/\")\n                    .contains(\"jlinenative\");\n        } finally {\n            restoreProperty(\"library.jline.path\", originalLibraryPath);\n            restoreProperty(\"library.jline.name\", originalLibraryName);\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}
