dsBundledNativeLibrary() {\n        String originalLibraryPath = System.clearProperty(\"library.jline.path\");\n        String originalLibraryName = System.clearProperty(\"library.jline.name\");\n        try {\n            assertThat(JLineNativeLoader.initialize()).isTrue();\n\n            String nativeLibraryPath = JLineNativeLoader.getNativeLibraryPath();\n            assertThat(nativeLibraryPath).isNotBlank();\n            assertThat(Path.of(nativeLibraryPath)).exists();\n            assertThat(JLineNativeLoader.getNativeLibrarySourceUrl())\n                    .contains(\"/org/jline/nativ/\")\n                    .contains(\"jlinenative\");\n        } finally {\n            restoreProperty(\"library.jline.path\", originalLibraryPath);\n            restoreProperty(\"library.jline.name\", originalLibraryName);\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 750, "output": 1451, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21145, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777812644304, "responseId": "resp_0756f404e31947770169f744a4f590819f8a5a2c0f5e19072d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_TDlKfj8LkV4NVsp3vZjC1U8C|fc_0756f404e31947770169f744b59b08819f9ce79d3c09173460", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1514 bytes to tests/src/org.jline/jline-native/3.27.1/src/test/java/org_jline/jline_native/JLineNativeLoaderTest.java"}], "isError": false, "timestamp": 1777812662715}]}
