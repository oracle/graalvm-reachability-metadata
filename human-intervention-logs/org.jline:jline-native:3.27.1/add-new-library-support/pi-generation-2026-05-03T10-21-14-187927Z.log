  package org_jline.jline_native;
  
  import org.jline.nativ.JLineNativeLoader;
  import org.jline.nativ.OSInfo;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import java.nio.file.Path;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JLineNativeLoaderTest {
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void initializesNativeLibraryFromPackagedResource() {
          String previousTemporaryDirectory = System.getProperty("jline.tmpdir");
          System.setProperty("jline.tmpdir", temporaryDirectory.toString());
          try {
              assertThat(JLineNativeLoader.initialize()).isTrue();
  
              String libraryFileName = System.mapLibraryName("jlinenative").replace(".dylib", ".jnilib");
              String nativeLibrarySourceUrl = JLineNativeLoader.getNativeLibrarySourceUrl();
  
              assertThat(JLineNativeLoader.getNativeLibraryPath())
                      .isNotBlank()
                      .contains(temporaryDirectory.toString())
                      .endsWith(libraryFileName);
              assertThat(nativeLibrarySourceUrl)
                      .isNotBlank()
                      .contains("/org/jline/nativ/" + OSInfo.getNativeLibFolderPathForCurrentOS() + "/")
                      .endsWith("/" + libraryFileName);
          } finally {
              if (previousTemporaryDirectory == null) {
                  System.clearProperty("jline.tmpdir");
              } else {
                  System.setProperty("jline.tmpdir", previousTemporaryDirectory);
              }
          }
      }
  }
