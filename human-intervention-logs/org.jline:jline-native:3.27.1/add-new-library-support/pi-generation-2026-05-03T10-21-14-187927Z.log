                  if (!Arrays.equals(buffer1, buffer2)) {
                      return "Content differs";
                  }
                  // Otherwise same bytes read, so continue ...
              } else {
                  // Nothing more in stream 1 ...
                  if (numRead2 > 0) {
                      return "EOF on first stream but not second";
                  } else {
                      return null;
                  }
              }
