arProperty(\"jline.tmpdir\");\n            } else {\n                System.setProperty(\"jline.tmpdir\", previousTemporaryDirectory);\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 870, "output": 481, "cacheRead": 16896, "cacheWrite": 0, "totalTokens": 18247, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777803619127, "responseId": "resp_0bb8c24b674491cd0169f72163ac188195b1765f6aafd83850"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_dxy0DFDDjLEEWVPBN62SP62d|fc_0bb8c24b674491cd0169f7216466bc8195b1c34dc9b5b0231c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1759 bytes to tests/src/org.jline/jline-native/3.27.1/src/test/java/org_jline/jline_native/JLineNativeLoaderTest.java"}], "isError": false, "timestamp": 1777803623664}]}
