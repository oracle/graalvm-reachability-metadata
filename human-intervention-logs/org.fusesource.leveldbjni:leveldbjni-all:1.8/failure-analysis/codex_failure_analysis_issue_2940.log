ry(MISSING_LIBRARY_NAME, null, classLoader);\\n\\n        UnsatisfiedLinkError error = assertThrows(UnsatisfiedLinkError.class, library::load);\\n\\n        assertThat(error).hasMessageContaining(\\\"Could not load library\\\");\\n        assertThat(classLoader.resourceNames()).containsExactly(\\n                library.getArchSpecifcResourcePath(),\\n                library.getPlatformSpecifcResourcePath(),\\n                library.getOperatingSystemSpecifcResourcePath(),\\n                library.getResorucePath());\\n    }\\n\\n    private static final class RecordingClassLoader extends ClassLoader {\\n        private final List<String> resourceNames = new ArrayList<>();\\n\\n        private RecordingClassLoader() {\\n            super(null);\\n        }\\n\\n        @Override\\n        public URL getResource(String name) {\\n            resourceNames.add(name);\\n            return null;\\n        }\\n\\n        private List<String> resourceNames() {\\n            return resourceNames;\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1782658869972}}\nhuman-intervention-logs/org.fusesource.leveldbjni:leveldbjni-all:1.8/add-new-library-support/pi-generation-2026-06-28T15-01-39-305896Z.log:1919:  import java.io.IOException;\nhuman-intervention-logs/org.fusesource.leveldbjni:leveldbjni-all:1.8/add-new-library-support/pi-generation-2026-06-28T15-01-39-305896Z.log:1948:                  .isInstanceOf(UnsatisfiedLinkError.class)\nhuman-intervention-logs/org.fusesource.leveldbjni:leveldbjni-all:1.8/add-new-library-support/pi-generation-2026-06-28T15-01-39-305896Z.log:1955:      void loadMakesExtractedNativeLibraryExecutableBeforeLoading(@TempDir final Path tempDirectory) throws IOException {\nhuman-intervention-logs/org.fusesource.leveldbjni:leveldbjni-all:1.8/add-new-library-support/pi-generation-2026-06-28T15-01-39-305896Z.log:1976:                      .isInstanceOf(UnsatisfiedLinkError.class)\nhuman-intervention-logs/org.fusesource.leveldbjni:leve