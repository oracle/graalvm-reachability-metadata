[tool-call] delta {"path":"tests/src/org.apache.groovy/groovy-groovysh/4.0.24/src/test/groovy/org_apache_groovy/groovy_groovysh/Groovy_groovyshTest.groovy","edits":[{"oldText":"import jline.console.completer.Completer\nimport org.apache.groovy.groovysh.BufferManager\nimport org.apache.groovy.groovysh.Command\nimport org.apache.groovy.groovysh.CommandRegistry\nimport org.apache.groovy.groovysh.completion.CommandNameCompleter\nimport org.junit.jupiter.api.Test\n","newText":"import org.apache.groovy.groovysh.BufferManager\nimport org.apache.groovy.groovysh.util.SimpleCompleter\nimport org.junit.jupiter.api.Test\n"},{"oldText":"    @Test\n    void completesRegisteredVisibleCommandNamesAndShortcuts() {\n        CommandRegistry registry = new CommandRegistry()\n        registry.register(new SampleCommand('display', 'd'))\n        registry.register(new SampleCommand('history', 'h'))\n        registry.register(new SampleCommand('internal', 'i', true))\n        CommandNameCompleter completer = new CommandNameCompleter(registry, false)\n        List<CharSequence> candidates = []\n\n        int completionIndex = completer.complete('h', 1, candidates)\n\n        assertThat(completionIndex).isZero()\n        assertThat(candidates).containsExactly('h', 'history')\n\n        List<CharSequence> hiddenCandidates = []\n        int hiddenCompletionIndex = completer.complete('i', 1, hiddenCandidates)\n\n        assertThat(hiddenCompletionIndex).isEqualTo(-1)\n        assertThat(hiddenCandidates).isEmpty()\n    }\n\n    @Test\n    void commandRegistryFindsCommandsByNameShortcutAndColonPrefixedName() {\n        CommandRegistry registry = new CommandRegistry()\n        Command display = registry.register(new SampleCommand('display', 'd'))\n\n        assertThat(registry.find('display')).isSameAs(display)\n        assertThat(registry.find('d')).isSameAs(display)\n        assertThat(registry.find(':display')).isSameAs(display)\n        assertThat(registry.commands()).containsExactly(display)\n\n        registry.remove(display)\n\n        assertThat(registry.find('display')).isNull()\n        assertThat(registry.commands()).isEmpty()\n    }\n\n    private static class SampleCommand implements Command {\n        final String name\n        final String shortcut\n        final boolean hidden\n\n        SampleCommand(String name, String shortcut, boolean hidden = false) {\n            this.name = name\n            this.shortcut = shortcut\n            this.hidden = hidden\n        }\n\n        @Override\n        Completer getCompleter() {\n            return null\n        }\n\n        @Override\n        String getDescription() {\n            return \"${name} command\"\n        }\n\n        @Override\n        String getUsage() {\n            return name\n        }\n\n        @Override\n        String getHelp() {\n            return name\n        }\n\n        @Override\n        List getAliases() {\n            return []\n        }\n\n        @Override\n        Object execute(List<String> args) {\n            return args\n        }\n    }\n}","newText":"    @Test\n    void completesSimpleCandidatesByPrefixAndControlsTrailingBlank() {\n        SimpleCompleter completer = new SimpleCompleter(['display', 'help', 'history'] as String[])\n        List<CharSequence> candidates = []\n\n        int completionIndex = completer.complete('h', 1, candidates)\n\n        assertThat(completionIndex).isZero()\n        assertThat(candidates).containsExactly('help ', 'history ')\n\n        completer.withBlank = false\n        List<CharSequence> candidatesWithoutBlank = []\n        int completionIndexWithoutBlank = completer.complete('d', 1, candidatesWithoutBlank)\n\n        assertThat(completionIndexWithoutBlank).isZero()\n        assertThat(candidatesWithoutBlank).containsExactly('display')\n    }\n\n    @Test\n    void loadsAndAddsSimpleCompletionCandidates() {\n        SimpleCompleter completer = new SimpleCompleter({ ['alpha', 'beta'] })\n        completer << 'alpine'\n        List<CharSequence> candidates = []\n\n        int completionIndex = completer.complete('al', 2, candidates)\n\n        assertThat(completionIndex).isZero()\n        assertThat(candidates).containsExactly('alpha ', 'alpine ')\n\n        List<CharSequence> missingCandidates = []\n        int missingCompletionIndex = completer.complete('missing', 7, missingCandidates)\n\n        assertThat(missingCompletionIndex).isEqualTo(-1)\n        assertThat(missingCandidates).isEmpty()\n    }\n}"}]}
[tool-call] end id=call_7W1CZ2sI8QKEuMZdVn60oWUb|fc_0080dbf5d0b5a751016a017ad0bfb48194ad539125d14c393f name=edit args={"path": "tests/src/org.apache.groovy/groovy-groovysh/4.0.24/src/test/groovy/org_apache_groovy/groovy_groovysh/Groovy_groovyshTest.groovy", "edits": [{"oldText": "import jline.console.completer.Completer\nimport org.apache.groovy.groovysh.BufferManager\nimport org.apache.groovy.groovysh.Command\nimport org.apache.groovy.groovysh.CommandRegistry\nimport org.apache.groovy.groovysh.completion.CommandNameCompleter\nimport org.junit.jupiter.api.Test\n", "newText": "import org.apache.groovy.groovysh.BufferManager\nimport org.apache.groovy.groovysh.util.SimpleCompleter\nimport org.junit.jupiter.api.Test\n"}, {"oldText": "    @Test\n    void completesRegisteredVisibleCommandNamesAndShortcuts() {\n        CommandRegistry registry = new CommandRegistry()\n        registry.register(new SampleCommand('display', 'd'))\n        registry.register(new SampleCommand('history', 'h'))\n        registry.register(new SampleCommand('internal', 'i', true))\n        CommandNameCompleter completer = new CommandNameCompleter(registry, false)\n        List<CharSequence> candidates = []\n\n        int completionIndex = completer.complete('h', 1, candidates)\n\n        assertThat(completionIndex).isZero()\n        assertThat(candidates).containsExactly('h', 'history')\n\n        List<CharSequence> hiddenCandidates = []\n        int hiddenCompletionIndex = completer.complete('i', 1, hiddenCandidates)\n\n        assertThat(hiddenCompletionIndex).isEqualTo(-1)\n        assertThat(hiddenCandidates).isEmpty()\n    }\n\n    @Test\n    void commandRegistryFindsCommandsByNameShortcutAndColonPrefixedName() {\n        CommandRegistry registry = new CommandRegistry()\n        Command display = registry.register(new SampleCommand('display', 'd'))\n\n        assertThat(registry.find('display')).isSameAs(display)\n        assertThat(registry.find('d')).isSameAs(display)\n        assertThat(registry.find(':display')).isSameAs(display)\n        assertThat(registry.commands()).containsExactly(display)\n\n        registry.remove(display)\n\n        assertThat(registry.find('display')).isNull()\n        assertThat(registry.commands()).isEmpty()\n    }\n\n    private static class SampleCommand implements Command {\n        final String name\n        final String shortcut\n        final boolean hidden\n\n        SampleCommand(String name, String shortcut, boolean hidden = false) {\n            this.name = name\n            this.shortcut = shortcut\n            this.hidden = hidden\n        }\n\n        @Override\n        Completer getCompleter() {\n            return null\n        }\n\n        @Override\n        String getDescription() {\n            return \"${name} command\"\n        }\n\n        @Override\n        String getUsage() {\n            return name\n        }\n\n        @Override\n        String getHelp() {\n            return name\n        }\n\n        @Override\n        List getAliases() {\n            return []\n        }\n\n        @Override\n        Object execute(List<String> args) {\n            return args\n        }\n    }\n}", "newText": "    @Test\n    void completesSimpleCandidatesByPrefixAndControlsTrailingBlank() {\n        SimpleCompleter completer = new SimpleCompleter(['display', 'help', 'history'] as String[])\n        List<CharSequence> candidates = []\n\n        int completionIndex = completer.complete('h', 1, candidates)\n\n        assertThat(completionIndex).isZero()\n        assertThat(candidates).containsExactly('help ', 'history ')\n\n        completer.withBlank = false\n        List<CharSequence> candidatesWithoutBlank = []\n        int completionIndexWithoutBlank = completer.complete('d', 1, candidatesWithoutBlank)\n\n        assertThat(completionIndexWithoutBlank).isZero()\n        assertThat(candidatesWithoutBlank).containsExactly('display')\n    }\n\n    @Test\n    void loadsAndAddsSimpleCompletionCandidates() {\n        SimpleCompleter completer = new SimpleCompleter({ ['alpha', 'beta'] })\n        completer << 'alpine'\n        List<CharSequence> candidates = []\n\n        int completionIndex = completer.complete('al', 2, candidates)\n\n        assertThat(completionIndex).isZero()\n        assertThat(candidates).containsExactly('alpha ', 'alpine ')\n\n        List<CharSequence> missingCandidates = []\n        int missingCompletionIndex = completer.complete('missing', 7, missingCandidates)\n\n        assertThat(missingCompletionIndex).isEqualTo(-1)\n        assertThat(missingCandidates).isEmpty()\n    }\n}"}]}
