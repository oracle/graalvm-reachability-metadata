      static boolean ignoreSyntaxErrorForLineEnding(String line) {
          def final lineEndings = ['{', '[', '(', ',', '.', '-', '+', '/', '*', '%', '&', '|', '?', '<', '>', '=', ':', "'''", '"""', '\\']
          for (String lineEnding in lineEndings) {
              if (line.endsWith(lineEnding)) {
                  return true
              }
          }
          return false
