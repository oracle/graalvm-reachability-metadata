      final int code
  
      private ParseCode(int code) {
          this.code = code
      }
  
      @Override
      String toString() {
          return code
      }
  }
  
  /**
   * Container for parse status details.
   */
  final class ParseStatus {
      final ParseCode code
  
      final Throwable cause
  
