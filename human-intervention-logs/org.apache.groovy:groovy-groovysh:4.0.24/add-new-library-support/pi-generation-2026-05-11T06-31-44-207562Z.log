          inserted.close()
          inserted = new java.io.ByteArrayInputStream(chars.getBytes('UTF-8'))
      }
  
      @Override
      int read(byte[] b) throws java.io.IOException {
          def insertb = inserted.read(b)
          if (insertb > 0) {
              return insertb
          }
          return wrapped.read(b)
      }
  
