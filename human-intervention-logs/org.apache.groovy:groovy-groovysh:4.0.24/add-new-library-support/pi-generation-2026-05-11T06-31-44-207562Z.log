n\nimport static org.assertj.core.api.Assertions.assertThat\nimport static org.assertj.core.api.Assertions.assertThatThrownBy\n\npublic class Groovy_groovyshTest {\n    private static final String TEST_PREFERENCE = 'groovysh.test.preference'\n\n    @TempDir\n    Path tempDir\n\n    @BeforeEach\n    void clearPreferencesBeforeTest() {\n        Preferences.clear()\n    }\n\n    @AfterEach\n    void clearPreferencesAfterTest() {\n        Preferences.clear()\n    }\n\n    @Test\n    void registersDefaultCommandsAliasesAndParsesCommandLines() {\n        ShellHarness harness = newHarness()\n        try {\n            Groovysh shell = harness.shell\n\n            List<String> commandNames = shell.registry.commands()*.name\n            assertThat(commandNames).contains(':help', ':show', ':clear', ':load', ':save', ':purge', ':set', 'import')\n            assertThat(shell.registry.find(':h')?.name).isEqualTo(':help')\n            assertThat(shell.registry.find(':show')?.shortcut).isEqualTo(':S')\n\n            CommandAlias questionAlias = (CommandAlias) shell.registry.find('?')\n            assertThat(questionAlias.targetName).isEqualTo(':help')\n            assertThat(questionAlias.target.name).isEqualTo(':help')\n\n            List<String> parsedArgs = []\n            Command command = shell.findCommand(':show \"variables\"', parsedArgs)\n            assertThat(command.name).isEqualTo(':show')\n            assertThat(parsedArgs).containsExactly('variables')\n            assertThat(shell.isExecutable(':S imports')).isTrue()\n            assertThat(shell.isExecutable('println 1')).isFalse()\n        } finally {\n            harness.close()\n        }\n    }\n\n    @Test\n    void displaysHelpVariablesImportsAndPreferencesThroughShellCommands() {\n        ShellHarness harness = newHarness(this.&registerCoreCommands)\n        try {\n            Groovysh shell = harness.shell\n            shell.interp.context.setVariable('answer', 42)\n            shell.imports.add('java.time.LocalDate')\n            Preferences.put(TEST_PREFERENCE, 'enabled')\n\n            shell.execute(':show variables')\n            shell.execute(':show imports')\n            shell.execute(':show preferences')\n            shell.execute(':help :show')\n\n            String output = harness.output()\n            assertThat(output).contains('Variables:', 'answer = 42')\n            assertThat(output).contains('Custom imports:', 'java.time.LocalDate')\n            assertThat(output).contains('Preferences:', \"$TEST_PREFERENCE=enabled\")\n            assertThat(output).contains('usage:', ':show')\n            assertThat(harness.errorOutput()).isEmpty()\n        } finally {\n            harness.close()\n        }\n    }\n\n    @Test\n    void savesDisplaysClearsAndLoadsCommandFiles() {\n        ShellHarness harness = newHarness(this.&registerCoreCommands)\n        try {\n            Groovysh shell = harness.shell\n            shell.buffers.updateSelected(['println \"first\"', 'println \"second\"'])\n\n            shell.execute(':display')\n\n            Path savedScript = tempDir.resolve('nested').resolve('session.groovy')\n            shell.execute(\":save ${savedScript}\")\n            String expectedSavedScript = ['println \"first\"', 'println \"second\"'].join(System.lineSeparator())\n            assertThat(Files.readString(savedScript)).isEqualTo(expectedSavedScript)\n\n            shell.execute(':clear')\n            assertThat(shell.buffers.current()).isEmpty()\n\n            shell.imports.add('java.util.Locale')\n            Path commandFile = tempDir.resolve('commands.groovysh')\n            Files.writeString(commandFile, ':show imports' + System.lineSeparator() + ':purge imports')\n            shell.execute(\":load ${commandFile}\")\n\n            assertThat(shell.imports).isEmpty()\n            assertThat(harness.output()).contains('1> println \"first\"', '2> println \"second\"', 'Custom imports:', 'java.util.Locale')\n        } finally {\n            harness.close()\n        }\n    }\n\n    @Test\n    void purgesVariablesImportsAndPreferences() {\n        ShellHarness harness = newHarness(this.&registerCoreCommands)\n        try {\n            Groovysh shell = harness.shell\n            shell.interp.context.setVariable('temporaryValue', 'present')\n            shell.imports.add('java.math.BigDecimal')\n            Preferences.put(TEST_PREFERENCE, 'enabled')\n\n            shell.execute(':purge variables')\n            shell.execute(':purge imports')\n            shell.execute(':purge preferences')\n\n            assertThat(shell.interp.context.variables).doesNotContainKey('temporaryValue')\n            assertThat(shell.imports).isEmpty()\n            assertThat(Preferences.get(TEST_PREFERENCE, null)).isNull()\n        } finally {\n            harness.close()\n        }\n    }\n\n    @Test\n    void managesParserStatusesBuffersAndCommandArgumentTokenization() {\n        Parser parser = new Parser()\n        ParseStatus complete = parser.parse(['1 + 1'])\n        ParseStatus incomplete = parser.parse(['if (true) {'])\n        ParseStatus error = parser.parse(['def ='])\n\n        assertThat(complete.code).isSameAs(ParseCode.COMPLETE)\n        assertThat(incomplete.code).isSameAs(ParseCode.INCOMPLETE)\n        assertThat(error.code).isSameAs(ParseCode.ERROR)\n        assertThat(error.cause).isNotNull()\n\n        BufferManager buffers = new BufferManager()\n        buffers.current().add('first')\n        int secondIndex = buffers.create(true)\n        buffers.current().add('second')\n        buffers.select(0)\n        assertThat(buffers.current()).containsExactly('first')\n        buffers.select(secondIndex)\n        assertThat(buffers.current()).containsExactly('second')\n        buffers.deleteSelected()\n        assertThat(buffers.current()).containsExactly('first')\n\n        List<String> tokens = CommandArgumentParser.parseLine('cmd plain \"two words\" \\'three words\\' escaped\\\\ space')\n        assertThat(tokens).containsExactly('cmd', 'plain', 'two words', 'three words', 'escaped space')\n        assertThat(CommandArgumentParser.parseLine(':show variables ignored', 2)).containsExactly(':show', 'variables')\n        assertThatThrownBy({ CommandArgumentParser.parseLine('cmd \"unterminated') })\n                .isInstanceOf(IllegalArgumentException)\n    }\n\n    @Test\n    void completesSimpleCandidatesCommandsAndBackslashEscapes() {\n        SimpleCompleter simpleCompleter = new SimpleCompleter(['alpha', 'alphabet', 'beta'] as String[])\n        List<CharSequence> simpleCandidates = []\n        assertThat(simpleCompleter.complete('alp', 3, simpleCandidates)).isEqualTo(0)\n        assertThat(simpleCandidates).containsExactly('alpha ', 'alphabet ')\n\n        simpleCompleter.withBlank = false\n        List<CharSequence> noBlankCandidates = []\n        assertThat(simpleCompleter.complete('bet', 3, noBlankCandidates)).isEqualTo(0)\n        assertThat(noBlankCandidates).containsExactly('beta')\n\n        ShellHarness harness = newHarness(this.&registerCoreCommands)\n        try {\n            CommandNameCompleter commandNameCompleter = new CommandNameCompleter(harness.shell.registry, false)\n            List<CharSequence> commandCandidates = []\n            assertThat(commandNameCompleter.complete(':', 1, commandCandidates)).isEqualTo(0)\n            assertThat(commandCandidates).contains(':help', ':h', ':show', ':S')\n\n            Completer escapeCompleter = new BackslashEscapeCompleter()\n            List<CharSequence> escapeCandidates = []\n            assertThat(escapeCompleter.complete('\"\\\\', 2, escapeCandidates)).isEqualTo(2)\n            assertThat(escapeCandidates).contains('n (newline)', 't (tab)', 'uXXXX (unicode)')\n        } finally {\n            harness.close()\n        }\n    }\n\n    @Test\n    void evaluatesShellExpressionsAndCustomImportsWhenDynamicClassLoadingIsAvailable() {\n        try {\n            ShellHarness harness = newHarness()\n            try {\n                Object arithmeticResult = harness.shell.execute('21 * 2')\n                assertThat(arithmeticResult).isEqualTo(42)\n                assertThat(harness.shell.interp.context.getVariable('_')).isEqualTo(42)\n\n                Object importResult = harness.shell.execute('import java.time.Month')\n                assertThat(importResult).isEqualTo('java.time.Month')\n                assertThat(harness.shell.imports).containsExactly('java.time.Month')\n                assertThat(harness.shell.importStatements).isEqualTo('import java.time.Month;')\n\n                Object importedTypeResult = harness.shell.execute('Month.JANUARY.length(false)')\n                assertThat(importedTypeResult).isEqualTo(31)\n            } finally {\n                harness.close()\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n        }\n    }\n\n    private void registerCoreCommands(Groovysh shell) {\n        shell.register(new HelpCommand(shell))\n        shell.register(new DisplayCommand(shell))\n        shell.register(new ClearCommand(shell))\n        shell.register(new ShowCommand(shell))\n        shell.register(new PurgeCommand(shell))\n        shell.register(new LoadCommand(shell))\n        shell.register(new SaveCommand(shell))\n        shell.register(new SetCommand(shell))\n    }\n\n    private static ShellHarness newHarness(Closure registrar = null) {\n        ByteArrayOutputStream output = new ByteArrayOutputStream()\n        ByteArrayOutputStream error = new ByteArrayOutputStream()\n        IO io = new IO(new ByteArrayInputStream(new byte[0]), output, error)\n        Binding binding = new Binding()\n        Groovysh shell = registrar == null\n                ? new Groovysh(binding, io)\n                : new Groovysh(Thread.currentThread().contextClassLoader, binding, io, registrar)\n        return new ShellHarness(shell, io, output, error)\n    }\n\n    private static final class ShellHarness implements Closeable {\n        final Groovysh shell\n        private final IO io\n        private final ByteArrayOutputStream output\n        private final ByteArrayOutputStream error\n\n        private ShellHarness(Groovysh shell, IO io, ByteArrayOutputStream output, ByteArrayOutputStream error) {\n            this.shell = shell\n            this.io = io\n            this.output = output\n            this.error = error\n        }\n\n        String output() {\n            io.flush()\n            return output.toString(StandardCharsets.UTF_8.name())\n        }\n\n        String errorOutput() {\n            io.flush()\n            return error.toString(StandardCharsets.UTF_8.name())\n        }\n\n        @Override\n        void close() throws IOException {\n            io.close()\n        }\n    }\n}\n"}
