jupiter.api.Test\\n\\nimport static org.assertj.core.api.Assertions.assertThat\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy\\n\"},{\"oldText\":\"    @Test\\n    void completesSimpleCandidatesByPrefixAndControlsTrailingBlank() {\\n        SimpleCompleter completer = new SimpleCompleter(['display', 'help', 'history'] as String[])\\n        List<CharSequence> candidates = []\\n\\n        int completionIndex = completer.complete('h', 1, candidates)\\n\\n        assertThat(completionIndex).isZero()\\n        assertThat(candidates).containsExactly('help ', 'history ')\\n\\n        completer.withBlank = false\\n        List<CharSequence> candidatesWithoutBlank = []\\n        int completionIndexWithoutBlank = completer.complete('d', 1, candidatesWithoutBlank)\\n\\n        assertThat(completionIndexWithoutBlank).isZero()\\n        assertThat(candidatesWithoutBlank).containsExactly('display')\\n    }\\n\\n    @Test\\n    void loadsAndAddsSimpleCompletionCandidates() {\\n        SimpleCompleter completer = new SimpleCompleter({ ['alpha', 'beta'] })\\n        completer << 'alpine'\\n        List<CharSequence> candidates = []\\n\\n        int completionIndex = completer.complete('al', 2, candidates)\\n\\n        assertThat(completionIndex).isZero()\\n        assertThat(candidates).containsExactly('alpha ', 'alpine ')\\n\\n        List<CharSequence> missingCandidates = []\\n        int missingCompletionIndex = completer.complete('missing', 7, missingCandidates)\\n\\n        assertThat(missingCompletionIndex).isEqualTo(-1)\\n        assertThat(missingCandidates).isEmpty()\\n    }\\n}\",\"newText\":\"    @Test\\n    void parsesCommandArgumentsWithQuotesAndEscapedBlanks() {\\n        List<String> arguments = CommandArgumentParser.parseLine(\\n                '  load \\\"two words\\\" \\\\'single quoted\\\\' escaped\\\\\\\\ space tail  ')\\n\\n        assertThat(arguments).containsExactly('load', 'two words', 'single quoted', 'escaped space', 'tail')\\n    }\\n\