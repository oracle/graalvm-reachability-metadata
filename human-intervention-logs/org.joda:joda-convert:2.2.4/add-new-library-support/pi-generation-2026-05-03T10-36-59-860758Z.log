  package org_joda.joda_convert;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.module.Configuration;
  import java.lang.module.ModuleFinder;
  import java.lang.reflect.Type;
  import java.net.URISyntaxException;
  import java.nio.file.Path;
  import java.security.CodeSource;
  import java.util.OptionalDouble;
  import java.util.OptionalInt;
  import java.util.OptionalLong;
  import java.util.Set;
  
  import com.google.common.reflect.TypeToken;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.joda.convert.StringConvert;
  import org.junit.jupiter.api.Test;
  
  public class StringConvertTest {
      private static final String JODA_CONVERT_MODULE = "org.joda.convert";
      private static final String GUAVA_MODULE = "com.google.common";
  
      @Test
      void constructorRegistersOptionalAndGuavaConverters() {
          StringConvert convert = new StringConvert();
  
          OptionalInt optionalInt = convert.convertFromString(OptionalInt.class, "17");
          OptionalLong optionalLong = convert.convertFromString(OptionalLong.class, "123456789");
          OptionalDouble optionalDouble = convert.convertFromString(OptionalDouble.class, "12.5");
          TypeToken<?> typeToken = convert.convertFromString(TypeToken.class, "java.util.List<java.lang.String>");
  
          assertThat(optionalInt).hasValue(17);
          assertThat(optionalLong).hasValue(123456789L);
          assertThat(optionalDouble).hasValue(12.5);
          assertThat(typeToken.getType().getTypeName()).isEqualTo("java.util.List<java.lang.String>");
          assertThat(convert.convertToString(typeToken)).isEqualTo("java.util.List<java.lang.String>");
      }
  
      @Test
      void constructorAddsGuavaReadEdgeWhenLoadedAsNamedModules() throws Exception {
          try {
              Object convert = newStringConvertFromModuleLayer();
              ClassLoader moduleLoader = convert.getClass().getModule().getLayer().findLoader(GUAVA_MODULE);
              Class<?> typeTokenClass = moduleLoader.loadClass("com.google.common.reflect.TypeToken");
  
              Object typeToken = convert.getClass()
                      .getMethod("convertFromString", Class.class, String.class)
                      .invoke(convert, typeTokenClass, "java.lang.String");
  
              assertThat(typeToken.toString()).isEqualTo("java.lang.String");
          } catch (Error error) {
              rethrowIfNotNativeImageDynamicClassLoadingError(error);
          }
      }
  
      @Test
      void registerMethodsUsesStringAndCharSequenceFactoryMethods() {
          StringConvert convert = new StringConvert(false);
  
          convert.registerMethods(StringMethodValue.class, "asText", "parse");
          convert.registerMethods(CharSequenceMethodValue.class, "asText", "parse");
  
          assertThat(convert.convertToString(new StringMethodValue("alpha"))).isEqualTo("alpha");
          assertThat(convert.convertFromString(StringMethodValue.class, "bravo"))
                  .extracting(StringMethodValue::asText)
                  .isEqualTo("bravo");
          assertThat(convert.convertToString(new CharSequenceMethodValue("charlie"))).isEqualTo("charlie");
          assertThat(convert.convertFromString(CharSequenceMethodValue.class, "delta"))
                  .extracting(CharSequenceMethodValue::asText)
                  .isEqualTo("delta");
      }
  
      @Test
      void registerMethodConstructorUsesStringAndCharSequenceConstructors() {
          StringConvert convert = new StringConvert(false);
  
          convert.registerMethodConstructor(StringBuilder.class, "toString");
          convert.registerMethodConstructor(CharSequenceConstructorValue.class, "asText");
  
          assertThat(convert.convertToString(new StringBuilder("echo"))).isEqualTo("echo");
          assertThat(convert.convertFromString(StringBuilder.class, "foxtrot").toString()).isEqualTo("foxtrot");
          assertThat(convert.findConverter(CharSequenceConstructorValue.class)).isNotNull();
      }
  
      @Test
      void typeConversionLoadsArrayClassByName() {
          StringConvert convert = new StringConvert();
  
          Type type = convert.convertFromString(Type.class, "[Ljava.lang.String;");
  
          assertThat(type).isEqualTo(String[].class);
          assertThat(convert.convertToString(type)).isEqualTo("java.lang.String[]");
      }
  
      private static Object newStringConvertFromModuleLayer() throws Exception {
          ModuleFinder finder = ModuleFinder.of(jarPath(StringConvert.class), jarPath(TypeToken.class));
          Configuration configuration = ModuleLayer.boot().configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(JODA_CONVERT_MODULE, GUAVA_MODULE));
          ModuleLayer layer = ModuleLayer.boot().defineModulesWithOneLoader(configuration, ClassLoader.getSystemClassLoader());
          ClassLoader moduleLoader = layer.findLoader(JODA_CONVERT_MODULE);
          ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(moduleLoader);
              Class<?> stringConvertClass = moduleLoader.loadClass("org.joda.convert.StringConvert");
              return stringConvertClass.getConstructor().newInstance();
          } finally {
              Thread.currentThread().setContextClassLoader(contextClassLoader);
          }
      }
  
      private static Path jarPath(Class<?> cls) throws URISyntaxException {
          CodeSource codeSource = cls.getProtectionDomain().getCodeSource();
          assertThat(codeSource).isNotNull();
          return Path.of(codeSource.getLocation().toURI());
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      public static final class StringMethodValue {
          private final String value;
  
          private StringMethodValue(String value) {
              this.value = value;
          }
  
          public String asText() {
              return value;
          }
  
          public static StringMethodValue parse(String value) {
              return new StringMethodValue(value);
          }
      }
  
      public static final class CharSequenceMethodValue {
          private final String value;
  
          private CharSequenceMethodValue(String value) {
              this.value = value;
          }
  
          public String asText() {
              return value;
          }
  
          public static CharSequenceMethodValue parse(CharSequence value) {
              return new CharSequenceMethodValue(value.toString());
          }
      }
  }
  
  final class CharSequenceConstructorValue {
      private final String value;
  
      CharSequenceConstructorValue(CharSequence value) {
          this.value = value.toString();
      }
  
      public String asText() {
          return value;
      }
  }
