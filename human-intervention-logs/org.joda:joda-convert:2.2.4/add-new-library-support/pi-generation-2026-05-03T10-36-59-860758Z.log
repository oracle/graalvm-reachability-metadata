 a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_joda.joda_convert;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Type;\nimport java.util.OptionalDouble;\nimport java.util.OptionalInt;\nimport java.util.OptionalLong;\n\nimport com.google.common.reflect.TypeToken;\nimport org.joda.convert.StringConvert;\nimport org.junit.jupiter.api.Test;\n\npublic class StringConvertTest {\n    @Test\n    void constructorRegistersOptionalAndGuavaConverters() {\n        StringConvert convert = new StringConvert();\n\n        OptionalInt optionalInt = convert.convertFromString(OptionalInt.class, \"17\");\n        OptionalLong optionalLong = convert.convertFromString(OptionalLong.class, \"123456789\");\n        OptionalDouble optionalDouble = convert.convertFromString(OptionalDouble.class, \"12.5\");\n        TypeToken<?> typeToken = convert.convertFromString(TypeToken.class, \"java.util.List<java.lang.String>\");\n\n        assertThat(optionalInt).hasValue(17);\n        assertThat(optionalLong).hasValue(123456789L);\n        assertThat(optionalDouble).hasValue(12.5);\n        assertThat(typeToken.getType().getTypeName()).isEqualTo(\"java.util.List<java.lang.String>\");\n        assertThat(convert.convertToString(typeToken)).isEqualTo(\"java.util.List<java.lang.String>\");\n    }\n\n    @Test\n    void registerMethodsUsesStringAndCharSequenceFactoryMethods() {\n        StringConvert convert = new StringConvert(false);\n\n        convert.registerMethods(StringMethodValue.class, \"asText\", \"parse\");\n        convert.registerMethods(CharSequenceMethodValue.class, \"asText\", \"parse\");\n\n        assertThat(convert.convertToString(new StringMethodValue(\"alpha\"))).isEqualTo(\"alpha\");\n        assertThat(convert.convertFromString(StringMethodValue.class, \"bravo\"))\n                .extracting(StringMethodValue::asText)\n                .isEqualTo(\"bravo\");\n        assertThat(convert.convertToString(new CharSequenceMethodValue(\"charlie\"))).isEqualTo(\"charlie\");\n        assertThat(convert.convertFromString(CharSequenceMethodValue.class, \"delta\"))\n                .extracting(CharSequenceMethodValue::asText)\n                .isEqualTo(\"delta\");\n    }\n\n    @Test\n    void registerMethodConstructorUsesStringAndCharSequenceConstructors() {\n        StringConvert convert = new StringConvert(false);\n\n        convert.registerMethodConstructor(StringConstructorValue.class, \"asText\");\n        convert.registerMethodConstructor(CharSequenceConstructorValue.class, \"asText\");\n\n        assertThat(convert.convertToString(new StringConstructorValue(\"echo\"))).isEqualTo(\"echo\");\n        assertThat(convert.convertFromString(StringConstructorValue.class, \"foxtrot\"))\n                .extracting(StringConstructorValue::asText)\n                .isEqualTo(\"foxtrot\");\n        assertThat(convert.convertToString(new CharSequenceConstructorValue(\"golf\"))).isEqualTo(\"golf\");\n        assertThat(convert.convertFromString(CharSequenceConstructorValue.class, \"hotel\"))\n                .extracting(CharSequenceConstructorValue::asText)\n                .isEqualTo(\"hotel\");\n    }\n\n    @Test\n    void typeConversionLoadsArrayClassByName() {\n        StringConvert convert = new StringConvert();\n\n        Type type = convert.convertFromString(Type.class, \"[Ljava.lang.String;\");\n\n        assertThat(type).isEqualTo(String[].class);\n        assertThat(convert.convertToString(type)).isEqualTo(\"java.lang.String[]\");\n    }\n\n    public static final class StringMethodValue {\n        private final String value;\n\n        private StringMethodValue(String value) {\n            this.value = value;\n        }\n\n        public String asText() {\n            return value;\n        }\n\n        public static StringMethodValue parse(String value) {\n            return new StringMethodValue(value);\n        }\n    }\n\n    public static final class CharSequenceMethodValue {\n        private final String value;\n\n        private CharSequenceMethodValue(String value) {\n            this.value = value;\n        }\n\n        public String asText() {\n            return value;\n        }\n\n        public static CharSequenceMethodValue parse(CharSequence value) {\n            return new CharSequenceMethodValue(value.toString());\n        }\n    }\n\n    public static final class StringConstructorValue {\n        private final String value;\n\n        public StringConstructorValue(String value) {\n            this.value = value;\n        }\n\n        public String asText() {\n            return value;\n        }\n    }\n\n    public static final class CharSequenceConstructorValue {\n        private final String value;\n\n        public CharSequenceConstructorValue(CharSequence value) {\n            this.value = value.toString();\n        }\n\n        public String asText() {\n            return value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3121, "output": 1435, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 29132, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777804358211, "responseId": "resp_03792c65327f0c5d0169f72446ad20819fa2c021988cd3db4a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Max4IgBhPl7QO8ahZZqgFpX5|fc_03792c65327f0c5d0169f7244bad20819fae586124cae9f179", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4918 bytes to tests/src/org.joda/joda-convert/2.2.4/src/test/java/org_joda/joda_convert/StringConvertTest.java"}], "isError": false, "timestamp": 1777804369344}]}
