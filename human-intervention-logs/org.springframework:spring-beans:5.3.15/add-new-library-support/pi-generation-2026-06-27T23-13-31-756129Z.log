swer\"}"}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 488, "output": 1064, "cacheRead": 40448, "cacheWrite": 0, "totalTokens": 42000, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "stop", "timestamp": 1782603278032, "responseId": "resp_0601c5c51d84452e016a405e0f16148193ae4ba0d406641e18"}, "toolResults": []}
