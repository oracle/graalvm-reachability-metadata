tory product value: \" + product.value());\n+124         }\n+125     }\n+126 \n+127     private static boolean canForkSecurityManagerJvm() {\n+128         return Runtime.version().feature() <= 21 && System.getProperty(\"java.class.path\", \"\")\n+129                 .contains(ConstructorResolverTest.class.getSimpleName());\n+130     }\n+131 \n+132     private static void assertFactoryMethodWorksInForkedSecurityManagerJvm()\n+133             throws IOException, InterruptedException {\n+134         Process process = new ProcessBuilder(securityManagerJvmCommand())\n+135                 .redirectErrorStream(true)\n+136                 .start();\n+137         boolean exited = process.waitFor(30, TimeUnit.SECONDS);\n+138         if (!exited) {\n+139             process.destroyForcibly();\n+140         }\n+141         String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n+142 \n+143         assertThat(exited).as(output).isTrue();\n+144         assertThat(process.exitValue()).as(output).isZero();\n+145     }\n+146 \n+147     private static List<String> securityManagerJvmCommand() {\n+148         List<String> command = new ArrayList<>();\n+149         command.add(javaExecutable());\n+150         command.add(\"-Djava.security.manager=allow\");\n+151         command.addAll(inheritedAgentArguments());\n+152         command.add(\"-cp\");\n+153         command.add(System.getProperty(\"java.class.path\"));\n+154         command.add(ConstructorResolverTest.class.getName());\n+155         command.add(SECURITY_MANAGER_FORK);\n+156         return command;\n+157     }\n+158 \n+159     private static String javaExecutable() {\n+160         String executable = System.getProperty(\"os.name\", \"\").toLowerCase().contains(\"win\") ? \"java.exe\" : \"java\";\n+161         return Path.of(System.getProperty(\"java.home\"), \"bin\", executable).toString();\n+162     }\n+163 \n+164     private static List<String> inheritedAgentArguments() {\n+165         return ManagementFactory.getRuntimeMXBean().getInputArguments().stream()\n+166                 .filter(argument -> argument.startsWith(\"-agentlib:native-image-agent\") ||\n+167                         argument.startsWith(\"-javaagent\"))\n+168                 .toList();\n+169     }\n+170 \n  97     private static FactoryProduct createFactoryProduct(String beanName) {\n  98         DefaultListableBeanFactory beanFactory = new DefaultListableBeanFactory();\n  99         RootBeanDefinition beanDefinition = new RootBeanDefinition(PublicFactory.class);\n 100         beanDefinition.setFactoryMethodName(\"create\");\n     ...", "firstChangedLine": 9}, "isError": false, "timestamp": 1782601673010}}
