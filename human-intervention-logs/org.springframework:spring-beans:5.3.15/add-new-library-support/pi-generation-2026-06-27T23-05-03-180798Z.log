[tool-call] delta {"path":"tests/src/org.springframework/spring-beans/5.3.15/src/test/java/org_springframework/spring_beans/ConstructorResolverTest.java","edits":[{"oldText":"package org_springframework.spring_beans;\n\nimport java.security.Permission;\n\nimport org.junit.jupiter.api.Test;","newText":"package org_springframework.spring_beans;\n\nimport java.io.IOException;\nimport java.lang.management.ManagementFactory;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Path;\nimport java.security.Permission;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.concurrent.TimeUnit;\n\nimport org.junit.jupiter.api.Test;"},{"oldText":"public class ConstructorResolverTest {\n\n    @Test","newText":"public class ConstructorResolverTest {\n\n    private static final String SECURITY_MANAGER_FORK = \"security-manager-fork\";\n\n    public static void main(String[] args) {\n        if (args.length == 1 && SECURITY_MANAGER_FORK.equals(args[0])) {\n            runFactoryMethodWithInstalledSecurityManager();\n        }\n    }\n\n    @Test"},{"oldText":"    @Test\n    @SuppressWarnings(\"removal\")\n    void factoryMethodResolutionUsesPublicFactoryMethodsWhenSecurityManagerIsInstalled() {\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        SecurityManager securityManager = new PermissiveSecurityManager();\n        boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);\n\n        try {\n            FactoryProduct product = createFactoryProduct(\"factoryProductWithSecurityManager\");\n\n            assertThat(product.value()).isEqualTo(\"factory\");\n            if (securityManagerInstalled) {\n                assertThat(System.getSecurityManager()).isSameAs(securityManager);\n            }\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    @Test","newText":"    @Test\n    @SuppressWarnings(\"removal\")\n    void factoryMethodResolutionUsesPublicFactoryMethodsWhenSecurityManagerIsInstalled() throws Exception {\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        SecurityManager securityManager = new PermissiveSecurityManager();\n        boolean securityManagerInstalled = installSecurityManagerIfSupported(securityManager);\n\n        try {\n            if (securityManagerInstalled) {\n                FactoryProduct product = createFactoryProduct(\"factoryProductWithSecurityManager\");\n\n                assertThat(product.value()).isEqualTo(\"factory\");\n                assertThat(System.getSecurityManager()).isSameAs(securityManager);\n            } else if (canForkSecurityManagerJvm()) {\n                assertFactoryMethodWorksInForkedSecurityManagerJvm();\n            } else {\n                FactoryProduct product = createFactoryProduct(\"factoryProductWithoutSecurityManagerSupport\");\n\n                assertThat(product.value()).isEqualTo(\"factory\");\n            }\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    @Test"},{"oldText":"    private static FactoryProduct createFactoryProduct(String beanName) {","newText":"    @SuppressWarnings(\"removal\")\n    private static void runFactoryMethodWithInstalledSecurityManager() {\n        System.setSecurityManager(new PermissiveSecurityManager());\n        FactoryProduct product = createFactoryProduct(\"forkedFactoryProductWithSecurityManager\");\n        if (!\"factory\".equals(product.value())) {\n            throw new IllegalStateException(\"Unexpected factory product value: \" + product.value());\n        }\n    }\n\n    private static boolean canForkSecurityManagerJvm() {\n        return Runtime.version().feature() <= 21 && System.getProperty(\"java.class.path\", \"\")\n                .contains(ConstructorResolverTest.class.getSimpleName());\n    }\n\n    private static void assertFactoryMethodWorksInForkedSecurityManagerJvm()\n            throws IOException, InterruptedException {\n        Process process = new ProcessBuilder(securityManagerJvmCommand())\n                .redirectErrorStream(true)\n                .start();\n        boolean exited = process.waitFor(30, TimeUnit.SECONDS);\n        if (!exited) {\n            process.destroyForcibly();\n        }\n        String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n\n        assertThat(exited).as(output).isTrue();\n        assertThat(process.exitValue()).as(output).isZero();\n    }\n\n    private static List<String> securityManagerJvmCommand() {\n        List<String> command = new ArrayList<>();\n        command.add(javaExecutable());\n        command.add(\"-Djava.security.manager=allow\");\n        command.addAll(inheritedAgentArguments());\n        command.add(\"-cp\");\n        command.add(System.getProperty(\"java.class.path\"));\n        command.add(ConstructorResolverTest.class.getName());\n        command.add(SECURITY_MANAGER_FORK);\n        return command;\n    }\n\n    private static String javaExecutable() {\n        String executable = System.getProperty(\"os.name\", \"\").toLowerCase().contains(\"win\") ? \"java.exe\" : \"java\";\n        return Path.of(System.getProperty(\"java.home\"), \"bin\", executable).toString();\n    }\n\n    private static List<String> inheritedAgentArguments() {\n        return ManagementFactory.getRuntimeMXBean().getInputArguments().stream()\n                .filter(argument -> argument.startsWith(\"-agentlib:native-image-agent\") ||\n                        argument.startsWith(\"-javaagent\"))\n                .toList();\n    }\n\n    private static FactoryProduct createFactoryProduct(String beanName) {"}]}
