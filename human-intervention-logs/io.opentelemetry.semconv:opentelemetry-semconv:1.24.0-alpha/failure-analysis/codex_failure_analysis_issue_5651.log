\npackage io_opentelemetry_semconv.opentelemetry_semconv;\\n\\nimport java.util.List;\\n\\nimport io.opentelemetry.api.common.AttributeKey;\\nimport io.opentelemetry.api.common.AttributeType;\\nimport io.opentelemetry.api.common.Attributes;\\nimport io.opentelemetry.semconv.AttributeKeyTemplate;\\nimport io.opentelemetry.semconv.ClientAttributes;\\nimport io.opentelemetry.semconv.ErrorAttributes;\\nimport io.opentelemetry.semconv.HttpAttributes;\\nimport io.opentelemetry.semconv.JvmAttributes;\\nimport io.opentelemetry.semconv.NetworkAttributes;\\nimport io.opentelemetry.semconv.SchemaUrls;\\nimport io.opentelemetry.semconv.ServerAttributes;\\nimport io.opentelemetry.semconv.UrlAttributes;\\nimport io.opentelemetry.semconv.UserAgentAttributes;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class Opentelemetry_semconvTest {\\n    @Test\\n    void schemaUrlsExposeCurrentAndPreviousSemanticConventionVersions() {\\n        assertThat(SchemaUrls.V1_24_0)\\n                .isEqualTo(\\\"https://opentelemetry.io/schemas/1.24.0\\\")\\n                .startsWith(\\\"https://opentelemetry.io/schemas/\\\");\\n        assertThat(SchemaUrls.V1_23_1).isEqualTo(\\\"https://opentelemetry.io/schemas/1.23.1\\\");\\n        assertThat(SchemaUrls.V1_22_0).isEqualTo(\\\"https://opentelemetry.io/schemas/1.22.0\\\");\\n    }\\n\\n    @Test\\n    void stableAttributeKeysExposeExpectedNamesAndTypes() {\\n        assertKey(HttpAttributes.HTTP_REQUEST_METHOD, \\\"http.request.method\\\", AttributeType.STRING);\\n        assertKey(HttpAttributes.HTTP_REQUEST_METHOD_ORIGINAL, \\\"http.request.method_original\\\", AttributeType.STRING);\\n        assertKey(HttpAttributes.HTTP_REQUEST_RESEND_COUNT, \\\"http.request.resend_count\\\", AttributeType.LONG);\\n        assertKey(HttpAttributes.HTTP_RESPONSE_STATUS_CODE, \\\"http.response.status_code\\\", AttributeType.LONG);\\n        assertKey(HttpAttributes.HTTP_ROUTE, \\\"http.route\\\", AttributeType.STRING);\\n        assertKey(UrlAttributes.URL_FULL, \\\"url.full\\\", AttributeType.STRING);\\n        assertKey(UrlAttributes.URL_PATH, \\\"url.path\\\", AttributeType.STRING);\\n        assertKey(ServerAttributes.SERVER_ADDRESS, \\\"server.address\\\", AttributeType.STRING);\\n        assertKey(ServerAttributes.SERVER_PORT, \\\"server.port\\\", AttributeType.LONG);\\n        assertKey(ClientAttributes.CLIENT_ADDRESS, \\\"client.address\\\", AttributeType.STRING);\\n        assertKey(ClientAttributes.CLIENT_PORT, \\\"client.port\\\", AttributeType.LONG);\\n        assertKey(NetworkAttributes.NETWORK_TRANSPORT, \\\"network.transport\\\", AttributeType.STRING);\\n        assertKey(NetworkAttributes.NETWORK_PEER_PORT, \\\"network.peer.port\\\", AttributeType.LONG);\\n        assertKey(UserAgentAttributes.USER_AGENT_ORIGINAL, \\\"user_agent.original\\\", AttributeType.STRING);\\n        assertKey(ErrorAttributes.ERROR_TYPE, \\\"error.type\\\", AttributeType.STRING);\\n        assertKey(JvmAttributes.JVM_THREAD_DAEMON, \\\"jvm.thread.daemon\\\", AttributeType.BOOLEAN);\\n        assertKey(JvmAttributes.JVM_THREAD_STATE, \\\"jvm.thread.state\\\", AttributeType.STRING);\\n    }\\n\\n    @Test\\n    void enumConstantsMatchSemanticConventionWireValues() {\\n        assertThat(HttpAttributes.HttpRequestMethodValues.GET).isEqualTo(\\\"GET\\\");\\n        assertThat(HttpAttributes.HttpRequestMethodValues.POST).isEqualTo(\\\"POST\\\");\\n        assertThat(HttpAttributes.HttpRequestMethodValues.OTHER).isEqualTo(\\\"_OTHER\\\");\\n        assertThat(NetworkAttributes.NetworkTransportValues.TCP).isEqualTo(\\\"tcp\\\");\\n        assertThat(NetworkAttributes.NetworkTransportValues.UDP).isEqualTo(\\\"udp\\\");\\n        assertThat(NetworkAttributes.NetworkTypeValues.IPV4).isEqualTo(\\\"ipv4\\\");\\n        assertThat(ErrorAttributes.ErrorTypeValues.OTHER).isEqualTo(\\\"_OTHER\\\");\\n        assertThat(JvmAttributes.JvmMemoryTypeValues.HEAP).isEqualTo(\\\"heap\\\");\\n        assertThat(JvmAttributes.JvmThreadStateValues.RUNNABLE).isEqualTo(\\\"runnable\\\");\\n        assertThat(JvmAttributes.JvmThreadStateValues.TIMED_WAITING).isEqualTo(\\\"timed_waiting\\\");\\n    }\\n\\n    @Test\\n    void networkHttpAndUrlAttributesCanDescribeRequest() {\\n        Attributes attributes = Attributes.builder()\\n                .put(HttpAttributes.HTTP_REQUEST_METHOD, HttpAttributes.HttpRequestMethodValues.POST)\\n                .put(HttpAttributes.HTTP_REQUEST_METHOD_ORIGINAL, \\\"post\\\")\\n                .put(HttpAttributes.HTTP_REQUEST_RESEND_COUNT, 1L)\\n                .put(HttpAttributes.HTTP_RESPONSE_STATUS_CODE, 201L)\\n                .put(HttpAttributes.HTTP_ROUTE, \\\"/orders/{id}\\\")\\n                .put(UrlAttributes.URL_FULL, \\\"https://example.test/orders/1?include=items\\\")\\n                .put(UrlAttributes.URL_PATH, \\\"/orders/1\\\")\\n                .put(UrlAttributes.URL_QUERY, \\\"include=items\\\")\\n                .put(UrlAttributes.URL_SCHEME, \\\"https\\\")\\n                .put(ServerAttributes.SERVER_ADDRESS, \\\"example.test\\\")\\n                .put(ServerAttributes.SERVER_PORT, 443L)\\n                .put(ClientAttributes.CLIENT_ADDRESS, \\\"192.0.2.10\\\")\\n                .put(ClientAttributes.CLIENT_PORT, 51_234L)\\n                .put(NetworkAttributes.NETWORK_TRANSPORT, NetworkAttributes.NetworkTransportValues.TCP)\\n                .put(NetworkAttributes.NETWORK_TYPE, NetworkAttributes.NetworkTypeValues.IPV4)\\n                .put(NetworkAttributes.NETWORK_PROTOCOL_NAME, \\\"http\\\")\\n                .put(NetworkAttributes.NETWORK_PROTOCOL_VERSION, \\\"1.1\\\")\\n                .put(UserAgentAttributes.USER_AGENT_ORIGINAL, \\\"semantic-conventions-test/1.0\\\")\\n                .build();\\n\\n        assertThat(attributes.get(HttpAttributes.HTTP_REQUEST_METHOD)).isEqualTo(\\\"POST\\\");\\n        assertThat(attributes.get(HttpAttributes.HTTP_RESPONSE_STATUS_CODE)).isEqualTo(201L);\\n        assertThat(attributes.get(UrlAttributes.URL_PATH)).isEqualTo(\\\"/orders/1\\\");\\n        assertThat(attributes.get(ServerAttributes.SERVER_PORT)).isEqualTo(443L);\\n        assertThat(attributes.get(ClientAttributes.CLIENT_ADDRESS)).isEqualTo(\\\"192.0.2.10\\\");\\n        assertThat(attributes.get(NetworkAttributes.NETWORK_TRANSPORT)).isEqualTo(\\\"tcp\\\");\\n        assertThat(attributes.get(UserAgentAttributes.USER_AGENT_ORIGINAL))\\n                .isEqualTo(\\\"semantic-conventions-test/1.0\\\");\\n        assertThat(attributes.asMap())\\n                .containsKeys(\\n                        HttpAttributes.HTTP_REQUEST_METHOD_ORIGINAL,\\n                        UrlAttributes.URL_FULL,\\n                        NetworkAttributes.NETWORK_TYPE);\\n    }\\n\\n    @Test\\n    void errorAndJvmAttributesCanDescribeRuntimeState() {\\n        Attributes attributes = Attributes.builder()\\n                .put(ErrorAttributes.ERROR_TYPE, ErrorAttributes.ErrorTypeValues.OTHER)\\n                .put(JvmAttributes.JVM_GC_ACTION, \\\"end of minor GC\\\")\\n                .put(JvmAttributes.JVM_GC_NAME, \\\"G1 Young Generation\\\")\\n                .put(JvmAttributes.JVM_MEMORY_POOL_NAME, \\\"G1 Eden Space\\\")\\n                .put(JvmAttributes.JVM_MEMORY_TYPE, JvmAttributes.JvmMemoryTypeValues.HEAP)\\n                .put(JvmAttributes.JVM_THREAD_DAEMON, true)\\n                .put(JvmAttributes.JVM_THREAD_STATE, JvmAttributes.JvmThreadStateValues.RUNNABLE)\\n                .build();\\n\\n        assertKey(JvmAttributes.JVM_GC_ACTION, \\\"jvm.gc.action\\\", AttributeType.STRING);\\n        assertKey(JvmAttributes.JVM_GC_NAME, \\\"jvm.gc.name\\\", AttributeType.STRING);\\n        assertKey(JvmAttributes.JVM_MEMORY_POOL_NAME, \\\"jvm.memory.pool.name\\\", AttributeType.STRING);\\n        assertKey(JvmAttributes.JVM_MEMORY_TYPE, \\\"jvm.memory.type\\\", AttributeType.STRING);\\n        assertThat(attributes.get(ErrorAttributes.ERROR_TYPE)).isEqualTo(\\\"_OTHER\\\");\\n        assertThat(attributes.get(JvmAttributes.JVM_MEMORY_TYPE)).isEqualTo(\\\"heap\\\");\\n        assertThat(attributes.get(JvmAttributes.JVM_THREAD_DAEMON)).isTrue();\\n        assertThat(attributes.get(JvmAttributes.JVM_THREAD_STATE)).isEqualTo(\\\"runnable\\\");\\n        assertThat(attributes.asMap())\\n                .containsOnlyKeys(\\n                        ErrorAttributes.ERROR_TYPE,\\n                        JvmAttributes.JVM_GC_ACTION,\\n                        JvmAttributes.JVM_GC_NAME,\\n                        JvmAttributes.JVM_MEMORY_POOL_NAME,\\n                        JvmAttributes.JVM_MEMORY_TYPE,\\n                        JvmAttributes.JVM_THREAD_DAEMON,\\n                        JvmAttributes.JVM_THREAD_STATE);\\n    }\\n\\n    @Test\\n    void attributeKeyTemplatesCreateTypedKeysWithNamespacedSuffixesAndCacheThem() {\\n        AttributeKey<List<String>> requestHeader = HttpAttributes.HTTP_REQUEST_HEADER.getAttributeKey(\\\"content-type\\\");\\n        AttributeKey<List<String>> sameRequestHeader = HttpAttributes.HTTP_REQUEST_HEADER.getAttributeKey(\\\"content-type\\\");\\n        AttributeKey<List<String>> responseHeader = HttpAttributes.HTTP_RESPONSE_HEADER.getAttributeKey(\\\"server\\\");\\n        AttributeKey<String> stringKey = AttributeKeyTemplate.stringKeyTemplate(\\\"custom\\\")\\n                .getAttributeKey(\\\"name\\\");\\n        AttributeKey<List<String>> stringArrayKey = AttributeKeyTemplate.stringArrayKeyTemplate(\\\"custom\\\")\\n                .getAttributeKey(\\\"tags\\\");\\n        AttributeKey<Boolean> booleanKey = AttributeKeyTemplate.booleanKeyTemplate(\\\"feature.flags\\\")\\n                .getAttributeKey(\\\"enabled\\\");\\n        AttributeKey<List<Boolean>> booleanArrayKey = AttributeKeyTemplate.booleanArrayKeyTemplate(\\\"feature.flags\\\")\\n                .getAttributeKey(\\\"states\\\");\\n        AttributeKey<Long> longKey = AttributeKeyTemplate.longKeyTemplate(\\\"queue\\\")\\n                .getAttributeKey(\\\"depth\\\");\\n        AttributeKey<List<Long>> longArrayKey = AttributeKeyTemplate.longArrayKeyTemplate(\\\"queue\\\")\\n                .getAttributeKey(\\\"partitions\\\");\\n        AttributeKey<Double> doubleKey = AttributeKeyTemplate.doubleKeyTemplate(\\\"cache\\\")\\n                .getAttributeKey(\\\"hit_ratio\\\");\\n        AttributeKey<List<Double>> doubleArrayKey = AttributeKeyTemplate.doubleArrayKeyTemplate(\\\"cache\\\")\\n                .getAttributeKey(\\\"latencies\\\");\\n\\n        assertThat(requestHeader).isSameAs(sameRequestHeader);\\n        assertKey(requestHeader, \\\"http.request.header.content-type\\\", AttributeType.STRING_ARRAY);\\n        assertKey(responseHeader, \\\"http.response.header.server\\\", AttributeType.STRING_ARRAY);\\n        assertKey(stringKey, \\\"custom.name\\\", AttributeType.STRING);\\n        assertKey(stringArrayKey, \\\"custom.tags\\\", AttributeType.STRING_ARRAY);\\n        assertKey(booleanKey, \\\"feature.flags.enabled\\\", AttributeType.BOOLEAN);\\n        assertKey(booleanArrayKey, \\\"feature.flags.states\\\", AttributeType.BOOLEAN_ARRAY);\\n        assertKey(longKey, \\\"queue.depth\\\", AttributeType.LONG);\\n        assertKey(longArrayKey, \\\"queue.partitions\\\", AttributeType.LONG_ARRAY);\\n        assertKey(doubleKey, \\\"cache.hit_ratio\\\", AttributeType.DOUBLE);\\n        assertKey(doubleArrayKey, \\\"cache.latencies\\\", AttributeType.DOUBLE_ARRAY);\\n\\n        Attributes attributes = Attributes.builder()\\n                .put(requestHeader, List.of(\\\"application/json\\\"))\\n                .put(responseHeader, List.of(\\\"test-server\\\"))\\n                .put(stringKey, \\\"value\\\")\\n                .put(stringArrayKey, List.of(\\\"blue\\\", \\\"green\\\"))\\n                .put(booleanKey, true)\\n                .put(booleanArrayKey, List.of(true, false))\\n                .put(longKey, 42L)\\n                .put(longArrayKey, List.of(0L, 1L))\\n                .put(doubleKey, 0.95)\\n                .put(doubleArrayKey, List.of(1.5, 2.5))\\n                .build();\\n\\n        assertThat(attributes.get(requestHeader)).containsExactly(\\\"application/json\\\");\\n        assertThat(attributes.get(responseHeader)).containsExactly(\\\"test-server\\\");\\n        assertThat(attributes.get(stringKey)).isEqualTo(\\\"value\\\");\\n        assertThat(attributes.get(stringArrayKey)).containsExactly(\\\"blue\\\", \\\"green\\\");\\n        assertThat(attributes.get(booleanKey)).isTrue();\\n        assertThat(attributes.get(booleanArrayKey)).containsExactly(true, false);\\n        assertThat(attributes.get(longKey)).isEqualTo(42L);\\n        assertThat(attributes.get(longArrayKey)).containsExactly(0L, 1L);\\n        assertThat(attributes.get(doubleKey)).isEqualTo(0.95);\\n        assertThat(attributes.get(doubleArrayKey)).containsExactly(1.5, 2.5);\\n    }\\n\\n    private static void assertKey(AttributeKey<?> key, String expectedName, AttributeType expectedType) {\\n        assertThat(key.getKey()).isEqualTo(expectedName);\\n        assertThat(key.getType()).isEqualTo(expectedType);\\n    }\\n}\\n\"}\n2225:[tool-call] end id=call_u2TvWqMY6RpeWWOD0TipL7vb|fc_07faf449cc887f280169f84df4a68c819182b1f1126e374893 name=write args={\"path\": \"tests/src/io.opentelemetry.semconv/opentelemetry-semconv/1.24.0-alpha/src/test/java/io_opentelemetry_semconv/opentelemetry_semconv/Opentelemetry_semconvTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_opentelemetry_semconv.opentelemetry_semconv;\\n\\nimport java.util.List;\\n\\nimport io.opentelemetry.api.common.AttributeKey;\\nimport io.opentelemetry.api.common.AttributeType;\\nimport io.opentelemetry.api.common.Attributes;\\nimport io.opentelemetry.semconv.AttributeKeyTemplate;