sTest {\n    @Test\n    void loadsClassesAndCreatesInstancesThroughSecurityActions() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        String testClassName = TestClass.class.getName();\n\n        try {\n            Thread.currentThread().setContextClassLoader(TestClass.class.getClassLoader());\n            assertThat(SecurityActionsInvoker.loadClass(testClassName)).isSameAs(TestClass.class);\n\n            Thread.currentThread().setContextClassLoader(new HidingClassLoader(TestClass.class.getClassLoader(), testClassName));\n            assertThat(SecurityActionsInvoker.loadClass(testClassName)).isSameAs(TestClass.class);\n\n            TestClass created = SecurityActionsInvoker.newInstance(\n                    testClassName,\n                    new Class<?>[] {Class.class},\n                    new Object[] {SecurityActionsTest.class},\n                    TestClass.class,\n                    TestClass.class.getClassLoader());\n\n            assertThat(created.getJavaClass()).isSameAs(SecurityActionsTest.class);\n            assertThat(created.getName()).isEqualTo(SecurityActionsTest.class.getName());\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static final class HidingClassLoader extends ClassLoader {\n        private final String hiddenClassName;\n\n        private HidingClassLoader(ClassLoader parent, String hiddenClassName) {\n            super(parent);\n            this.hiddenClassName = hiddenClassName;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (hiddenClassName.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {