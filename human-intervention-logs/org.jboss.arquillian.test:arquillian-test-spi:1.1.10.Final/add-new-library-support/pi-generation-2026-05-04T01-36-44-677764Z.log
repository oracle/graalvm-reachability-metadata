  package org_jboss_arquillian_test.arquillian_test_spi;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.jboss.arquillian.test.spi.SecurityActionsInvoker;
  import org.jboss.arquillian.test.spi.TestClass;
  import org.junit.jupiter.api.Test;
  
  public class SecurityActionsTest {
      @Test
      void loadsClassesAndCreatesInstancesThroughSecurityActions() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          String testClassName = TestClass.class.getName();
  
          try {
              Thread.currentThread().setContextClassLoader(TestClass.class.getClassLoader());
              assertThat(SecurityActionsInvoker.loadClass(testClassName)).isSameAs(TestClass.class);
  
              ClassLoader hidingClassLoader = new HidingClassLoader(TestClass.class.getClassLoader(), testClassName);
              Thread.currentThread().setContextClassLoader(hidingClassLoader);
              assertThat(SecurityActionsInvoker.loadClass(testClassName)).isSameAs(TestClass.class);
  
              TestClass created = SecurityActionsInvoker.newInstance(
                      testClassName,
                      new Class<?>[] {Class.class},
                      new Object[] {SecurityActionsTest.class},
                      TestClass.class,
                      TestClass.class.getClassLoader());
  
              assertThat(created.getJavaClass()).isSameAs(SecurityActionsTest.class);
              assertThat(created.getName()).isEqualTo(SecurityActionsTest.class.getName());
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private static final class HidingClassLoader extends ClassLoader {
          private final String hiddenClassName;
  
          private HidingClassLoader(ClassLoader parent, String hiddenClassName) {
              super(parent);
              this.hiddenClassName = hiddenClassName;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (hiddenClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
              return super.loadClass(name, resolve);
          }
      }
  }
