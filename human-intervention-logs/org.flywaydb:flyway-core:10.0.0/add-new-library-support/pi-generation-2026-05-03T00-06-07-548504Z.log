[tool-call] delta {"path":"tests/src/org.flywaydb/flyway-core/10.0.0/src/test/java/org_flywaydb/flyway_core/ClassUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_flywaydb.flyway_core;\n\nimport org.flywaydb.core.internal.util.ClassUtils;\nimport org.flywaydb.core.internal.util.ClassUtils.DoNotMapForLogging;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassUtilsTest {\n    @Test\n    void instantiatesClassesByNameAndClassLiteral() {\n        ClassLoader classLoader = Thread.currentThread().getContextClassLoader();\n\n        DefaultConstructed defaultConstructed = ClassUtils.instantiate(DefaultConstructed.class.getName(), classLoader);\n        DefaultConstructed constructedFromClass = ClassUtils.instantiate(DefaultConstructed.class);\n        ConstructedWithArguments constructedWithArguments = ClassUtils.instantiate(\n                ConstructedWithArguments.class.getName(),\n                classLoader,\n                \"flyway\",\n                10);\n\n        assertThat(defaultConstructed.getValue()).isEqualTo(\"default\");\n        assertThat(constructedFromClass.getValue()).isEqualTo(\"default\");\n        assertThat(constructedWithArguments.getDescription()).isEqualTo(\"flyway-10\");\n    }\n\n    @Test\n    void detectsAndLoadsConcreteImplementationClasses() throws Exception {\n        ClassLoader classLoader = Thread.currentThread().getContextClassLoader();\n\n        assertThat(ClassUtils.isPresent(DefaultConstructed.class.getName(), classLoader)).isTrue();\n        assertThat(ClassUtils.isImplementationPresent(TestService.class.getName(), classLoader)).isFalse();\n\n        Class<? extends TestService> loadedClass = ClassUtils.loadClass(\n                TestService.class,\n                TestServiceImplementation.class.getName(),\n                classLoader);\n\n        assertThat(loadedClass).isEqualTo(TestServiceImplementation.class);\n        assertThat(ClassUtils.loadClass(TestService.class, String.class.getName(), classLoader)).isNull();\n    }\n\n    @Test\n    void readsStaticAndInstanceFieldValues() {\n        assertThat(ClassUtils.getStaticFieldValue(\n                FieldFixture.class.getName(),\n                \"PUBLIC_STATIC_VALUE\",\n                Thread.currentThread().getContextClassLoader()))\n                .isEqualTo(\"static-value\");\n        assertThat(ClassUtils.getFieldValue(new FieldFixture(), \"privateValue\"))\n                .isEqualTo(\"instance-value\");\n    }\n\n    @Test\n    void collectsValuesFromGettableMethods() {\n        Map<String, String> values = ClassUtils.getGettableFieldValues(new GettableFixture(), \"flyway.\");\n\n        assertThat(values)\n                .containsEntry(\"flyway.name\", \"core\")\n                .containsEntry(\"flyway.majorVersion\", \"10\")\n                .doesNotContainKey(\"flyway.secret\");\n    }\n\n    public static class DefaultConstructed {\n        private final String value;\n\n        public DefaultConstructed() {\n            this.value = \"default\";\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n\n    public static class ConstructedWithArguments {\n        private final String description;\n\n        public ConstructedWithArguments(String name, Integer version) {\n            this.description = name + \"-\" + version;\n        }\n\n        public String getDescription() {\n            return description;\n        }\n    }\n\n    public interface TestService {\n    }\n\n    public static class TestServiceImplementation implements TestService {\n        public TestServiceImplementation() {\n        }\n    }\n\n    public static class FieldFixture {\n        public static final String PUBLIC_STATIC_VALUE = \"static-value\";\n\n        private final String privateValue = \"instance-value\";\n    }\n\n    public static class GettableFixture {\n        public String getName() {\n            return \"core\";\n        }\n\n        public Integer getMajorVersion() {\n            return 10;\n        }\n\n        @DoNotMapForLogging\n        public String getSecret() {\n            return \"hidden\";\n        }\n    }\n}\n"}
