tible.class);\n\n        assertThat(instance.value()).isEqualTo(\"default\");\n    }\n\n    @Test\n    void checksClassPresenceWithProvidedClassLoader() {\n        assertThat(ClassUtils.isPresent(DefaultConstructible.class.getName(), classLoader)).isTrue();\n        assertThat(ClassUtils.isPresent(\"org_flywaydb.flyway_core.DoesNotExist\", classLoader)).isFalse();\n    }\n\n    @Test\n    void checksServiceImplementationPresenceWithProvidedClassLoader() {\n        assertThat(ClassUtils.isImplementationPresent(SampleService.class.getName(), classLoader)).isFalse();\n    }\n\n    @Test\n    void loadsConcreteImplementationClass() throws Exception {\n        Class<? extends SampleService> loadedClass = ClassUtils.loadClass(\n                SampleService.class,\n                LoadableServiceImplementation.class.getName(),\n                classLoader);\n\n        assertThat(loadedClass).isEqualTo(LoadableServiceImplementation.class);\n    }\n\n    @Test\n    void readsPublicStaticFieldValueByClassName() {\n        String value = ClassUtils.getStaticFieldValue(StaticFieldHolder.class.getName(), \"TEXT\", classLoader);\n\n        assertThat(value).isEqualTo(\"static text\");\n    }\n\n    @Test\n    void readsDeclaredInstanceFieldValue() {\n        FieldHolder holder = new FieldHolder(\"private text\");\n\n        Object value = ClassUtils.getFieldValue(holder, \"text\");\n\n        assertThat(value).isEqualTo(\"private text\");\n    }\n\n    @Test\n    void readsValuesFromDeclaredGetterMethods() {\n        GettableFields fields = new GettableFields();\n\n        Map<String, String> values = ClassUtils.getGettableFieldValues(fields, \"flyway.\");\n\n        assertThat(values)\n                .containsEntry(\"flyway.name\", \"example\")\n                .containsEntry(\"flyway.count\", \"3\")\n                .doesNotContainKey(\"flyway.secret\");\n    }\n\n    public static class DefaultConstructible {\n        public DefaultConstructible() {\n        }\n\n        public String value() {\n            return \"default\";\n        }\n    }\n\n    public interface SampleService {\n    }\n\n    public static class LoadableServiceImplementation implements SampleService {\n        public LoadableServiceImplementation() {\n        }\n    }\n\n    public static class StaticFieldHolder {\n        public static final String TEXT = \"static text\";\n    }\n\n    public static class FieldHolder {\n        private final String text;\n\n        FieldHolder(String text) {\n            this.text = text;\n        }\n    }\n\n    public static class GettableFields {\n        public String getName() {\n            return \"example\";\n        }\n\n        public Integer getCount() {\n            return 3;\n        }\n\n        @ClassUtils.DoNotMapForLogging\n        public String getSecret() {\n            return \"hidden\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 644, "output": 1877, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 17881, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777786234731, "responseId": "resp_004b69b2bed49e020169f6dd7b15688196adb52ff0ec66c38a"}}
