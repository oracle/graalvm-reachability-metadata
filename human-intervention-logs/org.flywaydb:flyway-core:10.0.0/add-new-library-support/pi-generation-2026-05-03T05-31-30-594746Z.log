  package org_flywaydb.flyway_core;
  
  import org.flywaydb.core.internal.util.ClassUtils;
  import org.junit.jupiter.api.Test;
  
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassUtilsTest {
      private final ClassLoader classLoader = ClassUtilsTest.class.getClassLoader();
  
      @Test
      void instantiatesClassByNameWithDefaultConstructor() {
          DefaultConstructible instance = ClassUtils.instantiate(DefaultConstructible.class.getName(), classLoader);
  
          assertThat(instance.value()).isEqualTo("default");
      }
  
      @Test
      void instantiatesClassByNameWithExpressionConstructorPath() {
          DefaultConstructible instance = ClassUtils.instantiate(DefaultConstructible.class.getName(), classLoader, new Object[0]);
  
          assertThat(instance.value()).isEqualTo("default");
      }
  
      @Test
      void instantiatesClassObjectWithDefaultConstructor() {
          DefaultConstructible instance = ClassUtils.instantiate(DefaultConstructible.class);
  
          assertThat(instance.value()).isEqualTo("default");
      }
  
      @Test
      void checksClassPresenceWithProvidedClassLoader() {
          assertThat(ClassUtils.isPresent(DefaultConstructible.class.getName(), classLoader)).isTrue();
          assertThat(ClassUtils.isPresent("org_flywaydb.flyway_core.DoesNotExist", classLoader)).isFalse();
      }
  
      @Test
      void checksServiceImplementationPresenceWithProvidedClassLoader() {
          assertThat(ClassUtils.isImplementationPresent(SampleService.class.getName(), classLoader)).isFalse();
      }
  
      @Test
      void loadsConcreteImplementationClass() throws Exception {
