port java.io.OutputStream;"}, {"oldText": "            ClientHttpResponse response = connector.connect(\n                    HttpMethod.GET, uri, request -> request.writeWith(Mono.<DataBuffer>empty()))\n                    .block(Duration.ofSeconds(10));", "newText": "            ClientHttpResponse response = connector.connect(\n                    HttpMethod.GET, uri, request -> request.writeWith(Mono.<DataBuffer>empty()))\n                    .block(Duration.ofSeconds(20));"}, {"oldText": "            socket.setSoTimeout(10_000);\n            readHttpRequest(socket.getInputStream());\n            byte[] body = \"hello jetty\".getBytes(StandardCharsets.UTF_8);", "newText": "            byte[] body = \"hello jetty\".getBytes(StandardCharsets.UTF_8);"}, {"oldText": "    private static void readHttpRequest(InputStream input) throws IOException {\n        int state = 0;\n        while (state < 4) {\n            int value = input.read();\n            if (value == -1) {\n                throw new EOFException(\"HTTP request ended before headers were complete\");\n            }\n            if ((state == 0 || state == 2) && value == '\\r') {\n                state++;\n            } else if ((state == 1 || state == 3) && value == '\\n') {\n                state++;\n            } else {\n                state = (value == '\\r' ? 1 : 0);\n            }\n        }\n    }\n\n", "newText": ""}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 34672, "output": 1460, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 48932, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780930556548, "responseId": "resp_0e0983f2998288b6016a26d7fe28208194bec7edc28d73516b"}}
