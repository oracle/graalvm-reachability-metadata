\t    }\n    72\t\n    73\t    private static Void serveSingleHttpResponse(ServerSocket serverSocket) {\n    74\t        try (Socket socket = serverSocket.accept()) {\n    75\t            socket.setSoTimeout(10_000);\n    76\t            readHttpRequest(socket.getInputStream());\n    77\t            byte[] body = \"hello jetty\".getBytes(StandardCharsets.UTF_8);\n    78\t            byte[] headers = (\"HTTP/1.1 201 Created\\r\\n\"\n    79\t                    + \"Content-Type: text/plain;charset=UTF-8\\r\\n\"\n    80\t                    + \"Set-Cookie: flavor=vanilla; Path=/; HttpOnly; SameSite=Lax\\r\\n\"\n    81\t                    + \"Content-Length: \" + body.length + \"\\r\\n\"\n    82\t                    + \"Connection: close\\r\\n\"\n    83\t                    + \"\\r\\n\").getBytes(StandardCharsets.US_ASCII);\n    84\t            OutputStream output = socket.getOutputStream();\n    85\t            output.write(headers);\n    86\t            output.write(body);\n    87\t            output.flush();\n    88\t            return null;\n    89\t        } catch (IOException ex) {\n    90\t            throw new IllegalStateException(\"Failed to serve test HTTP response\", ex);\n    91\t        }\n    92\t    }\n    93\t\n    94\t    private static void readHttpRequest(InputStream input) throws IOException {\n    95\t        int state = 0;\n    96\t        while (state < 4) {\n    97\t            int value = input.read();\n    98\t            if (value == -1) {\n    99\t                throw new EOFException(\"HTTP request ended before headers were complete\");\n   100\t            }\n   101\t            if ((state == 0 || state == 2) && value == '\\r') {\n   102\t                state++;\n   103\t            } else if ((state == 1 || state == 3) && value == '\\n') {\n   104\t                state++;\n   105\t            } else {\n   106\t                state = (value == '\\r' ? 1 : 0);\n   107\t            }\n   108\t        }\n   109\t    }\n   110\t\n   111\t