\n80:         {\n81:             StringBuilder sb = new StringBuilder();\n82:             sb.append(this.getClass().getName());\n83:             sb.append(\"[reference=\");\n84:             sb.append(reference);\n85:             sb.append(\"; name=\");\n86:             sb.append(name);\n87:             sb.append(\"; contextName=\");\n88:             sb.append(contextName);\n89:             sb.append(\"; env=\");\n90:             sb.append(envToString(env));\n91:             sb.append(\"]\");\n92:             return sb.toString();\n93:         }\n94: \n95: \tpublic Object getObject() throws ClassNotFoundException, IOException\n96:         { return getObject(null); }\n97: \n98: \tpublic Object getObject(PropertiesConfig pcfg) throws ClassNotFoundException, IOException\n99: \t{\n100: \t    try\n101: \t\t{\n102: \t\t    Context initialContext;\n103: \t\t    if ( env == null )\n104: \t\t\tinitialContext = new InitialContext();\n105: \t\t    else\n106:                     {\n107:                         if (ReferenceableUtils.acceptDeserializedInitialContextEnvironment(pcfg))\n108:                             initialContext = new InitialContext( env );\n109:                         else\n110:                             throw new IOException(\n111:                                 \"A value indirectly serialized as a reference includes a non-default (non-null) InitialContext environment \" +\n112:                                 \"by which the reference wishes to be looked up. \" +\n113:                                 \"InitialContext environment parameters can redirect lookups to untrusted remote servers \" +\n114:                                 \"and potentially lead to download and execution of malicious code. SecurityConfigKey '\" +\n115:                                 SecurityConfigKey.ACCEPT_DESERIALIZED_INITIAL_CONTEXT_ENVIRONMENT +\n116:                                 \"' is set conservatively to false, so this operation is not supported. \" +\n117:            