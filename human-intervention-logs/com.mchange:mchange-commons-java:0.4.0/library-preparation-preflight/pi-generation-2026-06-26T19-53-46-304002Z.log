       * A null string value in a Reference sometimes goes to the literal
       * "null". Sigh. We convert this string to a Java null.
       */
      public static String literalNullToNull( String s )
      {
  	if (s == null || "null".equals( s ))
  	    return null;
  	else
  	    return s;
      }
  
