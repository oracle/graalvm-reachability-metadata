[tool-call] delta {"path":"tests/src/software.amazon.awssdk/third-party-jackson-core/2.34.0/src/test/java/software_amazon_awssdk/third_party_jackson_core/VersionUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage software_amazon_awssdk.third_party_jackson_core;\n\nimport software.amazon.awssdk.thirdparty.jackson.core.Version;\nimport software.amazon.awssdk.thirdparty.jackson.core.json.JsonReadFeature;\nimport software.amazon.awssdk.thirdparty.jackson.core.json.PackageVersion;\nimport software.amazon.awssdk.thirdparty.jackson.core.util.VersionUtil;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class VersionUtilTest {\n    private static final String FIXTURE_GROUP_ID = \"com.example.versionutil\";\n    private static final String FIXTURE_ARTIFACT_ID = \"versionutil-fixture\";\n    private static final String FIXTURE_VERSION = \"4.5.6\";\n\n    @Test\n    void versionForLoadsPackageVersionFromLibraryPackage() {\n        Version discoveredVersion = VersionUtil.versionFor(JsonReadFeature.class);\n\n        assertThat(discoveredVersion).isNotNull();\n        assertThat(discoveredVersion.isUnknownVersion()).isFalse();\n        assertThat(discoveredVersion).isEqualTo(PackageVersion.VERSION);\n    }\n\n    @SuppressWarnings(\"deprecation\")\n    @Test\n    void mavenVersionForReadsPomPropertiesFromClassLoaderResource() {\n        ClassLoader classLoader = VersionUtilTest.class.getClassLoader();\n\n        Version version = VersionUtil.mavenVersionFor(classLoader, FIXTURE_GROUP_ID, FIXTURE_ARTIFACT_ID);\n\n        assertThat(version).isNotNull();\n        assertThat(version.isUnknownVersion()).isFalse();\n        assertThat(version.toString()).isEqualTo(FIXTURE_VERSION);\n        assertThat(version.getGroupId()).isEqualTo(FIXTURE_GROUP_ID);\n        assertThat(version.getArtifactId()).isEqualTo(FIXTURE_ARTIFACT_ID);\n    }\n}\n"}
