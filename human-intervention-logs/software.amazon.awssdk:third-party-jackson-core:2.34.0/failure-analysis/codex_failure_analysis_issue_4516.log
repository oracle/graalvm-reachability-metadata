 class VersionUtilTest {\\n    private static final String FIXTURE_GROUP_ID = \\\"com.example.versionutil\\\";\\n    private static final String FIXTURE_ARTIFACT_ID = \\\"versionutil-fixture\\\";\\n    private static final String FIXTURE_VERSION = \\\"4.5.6\\\";\\n\\n    @Test\\n    void versionForLoadsPackageVersionFromLibraryPackage() {\\n        Version discoveredVersion = VersionUtil.versionFor(JsonReadFeature.class);\\n\\n        assertThat(discoveredVersion).isNotNull();\\n        assertThat(discoveredVersion.isUnknownVersion()).isFalse();\\n        assertThat(discoveredVersion).isEqualTo(PackageVersion.VERSION);\\n    }\\n\\n    @SuppressWarnings(\\\"deprecation\\\")\\n    @Test\\n    void mavenVersionForReadsPomPropertiesFromClassLoaderResource() {\\n        ClassLoader classLoader = VersionUtilTest.class.getClassLoader();\\n\\n        Version version = VersionUtil.mavenVersionFor(classLoader, FIXTURE_GROUP_ID, FIXTURE_ARTIFACT_ID);\\n\\n        assertThat(version).isNotNull();\\n        assertThat(version.isUnknownVersion()).isFalse();\\n        assertThat(version.toString()).isEqualTo(FIXTURE_VERSION);\\n        assertThat(version.getGroupId()).isEqualTo(FIXTURE_GROUP_ID);\\n        assertThat(version.getArtifactId()).isEqualTo(FIXTURE_ARTIFACT_ID);\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1268, \"output\": 819, \"cacheRead\": 27136, \"cacheWrite\": 0, \"totalTokens\": 29223, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777810530670, \"responseId\": \"resp_06c5097c2b1b76ca0169f73c63267881a092432472d9a7f829\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_pE7OfLqKOT8OikQDuixoYmDY|fc_06c5097c2b1b76ca0169f73c68c6f081a08f06c13c78914adf\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 1862 bytes to tests/src/software.amazon