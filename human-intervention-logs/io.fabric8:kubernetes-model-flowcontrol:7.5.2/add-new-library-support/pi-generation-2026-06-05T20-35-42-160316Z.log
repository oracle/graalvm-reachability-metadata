                  new io.fabric8.kubernetes.api.model.flowcontrol.v1beta3.PriorityLevelConfigurationBuilder()
                          .withNewMetadata()
                              .withName("beta3-priority")
                          .endMetadata()
                          .withNewSpec()
                              .withType("Limited")
