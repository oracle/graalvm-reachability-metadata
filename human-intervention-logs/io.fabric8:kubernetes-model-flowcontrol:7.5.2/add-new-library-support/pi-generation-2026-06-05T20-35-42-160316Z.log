      void buildsAndEditsBeta3Resources() throws Exception {
          io.fabric8.kubernetes.api.model.flowcontrol.v1beta3.FlowSchema schema =
                  new io.fabric8.kubernetes.api.model.flowcontrol.v1beta3.FlowSchemaBuilder()
                          .withNewMetadata()
