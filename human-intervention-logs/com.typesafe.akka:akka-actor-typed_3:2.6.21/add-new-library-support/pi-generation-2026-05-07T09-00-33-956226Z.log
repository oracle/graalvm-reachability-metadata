[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-actor-typed_3/2.6.21/src/test/scala/com_typesafe_akka/akka_actor_typed_3/ExtensionsImplTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_typed_3\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nimport akka.actor.typed.ActorSystem\nimport akka.actor.typed.scaladsl.Behaviors\nimport com.typesafe.config.ConfigFactory\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass ExtensionsImplTest {\n  @Test\n  def loadsJavaExtensionIdFromConfiguredStaticSingletonAccessor(): Unit = {\n    JavaSingletonAccessorExtensionId.resetCreateExtensionInvocations()\n    val actorSystemName: String = \"java-extension-id-accessor-test\"\n    val config = ConfigFactory\n      .parseString(\n        s\"\"\"\n           |akka.actor.typed.extensions = [\"${classOf[JavaSingletonAccessorExtensionId].getName}\"]\n           |akka.loglevel = \"WARNING\"\n           |\"\"\".stripMargin)\n      .withFallback(ConfigFactory.load())\n    val system: ActorSystem[Nothing] = ActorSystem(Behaviors.empty, actorSystemName, config)\n\n    try {\n      val extensionId: JavaSingletonAccessorExtensionId = JavaSingletonAccessorExtensionId.getInstance()\n      assertThat(system.hasExtension(extensionId)).isTrue()\n      assertThat(extensionId(system).actorSystemName()).isEqualTo(actorSystemName)\n      assertThat(JavaSingletonAccessorExtensionId.createExtensionInvocations()).isEqualTo(1)\n    } finally {\n      system.terminate()\n      Await.result(system.whenTerminated, 10.seconds)\n    }\n  }\n}\n"}
