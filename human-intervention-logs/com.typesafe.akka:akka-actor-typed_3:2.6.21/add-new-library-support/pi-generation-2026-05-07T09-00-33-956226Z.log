[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-actor-typed_3/2.6.21/src/test/java/com_typesafe_akka/akka_actor_typed_3/JavaSingletonAccessorExtensionId.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_typed_3;\n\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport akka.actor.typed.ActorSystem;\nimport akka.actor.typed.Extension;\nimport akka.actor.typed.ExtensionId;\n\npublic final class JavaSingletonAccessorExtensionId extends ExtensionId<JavaSingletonAccessorExtensionId.Instance> {\n    private static final JavaSingletonAccessorExtensionId INSTANCE = new JavaSingletonAccessorExtensionId();\n    private static final AtomicInteger CREATE_EXTENSION_INVOCATIONS = new AtomicInteger();\n\n    private JavaSingletonAccessorExtensionId() {\n    }\n\n    public static JavaSingletonAccessorExtensionId getInstance() {\n        return INSTANCE;\n    }\n\n    public static int createExtensionInvocations() {\n        return CREATE_EXTENSION_INVOCATIONS.get();\n    }\n\n    public static void resetCreateExtensionInvocations() {\n        CREATE_EXTENSION_INVOCATIONS.set(0);\n    }\n\n    @Override\n    public Instance createExtension(final ActorSystem<?> system) {\n        CREATE_EXTENSION_INVOCATIONS.incrementAndGet();\n        return new Instance(system.name());\n    }\n\n    public static final class Instance implements Extension {\n        private final String actorSystemName;\n\n        private Instance(final String actorSystemName) {\n            this.actorSystemName = actorSystemName;\n        }\n\n        public String actorSystemName() {\n            return actorSystemName;\n        }\n    }\n}\n"}
