  package com_typesafe_akka.akka_actor_typed_3
  
  import java.util.concurrent.TimeUnit
  
  import akka.actor.typed.ActorSystem
  import akka.actor.typed.scaladsl.Behaviors
  import com.typesafe.config.Config
  import com.typesafe.config.ConfigFactory
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class ExtensionsImplTest {
    @Test
    def loadsJavaSingletonAccessorExtensionFromConfiguration(): Unit = {
      val extensionClassName: String = classOf[JavaSingletonTypedExtensionId].getName
      val config: Config = ConfigFactory
        .parseString(
          s"""
             |akka.actor.typed.library-extensions = ["$extensionClassName"]
             |""".stripMargin)
        .withFallback(ConfigFactory.load())
      val systemName: String = s"extensions-impl-test-${java.lang.Long.toHexString(System.nanoTime())}"
      val system: ActorSystem[Nothing] = ActorSystem(Behaviors.empty, systemName, config)
  
      try {
        val extensionId: JavaSingletonTypedExtensionId = JavaSingletonTypedExtensionId.getInstance()
  
        assertThat(system.hasExtension(extensionId)).isTrue()
        assertThat(extensionId(system).systemName()).isEqualTo(systemName)
      } finally {
        system.terminate()
        system.getWhenTerminated.toCompletableFuture.get(10, TimeUnit.SECONDS)
      }
