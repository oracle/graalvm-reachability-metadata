  package com_typesafe_akka.akka_actor_typed_3
  
  import java.util.concurrent.TimeUnit
  
  import scala.annotation.static
  
  import akka.actor.typed.ActorSystem
  import akka.actor.typed.Extension
  import akka.actor.typed.ExtensionId
  import akka.actor.typed.scaladsl.Behaviors
  import com.typesafe.config.Config
  import com.typesafe.config.ConfigFactory
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class ExtensionsImplTest {
    @Test
    def loadsJavaSingletonAccessorExtensionFromConfiguration(): Unit = {
      val extensionClassName: String = classOf[JavaSingletonTypedExtensionId].getName
      val config: Config = ConfigFactory
        .parseString(
          s"""
             |akka.actor.typed.library-extensions = ["$extensionClassName"]
             |""".stripMargin)
        .withFallback(ConfigFactory.load())
      val system: ActorSystem[Nothing] = ActorSystem(Behaviors.empty, "extensions-impl-test", config)
  
      try {
        val extensionId: JavaSingletonTypedExtensionId = JavaSingletonTypedExtensionId.getInstance()
  
        assertThat(system.hasExtension(extensionId)).isTrue()
        assertThat(extensionId(system).systemName).isEqualTo("extensions-impl-test")
      } finally {
        system.terminate()
        system.getWhenTerminated.toCompletableFuture.get(10, TimeUnit.SECONDS)
      }
    }
  }
  
  final class JavaSingletonTypedExtension(val systemName: String) extends Extension
  
  final class JavaSingletonTypedExtensionId private () extends ExtensionId[JavaSingletonTypedExtension] {
    override def createExtension(system: ActorSystem[_]): JavaSingletonTypedExtension =
      new JavaSingletonTypedExtension(system.name)
  }
  
  object JavaSingletonTypedExtensionId {
    private val instance: JavaSingletonTypedExtensionId = new JavaSingletonTypedExtensionId()
  
    @static def getInstance(): JavaSingletonTypedExtensionId = instance
  }
