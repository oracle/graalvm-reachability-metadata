\n  }\n}\n\n---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_typed_3;\n\nimport akka.actor.typed.ActorSystem;\nimport akka.actor.typed.Extension;\nimport akka.actor.typed.ExtensionId;\n\npublic final class JavaSingletonTypedExtensionId extends ExtensionId<JavaSingletonTypedExtensionId.Instance> {\n    private static final JavaSingletonTypedExtensionId INSTANCE = new JavaSingletonTypedExtensionId();\n\n    private JavaSingletonTypedExtensionId() {\n    }\n\n    public static JavaSingletonTypedExtensionId getInstance() {\n        return INSTANCE;\n    }\n\n    @Override\n    public Instance createExtension(ActorSystem<?> system) {\n        return new Instance(system.name());\n    }\n\n    public static final class Instance implements Extension {\n        private final String systemName;\n\n        private Instance(String systemName) {\n            this.systemName = systemName;\n        }\n\n        public String systemName() {\n            return systemName;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
