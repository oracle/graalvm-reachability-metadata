  package org_playframework.play_test_3
  
  import java.util.Map as JMap
  
  import org.apache.pekko.stream.Materializer
  import org.apache.pekko.stream.testkit.NoMaterializer
  import org.apache.pekko.util.ByteString
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Assertions.assertThrows
  import org.junit.jupiter.api.Test
  import play.api.i18n.Messages
  import play.api.libs.json.Json
  import play.api.mvc.AnyContentAsText
  import play.api.mvc.Cookie
  import play.api.mvc.Results
  import play.api.test.ApplicationFactory
  import play.api.test.FakeRequest
  import play.api.test.Helpers
  import play.api.test.TestServer
  
  class Play_test_3Test {
    @Test
    def fakeRequestBuildsHeadersAttributesAndTypedBodies(): Unit = {
      val jsonRequest = FakeRequest("POST", "/submit?tag=one&tag=two")
        .withHeaders("Host" -> "example.test", "X-Trace" -> "trace-1")
        .withSession("user" -> "alice")
        .withFlash("notice" -> "saved")
        .withCookies(Cookie("theme", "dark"))
        .withJsonBody(Json.obj("answer" -> 42))
  
      assertThat(jsonRequest.method).isEqualTo("POST")
      assertThat(jsonRequest.path).isEqualTo("/submit")
      assertThat(jsonRequest.queryString("tag")).containsExactly("one", "two")
      assertThat(jsonRequest.headers.get("X-Trace").get).isEqualTo("trace-1")
      assertThat(jsonRequest.session.get("user").get).isEqualTo("alice")
      assertThat(jsonRequest.flash.get("notice").get).isEqualTo("saved")
      assertThat(jsonRequest.cookies.get("theme").get.value).isEqualTo("dark")
      assertThat((jsonRequest.body.json \ "answer").as[Int]).isEqualTo(42)
  
      val formRequest = FakeRequest("POST", "/form").withFormUrlEncodedBody(
        "tag" -> "scala",
        "tag" -> "play",
        "mode" -> "test"
      )
      assertThat(formRequest.body.data("tag")).containsExactly("scala", "play")
      assertThat(formRequest.body.data("mode")).containsExactly("test")
  
      val rawRequest = FakeRequest("PUT", "/raw").withRawBody(ByteString("payload"))
      assertThat(rawRequest.body.raw.initialData.decodeString("UTF-8")).isEqualTo("payload")
    }
  
    @Test
    def helpersCallActionsAndExtractResultMetadata(): Unit = {
      import Helpers._
  
      implicit val materializer: Materializer = NoMaterializer
      val components = Helpers.stubControllerComponents(
        bodyParser = Helpers.stubBodyParser[AnyContentAsText](AnyContentAsText("parsed request body"))
      )
      val action = components.actionBuilder {
        Results
          .Created("parsed response body")
          .as("text/plain")
          .withHeaders("X-Answer" -> "42")
          .withSession("token" -> "abc")
          .flashing("notice" -> "created")
          .withCookies(Cookie("flavour", "vanilla"))
      }
  
      val result = Helpers.call(action, FakeRequest("POST", "/parse").withTextBody("client body"))
  
      assertThat(Helpers.status(result)).isEqualTo(Helpers.CREATED)
      assertThat(Helpers.contentAsString(result)(Helpers.defaultAwaitTimeout, materializer)).isEqualTo("parsed response body")
      assertThat(Helpers.contentType(result)).contains("text/plain")
      assertThat(Helpers.header("X-Answer", result)).contains("42")
      assertThat(Helpers.session(result).get("token").get).isEqualTo("abc")
      assertThat(Helpers.flash(result).get("notice").get).isEqualTo("created")
      assertThat(Helpers.cookies(result).get("flavour").get.value).isEqualTo("vanilla")
    }
  
    @Test
    def applicationFactoryRoutesRequestsAndProvidesStubMessages(): Unit = {
      val factory = ApplicationFactory.withAction { actionBuilder =>
        actionBuilder { request =>
          Results.Ok(s"${request.method}:${request.path}")
        }
      }
      val application = factory.create()
  
      Helpers.running(application) {
        val routed = Helpers.route(application, FakeRequest("GET", "/factory"))
  
        assertThat(routed.isDefined).isTrue()
        assertThat(Helpers.status(routed.get)).isEqualTo(Helpers.OK)
        assertThat(Helpers.contentAsString(routed.get)(Helpers.defaultAwaitTimeout, application.materializer))
          .isEqualTo("GET:/factory")
      }
  
      val messagesApi = Helpers.stubMessagesApi(Map("en" -> Map("greeting" -> "Hello {0}")))
      val messages: Messages = Helpers.stubMessages(
        messagesApi,
        FakeRequest("GET", "/messages").withHeaders("Accept-Language" -> "en")
      )
      val messagesRequest = Helpers.stubMessagesRequest(messagesApi)
  
      assertThat(messages("greeting", "Ada")).isEqualTo("Hello Ada")
      assertThat(messagesRequest.messages.messagesApi).isSameAs(messagesApi)
    }
  
    @Test
    def javaHelpersBuildRequestsApplicationsAndExtractStrictContent(): Unit = {
      val call = new _root_.play.mvc.Call("PATCH", "/items/7?debug=true")
      val request = _root_.play.test.Helpers
        .fakeRequest(call)
        .header("X-Test", "java-helper")
        .bodyText("updated")
        .build()
  
      assertThat(request.method()).isEqualTo("PATCH")
      assertThat(request.uri()).isEqualTo("/items/7?debug=true")
      assertThat(request.header("X-Test").get()).isEqualTo("java-helper")
      assertThat(request.body().asText()).isEqualTo("updated")
  
      val result = _root_.play.mvc.Results.ok("java response").as("text/plain")
      assertThat(_root_.play.test.Helpers.contentAsString(result)).isEqualTo("java response")
      assertThat(_root_.play.test.Helpers.contentAsBytes(result).decodeString("UTF-8")).isEqualTo("java response")
  
      val database = _root_.play.test.Helpers.inMemoryDatabase("orders", JMap.of("MODE", "PostgreSQL"))
      assertThat(database.get("db.orders.driver")).isEqualTo("org.h2.Driver")
      assertThat(database.get("db.orders.url")).contains("MODE=PostgreSQL")
    }
  
    @Test
    def testServerExposesConfigurationAndGuardsRuntimeOnlyPorts(): Unit = {
      val application = ApplicationFactory.withResult(Results.Ok("server application")).create()
      val server = TestServer(port = 0, application = application, sslPort = Some(0))
  
      assertThat(server.config.port).contains(0)
      assertThat(server.config.sslPort).contains(0)
      assertThat(server.application).isSameAs(application)
      assertThrows(classOf[IllegalStateException], () => server.runningHttpPort)
      assertThrows(classOf[IllegalStateException], () => server.runningHttpsPort)
  
      server.stop()
    }
  }
