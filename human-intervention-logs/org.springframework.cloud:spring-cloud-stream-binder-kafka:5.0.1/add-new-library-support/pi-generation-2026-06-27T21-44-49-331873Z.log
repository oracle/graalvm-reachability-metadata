perties())) {\n                Map<String, TopicDescription> topicDescriptions = adminClient.describeTopics(List.of(topic))\n                        .allTopicNames()\n                        .get(15, TimeUnit.SECONDS);\n                Map<ConfigResource, Config> topicConfigs = adminClient.describeConfigs(List.of(topicResource))\n                        .all()\n                        .get(15, TimeUnit.SECONDS);\n\n                assertThat(producerDestination.getName()).isEqualTo(topic);\n                assertThat(topicDescriptions.get(topic).partitions()).hasSize(2);\n                assertThat(topicConfigs.get(topicResource).get(\"cleanup.policy\").value()).isEqualTo(\"compact\");\n                assertThat(topicConfigs.get(topicResource).get(\"retention.ms\").value()).isEqualTo(\"60000\");\n            }\n        } finally {\n            embeddedKafka.destroy();\n        }\n    }\n\n    @Test\n    @Timeout(60)\n    void bindingUtilsCreatesKafkaClientConfigurationsFromBinderAndBindingProperties() {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 991, "output": 878, "cacheRead": 32256, "cacheWrite": 0, "totalTokens": 34125, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782596663373, "responseId": "resp_06ff7c132ac4a3aa016a404437d8608190b4e78ae1fb3859f0"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_vWC1vVyXieaxheR9bXaRVl2J|fc_06ff7c132ac4a3aa016a40443bbb048190a5b4ae08b1e42bfd", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 3 block(s) in tests/src/org.springframework.cloud/spring-cloud-stream-binder-kafka/5.0.1/src/test/java/org_springframework_cloud/spring_cloud_stream_binder_kafka/Spring_cloud_stream_binder_kafkaTest.java."}], "details": {"diff": "     ...\n  22 \n  23 import org.apache.kafka.clients.CommonClientConfigs;\n  24 import org.apache.kafka.clients.admin.AdminClient;\n  25 import 