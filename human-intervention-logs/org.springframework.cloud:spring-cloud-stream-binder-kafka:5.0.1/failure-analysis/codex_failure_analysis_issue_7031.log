c_access_report.py:59:        for class_coverage in self.classes:\n./forge/utility_scripts/dynamic_access_report.py:60:            if class_coverage.uncovered_calls > 0 and class_coverage.class_name not in exhausted_classes:\n./forge/utility_scripts/dynamic_access_report.py:61:                return class_coverage\n./forge/utility_scripts/dynamic_access_report.py:65:        for index, class_coverage in enumerate(self.classes, start=1):\n./forge/utility_scripts/dynamic_access_report.py:66:            if class_coverage.class_name == class_name:\n./forge/utility_scripts/dynamic_access_report.py:77:def load_dynamic_access_coverage_report(\n./forge/utility_scripts/dynamic_access_report.py:80:) -> DynamicAccessCoverageReport:\n./forge/utility_scripts/dynamic_access_report.py:113:    return DynamicAccessCoverageReport(\n./forge/utility_scripts/dynamic_access_report.py:123:        previous_report: DynamicAccessCoverageReport | None,\n./forge/utility_scripts/dynamic_access_report.py:124:        current_report: DynamicAccessCoverageReport,\n./forge/utility_scripts/dynamic_access_report.py:145:def format_full_report(report: DynamicAccessCoverageReport) -> str:\n./forge/utility_scripts/dynamic_access_report.py:148:    for class_coverage in report.classes:\n./forge/utility_scripts/dynamic_access_report.py:149:        if class_coverage.uncovered_calls == 0:\n./forge/utility_scripts/dynamic_access_report.py:151:        lines.append(f\"### {class_coverage.class_name}\")\n./forge/utility_scripts/dynamic_access_report.py:152:        source_file = class_coverage.resolved_source_file or class_coverage.source_file\n./forge/utility_scripts/dynamic_access_report.py:155:        lines.append(f\"Coverage: {class_coverage.covered_calls}/{class_coverage.total_calls}\")\n./forge/utility_scripts/dynamic_access_report.py:157:        lines.append(format_call_sites(class_coverage.uncovered_call_sites))\n./forge/prompt_templates/fix-java-run/initial-with-sources.md:15:- Test that is fixed must maintain functional coverage. Never simplify the test to the point of triviality.\n./docs/DEVELOPING.md:29:To run the same coverage with future defaults enabled:\n./docs/DEVELOPING.md:143:### Coverage (JaCoCo)\n./docs/DEVELOPING.md:145:Generate coverage for the library under test exercised by our tests. Report contains coverage that focus exclusively on the provided library JARs, excluding unrelated external dependencies.\n./docs/DEVELOPING.md:318:- Generate dynamic access coverage report: `./gradlew generateDynamicAccessCoverageReport -Pcoordinates=[group:artifact:version|k/n|all]`\n./docs/DEVELOPING.md:319:  Output: `metadata/<group>/<artifact>/<version>/test/build/reports/dynamic-access/dynamic-access-coverage.json`\n./docs/DEVELOPING.md:321:- Coverage (single lib): `./gradlew jacocoTestReport -Pcoordinates=[group:artifact:version|k/n|all]`\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:3:description: Review pull requests with the `fixes-javac-fail` label in graalvm-reachability-metadata. Use when asked to review or triage a PR that fixes Java compilation failures for an existing library version update. Focus on validating the compile fix, keeping the diff scoped, and ensuring dynamic-access coverage does not drop between the previously tested version and the new version.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:9:These PRs repair test sources or test dependencies after an existing library is bumped and the new version no longer compiles with the old test code. Review them more lightly than `library-new-request` PRs: the library already exists, so the goal is to preserve working coverage across the version update rather than prove a brand-new metadata contribution from scratch.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:17:- Be more relaxed than `library-new-request`: do not reject only because a test resembles older coverage, stays in an existing package layout, or contains compatibility branches for multiple supported versions.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:18:- Do not accept changes that remove meaningful test coverage just to make `javac` pass.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:20:- Treat dynamic-access coverage preservation as the main quality gate. The new version should not report lower dynamic-access coverage than the previously tested version unless the PR gives a concrete, credible reason.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:54:4. Check dynamic-access coverage across versions.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:56:   - Compare `dynamicAccess.coverageRatio`, `coveredCalls`, `totalCalls`, and the `dynamicAccess.breakdown` entries for reflection, resources, proxies, serialization, JNI, or any other present report type.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:58:   - A lower `coverageRatio` or lower `coveredCalls` for the new version is blocking unless the total dynamic-access surface changed and the PR explains why the reduction is expected.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:59:   - If `totalCalls` increases while `coveredCalls` stays flat or the ratio drops, ask for additional test coverage or metadata unless the uncovered calls are clearly outside the library behavior under test.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:69:   - When the new total is below 25% of the original and the tests and dynamic-access stats still claim comparable coverage, ask for restored metadata or a concrete explanation of the API/package change.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:74:   - Prefer seeing the full target `test` lane green because a compile fix can still reduce runtime or native coverage.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:76:   - If CI is flaky but the diff and coverage comparison are sound, ask for a rerun instead of blocking on speculation.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:84:- Dynamic-access coverage does not drop between the previous and new tested versions, or any apparent drop is convincingly explained by a changed upstream API surface.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:90:- The fix makes compilation pass by weakening or bypassing the test instead of adapting it to the changed API while preserving meaningful coverage.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:92:- Dynamic-access coverage drops without a credible explanation and replacement coverage.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:100:- The API change is plausible but the PR does not explain why a coverage drop is expected.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:107:- For coverage drops: say that dynamic-access coverage must not regress between tested versions, cite the old and new values, and ask for either restored coverage or a concrete explanation.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:109:- For deleted coverage: say that the PR fixes compilation by removing coverage and should instead adapt the test to the new API.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:110:- For native skips that does not depend on the open-ended dynamic class loading: say that the PR avoids the failing native path instead of fixing it, so it does not demonstrate native-image runtime coverage.\n../7031-83b3a4c4/skills/review-fixes-javac-fail/SKILL.md:121:- Bad compile repair that removes coverage:\n./README.md:3:<p><a href=\"COVERAGE.md\"><picture><source media=\"(prefers-color-scheme: dark)\" srcset=\"https://img.shields.io/badge/dynamic/json.svg?label=supported%20libraries&query=%24.badges.librariesSupported&url=https%3A%2F%2Fraw.githubusercontent.com%2Foracle%2Fgraalvm-reachability-metadata%2Fstats%2Fcoverage%2Flatest%2Fbadges.json&style=flat&color=38BDF8&labelColor=1F2937\"><img alt=\"Supported libraries\" src=\"https://img.shields.io/badge/dynamic/json.svg?label=supporte