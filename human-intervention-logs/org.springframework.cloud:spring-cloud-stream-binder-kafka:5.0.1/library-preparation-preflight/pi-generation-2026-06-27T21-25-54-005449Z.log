ngframework.boot/spring-boot-amqp/index.json:37:    \"description\" : \"Spring Boot AMQP provides auto-configuration and support classes for integrating Spring Boot applications with AMQP messaging. It configures RabbitMQ-related infrastructure such as connection factories, templates, listener containers, health checks, metrics, Docker Compose support, and Testcontainers integration.\",\nmetadata/com.diffplug.durian/durian-core/1.2.0/reachability-metadata.json:590:          \"name\": \"images\"\nmetadata/org.springframework.boot/spring-boot-jdbc/index.json:9:    \"description\" : \"Spring Boot JDBC provides auto-configuration and support classes for JDBC-based data access in Spring Boot applications. It configures data sources, JDBC templates, transaction managers, database initialization, health checks, connection pool metrics, and Docker Compose/Testcontainers connection details.\",\nmetadata/org.jetbrains.kotlinx/kotlinx-coroutines-swing/1.10.2/reachability-metadata.json:960:          \"name\": \"images\"\nmetadata/com.formdev/flatlaf-extras/3.7.1/reachability-metadata.json:834:          \"name\" : \"images\"\nmetadata/com.itextpdf/layout/index.json:9:    \"description\" : \"iText Layout provides iText Core's high-level layout API for building PDF documents with elements such as paragraphs, tables, lists, and images. It handles page-aware composition and formatting on top of iText's lower-level PDF engine.\",\nmetadata/com.itextpdf/svg/index.json:9:    \"description\" : \"This iText module integrates SVG images into PDF creation and manipulation workflows. It parses and renders SVG content so it can be used within documents generated with iText.\",\nmetadata/com.itextpdf/io/index.json:9:    \"description\" : \"Provides iText's core input/output layer for reading and writing binary data, images, colors, and other low-level resources used in PDF processing. It also includes font parsing and encoding support plus random-access stream utilities that higher-level iText modules build on.\",\nmetadata/org.apache-extras.beanshell/bsh/2.0b6/reachability-metadata.json:1849:          \"name\" : \"images\"\nmetadata/library-and-framework-list.json:771:    \"description\": \"iText Core module that allows you to integrate SVG images in your PDF creation and manipulation process.\",\nmetadata/com.mchange/mchange-commons-java/0.2.15/reachability-metadata.json:1108:          \"name\" : \"images\"\nmetadata/com.mchange/mchange-commons-java/0.4.0/reachability-metadata.json:1061:          \"name\" : \"images\"\nmetadata/org.testcontainers/testcontainers/index.json:9:    \"description\" : \"Testcontainers is a Java library for JUnit tests that provides lightweight, throwaway Docker containers for databases, web browsers, and other services. It helps integration tests run against real dependencies instead of mocks or in-memory substitutes.\",\nmetadata/org.testcontainers/testcontainers/index.json:40:    \"description\" : \"Testcontainers is a Java library for tests that provides lightweight, throwaway instances of databases, web browsers, and other services running in Docker containers. It helps integration tests run against real dependencies instead of mocks or in-memory substitutes.\",\nmetadata/org.testcontainers/junit-jupiter/index.json:9:    \"description\" : \"Testcontainers JUnit Jupiter provides a JUnit 5 extension for managing Testcontainers-managed Docker containers during tests. It supplies the @Testcontainers and @Container annotations so containers can be started and stopped per test method or shared across a test class.\",\nmetadata/org.testcontainers/testcontainers/1.17.6/reachability-metadata.json:7:      \"type\": \"com.github.dockerjava.api.command.AsyncDockerCmd\"\nmetadata/org.testcontainers/testcontainers/1.17.6/reachability-metadata.json:11:        \"typeReached\": \"org.testcontainers.DockerClientFactory\"\nmetadata/org.testcontainers/testcontainers/1.17.6/reachability-metadata.json:19:        \"typeReached\": \"org.testco