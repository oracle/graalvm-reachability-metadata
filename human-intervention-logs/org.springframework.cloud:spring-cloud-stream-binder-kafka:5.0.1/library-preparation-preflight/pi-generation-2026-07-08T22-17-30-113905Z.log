 final class TrackingConsumerFactory implements ConsumerFactory<String, String> {\n470:\n471:        private final MockConsumer<String, String> consumer = new MockConsumer<>(OffsetResetStrategy.EARLIEST);\n472:\n473:        @Override\n474:        public Consumer<String, String> createConsumer(String groupId, String clientIdPrefix, String clientIdSuffix,\n475:                Properties properties) {\n476:            return this.consumer;\n477:        }\n478:\n479:        @Override\n480:        public boolean isAutoCommit() {\n481:            return false;\n482:        }\n483:\n484:        @Override\n485:        public Map<String, Object> getConfigurationProperties() {\n486:            return Map.of(ConsumerConfig.MAX_POLL_RECORDS_CONFIG, 1);\n487:        }\n488:\n489:        private MockConsumer<String, String> consumer() {\n490:            return this.consumer;\n491:        }\n492:    }\n493:}\ntests/src/org.springframework.boot/spring-boot-kafka/4.0.2/src/test/java/org_springframework_boot/spring_boot_kafka/Spring_boot_kafkaTest.java\n27:import org.springframework.boot.kafka.autoconfigure.DefaultKafkaConsumerFactoryCustomizer;\n28:import org.springframework.boot.kafka.autoconfigure.DefaultKafkaProducerFactoryCustomizer;\n29:import org.springframework.boot.kafka.autoconfigure.KafkaAutoConfiguration;\n30:import org.springframework.boot.kafka.autoconfigure.KafkaConnectionDetails;\n31:import org.springframework.boot.kafka.autoconfigure.KafkaProperties;\n33:import org.springframework.kafka.config.ConcurrentKafkaListenerContainerFactory;\n34:import org.springframework.kafka.core.DefaultKafkaConsumerFactory;\n35:import org.springframework.kafka.core.DefaultKafkaProducerFactory;\n36:import org.springframework.kafka.core.KafkaAdmin;\n37:import org.springframework.kafka.core.KafkaTemplate;\n41:import org.springframework.kafka.security.jaas.KafkaJaasLoginModuleInitializer;\n42:import org.springframework.kafka.transaction.KafkaTransactionManager;\n49:            .withConfigura