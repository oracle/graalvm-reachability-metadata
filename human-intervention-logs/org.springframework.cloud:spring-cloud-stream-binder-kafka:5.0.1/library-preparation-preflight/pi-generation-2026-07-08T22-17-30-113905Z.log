  429:    private static final class MarkingInterceptor implements ChannelInterceptor {
  430:
  431:        @Override
  432:        public Message<?> preSend(Message<?> message, MessageChannel channel) {
  433:            return message;
  434:        }
  435:
  436:        @Override
  437:        public Message<?> postReceive(Message<?> message, MessageChannel channel) {
  438:            return mark(message);
  439:        }
  440:
  441:        private Message<?> mark(Message<?> message) {
  442:            return MessageBuilder.fromMessage(message)
  443:                    .setHeader("intercepted", true)
  444:                    .build();
  445:        }
  446:    }
