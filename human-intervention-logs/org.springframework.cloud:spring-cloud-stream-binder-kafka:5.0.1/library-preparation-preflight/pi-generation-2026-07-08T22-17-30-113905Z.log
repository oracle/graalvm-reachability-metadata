age<?> successMessage = successChannel.receive(1_000);\n106:        assertThat(successMessage).isNotNull();\n107:        assertThat(successMessage.getPayload()).isNotNull();\n108:        assertThat(handler.getComponentType()).isEqualTo(\"kafka:outbound-channel-adapter\");\n109:        assertThat(handler.isRunning()).isTrue();\n110:\n111:        handler.stop();\n112:    }\n113:\n114:    @Test\n115:    void outboundAdapterPublishesSendFuturesWithCorrelationToken() throws Exception {\n116:        TrackingProducerFactory producerFactory = new TrackingProducerFactory();\n117:        QueueChannel futuresChannel = new QueueChannel();\n118:\n119:        KafkaProducerMessageHandler<String, String> handler = Kafka\n120:                .<String, String>outboundChannelAdapter(producerFactory)\n121:                .topic(TOPIC)\n122:                .messageKey(\"order-7\")\n123:                .futuresChannel(futuresChannel)\n124:                .sendFailureChannel(new QueueChannel())\n125:                .getObject();\n126:        handler.setBeanFactory(integrationBeanFactory());\n127:        handler.afterPropertiesSet();\n128:        handler.start();\n129:\n130:        String futureToken = \"future-token-1\";\n131:        handler.handleMessage(MessageBuilder.withPayload(\"future-send\")\n132:                .setHeader(KafkaIntegrationHeaders.FUTURE_TOKEN, futureToken)\n133:                .build());\n134:\n135:        Message<?> futureMessage = futuresChannel.receive(1_000);\n136:        assertThat(futureMessage).isNotNull();\n137:        assertThat(futureMessage.getHeaders()).containsEntry(KafkaIntegrationHeaders.FUTURE_TOKEN, futureToken);\n138:        assertThat(futureMessage.getPayload()).isInstanceOf(CompletableFuture.class);\n139:\n140:        CompletableFuture<?> sendFuture = (CompletableFuture<?>) futureMessage.getPayload();\n141:        assertThat(sendFuture.get(1, TimeUnit.SECONDS)).isInstanceOfSatisfying(SendResult.class, (sendResult) -> {\n142:            ProducerRecord<?, ?> producerRecord = ((SendResult<?, ?>) sendResult).getProducerRecord();\n143:            assertThat(producerRecord.topic()).isEqualTo(TOPIC);\n144:            assertThat(producerRecord.key()).isEqualTo(\"order-7\");\n145:            assertThat(producerRecord.value()).isEqualTo(\"future-send\");\n146:            assertThat(producerRecord.headers().lastHeader(KafkaIntegrationHeaders.FUTURE_TOKEN)).isNull();\n147:        });\n148:\n149:        handler.stop();\n150:    }\n151:\n152:    @Test\n153:    void pollableChannelUsesKafkaTemplateForSendsAndMessageSourceForReceives() {\n154:        TrackingProducerFactory producerFactory = new TrackingProducerFactory();\n155:        KafkaTemplate<String, String> kafkaTemplate = new KafkaTemplate<>(producerFactory);\n156:        TrackingConsumerFactory consumerFactory = new TrackingConsumerFactory();\n157:        ConsumerProperties consumerProperties = topicConsumerProperties();\n158:        KafkaMessageSource<String, String> source = new KafkaMessageSource<>(consumerFactory, consumerProperties);\n159:        source.setRawMessageHeader(true);\n160:        source.setPayloadType(String.class);\n161:        PollableKafkaChannel channel = new PollableKafkaChannel(kafkaTemplate, source);\n162:        channel.addInterceptor(new MarkingInterceptor());\n163:\n164:        assertThat(channel.send(MessageBuilder.withPayload(\"submitted\")\n165:                .setHeader(KafkaHeaders.TOPIC, TOPIC)\n166:                .setHeader(KafkaHeaders.KEY, \"order-2\")\n167:                .setHeader(KafkaHeaders.PARTITION, 0)\n168:                .build(), 1_000)).isTrue();\n169:        assertThat(producerFactory.lastProducer().history()).hasSize(1);\n170:        assertThat(producerFactory.lastProducer().history().get(0).value()).isEqualTo(\"submitted\");\n171:\n172:        try {\n173:            TopicPartition topicPartition = new TopicPartition(TOPIC, 0);\n174:            consumerFactory.consumer().updateBeginningOffsets(Map.of(topicPartition, 0L));\n175:            consumerFactory.consumer().updateEndOffsets(Map.of(topicPartition, 1L));\n176:            source.start();\n177:            consumerFactory.consumer().schedulePollTask(() -> {\n178:                consumerFactory.consumer().rebalance(List.of(topicPartition));\n179:                consumerFactory.consumer().addRecord(new ConsumerRecord<>(TOPIC, 0, 0L, \"order-2\", \"accepted\"));\n180:            });\n181:\n182:            Message<?> received = channel.receive(1_000);\n183:\n184:            assertThat(received).isNotNull();\n185:            assertThat(received.getPayload()).isEqualTo(\"accepted\");\n186:            assertThat(received.getHeaders()).containsEntry(\"intercepted\", true);\n187:            assertThat(received.getHeaders()).containsEntry(KafkaHeaders.RECEIVED_TOPIC, TOPIC);\n188:            assertThat(received.getHeaders().get(KafkaHeaders.RAW_DATA)).isInstanceOf(ConsumerRecord.class);\n189:            assertThat(source.getComponentType()).isEqualTo(\"kafka:message-source\");\n190:            assertThat(source.getAssignedPartitions()).containsExactly(topicPartition);\n191:        } finally {\n192:            source.destroy();\n193:            kafkaTemplate.destroy();\n194:        }\n195:    }\n196:\n197:    @Test\n198:    void messageSourceAcknowledgmentCallbackDefersOutOfOrderCommits() {\n199:        TrackingConsumerFactory consumerFactory = new TrackingConsumerFactory();\n200:        TopicPartition topicPartition = new TopicPartition(TOPIC, 0);\n201:        KafkaMessageSource<String, String> source = new KafkaMessageSource<>(consumerFactory,\n202:                assignedPartitionConsumerProperties());\n203:        source.setPayloadType(String.class);\n204:\n205:        try {\n206:            consumerFactory.consumer().updateBeginningOffsets(Map.of(topicPartition, 0L));\n207:            consumerFactory.consumer().updateEndOffsets(Map.of(topicPartition, 2L));\n208:            source.start();\n209:            consumerFactory.consumer().schedulePollTask(() -> {\n210:                consumerFactory.consumer().addRecord(new ConsumerRecord<>(TOPIC, 0, 0L, \"order-5\", \"packed\"));\n211:                consumerFactory.consumer().addRecord(new ConsumerRecord<>(TOPIC, 0, 1L, \"order-6\", \"shipped\"));\n212:            });\n213:\n214:            Message<?> first = source.receive();\n215:            Message<?> second = source.receive();\n216:            AcknowledgmentCallback firstAcknowledgment = acknowledgmentCallback(first);\n217:            AcknowledgmentCallback secondAcknowledgment = acknowledgmentCallback(second);\n218:            firstAcknowledgment.noAutoAck();\n219:            secondAcknowledgment.noAutoAck();\n220:\n221:            assertThat(first.getPayload()).isEqualTo(\"packed\");\n222:            assertThat(second.getPayload()).isEqualTo(\"shipped\");\n223:            assertThat(first.getHeaders()).containsEntry(KafkaMessageSource.REMAINING_RECORDS, 1);\n224:            assertThat(second.getHeaders()).containsEntry(KafkaMessageSource.REMAINING_RECORDS, 0);\n225:\n226:            secondAcknowledgment.acknowledge(AcknowledgmentCallback.Status.ACCEPT);\n227:\n228:            assertThat(secondAcknowledgment.isAcknowledged()).isTrue();\n229:            assertThat(consumerFactory.consumer().committed(Set.of(topicPartition))).doesNotContainKey(topicPartition);\n230:\n231:            firstAcknowledgment.acknowledge(AcknowledgmentCallback.Status.ACCEPT);\n232:\n233:            OffsetAndMetadata committedOffset = consumerFactory.consumer().committed(Set.of(topicPartition))\n234:                    .get(topicPartition);\n235:            assertThat(firstAcknowledgment.isAcknowledged()).isTrue();\n236:            assertThat(committedOffset).isNotNull();\n237:            assertThat(committedOffset.offset()).isEqualTo(2L);\n238:        } finally {\n239:            source.destroy();\n240:        }\n241:    }\n242:\n243:    @Test\n244:    void inboundChannelAdapterDslBuildsConfigurableKafkaMessageSource() {\n245:        TrackingConsumerFactory consumerFactory = new TrackingConsumerFactory();\n246:        ConsumerProperties consumerProperties = assignedPartitionConsumerProperties();\n247:\n248:        KafkaMessageSource<String, String> source = Kafka\n249:                .inboundChannelAdapter(consumerFactory, consumerProperties, false)\n250:                .messageConverter(new MessagingMessageConverter())\n251:                .payloadType(String.class)\n252:                .rawMessageHeader(true)\n253:                .getObject();\n254:\n255:        assertThat(source.getConsumerProperties()).isSameAs(consumerProperties);\n256:        assertThat(source.isRunning()).isFalse();\n257:        source.setCloseTimeout(Duration.ofMillis(100));\n258:        source.start();\n259:        assertThat(source.isRunning()).isTrue();\n260:        source.pause();\n261:        source.resume();\n262:        source.stop();\n263:        assertThat(source.isRunning()).isFalse();\n264:        source.destroy();\n265:    }\n266:\n267:    @Test\n268:    void messageDrivenAdapterAndInboundGatewayExposeLifecycleControlsWithoutStartingKafka() {\n269:        TrackingConsumerFactory consumerFactory = new TrackingConsumerFactory();\n270:        TrackingProducerFactory producerFactory = new TrackingProducerFactory();\n271:        KafkaTemplate<String, String> kafkaTemplate = new KafkaTemplate<>(producerFactory);\n272:        ContainerProperties containerProperties = new ContainerProperties(TOPIC);\n273:        containerProperties.setGroupId(\"integration-tests\");\n274:        containerProperties.setPollTimeout(10L);\n275:        KafkaMessageListenerContainer<String, String> adapterContainer =\n276:                new KafkaMessageListenerContainer<>(consumerFactory, containerProperties);\n277:        KafkaMessageListenerContainer<String, String> gatewayContainer =\n278:                new KafkaMessageListenerContainer<>(consumerFactory, new ContainerProperties(TOPIC));\n279:\n280:        KafkaMessageDrivenChannelAdapter<String, String> adapter = Kafka\n281:                .messageDrivenChannelAdapter(adapterContainer, KafkaMessageDrivenChannelAdapter.ListenerMode.record)\n282:                .recordMessageConverter(new MessagingMessageConverter())\n283:                .payloadType(String.class)\n284:                .filterInRetry(true)\n285:                .recordFilterStrategy(record -> false)\n286:                .ackDiscarded(false)\n287:                .getObject();\n288:        adapter.setBindSourceRecord(true);\n289:\n290:        KafkaInboundGateway<String, String, String> gateway = new KafkaInboundGateway<>(gatewayContainer,\n291:                kafkaTemplate);\n292:        gateway.setMessageConverter(new MessagingMessageConverter());\n293:        gateway.setPayloadType(String.class);\n294:        gateway.setBindSourceRecord(true);\n295:\n296:        assertThat(adapter.getComponentType()).isEqualTo(\"kafka:message-driven-channel-adapter\");\n297:        assertThat(gateway.getComponentType()).isEqualTo(\"kafka:inbound-gateway\");\n298:\n299:        adapter.pause();\n300:        gateway.pause();\n301:        adapter.resume();\n302:        gateway.resume();\n303:        assertThat(adapter.beforeShutdown()).isEqualTo(adapter.getPhase());\n304:        assertThat(gateway.beforeShutdown()).isEqualTo(gateway.getPhase());\n305:        assertThat(adapter.afterShutdown()).isEqualTo(adapter.getPhase());\n306:        assertThat(gateway.afterShutdown()).isEqualTo(gateway.getPhase());\n307:\n308:        kafkaTemplate.destroy();\n309:    }\n310:\n311:    @Test\n312:    void subscribableChannelVariantsManageSubscriptionsWithoutStartingContainers() {\n313:        TrackingConsumerFactory consumerFactory = new TrackingConsumerFactory();\n314:        TrackingProducerFactory producerFactory = new TrackingProducerFactory();\n315:        KafkaTemplate<String, String> kafkaTemplate = new KafkaTemplate<>(producerFactory);\n316:        ConcurrentKafkaListenerContainerFactory<String, String> containerFactory =\n317:                new ConcurrentKafkaListenerContainerFactory<>();\n318:        containerFactory.setConsumerFactory(consumerFactory);\n319:        containerFactory.getContainerProperties().setPollTimeout(10L);\n320:        MessageHandler messageHandler = message -> assertThat(message).isNotNull();\n321:\n322:        SubscribableKafkaChannel pointToPointChannel = Kafka.channel(kafkaTemplate, containerFactory, TOPIC)\n323:                .getObject();\n324:        pointToPointChannel.setBeanName(\"pointToPointKafkaChannel\");\n325:        pointToPointChannel.setBeanFactory(integrationBeanFactory());\n326:        pointToPointChannel.setGroupId(\"point-to-point-group\");\n327:        pointToPointChannel.setPhase(17);\n328:        pointToPointChannel.setAutoStartup(false);\n329:        pointToPointChannel.setMessageConverter(new MessagingMessageConverter());\n330:        pointToPointChannel.afterPropertiesSet();\n331:\n332:        PublishSubscribeKafkaChannel publishSubscribeChannel = Kafka\n333:                .publishSubscribeChannel(kafkaTemplate, containerFactory, TOPIC)\n334:                .getObject();\n335:        publishSubscribeChannel.setBeanName(\"publishSubscribeKafkaChannel\");\n336:        publishSubscribeChannel.setBeanFactory(integrationBeanFactory());\n337:        publishSubscribeChannel.setGroupId(\"publish-subscribe-group\");\n338:        publishSubscribeChannel.afterPropertiesSet();\n339:\n340:        assertThat(pointToPointChannel.subscribe(messageHandler)).isTrue();\n341:        assertThat(pointToPointChannel.subscribe(messageHandler)).isFalse();\n342:        assertThat(pointToPointChannel.unsubscribe(messageHandler)).isTrue();\n343:        assertThat(pointToPointChannel.getPhase()).isEqualTo(17);\n344:        assertThat(pointToPointChannel.isAutoStartup()).isFalse();\n345:        assertThat(pointToPointChannel.isRunning()).isFalse();\n346:\n347:        assertThat(publishSubscribeChannel.subscribe(messageHandler)).isTrue();\n348:        assertThat(publishSubscribeChannel.unsubscribe(messageHandler)).isTrue();\n349:\n350:        kafkaTemplate.destroy();\n351:    }\n352:\n353:    @Test\n354:    void errorStrategiesAndRecoverersPreserveKafkaRecordContext() {\n355:        ConsumerRecord<String, String> record = new ConsumerRecord<>(TOPIC, 0, 42L, \"order-3\", \"failed\");\n356:        Message<String> inputMessage = MessageBuilder.withPayload(\"failed\")\n357:                .setHeader(KafkaHeaders.RAW_DATA, record)\n358:                .build();\n359:        AttributeAccessor attributes = ErrorMessageUtils.getAttributeAccessor(inputMessage, null);\n360:        attributes.setAttribute(KafkaHeaders.RAW_DATA, record);\n361:\n362:        ErrorMessage errorMessage = new RawRecordHeaderErrorMessageStrategy()\n363:                .buildErrorMessage(new IllegalStateException(\"boom\"), attributes);\n364:\n365:        assertThat(errorMessage.getOriginalMessage()).isSameAs(inputMessage);\n366:        assertThat(errorMessage.getHeaders()).containsEntry(KafkaHeaders.RAW_DATA, record)\n367:                .containsEntry(\"sourceData\", record);\n368:\n369:        QueueChannel errors = new QueueChannel();\n370:        KafkaErrorSendingMessageRecoverer recoverer = new KafkaErrorSendingMessageRecoverer(errors,\n371:                new RawRecordHeaderErrorMessageStrategy());\n372:        recoverer.accept(record, new IllegalArgumentException(\"not recovered\"));\n373:\n374:        Message<?> recovered = errors.receive(1_000);\n375:        assertThat(recovered).isInstanceOf(ErrorMessage.class);\n376:        assertThat(((ErrorMessage) recovered).getPayload()).isInstanceOfSatisfying(MessagingException.class,\n377:                (exception) -> assertThat(exception.getCause()).isInstanceOf(IllegalArgumentException.class));\n378:        assertThat(recovered.getHeaders()).containsEntry(KafkaHeaders.RAW_DATA, record)\n379:                .containsEntry(\"sourceData\", record);\n380:    }\n381:\n38