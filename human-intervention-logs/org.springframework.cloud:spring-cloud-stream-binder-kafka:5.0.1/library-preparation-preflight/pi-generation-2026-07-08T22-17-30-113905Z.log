  114:    @Test
  115:    void outboundAdapterPublishesSendFuturesWithCorrelationToken() throws Exception {
  116:        TrackingProducerFactory producerFactory = new TrackingProducerFactory();
  117:        QueueChannel futuresChannel = new QueueChannel();
  118:
  119:        KafkaProducerMessageHandler<String, String> handler = Kafka
  120:                .<String, String>outboundChannelAdapter(producerFactory)
  121:                .topic(TOPIC)
  122:                .messageKey("order-7")
  123:                .futuresChannel(futuresChannel)
  124:                .sendFailureChannel(new QueueChannel())
  125:                .getObject();
  126:        handler.setBeanFactory(integrationBeanFactory());
  127:        handler.afterPropertiesSet();
  128:        handler.start();
  129:
  130:        String futureToken = "future-token-1";
  131:        handler.handleMessage(MessageBuilder.withPayload("future-send")
  132:                .setHeader(KafkaIntegrationHeaders.FUTURE_TOKEN, futureToken)
  133:                .build());
  134:
  135:        Message<?> futureMessage = futuresChannel.receive(1_000);
  136:        assertThat(futureMessage).isNotNull();
  137:        assertThat(futureMessage.getHeaders()).containsEntry(KafkaIntegrationHeaders.FUTURE_TOKEN, futureToken);
  138:        assertThat(futureMessage.getPayload()).isInstanceOf(CompletableFuture.class);
  139:
  140:        CompletableFuture<?> sendFuture = (CompletableFuture<?>) futureMessage.getPayload();
  141:        assertThat(sendFuture.get(1, TimeUnit.SECONDS)).isInstanceOfSatisfying(SendResult.class, (sendResult) -> {
  142:            ProducerRecord<?, ?> producerRecord = ((SendResult<?, ?>) sendResult).getProducerRecord();
  143:            assertThat(producerRecord.topic()).isEqualTo(TOPIC);
  144:            assertThat(producerRecord.key()).isEqualTo("order-7");
  145:            assertThat(producerRecord.value()).isEqualTo("future-send");
  146:            assertThat(producerRecord.headers().lastHeader(KafkaIntegrationHeaders.FUTURE_TOKEN)).isNull();
  147:        });
  148:
  149:        handler.stop();
  150:    }
