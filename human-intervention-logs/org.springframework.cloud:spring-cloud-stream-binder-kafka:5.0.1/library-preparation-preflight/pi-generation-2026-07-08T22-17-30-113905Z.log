382:    @Test\n383:    void sendFailureExceptionExposesFailedProducerRecord() {\n384:        ProducerRecord<String, String> record = new ProducerRecord<>(TOPIC, 0, \"order-4\", \"failed\");\n385:        Message<String> failedMessage = MessageBuilder.withPayload(\"failed\").build();\n386:\n387:        KafkaSendFailureException exception = new KafkaSendFailureException(failedMessage, record,\n388:                new IllegalStateException(\"send failed\"));\n389:\n390:        assertThat(exception.getFailedMessage()).isSameAs(failedMessage);\n391:        assertThat(exception.getRecord()).isSameAs(record);\n392:        assertThat(exception.getCause()).hasMessage(\"send failed\");\n393:        assertThat(exception.toString()).contains(TOPIC);\n394:    }\n395:\n396:    private static AcknowledgmentCallback acknowledgmentCallback(Message<?> message) {\n397:        assertThat(message).isNotNull();\n398:        AcknowledgmentCallback acknowledgmentCallback = new IntegrationMessageHeaderAccessor(message)\n399:                .getAcknowledgmentCallback();\n400:        assertThat(acknowledgmentCallback).isNotNull();\n401:        assertThat(acknowledgmentCallback.isAcknowledged()).isFalse();\n402:        return acknowledgmentCallback;\n403:    }\n404:\n405:    private static ConsumerProperties assignedPartitionConsumerProperties() {\n406:        ConsumerProperties consumerProperties = new ConsumerProperties(new TopicPartitionOffset(TOPIC, 0, 0L));\n407:        configureConsumerProperties(consumerProperties);\n408:        return consumerProperties;\n409:    }\n410:\n411:    private static ConsumerProperties topicConsumerProperties() {\n412:        ConsumerProperties consumerProperties = new ConsumerProperties(TOPIC);\n413:        configureConsumerProperties(consumerProperties);\n414:        return consumerProperties;\n415:    }\n416:\n417:    private static void configureConsumerProperties(ConsumerProperties consumerProperties) {\n418:        consumerProperties.setGroupId(\"integration-tests\");\n419:        consumerProperties.setClientId(\"spring-integration-kafka-test\");\n420:        consumerProperties.setPollTimeout(10L);\n421:    }\n422:\n423:    private static DefaultListableBeanFactory integrationBeanFactory() {\n424:        DefaultListableBeanFactory beanFactory = new DefaultListableBeanFactory();\n425:        beanFactory.registerSingleton(\"integrationEvaluationContext\", new StandardEvaluationContext());\n426:        return beanFactory;\n427:    }\n428:\n429:    private static final class MarkingInterceptor implements ChannelInterceptor {\n430:\n431:        @Override\n432:        public Message<?> preSend(Message<?> message, MessageChannel channel) {\n433:            return message;\n434:        }\n435:\n436:        @Override\n437:        public Message<?> postReceive(Message<?> message, MessageChannel channel) {\n438:            return mark(message);\n439:        }\n440:\n441:        private Message<?> mark(Message<?> message) {\n442:            return MessageBuilder.fromMessage(message)\n443:                    .setHeader(\"intercepted\", true)\n444:                    .build();\n445:        }\n446:    }\n447:\n448:    private static final class TrackingProducerFactory implements ProducerFactory<String, String> {\n449:\n450:        private MockProducer<String, String> lastProducer;\n451:\n452:        @Override\n453:        public Producer<String, String> createProducer() {\n454:            this.lastProducer = new MockProducer<>(true, null, new StringSerializer(), new StringSerializer());\n455:            return this.lastProducer;\n456:        }\n457:\n458:        @Override\n459:        public Map<String, Object> getConfigurationProperties() {\n460:            return Collections.emptyMap();\n461:        }\n462:\n463:        private MockProducer<String, String> lastProducer() {\n464:            assertThat(this.lastProducer).isNotNull();\n465:            return this.lastProducer;\n466:        }\n467:    }\n468:\n469:    private static final class TrackingConsumerFactory implements ConsumerFactory<String, String> {\n470:\n471:        private final MockConsumer<String, String> consumer = new MockConsumer<>(OffsetResetStrategy.EARLIEST);\n472:\n473:        @Override\n474:        public Consumer<String, String> createConsumer(String groupId, String clientIdPrefix, String clientIdSuffix,\n475:                Properties properties) {\n476:            return this.consumer;\n477:        }\n478:\n479:        @Override\n480:        public boolean isAutoCommit() {\n481:            return false;\n482:        }\n483:\n484:        @Override\n485:        public Map<String, Object> getConfigurationProperties() {\n486:            return Map.of(ConsumerConfig.MAX_POLL_RECORDS_CONFIG, 1);\n487:        }\n488:\n489:        private MockConsumer<String, String> consumer() {\n490:            return this.consumer;\n491:        }\n492:    }\n493:}\ntests/src/org.springframework.boot/spring-boot-kafka/4.0.2/src/test/java/org_springframework_boot/spring_boot_kafka/Spring_boot_kafkaTest.java\n27:import org.springframework.boot.kafka.autoconfigure.DefaultKafkaConsumerFactoryCustomizer;\n28:import org.springframework.boot.kafka.autoconfigure.DefaultKafkaProducerFactoryCustomizer;\n29:import org.springframework.boot.kafka.autoconfigure.KafkaAutoConfiguration;\n30:import org.springframework.boot.kafka.autoconfigure.KafkaConnectionDetails;\n31:import org.springframework.boot.kafka.autoconfigure.KafkaProperties;\n33:import org.springframework.kafka.config.ConcurrentKafkaListenerContainerFactory;\n34:import org.springframework.kafka.core.DefaultKafkaConsumerFactory;\n35:import org.springframework.kafka.core.DefaultKafkaProducerFactory;\n36:import org.springframework.kafka.core.KafkaAdmin;\n37:import org.springframework.kafka.core.KafkaTemplate;\n41:import org.springframework.kafka.security.jaas.KafkaJaasLoginModuleInitializer;\n42:import org.springframework.kafka.transaction.KafkaTransactionManager;\n49:            .withConfigu