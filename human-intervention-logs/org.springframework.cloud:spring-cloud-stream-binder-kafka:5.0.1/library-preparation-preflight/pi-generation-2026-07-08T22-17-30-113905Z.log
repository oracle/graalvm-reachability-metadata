  75:    @Test
  76:    void producerMessageHandlerDslSendsRecordsAndPublishesSuccessMessages() throws Exception {
  77:        TrackingProducerFactory producerFactory = new TrackingProducerFactory();
  78:        QueueChannel successChannel = new QueueChannel();
  79:
  80:        KafkaProducerMessageHandler<String, String> handler = Kafka
  81:                .<String, String>outboundChannelAdapter(producerFactory)
  82:                .topic(TOPIC)
  83:                .messageKey("order-1")
  84:                .partitionId(0)
  85:                .sync(true)
  86:                .sendTimeout(500)
  87:                .sendSuccessChannel(successChannel)
  88:                .getObject();
  89:        handler.setTimestampExpression(new SpelExpressionParser().parseExpression("123456789L"));
  90:        handler.setBeanFactory(integrationBeanFactory());
  91:        handler.afterPropertiesSet();
  92:        handler.start();
  93:
  94:        handler.handleMessage(MessageBuilder.withPayload("created").build());
  95:
  96:        MockProducer<String, String> producer = producerFactory.lastProducer();
  97:        assertThat(producer.history()).hasSize(1);
  98:        ProducerRecord<String, String> record = producer.history().get(0);
  99:        assertThat(record.topic()).isEqualTo(TOPIC);
  100:        assertThat(record.key()).isEqualTo("order-1");
  101:        assertThat(record.value()).isEqualTo("created");
  102:        assertThat(record.partition()).isEqualTo(0);
  103:        assertThat(record.timestamp()).isEqualTo(123456789L);
  104:
  105:        Message<?> successMessage = successChannel.receive(1_000);
  106:        assertThat(successMessage).isNotNull();
  107:        assertThat(successMessage.getPayload()).isNotNull();
  108:        assertThat(handler.getComponentType()).isEqualTo("kafka:outbound-channel-adapter");
  109:        assertThat(handler.isRunning()).isTrue();
  110:
  111:        handler.stop();
  112:    }
