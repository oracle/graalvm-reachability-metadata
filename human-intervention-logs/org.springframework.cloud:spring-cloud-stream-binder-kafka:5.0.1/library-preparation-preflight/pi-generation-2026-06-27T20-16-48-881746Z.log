  			props.putAll(mergedConfig);
  		}
  		if (!props.containsKey(ConsumerConfig.BOOTSTRAP_SERVERS_CONFIG)) {
  			props.put(ConsumerConfig.BOOTSTRAP_SERVERS_CONFIG,
  					configurationProperties.getKafkaConnectionString());
