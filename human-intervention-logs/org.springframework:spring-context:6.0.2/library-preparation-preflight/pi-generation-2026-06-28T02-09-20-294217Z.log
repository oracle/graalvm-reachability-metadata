  172-	/**
  173-	 * Create a new CommonAnnotationBeanPostProcessor,
  174-	 * with the init and destroy annotation types set to
  175:	 * {@link jakarta.annotation.PostConstruct} and {@link jakarta.annotation.PreDestroy},
  176-	 * respectively.
  177-	 */
  178-	public CommonAnnotationBeanPostProcessor() {
  179-		setOrder(Ordered.LOWEST_PRECEDENCE - 3);
  180-		setInitAnnotationType(PostConstruct.class);
  181-		setDestroyAnnotationType(PreDestroy.class);
  182-
  183-		// java.naming module present on JDK 9+?
  184-		if (jndiPresent) {
  185-			this.jndiFactory = new SimpleJndiBeanFactory();
  186-		}
  187-	}
  188-
