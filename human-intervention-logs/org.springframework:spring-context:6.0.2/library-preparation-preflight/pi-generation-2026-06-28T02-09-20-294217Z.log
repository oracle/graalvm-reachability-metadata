  190-	/**
  191-	 * Ignore the given resource type when resolving {@code @Resource} annotations.
  192-	 * @param resourceType the resource type to ignore
  193-	 */
  194-	public void ignoreResourceType(String resourceType) {
  195-		Assert.notNull(resourceType, "Ignored resource type must not be null");
  196-		this.ignoredResourceTypes.add(resourceType);
  197-	}
  198-
  199-	/**
  200-	 * Set whether to allow a fallback to a type match if no explicit name has been
  201-	 * specified. The default name (i.e. the field name or bean property name) will
  202-	 * still be checked first; if a bean of that name exists, it will be taken.
  203-	 * However, if no bean of that name exists, a by-type resolution of the
  204-	 * dependency will be attempted if this flag is "true".
  205-	 * <p>Default is "true". Switch this flag to "false" in order to enforce a
  206-	 * by-name lookup in all cases, throwing an exception in case of no name match.
  207-	 * @see org.springframework.beans.factory.config.AutowireCapableBeanFactory#resolveDependency
  208-	 */
  209-	public void setFallbackToDefaultTypeMatch(boolean fallbackToDefaultTypeMatch) {
  210-		this.fallbackToDefaultTypeMatch = fallbackToDefaultTypeMatch;
  211-	}
  212-
  213-	/**
  214-	 * Set whether to always use JNDI lookups equivalent to standard Jakarta EE resource
  215-	 * injection, <b>even for {@code name} attributes and default names</b>.
  216-	 * <p>Default is "false": Resource names are used for Spring bean lookups in the
  217-	 * containing BeanFactory; only {@code mappedName} attributes point directly
  218-	 * into JNDI. Switch this flag to "true" for enforcing Jakarta EE style JNDI lookups
  219-	 * in any case, even for {@code name} attributes and default names.
  220-	 * @see #setJndiFactory
  221-	 * @see #setResourceFactory
  222-	 */
  223-	public void setAlwaysUseJndiLookup(boolean alwaysUseJndiLookup) {
  224-		this.alwaysUseJndiLookup = alwaysUseJndiLookup;
  225-	}
  226-
  227-	/**
  228-	 * Specify the factory for objects to be injected into {@code @Resource} /
  229-	 * {@code @EJB} annotated fields and setter methods,
  230-	 * <b>for {@code mappedName} attributes that point directly into JNDI</b>.
  231-	 * This factory will also be used if "alwaysUseJndiLookup" is set to "true" in order
  232-	 * to enforce JNDI lookups even for {@code name} attributes and default names.
  233-	 * <p>The default is a {@link org.springframework.jndi.support.SimpleJndiBeanFactory}
  234-	 * for JNDI lookup behavior equivalent to standard Jakarta EE resource injection.
  235-	 * @see #setResourceFactory
