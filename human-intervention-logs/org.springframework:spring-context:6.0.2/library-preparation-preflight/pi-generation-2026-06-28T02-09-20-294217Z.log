  69-/**
  70- * {@link org.springframework.beans.factory.config.BeanPostProcessor} implementation
  71- * that supports common Java annotations out of the box, in particular the common
  72: * annotations in the {@code jakarta.annotation} package. These common Java
  73- * annotations are supported in many Jakarta EE technologies (e.g. JSF and JAX-RS).
  74- *
  75: * <p>This post-processor includes support for the {@link jakarta.annotation.PostConstruct}
  76: * and {@link jakarta.annotation.PreDestroy} annotations - as init annotation
  77- * and destroy annotation, respectively - through inheriting from
  78- * {@link InitDestroyAnnotationBeanPostProcessor} with pre-configured annotation types.
  79- *
  80: * <p>The central element is the {@link jakarta.annotation.Resource} annotation
  81- * for annotation-driven injection of named beans, by default from the containing
  82- * Spring BeanFactory, with only {@code mappedName} references resolved in JNDI.
  83- * The {@link #setAlwaysUseJndiLookup "alwaysUseJndiLookup" flag} enforces JNDI lookups
  84- * equivalent to standard Jakarta EE resource injection for {@code name} references
  85- * and default names as well. The target beans can be simple POJOs, with no special
  86- * requirements other than the type having to match.
  87- *
  88: * <p>This post-processor also supports the EJB 3 {@link jakarta.ejb.EJB} annotation,
  89: * analogous to {@link jakarta.annotation.Resource}, with the capability to
  90- * specify both a local bean name and a global JNDI name for fallback retrieval.
  91- * The target beans can be plain POJOs as well as EJB 3 Session Beans in this case.
  92- *
  93- * <p>For default usage, resolving resource names as Spring bean names,
  94- * simply define the following in your application context:
  95- *
  96- * <pre class="code">
  97- * &lt;bean class="org.springframework.context.annotation.CommonAnnotationBeanPostProcessor"/&gt;</pre>
  98- *
  99- * For direct JNDI access, resolving resource names as JNDI resource references
  100- * within the Jakarta EE application's "java:comp/env/" namespace, use the following:
  101- *
  102- * <pre class="code">
  103- * &lt;bean class="org.springframework.context.annotation.CommonAnnotationBeanPostProcessor"&gt;
  104- *   &lt;property name="alwaysUseJndiLookup" value="true"/&gt;
  105- * &lt;/bean&gt;</pre>
  106- *
  107- * {@code mappedName} references will always be resolved in JNDI,
  108- * allowing for global JNDI names (including "java:" prefix) as well. The
  109- * "alwaysUseJndiLookup" flag just affects {@code name} references and
  110- * default names (inferred from the field name / property name).
  111- *
  112- * <p><b>NOTE:</b> A default CommonAnnotationBeanPostProcessor will be registered
  113- * by the "context:annotation-config" and "context:component-scan" XML tags.
  114- * Remove or turn off the default annotation configuration there if you intend
  115- * to specify a custom CommonAnnotationBeanPostProcessor bean definition!
  116- * <p><b>NOTE:</b> Annotation injection will be performed <i>before</i> XML injection; thus
  117- * the latter configuration will override the former for properties wired through
  118- * both approaches.
  119- *
  120- * @author Juergen Hoeller
  121- * @author Sam Brannen
  122- * @since 2.5
  123- * @see #setAlwaysUseJndiLookup
  124- * @see #setResourceFactory
  125- * @see org.springframework.beans.factory.annotation.InitDestroyAnnotationBeanPostProcessor
  126- * @see org.springframework.beans.factory.annotation.AutowiredAnnotationBeanPostProcessor
  127- */
  128-@SuppressWarnings("serial")
  129-public class CommonAnnotationBeanPostProcessor extends InitDestroyAnnotationBeanPostProcessor
  130-		implements InstantiationAwareBeanPostProcessor, BeanFactoryAware, Serializable {
  131-
  132-	// Defensive reference to JNDI API for JDK 9+ (optional java.naming module)
  133-	private static final boolean jndiPresent = ClassUtils.isPresent(
  134-			"javax.naming.InitialContext", CommonAnnotationBeanPostProcessor.class.getClassLoader());
  135-
  136-	private static final Set<Class<? extends Annotation>> resourceAnnotationTypes = new LinkedHashSet<>(4);
  137-
  138-	@Nullable
  139-	private static final Class<? extends Annotation> ejbClass;
  140-
  141-	static {
  142-		resourceAnnotationTypes.add(Resource.class);
  143-
  144:		ejbClass = loadAnnotationType("jakarta.ejb.EJB");
  145-		if (ejbClass != null) {
  146-			resourceAnnotationTypes.add(ejbClass);
  147-		}
  148-	}
  149-
  150-
  151-	private final Set<String> ignoredResourceTypes = new HashSet<>(1);
  152-
  153-	private boolean fallbackToDefaultTypeMatch = true;
  154-
  155-	private boolean alwaysUseJndiLookup = false;
  156-
  157-	@Nullable
  158-	private transient BeanFactory jndiFactory;
  159-
  160-	@Nullable
  161-	private transient BeanFactory resourceFactory;
  162-
  163-	@Nullable
  164-	private transient BeanFactory beanFactory;
