import java.nio.charset.StandardCharsets\nimport scala.concurrent.duration.*\n\nclass Fs2IoIojvmnativeTest {\n  @Test\n  def readClassResourceReadsResourceRelativeToClass(): Unit = {\n    val bytes: Vector[Byte] = runIO(\n      fs2.io\n        .readClassResource[IO, Fs2IoIojvmnativeTest](\n          \"iojvmnative/class-resource.txt\",\n          chunkSize = 5\n        )\n        .compile\n        .toVector\n    )\n\n    assertThat(utf8(bytes)).isEqualTo(\"class resource from fs2.io.iojvmnative\\n\")\n  }\n\n  @Test\n  def readClassLoaderResourceReadsResourceFromProvidedClassLoader(): Unit = {\n    val resourceName: String = \"co_fs2/fs2_io_3/iojvmnative/classloader-resource.txt\"\n    val bytes: Vector[Byte] = runIO(\n      fs2.io\n        .readClassLoaderResource[IO](\n          resourceName,\n          chunkSize = 7,\n          classLoader = getClass.getClassLoader\n        )\n        .compile\n        .toVector\n    )\n\n    assertThat(utf8(bytes)).isEqualTo(\"classloader resource from fs2.io.iojvmnative\\n\")\n  }\n\n  private def runIO[A](effect: IO[A]): A =\n    effect.timeout(10.seconds).unsafeRunSync()\n\n  private def utf8(bytes: Vector[Byte]): String =\n    new String(bytes.toArray, StandardCharsets.UTF_8)\n}\n===== TLS TEST =====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage co_fs2.fs2_io_3\n\nimport cats.effect.IO\nimport cats.effect.unsafe.implicits.global\nimport fs2.io.net.tls.TLSContext\nimport org.assertj.core.api.Assertions.assertThatThrownBy\nimport org.junit.jupiter.api.Test\n\nimport java.io.IOException\nimport scala.concurrent.duration.*\n\nclass TLSContextCompanionPlatformInnerBuilderCompanionPlatformInnerAsyncBuilderTest {\n  @Test\n  def fromKeyStoreResourceLoadsClasspathResourceWithBuilderClassLoader(): Unit = {\n    val resourceName: String = \"co_fs2/fs2_io_3/iojvmnative/classloader-resource.txt\"\n    val storePassword: Array[Char] = \"store-password\".toCharArray\n    val keyPassword: Array[Char] = \"key-password\".toCharArray\n\n    assertThatThrownBy { () =>\n      runIO(\n        TLSContext.Builder\n          .forAsync[IO]\n          .fromKeyStoreResource(resourceName, storePassword, keyPassword)\n      )\n    }.isInstanceOf(classOf[IOException])\n  }\n\n  private def runIO[A](effect: IO[A]): A =\n    effect.timeout(10.seconds).unsafeRunSync()\n}\n===== STATS =====\n{\n  \"versions\" : [ {\n    \"version\" : \"3.11.0\",\n    \"dynamicAccess\" : {\n      \"breakdown\" : {\n        \"resources\" : {\n          \"coverageRatio\" : 1.0,\n          \"coveredCalls\" : 3,\n          \"totalCalls\" : 3\n        }\n      },\n      \"coverageRatio\" : 1.0,\n      \"coveredCalls\" : 3,\n      \"totalCalls\" : 3\n    },\n    \"libraryCoverage\" : {\n      \"instruction\" : {\n        \"covered\" : 223,\n        \"missed\" : 26001,\n        \"ratio\" : 0.008504,\n        \"total\" : 26224\n      },\n      \"line\" : {\n        \"covered\" : 30,\n        \"missed\" : 2285,\n        \"ratio\" : 0.012959,\n        \"total\" : 2315\n      },\n      \"method\" : {\n        \"covered\" : 26,\n        \"missed\" : 2843,\n        \"ratio\" : 0.009062,\n        \"total\" : 2869\n      }\n    }\n  } ]\n}\n","exit_code":0,"status":"completed"}}
