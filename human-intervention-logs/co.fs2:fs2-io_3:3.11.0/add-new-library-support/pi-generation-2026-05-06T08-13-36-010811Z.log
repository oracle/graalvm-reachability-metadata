[tool-call] delta {"path":"tests/src/co.fs2/fs2-io_3/3.11.0/src/test/scala/co_fs2/fs2_io_3/TLSContextCompanionPlatformInnerBuilderCompanionPlatformInnerAsyncBuilderTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage co_fs2.fs2_io_3\n\nimport cats.effect.IO\nimport cats.effect.unsafe.implicits.global\nimport fs2.io.net.tls.TLSContext\nimport org.assertj.core.api.Assertions.assertThatThrownBy\nimport org.junit.jupiter.api.Test\n\nimport java.io.IOException\nimport scala.concurrent.duration.*\n\nclass TLSContextCompanionPlatformInnerBuilderCompanionPlatformInnerAsyncBuilderTest {\n  @Test\n  def fromKeyStoreResourceLoadsClasspathResourceWithBuilderClassLoader(): Unit = {\n    val resourceName: String = \"co_fs2/fs2_io_3/iojvmnative/classloader-resource.txt\"\n    val storePassword: Array[Char] = \"store-password\".toCharArray\n    val keyPassword: Array[Char] = \"key-password\".toCharArray\n\n    assertThatThrownBy { () =>\n      runIO(\n        TLSContext.Builder\n          .forAsync[IO]\n          .fromKeyStoreResource(resourceName, storePassword, keyPassword)\n      )\n    }.isInstanceOf(classOf[IOException])\n  }\n\n  private def runIO[A](effect: IO[A]): A =\n    effect.timeout(10.seconds).unsafeRunSync()\n}\n"}
