delta {\"path\":\"tests/src/asm/asm/3.1/src/test/java/asm/asm/ClassReaderTest.java\",\"edits\":[{\"oldText\":\"import org.objectweb.asm.ClassReader;\\nimport org.objectweb.asm.Opcodes;\\n\\nimport java.io.IOException;\\nimport java.io.InputStream;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\",\"newText\":\"import org.objectweb.asm.AnnotationVisitor;\\nimport org.objectweb.asm.Attribute;\\nimport org.objectweb.asm.ClassReader;\\nimport org.objectweb.asm.ClassVisitor;\\nimport org.objectweb.asm.FieldVisitor;\\nimport org.objectweb.asm.MethodVisitor;\\nimport org.objectweb.asm.Opcodes;\\n\\nimport java.io.IOException;\\nimport java.io.InputStream;\\nimport java.util.ArrayList;\\nimport java.util.List;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\"},{\"oldText\":\"    @Test\\n    void readsTheSameClassBytesAsTheResourceStreamConstructor() throws IOException {\\n        ClassReader classReaderFromName = new ClassReader(CLASS_READER_NAME);\\n\\n        try (InputStream inputStream = ClassLoader.getSystemResourceAsStream(CLASS_READER_RESOURCE)) {\\n            assertThat(inputStream).isNotNull();\\n\\n            ClassReader classReaderFromStream = new ClassReader(inputStream);\\n\\n            assertThat(classReaderFromName.b).containsExactly(classReaderFromStream.b);\\n        }\\n    }\\n}\\n\",\"newText\":\"    @Test\\n    void readsTheSameClassBytesAsTheResourceStreamConstructor() throws IOException {\\n        ClassReader classReaderFromName = new ClassReader(CLASS_READER_NAME);\\n\\n        try (InputStream inputStream = ClassLoader.getSystemResourceAsStream(CLASS_READER_RESOURCE)) {\\n            assertThat(inputStream).isNotNull();\\n\\n            ClassReader classReaderFromStream = new ClassReader(inputStream);\\n\\n            assertThat(classReaderFromName.b).containsExactly(classReaderFromStream.b);\\n        }\\n    }\\n\\n    @Test\\n    void visitsClassLoadedFromTheSystemClassLoader() throws IOException {\\n      