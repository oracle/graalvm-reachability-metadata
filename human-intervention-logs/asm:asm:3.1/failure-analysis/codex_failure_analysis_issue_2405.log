 String GENERATED_CLASS_NAME = \\\"asm/asm/generated/MergedCollections\\\";\\n    private static final String ARRAY_LIST_NAME = ArrayList.class.getName().replace('.', '/');\\n    private static final String LINKED_LIST_NAME = LinkedList.class.getName().replace('.', '/');\\n\\n    @Test\\n    void computesFramesForMergedJdkCollectionTypes() {\\n        ClassWriter classWriter = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\\n        classWriter.visit(\\n                Opcodes.V1_6,\\n                Opcodes.ACC_PUBLIC,\\n                GENERATED_CLASS_NAME,\\n                null,\\n                \\\"java/lang/Object\\\",\\n                null);\\n        writeCollectionMergeMethod(classWriter);\\n        classWriter.visitEnd();\\n\\n        byte[] generatedBytecode = classWriter.toByteArray();\\n        ClassReader classReader = new ClassReader(generatedBytecode);\\n\\n        assertThat(generatedBytecode).isNotEmpty();\\n        assertThat(classReader.getClassName()).isEqualTo(GENERATED_CLASS_NAME);\\n        assertThat(classReader.getSuperName()).isEqualTo(\\\"java/lang/Object\\\");\\n    }\\n\\n    private static void writeCollectionMergeMethod(ClassWriter classWriter) {\\n        MethodVisitor methodVisitor = classWriter.visitMethod(\\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,\\n                \\\"chooseCollection\\\",\\n                \\\"(Z)Ljava/lang/Object;\\\",\\n                null,\\n                null);\\n        Label useLinkedList = new Label();\\n        Label returnValue = new Label();\\n\\n        methodVisitor.visitCode();\\n        methodVisitor.visitVarInsn(Opcodes.ILOAD, 0);\\n        methodVisitor.visitJumpInsn(Opcodes.IFEQ, useLinkedList);\\n        methodVisitor.visitTypeInsn(Opcodes.NEW, ARRAY_LIST_NAME);\\n        methodVisitor.visitInsn(Opcodes.DUP);\\n        methodVisitor.visitMethodInsn(Opcodes.INVOKESPECIAL, ARRAY_LIST_NAME, \\\"<init>\\\", \\\"()V\\\");\\n        methodVisitor.visitVarInsn(Opcodes.ASTORE, 1);\\