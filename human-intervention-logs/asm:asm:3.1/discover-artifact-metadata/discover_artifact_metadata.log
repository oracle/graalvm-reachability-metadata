    </condition>

    <condition property="test.thread.exist">
      <available file="${test.thread}"/>
    </condition>

    <condition property="test.stress.exist">
      <available file="${test.stress}"/>
    </condition>

    <condition property="test.perf.exist">
      <available file="${test.perf}"/>
    </condition>
    
