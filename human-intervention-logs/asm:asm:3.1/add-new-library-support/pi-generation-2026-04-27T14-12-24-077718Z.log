  package asm.asm;
  
  import org.junit.jupiter.api.Test;
  import org.objectweb.asm.AnnotationVisitor;
  import org.objectweb.asm.Attribute;
  import org.objectweb.asm.ClassReader;
  import org.objectweb.asm.ClassVisitor;
  import org.objectweb.asm.FieldVisitor;
  import org.objectweb.asm.MethodVisitor;
  import org.objectweb.asm.Opcodes;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.util.ArrayList;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassReaderTest {
      private static final String CLASS_READER_NAME = "org.objectweb.asm.ClassReader";
      private static final String CLASS_READER_RESOURCE = "org/objectweb/asm/ClassReader.class";
  
      @Test
      void readsClassBytesFromTheSystemClassLoader() throws IOException {
          ClassReader classReader = new ClassReader(CLASS_READER_NAME);
  
          assertThat(classReader.getClassName()).isEqualTo("org/objectweb/asm/ClassReader");
          assertThat(classReader.getSuperName()).isEqualTo("java/lang/Object");
          assertThat(classReader.getAccess() & Opcodes.ACC_PUBLIC).isEqualTo(Opcodes.ACC_PUBLIC);
          assertThat(classReader.getInterfaces()).isEmpty();
      }
  
      @Test
      void readsTheSameClassBytesAsTheResourceStreamConstructor() throws IOException {
          ClassReader classReaderFromName = new ClassReader(CLASS_READER_NAME);
  
          try (InputStream inputStream = ClassLoader.getSystemResourceAsStream(CLASS_READER_RESOURCE)) {
              assertThat(inputStream).isNotNull();
  
              ClassReader classReaderFromStream = new ClassReader(inputStream);
  
              assertThat(classReaderFromName.b).containsExactly(classReaderFromStream.b);
          }
      }
  
      @Test
      void visitsClassLoadedFromTheSystemClassLoader() throws IOException {
          ClassReader classReader = new ClassReader(CLASS_READER_NAME);
          RecordingClassVisitor classVisitor = new RecordingClassVisitor();
  
          classReader.accept(classVisitor, ClassReader.SKIP_CODE | ClassReader.SKIP_DEBUG | ClassReader.SKIP_FRAMES);
  
          assertThat(classVisitor.className).isEqualTo("org/objectweb/asm/ClassReader");
          assertThat(classVisitor.superName).isEqualTo("java/lang/Object");
          assertThat(classVisitor.interfaces).isEmpty();
          assertThat(classVisitor.methodNames).contains("<init>", "getClassName", "getSuperName");
          assertThat(classVisitor.visitEndCalled).isTrue();
      }
  
      private static final class RecordingClassVisitor implements ClassVisitor {
          private String className;
          private String superName;
          private String[] interfaces;
          private final List<String> methodNames = new ArrayList<>();
          private boolean visitEndCalled;
  
          @Override
