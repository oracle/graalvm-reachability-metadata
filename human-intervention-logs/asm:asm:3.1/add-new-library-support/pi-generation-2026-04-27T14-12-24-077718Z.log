[tool-call] delta {"path":"tests/src/asm/asm/3.1/src/test/java/asm/asm/ClassWriterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage asm.asm;\n\nimport org.junit.jupiter.api.Test;\nimport org.objectweb.asm.ClassReader;\nimport org.objectweb.asm.ClassWriter;\nimport org.objectweb.asm.Label;\nimport org.objectweb.asm.MethodVisitor;\nimport org.objectweb.asm.Opcodes;\n\nimport java.util.ArrayList;\nimport java.util.LinkedList;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassWriterTest {\n    private static final String GENERATED_CLASS_NAME = \"asm/asm/generated/MergedCollections\";\n    private static final String ARRAY_LIST_NAME = ArrayList.class.getName().replace('.', '/');\n    private static final String LINKED_LIST_NAME = LinkedList.class.getName().replace('.', '/');\n\n    @Test\n    void computesFramesForMergedJdkCollectionTypes() {\n        ClassWriter classWriter = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        classWriter.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC,\n                GENERATED_CLASS_NAME,\n                null,\n                \"java/lang/Object\",\n                null);\n        writeCollectionMergeMethod(classWriter);\n        classWriter.visitEnd();\n\n        byte[] generatedBytecode = classWriter.toByteArray();\n        ClassReader classReader = new ClassReader(generatedBytecode);\n\n        assertThat(generatedBytecode).isNotEmpty();\n        assertThat(classReader.getClassName()).isEqualTo(GENERATED_CLASS_NAME);\n        assertThat(classReader.getSuperName()).isEqualTo(\"java/lang/Object\");\n    }\n\n    private static void writeCollectionMergeMethod(ClassWriter classWriter) {\n        MethodVisitor methodVisitor = classWriter.visitMethod(\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,\n                \"chooseCollection\",\n                \"(Z)Ljava/lang/Object;\",\n                null,\n                null);\n        Label useLinkedList = new Label();\n        Label returnValue = new Label();\n\n        methodVisitor.visitCode();\n        methodVisitor.visitVarInsn(Opcodes.ILOAD, 0);\n        methodVisitor.visitJumpInsn(Opcodes.IFEQ, useLinkedList);\n        methodVisitor.visitTypeInsn(Opcodes.NEW, ARRAY_LIST_NAME);\n        methodVisitor.visitInsn(Opcodes.DUP);\n        methodVisitor.visitMethodInsn(Opcodes.INVOKESPECIAL, ARRAY_LIST_NAME, \"<init>\", \"()V\");\n        methodVisitor.visitVarInsn(Opcodes.ASTORE, 1);\n        methodVisitor.visitJumpInsn(Opcodes.GOTO, returnValue);\n        methodVisitor.visitLabel(useLinkedList);\n        methodVisitor.visitTypeInsn(Opcodes.NEW, LINKED_LIST_NAME);\n        methodVisitor.visitInsn(Opcodes.DUP);\n        methodVisitor.visitMethodInsn(Opcodes.INVOKESPECIAL, LINKED_LIST_NAME, \"<init>\", \"()V\");\n        methodVisitor.visitVarInsn(Opcodes.ASTORE, 1);\n        methodVisitor.visitLabel(returnValue);\n        methodVisitor.visitVarInsn(Opcodes.ALOAD, 1);\n        methodVisitor.visitInsn(Opcodes.ARETURN);\n        methodVisitor.visitMaxs(0, 0);\n        methodVisitor.visitEnd();\n    }\n}\n"}
[tool-call] end id=call_GSgfL2HUy5WQl8P5j8ecIewc|fc_07083aa4e0d3106d0169ef6ea9bd04819699e15ba9255ceba7 name=write args={"path": "tests/src/asm/asm/3.1/src/test/java/asm/asm/ClassWriterTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage asm.asm;\n\nimport org.junit.jupiter.api.Test;\nimport org.objectweb.asm.ClassReader;\nimport org.objectweb.asm.ClassWriter;\nimport org.objectweb.asm.Label;\nimport org.objectweb.asm.MethodVisitor;\nimport org.objectweb.asm.Opcodes;\n\nimport java.util.ArrayList;\nimport java.util.LinkedList;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassWriterTest {\n    private static final String GENERATED_CLASS_NAME = \"asm/asm/generated/MergedCollections\";\n    private static final String ARRAY_LIST_NAME = ArrayList.class.getName().replace('.', '/');\n    private static final String LINKED_LIST_NAME = LinkedList.class.getName().replace('.', '/');\n\n    @Test\n    void computesFramesForMergedJdkCollectionTypes() {\n        ClassWriter classWriter = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        classWriter.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC,\n                GENERATED_CLASS_NAME,\n                null,\n                \"java/lang/Object\",\n                null);\n        writeCollectionMergeMethod(classWriter);\n        classWriter.visitEnd();\n\n        byte[] generatedBytecode = classWriter.toByteArray();\n        ClassReader classReader = new ClassReader(generatedBytecode);\n\n        assertThat(generatedBytecode).isNotEmpty();\n        assertThat(classReader.getClassName()).isEqualTo(GENERATED_CLASS_NAME);\n        assertThat(classReader.getSuperName()).isEqualTo(\"java/lang/Object\");\n    }\n\n    private static void writeCollectionMergeMethod(ClassWriter classWriter) {\n        MethodVisitor methodVisitor = classWriter.visitMethod(\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,\n                \"chooseCollection\",\n                \"(Z)Ljava/lang/Object;\",\n                null,\n                null);\n        Label useLinkedList = new Label();\n        Label returnValue = new Label();\n\n        methodVisitor.visitCode();\n        methodVisitor.visitVarInsn(Opcodes.ILOAD, 0);\n        methodVisitor.visitJumpInsn(Opcodes.IFEQ, useLinkedList);\n        methodVisitor.visitTypeInsn(Opcodes.NEW, ARRAY_LIST_NAME);\n        methodVisitor.visitInsn(Opcodes.DUP);\n        methodVisitor.visitMethodInsn(Opcodes.INVOKESPECIAL, ARRAY_LIST_NAME, \"<init>\", \"()V\");\n        methodVisitor.visitVarInsn(Opcodes.ASTORE, 1);\n        methodVisitor.visitJumpInsn(Opcodes.GOTO, returnValue);\n        methodVisitor.visitLabel(useLinkedList);\n        methodVisitor.visitTypeInsn(Opcodes.NEW, LINKED_LIST_NAME);\n        methodVisitor.visitInsn(Opcodes.DUP);\n        methodVisitor.visitMethodInsn(Opcodes.INVOKESPECIAL, LINKED_LIST_NAME, \"<init>\", \"()V\");\n        methodVisitor.visitVarInsn(Opcodes.ASTORE, 1);\n        methodVisitor.visitLabel(returnValue);\n        methodVisitor.visitVarInsn(Opcodes.ALOAD, 1);\n        methodVisitor.visitInsn(Opcodes.ARETURN);\n        methodVisitor.visitMaxs(0, 0);\n        methodVisitor.visitEnd();\n    }\n}\n"}
