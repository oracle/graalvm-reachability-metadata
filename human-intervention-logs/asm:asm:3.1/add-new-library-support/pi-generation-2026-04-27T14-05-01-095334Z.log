[tool-call] delta {"path":"tests/src/asm/asm/3.1/src/test/java/asm/asm/ClassReaderTest.java","edits":[{"oldText":"import org.objectweb.asm.ClassReader;\n\nimport java.io.IOException;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n","newText":"import org.objectweb.asm.ClassReader;\nimport org.objectweb.asm.Opcodes;\n\nimport java.io.IOException;\nimport java.io.InputStream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n"},{"oldText":"public class ClassReaderTest {\n    @Test\n    void readsClassBytesFromTheSystemClassLoader() throws IOException {\n        ClassReader classReader = new ClassReader(ClassReader.class.getName());\n\n        assertThat(classReader.getClassName()).isEqualTo(\"org/objectweb/asm/ClassReader\");\n        assertThat(classReader.getSuperName()).isEqualTo(\"java/lang/Object\");\n    }\n}\n","newText":"public class ClassReaderTest {\n    private static final String CLASS_READER_NAME = \"org.objectweb.asm.ClassReader\";\n    private static final String CLASS_READER_RESOURCE = \"org/objectweb/asm/ClassReader.class\";\n\n    @Test\n    void readsClassBytesFromTheSystemClassLoader() throws IOException {\n        ClassReader classReader = new ClassReader(CLASS_READER_NAME);\n\n        assertThat(classReader.getClassName()).isEqualTo(\"org/objectweb/asm/ClassReader\");\n        assertThat(classReader.getSuperName()).isEqualTo(\"java/lang/Object\");\n        assertThat(classReader.getAccess()).isEqualTo(Opcodes.ACC_PUBLIC);\n        assertThat(classReader.getInterfaces()).isEmpty();\n    }\n\n    @Test\n    void readsTheSameClassBytesAsTheResourceStreamConstructor() throws IOException {\n        ClassReader classReaderFromName = new ClassReader(CLASS_READER_NAME);\n\n        try (InputStream inputStream = ClassLoader.getSystemResourceAsStream(CLASS_READER_RESOURCE)) {\n            assertThat(inputStream).isNotNull();\n\n            ClassReader classReaderFromStream = new ClassReader(inputStream);\n\n            assertThat(classReaderFromName.b).containsExactly(classReaderFromStream.b);\n        }\n    }\n}\n"}]}
[tool-call] end id=call_1AQU992kzk9OjU1mbJZSjMwv|fc_0a17f3ff06c80cf00169ef6d92c364819ea666e94da2403ab7 name=edit args={"path": "tests/src/asm/asm/3.1/src/test/java/asm/asm/ClassReaderTest.java", "edits": [{"oldText": "import org.objectweb.asm.ClassReader;\n\nimport java.io.IOException;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n", "newText": "import org.objectweb.asm.ClassReader;\nimport org.objectweb.asm.Opcodes;\n\nimport java.io.IOException;\nimport java.io.InputStream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n"}, {"oldText": "public class ClassReaderTest {\n    @Test\n    void readsClassBytesFromTheSystemClassLoader() throws IOException {\n        ClassReader classReader = new ClassReader(ClassReader.class.getName());\n\n        assertThat(classReader.getClassName()).isEqualTo(\"org/objectweb/asm/ClassReader\");\n        assertThat(classReader.getSuperName()).isEqualTo(\"java/lang/Object\");\n    }\n}\n", "newText": "public class ClassReaderTest {\n    private static final String CLASS_READER_NAME = \"org.objectweb.asm.ClassReader\";\n    private static final String CLASS_READER_RESOURCE = \"org/objectweb/asm/ClassReader.class\";\n\n    @Test\n    void readsClassBytesFromTheSystemClassLoader() throws IOException {\n        ClassReader classReader = new ClassReader(CLASS_READER_NAME);\n\n        assertThat(classReader.getClassName()).isEqualTo(\"org/objectweb/asm/ClassReader\");\n        assertThat(classReader.getSuperName()).isEqualTo(\"java/lang/Object\");\n        assertThat(classReader.getAccess()).isEqualTo(Opcodes.ACC_PUBLIC);\n        assertThat(classReader.getInterfaces()).isEmpty();\n    }\n\n    @Test\n    void readsTheSameClassBytesAsTheResourceStreamConstructor() throws IOException {\n        ClassReader classReaderFromName = new ClassReader(CLASS_READER_NAME);\n\n        try (InputStream inputStream = ClassLoader.getSystemResourceAsStream(CLASS_READER_RESOURCE)) {\n            assertThat(inputStream).isNotNull();\n\n            ClassReader classReaderFromStream = new ClassReader(inputStream);\n\n            assertThat(classReaderFromName.b).containsExactly(classReaderFromStream.b);\n        }\n    }\n}\n"}]}
