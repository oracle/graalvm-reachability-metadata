      public ClassWriter(final int flags) {
          index = 1;
          pool = new ByteVector();
          items = new Item[256];
          threshold = (int) (0.75d * items.length);
          key = new Item();
          key2 = new Item();
          key3 = new Item();
          this.computeMaxs = (flags & COMPUTE_MAXS) != 0;
          this.computeFrames = (flags & COMPUTE_FRAMES) != 0;
