      Integer INTEGER = new Integer(1);
      Integer FLOAT = new Integer(2);
      Integer DOUBLE = new Integer(3);
      Integer LONG = new Integer(4);
      Integer NULL = new Integer(5);
      Integer UNINITIALIZED_THIS = new Integer(6);
  
