[tool-call] delta {"path":"tests/src/asm/asm/3.1/src/test/java/asm/asm/ClassReaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage asm.asm;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.objectweb.asm.ClassReader;\nimport org.objectweb.asm.Opcodes;\n\npublic class ClassReaderTest {\n    @Test\n    void readsClassBytesLoadedByName() throws Exception {\n        ClassReader reader = new ClassReader(\"org.objectweb.asm.ClassReader\");\n\n        assertThat(reader.getClassName()).isEqualTo(\"org/objectweb/asm/ClassReader\");\n        assertThat(reader.getSuperName()).isEqualTo(\"java/lang/Object\");\n        assertThat(reader.getAccess() & Opcodes.ACC_PUBLIC).isEqualTo(Opcodes.ACC_PUBLIC);\n    }\n}\n"}
