[tool-call] delta {"path":"tests/src/org.apache.camel/camel-util/4.19.0/src/test/java/org_apache_camel/camel_util/AnnotationHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_util;\n\nimport java.lang.annotation.ElementType;\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\nimport java.lang.annotation.Target;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.List;\n\nimport org.apache.camel.util.AnnotationHelper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationHelperTest {\n    @Test\n    void findsAnnotatedMethodsAcrossClassHierarchy() {\n        List<Method> methods = AnnotationHelper.findMethodsWithAnnotation(AnnotatedChildService.class,\n                RouteAction.class);\n\n        assertThat(methods).extracting(Method::getName).contains(\"childAction\", \"parentAction\");\n    }\n\n    @Test\n    void readsAnnotationValuesFromMethodAndFieldMembers() throws NoSuchMethodException, NoSuchFieldException {\n        Method method = AnnotatedChildService.class.getDeclaredMethod(\"childAction\");\n        Field field = AnnotatedFieldHolder.class.getDeclaredField(\"endpointName\");\n\n        assertThat(AnnotationHelper.getAnnotationValue(method, RouteAction.class.getName(), \"value\"))\n                .isEqualTo(\"child-route\");\n        assertThat(AnnotationHelper.getAnnotationValue(method, RouteAction.class.getName(), \"description\"))\n                .isEqualTo(\"handles child messages\");\n        assertThat(AnnotationHelper.getAnnotationValue(field, EndpointName.class.getName(), \"value\"))\n                .isEqualTo(\"orders\");\n        assertThat(AnnotationHelper.getAnnotationValue(field, EndpointName.class.getName(), \"component\"))\n                .isEqualTo(\"seda\");\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.METHOD)\n    public @interface RouteAction {\n        String value();\n\n        String description() default \"\";\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @Target(ElementType.FIELD)\n    public @interface EndpointName {\n        String value();\n\n        String component() default \"direct\";\n    }\n\n    public static class AnnotatedParentService {\n        @RouteAction(\"parent-route\")\n        public void parentAction() {\n        }\n    }\n\n    public static final class AnnotatedChildService extends AnnotatedParentService {\n        @RouteAction(value = \"child-route\", description = \"handles child messages\")\n        public void childAction() {\n        }\n    }\n\n    public static final class AnnotatedFieldHolder {\n        @EndpointName(value = \"orders\", component = \"seda\")\n        public String endpointName;\n    }\n}\n"}
