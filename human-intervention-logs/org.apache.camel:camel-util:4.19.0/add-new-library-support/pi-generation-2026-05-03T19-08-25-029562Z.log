  package org_apache_camel.camel_util;
  
  import java.io.IOException;
  import java.net.URL;
  import java.util.Enumeration;
  
  import org.apache.camel.util.ObjectHelper;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ObjectHelperTest {
      private static final String DEFAULT_CAMEL_CONTEXT_CLASS = "org.apache.camel.impl.DefaultCamelContext";
      private static final String MISSING_RESOURCE_NAME = "missing-camel-util-resource-for-object-helper-test.txt";
  
      @Test
      void loadsApplicationClassArrayByName() {
          Class<?> loadedType = ObjectHelper.loadClass(ObjectHelperTest.class.getName() + "[]",
                  ObjectHelperTest.class.getClassLoader(), false);
  
          assertThat(loadedType).isEqualTo(ObjectHelperTest[].class);
      }
  
      @Test
      void detectsPublicAndNonPrivateNoArgConstructors() {
          assertThat(ObjectHelper.hasDefaultPublicNoArgConstructor(PublicNoArgConstructorCandidate.class)).isTrue();
          assertThat(ObjectHelper.hasDefaultNoArgConstructor(PackageNoArgConstructorCandidate.class)).isTrue();
          assertThat(ObjectHelper.hasDefaultNoArgConstructor(PrivateNoArgConstructorCandidate.class)).isFalse();
      }
  
      @Test
      void looksUpPublicStaticConstantFieldValues() {
          assertThat(ObjectHelper.lookupConstantFieldValue(ConstantHolder.class, ".TEXT")).isEqualTo("camel-util");
          assertThat(ObjectHelper.lookupConstantFieldValue(ConstantHolder.class, "NUMBER")).isEqualTo("19");
          assertThat(ObjectHelper.lookupConstantFieldValue(ConstantHolder.class, "MISSING")).isNull();
      }
  
      @Test
      void probesAllResourceUrlLoadersBeforeReturningNull() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(new MissingResourceCamelContextClassLoader());
  
              URL resource = ObjectHelper.loadResourceAsURL(MISSING_RESOURCE_NAME, new MissingResourceClassLoader());
  
              assertThat(resource).isNull();
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void returnsResourceEnumerationFromProvidedClassLoader() {
          Enumeration<URL> resources = ObjectHelper.loadResourcesAsURL(MISSING_RESOURCE_NAME,
                  ObjectHelperTest.class.getClassLoader());
  
          assertThat(resources).isNotNull();
          assertThat(resources.hasMoreElements()).isFalse();
      }
  
      @Test
      void returnsResourceEnumerationFromContextClassLoader() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(ObjectHelperTest.class.getClassLoader());
  
              Enumeration<URL> resources = ObjectHelper.loadResourcesAsURL(MISSING_RESOURCE_NAME);
  
              assertThat(resources).isNotNull();
              assertThat(resources.hasMoreElements()).isFalse();
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void probesCamelContextClassLoaderWhenLoadingResourceEnumerations() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(new ThrowingResourcesCamelContextClassLoader());
  
              Enumeration<URL> resources = ObjectHelper.loadResourcesAsURL(MISSING_RESOURCE_NAME,
                      new ThrowingResourcesClassLoader());
  
              assertThat(resources).isNotNull();
              assertThat(resources.hasMoreElements()).isFalse();
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void fallsBackToObjectHelperClassLoaderWhenResourceEnumerationLookupFails() {
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(new ThrowingResourcesMissingCamelContextClassLoader());
  
              Enumeration<URL> resources = ObjectHelper.loadResourcesAsURL(MISSING_RESOURCE_NAME,
                      new ThrowingResourcesClassLoader());
  
              assertThat(resources).isNotNull();
              assertThat(resources.hasMoreElements()).isFalse();
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      public static final class PublicNoArgConstructorCandidate {
      }
  
      static final class PackageNoArgConstructorCandidate {
          PackageNoArgConstructorCandidate() {
          }
      }
  
      static final class PrivateNoArgConstructorCandidate {
          private PrivateNoArgConstructorCandidate() {
          }
      }
  
      public static final class ConstantHolder {
          public static final String TEXT = "camel-util";
          public static final int NUMBER = 19;
      }
  
      private static class MissingResourceClassLoader extends ClassLoader {
          @Override
          public URL getResource(String name) {
              return null;
          }
      }
  
      private static final class MissingResourceCamelContextClassLoader extends MissingResourceClassLoader {
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {
                  return ObjectHelperTest.class;
              }
              return super.loadClass(name);
          }
      }
  
      private static class ThrowingResourcesClassLoader extends ClassLoader {
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              throw new IOException("Forced resource enumeration failure for coverage");
          }
      }
  
      private static final class ThrowingResourcesCamelContextClassLoader extends ThrowingResourcesClassLoader {
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {
                  return ObjectHelperTest.class;
              }
              return super.loadClass(name);
          }
      }
  
      private static final class ThrowingResourcesMissingCamelContextClassLoader extends ThrowingResourcesClassLoader {
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
              return super.loadClass(name);
          }
