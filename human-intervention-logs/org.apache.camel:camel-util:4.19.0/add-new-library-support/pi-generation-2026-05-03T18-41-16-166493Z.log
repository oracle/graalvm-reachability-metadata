[tool-call] delta {"path":"tests/src/org.apache.camel/camel-util/4.19.0/src/test/java/org_apache_camel/camel_util/ObjectHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_util;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Enumeration;\n\nimport org.apache.camel.util.ObjectHelper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectHelperTest {\n    private static final String DEFAULT_CAMEL_CONTEXT_CLASS = \"org.apache.camel.impl.DefaultCamelContext\";\n    private static final String MISSING_RESOURCE_NAME = \"missing-camel-util-resource-for-object-helper-test.txt\";\n\n    @Test\n    void loadsApplicationClassArrayByName() {\n        Class<?> loadedType = ObjectHelper.loadClass(ObjectHelperTest.class.getName() + \"[]\",\n                ObjectHelperTest.class.getClassLoader(), false);\n\n        assertThat(loadedType).isEqualTo(ObjectHelperTest[].class);\n    }\n\n    @Test\n    void detectsPublicAndNonPrivateNoArgConstructors() {\n        assertThat(ObjectHelper.hasDefaultPublicNoArgConstructor(PublicNoArgConstructorCandidate.class)).isTrue();\n        assertThat(ObjectHelper.hasDefaultNoArgConstructor(PackageNoArgConstructorCandidate.class)).isTrue();\n        assertThat(ObjectHelper.hasDefaultNoArgConstructor(PrivateNoArgConstructorCandidate.class)).isFalse();\n    }\n\n    @Test\n    void looksUpPublicStaticConstantFieldValues() {\n        assertThat(ObjectHelper.lookupConstantFieldValue(ConstantHolder.class, \".TEXT\")).isEqualTo(\"camel-util\");\n        assertThat(ObjectHelper.lookupConstantFieldValue(ConstantHolder.class, \"NUMBER\")).isEqualTo(\"19\");\n        assertThat(ObjectHelper.lookupConstantFieldValue(ConstantHolder.class, \"MISSING\")).isNull();\n    }\n\n    @Test\n    void probesAllResourceUrlLoadersBeforeReturningNull() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(new MissingResourceCamelContextClassLoader());\n\n            URL resource = ObjectHelper.loadResourceAsURL(MISSING_RESOURCE_NAME, new MissingResourceClassLoader());\n\n            assertThat(resource).isNull();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void probesCamelContextClassLoaderWhenLoadingResourceEnumerations() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(new ThrowingResourcesCamelContextClassLoader());\n\n            Enumeration<URL> resources = ObjectHelper.loadResourcesAsURL(MISSING_RESOURCE_NAME,\n                    new ThrowingResourcesClassLoader());\n\n            assertThat(resources).isNotNull();\n            assertThat(resources.hasMoreElements()).isFalse();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void fallsBackToObjectHelperClassLoaderWhenResourceEnumerationLookupFails() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(new ThrowingResourcesMissingCamelContextClassLoader());\n\n            Enumeration<URL> resources = ObjectHelper.loadResourcesAsURL(MISSING_RESOURCE_NAME,\n                    new ThrowingResourcesClassLoader());\n\n            assertThat(resources).isNotNull();\n            assertThat(resources.hasMoreElements()).isFalse();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    public static final class PublicNoArgConstructorCandidate {\n    }\n\n    static final class PackageNoArgConstructorCandidate {\n        PackageNoArgConstructorCandidate() {\n        }\n    }\n\n    static final class PrivateNoArgConstructorCandidate {\n        private PrivateNoArgConstructorCandidate() {\n        }\n    }\n\n    public static final class ConstantHolder {\n        public static final String TEXT = \"camel-util\";\n        public static final int NUMBER = 19;\n    }\n\n    private static class MissingResourceClassLoader extends ClassLoader {\n        @Override\n        public URL getResource(String name) {\n            return null;\n        }\n    }\n\n    private static final class MissingResourceCamelContextClassLoader extends MissingResourceClassLoader {\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {\n                return ObjectHelperTest.class;\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    private static class ThrowingResourcesClassLoader extends ClassLoader {\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            throw new IOException(\"Forced resource enumeration failure for coverage\");\n        }\n    }\n\n    private static final class ThrowingResourcesCamelContextClassLoader extends ThrowingResourcesClassLoader {\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {\n                return ObjectHelperTest.class;\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    private static final class ThrowingResourcesMissingCamelContextClassLoader extends ThrowingResourcesClassLoader {\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n    }\n}\n"}
