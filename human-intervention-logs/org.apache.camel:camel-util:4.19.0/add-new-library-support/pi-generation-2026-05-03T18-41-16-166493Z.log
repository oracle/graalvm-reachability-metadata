ader extends ThrowingResourcesClassLoader {\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {\n                return ObjectHelperTest.class;\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    private static final class ThrowingResourcesMissingCamelContextClassLoader extends ThrowingResourcesClassLoader {\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (DEFAULT_CAMEL_CONTEXT_CLASS.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 416, "output": 4108, "cacheRead": 13312, "cacheWrite": 0, "totalTokens": 17836, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777833611290, "responseId": "resp_0d96a10243801e210169f7968ba1f88194b11d300450d59d1c"}}
