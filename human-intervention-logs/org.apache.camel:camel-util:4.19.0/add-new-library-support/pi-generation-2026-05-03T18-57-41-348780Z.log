[tool-call] delta {"path":"tests/src/org.apache.camel/camel-util/4.19.0/src/test/java/org_apache_camel/camel_util/ReflectionHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_util;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.ArrayList;\nimport java.util.HashMap;\nimport java.util.HashSet;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\n\nimport org.apache.camel.util.ReflectionHelper;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionHelperTest {\n    @Test\n    void discoversNestedClassesFieldsAndInterfaceMethods() {\n        List<String> nestedClassNames = new ArrayList<>();\n        ReflectionHelper.doWithClasses(ReflectiveFixture.class,\n                nestedClass -> nestedClassNames.add(nestedClass.getSimpleName()));\n\n        assertThat(nestedClassNames).contains(\"NestedPart\", \"NestedMarker\");\n\n        Set<String> fieldNames = new HashSet<>();\n        ReflectionHelper.doWithFields(DerivedReflectiveFixture.class, field -> fieldNames.add(field.getName()));\n\n        assertThat(fieldNames).contains(\"baseField\", \"derivedField\");\n\n        Set<String> methodNames = new HashSet<>();\n        ReflectionHelper.doWithMethods(ChildOperations.class, method -> methodNames.add(method.getName()));\n\n        assertThat(methodNames).contains(\"childOperation\", \"parentOperation\");\n    }\n\n    @Test\n    void findsMethodsOnConcreteClassesAndInterfaces() {\n        Method concreteMethod = ReflectionHelper.findMethod(DerivedReflectiveFixture.class, \"derivedOperation\",\n                String.class);\n        Method interfaceMethod = ReflectionHelper.findMethod(ChildOperations.class, \"parentOperation\");\n\n        assertThat(concreteMethod).isNotNull();\n        assertThat(concreteMethod.getReturnType()).isEqualTo(String.class);\n        assertThat(interfaceMethod).isNotNull();\n        assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(ParentOperations.class);\n    }\n\n    @Test\n    void setsAndReadsPrimitiveAndObjectFields() {\n        MutableHolder holder = new MutableHolder();\n        Map<String, Field> fields = fieldsByName(MutableHolder.class);\n\n        ReflectionHelper.setField(requiredField(fields, \"enabled\"), holder, \"true\");\n        ReflectionHelper.setField(requiredField(fields, \"code\"), holder, \"7\");\n        ReflectionHelper.setField(requiredField(fields, \"count\"), holder, \"42\");\n        ReflectionHelper.setField(requiredField(fields, \"distance\"), holder, \"9001\");\n        ReflectionHelper.setField(requiredField(fields, \"ratio\"), holder, \"1.5\");\n        ReflectionHelper.setField(requiredField(fields, \"total\"), holder, \"2.5\");\n        ReflectionHelper.setField(requiredField(fields, \"description\"), holder, \"camel-util\");\n\n        assertThat(ReflectionHelper.getField(requiredField(fields, \"enabled\"), holder)).isEqualTo(Boolean.TRUE);\n        assertThat(ReflectionHelper.getField(requiredField(fields, \"code\"), holder)).isEqualTo(Byte.valueOf((byte) 7));\n        assertThat(ReflectionHelper.getField(requiredField(fields, \"count\"), holder)).isEqualTo(Integer.valueOf(42));\n        assertThat(ReflectionHelper.getField(requiredField(fields, \"distance\"), holder)).isEqualTo(Long.valueOf(9001L));\n        assertThat(ReflectionHelper.getField(requiredField(fields, \"ratio\"), holder)).isEqualTo(Float.valueOf(1.5F));\n        assertThat(ReflectionHelper.getField(requiredField(fields, \"total\"), holder)).isEqualTo(Double.valueOf(2.5D));\n        assertThat(ReflectionHelper.getField(requiredField(fields, \"description\"), holder)).isEqualTo(\"camel-util\");\n    }\n\n    private static Map<String, Field> fieldsByName(Class<?> type) {\n        Map<String, Field> fields = new HashMap<>();\n        ReflectionHelper.doWithFields(type, field -> fields.put(field.getName(), field));\n        return fields;\n    }\n\n    private static Field requiredField(Map<String, Field> fields, String name) {\n        Field field = fields.get(name);\n        assertThat(field).isNotNull();\n        return field;\n    }\n\n    private static final class ReflectiveFixture {\n        private static final class NestedPart {\n        }\n\n        private interface NestedMarker {\n        }\n    }\n\n    private static class BaseReflectiveFixture {\n        private String baseField = \"base\";\n    }\n\n    private static final class DerivedReflectiveFixture extends BaseReflectiveFixture {\n        private String derivedField = \"derived\";\n\n        String derivedOperation(String value) {\n            return value;\n        }\n    }\n\n    private interface ParentOperations {\n        void parentOperation();\n    }\n\n    private interface ChildOperations extends ParentOperations {\n        void childOperation();\n    }\n\n    private static final class MutableHolder {\n        private boolean enabled;\n        private byte code;\n        private int count;\n        private long distance;\n        private float ratio;\n        private double total;\n        private String description = \"initial\";\n    }\n}\n"}
