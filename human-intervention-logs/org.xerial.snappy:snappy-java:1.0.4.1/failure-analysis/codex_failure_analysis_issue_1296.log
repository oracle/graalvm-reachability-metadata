c_0b01435cdb5be1c0016a3d6d730ff081938426623727488824\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_xerial_snappy.snappy_java;\\n\\nimport org.junit.jupiter.api.BeforeAll;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\nimport org.xerial.snappy.Snappy;\\nimport org.xerial.snappy.SnappyInputStream;\\nimport org.xerial.snappy.SnappyLoader;\\nimport org.xerial.snappy.SnappyOutputStream;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class SnappyLoaderTest {\\n    private static final String LOADER_MODE_PROPERTY = \\\"snappy.loader.mode\\\";\\n    private static final String SYSTEM_LOADER_MODE = \\\"system\\\";\\n\\n    @TempDir\\n    static Path nativeLibraryTempDir;\\n\\n    @BeforeAll\\n    static void configureNativeLibraryLoading() throws Exception {\\n        System.clearProperty(SnappyLoader.KEY_SNAPPY_LIB_PATH);\\n        System.clearProperty(SnappyLoader.KEY_SNAPPY_LIB_NAME);\\n        System.setProperty(SnappyLoader.KEY_SNAPPY_DISABLE_BUNDLED_LIBS, \\\"false\\\");\\n\\n        if (SYSTEM_LOADER_MODE.equals(System.getProperty(LOADER_MODE_PROPERTY))) {\\n            System.setProperty(SnappyLoader.KEY_SNAPPY_USE_SYSTEMLIB, \\\"true\\\");\\n            return;\\n        }\\n\\n        System.setProperty(SnappyLoader.KEY_SNAPPY_TEMPDIR, nativeLibraryTempDir.toString());\\n        System.setProperty(SnappyLoader.KEY_SNAPPY_USE_SYSTEMLIB, \\\"false\\\");\\n\\n        String nativeLibraryName = System.mapLibraryName(\\\"snappyjava\\\");\\n        String extractedNativeLibraryName = \\\"snappy-\\\" + SnappyLoader.getVersion() + \\\"-\\\" + nativeLibraryName;\\n        Path extractedNativeLibrary = nativeLibraryTempDir.resolve(extractedNativeLibraryName);\\n        Files.writeString(extractedNativeLibrary, \\\"stale native library\\\", StandardCharsets.UTF_8);\\n    }\\n\\n    @Test\\n    void compressesByteArraysAndStreamsUsingBundledNativeLoader() throws Exception {\\n        byte[] input = \\\"\\\"\\\"\\n                Snappy's loader extracts the bundled JNI library and injects its native loader before\\n                normal compression APIs can run. This test uses only public compression and stream\\n                APIs so the supported loader path is exercised through real round trips.\\n                \\\"\\\"\\\".repeat(32).getBytes(StandardCharsets.UTF_8);\\n\\n        byte[] compressed = Snappy.compress(input);\\n\\n        assertThat(compressed).isNotEmpty();\\n        assertThat(Snappy.uncompress(compressed)).isEqualTo(input);\\n        assertThat(SnappyLoader.isNativeLibraryLoaded()).isTrue();\\n\\n        ByteArrayOutputStream compressedStream = new ByteArrayOutputStream();\\n        try (SnappyOutputStream snappyOutputStream = new SnappyOutputStream(compressedStream)) {\\n            snappyOutputStream.write(input);\\n        }\\n\\n        byte[] streamedCompressed = compressedStream.toByteArray();\\n        ByteArrayOutputStream streamedUncompressed = new ByteArrayOutputStream();\\n        ByteArrayInputStream compressedInput = new ByteArrayInputStream(streamedCompressed);\\n        try (SnappyInputStream snappyInputStream = new SnappyInputStream(compressedInput)) {\\n            byte[] buffer = new byte[64];\\n            for (int read = snappyInputStream.read(buffer);\\n                    read != -1;\\n                    read = snappyInputStream.read(buffer)) {\\n                streamedUncompressed.write(buffer, 0, read);\\n            }\\n        }\\n\\n        assertThat(streamedUncompressed.toByteArray()).isEqualTo(input);\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1782410611534}]}\n[recv] {\"type\": \"turn_start\"}\n[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"assistant\", \"content\": [], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"totalTokens\": 0, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"stop\", \"timestamp\": 1782410611544}}\n[assistant-event] thinking_start\n[assistant-event] thinking_end\n[tool-call] start id=unknown\n[tool-call] delta {\"path\":\"tests/src/org.xerial.snappy/snappy-java/1.0.4.1/src/test/java/org_xerial_snappy/snappy_java/SnappyLoaderTest.java\",\"edits\":[{\"oldText\":\"    void compressesByteArraysAndStreamsUsingBundledNativeLoader() throws Exception {\",\"newText\":\"    void compressesByteArraysAndStreamsUsingNativeLoader() throws Exception {\"}]}\n[tool-call] end id=call_MAwx7aupnpBx9LL1AwAqPg2G|fc_0b01435cdb5be1c0016a3d6d79089081938bbd417197ca97e7 name=edit args={\"path\": \"tests/src/org.xerial.snappy/snappy-java/1.0.4.1/src/test/java/org_xerial_snappy/snappy_java/SnappyLoaderTest.java\", \"edits\": [{\"oldText\": \"    void compressesByteArraysAndStreamsUsingBundledNativeLoader() throws Exception {\", \"newText\": \"    void compressesByteArraysAndStreamsUsingNativeLoader() throws Exception {\"}]}\n[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0b01435cdb5be1c0016a3d6d76e48c8193b25d666c2e0c80ce\\\",\\\"type\\\":\\\"reasoning\\\",\\\"content\\\":[],\\\"encrypted_content\\\":\\\"gAAAAABqPW157v86JmliAt3v3eCVhNaAIp2LHCGneN2gGPGRAks93_iPW-pX2-RgwyfZB_OFJ_W3Pgr9Z9p99fyXds8JoHfpqnFOEap4jY87wrZDUe2Al_ePRvtgpeu1oBOKMvUwlWxX63DHe1pxpDN-E-lpT-EJhb3UTkVcWw3pKlnt3k7oSWJ3vsRMkbSHxsld-E_uCb7kobpbZMtvjWwnDi7JFd55J