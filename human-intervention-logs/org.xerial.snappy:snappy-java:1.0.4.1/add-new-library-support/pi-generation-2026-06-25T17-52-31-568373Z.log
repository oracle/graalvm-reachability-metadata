              + OSInfo.getNativeLibFolderPathForCurrentOS()\n                + \"/\"\n                + nativeLibraryName;\n        String extractedNativeLibraryName = \"snappy-\" + SnappyLoader.getVersion() + \"-\" + nativeLibraryName;\n        Path extractedNativeLibrary = nativeLibraryTempDir.resolve(extractedNativeLibraryName);\n\n        try (InputStream nativeLibrary = SnappyLoader.class.getResourceAsStream(nativeLibraryResourcePath)) {\n            assertThat(nativeLibrary)\n                    .as(\"bundled native library resource %s\", nativeLibraryResourcePath)\n                    .isNotNull();\n            Files.copy(nativeLibrary, extractedNativeLibrary);\n        }\n        if (!System.getProperty(\"os.name\").contains(\"Windows\")) {\n            assertThat(extractedNativeLibrary.toFile().setExecutable(true, false)).isTrue();\n        }\n    }\n"}]}
