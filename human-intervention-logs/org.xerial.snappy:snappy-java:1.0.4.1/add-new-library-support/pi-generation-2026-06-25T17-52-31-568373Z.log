[tool-exec] end id=call_XisvRVQgoTtwCSEEU60HTkr7|fc_0b01435cdb5be1c0016a3d6d3de43c8193b17097238f96f857 name=read status=success
  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  String snappyNativeLibraryName = System.mapLibraryName("snappyjava")
  String snappyNativeOs = translateSnappyOsName(System.getProperty("os.name"))
  String snappyNativeArch = System.getProperty("os.arch").replaceAll("\\W", "")
  String snappyNativeResource = "org/xerial/snappy/native/${snappyNativeOs}/${snappyNativeArch}/${snappyNativeLibraryName}"
  Provider<Directory> snappySystemLibraryDirectory = layout.buildDirectory.dir("snappy-system-library")
  
  String translateSnappyOsName(String osName) {
      if (osName.contains("Windows")) {
          return "Windows"
      }
      if (osName.contains("Mac")) {
          return "Mac"
      }
      if (osName.contains("Linux")) {
          return "Linux"
      }
      return osName.replaceAll("\\W", "")
  }
  
  TaskProvider<Copy> copySnappySystemLibrary = tasks.register("copySnappySystemLibrary", Copy) {
      from({ configurations.testRuntimeClasspath.collect { zipTree(it) } }) {
          include snappyNativeResource
          eachFile { FileCopyDetails details ->
              details.path = details.name
          }
      }
      into snappySystemLibraryDirectory
      includeEmptyDirs = false
  }
  
  dependencies {
      testImplementation "org.xerial.snappy:snappy-java:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.withType(Test).configureEach {
      jvmArgs '--add-opens=java.base/java.lang=ALL-UNNAMED'
  }
  
  tasks.register("systemLibraryTest", Test) {
      dependsOn copySnappySystemLibrary
      testClassesDirs = sourceSets.test.output.classesDirs
      classpath = sourceSets.test.runtimeClasspath
      useJUnitPlatform()
      systemProperty "snappy.loader.mode", "system"
      systemProperty "java.library.path", snappySystemLibraryDirectory.get().asFile.absolutePath
  }
  
  tasks.named("test") {
      dependsOn tasks.named("systemLibraryTest")
      systemProperty "snappy.loader.mode", "bundled"
  }
  
  tasks.withType(org.gradle.testing.jacoco.tasks.JacocoReport).configureEach {
      dependsOn tasks.named("systemLibraryTest")
      executionData(tasks.named("systemLibraryTest"))
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          all {
              buildArgs.add('--add-opens=java.base/java.lang=ALL-UNNAMED')
          }
      }
  }
