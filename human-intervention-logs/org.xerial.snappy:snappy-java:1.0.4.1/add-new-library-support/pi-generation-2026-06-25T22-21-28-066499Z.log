y-java system library loading\".getBytes(UTF_8);\n            byte[] compressed = Snappy.compress(input);\n\n            assertThat(Snappy.uncompress(compressed)).isEqualTo(input);\n            assertThat(SnappyLoader.isNativeLibraryLoaded()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassDefinition(error);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassDefinition(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1499, "output": 3644, "cacheRead": 48128, "cacheWrite": 0, "totalTokens": 53271, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782426284913, "responseId": "resp_0b44f9dc1e8c1183016a3daaad4f00819090154ecbaf72d510"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_DhjlHsh1Mfr0T9rRzsI3MJgS|fc_0b44f9dc1e8c1183016a3daadea7648190b7e66eca103840ed", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1324 bytes to tests/src/org.xerial.snappy/snappy-java/1.0.4.1/src/test/java/org_xerial_snappy/snappy_java/SnappyLoaderSystemLibraryTest.java"}], "isError": false, "timestamp": 1782426337350}]}
