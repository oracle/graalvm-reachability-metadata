org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.net.URI;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.mortbay.util.TypeUtil;\\n\\npublic class TypeUtilTest {\\n    @Test\\n    void resolvesCanonicalNamesForPrimitiveAndBoxedTypes() {\\n        assertThat(TypeUtil.fromName(\\\"boolean\\\")).isEqualTo(Boolean.TYPE);\\n        assertThat(TypeUtil.fromName(\\\"java.lang.Integer\\\")).isEqualTo(Integer.class);\\n        assertThat(TypeUtil.fromName(\\\"String\\\")).isEqualTo(String.class);\\n        assertThat(TypeUtil.fromName(null)).isEqualTo(Void.TYPE);\\n\\n        assertThat(TypeUtil.toName(Boolean.TYPE)).isEqualTo(\\\"boolean\\\");\\n        assertThat(TypeUtil.toName(Integer.class)).isEqualTo(\\\"java.lang.Integer\\\");\\n        assertThat(TypeUtil.toName(String.class)).isEqualTo(\\\"java.lang.String\\\");\\n    }\\n\\n    @Test\\n    void convertsStringsUsingRegisteredValueOfMethods() {\\n        assertThat(TypeUtil.valueOf(Boolean.TYPE, \\\"true\\\")).isEqualTo(Boolean.TRUE);\\n        assertThat(TypeUtil.valueOf(Byte.TYPE, \\\"12\\\")).isEqualTo((byte) 12);\\n        assertThat(TypeUtil.valueOf(Double.TYPE, \\\"12.5\\\")).isEqualTo(12.5d);\\n        assertThat(TypeUtil.valueOf(Float.TYPE, \\\"3.5\\\")).isEqualTo(3.5f);\\n        assertThat(TypeUtil.valueOf(Integer.TYPE, \\\"42\\\")).isEqualTo(42);\\n        assertThat(TypeUtil.valueOf(Long.TYPE, \\\"123456789\\\")).isEqualTo(123456789L);\\n        assertThat(TypeUtil.valueOf(Short.TYPE, \\\"7\\\")).isEqualTo((short) 7);\\n\\n        assertThat(TypeUtil.valueOf(\\\"java.lang.Boolean\\\", \\\"false\\\")).isEqualTo(Boolean.FALSE);\\n    }\\n\\n    @Test\\n    void convertsStringsUsingAStringConstructorWhenNoValueOfMethodIsRegistered() {\\n        final Object value = TypeUtil.valueOf(URI.class, \\\"https://example.com/jetty-util?version=6\\\");\\n\\n        assertThat(value)\\n                .isInstanceOf(URI.class)\\n                .hasToString(\\\"https://example.com/jetty-util?version=6\\\");\\n    }\\n\\n    @Test\\n    void convertsStringAndCharacterSpecialCases() {\\n        assertThat(TypeUtil.valueOf(String.class, \\\"jetty\\\")).isEqualTo(\\\"jetty\\\");\\n        assertThat(TypeUtil.valueOf(Character.TYPE, \\\"mortbay\\\")).isEqualTo('m');\\n        assertThat(TypeUtil.valueOf(Character.class, \\\"jetty\\\")).isEqualTo('j');\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_14\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/LoaderTest.java\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_14\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/LoaderTest.java\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_mortbay_jetty.jetty_util;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.net.URL;\\nimport java.util.Locale;\\nimport java.util.ResourceBundle;\\nimport java.util.concurrent.Callable;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.mortbay.util.Loader;\\n\\npublic class LoaderTest {\\n    private static final String RESOURCE_NAME = \\\"org_mortbay_jetty/jetty_util/loader-resource.txt\\\";\\n    private static final String CONTEXT_BUNDLE = \\\"org_mortbay_jetty.jetty_util.loader_context\\\";\\n    private static final String SUPPLIED_BUNDLE = \\\"org_mortbay_jetty.jetty_util.loader_supplied\\\";\\n    private static final String DEFAULT_BUNDLE = \\\"org_mortbay_jetty.jetty_util.loader_default\\\";\\n\\n    @Test\\n    void locatesResourceWithContextClassLoader() throws Exception {\\n        final URL url = withContextClassLoader(\\n                LoaderTest.class.getClassLoader(),\\n                () -> Loader.getResource(null, RESOURCE_NAME, false));\\n\\n        assertThat(url).isNotNull();\\n    }\\n\\n    @Test\\n    void locatesResourceWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {\\n        final URL url = withContextClassLoader(\\n                new EmptyClassLoader(),\\n                () -> Loader.getResource(LoaderTest.class, RESOURCE_NAME, false));\\n\\n        assertThat(url).isNotNull();\\n    }\\n\\n    @Test\\n    void fallsBackToSystemResourceLookupWhenOtherLoadersMiss() throws Exception {\\n        final URL url = withContextClassLoader(\\n                new EmptyClassLoader(),\\n                () -> Loader.getResource(null, \\\"missing/mortbay-loader-resource.txt\\\", false));\\n\\n        assertThat(url).isNull();\\n    }\\n\\n    @Test\\n    void loadsClassWithContextClassLoader() throws Exception {\\n        final Class<?> type = withContextClassLoader(\\n                LoaderTest.class.getClassLoader(),\\n                () -> Loader.loadClass(null, String.class.getName(), false));\\n\\n        assertThat(type).isSameAs(String.class);\\n    }\\n\\n    @Test\\n    void loadsClassWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {\\n        final Class<?> type = withContextClassLoader(\\n                new EmptyClassLoader(),\\n                () -> Loader.loadClass(LoaderTest.class, LoaderTest.class.getName(), false));\\n\\n        assertThat(type).isSameAs(LoaderTest.class);\\n    }\\n\\n    @Test\\n    void fallsBackToClassForNameWhenNoClassLoaderIsAvailable() throws Exception {\\n        final Class<?> type = withContextClassLoader(\\n                null,\\n                () -> Loader.loadClass(null, String.class.getName(), false));\\n\\n        assertThat(type).isSameAs(String.class);\\n    }\\n\\n    @Test\\n    void loadsResourceBundleWithContextClassLoader() throws Exception {\\n        final ResourceBundle bundle = withContextClassLoader(\\n                LoaderTest.class.getClassLoader(),\\n                () -> Loader.getResourceBundle(null, CONTEXT_BUNDLE, false, Locale.ROOT));\\n\\n        assertThat(bundle.getString(\\\"message\\\")).isEqualTo(\\\"context\\\");\\n    }\\n\\n    @Test\\n    void loadsResourceBundleWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {\\n        final ResourceBundle bundle = withContextClassLoader(\\n                new EmptyClassLoader(),\\n                () -> Loader.getResourceBundle(LoaderTest.class, SUPPLIED_BUNDLE, false, Locale.ROOT));\\n\\n        assertThat(bundle.getString(\\\"message\\\")).isEqualTo(\\\"supplied\\\");\\n    }\\n\\n    @Test\\n    void fallsBackToDefaultResourceBundleLookupWhenNoClassLoaderIsAvailable() throws Exception {\\n        final ResourceBundle bundle = withContextClassLoader(\\n                null,\\n                () -> Loader.getResourceBundle(null, DEFAULT_BUNDLE, false, Locale.ROOT));\\n\\n        assertThat(bundle.getString(\\\"message\\\")).isEqualTo(\\\"default\\\");\\n    }\\n\\n    private static <T> T withContextClassLoader(ClassLoader classLoader, Callable<T> callable) throws Exception {\\n        final Thread thread = Thread.currentThread();\\n        final ClassLoader originalClassLoader = thread.getContextClassLoader();\\n        thread.setContextClassLoader(classLoader);\\n        try {\\n            return callable.call();\\n        } finally {\\n            thread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    private static final class EmptyClassLoader extends ClassLoader {\\n        EmptyClassLoader() {\\n            super(null);\\n        }\\n\\n        @Override\\n        public URL getResource(String name) {\\n            return null;\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String