  package org_mortbay_jetty.jetty_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.util.IntrospectionUtil;
  
  public class IntrospectionUtilTest {
      @Test
      void findsDeclaredMethodAndRecognizesJavaBeanSetter() throws Exception {
          final Method setter = IntrospectionUtil.findMethod(
                  ChildBean.class,
                  "setCount",
                  new Class[] { Integer.TYPE },
                  false,
                  true);
  
          assertThat(setter.getDeclaringClass()).isEqualTo(ChildBean.class);
          assertThat(setter.getParameterTypes()).containsExactly(Integer.TYPE);
          assertThat(IntrospectionUtil.isJavaBeanCompliantSetter(setter)).isTrue();
      }
  
      @Test
      void findsInheritedMethodWithAssignableArgument() throws Exception {
          final Method method = IntrospectionUtil.findMethod(
                  ChildBean.class,
                  "describe",
                  new Class[] { Integer.class },
                  true,
                  false);
  
          assertThat(method.getDeclaringClass()).isEqualTo(ParentBean.class);
          assertThat(method.getParameterTypes()).containsExactly(Number.class);
      }
  
      @Test
      void findsDeclaredAndInheritedFields() throws Exception {
          final Field localField = IntrospectionUtil.findField(
                  ChildBean.class,
                  "localText",
                  String.class,
                  false,
                  true);
          final Field inheritedField = IntrospectionUtil.findField(
                  ChildBean.class,
                  "inheritedText",
                  CharSequence.class,
                  true,
                  true);
  
          assertThat(localField.getDeclaringClass()).isEqualTo(ChildBean.class);
          assertThat(localField.getType()).isEqualTo(String.class);
          assertThat(inheritedField.getDeclaringClass()).isEqualTo(ParentBean.class);
          assertThat(inheritedField.getType()).isEqualTo(CharSequence.class);
      }
  
      @Test
      void detectsMatchingMethodSignaturesAndFieldNamesOnAnotherClass() throws Exception {
          final Method setter = IntrospectionUtil.findMethod(
                  ChildBean.class,
                  "setCount",
                  new Class[] { Integer.TYPE },
                  false,
                  true);
          final Field localField = IntrospectionUtil.findField(
                  ChildBean.class,
                  "localText",
                  String.class,
                  false,
                  true);
  
          assertThat(IntrospectionUtil.containsSameMethodSignature(setter, MirrorBean.class, true)).isTrue();
          assertThat(IntrospectionUtil.containsSameFieldName(localField, MirrorBean.class, true)).isTrue();
      }
  
      private static class ParentBean {
          protected CharSequence inheritedText;
  
          public String describe(Number value) {
              return "number=" + value;
          }
      }
  
      private static class ChildBean extends ParentBean {
          private String localText;
  
          public void setCount(int count) {
              localText = String.valueOf(count);
          }
      }
  
      private static class MirrorBean {
          private Object localText;
  
          public void setCount(int count) {
              localText = count;
          }
      }
  }
