  package org_mortbay_jetty.jetty_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Field;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.util.ajax.JSON;
  import org.mortbay.util.ajax.JSONObjectConvertor;
  
  public class JSONObjectConvertorTest {
      @Test
      void toJSONDiscoversAndInvokesPublicGetterMethods() throws Exception {
          clearCompilerGeneratedObjectClassCache();
          final JSON json = new JSON();
          json.addConvertor(SampleObject.class, new JSONObjectConvertor(false, new String[] {"secret"}));
          final SampleObject object = new SampleObject("Ada", 42, true, "hidden");
  
          final String serialized = json.toJSON(object);
          final Map parsed = (Map) json.fromJSON(serialized);
  
          assertThat(parsed).containsEntry("name", object.getName());
          assertThat(parsed).containsEntry("count", Long.valueOf(object.getCount()));
          assertThat(parsed).containsEntry("active", Boolean.TRUE);
          assertThat(parsed).doesNotContainKey("secret");
      }
  
      private static void clearCompilerGeneratedObjectClassCache() throws Exception {
          final Field field = JSONObjectConvertor.class.getDeclaredField("class$java$lang$Object");
          field.setAccessible(true);
          field.set(null, null);
      }
  
      public static class SampleObject {
          private final String name;
          private final int count;
          private final boolean active;
          private final String secret;
  
          public SampleObject(final String name, final int count, final boolean active, final String secret) {
              this.name = name;
              this.count = count;
              this.active = active;
              this.secret = secret;
          }
  
          public String getName() {
              return name;
          }
  
          public int getCount() {
              return count;
          }
  
          public boolean isActive() {
              return active;
          }
  
          public String getSecret() {
              return secret;
          }
      }
  }
