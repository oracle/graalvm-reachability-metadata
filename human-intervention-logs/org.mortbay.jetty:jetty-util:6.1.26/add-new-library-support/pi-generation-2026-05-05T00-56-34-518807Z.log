;\n        json.addConvertor(SampleObject.class, new JSONObjectConvertor(true, new String[] {\"secret\"}));\n        final SampleObject object = new SampleObject(\"Ada\", 42, true, \"hidden\");\n\n        final String serialized = json.toJSON(object);\n        final Map parsed = (Map) json.fromJSON(serialized);\n\n        assertThat(parsed).containsEntry(\"class\", SampleObject.class.getName());\n        assertThat(parsed).containsEntry(\"name\", object.getName());\n        assertThat(parsed).containsEntry(\"count\", Long.valueOf(object.getCount()));\n        assertThat(parsed).containsEntry(\"active\", Boolean.TRUE);\n        assertThat(parsed).doesNotContainKey(\"secret\");\n    }\n\n    public static class SampleObject {\n        private final String name;\n        private final int count;\n        private final boolean active;\n        private final String secret;\n\n        public SampleObject(final String name, final int count, final boolean active, final String secret) {\n            this.name = name;\n            this.count = count;\n            this.active = active;\n            this.secret = secret;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public boolean isActive() {\n            return active;\n        }\n\n        public String getSecret() {\n            return secret;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1041, "output": 999, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 19960, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777942572431, "responseId": "resp_0a040482419b381b0169f9402cdf7c8196b519a3b1c5ba652a"}}
