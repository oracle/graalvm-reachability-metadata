  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_mortbay_jetty.jetty_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.util.ajax.JSON;
  import org.mortbay.util.ajax.JSONEnumConvertor;
  
  public class JSONEnumConvertorTest {
      @Test
      void fromJSONConvertsClassAndValueFieldsToEnumConstant() {
          final JSONEnumConvertor convertor = new JSONEnumConvertor(true);
          final Map values = new LinkedHashMap();
          values.put("class", SampleState.class.getName());
          values.put("value", SampleState.STARTED.name());
  
          final Object converted = convertor.fromJSON(values);
  
          assertThat(converted).isEqualTo(SampleState.STARTED);
      }
  
      @Test
      void jsonRoundTripUsesEnumClassAndValueFields() {
          final JSON json = new JSON();
          json.addConvertor(SampleState.class, new JSONEnumConvertor(true));
  
          final String serialized = json.toJSON(SampleState.STOPPED);
          final Object parsed = json.fromJSON(serialized);
  
          assertThat(serialized).contains("\"class\":\"" + SampleState.class.getName() + "\"");
          assertThat(serialized).contains("\"value\":\"" + SampleState.STOPPED.name() + "\"");
          assertThat(parsed).isEqualTo(SampleState.STOPPED);
      }
  
      @Test
      void fromJSONIsRejectedWhenConvertorIsWriteOnly() {
          final JSONEnumConvertor convertor = new JSONEnumConvertor(false);
  
          assertThatThrownBy(() -> convertor.fromJSON(new LinkedHashMap()))
                  .isInstanceOf(UnsupportedOperationException.class);
      }
  
      public enum SampleState {
          STARTED,
          STOPPED
      }
  }
