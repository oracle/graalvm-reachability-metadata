  package org_mortbay_jetty.jetty_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.URL;
  import java.util.Locale;
  import java.util.ResourceBundle;
  import java.util.concurrent.Callable;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.util.Loader;
  
  public class LoaderTest {
      private static final String RESOURCE_NAME = "org_mortbay_jetty/jetty_util/loader-resource.txt";
      private static final String CONTEXT_BUNDLE = "org_mortbay_jetty.jetty_util.loader_context";
      private static final String SUPPLIED_BUNDLE = "org_mortbay_jetty.jetty_util.loader_supplied";
      private static final String DEFAULT_BUNDLE = "org_mortbay_jetty.jetty_util.loader_default";
  
      @Test
      void locatesResourceWithContextClassLoader() throws Exception {
          final URL url = withContextClassLoader(
                  LoaderTest.class.getClassLoader(),
                  () -> Loader.getResource(null, RESOURCE_NAME, false));
  
          assertThat(url).isNotNull();
      }
  
      @Test
      void locatesResourceWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {
          final URL url = withContextClassLoader(
                  new EmptyClassLoader(),
                  () -> Loader.getResource(LoaderTest.class, RESOURCE_NAME, false));
  
          assertThat(url).isNotNull();
      }
  
      @Test
      void fallsBackToSystemResourceLookupWhenOtherLoadersMiss() throws Exception {
          final URL url = withContextClassLoader(
                  new EmptyClassLoader(),
                  () -> Loader.getResource(null, "missing/mortbay-loader-resource.txt", false));
  
          assertThat(url).isNull();
      }
  
      @Test
      void loadsClassWithContextClassLoader() throws Exception {
          final Class<?> type = withContextClassLoader(
                  LoaderTest.class.getClassLoader(),
                  () -> Loader.loadClass(null, String.class.getName(), false));
  
          assertThat(type).isSameAs(String.class);
      }
  
      @Test
      void loadsClassWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {
          final Class<?> type = withContextClassLoader(
                  new EmptyClassLoader(),
                  () -> Loader.loadClass(LoaderTest.class, LoaderTest.class.getName(), false));
  
          assertThat(type).isSameAs(LoaderTest.class);
      }
  
      @Test
      void fallsBackToClassForNameWhenNoClassLoaderIsAvailable() throws Exception {
          final Class<?> type = withContextClassLoader(
                  null,
                  () -> Loader.loadClass(null, String.class.getName(), false));
  
          assertThat(type).isSameAs(String.class);
      }
  
      @Test
      void loadsResourceBundleWithContextClassLoader() throws Exception {
          final ResourceBundle bundle = withContextClassLoader(
                  LoaderTest.class.getClassLoader(),
                  () -> Loader.getResourceBundle(null, CONTEXT_BUNDLE, false, Locale.ROOT));
  
          assertThat(bundle.getString("message")).isEqualTo("context");
      }
  
      @Test
      void loadsResourceBundleWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {
          final ResourceBundle bundle = withContextClassLoader(
                  new EmptyClassLoader(),
                  () -> Loader.getResourceBundle(LoaderTest.class, SUPPLIED_BUNDLE, false, Locale.ROOT));
  
          assertThat(bundle.getString("message")).isEqualTo("supplied");
      }
  
      @Test
      void fallsBackToDefaultResourceBundleLookupWhenNoClassLoaderIsAvailable() throws Exception {
          final ResourceBundle bundle = withContextClassLoader(
                  null,
                  () -> Loader.getResourceBundle(null, DEFAULT_BUNDLE, false, Locale.ROOT));
  
          assertThat(bundle.getString("message")).isEqualTo("default");
      }
  
      private static <T> T withContextClassLoader(ClassLoader classLoader, Callable<T> callable) throws Exception {
          final Thread thread = Thread.currentThread();
          final ClassLoader originalClassLoader = thread.getContextClassLoader();
          thread.setContextClassLoader(classLoader);
          try {
              return callable.call();
          } finally {
              thread.setContextClassLoader(originalClassLoader);
          }
      }
  
      private static final class EmptyClassLoader extends ClassLoader {
          EmptyClassLoader() {
              super(null);
          }
  
          @Override
          public URL getResource(String name) {
              return null;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              throw new ClassNotFoundException(name);
          }
      }
  }
