[tool-call] delta {"path":"tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/LogTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty_util;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.log.Log;\nimport org.mortbay.log.Logger;\n\npublic class LogTest {\n    @Test\n    void warnsNestedExceptionsExposedByLegacyAccessors() {\n        System.setProperty(\"org.mortbay.log.class\", \"org.mortbay.log.StdErrLog\");\n        final Logger previousLogger = Log.getLog();\n        final RecordingLogger logger = new RecordingLogger();\n        Log.setLog(logger);\n\n        try {\n            final Throwable rootCause = new IllegalArgumentException(\"root cause\");\n            final LegacyNestedException exception = new LegacyNestedException(\"wrapper\", rootCause);\n\n            Log.warn(\"top level\", exception);\n\n            assertThat(logger.warnings)\n                    .extracting(LoggedWarning::message)\n                    .contains(\"top level\", \"Nested in \" + exception + \":\");\n            assertThat(logger.warnings)\n                    .extracting(LoggedWarning::throwable)\n                    .contains(exception, rootCause);\n        } finally {\n            Log.setLog(previousLogger);\n            System.clearProperty(\"org.mortbay.log.class\");\n        }\n    }\n\n    public static class LegacyNestedException extends Exception {\n        private final Throwable rootCause;\n\n        LegacyNestedException(String message, Throwable rootCause) {\n            super(message);\n            this.rootCause = rootCause;\n        }\n\n        public Throwable getRootCause() {\n            return rootCause;\n        }\n    }\n\n    private static final class RecordingLogger implements Logger {\n        private final List<LoggedWarning> warnings = new ArrayList<>();\n\n        @Override\n        public boolean isDebugEnabled() {\n            return false;\n        }\n\n        @Override\n        public void setDebugEnabled(boolean enabled) {\n        }\n\n        @Override\n        public void info(String msg, Object arg0, Object arg1) {\n        }\n\n        @Override\n        public void debug(String msg, Throwable th) {\n        }\n\n        @Override\n        public void debug(String msg, Object arg0, Object arg1) {\n        }\n\n        @Override\n        public void warn(String msg, Object arg0, Object arg1) {\n            warnings.add(new LoggedWarning(msg, null));\n        }\n\n        @Override\n        public void warn(String msg, Throwable th) {\n            warnings.add(new LoggedWarning(msg, th));\n        }\n\n        @Override\n        public Logger getLogger(String name) {\n            return this;\n        }\n    }\n\n    private static final class LoggedWarning {\n        private final String message;\n        private final Throwable throwable;\n\n        LoggedWarning(String message, Throwable throwable) {\n            this.message = message;\n            this.throwable = throwable;\n        }\n\n        String message() {\n            return message;\n        }\n\n        Throwable throwable() {\n            return throwable;\n        }\n    }\n}\n"}
