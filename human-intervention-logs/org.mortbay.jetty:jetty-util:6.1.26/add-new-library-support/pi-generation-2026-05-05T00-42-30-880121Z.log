  package org_mortbay_jetty.jetty_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.log.Log;
  import org.mortbay.log.Logger;
  
  public class LogTest {
      @Test
      void warnsNestedExceptionsExposedByLegacyAccessors() {
          System.setProperty("org.mortbay.log.class", "org.mortbay.log.StdErrLog");
          final Logger previousLogger = Log.getLog();
          final RecordingLogger logger = new RecordingLogger();
          Log.setLog(logger);
  
          try {
              final Throwable rootCause = new IllegalArgumentException("root cause");
              final LegacyNestedException exception = new LegacyNestedException("wrapper", rootCause);
  
              Log.warn("top level", exception);
  
              assertThat(logger.warnings)
                      .extracting(LoggedWarning::message)
                      .contains("top level", "Nested in " + exception + ":");
              assertThat(logger.warnings)
                      .extracting(LoggedWarning::throwable)
                      .contains(exception, rootCause);
          } finally {
              Log.setLog(previousLogger);
              System.clearProperty("org.mortbay.log.class");
          }
      }
  
      public static class LegacyNestedException extends Exception {
          private final Throwable rootCause;
  
          LegacyNestedException(String message, Throwable rootCause) {
              super(message);
              this.rootCause = rootCause;
          }
  
          public Throwable getRootCause() {
              return rootCause;
          }
      }
  
      private static final class RecordingLogger implements Logger {
          private final List<LoggedWarning> warnings = new ArrayList<>();
  
          @Override
          public boolean isDebugEnabled() {
              return false;
          }
  
          @Override
          public void setDebugEnabled(boolean enabled) {
          }
  
          @Override
