\n\n        final String serialized = json.toJSON(SampleState.STOPPED);\n        final Object parsed = json.fromJSON(serialized);\n\n        assertThat(serialized).contains(\"\\\"class\\\":\\\"org_mortbay_jetty.jetty_util.JSONEnumConvertorTest$SampleState\\\"\");\n        assertThat(serialized).contains(\"\\\"value\\\":\\\"STOPPED\\\"\");\n        assertThat(parsed).isEqualTo(SampleState.STOPPED);\n    }\n\n    @Test\n    void fromJSONIsRejectedWhenConvertorIsWriteOnly() {\n        final JSONEnumConvertor convertor = new JSONEnumConvertor(false);\n\n        assertThatThrownBy(() -> convertor.fromJSON(new LinkedHashMap()))\n                .isInstanceOf(UnsupportedOperationException.class);\n    }\n\n    public enum SampleState {\n        STARTED,\n        STOPPED\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3013, "output": 1090, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 26119, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777942294140, "responseId": "resp_09eb742cad3f53b90169f93f1697cc81a29bac15e592a972c1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_jq8aF2Ewa6dC9pC52990kUvh|fc_09eb742cad3f53b90169f93f1dfe2081a2a51cfd3f9858f07c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1937 bytes to tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/JSONEnumConvertorTest.java"}], "isError": false, "timestamp": 1777942305214}]}
