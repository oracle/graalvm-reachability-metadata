[tool-call] delta {"path":"tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/JSONEnumConvertorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty_util;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.util.LinkedHashMap;\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.util.ajax.JSON;\nimport org.mortbay.util.ajax.JSONEnumConvertor;\n\npublic class JSONEnumConvertorTest {\n    @Test\n    void fromJSONConvertsClassAndValueFieldsToEnumConstant() {\n        final JSONEnumConvertor convertor = new JSONEnumConvertor(true);\n        final Map values = new LinkedHashMap();\n        values.put(\"class\", SampleState.class.getName());\n        values.put(\"value\", SampleState.STARTED.name());\n\n        final Object converted = convertor.fromJSON(values);\n\n        assertThat(converted).isEqualTo(SampleState.STARTED);\n    }\n\n    @Test\n    void jsonRoundTripUsesEnumClassAndValueFields() {\n        final JSON json = new JSON();\n        json.addConvertor(SampleState.class, new JSONEnumConvertor(true));\n\n        final String serialized = json.toJSON(SampleState.STOPPED);\n        final Object parsed = json.fromJSON(serialized);\n\n        assertThat(serialized).contains(\"\\\"class\\\":\\\"org_mortbay_jetty.jetty_util.JSONEnumConvertorTest$SampleState\\\"\");\n        assertThat(serialized).contains(\"\\\"value\\\":\\\"STOPPED\\\"\");\n        assertThat(parsed).isEqualTo(SampleState.STOPPED);\n    }\n\n    @Test\n    void fromJSONIsRejectedWhenConvertorIsWriteOnly() {\n        final JSONEnumConvertor convertor = new JSONEnumConvertor(false);\n\n        assertThatThrownBy(() -> convertor.fromJSON(new LinkedHashMap()))\n                .isInstanceOf(UnsupportedOperationException.class);\n    }\n\n    public enum SampleState {\n        STARTED,\n        STOPPED\n    }\n}\n"}
