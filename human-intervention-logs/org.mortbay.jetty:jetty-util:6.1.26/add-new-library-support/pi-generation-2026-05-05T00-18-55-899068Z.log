  package org_mortbay_jetty.jetty_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.URI;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.util.TypeUtil;
  
  public class TypeUtilTest {
      @Test
      void resolvesCanonicalNamesForPrimitiveAndBoxedTypes() {
          assertThat(TypeUtil.fromName("boolean")).isEqualTo(Boolean.TYPE);
          assertThat(TypeUtil.fromName("java.lang.Integer")).isEqualTo(Integer.class);
          assertThat(TypeUtil.fromName("String")).isEqualTo(String.class);
          assertThat(TypeUtil.fromName(null)).isEqualTo(Void.TYPE);
  
          assertThat(TypeUtil.toName(Boolean.TYPE)).isEqualTo("boolean");
          assertThat(TypeUtil.toName(Integer.class)).isEqualTo("java.lang.Integer");
          assertThat(TypeUtil.toName(String.class)).isEqualTo("java.lang.String");
      }
  
      @Test
      void convertsStringsUsingRegisteredValueOfMethods() {
          assertThat(TypeUtil.valueOf(Boolean.TYPE, "true")).isEqualTo(Boolean.TRUE);
          assertThat(TypeUtil.valueOf(Byte.TYPE, "12")).isEqualTo((byte) 12);
          assertThat(TypeUtil.valueOf(Double.TYPE, "12.5")).isEqualTo(12.5d);
          assertThat(TypeUtil.valueOf(Float.TYPE, "3.5")).isEqualTo(3.5f);
          assertThat(TypeUtil.valueOf(Integer.TYPE, "42")).isEqualTo(42);
          assertThat(TypeUtil.valueOf(Long.TYPE, "123456789")).isEqualTo(123456789L);
          assertThat(TypeUtil.valueOf(Short.TYPE, "7")).isEqualTo((short) 7);
  
          assertThat(TypeUtil.valueOf("java.lang.Boolean", "false")).isEqualTo(Boolean.FALSE);
      }
  
      @Test
      void convertsStringsUsingAStringConstructorWhenNoValueOfMethodIsRegistered() {
          final Object value = TypeUtil.valueOf(URI.class, "https://example.com/jetty-util?version=6");
  
          assertThat(value)
                  .isInstanceOf(URI.class)
                  .hasToString("https://example.com/jetty-util?version=6");
      }
  
      @Test
      void convertsStringAndCharacterSpecialCases() {
          assertThat(TypeUtil.valueOf(String.class, "jetty")).isEqualTo("jetty");
          assertThat(TypeUtil.valueOf(Character.TYPE, "mortbay")).isEqualTo('m');
          assertThat(TypeUtil.valueOf(Character.class, "jetty")).isEqualTo('j');
      }
  }
