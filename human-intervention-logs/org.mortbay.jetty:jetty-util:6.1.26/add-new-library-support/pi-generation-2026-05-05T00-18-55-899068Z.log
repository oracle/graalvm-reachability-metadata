[tool-call] delta {"path":"tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/LoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty_util;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.net.URL;\nimport java.util.Locale;\nimport java.util.ResourceBundle;\nimport java.util.concurrent.Callable;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.util.Loader;\n\npublic class LoaderTest {\n    private static final String RESOURCE_NAME = \"org_mortbay_jetty/jetty_util/loader-resource.txt\";\n    private static final String CONTEXT_BUNDLE = \"org_mortbay_jetty.jetty_util.loader_context\";\n    private static final String SUPPLIED_BUNDLE = \"org_mortbay_jetty.jetty_util.loader_supplied\";\n    private static final String DEFAULT_BUNDLE = \"org_mortbay_jetty.jetty_util.loader_default\";\n\n    @Test\n    void locatesResourceWithContextClassLoader() throws Exception {\n        final URL url = withContextClassLoader(\n                LoaderTest.class.getClassLoader(),\n                () -> Loader.getResource(null, RESOURCE_NAME, false));\n\n        assertThat(url).isNotNull();\n    }\n\n    @Test\n    void locatesResourceWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {\n        final URL url = withContextClassLoader(\n                new EmptyClassLoader(),\n                () -> Loader.getResource(LoaderTest.class, RESOURCE_NAME, false));\n\n        assertThat(url).isNotNull();\n    }\n\n    @Test\n    void fallsBackToSystemResourceLookupWhenOtherLoadersMiss() throws Exception {\n        final URL url = withContextClassLoader(\n                new EmptyClassLoader(),\n                () -> Loader.getResource(null, \"missing/mortbay-loader-resource.txt\", false));\n\n        assertThat(url).isNull();\n    }\n\n    @Test\n    void loadsClassWithContextClassLoader() throws Exception {\n        final Class<?> type = withContextClassLoader(\n                LoaderTest.class.getClassLoader(),\n                () -> Loader.loadClass(null, String.class.getName(), false));\n\n        assertThat(type).isSameAs(String.class);\n    }\n\n    @Test\n    void loadsClassWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {\n        final Class<?> type = withContextClassLoader(\n                new EmptyClassLoader(),\n                () -> Loader.loadClass(LoaderTest.class, LoaderTest.class.getName(), false));\n\n        assertThat(type).isSameAs(LoaderTest.class);\n    }\n\n    @Test\n    void fallsBackToClassForNameWhenNoClassLoaderIsAvailable() throws Exception {\n        final Class<?> type = withContextClassLoader(\n                null,\n                () -> Loader.loadClass(null, String.class.getName(), false));\n\n        assertThat(type).isSameAs(String.class);\n    }\n\n    @Test\n    void loadsResourceBundleWithContextClassLoader() throws Exception {\n        final ResourceBundle bundle = withContextClassLoader(\n                LoaderTest.class.getClassLoader(),\n                () -> Loader.getResourceBundle(null, CONTEXT_BUNDLE, false, Locale.ROOT));\n\n        assertThat(bundle.getString(\"message\")).isEqualTo(\"context\");\n    }\n\n    @Test\n    void loadsResourceBundleWithSuppliedClassLoaderWhenContextClassLoaderMisses() throws Exception {\n        final ResourceBundle bundle = withContextClassLoader(\n                new EmptyClassLoader(),\n                () -> Loader.getResourceBundle(LoaderTest.class, SUPPLIED_BUNDLE, false, Locale.ROOT));\n\n        assertThat(bundle.getString(\"message\")).isEqualTo(\"supplied\");\n    }\n\n    @Test\n    void fallsBackToDefaultResourceBundleLookupWhenNoClassLoaderIsAvailable() throws Exception {\n        final ResourceBundle bundle = withContextClassLoader(\n                null,\n                () -> Loader.getResourceBundle(null, DEFAULT_BUNDLE, false, Locale.ROOT));\n\n        assertThat(bundle.getString(\"message\")).isEqualTo(\"default\");\n    }\n\n    private static <T> T withContextClassLoader(ClassLoader classLoader, Callable<T> callable) throws Exception {\n        final Thread thread = Thread.currentThread();\n        final ClassLoader originalClassLoader = thread.getContextClassLoader();\n        thread.setContextClassLoader(classLoader);\n        try {\n            return callable.call();\n        } finally {\n            thread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static final class EmptyClassLoader extends ClassLoader {\n        EmptyClassLoader() {\n            super(null);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            return null;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name);\n        }\n    }\n}\n"}
