                {
                    for (int i=0; i<LazyList.size(l); i++)              
                    {
                        Object e=LazyList.get(l,i);
                        if (e!=null)
                        {
                            if (values.length()>0)
                                values.append(',');
                            values.append(e.toString());
                        }
                    }   
                    return values.toString();
                }
          }
      }
      
