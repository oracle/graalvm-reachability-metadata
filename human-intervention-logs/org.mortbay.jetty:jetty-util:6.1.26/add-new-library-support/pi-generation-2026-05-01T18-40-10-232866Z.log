      {
          super((map.size()*3)/2);
          putAll(map);
      }
      
      /* ------------------------------------------------------------ */
      /** Get multiple values.
       * Single valued entries are converted to singleton lists.
       * @param name The entry key. 
       * @return Unmodifieable List of values.
       */
      public List getValues(Object name)
      {
