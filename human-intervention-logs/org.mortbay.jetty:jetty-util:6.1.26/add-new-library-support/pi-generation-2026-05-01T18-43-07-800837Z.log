          assertThat(((UrlEncoded) converted).getString("enabled")).isEqualTo("true");
      }
  
      @Test
      void returnsNullWhenNoStringConversionIsAvailable() {
          assertThat(TypeUtil.valueOf(Object.class, "ignored")).isNull();
      }
  }
