[tool-call] delta {"path":"tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/TypeUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty_util;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.util.TypeUtil;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypeUtilTest {\n    @Test\n    void resolvesPrimitiveAndWrapperNames() {\n        assertThat(TypeUtil.fromName(\"int\")).isSameAs(Integer.TYPE);\n        assertThat(TypeUtil.fromName(\"java.lang.Integer\")).isSameAs(Integer.class);\n        assertThat(TypeUtil.fromName(\"String\")).isSameAs(String.class);\n\n        assertThat(TypeUtil.toName(Integer.TYPE)).isEqualTo(\"int\");\n        assertThat(TypeUtil.toName(Integer.class)).isEqualTo(\"java.lang.Integer\");\n        assertThat(TypeUtil.toName(String.class)).isEqualTo(\"java.lang.String\");\n    }\n\n    @Test\n    void convertsValuesWithRegisteredValueOfMethods() {\n        assertThat(TypeUtil.valueOf(Boolean.TYPE, \"true\")).isEqualTo(Boolean.TRUE);\n        assertThat(TypeUtil.valueOf(Byte.TYPE, \"7\")).isEqualTo(Byte.valueOf((byte) 7));\n        assertThat(TypeUtil.valueOf(Double.TYPE, \"3.5\")).isEqualTo(Double.valueOf(\"3.5\"));\n        assertThat(TypeUtil.valueOf(Float.TYPE, \"2.25\")).isEqualTo(Float.valueOf(\"2.25\"));\n        assertThat(TypeUtil.valueOf(Integer.TYPE, \"42\")).isEqualTo(Integer.valueOf(42));\n        assertThat(TypeUtil.valueOf(Long.TYPE, \"99\")).isEqualTo(Long.valueOf(99L));\n        assertThat(TypeUtil.valueOf(Short.TYPE, \"12\")).isEqualTo(Short.valueOf((short) 12));\n\n        assertThat(TypeUtil.valueOf(\"Integer\", \"101\")).isEqualTo(Integer.valueOf(101));\n    }\n\n    @Test\n    void convertsStringsCharactersAndStringConstructableTypes() {\n        assertThat(TypeUtil.valueOf(String.class, \"unchanged\")).isEqualTo(\"unchanged\");\n        assertThat(TypeUtil.valueOf(Character.TYPE, \"jetty\")).isEqualTo(Character.valueOf('j'));\n        assertThat(TypeUtil.valueOf(Character.class, \"util\")).isEqualTo(Character.valueOf('u'));\n\n        StringConstructable constructed = (StringConstructable) TypeUtil.valueOf(StringConstructable.class, \"payload\");\n        assertThat(constructed.value()).isEqualTo(\"payload\");\n    }\n\n    public static class StringConstructable {\n        private final String value;\n\n        public StringConstructable(String value) {\n            this.value = value;\n        }\n\n        String value() {\n            return value;\n        }\n    }\n}\n"}
[tool-call] end id=call_23Fzaw4b9Jugl9MhOjtNG2Sq|fc_05e80ae20a23ca3d0169f780fd6f2081a2b96f856a8c399a5b name=write args={"path": "tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/TypeUtilTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty_util;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.util.TypeUtil;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypeUtilTest {\n    @Test\n    void resolvesPrimitiveAndWrapperNames() {\n        assertThat(TypeUtil.fromName(\"int\")).isSameAs(Integer.TYPE);\n        assertThat(TypeUtil.fromName(\"java.lang.Integer\")).isSameAs(Integer.class);\n        assertThat(TypeUtil.fromName(\"String\")).isSameAs(String.class);\n\n        assertThat(TypeUtil.toName(Integer.TYPE)).isEqualTo(\"int\");\n        assertThat(TypeUtil.toName(Integer.class)).isEqualTo(\"java.lang.Integer\");\n        assertThat(TypeUtil.toName(String.class)).isEqualTo(\"java.lang.String\");\n    }\n\n    @Test\n    void convertsValuesWithRegisteredValueOfMethods() {\n        assertThat(TypeUtil.valueOf(Boolean.TYPE, \"true\")).isEqualTo(Boolean.TRUE);\n        assertThat(TypeUtil.valueOf(Byte.TYPE, \"7\")).isEqualTo(Byte.valueOf((byte) 7));\n        assertThat(TypeUtil.valueOf(Double.TYPE, \"3.5\")).isEqualTo(Double.valueOf(\"3.5\"));\n        assertThat(TypeUtil.valueOf(Float.TYPE, \"2.25\")).isEqualTo(Float.valueOf(\"2.25\"));\n        assertThat(TypeUtil.valueOf(Integer.TYPE, \"42\")).isEqualTo(Integer.valueOf(42));\n        assertThat(TypeUtil.valueOf(Long.TYPE, \"99\")).isEqualTo(Long.valueOf(99L));\n        assertThat(TypeUtil.valueOf(Short.TYPE, \"12\")).isEqualTo(Short.valueOf((short) 12));\n\n        assertThat(TypeUtil.valueOf(\"Integer\", \"101\")).isEqualTo(Integer.v