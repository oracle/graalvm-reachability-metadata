  package org_mortbay_jetty.jetty_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.util.ajax.JSONPojoConvertor;
  
  public class JSONPojoConvertorInnerSetterTest {
      @Test
      void setPropsInvokesSettersForNullNumbersArraysAndPlainObjects() {
          final SetterBean bean = new SetterBean();
          final JSONPojoConvertor convertor = new JSONPojoConvertor(SetterBean.class);
          final Map properties = new LinkedHashMap();
          properties.put("nullableText", null);
          properties.put("count", Long.valueOf(7L));
          properties.put("labels", new Object[] {"alpha", "beta"});
          properties.put("scores", new Object[] {Long.valueOf(1L), Double.valueOf(2.9d)});
          properties.put("plainText", "plain");
  
          final int updatedProperties = convertor.setProps(bean, properties);
  
          assertThat(updatedProperties).isEqualTo(5);
          assertThat(bean.getNullableText()).isNull();
          assertThat(bean.getCount()).isEqualTo(7);
          assertThat(bean.getLabels()).containsExactly("alpha", "beta");
          assertThat(bean.getScores()).containsExactly(1, 2);
          assertThat(bean.getPlainText()).isEqualTo("plain");
      }
  
      @Test
      void setPropsAttemptsFallbackInvocationWhenArrayConversionFails() {
          final SetterBean bean = new SetterBean();
          final JSONPojoConvertor convertor = new JSONPojoConvertor(SetterBean.class);
          final Map properties = new LinkedHashMap();
          properties.put("labels", new Object[] {new Object()});
          properties.put("scores", new Object[] {Integer.valueOf(1), "not a number"});
  
          final int updatedProperties = convertor.setProps(bean, properties);
  
          assertThat(updatedProperties).isZero();
          assertThat(bean.getLabels()).isNull();
          assertThat(bean.getScores()).isNull();
      }
  
      @Test
      void setPropsUsesOriginalNumericArrayWhenElementConversionFails() {
          final SetterBean bean = new SetterBean();
          final JSONPojoConvertor convertor = new JSONPojoConvertor(SetterBean.class);
          final Integer[] originalScores = new Integer[] {Integer.valueOf(1), null, Integer.valueOf(3)};
          final Map properties = new LinkedHashMap();
          properties.put("boxedScores", originalScores);
  
          final int updatedProperties = convertor.setProps(bean, properties);
  
          assertThat(updatedProperties).isEqualTo(1);
          assertThat(bean.getBoxedScores()).isSameAs(originalScores);
      }
  
      @Test
      void setterUsesOriginalArrayWhenNonNumericArrayCopyFails() throws NoSuchMethodException,
              InvocationTargetException, IllegalAccessException {
          final SetterBean bean = new SetterBean();
          final Object[] originalValues = new Object[] {new Object()};
          final Method method = SetterBean.class.getMethod("setFallbackValue", Object.class);
          final ObjectAcceptingArraySetter setter = new ObjectAcceptingArraySetter("fallbackValue", method);
  
          setter.invoke(bean, originalValues);
  
          assertThat(bean.getFallbackValue()).isSameAs(originalValues);
      }
  
      public static class SetterBean {
          private String nullableText;
          private int count;
          private String[] labels;
          private int[] scores;
          private Integer[] boxedScores;
          private String plainText;
          private Object fallbackValue;
  
          public String getNullableText() {
              return nullableText;
          }
  
          public void setNullableText(final String nullableText) {
              this.nullableText = nullableText;
          }
  
          public int getCount() {
              return count;
          }
  
          public void setCount(final int count) {
              this.count = count;
          }
  
          public String[] getLabels() {
              return labels;
          }
  
          public void setLabels(final String[] labels) {
              this.labels = labels;
          }
  
          public int[] getScores() {
              return scores;
          }
  
          public void setScores(final int[] scores) {
              this.scores = scores;
          }
  
          public Integer[] getBoxedScores() {
              return boxedScores;
          }
  
          public void setBoxedScores(final Integer[] boxedScores) {
              this.boxedScores = boxedScores;
          }
  
          public String getPlainText() {
              return plainText;
          }
  
          public void setPlainText(final String plainText) {
              this.plainText = plainText;
          }
  
          public Object getFallbackValue() {
              return fallbackValue;
          }
  
          public void setFallbackValue(final Object fallbackValue) {
              this.fallbackValue = fallbackValue;
          }
      }
  
      public static class ObjectAcceptingArraySetter extends JSONPojoConvertor.Setter {
          public ObjectAcceptingArraySetter(final String propertyName, final Method method) {
              super(propertyName, method);
              _componentType = String.class;
              _numberType = null;
          }
      }
  }
