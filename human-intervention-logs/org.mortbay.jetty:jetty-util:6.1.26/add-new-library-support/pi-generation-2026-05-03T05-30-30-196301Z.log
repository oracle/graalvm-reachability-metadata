ngConstructedValue.class, \"created\");\n\n        assertThat(converted).isInstanceOf(StringConstructedValue.class);\n        assertThat(((StringConstructedValue) converted).value()).isEqualTo(\"created\");\n    }\n\n    public static final class StringConstructedValue {\n        private final String value;\n\n        public StringConstructedValue(String value) {\n            this.value = value;\n        }\n\n        String value() {\n            return this.value;\n        }\n    }\n}\n"}
