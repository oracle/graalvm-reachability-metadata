       assertThat(properties.containsKey(\"description\")).isFalse();\n    }\n\n    public static class WidgetSnapshot {\n        private final String name;\n        private final int count;\n        private final boolean ready;\n        private final String secret;\n\n        public WidgetSnapshot(String name, int count, boolean ready, String secret) {\n            this.name = name;\n            this.count = count;\n            this.ready = ready;\n            this.secret = secret;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public boolean isReady() {\n            return ready;\n        }\n\n        public String getSecret() {\n            return secret;\n        }\n\n        public String description() {\n            return name + ':' + count;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 762, "output": 991, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 24793, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777662282579, "responseId": "resp_093d95c7ba7805470169f4f94b07588197ba0fd503ba2531c5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_vMhSVLr7p7Rt7dRf4kx96GZ4|fc_093d95c7ba7805470169f4f954dbac819782aaf6599ebc178b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2073 bytes to tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/JSONObjectConvertorTest.java"}], "isError": false, "timestamp": 1777662295150}]}
