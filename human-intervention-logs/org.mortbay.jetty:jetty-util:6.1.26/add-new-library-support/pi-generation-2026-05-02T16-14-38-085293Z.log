<http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty_util;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.math.BigInteger;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.util.TypeUtil;\n\npublic class TypeUtilTest {\n\n    @Test\n    void resolvesCanonicalPrimitiveWrapperAndStringNames() {\n        assertThat(TypeUtil.fromName(\"boolean\")).isSameAs(Boolean.TYPE);\n        assertThat(TypeUtil.fromName(\"byte\")).isSameAs(Byte.TYPE);\n        assertThat(TypeUtil.fromName(\"char\")).isSameAs(Character.TYPE);\n        assertThat(TypeUtil.fromName(\"double\")).isSameAs(Double.TYPE);\n        assertThat(TypeUtil.fromName(\"float\")).isSameAs(Float.TYPE);\n        assertThat(TypeUtil.fromName(\"int\")).isSameAs(Integer.TYPE);\n        assertThat(TypeUtil.fromName(\"long\")).isSameAs(Long.TYPE);\n        assertThat(TypeUtil.fromName(\"short\")).isSameAs(Short.TYPE);\n        assertThat(TypeUtil.fromName(\"void\")).isSameAs(Void.TYPE);\n        assertThat(TypeUtil.fromName(\"java.lang.String\")).isSameAs(String.class);\n\n        assertThat(TypeUtil.toName(Boolean.TYPE)).isEqualTo(\"boolean\");\n        assertThat(TypeUtil.toName(Integer.class)).isEqualTo(\"java.lang.Integer\");\n        assertThat(TypeUtil.toName(String.class)).isEqualTo(\"java.lang.String\");\n    }\n\n    @Test\n    void createsPrimitiveAndWrapperValuesThroughRegisteredValueOfMethods() {\n        assertThat(TypeUtil.valueOf(Boolean.TYPE, \"true\")).isEqualTo(Boolean.TRUE);\n        assertThat(TypeUtil.valueOf(Byte.TYPE, \"7\")).isEqualTo(Byte.valueOf(\"7\"));\n        assertThat(TypeUtil.valueOf(Double.TYPE, \"12.5\")).isEqualTo(Double.valueOf(\"12.5\"));\n        assertThat(TypeUtil.valueOf(Float.TYPE, \"3.25\")).isEqualTo(Float.valueOf(\"3.25\"));\n        assertThat(TypeUtil.valueOf(Integer.TYPE, \"42\")).isEqualTo(Integer.valueOf(\"42\"));\n        assertThat(TypeUtil.valueOf(Long.TYPE, \"123456789\")).isEqualTo(Long.valueOf(\"123456789\"));\n        assertThat(TypeUtil.valueOf(Short.TYPE, \"9\")).isEqualTo(Short.valueOf(\"9\"));\n\n        assertThat(TypeUtil.valueOf(Boolean.class, \"false\")).isEqualTo(Boolean.FALSE);\n        assertThat(TypeUtil.valueOf(Byte.class, \"8\")).isEqualTo(Byte.valueOf(\"8\"));\n        assertThat(TypeUtil.valueOf(Double.class, \"6.5\")).isEqualTo(Double.valueOf(\"6.5\"));\n        assertThat(TypeUtil.valueOf(Float.class, \"4.5\")).isEqualTo(Float.valueOf(\"4.5\"));\n        assertThat(TypeUtil.valueOf(Integer.class, \"84\")).isEqualTo(Integer.valueOf(\"84\"));\n        assertThat(TypeUtil.valueOf(Long.class, \"987654321\")).isEqualTo(Long.valueOf(\"987654321\"));\n        assertThat(TypeUtil.valueOf(Short.class, \"10\")).isEqualTo(Short.valueOf(\"10\"));\n    }\n\n    @Test\n    void createsValuesForStringsCharactersNamedTypesAndStringConstructors() {\n        assertThat(TypeUtil.valueOf(String.class, \"jetty\")).isEqualTo(\"jetty\");\n        assertThat(TypeUtil.valueOf(Character.TYPE, \"abc\")).isEqualTo(Character.valueOf('a'));\n        assertThat(TypeUtil.valueOf(Character.class, \"xyz\")).isEqualTo(Character.valueOf('x'));\n        assertThat(TypeUtil.valueOf(\"int\", \"64\")).isEqualTo(Integer.valueOf(64));\n        assertThat(TypeUtil.valueOf(\"java.lang.String\", \"mortbay\")).isEqualTo(\"mortbay\");\n        assertThat(TypeUtil.valueOf(BigInteger.class, \"12345678901234567890\"))\n                .isEqualTo(new BigInteger(\"12345678901234567890\"));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 491, "output": 1929, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21364, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777738370280, "responseId": "resp_0215cb58b73f4e5f0169f622829fb4819185454dd5bbebeb30"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_lrhSbwA0htHttDhuJOV4AYri|fc_0215cb58b73f4e5f0169f622901a