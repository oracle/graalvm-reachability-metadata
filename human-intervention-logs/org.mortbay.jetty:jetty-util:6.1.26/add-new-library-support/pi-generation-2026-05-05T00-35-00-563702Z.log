 = LazyList.add(null, \"first\");\n        stringList = LazyList.add(stringList, \"second\");\n        assertThat((String[]) LazyList.toArray(stringList, String.class)).containsExactly(\"first\", \"second\");\n    }\n\n    @Test\n    void convertsListToPrimitiveArray() {\n        Object integerList = LazyList.add(null, 1);\n        integerList = LazyList.add(integerList, 2);\n\n        assertThat((int[]) LazyList.toArray(integerList, Integer.TYPE)).containsExactly(1, 2);\n    }\n\n    @Test\n    void addsItemsToNewAndExistingTypedArrays() {\n        assertThat(LazyList.addToArray(null, \"first\", String.class)).containsExactly(\"first\");\n\n        String[] values = {\"first\", \"second\"};\n        assertThat(LazyList.addToArray(values, \"third\", null)).containsExactly(\"first\", \"second\", \"third\");\n    }\n\n    @Test\n    void removesItemFromTypedArray() {\n        String[] values = {\"first\", \"second\", \"third\"};\n\n        assertThat(LazyList.removeFromArray(values, \"second\")).containsExactly(\"first\", \"third\");\n    }\n}\n"}], "isError": false, "timestamp": 1777941297899}]}
