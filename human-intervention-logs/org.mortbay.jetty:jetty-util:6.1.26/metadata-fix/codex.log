{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.mortbay.jetty/jetty-util/6.1.26/src/test/java/org_mortbay_jetty/jetty_util/TypeUtilTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty_util;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.net.URI;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.util.TypeUtil;\n\npublic class TypeUtilTest {\n    @Test\n    void resolvesCanonicalNamesForPrimitiveAndBoxedTypes() {\n        assertThat(TypeUtil.fromName(\"boolean\")).isEqualTo(Boolean.TYPE);\n        assertThat(TypeUtil.fromName(\"java.lang.Integer\")).isEqualTo(Integer.class);\n        assertThat(TypeUtil.fromName(\"String\")).isEqualTo(String.class);\n        assertThat(TypeUtil.fromName(null)).isEqualTo(Void.TYPE);\n\n        assertThat(TypeUtil.toName(Boolean.TYPE)).isEqualTo(\"boolean\");\n        assertThat(TypeUtil.toName(Integer.class)).isEqualTo(\"java.lang.Integer\");\n        assertThat(TypeUtil.toName(String.class)).isEqualTo(\"java.lang.String\");\n    }\n\n    @Test\n    void convertsStringsUsingRegisteredValueOfMethods() {\n        assertThat(TypeUtil.valueOf(Boolean.TYPE, \"true\")).isEqualTo(Boolean.TRUE);\n        assertThat(TypeUtil.valueOf(Byte.TYPE, \"12\")).isEqualTo((byte) 12);\n        assertThat(TypeUtil.valueOf(Double.TYPE, \"12.5\")).isEqualTo(12.5d);\n        assertThat(TypeUtil.valueOf(Float.TYPE, \"3.5\")).isEqualTo(3.5f);\n        assertThat(TypeUtil.valueOf(Integer.TYPE, \"42\")).isEqualTo(42);\n        assertThat(TypeUtil.valueOf(Long.TYPE, \"123456789\")).isEqualTo(123456789L);\n        assertThat(TypeUtil.valueOf(Short.TYPE, \"7\")).isEqualTo((short) 7);\n\n        assertThat(TypeUtil.valueOf(\"java.lang.Boolean\", \"false\")).isEqualTo(Boolean.FALSE);\n    }\n\n    @Test\n    void convertsStringsUsingAStringConstructorWhenNoValueOfMethodIsRegistered() {\n        final Object value = TypeUtil.valueOf(URI.class, \"https://example.com/jetty-util?version=6\");\n\n        assertThat(value)\n                .isInstanceOf(URI.class)\n                .hasToString(\"https://example.com/jetty-util?version=6\");\n    }\n\n    @Test\n    void convertsStringAndCharacterSpecialCases() {\n        assertThat(TypeUtil.valueOf(String.class, \"jetty\")).isEqualTo(\"jetty\");\n        assertThat(TypeUtil.valueOf(Character.TYPE, \"mortbay\")).isEqualTo('m');\n        assertThat(TypeUtil.valueOf(Character.class, \"jetty\")).isEqualTo('j');\n    }\n}\n","exit_code":0,"status":"completed"}}
