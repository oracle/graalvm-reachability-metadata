ce\", 37));\n\n                    assertThat(repository.findByName(\"Ada\")).extracting(Person::getAge).containsExactlyInAnyOrder(42,\n                            29);\n                    assertThat(repository.findByAgeGreaterThan(35)).extracting(Person::getName)\n                            .containsExactlyInAnyOrder(\"Ada\", \"Grace\");\n                    assertThat(repository.existsById(repository.findByName(\"Grace\").get(0).getId())).isTrue();\n\n                    jdbcTemplate.execute(\"SHUTDOWN\");\n                });\n    }\n\n    @Test\n    void repositoryAutoConfigurationCanBeDisabled() {\n        this.contextRunner\n                .withPropertyValues(dataSourceProperties(\"spring.data.jdbc.dialect=h2\",\n                        \"spring.data.jdbc.repositories.enabled=false\"))\n                .run((context) -> {\n                    assertThat(context).hasSingleBean(DataSource.class);\n                    assertThat(context).hasSingleBean(JdbcTemplate.class);\n                    assertThat(context).doesNotHaveBean(DataJdbcProperties.class);\n                    assertThat(context).doesNotHaveBean(JdbcAggregateTemplate.class);\n                    assertThat(context).doesNotHaveBean(PersonRepository.class);\n                });\n    }\n\n    @Test\n    void autoConfigurationUsesCustomNamingStrategyForJdbcMapping() {\n        this.contextRunner.withUserConfiguration(CustomNamingStrategyConfiguration.class)\n                .withPropertyValues(dataSourceProperties(\"spring.data.jdbc.dialect=h2\"))\n                .run((context) -> {\n                    assertThat(context).hasSingleBean(NamingStrategy.class);\n\n                    JdbcTemplate jdbcTemplate = context.getBean(JdbcTemplate.class);\n                    createNamedProductsTable(jdbcTemplate);\n\n                    ProductRepository repository = context.getBean(ProductRepository.class);\n                    ProductItem product = repository.save(new ProductItem(\"Keyboard\"));\n\n                    assertThat(product.getId()).isNotNull();\n                    assertThat(repository.findById(product.getId())).hasValueSatisfying(\n                            (savedProduct) -> assertThat(savedProduct.getDisplayName()).isEqualTo(\"Keyboard\"));\n                    assertThat(jdbcTemplate.queryForObject(\"SELECT \\\"title\\\" FROM \\\"named_products\\\" WHERE \\\"id\\\" = ?\",\n                            String.class, product.getId())).isEqualTo(\"Keyboard\");\n                    jdbcTemplate.execute(\"SHUTDOWN\");\n                });\n    }\n\n    private static String[] dataSourceProperties(String... additionalProperties) {\n        String databaseName = \"datajdbc_\" + UUID.randomUUID().toString().replace('-', '_');\n        List<String> properties = new ArrayList<>(List.of(\n                \"spring.datasource.type=org.springframework.jdbc.datasource.SimpleDriverDataSource\",\n                \"spring.datasource.driver-class-name=org.h2.Driver\",\n                \"spring.datasource.url=jdbc:h2:mem:\" + databaseName + \";DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\",\n                \"spring.datasource.username=sa\",\n                \"spring.datasource.password=\",\n                \"spring.sql.init.mode=never\"));\n        properties.addAll(List.of(additionalProperties));\n        return properties.toArray(String[]::new);\n    }\n\n    private static void createPeopleTable(JdbcTemplate jdbcTemplate) {\n        jdbcTemplate.execute(\"\"\"\n                CREATE TABLE \"people\" (\n                    \"ID\" BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,\n                    \"name\" VARCHAR(255) NOT NULL,\n                    \"age\" INTEGER NOT NULL\n                )\n                \"\"\");\n    }\n\n    private static void createNamedProductsTable(JdbcTemplate jdbcTemplate) {\n        jdbcTemplate.execute(\"\"\"\n                CREATE TABLE \"named_products\" (\n                    \"id\" BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,\n                    \"title\" VARCHAR(255) NOT NULL\n                )\n                \"\"\");\n    }\n\n    @Configuration(proxyBeanMethods = false)\n    @AutoConfigurationPackage\n    static class TestApplication {\n    }\n\n    @Configuration(proxyBeanMethods = false)\n    static class CustomNamingStrategyConfiguration {\n\n        @Bean\n        NamingStrategy customNamingStrategy() {\n            return new NamingStrategy() {\n\n                @Override\n                public String getTableName(Class<?> type) {\n                    if (ProductItem.class.equals(type)) {\n                        return \"named_products\";\n                    }\n                    return NamingStrategy.super.getTableName(type);\n                }\n\n                @Override\n                public String getColumnName(RelationalPersistentProperty property) {\n                    if (ProductItem.class.equals(property.getOwner().getType())\n                            && \"displayName\".equals(property.getName())) {\n                        return \"title\";\n                    }\n                    return NamingStrategy.super.getColumnName(property);\n                }\n\n            };\n        }\n\n    }\n\n}\n\n@Table(\"people\")\nclass Person {\n\n    @Id\n    private Long id;\n\n    @Column(\"name\")\n    private String name;\n\n    @Column(\"age\")\n    private int age;\n\n    Person() {\n    }\n\n    Person(String name, int age) {\n        this.name = name;\n        this.age = age;\n    }\n\n    Long getId() {\n        return this.id;\n    }\n\n    String getName() {\n        return this.name;\n    }\n\n    int getAge() {\n        return this.age;\n    }\n\n    void setAge(int age) {\n        this.age = age;\n    }\n\n}\n\ninterface PersonRepository extends CrudRepository<Person, Long> {\n\n    List<Person> findByName(String name);\n\n    List<Person> findByAgeGreaterThan(int age);\n\n}\n\nclass ProductItem {\n\n    @Id\n    private Long id;\n\n    private String displayName;\n\n    ProductItem() {\n    }\n\n    ProductItem(String displayName) {\n        this.displayName = displayName;\n    }\n\n    Long getId() {\n        return this.id;\n    }\n\n    String getDisplayName() {\n        return this.displayName;\n    }\n\n}\n\ninterface ProductRepository extends CrudRepository<ProductItem, Long> {\n\n}\n"}], "isError": false, "timestamp": 1779223539022}]}
