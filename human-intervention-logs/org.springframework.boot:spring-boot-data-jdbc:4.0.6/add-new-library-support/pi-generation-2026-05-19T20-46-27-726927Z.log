mework.context.annotation.Configuration;\nimport org.springframework.data.annotation.Id;\n", "newText": "import org.springframework.context.annotation.Bean;\nimport org.springframework.context.annotation.Configuration;\nimport org.springframework.data.annotation.Id;\n"}, {"oldText": "import org.springframework.data.relational.core.mapping.Column;\nimport org.springframework.data.relational.core.mapping.Table;\n", "newText": "import org.springframework.data.relational.core.mapping.Column;\nimport org.springframework.data.relational.core.mapping.NamingStrategy;\nimport org.springframework.data.relational.core.mapping.RelationalPersistentProperty;\nimport org.springframework.data.relational.core.mapping.Table;\n"}, {"oldText": "    @Test\n    void repositoryAutoConfigurationCanBeDisabled() {\n        this.contextRunner\n                .withPropertyValues(dataSourceProperties(\"spring.data.jdbc.dialect=h2\",\n                        \"spring.data.jdbc.repositories.enabled=false\"))\n                .run((context) -> {\n                    assertThat(context).hasSingleBean(DataSource.class);\n                    assertThat(context).hasSingleBean(JdbcTemplate.class);\n                    assertThat(context).doesNotHaveBean(DataJdbcProperties.class);\n                    assertThat(context).doesNotHaveBean(JdbcAggregateTemplate.class);\n                    assertThat(context).doesNotHaveBean(PersonRepository.class);\n                });\n    }\n\n    private static String[] dataSourceProperties(String... additionalProperties) {\n", "newText": "    @Test\n    void repositoryAutoConfigurationCanBeDisabled() {\n        this.contextRunner\n                .withPropertyValues(dataSourceProperties(\"spring.data.jdbc.dialect=h2\",\n                        \"spring.data.jdbc.repositories.enabled=false\"))\n                .run((context) -> {\n                    assertThat(context).hasSingleBean(DataSource.class);\n                    assertThat(context).hasSingleBean(JdbcTemplate.class);\n                    assertThat(context).doesNotHaveBean(DataJdbcProperties.class);\n                    assertThat(context).doesNotHaveBean(JdbcAggregateTemplate.class);\n                    assertThat(context).doesNotHaveBean(PersonRepository.class);\n                });\n    }\n\n    @Test\n    void autoConfigurationUsesCustomNamingStrategyForJdbcMapping() {\n        this.contextRunner.withUserConfiguration(CustomNamingStrategyConfiguration.class)\n                .withPropertyValues(dataSourceProperties(\"spring.data.jdbc.dialect=h2\"))\n                .run((context) -> {\n                    assertThat(context).hasSingleBean(NamingStrategy.class);\n\n                    JdbcTemplate jdbcTemplate = context.getBean(JdbcTemplate.class);\n                    createNamedProductsTable(jdbcTemplate);\n\n                    ProductRepository repository = context.getBean(ProductRepository.class);\n                    ProductItem product = repository.save(new ProductItem(\"Keyboard\"));\n\n                    assertThat(product.getId()).isNotNull();\n                    assertThat(repository.findById(product.getId())).hasValueSatisfying(\n                            (savedProduct) -> assertThat(savedProduct.getDisplayName()).isEqualTo(\"Keyboard\"));\n                    assertThat(jdbcTemplate.queryForObject(\"SELECT \\\"title\\\" FROM \\\"named_products\\\" WHERE \\\"id\\\" = ?\",\n                            String.class, product.getId())).isEqualTo(\"Keyboard\");\n                    jdbcTemplate.execute(\"SHUTDOWN\");\n                });\n    }\n\n    private static String[] dataSourceProperties(String... additionalProperties) {\n"}, {"oldText": "    private static void createPeopleTable(JdbcTemplate jdbcTemplate) {\n        jdbcTemplate.execute(\"\"\"\n                CREATE TABLE \"people\" (\n                    \"ID\" BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,\n                    \"name\" VARCHAR(255) NOT NULL,\n                    \"age\"