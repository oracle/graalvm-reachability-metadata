[tool-call] delta {"path":"tests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/SecurityUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_kafka.kafka_clients;\n\nimport org.apache.kafka.common.config.SecurityConfig;\nimport org.apache.kafka.common.security.auth.SecurityProviderCreator;\nimport org.apache.kafka.common.utils.SecurityUtils;\nimport org.junit.jupiter.api.Test;\n\nimport java.security.Provider;\nimport java.security.Security;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SecurityUtilsTest {\n\n    private static final String PROVIDER_NAME = \"KafkaClientsTestProvider\";\n\n    @Test\n    void addsConfiguredSecurityProviderByClassName() {\n        try {\n            SecurityUtils.addConfiguredSecurityProviders(Map.of(\n                    SecurityConfig.SECURITY_PROVIDERS_CONFIG, TestProviderCreator.class.getName()));\n\n            assertThat(Security.getProvider(PROVIDER_NAME)).isNotNull();\n        } finally {\n            Security.removeProvider(PROVIDER_NAME);\n        }\n    }\n\n    public static class TestProviderCreator implements SecurityProviderCreator {\n\n        @Override\n        public Provider getProvider() {\n            return new Provider(PROVIDER_NAME, \"1.0\", \"Provider used by kafka-clients reachability tests\") {\n            };\n        }\n    }\n}\n"}
