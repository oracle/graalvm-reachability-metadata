  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "com.formdev:flatlaf:$libraryVersion"
      testImplementation "com.formdev:flatlaf-extras:$libraryVersion"
      testCompileOnly 'com.github.weisj:jsvg:2.0.0'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.withType(Test).configureEach {
      jvmArgs "--add-opens=java.desktop/javax.swing=ALL-UNNAMED"
  }
  
