      options.release = null
      options.compilerArgs += ['--add-exports=java.security.jgss/sun.security.krb5=ALL-UNNAMED']
  }
  
  tasks.withType(Test).configureEach {
      jvmArgs += ['--add-exports=java.security.jgss/sun.security.krb5=ALL-UNNAMED']
      systemProperty 'java.vendor', 'IBM Corporation'
  }
  
  tasks.named("nativeTest", NativeRunTask).configure {
