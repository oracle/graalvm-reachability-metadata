      private void initCollectors() {
          kafkaMetricsCollector = new KafkaMetricsCollector(
              TelemetryMetricNamingConvention.getClientTelemetryMetricNamingStrategy(
                  telemetryProvider.domain()), EXCLUDE_LABELS);
