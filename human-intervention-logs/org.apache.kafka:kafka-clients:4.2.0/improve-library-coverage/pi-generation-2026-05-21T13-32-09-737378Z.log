    private static int firstDifferingByteIndexNativeEndian(long left, long right) {
      int n =
          IS_BIG_ENDIAN
              ? Long.numberOfLeadingZeros(left ^ right)
              : Long.numberOfTrailingZeros(left ^ right);
      return n >> 3;
    }
  
