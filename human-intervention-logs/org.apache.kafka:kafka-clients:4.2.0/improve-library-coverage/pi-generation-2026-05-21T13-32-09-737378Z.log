      private ResourceMetrics buildMetric(Metric metric) {
          return ResourceMetrics.newBuilder()
              .setResource(telemetryProvider.resource())
              .addScopeMetrics(ScopeMetrics.newBuilder()
                  .addMetrics(metric)
                  .build()).build();
