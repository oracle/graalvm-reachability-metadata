private Map<FieldDescriptor, Object> getAllFieldsMutable(boolean getBytesForString) {\n91:     final TreeMap<FieldDescriptor, Object> result = new TreeMap<FieldDescriptor, Object>();\n92:     final Descriptor descriptor = internalGetFieldAccessorTable().descriptor;\n93:     final List<FieldDescriptor> fields = descriptor.getFields();\n94: \n95:     for (int i = 0; i < fields.size(); i++) {\n96:       FieldDescriptor field = fields.get(i);\n97:       final OneofDescriptor oneofDescriptor = field.getContainingOneof();\n98: \n99:       /*\n100:        * If the field is part of a Oneof, then at maximum one field in the Oneof is set\n101:        * and it is not repeated. There is no need to iterate through the others.\n102:        */\n103:       if (oneofDescriptor != null) {\n104:         // Skip other fields in the Oneof we know are not set\n105:         i += oneofDescriptor.getFieldCount() - 1;\n106:         if (!hasOneof(oneofDescriptor)) {\n107:           // If no field is set in the Oneof, skip all the fields in the Oneof\n108:           continue;\n109:         }\n110:         // Get the pointer to the only field which is set in the Oneof\n111:         field = getOneofFieldDescriptor(oneofDescriptor);\n112:       } else {\n113:         // If we are not in a Oneof, we need to check if the field is set and if it is repeated\n114:         if (field.isRepeated()) {\n115:           final List<?> value = (List<?>) getField(field);\n116:           if (!value.isEmpty()) {\n117:             result.put(field, value);\n118:           }\n119:           continue;\n120:         }\n121:         if (!hasField(field)) {\n122:           continue;\n123:         }\n124:       }\n125:       // Add the field to the map\n126:       if (getBytesForString && field.getJavaType() == FieldDescriptor.JavaType.STRING) {\n127:         result.put(field, getFieldRaw(field));\n128:       } else {\n129:         result.put(field, getField(field));\n130:       }\n131:     }\n132:     return result;\n1