                "Class",
                // com.google.protobuf.MessageLiteOrBuilder:
                "DefaultInstanceForType",
                // com.google.protobuf.MessageLite:
                "ParserForType",
                "SerializedSize",
                // com.google.protobuf.MessageOrBuilder:
