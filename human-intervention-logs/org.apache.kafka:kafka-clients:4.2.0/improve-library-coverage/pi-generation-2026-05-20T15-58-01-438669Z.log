;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class GeneratedMessageV3Test {\n\n    @Test\n    void packsParsesUnpacksAndPrintsGeneratedProtobufMessage() throws Exception {\n        StringValue value = StringValue.of(\"payload\");\n        Any packed = Any.pack(value);\n        byte[] bytes = packed.toByteArray();\n\n        Any parsed = Any.parseFrom(bytes);\n        StringValue unpacked = parsed.unpack(StringValue.class);\n        Descriptors.Descriptor descriptor = StringValue.getDescriptor();\n\n        assertThat(unpacked.getValue()).isEqualTo(\"payload\");\n        assertThat(parsed.toString()).contains(\"type.googleapis.com\");\n        assertThat(descriptor.findFieldByName(\"value\")).isNotNull();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 542, "output": 467, "cacheRead": 71168, "cacheWrite": 0, "totalTokens": 72177, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779292473521, "responseId": "resp_035dab146d298b57016a0dd93a7bc08196bfb877d697fd02ef"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_EBEoHttesbT4rIVi1D364SUm|fc_035dab146d298b57016a0dd93f6a188196b257d8bdb7aeb703", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1185 bytes to tests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/GeneratedMessageV3Test.java"}], "isError": false, "timestamp": 1779292480529}]}
