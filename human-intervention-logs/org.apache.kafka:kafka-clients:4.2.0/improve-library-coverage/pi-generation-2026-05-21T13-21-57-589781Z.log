     672	                responseData.responses().iterator().next().partitionResponses().get(0).setRecordErrors(Collections.emptyList());
     673	                responseData.responses().iterator().next().partitionResponses().get(0).setErrorMessage(null);
     674	            }
     675	
     676	            if (version < 5) {
     677	                responseData.responses().iterator().next().partitionResponses().get(0).setLogStartOffset(-1);
     678	            }
     679	
     680	            if (version < 2) {
     681	                responseData.responses().iterator().next().partitionResponses().get(0).setLogAppendTimeMs(-1);
