     648	                            .setErrorCode(errorCode)
     649	                            .setBaseOffset(baseOffset)))).iterator())));
     650	
     651	        Supplier<ProduceResponseData> response = () -> new ProduceResponseData()
     652	                .setResponses(new ProduceResponseData.TopicProduceResponseCollection(singletonList(
     653	                    new ProduceResponseData.TopicProduceResponse()
     654	                        .setPartitionResponses(singletonList(
