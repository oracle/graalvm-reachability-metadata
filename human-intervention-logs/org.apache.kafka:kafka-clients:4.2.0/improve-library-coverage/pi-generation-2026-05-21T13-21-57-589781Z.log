  88\t    @Test\n    89\t    public void testAddOffsetsToTxnVersions() throws Exception {\n    90\t        testAllMessageRoundTrips(new AddOffsetsToTxnRequestData().\n    91\t                setTransactionalId(\"foobar\").\n    92\t                setProducerId(0xbadcafebadcafeL).\n    93\t                setProducerEpoch((short) 123).\n    94\t                setGroupId(\"baaz\"));\n    95\t        testAllMessageRoundTrips(new AddOffsetsToTxnResponseData().\n    96\t                setThrottleTimeMs(42).\n    97\t                setErrorCode((short) 0));\n    98\t    }\n    99\t\n   100\t    @Test\n   101\t    public void testAddPartitionsToTxnVersions() throws Exception {\n   102\t        AddPartitionsToTxnRequestData v3AndBelowData = new AddPartitionsToTxnRequestData().\n   103\t                setV3AndBelowTransactionalId(\"blah\").\n   104\t                setV3AndBelowProducerId(0xbadcafebadcafeL).\n   105\t                setV3AndBelowProducerEpoch((short) 30000).\n   106\t                setV3AndBelowTopics(new AddPartitionsToTxnTopicCollection(singletonList(\n   107\t                        new AddPartitionsToTxnTopic().\n   108\t                                setName(\"Topic\").\n   109\t                                setPartitions(singletonList(1))).iterator()));\n   110\t        testDuplication(v3AndBelowData);\n   111\t        testAllMessageRoundTripsUntilVersion((short) 3, v3AndBelowData);\n   112\t\n   113\t        AddPartitionsToTxnRequestData data = new AddPartitionsToTxnRequestData().\n   114\t                setTransactions(new AddPartitionsToTxnTransactionCollection(singletonList(\n   115\t                       new AddPartitionsToTxnRequestData.AddPartitionsToTxnTransaction().\n   116\t                              setTransactionalId(\"blah\").\n   117\t                              setProducerId(0xbadcafebadcafeL).\n   118\t                              setProducerEpoch((short) 30000).\n   119\t                              setTopics(v3AndBelowData.v3AndBelowTopics())).iterator()));\n   120\t        testDuplication(data);\n   121\t        testAllMessageRoundTripsFromVersion((short) 4, data);\n   122\t    }\n   123\t\n   124\t    @Test\n   125\t    public void testCreateTopicsVersions() throws Exception {\n   126\t        testAllMessageRoundTrips(new CreateTopicsRequestData().\n   127\t                setTimeoutMs(1000).setTopics(new CreateTopicsRequestData.CreatableTopicCollection()));\n   128\t    }\n   129\t\n   130\t    @Test\n   131\t    public void testDescribeAclsRequest() throws Exception {\n   132\t        testAllMessageRoundTrips(new DescribeAclsRequestData().\n   133\t                setResourceTypeFilter((byte) 42).\n   134\t                setResourceNameFilter(null).\n   135\t                setPatternTypeFilter((byte) 3).\n   136\t                setPrincipalFilter(\"abc\").\n   137\t                setHostFilter(null).\n   138\t                setOperation((byte) 0).\n   139\t                setPermissionType((byte) 0));\n   140\t    }\n   141\t\n   142\t    @Test\n   143\t    public void testMetadataVersions() throws Exception {\n   144\t        testAllMessageRoundTrips(new MetadataRequestData().setTopics(\n   145\t                Arrays.asList(new MetadataRequestData.MetadataRequestTopic().setName(\"foo\"),\n   146\t                        new MetadataRequestData.MetadataRequestTopic().setName(\"bar\")\n   147\t                )));\n   148\t        testAllMessageRoundTripsFromVersion((short) 1, new MetadataRequestData().\n   149\t                setTopics(null).\n   150\t                setAllowAutoTopicCreation(true).\n   151\t                setIncludeClusterAuthorizedOperations(false).\n   152\t                setIncludeTopicAuthorizedOperations(false));\n   153\t        testAllMessageRoundTripsFromVersion((short) 4, new MetadataRequestData().\n   154\t                setTopics(null).\n   155\t                setAllowAutoTopicCreation(false).\n   156\t                setIncludeClusterAuthorizedOperations(false).\n   157\t                setIncludeTopicAuthorizedOperations(false));\n   158\t    }\n   159\t\n   160\t    @Test\n   161\t    public void testHeartbeatVersions() throws Exception {\n   162\t        Supplier<HeartbeatRequestData> newRequest = () -> new HeartbeatRequestData()\n   163\t                .setGroupId(\"groupId\")\n   164\t                .setMemberId(memberId)\n   165\t                .setGenerationId(15);\n   166\t        testAllMessageRoundTrips(newRequest.get());\n   167\t        testAllMessageRoundTrips(newRequest.get().setGroupInstanceId(null));\n   168\t        testAllMessageRoundTripsFromVersion((short) 3, newRequest.get().setGroupInstanceId(\"instanceId\"));\n   169\t    }\n   170\t\n   171\t    @Test\n   172\t    public void testJoinGroupRequestVersions() throws Exception {\n   173\t        Supplier<JoinGroupRequestData> newRequest = () -> new JoinGroupRequestData()\n   174\t                .setGroupId(\"groupId\")\n   175\t                .setMemberId(memberId)\n   176\t                .setProtocolType(\"consumer\")\n   177\t                .setProtocols(new JoinGroupRequestData.JoinGroupRequestProtocolCollection())\n   178\t                .setSessionTimeoutMs(10000);\n   179\t        testAllMessageRoundTrips(newRequest.get());\n   180\t        testAllMessageRoundTripsFromVersion((short) 1, newRequest.get().setRebalanceTimeoutMs(20000));\n   181\t        testAllMessageRoundTrips(newRequest.get().setGroupInstanceId(null));\n   182\t        testAllMessageRoundTripsFromVersion((short) 5, newRequest.get().setGroupInstanceId(\"instanceId\"));\n   183\t    }\n   184\t\n   185\t    @Test\n   186\t    public void testListOffsetsRequestVersions() throws Exception {\n   187\t        List<ListOffsetsTopic> v = Collections.singletonList(new ListOffsetsTopic()\n   188\t                .setName(\"topic\")\n   189\t                .setPartitions(Collections.singletonList(new ListOffsetsPartition()\n   190\t                        .setPartitionIndex(0)\n   191\t                        .setTimestamp(123L))));\n   192\t        Supplier<ListOffsetsRequestData> newRequest = () -> new ListOffsetsRequestData()\n   193\t                .setTopics(v)\n   194\t                .setReplicaId(0);\n   195\t        testAllMessageRoundTrips(newRequest.get());\n   196\t        testAllMessageRoundTripsFromVersion((short) 2, newRequest.get().setIsolationLevel(IsolationLevel.READ_COMMITTED.id()));\n   197\t    }\n   198\t\n   199\t    @Test\n   200\t    public void testListOffsetsResponseVersions() throws Exception {\n   201\t        ListOffsetsPartitionResponse partition = new ListOffsetsPartitionResponse()\n   202\t                .setErrorCode(Errors.NONE.code())\n   203\t                .setPartitionIndex(0);\n   204\t        List<ListOffsetsTopicResponse> topics = Collections.singletonList(new ListOffsetsTopicResponse()\n   205\t                .setName(\"topic\")\n   206\t                .setPartitions(Collections.singletonList(partition)));\n   207\t        Supplier<ListOffsetsResponseData> response = () -> new ListOffsetsResponseData()\n   208\t                .setTopics(topics);\n   209\t        for (short version = ApiKeys.LIST_OFFSETS.oldestVersion(); version <= ApiKeys.LIST_OFFSETS.latestVersion(); ++version) {\n   210\t            ListOffsetsResponseData responseData = response.get();\n   211\t            responseData.topics().get(0).partitions().get(0)\n   212\t                .setOffset(456L)\n   213\t                .setTimestamp(123L);\n   214\t            if (version > 1) {\n   215\t                responseData.setThrottleTimeMs(1000);\n   216\t            }\n   217\t            if (version > 3) {\n   218\t                partition.setLeaderEpoch(1);\n   219\t            }\n   220\t            testEquivalentMessageRoundTrip(version, responseData);\n   221\t        }\n   222\t    }\n   223\t\n   224\t    @Test\n   225\t    public void testJoinGroupResponseVersions() throws Exception {\n   226\