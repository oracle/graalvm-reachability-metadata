     688	            if (version >= 13) {
     689	                responseData.responses().iterator().next().setTopicId(topicId);
     690	            } else {
     691	                responseData.responses().iterator().next().setName(topicName);
     692	            }
     693	
     694	            if (version >= 3 && version <= 4) {
     695	                testAllMessageRoundTripsBetweenVersions(version, (short) 5, responseData, responseData);
     696	            } else if (version >= 6 && version <= 7) {
     697	                testAllMessageRoundTripsBetweenVersions(version, (short) 8, responseData, responseData);
     698	            } else if (version <= 12) {
     699	                testAllMessageRoundTripsBetweenVersions(version, (short) 12, responseData, responseData);
     700	            } else {
