     519	                requestData.setMemberId("");
     520	                assertThrows(UnsupportedVersionException.class, () -> testEquivalentMessageRoundTrip(finalVersion, requestData));
     521	                requestData.setGenerationId(-1);
     522	            }
     523	
     524	            testAllMessageRoundTripsFromVersion(version, requestData);
     525	        }
     526	    }
