     458	    @Test
     459	    public void testTxnOffsetCommitRequestVersions() throws Exception {
     460	        String groupId = "groupId";
     461	        String topicName = "topic";
     462	        String metadata = "metadata";
     463	        String txnId = "transactionalId";
     464	        int producerId = 25;
     465	        short producerEpoch = 10;
     466	        String instanceId = "instance";
     467	        String memberId = "member";
     468	        int generationId = 1;
     469	
     470	        int partition = 2;
     471	        int offset = 100;
     472	
     473	        testAllMessageRoundTrips(new TxnOffsetCommitRequestData()
     474	                                     .setGroupId(groupId)
     475	                                     .setTransactionalId(txnId)
     476	                                     .setProducerId(producerId)
     477	                                     .setProducerEpoch(producerEpoch)
     478	                                     .setTopics(Collections.singletonList(
     479	                                         new TxnOffsetCommitRequestTopic()
     480	                                             .setName(topicName)
     481	                                             .setPartitions(Collections.singletonList(
     482	                                                 new TxnOffsetCommitRequestPartition()
     483	                                                     .setPartitionIndex(partition)
     484	                                                     .setCommittedMetadata(metadata)
     485	                                                     .setCommittedOffset(offset)
     486	                                             )))));
     487	
     488	        Supplier<TxnOffsetCommitRequestData> request =
     489	            () -> new TxnOffsetCommitRequestData()
     490	                      .setGroupId(groupId)
     491	                      .setTransactionalId(txnId)
     492	                      .setProducerId(producerId)
     493	                      .setProducerEpoch(producerEpoch)
     494	                      .setGroupInstanceId(instanceId)
     495	                      .setMemberId(memberId)
     496	                      .setGenerationId(generationId)
     497	                      .setTopics(Collections.singletonList(
     498	                          new TxnOffsetCommitRequestTopic()
     499	                              .setName(topicName)
     500	                              .setPartitions(Collections.singletonList(
     501	                                  new TxnOffsetCommitRequestPartition()
     502	                                      .setPartitionIndex(partition)
     503	                                      .setCommittedLeaderEpoch(10)
     504	                                      .setCommittedMetadata(metadata)
     505	                                      .setCommittedOffset(offset)
     506	                              ))));
     507	
     508	        for (short version : ApiKeys.TXN_OFFSET_COMMIT.allVersions()) {
     509	            TxnOffsetCommitRequestData requestData = request.get();
     510	            if (version < 2) {
     511	                requestData.topics().get(0).partitions().get(0).setCommittedLeaderEpoch(-1);
     512	            }
     513	
     514	            if (version < 3) {
     515	                final short finalVersion = version;
     516	                assertThrows(UnsupportedVersionException.class, () -> testEquivalentMessageRoundTrip(finalVersion, requestData));
     517	                requestData.setGroupInstanceId(null);
     518	                assertThrows(UnsupportedVersionException.class, () -> testEquivalentMessageRoundTrip(finalVersion, requestData));
     519	                requestData.setMemberId("");
     520	                assertThrows(UnsupportedVersionException.class, () -> testEquivalentMessageRoundTrip(finalVersion, requestData));
     521	                requestData.setGenerationId(-1);
     522	            }
     523	
     524	            testAllMessageRoundTripsFromVersion(version, requestData);
     525	        }
     526	    }
