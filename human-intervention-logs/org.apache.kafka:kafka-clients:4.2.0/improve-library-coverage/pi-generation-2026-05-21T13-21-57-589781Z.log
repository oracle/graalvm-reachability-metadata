     802	    private void testJsonRoundTrip(short version, Message message, Message expected) throws Exception {
     803	        String jsonConverter = jsonConverterTypeName(message.getClass().getTypeName());
     804	        Class<?> converter = Class.forName(jsonConverter);
     805	        Method writeMethod = converter.getMethod("write", message.getClass(), short.class);
     806	        JsonNode jsonNode = (JsonNode) writeMethod.invoke(null, message, version);
     807	        Method readMethod = converter.getMethod("read", JsonNode.class, short.class);
     808	        Message message2 = (Message) readMethod.invoke(null, jsonNode, version);
     809	        assertEquals(expected, message2);
     810	        assertEquals(expected.hashCode(), message2.hashCode());
     811	        assertEquals(expected.toString(), message2.toString());
     812	    }
