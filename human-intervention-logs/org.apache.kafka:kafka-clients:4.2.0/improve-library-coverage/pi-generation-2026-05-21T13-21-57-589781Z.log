     814	    private static String jsonConverterTypeName(String source) {
     815	        int outerClassIndex = source.lastIndexOf('$');
     816	        if (outerClassIndex == -1) {
     817	            return  source + "JsonConverter";
     818	        } else {
     819	            return source.substring(0, outerClassIndex) + "JsonConverter$" +
     820	                source.substring(outerClassIndex + 1) + "JsonConverter";
     821	        }
     822	    }
