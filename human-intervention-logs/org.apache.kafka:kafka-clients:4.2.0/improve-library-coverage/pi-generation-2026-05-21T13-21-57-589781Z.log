romVersion((short) 1, newResponse.get().setThrottleTimeMs(1000));\n   247\t\n   248\t        testAllMessageRoundTripsFromVersion((short) 3, newResponse.get().setMembers(\n   249\t            Collections.singletonList(new MemberResponse()\n   250\t            .setMemberId(memberId)\n   251\t            .setGroupInstanceId(instanceId))\n   252\t        ));\n   253\t    }\n   254\t\n   255\t    @Test\n   256\t    public void testSyncGroupDefaultGroupInstanceId() throws Exception {\n   257\t        Supplier<SyncGroupRequestData> request = () -> new SyncGroupRequestData()\n   258\t                .setGroupId(\"groupId\")\n   259\t                .setMemberId(memberId)\n   260\t                .setGenerationId(15)\n   261\t                .setAssignments(new ArrayList<>());\n   262\t        testAllMessageRoundTrips(request.get());\n   263\t        testAllMessageRoundTrips(request.get().setGroupInstanceId(null));\n   264\t        testAllMessageRoundTripsFromVersion((short) 3, request.get().setGroupInstanceId(instanceId));\n   265\t    }\n   266\t\n   267\t    @Test\n   268\t    public void testOffsetCommitDefaultGroupInstanceId() throws Exception {\n   269\t        testAllMessageRoundTrips(new OffsetCommitRequestData()\n   270\t                .setTopics(new ArrayList<>())\n   271\t                .setGroupId(\"groupId\"));\n   272\t\n   273\t        Supplier<OffsetCommitRequestData> request = () -> new OffsetCommitRequestData()\n   274\t                .setGroupId(\"groupId\")\n   275\t                .setMemberId(memberId)\n   276\t                .setTopics(new ArrayList<>())\n   277\t                .setGenerationIdOrMemberEpoch(15);\n   278\t        testAllMessageRoundTripsFromVersion((short) 1, request.get());\n   279\t        testAllMessageRoundTripsFromVersion((short) 1, request.get().setGroupInstanceId(null));\n   280\t        testAllMessageRoundTripsFromVersion((short) 7, request.get().setGroupInstanceId(instanceId));\n   281\t    }\n   282\t\n   283\t    @Test\n   284\t    public void testDescribeGroupsRequestVersions() throws Exception {\n   285\t        testAllMessageRoundTrips(new DescribeGroupsRequestData()\n   286\t                .setGroups(Collections.singletonList(\"group\"))\n   287\t                .setIncludeAuthorizedOperations(false));\n   288\t    }\n   289\t\n   290\t    @Test\n   291\t    public void testDescribeGroupsResponseVersions() throws Exception {\n   292\t        DescribedGroupMember baseMember = new DescribedGroupMember()\n   293\t            .setMemberId(memberId);\n   294\t\n   295\t        DescribedGroup baseGroup = new DescribedGroup()\n   296\t                                       .setGroupId(\"group\")\n   297\t                                       .setGroupState(\"Stable\").setErrorCode(Errors.NONE.code())\n   298\t                                       .setMembers(Collections.singletonList(baseMember))\n   299\t                                       .setProtocolType(\"consumer\");\n   300\t        DescribeGroupsResponseData baseResponse = new DescribeGroupsResponseData()\n   301\t                                                      .setGroups(Collections.singletonList(baseGroup));\n   302\t        testAllMessageRoundTrips(baseResponse);\n   303\t\n   304\t        testAllMessageRoundTripsFromVersion((short) 1, baseResponse.setThrottleTimeMs(10));\n   305\t\n   306\t        baseGroup.setAuthorizedOperations(1);\n   307\t        testAllMessageRoundTripsFromVersion((short) 3, baseResponse);\n   308\t\n   309\t        baseMember.setGroupInstanceId(instanceId);\n   310\t        testAllMessageRoundTripsFromVersion((short) 4, baseResponse);\n   311\t    }\n   312\t\n   313\t    @Test\n   314\t    public void testDescribeClusterRequestVersions() throws Exception {\n   315\t        testAllMessageRoundTrips(new DescribeClusterRequestData()\n   316\t            .setIncludeClusterAuthorizedOperations(true));\n   317\t    }\n   318\t\n   319\t    @Test\n   320\t    public void testDescribeClusterResponseVersions() throws Exception {\n   321\t        DescribeClusterResponseData data = new DescribeClusterResponseData()\n   322\t            .setBrokers(new DescribeClusterBrokerCollection(\n   323\t                Collections.singletonList(new DescribeClusterBroker()\n   324\t                    .setBrokerId(1)\n   325\t                    .setHost(\"localhost\")\n   326\t                    .setPort(9092)\n   327\t                    .setRack(\"rack1\")).iterator()))\n   328\t            .setClusterId(\"clusterId\")\n   329\t            .setControllerId(1)\n   330\t            .setClusterAuthorizedOperations(10);\n   331\t\n   332\t        testAllMessageRoundTrips(data);\n   333\t    }\n   334\t\n   335\t    @Test\n   336\t    public void testGroupInstanceIdIgnorableInDescribeGroupsResponse() throws Exception {\n   337\t        DescribeGroupsResponseData responseWithGroupInstanceId =\n   338\t            new DescribeGroupsResponseData()\n   339\t                .setGroups(Collections.singletonList(\n   340\t                    new DescribedGroup()\n   341\t                        .setGroupId(\"group\")\n   342\t                        .setGroupState(\"Stable\")\n   343\t                        .setErrorCode(Errors.NONE.code())\n   344\t                        .setMembers(Collections.singletonList(\n   345\t                            new DescribedGroupMember()\n   346\t                                .setMemberId(memberId)\n   347\t                                .setGroupInstanceId(instanceId)))\n   348\t                        .setProtocolType(\"consumer\")\n   349\t                ));\n   350\t\n   351\t        DescribeGroupsResponseData expectedResponse = responseWithGroupInstanceId.duplicate();\n   352\t        // Unset GroupInstanceId\n   353\t        expectedResponse.groups().get(0).members().get(0).setGroupInstanceId(null);\n   354\t\n   355\t        testAllMessageRoundTripsBeforeVersion((short) 4, responseWithGroupInstanceId, expectedResponse);\n   356\t 