     783	    private void testByteBufferRoundTrip(short version, Message message, Message expected) throws Exception {
     784	        ObjectSerializationCache cache = new ObjectSerializationCache();
     785	        int size = message.size(cache, version);
     786	        ByteBuffer buf = ByteBuffer.allocate(size);
     787	        ByteBufferAccessor byteBufferAccessor = new ByteBufferAccessor(buf);
     788	        message.write(byteBufferAccessor, cache, version);
     789	        assertEquals(size, buf.position(), "The result of the size function does not match the number of bytes " +
     790	            "written for version " + version);
     791	        Message message2 = message.getClass().getConstructor().newInstance();
     792	        buf.flip();
     793	        message2.read(byteBufferAccessor, version);
     794	        assertEquals(size, buf.position(), "The result of the size function does not match the number of bytes " +
     795	            "read back in for version " + version);
     796	        assertEquals(expected, message2, "The message object created after a round trip did not match for " +
     797	            "version " + version);
     798	        assertEquals(expected.hashCode(), message2.hashCode());
     799	        assertEquals(expected.toString(), message2.toString());
     800	    }
