st\",\n                saslProperties,\n                callbacks -> {\n                });\n\n        assertThat(client).isNotNull();\n        assertThat(client.getClass().getName())\n                .isEqualTo(\"org.apache.kafka.common.security.scram.internals.ScramSaslClient\");\n    }\n\n}\n"}], "isError": false, "timestamp": 1779382131826}}
