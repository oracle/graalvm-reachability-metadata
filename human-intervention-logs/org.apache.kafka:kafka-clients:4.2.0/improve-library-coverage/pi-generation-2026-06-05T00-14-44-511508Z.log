"call_DU2IuCHHYEf0XNg7pF6WIfWL|fc_07cd1840f52c1c0a016a2214aa0f3481958e79baaabbac4584", "name": "write", "arguments": {"path": "tests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaShadedComGoogleProtobufGeneratedMessageLiteInnerSerializedFormTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_kafka.kafka_clients;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.OutputStream;\nimport java.util.Arrays;\n\nimport org.apache.kafka.shaded.com.google.protobuf.ByteString;\nimport org.apache.kafka.shaded.com.google.protobuf.CodedInputStream;\nimport org.apache.kafka.shaded.com.google.protobuf.CodedOutputStream;\nimport org.apache.kafka.shaded.com.google.protobuf.ExtensionRegistryLite;\nimport org.apache.kafka.shaded.com.google.protobuf.GeneratedMessageLite.SerializedForm;\nimport org.apache.kafka.shaded.com.google.protobuf.InvalidProtocolBufferException;\nimport org.apache.kafka.shaded.com.google.protobuf.MessageLite;\nimport org.apache.kafka.shaded.com.google.protobuf.Parser;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgApacheKafkaShadedComGoogleProtobufGeneratedMessageLiteInnerSerializedFormTest {\n\n    @Test\n    void serializedFormResolvesDefaultInstanceAfterClassNameLookup() throws Exception {\n        byte[] expectedPayload = new byte[] {3, 1, 4, 1, 5};\n        byte[] serializedForm = serializeSerializedFormWithoutMessageClass(new ModernLiteMessage(expectedPayload));\n\n        Object resolved = deserialize(serializedForm);\n\n        assertThat(resolved).isInstanceOf(ModernLiteMessage.class);\n        assertThat(((ModernLiteMessage) resolved).payload()).isEqualTo(expectedPayload);\n    }\n\n    @Test\n    void serializedFormUsesLegacyDefaultInstanceFallback() throws Exception {\n        byte[] expectedPayload = new byte[] {2, 7, 1, 8};\n        byte[] serializedForm = serializeSerializedForm(new LegacyLiteMessage(expectedPayload));\n\n        Object resolved = deserialize(serializedForm);\n\n        assertThat(resolved).isInstanceOf(LegacyLiteMessage.class);\n        assertThat(((LegacyLiteMessage) resolved).payload()).isEqualTo(expectedPayload);\n    }\n\n    private static byte[] serializeSerializedForm(MessageLite message) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(SerializedForm.of(message));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serializeSerializedFormWithoutMessageClass(MessageLite message) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new NullMessageClassObjectOutputStream(bytes, message.getClass())) {\n            output.writeObject(SerializedForm.of(message));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedForm) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedForm))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class NullMessageClassObjectOutputStream extends ObjectOutputStream {\n        private final Class<?> messageClass;\n\n        NullMessageClassObjectOutputStream(OutputStream output, Class<?> messageClass) throws IOException {\n            super(output);\n            this.messageClass = messageClass;\n            enableReplaceObject(true);\n  