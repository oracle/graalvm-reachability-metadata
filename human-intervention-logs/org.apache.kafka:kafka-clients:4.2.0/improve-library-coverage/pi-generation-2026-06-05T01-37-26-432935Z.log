wOy|fc_0cc1c6e800be8e7c016a222811ae0c8197a91e94687b686f71", "name": "write", "arguments": {"path": "tests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaCommonSecurityKerberosKerberosErrorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_kafka.kafka_clients;\n\nimport org.apache.kafka.common.security.kerberos.KerberosError;\nimport org.junit.jupiter.api.Test;\n\nimport sun.security.krb5.KrbException;\n\nimport javax.security.sasl.SaslException;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OrgApacheKafkaCommonSecurityKerberosKerberosErrorTest {\n\n    @Test\n    void testKerberosErrorRecognizesRetriableKrbExceptionCause() throws Exception {\n        String previousVendor = System.getProperty(\"java.vendor\");\n        System.setProperty(\"java.vendor\", \"IBM Corporation\");\n        try {\n            SaslException exception = new SaslException(\"server principal is unknown\", new KrbException(7));\n\n            KerberosError error = KerberosError.fromException(exception);\n\n            assertThat(error).isEqualTo(KerberosError.SERVER_NOT_FOUND);\n            assertThat(error.retriable()).isFalse();\n        } finally {\n            if (previousVendor == null) {\n                System.clearProperty(\"java.vendor\");\n            } else {\n                System.setProperty(\"java.vendor\", previousVendor);\n            }\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaCommonSecurityKerberosKerberosErrorTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_kafka.kafka_clients;\\n\\nimport org.apache.kafka.common.security.kerberos.KerberosError;\\nimport org.junit.jupiter.api.Test;\\n\\nimport sun.security.krb5.KrbException;\\n\\nimport javax.security.sasl.SaslException;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class OrgApacheKafkaCommonSecurityKerberosKerberosErrorTest {\\n\\n    @Test\\n    void testKerberosErrorRecognizesRetriableKrbExceptionCause() throws Exception {\\n        String previousVendor = System.getProperty(\\\"java.vendor\\\");\\n        System.setProperty(\\\"java.vendor\\\", \\\"IBM Corporation\\\");\\n        try {\\n            SaslException exception = new SaslException(\\\"server principal is unknown\\\", new KrbException(7));\\n\\n            KerberosError error = KerberosError.fromException(exception);\\n\\n            assertThat(error).isEqualTo(KerberosError.SERVER_NOT_FOUND);\\n            assertThat(error.retriable()).isFalse();\\n        } finally {\\n            if (previousVendor == null) {\\n                System.clearProperty(\\\"java.vendor\\\");\\n            } else {\\n                System.setProperty(\\\"java.vendor\\\", previousVendor);\\n            }\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 462, "output": 1212, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 25738, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780623354954, "responseId": "resp_0cc1c6e800be8e7c016a2227fb978c8197bf5a0a261f9020fe"}}
