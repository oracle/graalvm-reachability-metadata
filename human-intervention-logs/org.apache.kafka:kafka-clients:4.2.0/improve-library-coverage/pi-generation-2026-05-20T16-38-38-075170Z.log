          }
      }
  
      private static boolean canLoad(String clazz) {
          try {
              Class.forName(clazz);
              return true;
          } catch (Exception e) {
              return false;
          }
      }
  
      private final int errorCode;
      private final boolean retriable;
  
      KerberosError(int errorCode, boolean retriable) {
          this.errorCode = errorCode;
          this.retriable = retriable;
      }
  
