nsExactlyElementsOf(values);\n        }\n    }\n\n    @Test\n    void deserializesLinkedListUsingDefaultConstructor() {\n        Map<String, Object> configs = new HashMap<>();\n        configs.put(CommonClientConfigs.DEFAULT_LIST_VALUE_SERDE_TYPE_CLASS, LinkedList.class);\n        configs.put(CommonClientConfigs.DEFAULT_LIST_VALUE_SERDE_INNER_CLASS, Serdes.StringSerde.class);\n\n        try (ListSerializer<String> serializer = new ListSerializer<>();\n             ListDeserializer<String> deserializer = new ListDeserializer<>()) {\n            serializer.configure(configs, false);\n            deserializer.configure(configs, false);\n\n            List<String> values = Arrays.asList(\"alpha\", null, \"omega\");\n            List<String> deserialized = deserializer.deserialize(\"list-topic\", serializer.serialize(\"list-topic\", values));\n\n            assertThat(deserialized)\n                    .isInstanceOf(LinkedList.class)\n                    .containsExactlyElementsOf(values);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1655, "output": 1164, "cacheRead": 35840, "cacheWrite": 0, "totalTokens": 38659, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779371972054, "responseId": "resp_0f0e09115fad8eb0016a0f0fc486b08191b2b2193c1937b404"}}
