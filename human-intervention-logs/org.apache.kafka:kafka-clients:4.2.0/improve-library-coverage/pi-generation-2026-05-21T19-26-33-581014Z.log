          } else {
              UNMAP = null;
              UNMAP_NOT_SUPPORTED_EXCEPTION = exception;
          }
      }
  
      private ByteBufferUnmapper() {}
  
      /**
       * Unmap the provided mapped or direct byte buffer.
       *
