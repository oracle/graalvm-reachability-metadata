              consumer.addRecord(new ConsumerRecord<>("test_topic", 0, 1L, 1, "message1"));
  
              ConsumerRecords<Integer, String> records = consumer.poll(Duration.ofMillis(100));
              for (ConsumerRecord<Integer, String> record : records) {
