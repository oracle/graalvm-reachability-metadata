  17: package org.apache.kafka.common.internals;
  18: 
  19: import java.util.concurrent.CompletableFuture;
  20: import java.util.concurrent.Executor;
  21: import java.util.concurrent.TimeUnit;
  22: import java.util.function.Supplier;
  23: 
  24: /**
  25:  * This internal class exists because CompletableFuture exposes complete(), completeExceptionally() and
  26:  * other methods which would allow erroneous completion by user code of a KafkaFuture returned from a
  27:  * Kafka API to a client application.
  28:  * @param <T> The type of the future value.
  29:  */
  30: public class KafkaCompletableFuture<T> extends CompletableFuture<T> {
  31: 
  32:     /**
  33:      * Completes this future normally. For internal use by the Kafka clients, not by user code.
  34:      * @param value the result value
  35:      * @return {@code true} if this invocation caused this CompletableFuture
  36:      * to transition to a completed state, else {@code false}
  37:      */
  38:     boolean kafkaComplete(T value) {
  39:         return super.complete(value);
  40:     }
  41: 
  42:     /**
  43:      * Completes this future exceptionally. For internal use by the Kafka clients, not by user code.
  44:      * @param throwable the exception.
  45:      * @return {@code true} if this invocation caused this CompletableFuture
  46:      * to transition to a completed state, else {@code false}
  47:      */
  48:     boolean kafkaCompleteExceptionally(Throwable throwable) {
  49:         return super.completeExceptionally(throwable);
  50:     }
  51: 
  52:     @Override
  53:     public boolean complete(T value) {
  54:         throw erroneousCompletionException();
  55:     }
  56: 
  57:     @Override
  58:     public boolean completeExceptionally(Throwable ex) {
  59:         throw erroneousCompletionException();
  60:     }
  61: 
  62:     @Override
  63:     public void obtrudeValue(T value) {
  64:         throw erroneousCompletionException();
  65:     }
  66: 
  67:     @Override
  68:     public void obtrudeException(Throwable ex) {
  69:         throw erroneousCompletionException();
  70:     }
  71: 
  72:     @Override
  73:     public <U> CompletableFuture<U> newIncompleteFuture() {
  74:         return new KafkaCompletableFuture<>();
  75:     }
  76: 
  77:     @Override
  78:     public CompletableFuture<T> completeAsync(Supplier<? extends T> supplier, Executor executor) {
  79:         throw erroneousCompletionException();
  80:     }
  81: 
  82:     @Override
  83:     public CompletableFuture<T> completeAsync(Supplier<? extends T> supplier) {
  84:         throw erroneousCompletionException();
  85:     }
  86: 
  87:     @Override
  88:     public CompletableFuture<T> completeOnTimeout(T value, long timeout, TimeUnit unit) {
  89:         throw erroneousCompletionException();
  90:     }
