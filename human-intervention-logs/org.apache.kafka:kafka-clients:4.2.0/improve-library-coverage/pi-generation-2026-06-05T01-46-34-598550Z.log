  package org_apache_kafka.kafka_clients;
  
  import org.apache.kafka.common.utils.LoggingSignalHandler;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThatCode;
  
  public class OrgApacheKafkaCommonUtilsLoggingSignalHandlerTest {
  
      @Test
      void registersLoggingSignalHandlers() {
          assertThatCode(() -> new LoggingSignalHandler().register())
                  .doesNotThrowAnyException();
