f", "name": "edit", "arguments": {"path": "tests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaCommonUtilsLoggingSignalHandlerTest.java", "edits": [{"oldText": "import org.apache.kafka.common.utils.LoggingSignalHandler;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThatCode;\n", "newText": "import org.apache.kafka.common.utils.LoggingSignalHandler;\nimport org.junit.jupiter.api.Test;\nimport sun.misc.Signal;\nimport sun.misc.SignalHandler;\n\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatCode;\n"}, {"oldText": "    @Test\n    void registersLoggingSignalHandlers() {\n        assertThatCode(() -> new LoggingSignalHandler().register())\n                .doesNotThrowAnyException();\n    }\n", "newText": "    @Test\n    void registersLoggingSignalHandlers() {\n        assertThatCode(() -> new LoggingSignalHandler().register())\n                .doesNotThrowAnyException();\n    }\n\n    @Test\n    void delegatesRaisedSignalToPreviousSignalHandler() throws Exception {\n        CountDownLatch previousHandlerInvoked = new CountDownLatch(1);\n        Map<Signal, SignalHandler> originalHandlers = new LinkedHashMap<>();\n        Signal hup = new Signal(\"HUP\");\n\n        try {\n            for (String signalName : new String[] {\"TERM\", \"INT\", \"HUP\"}) {\n                Signal signal = new Signal(signalName);\n                SignalHandler previousHandler = Signal.handle(signal, handledSignal -> {\n                    if (\"HUP\".equals(handledSignal.getName())) {\n                        previousHandlerInvoked.countDown();\n                    }\n                });\n                originalHandlers.put(signal, previousHandler);\n            }\n\n            new LoggingSignalHandler().register();\n            Signal.raise(hup);\n\n            assertThat(previousHandlerInvoked.await(5, TimeUnit.SECONDS)).isTrue();\n        } finally {\n            for (Map.Entry<Signal, SignalHandler> originalHandler : originalHandlers.entrySet()) {\n                Signal.handle(originalHandler.getKey(), originalHandler.getValue());\n            }\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 357, "output": 949, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 17178, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779382999989, "responseId": "resp_08f23d53e5f86dbc016a0f3ad85868819692afeb256db7b2ac"}}
