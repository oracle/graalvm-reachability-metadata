          try {
              descriptor = extension.getDescriptor();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
              return;
          }
  
          assertThat(descriptor.getName()).isEqualTo("extra");
          assertThat(descriptor.getMessageType().getName()).isEqualTo("ExtensionValue");
      }
  
      public static final class DescriptorHolder {
          public static final Descriptors.FileDescriptor descriptor = buildDescriptor();
          public static final DynamicMessage extensionValueDefaultInstance = DynamicMessage.getDefaultInstance(
                  descriptor.findMessageTypeByName("ExtensionValue"));
  
          private DescriptorHolder() {
          }
  
          private static Descriptors.FileDescriptor buildDescriptor() {
              DescriptorProtos.DescriptorProto container = DescriptorProtos.DescriptorProto.newBuilder()
                      .setName("Container")
