rc/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/SaslOauthbearerDefaultsTest.java\ntests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaCommonUtilsLoggingSignalHandlerTest.java\ntests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaShadedComGoogleProtobufGeneratedMessageLiteInnerSerializedFormTest.java\ntests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaShadedComGoogleProtobufDescriptorMessageInfoFactoryTest.java\ntests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaCommonSerializationListDeserializerTest.java\ntests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/KafkaClientsTest.java\ntests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaCommonUtilsChildFirstClassLoaderTest.java\ntests/src/org.apache.kafka/kafka-clients/4.2.0/src/test/java/org_apache_kafka/kafka_clients/OrgApacheKafkaCommonNetworkSelectorTestTest.java\n","exit_code":0,"status":"completed"}}
