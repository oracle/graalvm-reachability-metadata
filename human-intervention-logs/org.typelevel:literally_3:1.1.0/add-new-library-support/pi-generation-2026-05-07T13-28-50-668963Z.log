[tool-call] delta {"path":"tests/src/org.typelevel/literally_3/1.1.0/src/test/scala/org_typelevel/literally_3/Literally_3Test.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_typelevel.literally_3\n\nimport java.util.Locale\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.typelevel.literally.Literally\nimport scala.compiletime.testing.{typeCheckErrors, typeChecks}\nimport scala.quoted.{Expr, Quotes}\n\nclass Literally_3Test {\n  import Literally_3TestSyntax.*\n\n  @Test\n  def validatedIntegerLiteralsExpandToRuntimeValues(): Unit = {\n    val singleDigit: Int = positiveInt\"7\"\n    val answer: Int = positiveInt\"40\" + positiveInt\"2\"\n    val maximum: Int = positiveInt\"2147483647\"\n\n    assertThat(singleDigit).isEqualTo(7)\n    assertThat(answer).isEqualTo(42)\n    assertThat(maximum).isEqualTo(Int.MaxValue)\n  }\n\n  @Test\n  def independentLiteralImplementationsCanTransformValidatedInput(): Unit = {\n    val releaseToken: String = normalizedToken\"Release_Candidate-1\"\n    val map: Map[String, Int] = Map(\n      normalizedToken\"Primary_Node\" -> positiveInt\"1\",\n      normalizedToken\"Backup_Node\" -> positiveInt\"2\"\n    )\n\n    assertThat(releaseToken).isEqualTo(\"release_candidate-1\")\n    assertThat(map).containsEntry(\"primary_node\", 1)\n    assertThat(map).containsEntry(\"backup_node\", 2)\n  }\n\n  @Test\n  def validCustomInterpolatorsTypeCheckAtCompileTime(): Unit = {\n    val positiveIntCode: String =\n      \"\"\"import org_typelevel.literally_3.Literally_3TestSyntax.*\n        |positiveInt\"12345\"\n        |\"\"\".stripMargin\n    val normalizedTokenCode: String =\n      \"\"\"import org_typelevel.literally_3.Literally_3TestSyntax.*\n        |normalizedToken\"Alpha_Beta-9\"\n        |\"\"\".stripMargin\n\n    assertThat(typeChecks(positiveIntCode)).isTrue\n    assertThat(typeChecks(normalizedTokenCode)).isTrue\n  }\n\n  @Test\n  def validationFailuresAreReportedAsCompileTimeErrors(): Unit = {\n    val invalidNumberErrors = typeCheckErrors(\n      \"\"\"import org_typelevel.literally_3.Literally_3TestSyntax.*\n        |positiveInt\"0\"\n        |\"\"\".stripMargin\n    )\n    val invalidTokenErrors = typeCheckErrors(\n      \"\"\"import org_typelevel.literally_3.Literally_3TestSyntax.*\n        |normalizedToken\"contains spaces\"\n        |\"\"\".stripMargin\n    )\n\n    assertThat(renderMessages(invalidNumberErrors))\n      .contains(\"Expected a positive base-10 integer literal, got: 0\")\n    assertThat(renderMessages(invalidTokenErrors))\n      .contains(\"Expected an ASCII token literal, got: contains spaces\")\n  }\n\n  @Test\n  def interpolationArgumentsAreRejectedByTheDefaultLiteralApplyMethod(): Unit = {\n    val interpolationErrors = typeCheckErrors(\n      \"\"\"import org_typelevel.literally_3.Literally_3TestSyntax.*\n        |val suffix = 3\n        |positiveInt\"12$suffix\"\n        |\"\"\".stripMargin\n    )\n\n    assertThat(renderMessages(interpolationErrors)).contains(\"interpolation not supported\")\n  }\n\n  @Test\n  def literalInstancesAreOrdinaryRuntimeValuesAfterExpansion(): Unit = {\n    assertThat(PositiveInt).isNotNull\n    assertThat(PositiveInt.Expr).isNotNull\n    assertThat(NormalizedToken).isNotNull\n    assertThat(NormalizedToken.Expr).isNotNull\n  }\n\n  private def renderMessages(errors: List[scala.compiletime.testing.Error]): String =\n    errors.map(_.message).mkString(\"\\n\")\n}\n\nobject Literally_3TestSyntax {\n  object PositiveInt extends Literally[Int] {\n    override def validate(s: String)(using Quotes): Either[String, Expr[Int]] =\n      s.toIntOption match {\n        case Some(value) if value > 0 => Right(Expr(value))\n        case _ => Left(s\"Expected a positive base-10 integer literal, got: $s\")\n      }\n  }\n\n  object NormalizedToken extends Literally[String] {\n    override def validate(s: String)(using Quotes): Either[String, Expr[String]] =\n      if s.matches(\"[A-Za-z][A-Za-z0-9_-]*\") then Right(Expr(s.toLowerCase(Locale.ROOT)))\n      else Left(s\"Expected an ASCII token literal, got: $s\")\n  }\n\n  extension (inline context: StringContext) {\n    inline def positiveInt(inline args: Any*): Int = ${ PositiveInt('context, 'args) }\n\n    inline def normalizedToken(inline args: Any*): String = ${ NormalizedToken('context, 'args) }\n  }\n}\n"}
