malizedToken extends Literally[String] {\n    override def validate(s: String)(using Quotes): Either[String, Expr[String]] =\n      if s.matches(\"[A-Za-z][A-Za-z0-9_-]*\") then Right(Expr(s.toLowerCase(Locale.ROOT)))\n      else Left(s\"Expected an ASCII token literal, got: $s\")\n  }\n\n  extension (inline context: StringContext) {\n    inline def positiveInt(inline args: Any*): Int = ${ PositiveInt('context, 'args) }\n\n    inline def normalizedToken(inline args: Any*): String = ${ NormalizedToken('context, 'args) }\n  }\n}\n", "newText": "\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 25385, "output": 1446, "cacheRead": 7168, "cacheWrite": 0, "totalTokens": 33999, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778160559571, "responseId": "resp_0b727821520cb5c80169fc93b0f3b4819293668ccb23f3176c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_vpscmJfO6hvDOZrdAnbh8HVR|fc_0b727821520cb5c80169fc93c162f481929a7438fd0cb3ba77", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/org.typelevel/literally_3/1.1.0/src/test/scala/org_typelevel/literally_3/Literally_3Test.scala."}], "details": {"diff": "     ...\n   5  * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n   6  */\n   7 package org_typelevel.literally_3\n   8 \n-  9 import java.util.Locale\n  10 import org.assertj.core.api.Assertions.assertThat\n  11 import org.junit.jupiter.api.Test\n- 12 import org.typelevel.literally.Literally\n  13 import scala.compiletime.testing.{typeCheckErrors, typeChecks}\n- 14 import scala.quoted.{Expr, Quotes}\n  15 \n  16 class Literally_3Test {\n  17   import Literally_3TestSyntax.*\n  18 \n     ...\n  97   private def renderMessages(errors: List[scala.compiletime.testing.Error]): String =\n  98     errors.map(_.message).mkString(\"\\n\")\n  99 }\n 100 \n-101 object Literally_