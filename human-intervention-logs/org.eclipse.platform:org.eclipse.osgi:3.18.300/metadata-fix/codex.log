l\";\n    private static final String RUNTIME_CONTEXT = \"runtime\";\n    private static final String INITIAL_PID = LOG_ADMIN_PID + \"|\" + INITIAL_CONTEXT;\n    private static final String RUNTIME_PID = LOG_ADMIN_PID + \"|\" + RUNTIME_CONTEXT;\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void configurationAdminServiceConfiguresLoggerContextsAtStartupAndFromEvents() throws Exception {\n        Framework framework = new EquinoxFactory().newFramework(frameworkConfiguration());\n        boolean started = false;\n        try {\n            framework.start();\n            started = true;\n            BundleContext context = framework.getBundleContext();\n            LoggerAdmin loggerAdmin = waitForService(context, LoggerAdmin.class);\n\n            TestConfigurationAdmin configurationAdmin = new TestConfigurationAdmin();\n            configurationAdmin.put(\n                            new TestConfiguration(INITIAL_PID, null, logLevels(\"startup.logger\", LogLevel.DEBUG)));\n            ServiceRegistration<ConfigurationAdmin> registration = context.registerService(ConfigurationAdmin.class,\n                            configurationAdmin, null);\n\n            SynchronousConfigurationListener listener = waitForService(context, SynchronousConfigurationListener.class);\n            assertThat(loggerAdmin.getLoggerContext(INITIAL_CONTEXT).getLogLevels())\n                            .containsEntry(\"startup.logger\", LogLevel.DEBUG);\n\n            configurationAdmin.put(new TestConfiguration(RUNTIME_PID, null, logLevels(\"event.logger\", LogLevel.ERROR)));\n            listener.configurationEvent(\n                            new ConfigurationEvent(registration.getReference(), ConfigurationEvent.CM_UPDATED, null,\n                                            RUNTIME_PID));\n            assertThat(loggerAdmin.getLoggerContext(RUNTIME_CONTEXT).getLogLevels())\n                            .containsEntry(\"event.logger\", LogLevel.ERROR);\n        } finally {\n            if (started) {\n                framework.stop();\n                framework.waitForStop(TimeUnit.SECONDS.toMillis(5));\n            }\n        }\n    }\n\n    private Map<String, String> frameworkConfiguration() {\n        Map<String, String> configuration = new HashMap<>();\n        configuration.put(Constants.FRAMEWORK_STORAGE, temporaryDirectory.resolve(\"framework\").toString());\n        configuration.put(Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT);\n        configuration.put(Constants.FRAMEWORK_BUNDLE_PARENT, Constants.FRAMEWORK_BUNDLE_PARENT_APP);\n        configuration.put(Constants.FRAMEWORK_BOOTDELEGATION, \"org.osgi.service.cm.*\");\n        configuration.put(Constants.FRAMEWORK_SYSTEMPACKAGES_EXTRA,\n                        \"org.osgi.service.cm;version=\\\"1.6\\\",org.osgi.service.cm.annotations;version=\\\"1.6\\\"\");\n        return configuration;\n    }\n\n    private static Dictionary<String, Object> logLevels(String loggerName, LogLevel level) {\n        Hashtable<String, Object> properties = new Hashtable<>();\n        properties.put(loggerName, level.name());\n        return properties;\n    }\n\n    private static <T> T waitForService(BundleContext context, Class<T> serviceType) throws InterruptedException {\n        long deadline = System.nanoTime() + TimeUnit.SECONDS.toNanos(5);\n        while (System.nanoTime() < deadline) {\n            ServiceReference<T> reference = context.getServiceReference(serviceType);\n            if (reference != null) {\n                T service = context.getService(reference);\n                if (service != null) {\n                    return service;\n                }\n            }\n            Thread.sleep(10L);\n        }\n        ServiceReference<T> reference = context.getServiceReference(serviceType);\n        assertThat(reference).as(\"service reference for %s\", serviceType.getName()).isNotNull();\n        T service = context.getService(reference);\n        assertThat(service).as(\"service instance for %s\", serviceType.getName()).isNotNull();\n        return service;\n    }\n\n    private static final class TestConfigurationAdmin implements ConfigurationAdmin {\n        private final Map<String, TestConfiguration> configurations = new HashMap<>();\n\n        void put(TestConfiguration configuration) {\n            configurations.put(configuration.getPid(), configuration);\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid) throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration creation is not used by this test\");\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid, String location) throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration creation is not used by this test\");\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid, String location) throws IOException {\n            return configurations.get(pid);\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid) throws IOException {\n            return getConfiguration(pid, null);\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(String factoryPid, String name, String location)\n                        throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration lookup is not used by this test\");\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(String factoryPid, String name) throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration lookup is not used by this test\");\n        }\n\n        @Override\n        public Configuration[] listConfigurations(String filter) throws IOException, InvalidSyntaxException {\n            return configurations.values().toArray(Configuration[]::new);\n        }\n    }\n\n    private static final class TestConfiguration implements Configuration {\n        private final String pid;\n        private final String factoryPid;\n        private Dictionary<String, Object> properties;\n\n        TestConfiguration(String pid, String factoryPid, Dictionary<String, Object> properties) {\n            this.pid = pid;\n            this.factoryPid = factoryPid;\n            this.properties = properties;\n        }\n\n        @Override\n        public String getPid() {\n            return pid;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProperties() {\n            return properties;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProcessedProperties(ServiceReference<?> reference) {\n            return properties;\n        }\n\n        @Override\n        public void update(Dictionary<String, ?> newProperties) throws IOException {\n            properties = copy(newProperties);\n        }\n\n        @Override\n        public void delete() throws IOException {\n            properties = new Hashtable<>();\n        }\n\n        @Override\n        public String getFactoryPid() {\n            return factoryPid;\n        }\n\n        @Override\n        public void update() throws IOException {\n            // The in-memory configuration is already current.\n        }\n\n        @Override\n        public boolean updateIfDifferent(Dictionary<String, ?> newProperties) throws IOException {\n            update(newProperties);\n            return true;\n        }\n\n        @Override\n        public void setBundleLocation(String location) {\n            // Bundle locations are irrelevant for logger context configuration.\n        }\n\n        @Override\n        public String getBundleLocation() {\n\n---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not