piter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.osgi.framework.Bundle;\nimport org.osgi.framework.BundleContext;\nimport org.osgi.framework.BundleException;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.launch.Framework;\n\npublic class MultiplexingURLStreamHandlerTest {\n    private static final String PROTOCOL = \"multiplexed\";\n\n    @TempDir\n    Path storage;\n\n    @Test\n    void delegatesUrlStreamHandlerOperationsToAuthorizedHandler() throws Exception {\n        Framework framework = newFramework();\n        framework.init();\n        framework.start();\n        try {\n            RecordingUrlStreamHandler authorizedHandler = new RecordingUrlStreamHandler();\n            ExposedMultiplexingUrlStreamHandler handler = new ExposedMultiplexingUrlStreamHandler(\n                    PROTOCOL, new TestUrlStreamHandlerFactory(framework.getBundleContext(), authorizedHandler),\n                    authorizedHandler);\n            URL firstUrl = url(\"multiplexed://localhost:42/alpha?one#fragment\");\n            URL secondUrl = url(\"multiplexed://localhost:42/alpha?two#fragment\");\n\n            assertThat(handler.connect(firstUrl)).isSameAs(authorizedHandler.connection);\n            assertThat(handler.connect(firstUrl, proxy())).isSameAs(authorizedHandler.proxyConnection);\n            assertThat(handler.areEqual(firstUrl, secondUrl)).isTrue();\n            assertThat(handler.defaultPort()).isEqualTo(1717);\n            assertThat(handler.hostAddress(firstUrl)).isEqualTo(InetAddress.getLoopbackAddress());\n            assertThat(handler.urlHashCode(firstUrl)).isEqualTo(31337);\n            assertThat(handler.haveEqualHosts(firstUrl, secondUrl)).isTrue();\n            assertThat(handler.haveSameFile(firstUrl, secondUrl)).isTrue();\n            assertThat(handler.externalForm(firstUrl)).isEqualTo(\"authorized:multiplexed://localhost:42/alpha?one\");\n\n            URL parsedUrl = url(\"multiplexed://initial.example/original\");\n            handler.parse(parsedUrl, \"multiplexed://parsed.example:77/updated?query\", 0,\n                    \"multiplexed://parsed.example:77/updated?query\".length());\n            assertThat(parsedUrl.getHost()).isEqualTo(\"parsed.example\");\n            assertThat(parsedUrl.getPort()).isEqualTo(77);\n            assertThat(parsedUrl.getPath()).isEqualTo(\"/updated\");\n            assertThat(parsedUrl.getQuery()).isEqualTo(\"query\");\n\n            URL updatedUrl = url(\"multiplexed://before.example/original\");\n            handler.updateUrl(updatedUrl, PROTOCOL, \"changed.example\", 9191, null, null, \"/changed\", \"q=1\",\n                    \"fragment\");\n            assertThat(updatedUrl.getHost()).isEqualTo(\"changed.example\");\n            assertThat(updatedUrl.getPort()).isEqualTo(9191);\n            assertThat(updatedUrl.getPath()).isEqualTo(\"/changed\");\n            assertThat(updatedUrl.getQuery()).isEqualTo(\"q=1\");\n            assertThat(updatedUrl.getRef()).isEqualTo(\"fragment\");\n\n            assertThat(authorizedHandler.openConnectionCalls).isEqualTo(1);\n            assertThat(authorizedHandler.openConnectionWithProxyCalls).isEqualTo(1);\n            assertThat(authorizedHandler.equalsCalls).isEqualTo(1);\n            assertThat(authorizedHandler.defaultPortCalls).isEqualTo(1);\n            assertThat(authorizedHandler.hostAddressCalls).isEqualTo(1);\n            assertThat(authorizedHandler.hashCodeCalls).isEqualTo(1);\n            assertThat(authorizedHandler.hostsEqualCalls).isEqualTo(1);\n            assertThat(authorizedHandler.parseUrlCalls).isEqualTo(1);\n            assertThat(authorizedHandler.sameFileCalls).isEqualTo(1);\n            assertThat(authorizedHandler.setUrlCalls).isEqualTo(1);\n            assertThat(authorizedHandler.toExternalFormCalls).isEqualTo(1);\n        } finally {\n            stopFramework(framework);\n        }\n    }\n\n    private Framework newFramework() {\n        return new EquinoxFactory().newFramework(Map.of(\n                Constants.FRAMEWORK_STORAGE, storage.toString(),\n                Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT));\n    }\n\n    private static URL url(String spec) throws IOException {\n        return new URL(null, spec, new PassiveUrlStreamHandler());\n    }\n\n    private static Proxy proxy() {\n        return new Proxy(Proxy.Type.HTTP, InetSocketAddress.createUnresolved(\"proxy.example\", 8080));\n    }\n\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\n        if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING)) != 0) {\n            framework.stop();\n            framework.waitForStop(10_000L);\n        }\n    }\n\n    private static final class ExposedMultiplexingUrlStreamHandler extends MultiplexingURLStreamHandler {\n        ExposedMultiplexingUrlStreamHandler(\n                String protocol, URLStreamHandlerFactoryImpl factory, URLStreamHandler authorized) {\n            super(protocol, factory, authorized);\n        }\n\n        URLConnection connect(URL url) throws IOException {\n            return openConnection(url);\n        }\n\n        URLConnection connect(URL url, Proxy proxy) throws IOException {\n            return openConnection(url, proxy);\n        }\n\n        boolean areEqual(URL firstUrl, URL secondUrl) {\n            return equals(firstUrl, secondUrl);\n        }\n\n        int defaultPort() {\n            return getDefaultPort();\n        }\n\n        InetAddress hostAddress(URL url) {\n            return getHostAddress(url);\n        }\n\n        int urlHashCode(URL url) {\n            return hashCode(url);\n        }\n\n        boolean haveEqualHosts(URL firstUrl, URL secondUrl) {\n            return hostsEqual(firstUrl, secondUrl);\n        }\n\n        void parse(URL url, String spec, int start, int limit) {\n            parseURL(url, spec, start, limit);\n        }\n\n        boolean haveSameFile(URL firstUrl, URL secondUrl) {\n            return sameFile(firstUrl, secondUrl);\n        }\n\n        void updateUrl(URL url, String protocol, String host, int port, String authority, String userInfo, String path,\n                String query, String reference) {\n            setURL(url, protocol, host, port, authority, userInfo, path, query, reference);\n        }\n\n        String externalForm(URL url) {\n            return toExternalForm(url);\n        }\n    }\n\n    private static final class TestUrlStreamHandlerFactory extends URLStreamHandlerFactoryImpl {\n        private final URLStreamHandler authorizedHandler;\n\n        TestUrlStreamHandlerFactory(BundleContext context, URLStreamHandler authorizedHandler) {\n            super(context, (EquinoxContainer) null);\n            this.authorizedHandler = authorizedHandler;\n        }\n\n        @Override\n        protected URLStreamHandler findAuthorizedURLStreamHandler(String protocol) {\n            return authorizedHandler;\n        }\n    }\n\n    private static class RecordingUrlStreamHandler extends URLStreamHandler {\n        final URLConnection connection = new NoOpURLConnection();\n        final URLConnection proxyConnection = new NoOpURLConnection();\n        int openConnectionCalls;\n        int openConnectionWithProxyCalls;\n        int equalsCalls;\n        int defaultPortCalls;\n        int hostAddressCalls;\n        int hashCodeCalls;\n        int hostsEqualCalls;\n        int parseUrlCalls;\n        int sameFileCalls;\n        int setUrlCalls;\n        int toExternalFormCalls;\n\n        @Override\n        protected URLConnection openConnection(URL url) {\n            openConnectionCalls++;\n            return connection;\n        }\n\n        @Override\n        protected URLConnection openConnection(URL url, Proxy proxy) {\n            openConnectionWithProxyCalls++;\n            return proxyConnection;\n        }\n\n        @Override\n        protected boolean equals(URL firstUrl, URL secondUrl) {\n            equalsCalls++;\n            return firstUrl.getHost().equals(secondUrl.getHost());\n        }\n\n        @Override\n        protected int getDefaultPort() {\n            defaultPortCalls++;\n            return 1717;\n        }\n\n        @Override\n        protected InetAddress getHostAddress(URL url) {\n            hostAddressCalls++;\n            return InetAddress.getLoopbackAddress();\n        }\n\n        @Override\n        protected int hashCode(URL url) {\n            hashCodeCalls++;\n            return 31337;\n        }\n\n        @Override\n        protected boolean hostsEqual(URL firstUrl, URL secondUrl) {\n            hostsEqualCalls++;\n            return firstUrl.getHost().equals(secondUrl.getHost());\n        }\n\n        @Override\n        protected void parseURL(URL url, String spec, int start, int limit) {\n            parseUrlCalls++;\n            super.parseURL(url, spec, start, limit);\n        }\n\n        @Override\n        protected boolean sameFile(URL firstUrl, URL secondUrl) {\n            sameFileCalls++;\n            return firstUrl.getHost().equals(secondUrl.getHost()) && firstUrl.getPath().equals(secondUrl.getPath());\n        }\n\n        @Override\n        protected void setURL(URL url, String protocol, String host, int port, String authority, String userInfo,\n                String path, String query, String reference) {\n            setUrlCalls++;\n            super.setURL(url, protocol, host, port, authority, userInfo, path, query, reference);\n        }\n\n        @Override\n        protected String toExternalForm(URL url) {\n            toExternalFormCalls++;\n            return \"authorized:\" + url.getProtocol() + \"://\" + url.getHost() + \":\" + url.getPort()\n                    + url.getPath() + \"?\" + url.getQuery();\n        }\n    }\n\n    private static final class PassiveUrlStreamHandler extends URLStreamHandler {\n        @Override\n        protected URLConnection openConnection(URL url) {\n            return new NoOpURLConnection();\n        }\n    }\n\n    private static final class NoOpURLConnection extends URLConnection {\n        NoOpURLConnection() {\n            super(null);\n        }\n\n        @Override\n        public void connect() {\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/MultiplexingURLStreamHandlerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_eclipse_platform.org_eclipse_osgi;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.IOException;\\nimport java.net.InetAddress;\\nimport java.net.InetSocketAddress;\\nimport java.net.Proxy;\\nimport java.net.URL;\\nimport java.net.URLConnection;\\nimport java.net.URLStreamHandler;\\nimport java.nio.file.Path;\\nimport java.util.Map;\\nimport org.eclipse.osgi.internal.framework.EquinoxContainer;\\nimport org.eclipse.osgi.internal.url.MultiplexingURLStreamHandler;\\nimport org.eclipse.osgi.internal.url.URLStreamHandlerFactoryImpl;\\nimport org.eclipse.osgi.launch.EquinoxFactory;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\nimport org.osgi.framework.Bundle;\\nimport org.osgi.framework.BundleContext;\\nimport org.osgi.framework.BundleException;\\nimport org.osgi.framework.Constants;\\nimport org.osgi.framework.launch.Framework;\\n\\npublic class MultiplexingURLStreamHandlerTest {\\n    private static final String PROTOCOL = \\\"multiplexed\\\";\\n\\n    @TempDir\\n    Path storage;\\n\\n    @Test\\n    void delegatesUrlStreamHandlerOperationsToAuthorizedHandler() throws Exception {\\n        Framework framework = newFramework();\\n        framework.init();\\n        framework.start();\\n        try {\\n   