ting frameworks**\\n\\nI’m considering how to approach my tests. I don’t think I need to reflect directly in them. The Framework APIs might need adjustment, and I think I’ll use something like `new EquinoxFactory()`, which looks like it's public. I'll need to check if I should add the dependency for `org.osgi.service.cm` in build.gradle. Is metadata essential if native tests fail? It seems simple, but I need to clarify whether source jars are necessary. I should start writing!\"}]}"}, {"type": "toolCall", "id": "call_wWlx5UW6CHP2KLxvOGmaZZPA|fc_0224c4549ca9daf80169f7c3cd944c81939d7d9130105d6677", "name": "write", "arguments": {"path": "tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/ConfigAdminListenerInnerLoggerContextConfigurationTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.nio.file.Path;\nimport java.util.Collections;\nimport java.util.Dictionary;\nimport java.util.HashMap;\nimport java.util.Hashtable;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.concurrent.TimeUnit;\nimport org.eclipse.osgi.launch.EquinoxFactory;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.osgi.framework.BundleContext;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.InvalidSyntaxException;\nimport org.osgi.framework.ServiceReference;\nimport org.osgi.framework.ServiceRegistration;\nimport org.osgi.framework.launch.Framework;\nimport org.osgi.service.cm.Configuration;\nimport org.osgi.service.cm.Configuration.ConfigurationAttribute;\nimport org.osgi.service.cm.ConfigurationAdmin;\nimport org.osgi.service.cm.ConfigurationEvent;\nimport org.osgi.service.cm.SynchronousConfigurationListener;\nimport org.osgi.service.log.LogLevel;\nimport org.osgi.service.log.admin.LoggerAdmin;\n\npublic class ConfigAdminListenerInnerLoggerContextConfigurationTest {\n    private static final String LOG_ADMIN_PID = \"org.osgi.service.log.admin\";\n    private static final String INITIAL_CONTEXT = \"initial\";\n    private static final String RUNTIME_CONTEXT = \"runtime\";\n    private static final String INITIAL_PID = LOG_ADMIN_PID + \"|\" + INITIAL_CONTEXT;\n    private static final String RUNTIME_PID = LOG_ADMIN_PID + \"|\" + RUNTIME_CONTEXT;\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void configurationAdminServiceConfiguresLoggerContextsAtStartupAndFromEvents() throws Exception {\n        Framework framework = new EquinoxFactory().newFramework(frameworkConfiguration());\n        try {\n            framework.start();\n            BundleContext context = framework.getBundleContext();\n            LoggerAdmin loggerAdmin = waitForService(context, LoggerAdmin.class);\n\n            TestConfigurationAdmin configurationAdmin = new TestConfigurationAdmin();\n            configurationAdmin.put(new TestConfiguration(INITIAL_PID, null, logLevels(\"startup.logger\", LogLevel.DEBUG)));\n            ServiceRegistration<ConfigurationAdmin> registration = context.registerService(ConfigurationAdmin.class,\n                            configurationAdmin, null);\n\n            SynchronousConfigurationListener listener = waitForService(context, SynchronousConfigurationListener.class);\n            assertThat(loggerAdmin.getLoggerContext(INITIAL_CONTEXT).getLogLevels())\n                            .containsEntry(\"startup.logger\", LogLevel.DEBUG);\n\n            configurationAdmin.put(new TestConfiguration(RUNTIME_PID, null, logLevels(\"event.logger\", LogLevel.ERROR)));\n            listener.configurationEvent(new ConfigurationEvent(registration.getReference(), ConfigurationEvent.CM_UPDATED,\n                            null, RUNTIME_PID));\n            assertThat(loggerAdmin.getLoggerContext(RUNTIME_CONTEXT).getLogLevels())\n                            .containsEntry(\"event.logger\", LogLevel.ERROR);\n        } finally {\n            framework.stop();\n            framework.waitForStop(TimeUnit.SECONDS.toMillis(5));\n        }\n    }\n\n    private Map<String, String> frameworkConfiguration() {\n        Map<String, String> configuration = new HashMap<>();\n        configuration.put(Constants.FRAMEWORK_STORAGE, temporaryDirectory.resolve(\"framework\").toString());\n        configuration.put(Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT);\n        configuration.put(Constants.FRAMEWORK_BOOTDELEGATION, \"org.osgi.service.cm.*\");\n        configuration.put(Constants.FRAMEWORK_SYSTEMPACKAGES_EXTRA,\n                        \"org.osgi.service.cm;version=\\\"1.6\\\",org.osgi.service.cm.annotations;version=\\\"1.6\\\"\");\n        return configuration;\n    }\n\n    private static Dictionary<String, Object> logLevels(String loggerName, LogLevel level) {\n        Hashtable<String, Object> properties = new Hashtable<>();\n        properties.put(loggerName, level.name());\n        return properties;\n    }\n\n    private static <T> T waitForService(BundleContext context, Class<T> serviceType) throws InterruptedException {\n        long deadline = System.nanoTime() + TimeUnit.SECONDS.toNanos(5);\n        while (System.nanoTime() < deadline) {\n            ServiceReference<T> reference = context.getServiceReference(serviceType);\n            if (reference != null) {\n                T service = context.getService(reference);\n                if (service != null) {\n                    return service;\n                }\n            }\n            Thread.sleep(10L);\n        }\n        ServiceReference<T> reference = context.getServiceReference(serviceType);\n        assertThat(reference).as(\"service reference for %s\", serviceType.getName()).isNotNull();\n        T service = context.getService(reference);\n        assertThat(service).as(\"service instance for %s\", serviceType.getName()).isNotNull();\n        return service;\n    }\n\n    private static final class TestConfigurationAdmin implements ConfigurationAdmin {\n        private final Map<String, TestConfiguration> configurations = new HashMap<>();\n\n        void put(TestConfiguration configuration) {\n            configurations.put(configuration.getPid(), configuration);\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid) throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration creation is not used by this test\");\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid, String location) throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration creation is not used by this test\");\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid, String location) throws IOException {\n            return configurations.get(pid);\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid) throws IOException {\n            return getConfiguration(pid, null);\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(String factoryPid, String name, String location) throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration lookup is not used by this test\");\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(String factoryPid, String name) throws IOException {\n            throw new UnsupportedOperationException(\"Factory configuration lookup is not used by this test\");\n        }\n\n        @Override\n        public Configuration[] listConfigurations(String filter) throws IOException, InvalidSyntaxException {\n            return configurations.values().toArray(Configuration[]::new);\n        }\n    }\n\n    private static final class TestConfiguration implements Configuration {\n        private final String pid;\n        private final String factoryPid;\n        private Dictionary<String, Object> properties;\n\n        TestConfiguration(String pid, String factoryPid, Dictionary<String, Object> properties) {\n            this.pid = pid;\n            this.factoryPid = factoryPid;\n            this.properties = properties;\n        }\n\n        @Override\n        public String getPid() {\n            return pid;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProperties() {\n            return properties;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProcessedProperties(ServiceReference<?> reference) {\n            return properties;\n        }\n\n        @Override\n        public void update(Dictionary<String, ?> newProperties) throws IOException {\n            properties = copy(newProperties);\n        }\n\n        @Override\n        public void delete() throws IOException {\n            properties = new Hashtable<>();\n        }\n\n        @Override\n        public String getFactoryPid() {\n            return factoryPid;\n        }\n\n        @Override\n        public void update() throws IOException {\n            // The in-memory configuration is already current.\n        }\n\n        @Override\n        public boolean updateIfDifferent(Dictionary<String, ?> newProperties) throws IOException {\n            update(newProperties);\n            return true;\n        }\n\n        @Override\n        public void setBundleLocation(String location) {\n            // Bundle locations are irrelevant for logger context configuration.\n        }\n\n        @Override\n        public String getBundleLocation() {\n            return null;\n        }\n\n        @Override\n        public long getChangeCount() {\n            return 0L;\n        }\n\n        @Override\n        public void addAttributes(ConfigurationAttribute... attrs) throws IOException {\n            // Attributes are irrelevant for logger context configuration.\n        }\n\n        @Override\n        public Set<ConfigurationAttribute> getAttributes() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public void removeAttributes(ConfigurationAttribute... attrs) throws IOException {\n            // Attributes are irrelevant for logger context configuration.\n        }\n\n        private static Dictionary<String, Object> copy(Dictionary<String, ?> source) {\n            Hashtable<String, Object> copy = new Hashtable<>();\n            for (java.util.Enumeration<String> keys = source.keys(); keys.hasMoreElements();) {\n                String key = keys.nextElement();\n                copy.put(key, source.get(key));\n            }\n            return copy;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1565, "output": 3460, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 27041, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777845174044, "responseId": "resp_0224c4549ca9daf80169f7c3b67bec8193952f11dfc7184e7d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wWlx5UW6CHP2KLxvOGmaZZPA|fc_0224c4549ca9daf80169f7c3cd944c81939d7d9130105d6677", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 9865 bytes to tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/ConfigAdminListenerInnerLoggerContextConfigurationTest.java"}], "isError": false, "timestamp": 1777845208800}]}
