  		this.factory = factory;
  	}
  
  	void start() {
  		configTracker.open();
  	}
  
  	void stop() {
  		configTracker.close();
  	}
  
  	private ServiceRegistration<?> registerConfigurationListener(ServiceReference<?> configRef) {
