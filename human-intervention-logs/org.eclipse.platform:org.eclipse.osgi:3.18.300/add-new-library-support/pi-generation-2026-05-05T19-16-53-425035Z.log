[tool-call] delta {"path":"tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/ConfigAdminListenerInnerLoggerContextConfigurationTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.util.Collections;\nimport java.util.Dictionary;\nimport java.util.HashMap;\nimport java.util.Hashtable;\nimport java.util.Map;\nimport java.util.Set;\nimport org.eclipse.osgi.launch.EquinoxFactory;\nimport org.junit.jupiter.api.Test;\nimport org.osgi.framework.BundleException;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.InvalidSyntaxException;\nimport org.osgi.framework.ServiceReference;\nimport org.osgi.framework.ServiceRegistration;\nimport org.osgi.framework.launch.Framework;\nimport org.osgi.service.cm.Configuration;\nimport org.osgi.service.cm.ConfigurationAdmin;\nimport org.osgi.service.cm.ConfigurationEvent;\nimport org.osgi.service.cm.SynchronousConfigurationListener;\nimport org.osgi.service.log.LogLevel;\nimport org.osgi.service.log.admin.LoggerAdmin;\nimport org.osgi.service.log.admin.LoggerContext;\n\npublic class ConfigAdminListenerInnerLoggerContextConfigurationTest {\n    private static final String LOGGER_CONTEXT_PID = \"org.osgi.service.log.admin\";\n    private static final String APPLICATION_CONTEXT = \"application\";\n    private static final String APPLICATION_PID = LOGGER_CONTEXT_PID + \"|\" + APPLICATION_CONTEXT;\n    private static final String LOGGER_NAME = \"sample.logger\";\n\n    @Test\n    void configurationAdminServiceUpdatesLoggerContextThroughRegisteredConfigurationListener() throws Exception {\n        Framework framework = new EquinoxFactory().newFramework(Map.of(\n                Constants.FRAMEWORK_SYSTEMPACKAGES_EXTRA, \"org.osgi.service.cm\",\n                LoggerContext.LOGGER_CONTEXT_DEFAULT_LOGLEVEL, LogLevel.WARN.name()));\n        framework.init();\n        framework.start();\n        try {\n            LoggerAdmin loggerAdmin = getRequiredService(framework, LoggerAdmin.class);\n            MockConfigurationAdmin configurationAdmin = new MockConfigurationAdmin();\n            configurationAdmin.put(new MockConfiguration(APPLICATION_PID, null, dictionaryWithLogLevel(LogLevel.DEBUG)));\n            configurationAdmin.put(new MockConfiguration(LOGGER_CONTEXT_PID + \"|factory\", \"factory.pid\",\n                    dictionaryWithLogLevel(LogLevel.TRACE)));\n\n            ServiceRegistration<ConfigurationAdmin> adminRegistration = framework.getBundleContext()\n                    .registerService(ConfigurationAdmin.class, configurationAdmin, null);\n            try {\n                LoggerContext applicationContext = loggerAdmin.getLoggerContext(APPLICATION_CONTEXT);\n                assertThat(applicationContext.getEffectiveLogLevel(LOGGER_NAME)).isEqualTo(LogLevel.DEBUG);\n\n                SynchronousConfigurationListener listener = getRequiredService(framework,\n                        SynchronousConfigurationListener.class);\n                @SuppressWarnings(\"unchecked\")\n                ServiceReference<ConfigurationAdmin> adminReference = (ServiceReference<ConfigurationAdmin>) adminRegistration\n                        .getReference();\n\n                configurationAdmin.put(new MockConfiguration(APPLICATION_PID, null, dictionaryWithLogLevel(LogLevel.ERROR)));\n                listener.configurationEvent(new ConfigurationEvent(adminReference, ConfigurationEvent.CM_UPDATED, null,\n                        APPLICATION_PID));\n                assertThat(applicationContext.getEffectiveLogLevel(LOGGER_NAME)).isEqualTo(LogLevel.ERROR);\n\n                listener.configurationEvent(new ConfigurationEvent(adminReference, ConfigurationEvent.CM_DELETED, null,\n                        APPLICATION_PID));\n                assertThat(applicationContext.getEffectiveLogLevel(LOGGER_NAME)).isEqualTo(LogLevel.WARN);\n            } finally {\n                adminRegistration.unregister();\n            }\n        } finally {\n            stopFramework(framework);\n        }\n    }\n\n    private static Dictionary<String, Object> dictionaryWithLogLevel(LogLevel level) {\n        Hashtable<String, Object> properties = new Hashtable<>();\n        properties.put(LOGGER_NAME, level.name());\n        properties.put(\"ignored.invalid.level\", \"not-a-log-level\");\n        return properties;\n    }\n\n    private static <T> T getRequiredService(Framework framework, Class<T> serviceClass) throws InterruptedException {\n        long deadline = System.nanoTime() + 10_000_000_000L;\n        while (System.nanoTime() < deadline) {\n            ServiceReference<T> reference = framework.getBundleContext().getServiceReference(serviceClass);\n            if (reference != null) {\n                T service = framework.getBundleContext().getService(reference);\n                if (service != null) {\n                    return service;\n                }\n            }\n            Thread.sleep(25L);\n        }\n        throw new AssertionError(\"Service was not registered: \" + serviceClass.getName());\n    }\n\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\n        framework.stop();\n        framework.waitForStop(10_000L);\n    }\n\n    private static final class MockConfigurationAdmin implements ConfigurationAdmin {\n        private final Map<String, Configuration> configurations = new HashMap<>();\n\n        void put(Configuration configuration) {\n            configurations.put(configuration.getPid(), configuration);\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid, String location) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid, String location) throws IOException {\n            return configurations.get(pid);\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid) throws IOException {\n            return getConfiguration(pid, null);\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(String factoryPid, String name, String location) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(String factoryPid, String name) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration[] listConfigurations(String filter) throws IOException, InvalidSyntaxException {\n            return configurations.values().stream()\n                    .filter(configuration -> configuration.getProperties() != null)\n                    .toArray(Configuration[]::new);\n        }\n    }\n\n    private static final class MockConfiguration implements Configuration {\n        private final String pid;\n        private final String factoryPid;\n        private Dictionary<String, Object> properties;\n\n        MockConfiguration(String pid, String factoryPid, Dictionary<String, Object> properties) {\n            this.pid = pid;\n            this.factoryPid = factoryPid;\n            this.properties = properties;\n        }\n\n        @Override\n        public String getPid() {\n            return pid;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProperties() {\n            return properties;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProcessedProperties(ServiceReference<?> reference) {\n            return getProperties();\n        }\n\n        @Override\n        public void update(Dictionary<String, ?> properties) throws IOException {\n            Hashtable<String, Object> updated = new Hashtable<>();\n            for (java.util.Enumeration<String> keys = properties.keys(); keys.hasMoreElements();) {\n                String key = keys.nextElement();\n                updated.put(key, properties.get(key));\n            }\n            this.properties = updated;\n        }\n\n        @Override\n        public void delete() throws IOException {\n            properties = null;\n        }\n\n        @Override\n        public String getFactoryPid() {\n            return factoryPid;\n        }\n\n        @Override\n        public void update() throws IOException {\n        }\n\n        @Override\n        public boolean updateIfDifferent(Dictionary<String, ?> properties) throws IOException {\n            update(properties);\n            return true;\n        }\n\n        @Override\n        public void setBundleLocation(String location) {\n        }\n\n        @Override\n        public String getBundleLocation() {\n            return null;\n        }\n\n        @Override\n        public long getChangeCount() {\n            return 0L;\n        }\n\n        @Override\n        public void addAttributes(ConfigurationAttribute... attrs) throws IOException {\n        }\n\n        @Override\n        public Set<ConfigurationAttribute> getAttributes() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public void removeAttributes(ConfigurationAttribute... attrs) throws IOException {\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof Configuration)) {\n