  	 *           {@code null}
  	 * @since 1.6
  	 */
  	public Configuration getFactoryConfiguration(String factoryPid, String name,
  			String location) throws IOException;
  
      /**
  	 * Get an existing or new {@code Configuration} object from the persistent
