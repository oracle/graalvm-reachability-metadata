stamp": 1778009357345, "responseId": "resp_02d6fef8a636ae1d0169fa450dbe50819eb8af93fa39521ca4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_bpcQzYnB4SDu8LOIHEPlFWMk|fc_02d6fef8a636ae1d0169fa450fcef8819eaf8771d01f9731d7", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.net.InetAddress;\nimport java.net.InetSocketAddress;\nimport java.net.Proxy;\nimport java.net.URI;\nimport java.net.URL;\nimport java.net.URLConnection;\nimport java.net.URLStreamHandler;\nimport java.nio.file.Path;\nimport java.util.Map;\nimport org.eclipse.osgi.internal.framework.BundleContextImpl;\nimport org.eclipse.osgi.internal.url.MultiplexingURLStreamHandler;\nimport org.eclipse.osgi.internal.url.URLStreamHandlerFactoryImpl;\nimport org.eclipse.osgi.launch.EquinoxFactory;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.osgi.framework.Bundle;\nimport org.osgi.framework.BundleContext;\nimport org.osgi.framework.BundleException;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.launch.Framework;\n\npublic class MultiplexingURLStreamHandlerTest {\n    private static final String PROTOCOL = \"multiplexed\";\n\n    @TempDir\n    Path storage;\n\n    @Test\n    void delegatesUrlStreamHandlerOperationsToAuthorizedHandler() throws Exception {\n        Framework framework = newFramework();\n        framework.init();\n        framework.start();\n        try {\n            RecordingUrlStreamHandler authorizedHandler = new RecordingUrlStreamHandler();\n            ExposedMultiplexingUrlStreamHandler handler = new ExposedMultiplexingUrlStreamHandler(\n                    PROTOCOL, new TestUrlStreamHandlerFactory(framework.getBundleContext(), authorizedHandler),\n                    authorizedHandler);\n            URL firstUrl = url(\"multiplexed://localhost:42/alpha?one#fragment\");\n            URL secondUrl = url(\"multiplexed://localhost:42/alpha?two#fragment\");\n\n            assertThat(handler.connect(firstUrl)).isSameAs(authorizedHandler.connection);\n            assertThat(handler.connect(firstUrl, proxy())).isSameAs(authorizedHandler.proxyConnection);\n            assertThat(handler.areEqual(firstUrl, secondUrl)).isTrue();\n            assertThat(handler.defaultPort()).isEqualTo(1717);\n            assertThat(handler.hostAddress(firstUrl)).isEqualTo(InetAddress.getLoopbackAddress());\n            assertThat(handler.urlHashCode(firstUrl)).isEqualTo(31337);\n            assertThat(handler.haveEqualHosts(firstUrl, secondUrl)).isTrue();\n            assertThat(handler.haveSameFile(firstUrl, secondUrl)).isTrue();\n            assertThat(handler.externalForm(firstUrl)).isEqualTo(\"authorized:multiplexed://localhost:42/alpha?one\");\n\n            URL parsedUrl = url(\"multiplexed://initial.example/original\");\n            String parsedSpec = \"multiplexed://parsed.example:77/updated?query\";\n            handler.parse(parsedUrl, parsedSpec, PROTOCOL.length() + 1, parsedSpec.length());\n            assertThat(parsedUrl.getHost()).isEqualTo(\"parsed.example\");\n            assertThat(parsedUrl.getPort()).isEqualTo(77);\n            assertThat(parsedUrl.getPath()).isEqualTo(\"/updated\");\n            assertThat(parsedUrl.getQuery()).isEqualTo(\"query\");\n\n            URL updatedUrl = url(\"multiplexed://before.example/original\");\n            handler.updateUrl(updatedUrl, PROTOCOL, \"changed.example\", 9191, null, null, \"/changed\", \"q=1\",\n                    \"fragment\");\n            assertThat(updatedUrl.getHost()).isEqualTo(\"changed.example\");\n            assertThat(updatedUrl.getPort()).isEqualTo(9191);\n            assertThat(updatedUrl.getPath()).isEqualTo(\"/changed\");\n            assertThat(updatedUrl.getQuery()).isEqualTo(\"q=1\");\n            assertThat(updatedUrl.getRef()).isEqualTo(\"fragment\");\n\n            assertThat(authorizedHandler.openConnectionCalls).isEqualTo(1);\n            assertThat(authorizedHandler.openConnectionWithProxyCalls).isEqualTo(1);\n            assertThat(authorizedHandler.equalsCalls).isEqualTo(1);\n            assertThat(authorizedHandler.defaultPortCalls).isEqualTo(1);\n            assertThat(authorizedHandler.hostAddressCalls).isEqualTo(1);\n            assertThat(authorizedHandler.hashCodeCalls).isEqualTo(1);\n            assertThat(authorizedHandler.hostsEqualCalls).isEqualTo(1);\n            assertThat(authorizedHandler.parseUrlCalls).isEqualTo(1);\n            assertThat(authorizedHandler.sameFileCalls).isEqualTo(1);\n            assertThat(authorizedHandler.setUrlCalls).isEqualTo(1);\n            assertThat(authorizedHandler.toExternalFormCalls).isEqualTo(1);\n        } finally {\n            stopFramework(framework);\n        }\n    }\n\n    private Framework newFramework() {\n        return new EquinoxFactory().newFramework(Map.of(\n                Constants.FRAMEWORK_STORAGE, storage.toString(),\n                Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT));\n    }\n\n    private static URL url(String spec) throws IOException {\n        return new URL(null, spec, new PassiveUrlStreamHandler());\n    }\n\n    private static Proxy proxy() {\n        return new Proxy(Proxy.Type.HTTP, InetSocketAddress.createUnresolved(\"proxy.example\", 8080));\n    }\n\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\n        if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING)) != 0) {\n            framework.stop();\n            framework.waitForStop(10_000L);\n        }\n    }\n\n    private static final class ExposedMultiplexingUrlStreamHandler extends MultiplexingURLStreamHandler {\n        ExposedMultiplexingUrlStreamHandler(\n                String protocol, URLStreamHandlerFactoryImpl factory, URLStreamHandler authorized) {\n            super(protocol, factory, authorized);\n        }\n\n        URLConnection connect(URL url) throws IOException {\n            return openConnection(url);\n        }\n\n        URLConnection connect(URL url, Proxy proxy) throws IOException {\n            return openConnection(url, proxy);\n        }\n\n        boolean areEqual(URL firstUrl, URL secondUrl) {\n            return equals(firstUrl, secondUrl);\n        }\n\n        int defaultPort() {\n            return getDefaultPort();\n        }\n\n        InetAddress hostAddress(URL url) {\n            return getHostAddress(url);\n        }\n\n        int urlHashCode(URL url) {\n            return hashCode(url);\n        }\n\n        boolean haveEqualHosts(URL firstUrl, URL secondUrl) {\n            return hostsEqual(firstUrl, secondUrl);\n        }\n\n        void parse(URL url, String spec, int start, int limit) {\n            parseURL(url, spec, start, limit);\n        }\n\n        boolean haveSameFile(URL firstUrl, URL secondUrl) {\n            return sameFile(firstUrl, secondUrl);\n        }\n\n        void updateUrl(URL url, String protocol, String host, int port, String authority, String userInfo, String path,\n                String query, String reference) {\n            setURL(url, protocol, host, port, authority, userInfo, path, query, reference);\n        }\n\n        String externalForm(URL url) {\n            return toExternalForm(url);\n        }\n    }\n\n    private static final class TestUrlStreamHandlerFactory extends URLStreamHandlerFactoryImpl {\n        private final URLStreamHandler authorizedHandler;\n\n        TestUrlStreamHandlerFactory(BundleContext context, URLStreamHandler authorizedHandler) {\n            super(context, ((BundleContextImpl) context).getContainer());\n            this.authorizedHandler = authorizedHandler;\n        }\n\n        @Override\n        protected URLStreamHandler findAuthorizedURLStreamHandler(String protocol) {\n            return authorizedHandler;\n        }\n    }\n\n    private static class RecordingUrlStreamHandler extends URLStreamHandler {\n        final URLConnection connection = new NoOpURLConnection();\n        final URLConnection proxyConnection = new NoOpURLConnection();\n        int openConnectionCalls;\n        int openConnectionWithProxyCalls;\n        int equalsCalls;\n        int defaultPortCalls;\n        int hostAddressCalls;\n        int hashCodeCalls;\n        int hostsEqualCalls;\n        int parseUrlCalls;\n        int sameFileCalls;\n        int setUrlCalls;\n        int toExternalFormCalls;\n\n        @Override\n        protected URLConnection openConnection(URL url) {\n            openConnectionCalls++;\n            return connection;\n        }\n\n        @Override\n        protected URLConnection openConnection(URL url, Proxy proxy) {\n            openConnectionWithProxyCalls++;\n            return proxyConnection;\n        }\n\n        @Override\n        protected boolean equals(URL firstUrl, URL secondUrl) {\n            equalsCalls++;\n            return firstUrl.getHost().equals(secondUrl.getHost());\n        }\n\n        @Override\n        protected int getDefaultPort() {\n            defaultPortCalls++;\n            return 1717;\n        }\n\n        @Override\n        protected InetAddress getHostAddress(URL url) {\n            hostAddressCalls++;\n            return InetAddress.getLoopbackAddress();\n        }\n\n        @Override\n        protected int hashCode(URL url) {\n            hashCodeCalls++;\n            return 31337;\n        }\n\n        @Override\n        protected boolean hostsEqual(URL firstUrl, URL secondUrl) {\n            hostsEqualCalls++;\n            return firstUrl.getHost().equals(secondUrl.getHost());\n        }\n\n        @Override\n        protected void parseURL(URL url, String spec, int start, int limit) {\n            parseUrlCalls++;\n            URI parsedUri = URI.create(spec.substring(0, limit));\n            super.setURL(url, parsedUri.getScheme(), parsedUri.getHost(), parsedUri.getPort(),\n                    parsedUri.getAuthority(), parsedUri.getUserInfo(), parsedUri.getPath(), parsedUri.getQuery(),\n                    parsedUri.getFragment());\n        }\n\n        @Override\n        protected boolean sameFile(URL firstUrl, URL secondUrl) {\n            sameFileCalls++;\n            return firstUrl.getHost().equals(secondUrl.getHost()) && firstUrl.getPath().equals(secondUrl.getPath());\n        }\n\n        @Override\n        protected void setURL(URL url, String protocol, String host, int port, String authority, String userInfo,\n                String path, String query, String reference) {\n            setUrlCalls++;\n            super.setURL(url, protocol, host, port, authority, userInfo, path, query, reference);\n        }\n\n        @Override\n        protected String toExternalForm(URL url) {\n            toExternalFormCalls++;\n            return \"authorized:\" + url.getProtocol() + \"://\" + url.getHost() + \":\" + url.getPort()\n                    + url.getPath() + \"?\" + url.getQuery();\n        }\n    }\n\n    private static final class PassiveUrlStreamHandler extends URLStreamHandler {\n        @Override\n        protected URLConnection openConnection(URL url) {\n            return new NoOpURLConnection();\n        }\n    }\n\n    private static final class NoOpURLConnection extends URLConnection {\n        NoOpURLConnection() {\n            super(null);\n        }\n\n        @Override\n        public void connect() {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778009360100}, {"role": "toolResult", "toolCallId": "call_CzmngNfmrTNuzZKhM4omF8BQ|fc_02d6fef8a636ae1d0169fa450fcf0c819eb9691af733e5e2e7", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.file.Path;\nimport java.util.Map;\nimport org.eclipse.osgi.launch.EquinoxFactory;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.osgi.framework.Bundle;\nimport org.osgi.framework.BundleException;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.launch.Framework;\n\npublic class EquinoxFactoryManagerTest {\n    @TempDir\n    Path storageRoot;\n\n    @Test\n    void multipleFrameworksShareAndUnregisterUrlAndContentHandlerFactories() throws Exception {\n        Framework firstFramework = newFramework(storageRoot.resolve(\"first\"));\n        Framework secondFramework = newFramework(storageRoot.resolve(\"second\"));\n\n        try {\n            firstFramework.init();\n            firstFramework.start();\n            try {\n                secondFramework.init();\n                secondFramework.start();\n                try {\n                    assertThat(firstFramework.getState()).isEqualTo(Bundle.ACTIVE);\n                    assertThat(secondFramework.getState()).isEqualTo(Bundle.ACTIVE);\n                } finally {\n                    stopFramework(secondFramework);\n                }\n            } finally {\n                stopFramework(firstFramework);\n            }\n        } finally {\n            stopFramework(secondFramework);\n        }\n    }\n\n    private static Framework newFramework(Path storage) {\n        return new EquinoxFactory().newFramework(Map.of(\n                Constants.FRAMEWORK_STORAGE, storage.toString(),\n                Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT));\n    }\n\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\n        if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING)) != 0) {\n            framework.stop();\n            framework.waitForStop(10_000L);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778009360100}, {"role": "toolResult", "toolCallId": "call_RJEhvhT5UZtBmwgwfeUl2UWl|fc_02d6fef8a636ae1d0169fa450fcf20819e91663a0093cf8f62", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.util.Collections;\nimport java.util.Dictionary;\nimport java.util.Enumeration;\nimport java.util.HashMap;\nimport java.util.Hashtable;\nimport java.util.Map;\nimport java.util.Set;\nimport org.eclipse.osgi.launch.EquinoxFactory;\nimport org.junit.jupiter.api.Test;\nimport org.osgi.framework.BundleException;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.InvalidSyntaxException;\nimport org.osgi.framework.ServiceReference;\nimport org.osgi.framework.ServiceRegistration;\nimport org.osgi.framework.launch.Framework;\nimport org.osgi.service.cm.Configuration;\nimport org.osgi.service.cm.Configuration.ConfigurationAttribute;\nimport org.osgi.service.cm.ConfigurationAdmin;\nimport org.osgi.service.cm.ConfigurationEvent;\nimport org.osgi.service.cm.SynchronousConfigurationListener;\nimport org.osgi.service.log.LogLevel;\nimport org.osgi.service.log.admin.LoggerAdmin;\nimport org.osgi.service.log.admin.LoggerContext;\n\npublic class ConfigAdminListenerInnerLoggerContextConfigurationTest {\n    private static final String LOGGER_CONTEXT_PID = \"org.osgi.service.log.admin\";\n    private static final String APPLICATION_CONTEXT = \"application\";\n    private static final String APPLICATION_PID = LOGGER_CONTEXT_PID + \"|\" + APPLICATION_CONTEXT;\n    private static final String LOGGER_NAME = \"sample.logger\";\n\n    @Test\n    void configurationAdminServiceUpdatesLoggerContextThroughRegisteredConfigurationListener() throws Exception {\n        Framework framework = new EquinoxFactory().newFramework(Map.of(\n                Constants.FRAMEWORK_SYSTEMPACKAGES_EXTRA, \"org.osgi.service.cm\",\n                LoggerContext.LOGGER_CONTEXT_DEFAULT_LOGLEVEL, LogLevel.WARN.name()));\n        framework.init();\n        framework.start();\n        try {\n            LoggerAdmin loggerAdmin = getRequiredService(framework, LoggerAdmin.class);\n            MockConfigurationAdmin configurationAdmin = new MockConfigurationAdmin();\n            configurationAdmin.put(new MockConfiguration(\n                    APPLICATION_PID, null, dictionaryWithLogLevel(LogLevel.DEBUG)));\n            configurationAdmin.put(new MockConfiguration(LOGGER_CONTEXT_PID + \"|factory\", \"factory.pid\",\n                    dictionaryWithLogLevel(LogLevel.TRACE)));\n\n            ServiceRegistration<ConfigurationAdmin> adminRegistration = framework.getBundleContext()\n                    .registerService(ConfigurationAdmin.class, configurationAdmin, null);\n            try {\n                LoggerContext applicationContext = loggerAdmin.getLoggerContext(APPLICATION_CONTEXT);\n                assertThat(applicationContext.getEffectiveLogLevel(LOGGER_NAME)).isEqualTo(LogLevel.DEBUG);\n\n                SynchronousConfigurationListener listener = getRequiredService(framework,\n                        SynchronousConfigurationListener.class);\n                @SuppressWarnings(\"unchecked\")\n                ServiceReference<ConfigurationAdmin> adminReference =\n                        (ServiceReference<ConfigurationAdmin>) adminRegistration.getReference();\n\n                configurationAdmin.put(new MockConfiguration(\n                        APPLICATION_PID, null, dictionaryWithLogLevel(LogLevel.ERROR)));\n                listener.configurationEvent(new ConfigurationEvent(adminReference, ConfigurationEvent.CM_UPDATED, null,\n                        APPLICATION_PID));\n                assertThat(applicationContext.getEffectiveLogLevel(LOGGER_NAME)).isEqualTo(LogLevel.ERROR);\n\n                listener.configurationEvent(new ConfigurationEvent(adminReference, ConfigurationEvent.CM_DELETED, null,\n                        APPLICATION_PID));\n                assertThat(applicationContext.getEffectiveLogLevel(LOGGER_NAME)).isEqualTo(LogLevel.WARN);\n            } finally {\n                adminRegistration.unregister();\n            }\n        } finally {\n            stopFramework(framework);\n        }\n    }\n\n    private static Dictionary<String, Object> dictionaryWithLogLevel(LogLevel level) {\n        Hashtable<String, Object> properties = new Hashtable<>();\n        properties.put(LOGGER_NAME, level.name());\n        properties.put(\"ignored.invalid.level\", \"not-a-log-level\");\n        return properties;\n    }\n\n    private static <T> T getRequiredService(Framework framework, Class<T> serviceClass) throws InterruptedException {\n        long deadline = System.nanoTime() + 10_000_000_000L;\n        while (System.nanoTime() < deadline) {\n            ServiceReference<T> reference = framework.getBundleContext().getServiceReference(serviceClass);\n            if (reference != null) {\n                T service = framework.getBundleContext().getService(reference);\n                if (service != null) {\n                    return service;\n                }\n            }\n            Thread.sleep(25L);\n        }\n        throw new AssertionError(\"Service was not registered: \" + serviceClass.getName());\n    }\n\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\n        framework.stop();\n        framework.waitForStop(10_000L);\n    }\n\n    private static final class MockConfigurationAdmin implements ConfigurationAdmin {\n        private final Map<String, Configuration> configurations = new HashMap<>();\n\n        void put(Configuration configuration) {\n            configurations.put(configuration.getPid(), configuration);\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration createFactoryConfiguration(String factoryPid, String location) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid, String location) throws IOException {\n            return configurations.get(pid);\n        }\n\n        @Override\n        public Configuration getConfiguration(String pid) throws IOException {\n            return getConfiguration(pid, null);\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(\n                String factoryPid, String name, String location) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration getFactoryConfiguration(String factoryPid, String name) throws IOException {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Configuration[] listConfigurations(String filter) throws IOException, InvalidSyntaxException {\n            return configurations.values().stream()\n                    .filter(configuration -> configuration.getProperties() != null)\n                    .toArray(Configuration[]::new);\n        }\n    }\n\n    private static final class MockConfiguration implements Configuration {\n        private final String pid;\n        private final String factoryPid;\n        private Dictionary<String, Object> properties;\n\n        MockConfiguration(String pid, String factoryPid, Dictionary<String, Object> properties) {\n            this.pid = pid;\n            this.factoryPid = factoryPid;\n            this.properties = properties;\n        }\n\n        @Override\n        public String getPid() {\n            return pid;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProperties() {\n            return properties;\n        }\n\n        @Override\n        public Dictionary<String, Object> getProcessedProperties(ServiceReference<?> reference) {\n            return getProperties();\n        }\n\n        @Override\n        public void update(Dictionary<String, ?> properties) throws IOException {\n            Hashtable<String, Object> updated = new Hashtable<>();\n            for (Enumeration<String> keys = properties.keys(); keys.hasMoreElements();) {\n                String key = keys.nextElement();\n                updated.put(key, properties.get(key));\n            }\n            this.properties = updated;\n        }\n\n        @Override\n        public void delete() throws IOException {\n            properties = null;\n        }\n\n        @Override\n        public String getFactoryPid() {\n            return factoryPid;\n        }\n\n        @Override\n        public void update() throws IOException {\n        }\n\n        @Override\n        public boolean updateIfDifferent(Dictionary<String, ?> properties) throws IOException {\n            update(properties);\n            return true;\n        }\n\n        @Override\n        public void setBundleLocation(String location) {\n        }\n\n        @Override\n        public String getBundleLocation() {\n            return null;\n        }\n\n        @Override\n        public long getChangeCount() {\n            return 0L;\n        }\n\n        @Override\n        public void addAttributes(ConfigurationAttribute... attrs) throws IOException {\n        }\n\n        @Override\n        public Set<ConfigurationAttribute> getAttributes() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public void removeAttributes(ConfigurationAttribute... attrs) throws IOException {\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof Configuration)) {\n                return false;\n            }\n            return pid.equals(((Configuration) other).getPid());\n        }\n\n        @Override\n        public int hashCode() {\n            return pid.hashCode();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778009360104}]}
