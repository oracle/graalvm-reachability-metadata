  package org_eclipse_platform.org_eclipse_osgi;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.nio.file.Path;
  import java.util.Map;
  import org.eclipse.osgi.launch.EquinoxFactory;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.osgi.framework.Bundle;
  import org.osgi.framework.BundleException;
  import org.osgi.framework.Constants;
  import org.osgi.framework.launch.Framework;
  
  public class EquinoxFactoryManagerTest {
      @TempDir
      Path storageRoot;
  
      @Test
      void multipleFrameworksShareAndUnregisterUrlAndContentHandlerFactories() throws Exception {
          Framework firstFramework = newFramework(storageRoot.resolve("first"));
          Framework secondFramework = newFramework(storageRoot.resolve("second"));
  
          try {
              firstFramework.init();
              firstFramework.start();
              try {
                  secondFramework.init();
                  secondFramework.start();
                  try {
                      assertThat(firstFramework.getState()).isEqualTo(Bundle.ACTIVE);
                      assertThat(secondFramework.getState()).isEqualTo(Bundle.ACTIVE);
                  } finally {
                      stopFramework(secondFramework);
                  }
              } finally {
                  stopFramework(firstFramework);
              }
          } finally {
              stopFramework(secondFramework);
          }
      }
  
      private static Framework newFramework(Path storage) {
          return new EquinoxFactory().newFramework(Map.of(
                  Constants.FRAMEWORK_STORAGE, storage.toString(),
                  Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT));
      }
  
      private static void stopFramework(Framework framework) throws BundleException, InterruptedException {
          if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING)) != 0) {
              framework.stop();
              framework.waitForStop(10_000L);
          }
      }
  }
