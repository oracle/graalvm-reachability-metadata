org_eclipse_platform/org_eclipse_osgi/BundleLoaderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.net.URL;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Enumeration;\nimport java.util.Map;\nimport java.util.jar.Attributes;\nimport java.util.jar.JarOutputStream;\nimport java.util.jar.Manifest;\nimport javax.crypto.Cipher;\nimport org.eclipse.osgi.internal.framework.EquinoxConfiguration;\nimport org.eclipse.osgi.launch.EquinoxFactory;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.osgi.framework.Bundle;\nimport org.osgi.framework.BundleException;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.launch.Framework;\n\npublic class BundleLoaderTest {\n    private static final String JAVA_CLASS_NAME = String.class.getName();\n    private static final String JAVA_CLASS_RESOURCE = \"java/lang/String.class\";\n    private static final String PARENT_CLASS_NAME = Cipher.class.getName();\n    private static final String PARENT_CLASS_RESOURCE = \"javax/crypto/Cipher.class\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void javaPackageClassAndResourcesAreDelegatedToParentClassLoader() throws Exception {\n        Framework framework = newFramework(Map.of());\n        framework.init();\n        framework.start();\n        try {\n            Bundle bundle = installEmptyBundle(framework, \"java-delegation\");\n\n            assertThat(bundle.loadClass(JAVA_CLASS_NAME)).isSameAs(String.class);\n            bundle.getResource(JAVA_CLASS_RESOURCE);\n            drain(bundle.getResources(JAVA_CLASS_RESOURCE));\n        } finally {\n            stopFramework(framework);\n        }\n    }\n\n    @Test\n    void bootDelegatedClassAndResourcesAreRequestedFromParentClassLoader() throws Exception {\n        Framework framework = newFramework(Map.of(Constants.FRAMEWORK_BOOTDELEGATION, \"javax.crypto\"));\n        framework.init();\n        framework.start();\n        try {\n            Bundle bundle = installEmptyBundle(framework, \"boot-delegation\");\n\n            assertThat(bundle.loadClass(PARENT_CLASS_NAME)).isSameAs(Cipher.class);\n            bundle.getResource(PARENT_CLASS_RESOURCE);\n            drain(bundle.getResources(PARENT_CLASS_RESOURCE));\n        } finally {\n            stopFramework(framework);\n        }\n    }\n\n    @Test\n    void compatibilityBootDelegationFallsBackToParentClassLoader() throws Exception {\n        Framework framework = newFramework(Map.of(EquinoxConfiguration.PROP_COMPATIBILITY_BOOTDELEGATION, \"true\"));\n        framework.init();\n        framework.start();\n        try {\n            Bundle bundle = installEmptyBundle(framework, \"compatibility-delegation\");\n\n            assertThat(bundle.loadClass(PARENT_CLASS_NAME)).isSameAs(Cipher.class);\n            bundle.getResource(PARENT_CLASS_RESOURCE);\n            drain(bundle.getResources(PARENT_CLASS_RESOURCE));\n        } finally {\n            stopFramework(framework);\n        }\n    }\n\n    private Framework newFramework(Map<String, String> extraConfiguration) {\n        Map<String, String> configuration = new java.util.HashMap<>();\n        configuration.put(Constants.FRAMEWORK_STORAGE, temporaryDirectory.resolve(\"framework\").toString());\n        configuration.put(Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT);\n        configuration.putAll(extraConfiguration);\n        return new EquinoxFactory().newFramework(configuration);\n    }\n\n    private Bundle installEmptyBundle(Framework framework, String symbolicName) throws Exception {\n        Path bundleJar = temporaryDirectory.resolve(symbolicName + \".jar\");\n        writeEmptyBundle(bundleJar, symbolicName);\n        return framework.getBundleContext().installBundle(bundleJar.toUri().toString());\n    }\n\n    private static void writeEmptyBundle(Path bundleJar, String symbolicName) throws IOException {\n        Manifest manifest = new Manifest();\n        Attributes attributes = manifest.getMainAttributes();\n        attributes.put(Attributes.Name.MANIFEST_VERSION, \"1.0\");\n        attributes.putValue(Constants.BUNDLE_MANIFESTVERSION, \"2\");\n        attributes.putValue(Constants.BUNDLE_SYMBOLICNAME, symbolicName);\n        attributes.putValue(Constants.BUNDLE_VERSION, \"1.0.0\");\n\n        try (OutputStream outputStream = Files.newOutputStream(bundleJar);\n                JarOutputStream jarOutputStream = new JarOutputStream(outputStream, manifest)) {\n            jarOutputStream.flush();\n        }\n    }\n\n    private static void drain(Enumeration<URL> resources) {\n        if (resources == null) {\n            return;\n        }\n        while (resources.hasMoreElements()) {\n            resources.nextElement();\n        }\n    }\n\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\n        if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING)) != 0) {\n            framework.stop();\n            framework.waitForStop(10_000L);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/BundleLoaderTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_eclipse_platform.org_eclipse_osgi;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.IOException;\\nimport java