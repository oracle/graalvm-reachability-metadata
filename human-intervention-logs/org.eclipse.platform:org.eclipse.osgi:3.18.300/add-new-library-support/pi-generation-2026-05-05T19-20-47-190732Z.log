_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.file.Path;\nimport java.util.Map;\nimport org.eclipse.osgi.launch.EquinoxFactory;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.osgi.framework.Bundle;\nimport org.osgi.framework.BundleException;\nimport org.osgi.framework.Constants;\nimport org.osgi.framework.launch.Framework;\n\npublic class EquinoxFactoryManagerTest {\n    @TempDir\n    Path storageRoot;\n\n    @Test\n    void multipleFrameworksShareAndUnregisterUrlAndContentHandlerFactories() throws Exception {\n        Framework firstFramework = newFramework(storageRoot.resolve(\"first\"));\n        Framework secondFramework = newFramework(storageRoot.resolve(\"second\"));\n\n        firstFramework.init();\n        secondFramework.init();\n        firstFramework.start();\n        try {\n            secondFramework.start();\n            try {\n                assertThat(firstFramework.getState()).isEqualTo(Bundle.ACTIVE);\n                assertThat(secondFramework.getState()).isEqualTo(Bundle.ACTIVE);\n            } finally {\n                stopFramework(secondFramework);\n            }\n        } finally {\n            stopFramework(firstFramework);\n        }\n    }\n\n    private static Framework newFramework(Path storage) {\n        return new EquinoxFactory().newFramework(Map.of(\n                Constants.FRAMEWORK_STORAGE, storage.toString(),\n                Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT));\n    }\n\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\n        if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING | Bundle.RESOLVED)) != 0) {\n            framework.stop();\n            framework.waitForStop(10_000L);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/EquinoxFactoryManagerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_eclipse_platform.org_eclipse_osgi;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.nio.file.Path;\\nimport java.util.Map;\\nimport org.eclipse.osgi.launch.EquinoxFactory;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\nimport org.osgi.framework.Bundle;\\nimport org.osgi.framework.BundleException;\\nimport org.osgi.framework.Constants;\\nimport org.osgi.framework.launch.Framework;\\n\\npublic class EquinoxFactoryManagerTest {\\n    @TempDir\\n    Path storageRoot;\\n\\n    @Test\\n    void multipleFrameworksShareAndUnregisterUrlAndContentHandlerFactories() throws Exception {\\n        Framework firstFramework = newFramework(storageRoot.resolve(\\\"first\\\"));\\n        Framework secondFramework = newFramework(storageRoot.resolve(\\\"second\\\"));\\n\\n        firstFramework.init();\\n        secondFramework.init();\\n        firstFramework.start();\\n        try {\\n            secondFramework.start();\\n            try {\\n                assertThat(firstFramework.getState()).isEqualTo(Bundle.ACTIVE);\\n                assertThat(secondFramework.getState()).isEqualTo(Bundle.ACTIVE);\\n            } finally {\\n                stopFramework(secondFramework);\\n            }\\n        } finally {\\n            stopFramework(firstFramework);\\n        }\\n    }\\n\\n    private static Framework newFramework(Path storage) {\\n        return new EquinoxFactory().newFramework(Map.of(\\n                Constants.FRAMEWORK_STORAGE, storage.toString(),\\n                Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT));\\n    }\\n\\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\\n        if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING | Bundle.RESOLVED)) != 0) {\\n            framework.stop();\\n            framework.waitForStop(10_000L);\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2061, "output": 1041, "cacheRead": 37376, "cacheWrite": 0, "totalTokens": 40478, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778008795158, "responseId": "resp_02992754f501f42e0169fa42dc4d688196bfe9271560dab04b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_WIstmfYiaVRqNJiOehLn36TM|fc_02992754f501f42e0169fa42e92ec881968be85e71a53f5da1", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2058 bytes to tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/EquinoxFactoryManagerTest.java"}], "isError": false, "timestamp": 1778008814536}]}
