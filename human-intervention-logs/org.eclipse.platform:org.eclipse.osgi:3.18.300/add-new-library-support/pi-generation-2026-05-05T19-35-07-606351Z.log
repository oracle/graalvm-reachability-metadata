pse_platform/org_eclipse_osgi/ContextFinderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_eclipse_platform.org_eclipse_osgi;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport org.eclipse.osgi.internal.framework.ContextFinder;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class ContextFinderTest {\n    private static final String PARENT_ONLY_CLASS_NAME = \"org.example.ParentOnlyClass\";\n    private static final String PARENT_ONLY_RESOURCE_NAME = \"org/example/parent-only-resource.txt\";\n\n    @TempDir\n    java.nio.file.Path temporaryDirectory;\n\n    @Test\n    void loadClassConsultsStackClassLoaderAndThenParentContextClassLoader() throws Exception {\n        ParentContextClassLoader parentClassLoader = new ParentContextClassLoader(resourceUrl());\n        ContextFinder contextFinder = new ContextFinder(parentClassLoader, getClass().getClassLoader());\n\n        assertThat(contextFinder.loadClass(ContextFinderTest.class.getName())).isSameAs(ContextFinderTest.class);\n        assertThat(contextFinder.loadClass(PARENT_ONLY_CLASS_NAME)).isSameAs(ParentOnlyMarker.class);\n    }\n\n    @Test\n    void getResourceConsultsStackClassLoaderAndThenParentContextClassLoader() throws Exception {\n        URL parentResourceUrl = resourceUrl();\n        ParentContextClassLoader parentClassLoader = new ParentContextClassLoader(parentResourceUrl);\n        ContextFinder contextFinder = new ContextFinder(parentClassLoader, getClass().getClassLoader());\n\n        assertThat(contextFinder.getResource(ContextFinderTest.class.getName().replace('.', '/') + \".class\"))\n                .isNotNull();\n        assertThat(contextFinder.getResource(PARENT_ONLY_RESOURCE_NAME)).isEqualTo(parentResourceUrl);\n    }\n\n    @Test\n    void getResourcesConsultsStackClassLoaderAndThenParentContextClassLoader() throws Exception {\n        URL parentResourceUrl = resourceUrl();\n        ParentContextClassLoader parentClassLoader = new ParentContextClassLoader(parentResourceUrl);\n        ContextFinder contextFinder = new ContextFinder(parentClassLoader, getClass().getClassLoader());\n\n        List<URL> stackLoaderResources = Collections.list(\n                contextFinder.getResources(ContextFinderTest.class.getName().replace('.', '/') + \".class\"));\n        List<URL> parentResources = Collections.list(contextFinder.getResources(PARENT_ONLY_RESOURCE_NAME));\n\n        assertThat(stackLoaderResources).isNotEmpty();\n        assertThat(parentResources).containsExactly(parentResourceUrl);\n    }\n\n    private URL resourceUrl() throws IOException {\n        java.nio.file.Path resource = temporaryDirectory.resolve(\"parent-only-resource.txt\");\n        java.nio.file.Files.writeString(resource, \"loaded by parent context class loader\");\n        return resource.toUri().toURL();\n    }\n\n    private static final class ParentContextClassLoader extends ClassLoader {\n        private final URL resourceUrl;\n\n        ParentContextClassLoader(URL resourceUrl) {\n            super(null);\n            this.resourceUrl = resourceUrl;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (PARENT_ONLY_CLASS_NAME.equals(name)) {\n                return ParentOnlyMarker.class;\n            }\n            throw new ClassNotFoundException(name);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (PARENT_ONLY_RESOURCE_NAME.equals(name)) {\n                return resourceUrl;\n            }\n            return null;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) {\n            if (PARENT_ONLY_RESOURCE_NAME.equals(name)) {\n                return Collections.enumeration(List.of(resourceUrl));\n            }\n            return Collections.emptyEnumeration();\n        }\n    }\n\n    private static final class ParentOnlyMarker {\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/ContextFinderTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_eclipse_platform.org_eclipse_osgi;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.IOException;\\nimport java.net.URL;\\nimport java.util.Collections;\\nimport java.util.Enumeration;\\nimport java.util.List;\\nimport org.eclipse.osgi.internal.framework.ContextFinder;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\n\\npublic class ContextFinderTest {\\n    private static final String PARENT_ONLY_CLASS_NAME = \\\"org.example.ParentOnlyClass\\\";\\n    private static final String PARENT_ONLY_RESOURCE_NAME = \\\"org/example/parent-only-resource.txt\\\";\\n\\n    @TempDir\\n    java.nio.file.Path temporaryDirectory;\\n\\n    @Test\\n    void loadClassConsultsStackClassLoaderAndThenParentContextClassLoader() throws Exception {\\n        ParentContextClassLoader parentClassLoader = new ParentContextClassLoader(resourceUrl());\\n        ContextFinder contextFinder = new ContextFinder(parentClassLoader, getClass().getClassLoader());\\n\\n        assertThat(contextFinder.loadClass(ContextFinderTest.class.getName())).isSameAs(ContextFinderTest.class);\\n        assertThat(contextFinder.loadClass(PARENT_ONLY_CLASS_NAME)).isSameAs(ParentOnlyMarker.class);\\n    }\\n\\n    @Test\\n    void getResourceConsultsStackClassLoaderAndThenParentContextClassLoader() throws Exception {\\n        URL parentResourceUrl = resourceUrl();\\n        ParentContextClassLoader parentClassLoader = new ParentContextClassLoader(parentResourceUrl);\\n        ContextFinder contextFinder = new ContextFinder(parentClassLoader, getClass().getClassLoader());\\n\\n        assertThat(contextFinder.getResource(ContextFinderTest.class.getName().replace('.', '/') + \\\".class\\\"))\\n                .isNotNull();\\n        assertThat(contextFinder.getResource(PARENT_ONLY_RESOURCE_NAME)).isEqualTo(parentResourceUrl);\\n    }\\n\\n    @Test\\n    void getResourcesConsultsStackClassLoaderAndThenParentContextClassLoader() throws Exception {\\n        URL parentResourceUrl = resourceUrl();\\n        ParentContextClassLoader parentClassLoader = new ParentContextClassLoader(parentResourceUrl);\\n        ContextFinder contextFinder = new ContextFinder(parentClassLoader, getClass().getClassLoader());\\n\\n        List<URL> stackLoaderResources = Collections.list(\\n                contextFinder.getResources(ContextFinderTest.class.getName().replace('.', '/') + \\\".class\\\"));\\n        List<URL> parentResources = Collections.list(contextFinder.getResources(PARENT_ONLY_RESOURCE_NAME));\\n\\n        assertThat(stackLoaderResources).isNotEmpty();\\n        assertThat(parentResources).containsExactly(parentResourceUrl);\\n    }\\n\\n    private URL resourceUrl() throws IOException {\\n        java.nio.file.Path resource = temporaryDirectory.resolve(\\\"parent-only-resource.txt\\\");\\n        java.nio.file.Files.writeString(resource, \\\"loaded by parent context class loader\\\");\\n        return resource.toUri().toURL();\\n    }\\n\\n    private static final class ParentContextClassLoader extends ClassLoader {\\n        private final URL resourceUrl;\\n\\n        ParentContextClassLoader(URL resourceUrl) {\\n            super(null);\\n            this.resourceUrl = resourceUrl;\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\\n            if (PARENT_ONLY_CLASS_NAME.equals(name)) {\\n                return ParentOnlyMarker.class;\\n            }\\n            throw new ClassNotFoundException(name);\\n        }\\n\\n        @Override\\n        public URL getResource(String name) {\\n            if (PARENT_ONLY_RESOURCE_NAME.equals(name)) {\\n                return resourceUrl;\\n            }\\n            return null;\\n        }\\n\\n        @Override\\n        public Enumeration<URL> getResources(String name) {\\n            if (PARENT_ONLY_RESOURCE_NAME.equals(name)) {\\n                return Collections.enumeration(List.of(resourceUrl));\\n            }\\n            return Collections.emptyEnumeration();\\n        }\\n    }\\n\\n    private static final class ParentOnlyMarker {\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1303, "output": 1909, "cacheRead": 11264, "cacheWrite": 0, "totalTokens": 14476, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778009635170, "responseId": "resp_0ea784e420c3c3470169fa46239370819683f344f04e669589"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2kaJy3QsY3cJjQu9ESE6iI4e|fc_0ea784e420c3c3470169fa46316ac8819696195dcae8c416b9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4140 bytes to tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300/src/test/java/org_eclipse_platform/org_eclipse_osgi/ContextFinderTest.java"}], "isError": false, "timestamp": 1778009657516}]}
