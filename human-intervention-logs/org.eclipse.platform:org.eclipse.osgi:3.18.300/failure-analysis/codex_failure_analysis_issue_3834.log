ndle.getResource(JAVA_CLASS_RESOURCE);\\n            drain(bundle.getResources(JAVA_CLASS_RESOURCE));\\n        } finally {\\n            stopFramework(framework);\\n        }\\n    }\\n\\n    @Test\\n    void bootDelegatedClassAndResourcesAreRequestedFromParentClassLoader() throws Exception {\\n        Framework framework = newFramework(Map.of(Constants.FRAMEWORK_BOOTDELEGATION, \\\"javax.crypto\\\"));\\n        framework.init();\\n        framework.start();\\n        try {\\n            Bundle bundle = installEmptyBundle(framework, \\\"org.example.bootdelegation\\\");\\n\\n            assertThat(bundle.loadClass(PARENT_CLASS_NAME)).isSameAs(Cipher.class);\\n            bundle.getResource(PARENT_CLASS_RESOURCE);\\n            drain(bundle.getResources(PARENT_CLASS_RESOURCE));\\n        } finally {\\n            stopFramework(framework);\\n        }\\n    }\\n\\n    @Test\\n    void compatibilityBootDelegationFallsBackToParentClassLoader() throws Exception {\\n        Framework framework = newFramework(Map.of(EquinoxConfiguration.PROP_COMPATIBILITY_BOOTDELEGATION, \\\"true\\\"));\\n        framework.init();\\n        framework.start();\\n        try {\\n            Bundle bundle = installEmptyBundle(framework, \\\"org.example.compatibilitydelegation\\\");\\n\\n            assertThat(bundle.loadClass(PARENT_CLASS_NAME)).isSameAs(Cipher.class);\\n            bundle.getResource(PARENT_CLASS_RESOURCE);\\n            drain(bundle.getResources(PARENT_CLASS_RESOURCE));\\n        } finally {\\n            stopFramework(framework);\\n        }\\n    }\\n\\n    private Framework newFramework(Map<String, String> extraConfiguration) {\\n        Map<String, String> configuration = new HashMap<>();\\n        configuration.put(Constants.FRAMEWORK_STORAGE, temporaryDirectory.resolve(\\\"framework\\\").toString());\\n        configuration.put(Constants.FRAMEWORK_STORAGE_CLEAN, Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT);\\n        configuration.putAll(extraConfiguration);\\n        return new EquinoxFactory().newFramework(configuration);\\n    }\\n\\n    private Bundle installEmptyBundle(Framework framework, String symbolicName) throws Exception {\\n        Path bundleJar = temporaryDirectory.resolve(symbolicName + \\\".jar\\\");\\n        writeEmptyBundle(bundleJar, symbolicName);\\n        return framework.getBundleContext().installBundle(bundleJar.toUri().toString());\\n    }\\n\\n    private static void writeEmptyBundle(Path bundleJar, String symbolicName) throws IOException {\\n        Manifest manifest = new Manifest();\\n        Attributes attributes = manifest.getMainAttributes();\\n        attributes.put(Attributes.Name.MANIFEST_VERSION, \\\"1.0\\\");\\n        attributes.putValue(Constants.BUNDLE_MANIFESTVERSION, \\\"2\\\");\\n        attributes.putValue(Constants.BUNDLE_SYMBOLICNAME, symbolicName);\\n        attributes.putValue(Constants.BUNDLE_VERSION, \\\"1.0.0\\\");\\n\\n        try (OutputStream outputStream = Files.newOutputStream(bundleJar);\\n                JarOutputStream jarOutputStream = new JarOutputStream(outputStream, manifest)) {\\n            jarOutputStream.flush();\\n        }\\n    }\\n\\n    private static void drain(Enumeration<URL> resources) {\\n        if (resources == null) {\\n            return;\\n        }\\n        while (resources.hasMoreElements()) {\\n            resources.nextElement();\\n        }\\n    }\\n\\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\\n        if ((framework.getState() & (Bundle.ACTIVE | Bundle.STARTING)) != 0) {\\n            framework.stop();\\n            framework.waitForStop(10_000L);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778009613624}, {\"role\": \"toolResult\", \"toolCallId\": \"call_HH1JKrV9a7yGKao2ssh9Oz62|fc_0ea784e420c3c3470169fa460d4c408196a06e04338894bdeb\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived vi