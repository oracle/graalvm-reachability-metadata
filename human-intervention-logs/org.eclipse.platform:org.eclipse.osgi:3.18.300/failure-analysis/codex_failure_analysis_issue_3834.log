"responseId\": \"resp_03ad01c0eee629e20169f62708e934819f87697fae6209dc31\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_4zJjKiOUBNzRTtKVzo76A2Im|fc_03ad01c0eee629e20169f627144a10819faddc11984235d197\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_eclipse_platform.org_eclipse_osgi;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.IOException;\\nimport java.nio.file.Path;\\nimport java.time.Duration;\\nimport java.time.Instant;\\nimport java.util.ArrayList;\\nimport java.util.Dictionary;\\nimport java.util.Hashtable;\\nimport java.util.List;\\nimport java.util.Map;\\nimport java.util.Set;\\nimport org.eclipse.osgi.launch.EquinoxFactory;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\nimport org.osgi.framework.Bundle;\\nimport org.osgi.framework.BundleContext;\\nimport org.osgi.framework.BundleException;\\nimport org.osgi.framework.Constants;\\nimport org.osgi.framework.InvalidSyntaxException;\\nimport org.osgi.framework.ServiceReference;\\nimport org.osgi.framework.ServiceRegistration;\\nimport org.osgi.framework.launch.Framework;\\nimport org.osgi.service.cm.Configuration;\\nimport org.osgi.service.cm.Configuration.ConfigurationAttribute;\\nimport org.osgi.service.cm.ConfigurationAdmin;\\nimport org.osgi.service.cm.ConfigurationEvent;\\nimport org.osgi.service.cm.SynchronousConfigurationListener;\\nimport org.osgi.service.log.LogLevel;\\nimport org.osgi.service.log.admin.LoggerAdmin;\\n\\npublic class ConfigAdminListenerInnerLoggerContextConfigurationTest {\\n    private static final String LOG_ADMIN_PID_PREFIX = \\\"org.osgi.service.log.admin\\\";\\n    private static final String LOGGER_NAME = \\\"example.logger\\\";\\n    private static final Duration SERVICE_TIMEOUT = Duration.ofSeconds(10);\\n\\n    @TempDir\\n    Path frameworkStorage;\\n\\n    @Test\\n    public void configurationEventAppliesLogLevelChangesFromConfigurationAdmin() throws Exception {\\n        Framework framework = new EquinoxFactory().newFramework(frameworkConfiguration());\\n        ServiceRegistration<ConfigurationAdmin> configAdminRegistration = null;\\n\\n        try {\\n            framework.start();\\n            BundleContext context = framework.getBundleContext();\\n            LoggerAdmin loggerAdmin = getService(context, LoggerAdmin.class);\\n            TestConfigurationAdmin configAdmin = new TestConfigurationAdmin();\\n            String contextName = \\\"dynamic.access.context\\\";\\n            String pid = LOG_ADMIN_PID_PREFIX + \\\"|\\\" + contextName;\\n\\n            configAdmin.put(new TestConfiguration(pid, null, logLevelProperties(LogLevel.DEBUG)));\\n            configAdminRegistration = context.registerService(ConfigurationAdmin.class, configAdmin, null);\\n\\n            SynchronousConfigurationListener listener = getService(context, SynchronousConfigurationListener.class);\\n            assertThat(loggerAdmin.getLoggerContext(contextName).getLogLevels())\\n                    .containsEntry(LOGGER_NAME, LogLevel.DEBUG);\\n\\n            configAdmin.put(new TestConfiguration(pid, null, logLevelProperties(LogLevel.ERROR)));\\n            listener.configurationEvent(new ConfigurationEvent(\\n                    configAdminRegistration.getReference(), ConfigurationEvent.CM_UPDATED, null, pid));\\n            assertThat(loggerAdmin.getLoggerContext(contextName).getLogLevels())\\n                    .containsEntry(LOGGER_NAME, LogLevel.ERROR);\\n\\n            listener.configurationEvent(new ConfigurationEvent(\\n                    configAdminRegistration.getReference(), ConfigurationEvent.CM_DELETED, null, pid));\\n            assertThat(loggerAdmin.getLoggerContext(contextName).getLogLevels()).doesNotContainKey(LOGGER_NAME);\\n        } finally {\\n            if (configAdminRegistration != null) {\\n                configAdminRegistration.unregister();\\n            }\\n            stopFramework(framework);\\n        }\\n    }\\n\\n    private Map<String, String> frameworkConfiguration() {\\n        return Map.of(\\n                Constants.FRAMEWORK_STORAGE,\\n                frameworkStorage.toAbsolutePath().toString(),\\n                Constants.FRAMEWORK_STORAGE_CLEAN,\\n                Constants.FRAMEWORK_STORAGE_CLEAN_ONFIRSTINIT,\\n                Constants.FRAMEWORK_SYSTEMPACKAGES_EXTRA,\\n                \\\"org.osgi.service.cm\\\",\\n                \\\"osgi.parentClassloader\\\",\\n                \\\"app\\\",\\n                \\\"osgi.contextClassLoaderParent\\\",\\n                \\\"app\\\");\\n    }\\n\\n    private static Dictionary<String, Object> logLevelProperties(LogLevel logLevel) {\\n        Hashtable<String, Object> properties = new Hashtable<>();\\n        properties.put(LOGGER_NAME, logLevel.name());\\n        return properties;\\n    }\\n\\n    private static <S> S getService(BundleContext context, Class<S> serviceType) throws InterruptedException {\\n        ServiceReference<S> reference = waitForServiceReference(context, serviceType);\\n        S service = context.getService(reference);\\n        assertThat(service).isNotNull();\\n        return service;\\n    }\\n\\n    private static <S> ServiceReference<S> waitForServiceReference(BundleContext context, Class<S> serviceType)\\n            throws InterruptedException {\\n        Instant deadline = Instant.now().plus(SERVICE_TIMEOUT);\\n        ServiceReference<S> reference = context.getServiceReference(serviceType);\\n        while (reference == null && Instant.now().isBefore(deadline)) {\\n            Thread.sleep(25L);\\n            reference = context.getServiceReference(serviceType);\\n        }\\n        assertThat(reference).as(\\\"service reference for %s\\\", serviceType.getName()).isNotNull();\\n        return reference;\\n    }\\n\\n    private static void stopFramework(Framework framework) throws BundleException, InterruptedException {\\n        int state = framework.getState();\\n        if ((state & (Bundle.ACTIVE | Bundle.STARTING | Bundle.STOPPING)) != 0) {\\n            framework.stop();\\n            framework.waitForStop(SERVICE_TIMEOUT.toMillis());\\n        }\\n    }\\n\\n    private static final class TestConfigurationAdmin implements ConfigurationAdmin {\\n        private final List<Configuration> configurations = new ArrayList<>();\\n\\n        void put(Configuration configuration) {\\n            configurations.removeIf(existing -> existing.getPid().equals(configuration.getPid()));\\n            configurations.add(configuration);\\n        }\\n\\n        @Override\\n        public Configuration createFactoryConfiguration(String factoryPid) {\\n            throw new UnsupportedOperationException(\\\"Factory configurations are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public Configuration createFactoryConfiguration(String factoryPid, String location) {\\n            throw new UnsupportedOperationException(\\\"Factory configurations are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public Configuration getConfiguration(String pid, String location) {\\n            return configurations.stream()\\n                    .filter(configuration -> configuration.getPid().equals(pid))\\n                    .findFirst()\\n                    .orElseThrow(() -> new IllegalArgumentException(\\\"Unknown configuration pid: \\\" + pid));\\n        }\\n\\n        @Override\\n        public Configuration getConfiguration(String pid) {\\n            return getConfiguration(pid, null);\\n        }\\n\\n        @Override\\n        public Configuration getFactoryConfiguration(String factoryPid, String name, String location) {\\n            throw new UnsupportedOperationException(\\\"Factory configurations are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public Configuration getFactoryConfiguration(String factoryPid, String name) {\\n            throw new UnsupportedOperationException(\\\"Factory configurations are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public Configuration[] listConfigurations(String filter) throws InvalidSyntaxException {\\n            return configurations.toArray(Configuration[]::new);\\n        }\\n    }\\n\\n    private static final class TestConfiguration implements Configuration {\\n        private final String pid;\\n        private final String factoryPid;\\n        private final Dictionary<String, Object> properties;\\n\\n        private TestConfiguration(String pid, String factoryPid, Dictionary<String, Object> properties) {\\n            this.pid = pid;\\n            this.factoryPid = factoryPid;\\n            this.properties = properties;\\n        }\\n\\n        @Override\\n        public String getPid() {\\n            return pid;\\n        }\\n\\n        @Override\\n        public Dictionary<String, Object> getProperties() {\\n            return properties;\\n        }\\n\\n        @Override\\n        public Dictionary<String, Object> getProcessedProperties(ServiceReference<?> reference) {\\n            return getProperties();\\n        }\\n\\n        @Override\\n        public void update(Dictionary<String, ?> properties) throws IOException {\\n            throw new UnsupportedOperationException(\\\"Configuration updates are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public void delete() throws IOException {\\n            throw new UnsupportedOperationException(\\\"Configuration deletion is driven by events in this test\\\");\\n        }\\n\\n        @Override\\n        public String getFactoryPid() {\\n            return factoryPid;\\n        }\\n\\n        @Override\\n        public void update() throws IOException {\\n            throw new UnsupportedOperationException(\\\"Configuration updates are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public boolean updateIfDifferent(Dictionary<String, ?> properties) throws IOException {\\n            throw new UnsupportedOperationException(\\\"Configuration updates are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public void setBundleLocation(String location) {\\n            throw new UnsupportedOperationException(\\\"Bundle locations are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public String getBundleLocation() {\\n            return null;\\n        }\\n\\n        @Override\\n        public long getChangeCount() {\\n            return 1L;\\n        }\\n\\n        @Override\\n        public void addAttributes(ConfigurationAttribute... attrs) throws IOException {\\n            throw new UnsupportedOperationException(\\\"Configuration attributes are not used by this test\\\");\\n        }\\n\\n        @Override\\n        public Set<ConfigurationAttribute> getAttributes() {\\n            return Set.of();\\n        }\\n\\n        @Override\\n        public void removeAttributes(ConfigurationAttribute... attrs) throws IOException {\\n            throw new UnsupportedOperationException(\\\"Configuration attributes are not used by this test\\\");\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777739540742}]}\nhuman-intervention-logs/org.eclipse.platform:org.eclipse.osgi:3.18.300/add-new-library-support/pi-generation-2026-05-02T16-32-54-763809Z.log:4072:[tool-call] delta {\"command\":\"git diff --stat && git status --short tests/src/org.eclipse.platform/org.eclipse.osgi/3.18.300\"}\nhuman-intervention-logs/org.eclipse.platform:org.eclipse.osgi:3.18.300/add-new-library-support/pi-generation-2026-05-02T16-32-54-763809Z.log:4073:[tool-call] end id=call_9cp6ZolJ8FLoWK0TQ50v0LLB|fc_03ad01c0eee629e20169f62726761c819f82ec9734801717b0 n