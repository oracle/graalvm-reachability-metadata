  			}
  		}
  		return resources;
  	}
  
  	@Override
  	public @Nullable URL getResource(String name) {
  		ClassLoaderFile file = this.updatedFiles.getFile(name);
  		if (file != null && file.getKind() == Kind.DELETED) {
  			return null;
  		}
