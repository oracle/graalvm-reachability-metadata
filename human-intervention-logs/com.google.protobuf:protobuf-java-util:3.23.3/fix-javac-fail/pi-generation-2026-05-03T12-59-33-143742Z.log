wnFields(String json, Message.Builder builder) throws IOException {\n        JsonFormat.parser().ignoringUnknownFields().merge(json, builder);\n    }\n\n    @Test\n    public void testAllFields() throws Exception {\n        TestAllTypes.Builder builder = TestAllTypes.newBuilder();\n        setAllFields(builder);\n        TestAllTypes message = builder.build();\n        assertThat(toJsonString(message)).isEqualTo(\n                \"\"\"\n                        {\n                          \"optionalInt32\": 1234,\n                          \"optionalInt64\": \"1234567890123456789\",\n                          \"optionalUint32\": 5678,\n                          \"optionalUint64\": \"2345678901234567890\",\n                          \"optionalSint32\": 9012,\n                          \"optionalSint64\": \"3456789012345678901\",\n                          \"optionalFixed32\": 3456,\n                          \"optionalFixed64\": \"4567890123456789012\",\n                          \"optionalSfixed32\": 7890,\n                          \"optionalSfixed64\": \"5678901234567890123\",\n                          \"optionalFloat\": 1.5,\n                          \"optionalDouble\": 1.25,\n                          \"optionalBool\": true,\n                          \"optionalString\": \"Hello world!\",\n                          \"optionalBytes\": \"AAEC\",\n                          \"optionalNestedMessage\": {\n                            \"value\": 100\n                          },\n                          \"optionalNestedEnum\": \"BAR\",\n\n[1796 more lines in file. Use offset=201 to continue.]"}], "isError": false, "timestamp": 1777813146269}, {"role": "toolResult", "toolCallId": "call_i7fr2uyo9xKGBD1hUnn8JeZm|fc_05d0d9aefe25e5d30169f74699fa6c81a0b6d22047311c6607", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, 