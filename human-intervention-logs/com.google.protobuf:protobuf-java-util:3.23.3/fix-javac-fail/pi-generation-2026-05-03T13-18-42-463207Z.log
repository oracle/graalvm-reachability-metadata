eldDescriptorProto.newBuilder().setName(\"field_name\").setNumber(1))\n                .setOptions(DescriptorOptions.newBuilder()\n                        .setDeprecated(true)\n                        .setJavaPackage(\"com.example\"))\n                .build();\n        FieldMask mask = FieldMaskUtil.fromStringList(ImmutableList.of(\"name\", \"options.deprecated\"));\n        DescriptorProto actual = FieldMaskUtil.trim(mask, source);\n        assertThat(actual).isEqualTo(DescriptorProto.newBuilder()\n                .setName(\"message_name\")\n                .setOptions(DescriptorOptions.newBuilder().setDeprecated(true))\n                .build());\n"}]}
