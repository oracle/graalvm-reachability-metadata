  package com_google_protobuf.protobuf_java_util;
  
  import com.google.common.collect.ImmutableList;
  import com.google.common.truth.Truth;
  import com.google.protobuf.DescriptorProtos.DescriptorOptions;
  import com.google.protobuf.DescriptorProtos.DescriptorProto;
  import com.google.protobuf.DescriptorProtos.FieldDescriptorProto;
  import com.google.protobuf.FieldMask;
  import com.google.protobuf.util.FieldMaskUtil;
  import org.junit.Test;
  
  import static com.google.common.truth.Truth.assertThat;
  import static com.google.common.truth.Truth.assertWithMessage;
  
  @SuppressWarnings("UnusedAssignment")
  public class FieldMaskUtilTest {
      @Test
      public void testIsValid() {
          Truth.assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "name")).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "nonexist")).isFalse();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "options.deprecated")).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "field")).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "nested_type")).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "options.nonexist")).isFalse();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, FieldMaskUtil.fromString("name"))).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, FieldMaskUtil.fromString("nonexist"))).isFalse();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, FieldMaskUtil.fromString("name,nonexist"))).isFalse();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), "name")).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), "nonexist")).isFalse();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), FieldMaskUtil.fromString("name"))).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), FieldMaskUtil.fromString("nonexist"))).isFalse();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "options.deprecated")).isTrue();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "field.name")).isFalse();
          assertThat(FieldMaskUtil.isValid(DescriptorProto.class, "name.value")).isFalse();
      }
  
      @Test
      public void testToString() {
          assertThat(FieldMaskUtil.toString(FieldMask.getDefaultInstance())).isEmpty();
          FieldMask mask = FieldMask.newBuilder().addPaths("foo").build();
          assertThat(FieldMaskUtil.toString(mask)).isEqualTo("foo");
          mask = FieldMask.newBuilder().addPaths("foo").addPaths("bar").build();
          assertThat(FieldMaskUtil.toString(mask)).isEqualTo("foo,bar");
          mask = FieldMask.newBuilder().addPaths("").addPaths("foo").addPaths("").addPaths("bar").addPaths("").build();
          assertThat(FieldMaskUtil.toString(mask)).isEqualTo("foo,bar");
      }
  
      @Test
      public void testFromString() {
          FieldMask mask = FieldMaskUtil.fromString("");
          assertThat(mask.getPathsCount()).isEqualTo(0);
          mask = FieldMaskUtil.fromString("foo");
          assertThat(mask.getPathsCount()).isEqualTo(1);
          assertThat(mask.getPaths(0)).isEqualTo("foo");
          mask = FieldMaskUtil.fromString("foo,bar.baz");
          assertThat(mask.getPathsCount()).isEqualTo(2);
          assertThat(mask.getPaths(0)).isEqualTo("foo");
          assertThat(mask.getPaths(1)).isEqualTo("bar.baz");
          mask = FieldMaskUtil.fromString(",foo,,bar,");
          assertThat(mask.getPathsCount()).isEqualTo(2);
          assertThat(mask.getPaths(0)).isEqualTo("foo");
          assertThat(mask.getPaths(1)).isEqualTo("bar");
          mask = FieldMaskUtil.fromString(DescriptorProto.class, ",name");
          try {
              mask = FieldMaskUtil.fromString(DescriptorProto.class, "name,nonexist");
              assertWithMessage("Exception is expected.").fail();
          } catch (IllegalArgumentException ignored) {
          }
      }
  
      @Test
      public void testFromFieldNumbers() {
          FieldMask mask = FieldMaskUtil.fromFieldNumbers(DescriptorProto.class);
          assertThat(mask.getPathsCount()).isEqualTo(0);
          mask = FieldMaskUtil.fromFieldNumbers(DescriptorProto.class, DescriptorProto.NAME_FIELD_NUMBER);
          assertThat(mask.getPathsCount()).isEqualTo(1);
          assertThat(mask.getPaths(0)).isEqualTo("name");
          mask = FieldMaskUtil.fromFieldNumbers(
                  DescriptorProto.class,
                  DescriptorProto.NAME_FIELD_NUMBER,
                  DescriptorProto.OPTIONS_FIELD_NUMBER);
          assertThat(mask.getPathsCount()).isEqualTo(2);
          assertThat(mask.getPaths(0)).isEqualTo("name");
          assertThat(mask.getPaths(1)).isEqualTo("options");
          try {
              int invalidFieldNumber = 1000;
              mask = FieldMaskUtil.fromFieldNumbers(DescriptorProto.class, invalidFieldNumber);
              assertWithMessage("Exception is expected.").fail();
          } catch (IllegalArgumentException expected) {
          }
      }
  
      @Test
      public void testToJsonString() {
          FieldMask mask = FieldMask.getDefaultInstance();
          assertThat(FieldMaskUtil.toJsonString(mask)).isEmpty();
          mask = FieldMask.newBuilder().addPaths("foo").build();
          assertThat(FieldMaskUtil.toJsonString(mask)).isEqualTo("foo");
          mask = FieldMask.newBuilder().addPaths("foo.bar_baz").addPaths("").build();
          assertThat(FieldMaskUtil.toJsonString(mask)).isEqualTo("foo.barBaz");
          mask = FieldMask.newBuilder().addPaths("foo").addPaths("bar_baz").build();
          assertThat(FieldMaskUtil.toJsonString(mask)).isEqualTo("foo,barBaz");
      }
  
      @Test
      public void testFromJsonString() {
          FieldMask mask = FieldMaskUtil.fromJsonString("");
          assertThat(mask.getPathsCount()).isEqualTo(0);
          mask = FieldMaskUtil.fromJsonString("foo");
          assertThat(mask.getPathsCount()).isEqualTo(1);
          assertThat(mask.getPaths(0)).isEqualTo("foo");
          mask = FieldMaskUtil.fromJsonString("foo.barBaz");
          assertThat(mask.getPathsCount()).isEqualTo(1);
          assertThat(mask.getPaths(0)).isEqualTo("foo.bar_baz");
          mask = FieldMaskUtil.fromJsonString("foo,barBaz");
          assertThat(mask.getPathsCount()).isEqualTo(2);
          assertThat(mask.getPaths(0)).isEqualTo("foo");
          assertThat(mask.getPaths(1)).isEqualTo("bar_baz");
      }
  
      @Test
      public void testFromStringList() {
          FieldMask mask = FieldMaskUtil.fromStringList(DescriptorProto.class, ImmutableList.of("options.deprecated", "field"));
          assertThat(mask).isEqualTo(FieldMask.newBuilder()
                  .addPaths("options.deprecated")
                  .addPaths("field")
                  .build());
          mask = FieldMaskUtil.fromStringList(DescriptorProto.getDescriptor(), ImmutableList.of("options.deprecated", "field"));
          assertThat(mask).isEqualTo(FieldMask.newBuilder().addPaths("options.deprecated").addPaths("field").build());
          mask = FieldMaskUtil.fromStringList(ImmutableList.of("options.deprecated", "field"));
          assertThat(mask).isEqualTo(FieldMask.newBuilder()
                  .addPaths("options.deprecated")
                  .addPaths("field")
                  .build());
      }
  
      @Test
      public void testUnion() {
          FieldMask mask1 = FieldMaskUtil.fromString("foo,bar.baz,bar.quz");
          FieldMask mask2 = FieldMaskUtil.fromString("foo.bar,bar");
          FieldMask result = FieldMaskUtil.union(mask1, mask2);
          assertThat(FieldMaskUtil.toString(result)).isEqualTo("bar,foo");
      }
  
      @Test
      public void testUnion_usingVarArgs() {
          FieldMask mask1 = FieldMaskUtil.fromString("foo");
          FieldMask mask2 = FieldMaskUtil.fromString("foo.bar,bar.quz");
          FieldMask mask3 = FieldMaskUtil.fromString("bar.quz");
          FieldMask mask4 = FieldMaskUtil.fromString("bar");
          FieldMask result = FieldMaskUtil.union(mask1, mask2, mask3, mask4);
          assertThat(FieldMaskUtil.toString(result)).isEqualTo("bar,foo");
      }
  
      @Test
      public void testSubstract() {
          FieldMask mask1 = FieldMaskUtil.fromString("foo,bar.baz,bar.quz");
          FieldMask mask2 = FieldMaskUtil.fromString("foo.bar,bar");
          FieldMask result = FieldMaskUtil.subtract(mask1, mask2);
          assertThat(FieldMaskUtil.toString(result)).isEqualTo("foo");
      }
  
      @Test
      public void testSubstract_usingVarArgs() {
          FieldMask mask1 = FieldMaskUtil.fromString("foo,bar.baz,bar.quz.bar");
          FieldMask mask2 = FieldMaskUtil.fromString("foo.bar,bar.baz.quz");
          FieldMask mask3 = FieldMaskUtil.fromString("bar.quz");
          FieldMask mask4 = FieldMaskUtil.fromString("foo,bar.baz");
          FieldMask result = FieldMaskUtil.subtract(mask1, mask2, mask3, mask4);
          assertThat(FieldMaskUtil.toString(result)).isEmpty();
      }
  
      @Test
      public void testIntersection() {
          FieldMask mask1 = FieldMaskUtil.fromString("foo,bar.baz,bar.quz");
          FieldMask mask2 = FieldMaskUtil.fromString("foo.bar,bar");
          FieldMask result = FieldMaskUtil.intersection(mask1, mask2);
          assertThat(FieldMaskUtil.toString(result)).isEqualTo("bar.baz,bar.quz,foo.bar");
      }
  
      @Test
      public void testMerge() {
          DescriptorProto source = DescriptorProto.newBuilder()
                  .setOptions(DescriptorOptions.newBuilder().setDeprecated(true))
                  .build();
          DescriptorProto.Builder builder = DescriptorProto.newBuilder();
          FieldMaskUtil.merge(FieldMaskUtil.fromString("options"), source, builder);
          assertThat(builder.getOptions().getDeprecated()).isTrue();
      }
  
      @Test
      public void testTrim() {
          DescriptorProto source = DescriptorProto.newBuilder()
                  .setName("message_name")
                  .addField(FieldDescriptorProto.newBuilder().setName("field_name").setNumber(1))
                  .setOptions(DescriptorOptions.newBuilder()
                          .setDeprecated(true)
                          .setJavaPackage("com.example"))
                  .build();
          FieldMask mask = FieldMaskUtil.fromStringList(ImmutableList.of("name", "options.deprecated"));
          DescriptorProto actual = FieldMaskUtil.trim(mask, source);
          assertThat(actual).isEqualTo(DescriptorProto.newBuilder()
                  .setName("message_name")
                  .setOptions(DescriptorOptions.newBuilder().setDeprecated(true))
                  .build());
      }
  }
