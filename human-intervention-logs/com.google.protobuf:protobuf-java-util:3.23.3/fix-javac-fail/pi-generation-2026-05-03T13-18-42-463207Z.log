Types.getDescriptor(), \"nonexist\")).isFalse();\n        assertThat(FieldMaskUtil.isValid(NestedTestAllTypes.getDescriptor(), FieldMaskUtil.fromString(\"payload\"))).isTrue();\n        assertThat(FieldMaskUtil.isValid(NestedTestAllTypes.getDescriptor(), FieldMaskUtil.fromString(\"nonexist\"))).isFalse();\n        assertThat(FieldMaskUtil.isValid(NestedTestAllTypes.class, \"payload.optional_nested_message.bb\")).isTrue();\n        assertThat(FieldMaskUtil.isValid(NestedTestAllTypes.class, \"payload.repeated_nested_message.bb\")).isFalse();\n        assertThat(FieldMaskUtil.isValid(NestedTestAllTypes.class, \"payload.optional_int32.bb\")).isFalse();\n","newText":"        Truth.assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"name\")).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"nonexist\")).isFalse();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"options.deprecated\")).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"field\")).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"nested_type\")).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"options.nonexist\")).isFalse();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, FieldMaskUtil.fromString(\"name\"))).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, FieldMaskUtil.fromString(\"nonexist\"))).isFalse();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, FieldMaskUtil.fromString(\"name,nonexist\"))).isFalse();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), \"name\")).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), \"nonexist\")).isFalse();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), FieldMaskUtil.fromString(\"name\"))).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.getDescriptor(), FieldMaskUtil.fromString(\"nonexist\"))).isFalse();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"options.deprecated\")).isTrue();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"field.name\")).isFalse();\n        assertThat(FieldMaskUtil.isValid(DescriptorProto.class, \"name.value\")).isFalse();\n"},{"oldText":"        mask = FieldMaskUtil.fromString(NestedTestAllTypes.class, \",payload\");\n        try {\n            mask = FieldMaskUtil.fromString(NestedTestAllTypes.class, \"payload,nonexist\");\n","newText":"        mask = FieldMaskUtil.fromString(DescriptorProto.class, \",name\");\n        try {\n            mask = FieldMaskUtil.fromString(DescriptorProto.class, \"name,nonexist\");\n"},{"oldText":"        FieldMask mask = FieldMaskUtil.fromFieldNumbers(TestAllTypes.class);\n        assertThat(mask.getPathsCount()).isEqualTo(0);\n        mask = FieldMaskUtil.fromFieldNumbers(TestAllTypes.class, TestAllTypes.OPTIONAL_INT32_FIELD_NUMBER);\n        assertThat(mask.getPathsCount()).isEqualTo(1);\n        assertThat(mask.getPaths(0)).isEqualTo(\"optional_int32\");\n        mask = FieldMaskUtil.fromFieldNumbers(\n                TestAllTypes.class,\n                TestAllTypes.OPTIONAL_INT32_FIELD_NUMBER,\n                TestAllTypes.OPTIONAL_INT64_FIELD_NUMBER);\n        assertThat(mask.getPathsCount()).isEqualTo(2);\n        assertThat(mask.getPaths(0)).isEqualTo(\"optional_int32\");\n        assertThat(mask.getPaths(1)).isEqualTo(\"optional_int64\");\n        try {\n            int invalidFieldNumber = 1000;\n            mask = FieldMaskUtil.fromFieldNumbers(TestAllTypes.class, invalidFieldNumber);\n","newText":"        FieldMask mask = FieldMaskUtil.fromFieldNumbers(DescriptorProto.class);\n        assertThat(mask.getPathsCount()).isEqualTo(0);\n        mask = FieldMaskUtil.fromFieldNumbers(DescriptorProto.class, DescriptorProto.NAME_FIELD_NUMBER);\n        assertThat(mask.getPathsCount()).isEqualTo(1);\n        assertThat(mask.getPaths(0)).isEqualTo(\"name\");\n        mask = FieldMaskUtil.fromFieldNumbers(\n                DescriptorProto.class,\n                DescriptorProto.NAME_FIELD_NUMBER,\n                DescriptorProto.OPTIONS_FIELD_NUMBER);\n        assertThat(mask.getPathsCount()).isEqualTo(2);\n        assertThat(mask.getPaths(0)).isEqualTo(\"name\");\n        assertThat(mask.getPaths(1)).isEqualTo(\"options\");\n        try {\n            int invalidFieldNumber = 1000;\n            mask = FieldMaskUtil.fromFieldNumbers(DescriptorProto.class, invalidFieldNumber);\n"},{"oldText":"        FieldMask mask = FieldMaskUtil.fromStringList(NestedTestAllTypes.class, ImmutableList.of(\"payload.repeated_nested_message\", \"child\"));\n        assertThat(mask).isEqualTo(FieldMask.newBuilder()\n                .addPaths(\"payload.repeated_nested_message\")\n                .addPaths(\"child\")\n                .build());\n        mask = FieldMaskUtil.fromStringList(NestedTestAllTypes.getDescriptor(), ImmutableList.of(\"payload.repeated_nested_message\", \"child\"));\n        assertThat(mask).isEqualTo(FieldMask.newBuilder().addPaths(\"payload.repeated_nested_message\").addPaths(\"child\").build());\n        mask = FieldMaskUtil.fromStringList(ImmutableList.of(\"payload.repeated_nested_message\", \"child\"));\n        assertThat(mask).isEqualTo(FieldMask.newBuilder()\n                .addPaths(\"payload.repeated_nested_message\")\n                .addPaths(\"child\")\n                .build());\n","newText":"        FieldMask mask = FieldMaskUtil.fromStringList(DescriptorProto.class, ImmutableList.of(\"options.deprecated\", \"field\"));\n        assertThat(mask).isEqualTo(FieldMask.newBuilder()\n                .addPaths(\"options.deprecated\")\n                .addPaths(\"field\")\n                .build());\n        mask = FieldMaskUtil.fromStringList(DescriptorProto.getDescriptor(), ImmutableList.of(\"options.deprecated\", \"field\"));\n        assertThat(mask).isEqualTo(FieldMask.newBuilder().addPaths