              propertyName,
              new SimplePropertyDescriptor(
                  propertyName,
                  read != null ? read : descriptor.getReadMethod(),
                  writeMethod != null ? writeMethod : descriptor.getWriteMethod()));
        }
      }
  
      SimplePropertyDescriptor[] pdsArray = new SimplePropertyDescriptor[properties.size()];
