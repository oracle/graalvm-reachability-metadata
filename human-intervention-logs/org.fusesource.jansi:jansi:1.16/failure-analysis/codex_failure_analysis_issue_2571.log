try {\\\\n            PlatformDependent.setMemory(address, capacity, (byte) 0);\\\\n\\\\n            if (PlatformDependent.hasDirectBufferNoCleanerConstructor()) {\\\\n                ByteBuffer buffer = PlatformDependent.directBuffer(address, capacity);\\\\n                buffer.putInt(0, 0x12345678);\\\\n\\\\n                assertTrue(buffer.isDirect());\\\\n                assertEquals(capacity, buffer.capacity());\\\\n                assertEquals(0x12345678, PlatformDependent.getInt(address));\\\\n            } else {\\\\n                assertThrows(UnsupportedOperationException.class, () -> PlatformDependent.directBuffer(address,\\\\n                        capacity));\\\\n            }\\\\n        } finally {\\\\n            PlatformDependent.freeMemory(address);\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    public void allocatesDirectNoCleanerBufferWhenConstructorPathIsAvailable() {\\\\n        if (!PlatformDependent.useDirectBufferNoCleaner()) {\\\\n            assertTrue(!PlatformDependent.hasDirectBufferNoCleanerConstructor()\\\\n                    || PlatformDependent.maxDirectMemory() == 0);\\\\n            return;\\\\n        }\\\\n\\\\n        ByteBuffer buffer = PlatformDependent.allocateDirectNoCleaner(32);\\\\n        try {\\\\n            long address = PlatformDependent.directBufferAddress(buffer);\\\\n            buffer.putLong(0, 0x0102030405060708L);\\\\n\\\\n            assertTrue(buffer.isDirect());\\\\n            assertEquals(32, buffer.capacity());\\\\n            assertEquals(0x0102030405060708L, PlatformDependent.getLong(address));\\\\n        } finally {\\\\n            PlatformDependent.freeDirectNoCleaner(buffer);\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    public void reallocatesDirectNoCleanerBufferWhenConstructorPathIsAvailable() {\\\\n        if (!PlatformDependent.useDirectBufferNoCleaner()) {\\\\n            assertTrue(!PlatformDependent.hasDirectBufferNoCleanerConstructor()\\\\n                    || PlatformDependent.maxDirectMemory() == 0);\\\\n            return;\\\\n        }\\\\n\\\\n        ByteBuffer buffer = PlatformDependent.allocateDirectNoCleaner(16);\\\\n        try {\\\\n            buffer.putLong(0, 0x1112131415161718L);\\\\n            ByteBuffer reallocated = PlatformDependent.reallocateDirectNoCleaner(buffer, 32);\\\\n            buffer = reallocated;\\\\n            long address = PlatformDependent.directBufferAddress(reallocated);\\\\n\\\\n            assertTrue(reallocated.isDirect());\\\\n            assertEquals(32, reallocated.capacity());\\\\n            assertEquals(0x1112131415161718L, PlatformDependent.getLong(address));\\\\n        } finally {\\\\n            PlatformDependent.freeDirectNoCleaner(buffer);\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    public void alignsDirectByteBufferUsingPlatformSupport() {\\\\n        ByteBuffer buffer = ByteBuffer.allocateDirect(64);\\\\n        buffer.position(3);\\\\n        buffer.limit(buffer.capacity());\\\\n\\\\n        ByteBuffer aligned = PlatformDependent.alignDirectBuffer(buffer, 8);\\\\n\\\\n        assertNotNull(aligned);\\\\n        assertTrue(aligned.isDirect());\\\\n        if (PlatformDependent.hasUnsafe()) {\\\\n            assertEquals(0, PlatformDependent.directBufferAddress(aligned) % 8);\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    public void allocatesUninitializedByteArrayThroughPlatformSupport() {\\\\n        int size = 2048;\\\\n\\\\n        byte[] bytes = PlatformDependent.allocateUninitializedArray(size);\\\\n\\\\n        assertNotNull(bytes);\\\\n        assertEquals(size, bytes.length);\\\\n    }\\\\n}\\\\n\\\"}], \\\"isError\\\": false, \\\"timestamp\\\": 1777254636621}, {\\\"role\\\": \\\"toolResult\\\", \\\"toolCallId\\\": \\\"call_0EePgGRQGHMABb4nQWfuPSbk|fc_07bc8b53056ebef30169eec0ec697c8191bcb3c2c72bdbbb4d\\\", \\\"toolName\\\": \\\"read\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"/*\\\\n * Copyright and related rights waived via CC0\\\\n