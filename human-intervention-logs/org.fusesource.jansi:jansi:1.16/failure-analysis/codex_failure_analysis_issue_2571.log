jupiter.api.Test;\\\\n\\\\npublic class TrampolineTest {\\\\n\\\\n    @Test\\\\n    void invokeDispatchesToTargetMethodThroughTrampoline() throws NoSuchMethodException, InvocationTargetException, IllegalAccessException {\\\\n        Method method = MethodUtil.getMethod(InvocableTarget.class, \\\\\\\"combine\\\\\\\", new Class<?>[] {String.class, Integer.class});\\\\n\\\\n        Object result = MethodUtil.invoke(method, new InvocableTarget(), new Object[] {\\\\\\\"value-\\\\\\\", 7});\\\\n\\\\n        assertThat(result).isEqualTo(\\\\\\\"value-7\\\\\\\");\\\\n    }\\\\n\\\\n    public static final class InvocableTarget {\\\\n        public String combine(String prefix, Integer value) {\\\\n            return prefix + value;\\\\n        }\\\\n    }\\\\n}\\\\n\\\"}], \\\"isError\\\": false, \\\"timestamp\\\": 1777277298339}, {\\\"role\\\": \\\"toolResult\\\", \\\"toolCallId\\\": \\\"call_94QxGn2gZcWbMJdtexRZ9VFU|fc_0b614f36872743ca0169ef197205288195acc10109583d2b24\\\", \\\"toolName\\\": \\\"read\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"/*\\\\n * Copyright and related rights waived via CC0\\\\n *\\\\n * You should have received a copy of the CC0 legalcode along with this\\\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\\\n */\\\\npackage org_openjfx.javafx_base;\\\\n\\\\nimport static org.assertj.core.api.Assertions.assertThat;\\\\n\\\\nimport com.sun.javafx.reflect.MethodUtil;\\\\nimport java.lang.invoke.MethodHandle;\\\\nimport java.lang.invoke.MethodHandles;\\\\nimport java.lang.invoke.MethodType;\\\\nimport java.lang.reflect.Method;\\\\nimport java.security.Permission;\\\\nimport java.util.Arrays;\\\\nimport java.util.List;\\\\nimport org.junit.jupiter.api.Test;\\\\n\\\\n@SuppressWarnings(\\\\\\\"removal\\\\\\\")\\\\npublic class MethodUtilTest {\\\\n\\\\n    @Test\\\\n    void getMethodAndGetMethodsExposePublicMembers() throws NoSuchMethodException {\\\\n        Method resolvedMethod = MethodUtil.getMetho