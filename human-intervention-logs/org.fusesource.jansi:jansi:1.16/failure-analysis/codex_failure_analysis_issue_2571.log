1);\\\\n        PrivilegedAction<?> directBufferConstructorAction = newDirectBufferConstructorAction(directBuffer);\\\\n        Class<?> originalIntegerType = replaceIntegerPrimitiveType(long.class);\\\\n        try {\\\\n            Object result = directBufferConstructorAction.run();\\\\n\\\\n            assertTrue(result instanceof Constructor<?>);\\\\n            Constructor<?> directBufferConstructor = (Constructor<?>) result;\\\\n            assertEquals(directBuffer.getClass(), directBufferConstructor.getDeclaringClass());\\\\n            assertArrayEquals(new Class<?>[] { long.class, long.class }, directBufferConstructor.getParameterTypes());\\\\n        } finally {\\\\n            Class<?> restoredIntegerType = replaceIntegerPrimitiveType(originalIntegerType);\\\\n            assertSame(long.class, restoredIntegerType);\\\\n        }\\\\n    }\\\\n\\\\n    private static PrivilegedAction<?> newDirectBufferConstructorAction(ByteBuffer directBuffer) throws Exception {\\\\n        Class<?> actionClass = PlatformDependent0_5Test.class.getClassLoader()\\\\n                .loadClass(DIRECT_BUFFER_CONSTRUCTOR_ACTION_CLASS_NAME);\\\\n        Constructor<?> actionConstructor = actionClass.getDeclaredConstructor(ByteBuffer.class);\\\\n        actionConstructor.setAccessible(true);\\\\n        return (PrivilegedAction<?>) actionConstructor.newInstance(directBuffer);\\\\n    }\\\\n\\\\n    private static Class<?> replaceIntegerPrimitiveType(Class<?> replacementType) throws Exception {\\\\n        Field integerTypeField = Integer.class.getDeclaredField(\\\\\\\"TYPE\\\\\\\");\\\\n        Unsafe unsafe = UnsafeAccess.UNSAFE;\\\\n        Object staticFieldBase = unsafe.staticFieldBase(integerTypeField);\\\\n        long staticFieldOffset = unsafe.staticFieldOffset(integerTypeField);\\\\n        Class<?> previousType = (Class<?>) unsafe.getObject(staticFieldBase, staticFieldOffset);\\\\n        unsafe.putObject(staticFieldBase, staticFieldOffset, replacementType);\\\\n    