   * @author Mikhail Polivakha
   * @since 4.0
   */
  public interface RowMapperFactory {
  
  	/**
  	 * Obtain a {@link RowMapper} based on the expected return type passed in as an argument.
  	 *
  	 * @param result must not be {@code null}.
