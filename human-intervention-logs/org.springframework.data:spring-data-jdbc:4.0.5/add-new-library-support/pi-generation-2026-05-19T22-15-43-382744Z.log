  		this.example = example;
  		this.sort = sort;
  		this.limit = limit;
  		this.resultType = resultType;
  		this.fieldsToInclude = fieldsToInclude;
  		this.projectionFactory = projectionFactory;
  		this.converter = converter;
  	}
  
  	@Override
  	public FetchableFluentQuery<R> sortBy(Sort sort) {
  
