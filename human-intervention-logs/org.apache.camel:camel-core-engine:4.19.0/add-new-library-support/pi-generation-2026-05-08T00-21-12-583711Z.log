  +                public void configure() {
  +                    onException(IllegalArgumentException.class)
  +                            .handled(true)
  +                            .process(exchange -> {
  +                                Exception exception = exchange.getProperty(Exchange.EXCEPTION_CAUGHT, Exception.class);
