index.json:9:    \"description\": \"Camel Base Engine provides Apache Camel's core runtime implementation classes, including the base CamelContext machinery, factory and resolver infrastructure, route services, templates, and debugging or tracing support. It sits above camel-base and supplies the engine services that wire components, endpoints, processors, registries, lifecycle strategies, management hooks, and resource resolvers into a running Camel context.\",\nmetadata/org.apache.kafka/kafka-streams/3.5.1/reachability-metadata.json:133:  \"resources\": [\nmetadata/org.apache.camel/camel-base-engine/4.20.0/reachability-metadata.json:132:  \"resources\" : [\nmetadata/com.google.api.grpc/proto-google-cloud-secretmanager-v1beta2/index.json:9:    \"description\" : \"This artifact provides the generated Java Protocol Buffer message classes and descriptors for the Google Cloud Secret Manager v1beta2 API. JVM and gRPC/protobuf clients use it to serialize requests and responses for managing secrets, secret versions, IAM policies, and related Secret Manager resources.\",\nmetadata/io.dropwizard.metrics5/metrics-core/5.0.1/reachability-metadata.json:2:  \"resources\": [\nmetadata/org.apache.kafka/kafka-streams/3.6.0/reachability-metadata.json:66:      \"type\" : \"org.apache.kafka.common.resource.PatternType[]\"\nmetadata/org.apache.kafka/kafka-streams/3.6.0/reachability-metadata.json:671:  \"resources\" : [\nmetadata/jakarta.persistence/jakarta.persistence-api/4.0.0-M2/reachability-metadata.json:21:  \"resources\" : [\nmetadata/io.dropwizard.metrics5/metrics-core/5.0.0/reachability-metadata.json:2:  \"resources\": [\nmetadata/org.jboss.logging/jboss-logging-processor/index.json:9:    \"description\" : \"JBoss Logging Processor is the annotation processor for JBoss Logging Tools that processes annotated message bundle and logger interfaces. It validates logging metadata and generates typed implementation classes and translation resources at compile time.\",\nmetadata/org.jboss.logging/jboss-logging-processor/index.json:31:    \"description\" : \"JBoss Logging Processor is the annotation processor for JBoss Logging Tools that processes annotated message bundle and logger interfaces. It validates logging metadata and generates typed implementation classes and translation resources at compile time.\",\nmetadata/jakarta.persistence/jakarta.persistence-api/3.0.0/reachability-metadata.json:21:  \"resources\" : [\nmetadata/io.github.resilience4j/resilience4j-bulkhead/index.json:9:    \"description\" : \"Resilience4j Bulkhead provides semaphore- and thread-pool-based bulkhead implementations that limit concurrent calls to protected code. It helps isolate failures and prevent one overloaded dependency or code path from exhausting resources needed by the rest of a JVM application.\",\nmetadata/jakarta.persistence/jakarta.persistence-api/3.2.0/reachability-metadata.json:21:  \"resources\" : [\nmetadata/jakarta.persistence/jakarta.persistence-api/4.0.0-M1/reachability-metadata.json:21:  \"resources\" : [\nmetadata/com.beust/jcommander/1.78/reachability-metadata.json:207:  \"resources\" : [\nmetadata/dev.zio/zio_3/index.json:9:    \"description\" : \"ZIO is a Scala 3 effect system for building asynchronous, concurrent, and resource-safe applications on the JVM. It provides the core runtime and data types for composing typed effects, managing fibers, scheduling work, and handling errors.\",\nmetadata/com.beust/jcommander/1.75/reachability-metadata.json:201:  \"resources\" : [\nmetadata/org.immutables/value/2.8.2/reachability-metadata.json:272:  \"resources\" : [\nmetadata/com.beust/jcommander/1.72/reachability-metadata.json:219:  \"resources\" : [\nmetadata/dev.zio/zio-test_3/index.json:9:    \"description\" : \"ZIO Test is the testing module for ZIO, providing a composable Scala test framework built around ZIO effects. It supplies assertions, generators, test aspects, test services, reporting support, and execution tools for testing effectful, concurrent, and resource-safe Scala applications.\",\nmetadata/org.apache.ant/ant-launcher/1.8.1/reachability-metadata.json:10:  \"resources\": [\nmetadata/org.apache.ant/ant-launcher/1.8.1/reachability-metadata.json:15:      \"glob\": \"org/example/locator-resource.txt\"\nmetadata/org.apache.ant/ant-launcher/1.8.1/reachability-metadata.json:21:      \"glob\": \"org/example/missing-locator-resource.txt\"\nmetadata/com.graphql-java/graphql-java/19.7/reachability-metadata.json:2:  \"resources\" : [\nmetadata/com.graphql-java/graphql-java/19.2/reachability-metadata.json:74:  \"resources\": [\nmetadata/org.immutables/value/2.8.9-ea-0/reachability-metadata.json:360:  \"resources\" : [\nmetadata/com.graphql-java/graphql-java/2018-06-27T00-18-28-1e12da9/reachability-metadata.json:2:  \"resources\" : [\nmetadata/org.springframework.security/spring-security-crypto/6.0.0/reachability-metadata.json:232:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpclient/4.5.5/reachability-metadata.json:27:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpcore/4.4.10/reachability-metadata.json:32:  \"resources\": [\nmetadata/org.springframework.security/spring-security-crypto/5.7.3/reachability-metadata.json:232:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpclient/4.5.14/reachability-metadata.json:16:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpcore/4.0.1/reachability-metadata.json:25:  \"resources\": [\nmetadata/org.springframework.security/spring-security-crypto/6.4.0/reachability-metadata.json:238:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpcore/4.4.12/reachability-metadata.json:32:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpcore/4.4.14/reachability-metadata.json:32:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpcore/4.4.15/reachability-metadata.json:32:  \"resources\": [\nmetadata/org.apache.httpcomponents/httpcore/4.4.9/reachability-metadata.json:32:  \"resources\": [\nmetadata/org.apache.httpcomponent