:2:  \"resources\": [\nmetadata/org.apache.openejb/javaee-api/5.0-2/reachability-metadata.json:10:  \"resources\" : [\nmetadata/org.apache.openejb/javaee-api/index.json:4:    \"allowed-packages\": [ \"javax.activation\", \"javax.annotation\", \"javax.ejb\", \"javax.enterprise.deploy\", \"javax.interceptor\", \"javax.jms\", \"javax.jws\", \"javax.mail\", \"javax.management.j2ee\", \"javax.persistence\", \"javax.resource\", \"javax.security.jacc\", \"javax.servlet\", \"javax.transaction\", \"javax.xml\", \"org.apache.geronimo.mail\" ],\nmetadata/org.osgi/org.osgi.resource/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/osgi/org.osgi.resource/$version$/org.osgi.resource-$version$-sources.jar\",\nmetadata/org.osgi/org.osgi.resource/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/osgi/org.osgi.resource/$version$/org.osgi.resource-$version$-javadoc.jar\",\nmetadata/org.osgi/org.osgi.resource/index.json:9:    \"description\" : \"org.osgi.resource provides the OSGi Resource API, a set of interfaces for describing resources, their capabilities, requirements, wires, and wirings. It is used by OSGi frameworks and related services to model dependency resolution and the resolved wiring state of bundles or repository resources.\",\nmetadata/org.osgi/org.osgi.resource/index.json:15:      \"org.osgi.resource\"\nmetadata/dev.zio/zio-interop-cats_3/index.json:9:    \"description\" : \"ZIO Interop Cats provides type class instances and syntax that let ZIO effects, streams, queues, STM, and related data types work with Cats, Cats Effect, Cats MTL, and FS2 APIs. It helps Scala applications use ZIO with Typelevel libraries while preserving ZIO's typed errors, environments, resources, and concurrency abstractions.\",\nmetadata/org.osgi/org.osgi.service.repository/index.json:9:    \"description\" : \"This OSGi companion API defines the Repository service for discovering resources and the capabilities that satisfy OSGi requirements. It also provides requirement expression and builder types used by resolvers and repository implementations to describe and query repository contents.\",\nmetadata/org.apache.lucene/lucene-core/5.3.0/reachability-metadata.json:298:  \"resources\" : [\nmetadata/org.osgi/osgi.core/8.0.0/reachability-metadata.json:72:  \"resources\" : [\nmetadata/org.osgi/org.osgi.namespace.service/index.json:9:    \"description\" : \"This artifact defines the OSGi service namespace constants used to describe service capabilities and requirements in OSGi resource metadata. It provides the ServiceNamespace API for expressing service object class attributes and matching metadata rather than a runtime service implementation.\",\nmetadata/org.apache.lucene/lucene-core/5.5.0/reachability-metadata.json:298:  \"resources\" : [\nmetadata/io.opentelemetry.semconv/opentelemetry-semconv/index.json:8:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the semantic attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to telemetry attributes consistently when producing traces, metrics, logs, and resource metadata.\",\nmetadata/io.opentelemetry.semconv/opentelemetry-semconv/index.json:23:    \"description\" : \"OpenTelemetry Semantic Conventions provides generated Java constants for the stable semantic attributes defined by the OpenTelemetry specification. Applications and instrumentation libraries use it to refer to telemetry attributes consistently when producing traces, metrics, logs, and resource metadata.\",\nmetadata/org.apache.lucene/lucene-core/4.10.4/reachability-metadata.json:357:  \"resources\" : [\nmetadata/org.apache.lucene/lucene-core/5.1.0/reachability-metadata.json:298:  \"resources\" : [\nmetadata/org.liquibase/liquibase-core/4.25.0/reachability-metadata.json:8967:  \"resources\": [\nmetadata/org.apache.velocity/velocity-engine-core/2.3/reachability-metadata.json:549:        \"typeReached\" : \"org.apache.velocity.runtime.resource.ResourceManagerImpl\"\nmetadata/org.apache.velocity/velocity-engine-core/2.3/reachability-metadata.json:551:      \"type\" : \"org.apache.velocity.runtime.resource.ResourceCacheImpl\",\nmetadata/org.apache.velocity/velocity-engine-core/2.3/reachability-metadata.json:563:      \"type\" : \"org.apache.velocity.runtime.resource.ResourceManagerImpl\",\nmetadata/org.apache.velocity/velocity-engine-core/2.3/reachability-metadata.json:573:        \"typeReached\" : \"org.apache.velocity.runtime.resource.loader.ResourceLoaderFactory\"\nmetadata/org.apache.velocity/velocity-engine-core/2.3/reachability-metadata.json:575:      \"type\" : \"org.apache.velocity.runtime.resource.loader.FileResourceLoader\",\nmetadata/org.apache.velocity/velocity-engine-core/2.3/reachability-metadata.json:647:  \"resources\" : [\nmetadata/org.osgi/osgi.core/index.json:9:    \"description\" : \"OSGi Core provides the Release 8 Java API interfaces and classes used to compile bundles for the OSGi module and service platform. It defines the framework contracts for bundle lifecycle management, service registration, permissions, resource wiring, and related behaviors implemented by OSGi-compliant runtimes.\",\nmetadata/org.osgi/osgi.core/index.json:23:    \"description\" : \"OSGi Core provides the Release 7 API interfaces and classes used to compile bundles for the OSGi module and service platform. It defines framework contracts for bundles, lifecycle management, service registration, permissions, and resource wiring that OSGi-compliant runtimes implement.\",\nmetadata/org.apache.velocity/velocity-engine-core/index.json:9:    \"description\" : \"Apache Velocity Engine Core is the runtime for Apache Velocity, a Java template engine that merges templates with context data to produce text output. It provides the parser, template rendering engine, resource loading, introspection, and macro support used to embed Velocity templating in JVM applications.\",\nmetadata/org.apache.lucene/lucene-core/5.0.0/reachability-metadata.json:345:  \"resources\" : [\nmetadata/joda-time/joda-time/2.9.9/reachability-metadata.json:33:  \"resources\": [\nmetadata/xpp3/xpp3/1.1.4c/reachability-metadata.json:64:  \"resources\" : [\nmetadata/dev.zio/zio-managed_3/index.json:9:    \"description\" : \"ZIO Managed provides the legacy ZManaged resource-management API for Scala 3 applications built on ZIO. It models acquisition, use, and release of resources as composable effects with deterministic finalization and integration with ZIO effects, scopes, streams, and layers.\",\nmetadata/javax.transaction/transaction-api/index.json:9:    \"description\" : \"The Java Transaction API defines standard interfaces and exceptions for demarcating and coordinating transactions in Java applications and application servers. It covers user-managed transactions, transaction manager operations, synchronization callbacks, and XA resource integration contracts used by compliant transaction implementations.\",\nmetadata/org.codehaus.plexus/plexus-container-default/1.0-alpha-8/reachability-metadata.json:79:      \"type\" : \"sun.util.resources.cldr.CalendarData\"\nmetadata/org.codehaus.plexus/plexus-container-default/1.0-alpha-8/reachability-metadata.json:999:  \"resources\" : [\nmetadata/ch.qos.logback/logback-core/1.2.12/reachability-metadata.json:68:  \"resources\" : [\nmetadata/com.zaxxer/HikariCP/4.0.3/reachability-metadata.json:89:  \"resources\" : [\nmetadata/org.codehaus.plexus/plexus-container-default/1.0-alpha-7/reachability-metadata.json:79:      \"type\" : \"sun.util.resources.cldr.CalendarData\"\nmetadata/org.codehaus.plexus/plexus-container-default/1.0-alpha-7/reachability-metadata.json:999:  \"resources\" : [\nmetadata/ch.qos.logback/logback-core/1.1.3/reachability-metadata.json:164:  \"resources\" : [\nmetadata/ch.qos.logback/logback-core/1.5.30/reachability-metadata.json:91:  \"resources\" : [\nmetadata/org.apache-extras.beanshell/bsh/2.0b6/reacha