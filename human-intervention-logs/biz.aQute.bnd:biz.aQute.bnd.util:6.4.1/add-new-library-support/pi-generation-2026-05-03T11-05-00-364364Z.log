[tool-call] delta {"path":"tests/src/biz.aQute.bnd/biz.aQute.bnd.util/6.4.1/src/test/java/biz_aQute_bnd/biz_aQute_bnd_util/ImmutableListInnerSerializationProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage biz_aQute_bnd.biz_aQute_bnd_util;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatExceptionOfType;\n\nimport aQute.bnd.unmodifiable.Lists;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ImmutableListInnerSerializationProxyTest {\n\t@Test\n\tvoid serializesAndDeserializesNonEmptyImmutableListThroughSerializationProxy() throws Exception {\n\t\tList<String> original = Lists.of(\"alpha\", \"beta\", \"gamma\");\n\n\t\tByteArrayOutputStream bytes = new ByteArrayOutputStream();\n\t\ttry (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n\t\t\toutput.writeObject(original);\n\t\t}\n\n\t\tObject restored;\n\t\ttry (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n\t\t\trestored = input.readObject();\n\t\t}\n\n\t\tassertThat(restored).isInstanceOf(List.class);\n\t\tassertThat((List<?>) restored).containsExactly(\"alpha\", \"beta\", \"gamma\");\n\t\tassertThat(restored).isNotSameAs(original);\n\t\tassertThatExceptionOfType(UnsupportedOperationException.class)\n\t\t\t.isThrownBy(() -> ((List<Object>) restored).add(\"delta\"));\n\t}\n}\n"}
