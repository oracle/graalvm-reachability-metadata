  package biz_aQute_bnd.biz_aQute_bnd_util;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatExceptionOfType;
  
  import aQute.bnd.unmodifiable.Lists;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.List;
  
  import org.junit.jupiter.api.Test;
  
  public class ImmutableListInnerSerializationProxyTest {
  	@Test
  	void serializesAndDeserializesNonEmptyImmutableListThroughSerializationProxy() throws Exception {
  		List<String> original = Lists.of("alpha", "beta", "gamma");
  
  		ByteArrayOutputStream bytes = new ByteArrayOutputStream();
  		try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
  			output.writeObject(original);
  		}
  
  		Object restored;
  		try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
  			restored = input.readObject();
  		}
  
  		assertThat(restored).isInstanceOf(List.class);
  		List<?> restoredList = (List<?>) restored;
  		assertThat(restoredList).containsExactly("alpha", "beta", "gamma");
  		assertThat(restoredList).isNotSameAs(original);
  		assertThatExceptionOfType(UnsupportedOperationException.class).isThrownBy(restoredList::clear);
