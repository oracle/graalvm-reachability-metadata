ssionToken = sessionToken;\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777613693759}, {\"role\": \"toolResult\", \"toolCallId\": \"call_4VoUvcH5tCdYfwZGRF9ZMH9z|fc_0f4b3e11ae42a2460169f43b7d83c88190a983d15cddb2a331\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"      \\\"fields\\\" : [\\n        {\\n          \\\"name\\\" : \\\"label\\\"\\n        },\\n        {\\n          \\\"name\\\" : \\\"cachedDisplayName\\\"\\n        }\\n      ]\\n    },\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"cn.hutool.core.builder.CompareToBuilder\\\"\\n      },\\n      \\\"type\\\" : \\\"cn_hutool.hutool_all.CompareToBuilderTest$SessionRecord\\\",\\n      \\\"fields\\\" : [\\n        {\\n          \\\"name\\\" : \\\"label\\\"\\n        },\\n        {\\n          \\\"name\\\" : \\\"sessionToken\\\"\\n        }\\n      ]\\n    },\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"cn.hutool.core.builder.EqualsBuilder\\\"\\n      },\\n      \\\"type\\\" : \\\"cn_hutool.hutool_all.EqualsBuilderTest$IdentifiedRecord\\\",\\n      \\\"fields\\\" : [\\n        {\\n          \\\"name\\\" : \\\"identifier\\\"\\n        }\\n      ]\\n    },\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"cn.hutool.core.builder.EqualsBuilder\\\"\\n      },\\n      \\\"type\\\" : \\\"cn_hutool.hutool_all.EqualsBuilderTest$RankedRecord\\\",\\n      \\\"fields\\\" : [\\n        {\\n          \\\"name\\\" : \\\"label\\\"\\n        }\\n      ]\\n    },\\n    {\\n      \\\"condition\\\" : {\\n        \\\"typeReached\\\" : \\\"cn.hutool.core.builder.EqualsBuilder\\\"\\n      },\\n      \\\"type\\\" : \\\"cn_hutool.hutool_all.EqualsBuilderTest$SessionRecord\\\",\\n      \\\"fields\\\" : [\\n        {\\n          \\\"name\\\" : \\\"label\\\"\\n        },\\n        {\\n          \\\"name\\\" : \\\"sessionToken\\\"\\n        }\\n      ]\\n    },\\n    {\\n      \\\"condition\\\" : {\\n        \\\"t