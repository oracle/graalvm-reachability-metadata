n\\t\\t\\t\\t\\tif (null != targetValue) {\\n\\t\\t\\t\\t\\t\\tactualArgs[i] = targetValue;\\n\\t\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\t\\tactualArgs[i] = args[i];\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\tactualArgs[i] = args[i];\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\tif (method.isDefault()) {\\n\\t\\t\\t// 当方法是default方法时，尤其对象是代理对象，需使用句柄方式执行\\n\\t\\t\\t// 代理对象情况下调用method.invoke会导致循环引用执行，最终栈溢出\\n\\t\\t\\treturn MethodHandleUtil.invokeSpecial(obj, method, args);\\n\\t\\t}\\n\\n\\t\\treturn (T) method.invoke(ClassUtil.isStatic(method) ? null : obj, actualArgs);\\n\\t}\\n\\n\\t/**\\n\\t * 执行对象中指定方法\\n\\n[114 more lines in file. Use offset=1090 to continue.]\"}], \"isError\": false, \"timestamp\": 1777735132667}}\n1980:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0b06730402872aed0169f615d3b160819ea0bf2a610a3f1e30\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp9hXc51xGUHc-HJ7_taU8tZcdH15SWIy_QvEVCOIMX4GFok69ee5Q5makd7NRnIkaK2PHHnzKBEQc1oYUYeduBv-FaBrQOiqKow_YN-4fozAY659d0m6vDVglYpceQ_5fMqwhNC-JTfMX06mEh9-Zr8ttxcmlp-sdqCX7ryh5TiDT2mCZt2_rD22aQFImqoFy0QprXUyNveJdIWYbCXf3W1nYJfE6fkUEZGu5avMh4xSBClAKpFewPNYcE4Zst39662e1iH2chtkIu3Ed1uDwpmwz_nBO0LW_wubIYTFg8cbTDWBD6_bXA9gojEB6prCUUyuBidZTm79Xr336BrOeLZXxk9zqiCePSzeU0rrch4wkmap4NDd8H4-KeFINMvPFNqxxuLYQQmLEZpjhXKYpHDx5agrF9JbnjUAkGIAQsLZv84iP_Wtld9FR-yN1hgfopPPz3VqKpropo_g5z-cwRmBuSl0u3yNRSUDB-R0ZoR6-_0tyz0iov8N_4yUEGD1qWn50wxM_NLKMeH03cEJQTvw0q_1wThCsDWPPr_sHpYcOJJnZdAQcyAvzJvKUuFHokMUpcx6xRMANtt9GEcvm28vpXyTKO6Qoet6cAUgwkCj8w3oGsl5NzZ6BNx_CZ6-3ejq2rHhk-V80-6qCqMTEwN5ODyDPKxDdr383kkxvrZeWXZGxtKjYnoiA3RZ7EG6ipE6JY_JvT37QvfGina4Nysh9mRUkCsbf1zNJHL2U3JTN9YxI9PV7P_blU1kz2Pw3QNHAKTA-6-fmadPj4ezk2CqBC7DD1SqVPHZXGe-Llp0iT2YjPbGf5UFw6sImvXuZ-sE9fmZku4hgL1r4QSbXlPQZIw3CZ5TND7MwAru6jjg4eCWJiGiPpFbOfkmOpLMphvVMqIz0QtYZ6JDcYdMaXomIXQm-i98dqEoYsSL8nDbJRtb5eE8KRw