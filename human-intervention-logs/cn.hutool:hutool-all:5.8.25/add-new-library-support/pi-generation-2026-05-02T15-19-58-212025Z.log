[tool-call] delta {"path":"tests/src/cn.hutool/hutool-all/5.8.25/src/test/java/cn_hutool/hutool_all/ReflectUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cn_hutool.hutool_all;\n\nimport cn.hutool.core.util.ReflectUtil;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\nimport java.util.Map;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectUtilTest {\n    @Test\n    void createsInstancesFromClassNameAndConstructors() {\n        Object stringBuilder = ReflectUtil.newInstance(\"java.lang.StringBuilder\");\n        assertThat(stringBuilder).isInstanceOf(StringBuilder.class);\n\n        DefaultPojo defaultPojo = ReflectUtil.newInstance(DefaultPojo.class);\n        assertThat(defaultPojo.getName()).isEqualTo(\"default\");\n\n        ConstructorPojo constructorPojo = ReflectUtil.newInstance(ConstructorPojo.class, \"Ada\", Integer.valueOf(42));\n        assertThat(constructorPojo.describe()).isEqualTo(\"Ada:42\");\n    }\n\n    @Test\n    void discoversConstructorsFieldsAndMethodsDirectly() {\n        Constructor<?>[] constructors = ReflectUtil.getConstructorsDirectly(ChildPojo.class);\n        assertThat(constructors).isNotEmpty();\n\n        Field[] fieldsWithParents = ReflectUtil.getFieldsDirectly(ChildPojo.class, true);\n        assertThat(Arrays.stream(fieldsWithParents).map(Field::getName))\n                .contains(\"childName\", \"baseName\");\n\n        Method[] interfaceMethods = ReflectUtil.getMethodsDirectly(GreetingContract.class, true, true);\n        assertThat(Arrays.stream(interfaceMethods).map(Method::getName))\n                .contains(\"fromInterface\", \"defaultGreeting\");\n\n        Method[] declaredInterfaceMethods = ReflectUtil.getMethodsDirectly(GreetingContract.class, false, true);\n        assertThat(Arrays.stream(declaredInterfaceMethods).map(Method::getName))\n                .contains(\"fromInterface\", \"defaultGreeting\");\n\n        Method[] classMethods = ReflectUtil.getMethodsDirectly(ChildPojo.class, true, false);\n        assertThat(Arrays.stream(classMethods).map(Method::getName))\n                .contains(\"publicGreeting\", \"defaultGreeting\", \"baseGreeting\")\n                .doesNotContain(\"wait\");\n    }\n\n    @Test\n    void readsAndWritesFieldsThroughReflectUtil() {\n        ChildPojo pojo = new ChildPojo();\n\n        ReflectUtil.setFieldValue(pojo, \"childName\", \"updated\");\n        ReflectUtil.setFieldValue(pojo, \"count\", \"7\");\n\n        assertThat(ReflectUtil.getFieldValue(pojo, \"childName\")).isEqualTo(\"updated\");\n        assertThat(ReflectUtil.getFieldValue(pojo, \"count\")).isEqualTo(7);\n        assertThat(ReflectUtil.getFieldMap(ChildPojo.class)).containsKeys(\"childName\", \"baseName\", \"count\");\n    }\n\n    @Test\n    void findsPublicMethodsAndInvokesMethods() {\n        Method[] publicMethods = ReflectUtil.getPublicMethods(ChildPojo.class);\n        assertThat(Arrays.stream(publicMethods).map(Method::getName)).contains(\"publicGreeting\");\n\n        Set<String> publicMethodNames = ReflectUtil.getPublicMethodNames(ChildPojo.class);\n        assertThat(publicMethodNames).contains(\"publicGreeting\", \"fromInterface\");\n\n        Method publicGreeting = ReflectUtil.getPublicMethod(ChildPojo.class, \"publicGreeting\", String.class);\n        assertThat(publicGreeting).isNotNull();\n\n        ChildPojo pojo = new ChildPojo();\n        String greeting = ReflectUtil.invoke(pojo, publicGreeting, \"Grace\");\n        assertThat(greeting).isEqualTo(\"hello Grace from child\");\n\n        String privateMessage = ReflectUtil.invoke(pojo, \"privateMessage\", \"secret\");\n        assertThat(privateMessage).isEqualTo(\"private secret\");\n    }\n\n    @Test\n    void createsFallbackInstancesForArraysInterfacesAndConstructorOnlyTypes() {\n        int[] numbers = ReflectUtil.newInstanceIfPossible(int[].class);\n        assertThat(numbers).isEmpty();\n\n        Map<?, ?> map = ReflectUtil.newInstanceIfPossible(Map.class);\n        assertThat(map).isEmpty();\n\n        ConstructorOnlyPojo constructorOnlyPojo = ReflectUtil.newInstanceIfPossible(ConstructorOnlyPojo.class);\n        assertThat(constructorOnlyPojo).isNotNull();\n        assertThat(constructorOnlyPojo.describe()).isEqualTo(\"created:null:null\");\n    }\n\n    public interface GreetingContract {\n        String fromInterface();\n\n        default String defaultGreeting() {\n            return \"default greeting\";\n        }\n    }\n\n    public static class BasePojo {\n        private String baseName = \"base\";\n\n        public String baseGreeting() {\n            return \"base \" + baseName;\n        }\n    }\n\n    public static class ChildPojo extends BasePojo implements GreetingContract {\n        private String childName = \"child\";\n        private int count = 1;\n\n        @Override\n        public String fromInterface() {\n            return \"interface \" + childName;\n        }\n\n        public String publicGreeting(String name) {\n            return \"hello \" + name + \" from \" + childName;\n        }\n\n        private String privateMessage(String value) {\n            return \"private \" + value;\n        }\n    }\n\n    public static class DefaultPojo {\n        private final String name;\n\n        public DefaultPojo() {\n            this.name = \"default\";\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    public static class ConstructorPojo {\n        private final String name;\n        private final Integer value;\n\n        public ConstructorPojo(String name, Integer value) {\n            this.name = name;\n            this.value = value;\n        }\n\n        public String describe() {\n            return name + \":\" + value;\n        }\n    }\n\n    public static class ConstructorOnlyPojo {\n        private final String name;\n        private final Integer value;\n\n        public ConstructorOnlyPojo(String name, Integer value) {\n            this.name = name;\n            this.value = value;\n        }\n\n        public String describe() {\n            return \"created:\" + name + \":\" + value;\n        }\n    }\n}\n"}
