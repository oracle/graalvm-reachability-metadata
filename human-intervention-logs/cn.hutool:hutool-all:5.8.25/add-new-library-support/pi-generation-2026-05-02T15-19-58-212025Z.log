  	 * @return 方法
  	 * @throws SecurityException 无权访问抛出异常
  	 * @since 3.2.0
  	 */
  	public static Method getMethodIgnoreCase(Class<?> clazz, String methodName, Class<?>... paramTypes) throws SecurityException {
  		return getMethod(clazz, true, methodName, paramTypes);
  	}
  
