[tool-call] delta {"path":"tests/src/cn.hutool/hutool-all/5.8.25/src/test/java/cn_hutool/hutool_all/DbConfigTest.java","edits":[{"oldText":"import cn.hutool.db.DbRuntimeException;\nimport cn.hutool.db.ds.pooled.DbConfig;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DbConfigTest {\n    private static final String H2_JDBC_URL = \"jdbc:h2:mem:db_config_test\";\n\n    @Test\n    public void initLoadsIdentifiedDriverClass() {\n        DbRuntimeException exception = null;\n        try {\n            new DbConfig(H2_JDBC_URL, \"sa\", \"\");\n        } catch (DbRuntimeException expected) {\n            exception = expected;\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return;\n        }\n\n        assertThat(exception)\n                .isNotNull()\n                .hasMessageContaining(\"Get jdbc driver\")\n                .hasMessageContaining(H2_JDBC_URL)\n                .hasCauseInstanceOf(ClassNotFoundException.class);\n    }\n}\n","newText":"import cn.hutool.db.ds.pooled.DbConfig;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DbConfigTest {\n    private static final String H2_DRIVER = \"org.h2.Driver\";\n    private static final String H2_JDBC_URL = \"jdbc:h2:mem:db_config_test\";\n\n    @Test\n    public void initLoadsIdentifiedDriverClass() {\n        DbConfig config = new DbConfig(H2_JDBC_URL, \"sa\", \"\");\n\n        assertThat(config.getDriver()).isEqualTo(H2_DRIVER);\n        assertThat(config.getUrl()).isEqualTo(H2_JDBC_URL);\n        assertThat(config.getUser()).isEqualTo(\"sa\");\n        assertThat(config.getPass()).isEmpty();\n    }\n}\n"}]}
