[tool-call] delta {"path":"tests/src/cn.hutool/hutool-all/5.8.25/src/test/java/cn_hutool/hutool_all/DbConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cn_hutool.hutool_all;\n\nimport cn.hutool.db.DbRuntimeException;\nimport cn.hutool.db.ds.pooled.DbConfig;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DbConfigTest {\n    private static final String H2_JDBC_URL = \"jdbc:h2:mem:db_config_test\";\n\n    @Test\n    public void initLoadsIdentifiedDriverClass() {\n        DbRuntimeException exception = null;\n        try {\n            new DbConfig(H2_JDBC_URL, \"sa\", \"\");\n        } catch (DbRuntimeException expected) {\n            exception = expected;\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return;\n        }\n\n        assertThat(exception)\n                .isNotNull()\n                .hasMessageContaining(\"Get jdbc driver\")\n                .hasMessageContaining(H2_JDBC_URL)\n                .hasCauseInstanceOf(ClassNotFoundException.class);\n    }\n}\n"}
