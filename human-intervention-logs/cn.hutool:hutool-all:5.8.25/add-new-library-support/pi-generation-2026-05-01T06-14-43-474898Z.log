  package cn_hutool.hutool_all;
  
  import cn.hutool.db.DbRuntimeException;
  import cn.hutool.db.ds.pooled.DbConfig;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DbConfigTest {
      private static final String H2_JDBC_URL = "jdbc:h2:mem:db_config_test";
  
      @Test
      public void initLoadsIdentifiedDriverClass() {
          DbRuntimeException exception = null;
          try {
              new DbConfig(H2_JDBC_URL, "sa", "");
          } catch (DbRuntimeException expected) {
              exception = expected;
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
              return;
          }
  
          assertThat(exception)
                  .isNotNull()
                  .hasMessageContaining("Get jdbc driver")
                  .hasMessageContaining(H2_JDBC_URL)
                  .hasCauseInstanceOf(ClassNotFoundException.class);
      }
  }
