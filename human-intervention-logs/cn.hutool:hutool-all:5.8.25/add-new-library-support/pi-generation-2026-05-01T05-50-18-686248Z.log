tion.Alias;\nimport cn.hutool.core.annotation.AnnotationProxy;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationProxyTest {\n    @Test\n    public void proxiesAnnotationAttributesAndObjectMethods() {\n        AliasedMarker sourceAnnotation = AnnotatedSubject.class.getAnnotation(AliasedMarker.class);\n        AnnotationProxy<AliasedMarker> annotationProxy = new AnnotationProxy<>(sourceAnnotation);\n\n        AliasedMarker proxy = ProxyUtil.newProxyInstance(annotationProxy, AliasedMarker.class);\n\n        assertThat(proxy.value()).isEqualTo(\"primary\");\n        assertThat(proxy.name()).isEqualTo(\"primary\");\n        assertThat(proxy.priority()).isEqualTo(7);\n        assertThat(proxy.annotationType()).isEqualTo(AliasedMarker.class);\n        assertThat(proxy.toString()).contains(AnnotationProxy.class.getName());\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface AliasedMarker {\n        String value();\n\n        @Alias(\"value\")\n        String name() default \"\";\n\n        int priority() default 1;\n    }\n\n    @AliasedMarker(value = \"primary\", priority = 7)\n    public static class AnnotatedSubject {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 212, "output": 481, "cacheRead": 34816, "cacheWrite": 0, "totalTokens": 35509, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777614491493, "responseId": "resp_084903848afd292f0169f43e9bf27081a299f24f417e2fb907"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2pDygyo3yFBdgLNlHjrZnTKs|fc_084903848afd292f0169f43e9f51fc81a293d0a6cd1546ac31", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1571 bytes to tests/src/cn.hutool/hutool-all/5.8.25/src/test/java/cn_hutool/hut