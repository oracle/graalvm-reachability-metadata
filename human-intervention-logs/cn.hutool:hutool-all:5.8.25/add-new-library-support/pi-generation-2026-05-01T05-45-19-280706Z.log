ghts waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cn_hutool.hutool_all;\n\nimport cn.hutool.aop.aspects.Aspect;\nimport cn.hutool.aop.proxy.JdkProxyFactory;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JdkInterceptorTest {\n    @Test\n    public void invokesTargetMethodThroughJdkProxy() {\n        GreetingService target = new DefaultGreetingService(\"Hello\");\n        RecordingAspect aspect = new RecordingAspect();\n\n        GreetingService proxy = new JdkProxyFactory().proxy(target, aspect);\n        String greeting = proxy.greet(\"Hutool\");\n\n        assertThat(greeting).isEqualTo(\"Hello, Hutool\");\n        assertThat(aspect.getEvents()).containsExactly(\"before:greet\", \"after:greet=Hello, Hutool\");\n        assertThat(aspect.getTargets()).containsOnly(target);\n        assertThat(aspect.getArguments()).containsExactly(\"Hutool\");\n    }\n\n    public interface GreetingService {\n        String greet(String name);\n    }\n\n    public static class DefaultGreetingService implements GreetingService {\n        private final String salutation;\n\n        public DefaultGreetingService(String salutation) {\n            this.salutation = salutation;\n        }\n\n        @Override\n        public String greet(String name) {\n            return salutation + \", \" + name;\n        }\n    }\n\n    public static class RecordingAspect implements Aspect {\n        private final List<String> events = new ArrayList<>();\n        private final List<Object> targets = new ArrayList<>();\n        private final List<Object> arguments = new ArrayList<>();\n\n        @Override\n        public boolean before(Object target, Method method, Object[] args) {\n            targets.add(target);\n            arguments.add(args[0]);\n            events.add(\"before:\" + method.getName());\n            return true;\n        }\n\n        @Override\n        public boolean after(Object target, Method method, Object[] args, Object returnVal) {\n            targets.add(target);\n            events.add(\"after:\" + method.getName() + \"=\" + returnVal);\n            return true;\n        }\n\n        @Override\n        public boolean afterException(Object target, Method method, Object[] args, Throwable e) {\n            events.add(\"exception:\" + method.getName());\n            return true;\n        }\n\n        public List<String> getEvents() {\n            return events;\n        }\n\n        public List<Object> getTargets() {\n            return targets;\n        }\n\n        public List<Object> getArguments() {\n            return arguments;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 694, "output": 1855, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 24053, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777614260558, "responseId": "resp_0c50251d46d106500169f43db4ead8819f8ea4fdc22410483c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YPlY7TQIywvj9fRzNXynWsYH|fc_0c50251d46d106500169f43dc731b4819fa202b1ac5a6a3c9d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2802 bytes to tests/src/cn.hutool/hutool-all/5.8.25/src/test/java/cn_hutool/hutool_all/JdkInterceptorTest.java"}], "isError": false, "timestamp": 1777614281917}]}
