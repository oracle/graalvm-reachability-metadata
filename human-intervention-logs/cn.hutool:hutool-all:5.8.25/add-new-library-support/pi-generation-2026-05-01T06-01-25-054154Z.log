[tool-call] delta {"path":"tests/src/cn.hutool/hutool-all/5.8.25/src/test/java/cn_hutool/hutool_all/ClassScannerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cn_hutool.hutool_all;\n\nimport cn.hutool.core.lang.ClassScanner;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassScannerTest {\n    @Test\n    public void loadsClassNamesThroughScannerLoader() {\n        ExposedClassScanner scanner = new ExposedClassScanner();\n\n        Class<?> loadedClass = scanner.loadClassByName(ClassScanner.class.getName());\n\n        assertThat(loadedClass).isSameAs(ClassScanner.class);\n        assertThat(scanner.getClassesOfLoadError()).isEmpty();\n    }\n\n    private static final class ExposedClassScanner extends ClassScanner {\n        Class<?> loadClassByName(String className) {\n            return loadClass(className);\n        }\n    }\n}\n"}
