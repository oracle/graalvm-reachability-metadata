  	 */
  	public static Method getPublicMethod(Class<?> clazz, String methodName, Class<?>... paramTypes) throws SecurityException {
  		try {
  			return clazz.getMethod(methodName, paramTypes);
  		} catch (NoSuchMethodException ex) {
  			return null;
  		}
  	}
  
  	/**
