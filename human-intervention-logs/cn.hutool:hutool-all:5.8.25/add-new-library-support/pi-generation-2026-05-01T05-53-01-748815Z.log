\n\n\t/**\n\t * 替换属性值\n\t *\n\t * @param attributeName 属性名\n\t * @param operator      替换操作\n\t */\n\tvoid replaceAttribute(String attributeName, UnaryOperator<AnnotationAttribute> operator);\n\n\t/**\n\t * 获取属性值\n\t *\n\t * @param attributeName 属性名\n\t * @return 属性值\n\t */\n\tObject getAttributeValue(String attributeName);\n\n}\n"}], "isError": false, "timestamp": 1777614679326}}
