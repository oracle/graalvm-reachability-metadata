  package com_formdev.flatlaf;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.invoke.MethodHandles;
  import java.lang.reflect.Field;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import javax.swing.LookAndFeel;
  import javax.swing.UIDefaults;
  import javax.swing.UIManager;
  import javax.swing.UIManager.LookAndFeelInfo;
  import com.formdev.flatlaf.FlatLaf;
  import com.formdev.flatlaf.FlatLightLaf;
  import com.formdev.flatlaf.util.SystemInfo;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import sun.misc.Unsafe;
  
  public class FlatLafTest {
      private static final String BUNDLE_NAME = "com.formdev.flatlaf.resources.Bundle";
      private static final String MORE_TABS_KEY = "TabbedPane.moreTabsButtonToolTipText";
      private static final String BUTTON_UI_CLASS_NAME = "com.formdev.flatlaf.ui.FlatButtonUI";
      private static final String METAL_LOOK_AND_FEEL_CLASS_NAME = "javax.swing.plaf.metal.MetalLookAndFeel";
      private static final Unsafe UNSAFE = findUnsafe();
  
      @Test
      void loadsResourceBundleWhenSwingDefaultsCannotResolveIt() throws Exception {
          ResourceBundleMissDefaults defaults = new ResourceBundleMissDefaults();
          Method method = FlatLaf.class.getDeclaredMethod(
                  "initResourceBundle", UIDefaults.class, String.class);
          method.setAccessible(true);
  
          method.invoke(new FlatLightLaf(), defaults, BUNDLE_NAME);
          defaults.useStoredValues();
  
          assertThat(defaults.get(MORE_TABS_KEY)).isEqualTo("Show Hidden Tabs");
      }
  
      @Test
      void initializesAquaThroughUiManagerFactory() throws Exception {
          StaticFieldValue macOs = setStaticField(SystemInfo.class, "isMacOS", true);
          StaticFieldValue java9OrLater = setStaticField(SystemInfo.class, "isJava_9_orLater", true);
          StaticFieldValue aquaLoaded = setStaticField(FlatLaf.class, "aquaLoaded", false);
          LookAndFeel previousLookAndFeel = UIManager.getLookAndFeel();
          StaticFieldValue installedLookAndFeels = setStaticField(
                  UIManager.class, "installedLAFs", new LookAndFeelInfo[] {
                          new LookAndFeelInfo("Mac OS X", METAL_LOOK_AND_FEEL_CLASS_NAME)
                  });
          try {
              try {
                  UIManager.setLookAndFeel(new FlatLightLaf());
  
                  assertThat(UIManager.getLookAndFeel()).isInstanceOf(FlatLightLaf.class);
              } catch (IllegalStateException expectedWhenAquaIsUnavailable) {
                  assertThat(expectedWhenAquaIsUnavailable).isNotNull();
              }
          } finally {
              restoreLookAndFeel(previousLookAndFeel);
              installedLookAndFeels.restore();
              aquaLoaded.restore();
              java9OrLater.restore();
              macOs.restore();
          }
      }
  
      @Test
      void lazyUiDelegateLoadsClassFromFlatLafClassLoader() throws Exception {
          try {
              URL flatLafLocation = FlatLaf.class.getProtectionDomain().getCodeSource().getLocation();
              try (URLClassLoader classLoader = new URLClassLoader(
                      new URL[] {flatLafLocation}, ClassLoader.getPlatformClassLoader())) {
                  Class<?> lookAndFeelClass = Class.forName(
                          "com.formdev.flatlaf.FlatLightLaf", true, classLoader);
                  LookAndFeel lookAndFeel = (LookAndFeel) lookAndFeelClass.getDeclaredConstructor().newInstance();
                  LookAndFeel previousLookAndFeel = UIManager.getLookAndFeel();
                  try {
                      UIManager.setLookAndFeel(lookAndFeel);
                      UIDefaults defaults = UIManager.getLookAndFeelDefaults();
  
                      Object uiClass = defaults.get(BUTTON_UI_CLASS_NAME);
  
                      assertThat(uiClass).isInstanceOf(Class.class);
                      assertThat(((Class<?>) uiClass).getName()).isEqualTo(BUTTON_UI_CLASS_NAME);
                      assertThat(((Class<?>) uiClass).getClassLoader()).isSameAs(classLoader);
                  } finally {
                      restoreLookAndFeel(previousLookAndFeel);
                  }
              }
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause();
              if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return;
              }
              throw exception;
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void restoreLookAndFeel(LookAndFeel lookAndFeel) throws Exception {
          if (lookAndFeel != null && UIManager.getLookAndFeel() != lookAndFeel) {
              UIManager.setLookAndFeel(lookAndFeel);
          }
      }
  
      private static Unsafe findUnsafe() {
          try {
              Field field = Unsafe.class.getDeclaredField("theUnsafe");
              field.setAccessible(true);
              return (Unsafe) field.get(null);
          } catch (ReflectiveOperationException ex) {
              throw new IllegalStateException("Unable to access Unsafe", ex);
          }
      }
  
      private static StaticFieldValue setStaticField(Class<?> type, String name, Object value) throws Exception {
          MethodHandles.lookup().ensureInitialized(type);
          Field field = type.getDeclaredField(name);
          Object base = UNSAFE.staticFieldBase(field);
          long offset = UNSAFE.staticFieldOffset(field);
          Object oldValue = field.getType() == boolean.class
                  ? UNSAFE.getBoolean(base, offset)
                  : UNSAFE.getObject(base, offset);
          putStaticField(field, base, offset, value);
          return new StaticFieldValue(field, base, offset, oldValue);
      }
  
      private static void putStaticField(Field field, Object base, long offset, Object value) {
          if (field.getType() == boolean.class) {
              UNSAFE.putBoolean(base, offset, (Boolean) value);
          } else {
              UNSAFE.putObject(base, offset, value);
          }
      }
  
      private static final class StaticFieldValue {
          private final Field field;
          private final Object base;
          private final long offset;
          private final Object value;
  
          StaticFieldValue(Field field, Object base, long offset, Object value) {
              this.field = field;
              this.base = base;
              this.offset = offset;
              this.value = value;
          }
  
          void restore() {
              putStaticField(field, base, offset, value);
          }
      }
  
      private static final class ResourceBundleMissDefaults extends UIDefaults {
          private boolean resourceBundleLookupFails = true;
  
          ResourceBundleMissDefaults() {
              super(10, 0.75f);
          }
  
          @Override
          public Object get(Object key) {
              if (resourceBundleLookupFails && MORE_TABS_KEY.equals(key)) {
                  return null;
              }
              return super.get(key);
          }
  
          void useStoredValues() {
              resourceBundleLookupFails = false;
          }
      }
  }
