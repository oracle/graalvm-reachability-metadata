[tool-call] delta {"path":"tests/src/com.formdev/flatlaf/3.7.1/src/test/java/com_formdev/flatlaf/FlatPopupFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_formdev.flatlaf;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.invoke.MethodHandles;\nimport java.lang.reflect.Field;\nimport javax.swing.JPanel;\nimport javax.swing.Popup;\nimport javax.swing.UIManager;\nimport com.formdev.flatlaf.FlatClientProperties;\nimport com.formdev.flatlaf.ui.FlatPopupFactory;\nimport com.formdev.flatlaf.util.SystemInfo;\nimport org.junit.jupiter.api.Test;\nimport sun.misc.Unsafe;\n\npublic class FlatPopupFactoryTest {\n    private static final Unsafe UNSAFE = findUnsafe();\n\n    @Test\n    void publicGetPopupUsesJava8HeavyWeightFallbackWhenRequested() throws Exception {\n        StaticFieldValue java9OrLater = setStaticField(SystemInfo.class, \"isJava_9_orLater\", false);\n        Object previousDropShadowPainted = UIManager.get(\"Popup.dropShadowPainted\");\n        JPanel owner = new JPanel();\n        JPanel contents = new JPanel();\n        contents.putClientProperty(FlatClientProperties.POPUP_FORCE_HEAVY_WEIGHT, Boolean.TRUE);\n\n        try {\n            UIManager.put(\"Popup.dropShadowPainted\", Boolean.FALSE);\n\n            Popup popup = new FlatPopupFactory().getPopup(owner, contents, 25, 25);\n            try {\n                assertThat(popup).isNotNull();\n            } finally {\n                popup.hide();\n            }\n        } finally {\n            UIManager.put(\"Popup.dropShadowPainted\", previousDropShadowPainted);\n            java9OrLater.restore();\n        }\n    }\n\n    private static Unsafe findUnsafe() {\n        try {\n            Field field = Unsafe.class.getDeclaredField(\"theUnsafe\");\n            field.setAccessible(true);\n            return (Unsafe) field.get(null);\n        } catch (ReflectiveOperationException ex) {\n            throw new IllegalStateException(\"Unable to access Unsafe\", ex);\n        }\n    }\n\n    private static StaticFieldValue setStaticField(Class<?> type, String name, boolean value) throws Exception {\n        MethodHandles.lookup().ensureInitialized(type);\n        Field field = type.getDeclaredField(name);\n        Object base = UNSAFE.staticFieldBase(field);\n        long offset = UNSAFE.staticFieldOffset(field);\n        boolean oldValue = UNSAFE.getBoolean(base, offset);\n        UNSAFE.putBoolean(base, offset, value);\n        return new StaticFieldValue(base, offset, oldValue);\n    }\n\n    private static final class StaticFieldValue {\n        private final Object base;\n        private final long offset;\n        private final boolean value;\n\n        StaticFieldValue(Object base, long offset, boolean value) {\n            this.base = base;\n            this.offset = offset;\n            this.value = value;\n        }\n\n        void restore() {\n            UNSAFE.putBoolean(base, offset, value);\n        }\n    }\n}\n"}
