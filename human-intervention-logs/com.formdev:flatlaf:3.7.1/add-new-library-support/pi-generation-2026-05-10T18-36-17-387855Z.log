pedDimension\"))\n                    .isEqualTo(new Dimension(31, 37));\n        } finally {\n            FlatLaf.unregisterCustomDefaultsSource(FALLBACK_PACKAGE, classLoader);\n            FlatLaf.unregisterCustomDefaultsSource(DEFAULTS_PACKAGE, classLoader);\n        }\n    }\n\n    @Test\n    void invokesStaticFactoryMethodBranch() throws Exception {\n        Method factoryMethod = DimensionFactory.class.getDeclaredMethod(\n                \"dimension\", int.class, int.class);\n        Class<?> loaderClass = Class.forName(\"com.formdev.flatlaf.UIDefaultsLoader\");\n        Method loaderMethod = loaderClass.getDeclaredMethod(\n                \"invokeConstructorOrStaticMethod\", Executable[].class, List.class, Function.class);\n        loaderMethod.setAccessible(true);\n\n        Object value = loaderMethod.invoke(null, new Object[] {\n                new Executable[] {factoryMethod},\n                Arrays.asList(\"dimension\", \"41\", \"43\"),\n                (Function<String, String>) input -> input\n        });\n\n        assertThat(value).isEqualTo(new Dimension(41, 43));\n    }\n\n    public static class DimensionFactory {\n        public static Dimension dimension(int width, int height) {\n            return new Dimension(width, height);\n        }\n    }\n\n    private static class MappingClassLoader extends ClassLoader {\n        MappingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (MAPPED_DIMENSION_CLASS.equals(name)) {\n                return Dimension.class;\n            }\n            return super.loadClass(name);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (name.startsWith(FALLBACK_PACKAGE.replace('.', '/')) && name.endsWith(\".properties\")) {\n                return null;\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            return getParent().getResource(name);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778438058119}}
