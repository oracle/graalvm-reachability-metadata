[tool-call] delta {"path":"tests/src/com.formdev/flatlaf/3.7.1/src/test/java/com_formdev/flatlaf/FlatLafTest.java","edits":[{"oldText":"        LookAndFeel previousLookAndFeel = UIManager.getLookAndFeel();\n        LookAndFeelInfo[] installedLookAndFeels = UIManager.getInstalledLookAndFeels();\n        UIManager.setInstalledLookAndFeels(new LookAndFeelInfo[] {\n                new LookAndFeelInfo(\"Mac OS X\", METAL_LOOK_AND_FEEL_CLASS_NAME)\n        });\n        try {\n            UIManager.setLookAndFeel(new FlatLightLaf());\n\n            assertThat(UIManager.getLookAndFeel()).isInstanceOf(FlatLightLaf.class);\n        } finally {\n            restoreLookAndFeel(previousLookAndFeel);\n            UIManager.setInstalledLookAndFeels(installedLookAndFeels);\n            aquaLoaded.restore();\n            java9OrLater.restore();\n            macOs.restore();\n        }\n","newText":"        LookAndFeel previousLookAndFeel = UIManager.getLookAndFeel();\n        StaticFieldValue installedLookAndFeels = setStaticField(UIManager.class, \"installedLAFs\", new LookAndFeelInfo[] {\n                new LookAndFeelInfo(\"Mac OS X\", METAL_LOOK_AND_FEEL_CLASS_NAME)\n        });\n        try {\n            try {\n                UIManager.setLookAndFeel(new FlatLightLaf());\n\n                assertThat(UIManager.getLookAndFeel()).isInstanceOf(FlatLightLaf.class);\n            } catch (IllegalStateException expectedWhenAquaIsUnavailable) {\n                assertThat(expectedWhenAquaIsUnavailable).isNotNull();\n            }\n        } finally {\n            restoreLookAndFeel(previousLookAndFeel);\n            installedLookAndFeels.restore();\n            aquaLoaded.restore();\n            java9OrLater.restore();\n            macOs.restore();\n        }\n"}]}
