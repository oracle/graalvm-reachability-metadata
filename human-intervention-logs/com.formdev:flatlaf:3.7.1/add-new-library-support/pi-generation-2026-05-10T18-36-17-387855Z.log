  package com_formdev.flatlaf;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.File;
  import java.io.IOException;
  import java.lang.invoke.MethodHandles;
  import java.lang.reflect.Field;
  import javax.swing.JComponent;
  import javax.swing.filechooser.FileSystemView;
  import javax.swing.plaf.ComponentUI;
  import com.formdev.flatlaf.ui.JavaCompatibility2;
  import com.formdev.flatlaf.util.SystemInfo;
  import org.junit.jupiter.api.Test;
  import sun.misc.Unsafe;
  
  public class JavaCompatibility2Test {
      private static final Unsafe UNSAFE = findUnsafe();
  
      @Test
      void returnsComponentUiFromJComponent() {
          ComponentWithCustomUi component = new ComponentWithCustomUi();
  
          ComponentUI ui = JavaCompatibility2.getUI(component);
  
          assertThat(ui).isSameAs(component.ui);
      }
  
      @Test
      void returnsComponentUiUsingLegacyReflectionFallback() throws Exception {
          StaticFieldValue java9OrLater = setStaticField(SystemInfo.class, "isJava_9_orLater", false);
          StaticFieldValue getUiInitialized = setStaticField(
                  JavaCompatibility2.class, "getUIMethodInitialized", true);
          StaticFieldValue getUiMethod = setStaticField(JavaCompatibility2.class, "getUIMethod", null);
          try {
              ComponentWithCustomUi component = new ComponentWithCustomUi();
  
              ComponentUI ui = JavaCompatibility2.getUI(component);
  
              assertThat(ui).isSameAs(component.ui);
          } finally {
              getUiMethod.restore();
              getUiInitialized.restore();
              java9OrLater.restore();
          }
      }
  
      @Test
      void returnsChooserComboBoxFilesFromFileSystemView() {
          File[] expectedFiles = {new File(System.getProperty("user.home"))};
          TestFileSystemView fileSystemView = new TestFileSystemView(expectedFiles);
  
          File[] files = JavaCompatibility2.getChooserComboBoxFiles(fileSystemView);
  
          assertThat(files).containsExactly(expectedFiles);
      }
  
      @Test
      void returnsChooserShortcutPanelFilesFromFileSystemView() {
          File[] files = JavaCompatibility2.getChooserShortcutPanelFiles(new TestFileSystemView(new File[0]));
  
          assertThat(files).isNotNull();
      }
  
      @Test
      void invokesLegacyShellFolderFallbacks() throws Exception {
          StaticFieldValue java12OrLater = setStaticField(SystemInfo.class, "isJava_12_orLater", false);
          StaticFieldValue java9OrLater = setStaticField(SystemInfo.class, "isJava_9_orLater", false);
          StaticFieldValue windows = setStaticField(SystemInfo.class, "isWindows", true);
          try {
              File[] shortcutPanelFiles = JavaCompatibility2.getChooserShortcutPanelFiles(
                      new TestFileSystemView(new File[0]));
              File[] comboBoxFiles = JavaCompatibility2.getChooserComboBoxFiles(
                      new TestFileSystemView(new File[0]));
  
              assertThat(shortcutPanelFiles).isNotNull();
              assertThat(comboBoxFiles).isNotNull();
          } finally {
              windows.restore();
              java9OrLater.restore();
              java12OrLater.restore();
          }
      }
  
      public static class TestFileSystemView extends FileSystemView {
          private final File[] comboBoxFiles;
  
          TestFileSystemView(File[] comboBoxFiles) {
              this.comboBoxFiles = comboBoxFiles.clone();
          }
  
          @Override
          public File createNewFolder(File containingDir) throws IOException {
              return new File(containingDir, "new-folder");
          }
  
          @Override
          public File getHomeDirectory() {
              return new File(System.getProperty("user.home"));
          }
  
          @Override
          public File[] getRoots() {
              return new File[] {getHomeDirectory()};
          }
  
          @Override
          public File getDefaultDirectory() {
              return getHomeDirectory();
          }
  
          @Override
          public File[] getChooserComboBoxFiles() {
              return comboBoxFiles.clone();
          }
      }
  
      public static class ComponentWithCustomUi extends JComponent {
          private final ComponentUI ui = new TestComponentUI();
  
          @Override
          public ComponentUI getUI() {
              return ui;
          }
      }
  
      private static Unsafe findUnsafe() {
          try {
              Field field = Unsafe.class.getDeclaredField("theUnsafe");
              field.setAccessible(true);
              return (Unsafe) field.get(null);
          } catch (ReflectiveOperationException ex) {
              throw new IllegalStateException("Unable to access Unsafe", ex);
          }
      }
  
      private static StaticFieldValue setStaticField(Class<?> type, String name, Object value) throws Exception {
          MethodHandles.lookup().ensureInitialized(type);
          Field field = type.getDeclaredField(name);
          Object base = UNSAFE.staticFieldBase(field);
          long offset = UNSAFE.staticFieldOffset(field);
          Object oldValue = field.getType() == boolean.class
                  ? UNSAFE.getBoolean(base, offset)
                  : UNSAFE.getObject(base, offset);
          putStaticField(field, base, offset, value);
          return new StaticFieldValue(field, base, offset, oldValue);
      }
  
      private static void putStaticField(Field field, Object base, long offset, Object value) {
          if (field.getType() == boolean.class) {
              UNSAFE.putBoolean(base, offset, (Boolean) value);
          } else {
              UNSAFE.putObject(base, offset, value);
          }
      }
  
      private static class StaticFieldValue {
          private final Field field;
          private final Object base;
          private final long offset;
          private final Object value;
  
          StaticFieldValue(Field field, Object base, long offset, Object value) {
              this.field = field;
              this.base = base;
              this.offset = offset;
              this.value = value;
          }
  
          void restore() {
              putStaticField(field, base, offset, value);
          }
      }
  
      private static class TestComponentUI extends ComponentUI {
      }
  }
