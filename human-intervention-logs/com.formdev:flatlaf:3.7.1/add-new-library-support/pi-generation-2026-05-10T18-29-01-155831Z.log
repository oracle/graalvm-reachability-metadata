              return null;
          }
  
          Image img = sf.getIcon(false);
  
          if (img != null) {
              return new ImageIcon(img, sf.getFolderType());
          } else {
              return UIManager.getIcon(f.isDirectory() ? "FileView.directoryIcon" : "FileView.fileIcon");
          }
      }
  
