  package com_formdev.flatlaf;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.awt.Color;
  import java.awt.Component;
  import java.awt.Graphics;
  import java.lang.invoke.MethodHandles;
  import java.util.Map;
  import javax.swing.Icon;
  import javax.swing.JButton;
  import javax.swing.UIManager;
  import javax.swing.border.AbstractBorder;
  import com.formdev.flatlaf.ui.FlatButtonUI;
  import com.formdev.flatlaf.ui.FlatStylingSupport;
  import com.formdev.flatlaf.ui.FlatStylingSupport.Styleable;
  import com.formdev.flatlaf.ui.FlatStylingSupport.StyleableField;
  import com.formdev.flatlaf.ui.FlatStylingSupport.StyleableLookupProvider;
  import com.formdev.flatlaf.ui.FlatStylingSupport.StyleableObject;
  import org.junit.jupiter.api.Test;
  
  public class FlatStylingSupportTest {
      @Test
      void appliesAndReadsAnnotatedFields() {
          AnnotatedStyleable styleable = new AnnotatedStyleable();
  
          Object oldColor = styleable.applyStyleProperty("foreground", Color.RED);
          Object oldArrowType = styleable.applyStyleProperty("icon.arrowType", 7);
          Map<String, Class<?>> infos = styleable.getStyleableInfos();
  
          assertThat(oldColor).isEqualTo(Color.BLACK);
          assertThat(oldArrowType).isEqualTo(3);
          assertThat(styleable.foreground).isEqualTo(Color.RED);
          assertThat(styleable.iconArrowType).isEqualTo(7);
          assertThat(infos)
                  .containsEntry("foreground", Color.class)
                  .containsEntry("icon.arrowType", int.class)
                  .containsEntry("typedNumber", Number.class);
          assertThat(styleable.getStyleableValue("foreground")).isEqualTo(Color.RED);
          assertThat(styleable.getStyleableValue("icon.arrowType")).isEqualTo(7);
      }
  
      @Test
      void appliesAndReadsStyleableFieldWithLookupProvider() {
          LookupStyleable styleable = new LookupStyleable();
  
          Object oldValue = styleable.applyStyleProperty("externalLabel", "updated");
          Map<String, Class<?>> infos = styleable.getStyleableInfos();
  
          assertThat(oldValue).isEqualTo("initial");
          assertThat(styleable.externalLabel).isEqualTo("updated");
          assertThat(infos).containsEntry("externalLabel", String.class);
          assertThat(styleable.getStyleableValue("externalLabel")).isEqualTo("updated");
      }
  
      @Test
      void appliesPropertiesUsingJavaBeanGetterAndSetterMethods() {
          PropertyBean bean = new PropertyBean();
  
          Object oldTitle = FlatStylingSupport.applyToAnnotatedObjectOrComponent(
                  new Object(), bean, "title", "updated");
          Object oldActive = FlatStylingSupport.applyToAnnotatedObjectOrComponent(
                  new Object(), bean, "active", false);
  
          assertThat(oldTitle).isEqualTo("initial");
          assertThat(bean.getTitle()).isEqualTo("updated");
          assertThat(oldActive).isEqualTo(true);
          assertThat(bean.isActive()).isFalse();
      }
  
      @Test
      void clonesSharedStyleableBorderBeforeApplyingBorderStyle() {
          JButton button = new JButton("styled");
          CloneableStyleableBorder originalBorder = new CloneableStyleableBorder();
          button.setBorder(originalBorder);
          ExposedButtonUI ui = new ExposedButtonUI();
  
          Object oldValue = ui.applyStyle(button, "lineColor", Color.ORANGE);
  
          assertThat(oldValue).isEqualTo(Color.BLACK);
          assertThat(button.getBorder()).isInstanceOf(CloneableStyleableBorder.class);
          assertThat(button.getBorder()).isNotSameAs(originalBorder);
          CloneableStyleableBorder clonedBorder = (CloneableStyleableBorder) button.getBorder();
          assertThat(clonedBorder.lineColor).isEqualTo(Color.ORANGE);
          assertThat(originalBorder.lineColor).isEqualTo(Color.BLACK);
      }
  
      @Test
      void clonesSharedStyleableHelpIconBeforeApplyingIconStyle() {
          Object oldHelpIcon = UIManager.get("HelpButton.icon");
          try {
              UIManager.put("HelpButton.icon", new CloneableStyleableIcon());
              JButton button = new JButton("help");
              ExposedButtonUI ui = new ExposedButtonUI();
              button.setUI(ui);
  
              Object oldValue = ui.applyStyle(button, "help.iconColor", Color.MAGENTA);
  
              assertThat(oldValue).isEqualTo(Color.BLACK);
              assertThat(ui.getStyleableValue(button, "help.iconColor")).isEqualTo(Color.MAGENTA);
          } finally {
              if (oldHelpIcon != null) {
                  UIManager.put("HelpButton.icon", oldHelpIcon);
              } else {
                  UIManager.getDefaults().remove("HelpButton.icon");
              }
          }
      }
  
      public static class AnnotatedStyleable implements StyleableObject {
          @Styleable
          public Color foreground = Color.BLACK;
          @Styleable(dot = true)
          public int iconArrowType = 3;
          @Styleable(type = Number.class)
          public int typedNumber = 11;
      }
  
      public static class ExternalFieldHolder {
          public String externalLabel = "initial";
      }
  
      @StyleableField(cls = ExternalFieldHolder.class, key = "externalLabel")
      public static class LookupStyleable
              extends ExternalFieldHolder
              implements StyleableObject, StyleableLookupProvider {
          @Override
          public MethodHandles.Lookup getLookupForStyling() {
              return MethodHandles.lookup();
          }
      }
  
      public static class PropertyBean {
          private String title = "initial";
          private boolean active = true;
  
          public String getTitle() {
              return title;
          }
  
          public void setTitle(String title) {
              this.title = title;
          }
  
          public boolean isActive() {
              return active;
          }
  
          public void setActive(boolean active) {
              this.active = active;
          }
      }
  
      public static class CloneableStyleableBorder extends AbstractBorder implements StyleableObject {
          @Styleable
          public Color lineColor = Color.BLACK;
      }
  
      public static class CloneableStyleableIcon implements Icon, StyleableObject {
          @Styleable
          public Color iconColor = Color.BLACK;
  
          @Override
          public void paintIcon(Component c, Graphics g, int x, int y) {
              // No painting is needed for styling tests.
          }
  
          @Override
          public int getIconWidth() {
              return 16;
          }
  
          @Override
          public int getIconHeight() {
              return 16;
          }
      }
  
      public static class ExposedButtonUI extends FlatButtonUI {
          public ExposedButtonUI() {
              super(false);
          }
  
          public Object applyStyle(JButton button, String key, Object value) {
              return applyStyleProperty(button, key, value);
          }
      }
