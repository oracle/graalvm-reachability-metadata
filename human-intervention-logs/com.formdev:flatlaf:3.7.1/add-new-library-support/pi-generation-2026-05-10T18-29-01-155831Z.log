  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "com.formdev:flatlaf:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.withType(JavaCompile).configureEach {
      options.compilerArgs += ['--add-exports=java.desktop/sun.awt.shell=ALL-UNNAMED']
  }
  
  test {
      jvmArgs '--add-exports=java.desktop/sun.awt.shell=ALL-UNNAMED',
              '--add-opens=java.desktop/sun.awt.shell=ALL-UNNAMED'
  }
  
  graalvmNative {
      binaries.all {
          buildArgs.add('--add-exports=java.desktop/sun.awt.shell=ALL-UNNAMED')
          buildArgs.add('--add-opens=java.desktop/sun.awt.shell=ALL-UNNAMED')
      }
  
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
