isEqualTo(new Dimension(32, 32));\n    }\n\n    @Test\n    void returnsLegacyShellFolderIconWhenLargeSystemIconMethodIsUnavailable() throws Exception {\n        StaticFieldValue java17OrLater = setStaticField(SystemInfo.class, \"isJava_17_orLater\", false);\n        Object oldIconSize = UIManager.get(\"FileChooser.shortcuts.iconSize\");\n        UIManager.put(\"FileChooser.shortcuts.iconSize\", new Dimension(32, 32));\n        try {\n            LargeIconFileSystemView fileSystemView = new LargeIconFileSystemView();\n            ExposedShortcutsPanel panel = createPanel(fileSystemView);\n            ShellFolder shellFolder = createShellFolder(fileSystemView.getHomeDirectory());\n\n            Icon icon = panel.iconFor(fileSystemView, shellFolder);\n\n            assertThat(icon).isInstanceOf(ImageIcon.class);\n            assertThat(((ImageIcon) icon).getImage()).isSameAs(ShellFolderWithIcon.ICON_IMAGE);\n        } finally {\n            restoreUiDefault(\"FileChooser.shortcuts.iconSize\", oldIconSize);\n            java17OrLater.restore();\n        }\n    }\n\n    private static ExposedShortcutsPanel createPanel(FileSystemView fileSystemView) {\n        Object oldFilesFunction = UIManager.get(\"FileChooser.shortcuts.filesFunction\");\n        UIManager.put(\"FileChooser.shortcuts.filesFunction\", (Function<File[], File[]>) files -> new File[0]);\n        try {\n            return new ExposedShortcutsPanel(new JFileChooser(fileSystemView));\n        } finally {\n            restoreUiDefault(\"FileChooser.shortcuts.filesFunction\", oldFilesFunction);\n        }\n    }\n\n    private static ShellFolder createShellFolder(File homeDirectory) throws FileNotFoundException {\n        ShellFolder shellFolder = ShellFolder.getShellFolder(homeDirectory);\n        return new ShellFolderWithIcon(shellFolder);\n    }\n\n    private static void restoreUiDefault(String key, Object oldValue) {\n        if (oldValue != null) {\n            UIManager.put(key, oldValue);\n        } else {\n            UIManager.getDefaults().remove(key);\n        }\n    }\n\n    private static Unsafe findUnsafe() {\n        try {\n            Field field = Unsafe.class.getDeclaredField(\"theUnsafe\");\n            field.setAccessible(true);\n            return (Unsafe) field.get(null);\n        } catch (ReflectiveOperationException ex) {\n            throw new IllegalStateException(\"Unable to access Unsafe\", ex);\n        }\n    }\n\n    private static StaticFieldValue setStaticField(Class<?> type, String name, Object value) throws Exception {\n        MethodHandles.lookup().ensureInitialized(type);\n        Field field = type.getDeclaredField(name);\n        Object base = UNSAFE.staticFieldBase(field);\n        long offset = UNSAFE.staticFieldOffset(field);\n        Object oldValue = field.getType() == boolean.class\n                ? UNSAFE.getBoolean(base, offset)\n                : UNSAFE.getObject(base, offset);\n        putStaticField(field, base, offset, value);\n        return new StaticFieldValue(field, base, offset, oldValue);\n    }\n\n    private static void putStaticField(Field field, Object base, long offset, Object value) {\n        if (field.getType() == boolean.class) {\n            UNSAFE.putBoolean(base, offset, (Boolean) value);\n        } else {\n            UNSAFE.putObject(base, offset, value);\n        }\n    }\n\n    private static class StaticFieldValue {\n        private final Field field;\n        private final Object base;\n        private final long offset;\n        private final Object value;\n\n        StaticFieldValue(Field field, Object base, long offset, Object value) {\n            this.field = field;\n            this.base = base;\n            this.offset = offset;\n            this.value = value;\n        }\n\n        void restore() {\n            putStaticField(field, base, offset, value);\n        }\n    }\n\n    public static class ExposedShortcutsPanel extends FlatShortcutsPanel {\n        public ExposedShortcutsPanel(JFileChooser fileChooser) {\n            super(fileChooser);\n        }\n\n        public Icon iconFor(FileSystemView fileSystemView, File file) {\n            return getIcon(fileSystemView, file);\n        }\n    }\n\n    public static class LargeIconFileSystemView extends FileSystemView {\n        private final File homeDirectory = new File(System.getProperty(\"user.home\"));\n        private final Icon largeSystemIcon = new TestIcon(32, 32);\n        private File largeIconFile;\n        private Dimension largeIconSize;\n\n        @Override\n        public File createNewFolder(File containingDir) throws IOException {\n            return new File(containingDir, \"new-folder\");\n        }\n\n        @Override\n        public File getHomeDirectory() {\n            return homeDirectory;\n        }\n\n        @Override\n        public File getDefaultDirectory() {\n            return homeDirectory;\n        }\n\n        @Override\n        public File[] getRoots() {\n            return new File[] {homeDirectory};\n        }\n\n        @Override\n        public File[] getChooserShortcutPanelFiles() {\n            return new File[0];\n        }\n\n        @Override\n        public Icon getSystemIcon(File file) {\n            return new TestIcon(16, 16);\n        }\n\n        @Override\n        public Icon getSystemIcon(File file, int width, int height) {\n            largeIconFile = file;\n            largeIconSize = new Dimension(width, height);\n            return largeSystemIcon;\n        }\n    }\n\n    public static class ShellFolderWithIcon extends ShellFolder {\n        private static final Image ICON_IMAGE = new BufferedImage(32, 32, BufferedImage.TYPE_INT_ARGB);\n\n        ShellFolderWithIcon(ShellFolder parent) {\n            super(parent, \"shortcut-folder\");\n        }\n\n        @Override\n        protected Object writeReplace() throws ObjectStreamException {\n            return new File(getPath());\n        }\n\n        @Override\n        public boolean isLink() {\n            return false;\n        }\n\n        @Override\n        public ShellFolder getLinkLocation() {\n            return null;\n        }\n\n        @Override\n        public String getDisplayName() {\n            return \"shortcut-folder\";\n        }\n\n        @Override\n        public String getFolderType() {\n            return \"directory\";\n        }\n\n        @Override\n        public String getExecutableType() {\n            return null;\n        }\n\n        @Override\n        public Image getIcon(boolean getLargeIcon) {\n            return ICON_IMAGE;\n        }\n    }\n\n    public static class TestIcon implements Icon {\n        private final int width;\n        private final int height;\n\n        TestIcon(int width, int height) {\n            this.width = width;\n            this.height = height;\n        }\n\n        @Override\n        public void paintIcon(Component c, Graphics g, int x, int y) {\n            // The icon is only used as a return value for shortcut icon lookup.\n        }\n\n        @Override\n        public int getIconWidth() {\n            return width;\n        }\n\n        @Override\n        public int getIconHeight() {\n            return height;\n        }\n    }\n}\n"}
