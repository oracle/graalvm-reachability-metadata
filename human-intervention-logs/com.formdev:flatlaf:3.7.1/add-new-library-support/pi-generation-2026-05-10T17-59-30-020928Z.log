  package com_formdev.flatlaf;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.awt.Dimension;
  import java.net.URL;
  import javax.swing.UIManager;
  import com.formdev.flatlaf.FlatLaf;
  import com.formdev.flatlaf.FlatLightLaf;
  import org.junit.jupiter.api.Test;
  
  public class UIDefaultsLoaderTest {
      private static final String DEFAULTS_PACKAGE = "com_formdev.flatlaf.defaults";
      private static final String FALLBACK_PACKAGE = "com_formdev.flatlaf.fallback";
      private static final String MAPPED_DIMENSION_CLASS = "com_formdev.flatlaf.MappedDimension";
  
      @Test
      void loadsDefaultsResourcesAndInstantiatesConfiguredValues() throws Exception {
          MappingClassLoader classLoader = new MappingClassLoader(
                  UIDefaultsLoaderTest.class.getClassLoader());
          FlatLaf.registerCustomDefaultsSource(DEFAULTS_PACKAGE, classLoader);
          FlatLaf.registerCustomDefaultsSource(FALLBACK_PACKAGE, classLoader);
          try {
              FlatLightLaf.setup();
  
              assertThat(UIManager.get("UIDefaultsLoaderTest.noArgDimension"))
                      .isEqualTo(new Dimension());
              assertThat(UIManager.get("UIDefaultsLoaderTest.dimension"))
                      .isEqualTo(new Dimension(17, 23));
              assertThat(UIManager.get("UIDefaultsLoaderTest.mappedDimension"))
                      .isEqualTo(new Dimension(31, 37));
          } finally {
              FlatLaf.unregisterCustomDefaultsSource(FALLBACK_PACKAGE, classLoader);
              FlatLaf.unregisterCustomDefaultsSource(DEFAULTS_PACKAGE, classLoader);
          }
      }
  
      private static class MappingClassLoader extends ClassLoader {
          MappingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (MAPPED_DIMENSION_CLASS.equals(name)) {
                  return Dimension.class;
              }
              return super.loadClass(name);
          }
  
          @Override
          public URL getResource(String name) {
              return getParent().getResource(name);
          }
      }
  }
