  	{
  		try {
  			return applyToAnnotatedObject( obj, key, value );
  		} catch( UnknownStyleException ex ) {
  			// apply to border
  			Border border = c.getBorder();
  			if( border instanceof StyleableObject ) {
  				if( borderShared.get() ) {
  					border = cloneBorder( border );
  					c.setBorder( border );
  					borderShared.set( false );
