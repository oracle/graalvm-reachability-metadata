  		try {
  			return borderClass.getDeclaredConstructor().newInstance();
  		} catch( Exception ex ) {
  			throw new IllegalArgumentException( "failed to clone border '" + borderClass.getName() + "'", ex );
  		}
  	}
  
  	static Icon cloneIcon( Icon icon )
  		throws IllegalArgumentException
