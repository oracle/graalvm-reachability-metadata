avaCompatibility2;\nimport com.formdev.flatlaf.util.SystemInfo;\nimport sun.misc.Unsafe;\nimport org.junit.jupiter.api.Test;\n\npublic class JavaCompatibility2Test {\n    private static final Unsafe UNSAFE = findUnsafe();\n\n    @Test\n    void returnsComponentUiFromJComponent() {\n        ComponentWithCustomUi component = new ComponentWithCustomUi();\n\n        ComponentUI ui = JavaCompatibility2.getUI(component);\n\n        assertThat(ui).isSameAs(component.ui);\n    }\n\n    @Test\n    void returnsComponentUiUsingLegacyReflectionFallback() throws Exception {\n        StaticFieldValue java9OrLater = setStaticField(SystemInfo.class, \"isJava_9_orLater\", false);\n        StaticFieldValue getUiInitialized = setStaticField(\n                JavaCompatibility2.class, \"getUIMethodInitialized\", true);\n        StaticFieldValue getUiMethod = setStaticField(JavaCompatibility2.class, \"getUIMethod\", null);\n        try {\n            ComponentWithCustomUi component = new ComponentWithCustomUi();\n\n            ComponentUI ui = JavaCompatibility2.getUI(component);\n\n            assertThat(ui).isSameAs(component.ui);\n        } finally {\n            getUiMethod.restore();\n            getUiInitialized.restore();\n            java9OrLater.restore();\n        }\n    }\n\n    @Test\n    void returnsChooserComboBoxFilesFromFileSystemView() {\n        File[] expectedFiles = {new File(System.getProperty(\"user.home\"))};\n        TestFileSystemView fileSystemView = new TestFileSystemView(expectedFiles);\n\n        File[] files = JavaCompatibility2.getChooserComboBoxFiles(fileSystemView);\n\n        assertThat(files).containsExactly(expectedFiles);\n    }\n\n    @Test\n    void returnsChooserShortcutPanelFilesFromFileSystemView() {\n        File[] files = JavaCompatibility2.getChooserShortcutPanelFiles(new TestFileSystemView(new File[0]));\n\n        assertThat(files).isNotNull();\n    }\n\n    @Test\n    void invokesLegacyShellFolderFallbacks() throws Exception {\n        StaticFieldValue java12OrLater = setStaticField(SystemInfo.class, \"isJava_12_orLater\", false);\n        StaticFieldValue java9OrLater = setStaticField(SystemInfo.class, \"isJava_9_orLater\", false);\n        StaticFieldValue windows = setStaticField(SystemInfo.class, \"isWindows\", true);\n        try {\n            File[] shortcutPanelFiles = JavaCompatibility2.getChooserShortcutPanelFiles(\n                    new TestFileSystemView(new File[0]));\n            File[] comboBoxFiles = JavaCompatibility2.getChooserComboBoxFiles(\n                    new TestFileSystemView(new File[0]));\n\n            assertThat(shortcutPanelFiles).isNotNull();\n            assertThat(comboBoxFiles).isNotNull();\n        } finally {\n            windows.restore();\n            java9OrLater.restore();\n            java12OrLater.restore();\n        }\n    }\n\n    public static class TestFileSystemView extends FileSystemView {\n        private final File[] comboBoxFiles;\n\n        TestFileSystemView(File[] comboBoxFiles) {\n            this.comboBoxFiles = comboBoxFiles.clone();\n        }\n\n        @Override\n        public File createNewFolder(File containingDir) throws IOException {\n            return new File(containingDir, \"new-folder\");\n        }\n\n        @Override\n        public File getHomeDirectory() {\n            return new File(System.getProperty(\"user.home\"));\n        }\n\n        @Override\n        public File[] getRoots() {\n            return new File[] {getHomeDirectory()};\n        }\n\n        @Override\n        public File getDefaultDirectory() {\n            return getHomeDirectory();\n        }\n\n        @Override\n        public File[] getChooserComboBoxFiles() {\n            return comboBoxFiles.clone();\n        }\n    }\n\n    public static class ComponentWithCustomUi extends JComponent {\n        private final ComponentUI ui = new TestComponentUI();\n\n        @Override\n        public ComponentUI getUI() {\n            return ui;\n        }\n    }\n\n    private static Unsafe findUnsafe() {\n        try {\n            Field field = Unsafe.class.getDeclaredField(\"theUnsafe\");\n            field.setAccessible(true);\n            return (Unsafe) field.get(null);\n        } catch (ReflectiveOperationException ex) {\n            throw new IllegalStateException(\"Unable to access Unsafe\", ex);\n        }\n    }\n\n    private static StaticFieldValue setStaticField(Class<?> type, String name, Object value) throws Exception {\n        Field field = type.getDeclaredField(name);\n        Object base = UNSAFE.staticFieldBase(field);\n        long offset = UNSAFE.staticFieldOffset(field);\n        Object oldValue = field.getType() == boolean.class\n                ? UNSAFE.getBoolean(base, offset)\n                : UNSAFE.getObject(base, offset);\n        putStaticField(field, base, offset, value);\n        return new StaticFieldValue(field, base, offset, oldValue);\n    }\n\n    private static void putStaticField(Field field, Object base, long offset, Object value) {\n        if (field.getType() == boolean.class) {\n            UNSAFE.putBoolean(base, offset, (Boolean) value);\n        } else {\n            UNSAFE.putObject(base, offset, value);\n        }\n    }\n\n    private static class StaticFieldValue {\n        private final Field field;\n        private final Object base;\n        private final long offset;\n        private final Object value;\n\n        StaticFieldValue(Field field, Object base, long offset, Object value) {\n            this.field = field;\n            this.base = base;\n            this.offset = offset;\n            this.value = value;\n        }\n\n        void restore() {\n            putStaticField(field, base, offset, value);\n        }\n    }\n\n    private static class TestComponentUI extends ComponentUI {\n    }\n}\n"}], "isError": false, "timestamp": 1778436484747}]}
