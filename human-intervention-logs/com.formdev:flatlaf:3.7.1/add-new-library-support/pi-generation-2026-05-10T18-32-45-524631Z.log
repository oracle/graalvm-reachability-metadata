= image.createGraphics();\n        try {\n            FontMetrics fontMetrics = graphics.getFontMetrics(component.getFont());\n            String text = \"FlatLaf Java compatibility clipping\";\n            int availableWidth = fontMetrics.stringWidth(\"FlatLaf\");\n\n            String clipped = JavaCompatibility.getClippedString(\n                    component, fontMetrics, text, availableWidth);\n\n            assertThat(fontMetrics.stringWidth(text)).isGreaterThan(availableWidth);\n            assertThat(clipped)\n                    .isNotBlank()\n                    .isNotEqualTo(text);\n        } finally {\n            graphics.dispose();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3221, "output": 1057, "cacheRead": 32256, "cacheWrite": 0, "totalTokens": 36534, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778437946712, "responseId": "resp_00db6caf0c8ee10c016a00cf3b57a881a1a8e6d3842b9c2219"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_MuQqWORQP1G2vaw7MlKmxla5|fc_00db6caf0c8ee10c016a00cf42c5ec81a19621de818711e5bc", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2226 bytes to tests/src/com.formdev/flatlaf/3.7.1/src/test/java/com_formdev/flatlaf/JavaCompatibilityTest.java"}], "isError": false, "timestamp": 1778437958332}]}
