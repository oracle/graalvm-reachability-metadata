[tool-call] delta {"path":"tests/src/com.formdev/flatlaf/3.7.1/src/test/java/com_formdev/flatlaf/NativeLibraryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_formdev.flatlaf;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.formdev.flatlaf.util.NativeLibrary;\nimport org.junit.jupiter.api.Test;\n\npublic class NativeLibraryTest {\n    private static final String MISSING_LIBRARY_NAME = \"flatlaf-test-native-library-that-does-not-exist\";\n\n    @Test\n    void returnsNotLoadedWhenCustomClassLoaderCannotFindLibraryResource() {\n        NativeLibrary library = new NativeLibrary(\n                MISSING_LIBRARY_NAME, ClassLoader.getPlatformClassLoader(), true);\n\n        assertThat(library.isLoaded()).isFalse();\n    }\n\n    @Test\n    void returnsNotLoadedWhenModuleResourceLookupCannotFindLibraryResource() {\n        NativeLibrary library = new NativeLibrary(MISSING_LIBRARY_NAME, null, true);\n\n        assertThat(library.isLoaded()).isFalse();\n    }\n}\n"}
