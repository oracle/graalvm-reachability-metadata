String.class});\n    34\t\n    35\t        NoArgumentFactoryBean noArgumentBean = (NoArgumentFactoryBean) noArgumentCreator.call();\n    36\t        OneArgumentFactoryBean oneArgumentBean = (OneArgumentFactoryBean) oneArgumentCreator.call1(\"created-from-argument\");\n    37\t\n    38\t        assertThat(noArgumentBean.getValue()).isEqualTo(\"created-without-arguments\");\n    39\t        assertThat(oneArgumentBean.getValue()).isEqualTo(\"created-from-argument\");\n    40\t    }\n    41\t\n    42\t    @Test\n    43\t    void invokesMethodGetterAndSetterThroughAnnotatedAccessors() {\n    44\t        ObjectMapper mapper = new ObjectMapper();\n    45\t        AccessorBean bean = new AccessorBean(\"read-through-getter\");\n    46\t        AccessorBean restored = new AccessorBean();\n    47\t        BeanDescription serializationDescription = mapper.getSerializationConfig()\n    48\t                .introspect(mapper.constructType(AccessorBean.class));\n    49\t        BeanDescription deserializationDescription = mapper.getDeserializationConfig()\n    50\t                .introspect(mapper.constructType(AccessorBean.class));\n    51\t        AnnotatedMethod getter = findProperty(serializationDescription, \"value\").getGetter();\n    52\t        AnnotatedMethod setter = findProperty(deserializationDescription, \"value\").getSetter();\n    53\t\n    54\t        setter.setValue(restored, \"written-through-setter\");\n    55\t\n    56\t        assertThat(getter.getValue(bean)).isEqualTo(\"read-through-getter\");\n    57\t        assertThat(restored.getValue()).isEqualTo(\"written-through-setter\");\n    58\t    }\n    59\t\n    60\t    @Test\n    61\t    void resolvesSerializedAnnotatedMethodBackToDeclaredMethod() throws Exception {\n    62\t        ObjectMapper mapper = new ObjectMapper();\n    63\t        BeanDescription description = mapper.getSerializationConfig()\n    64\t                .introspect(mapper.constructType(AccessorBean.class));\n    65\t        AnnotatedMethod getter = findProperty(description, \"value\").getGetter();\n    66\t\n    67\t        AnnotatedMethod restored = roundTripThroughJavaSerialization(getter);\n    68\t\n    69\t        assertThat(restored.getName()).isEqualTo(\"getValue\");\n    70\t        assertThat(restored.getValue(new AccessorBean(\"resolved-method\"))).isEqualTo(\"resolved-method\");\n    71\t    }\n    72\t\n    73\t    private static BeanPropertyDefinition findProperty(BeanDescription description, String propertyName) {\n    74\t        for (BeanPropertyDefinition property : description.findProperties()) {\n    75\t            if (propertyName.equals(property.getName())) {\n    76\t                return property;\n    77\t            }\n    78\t        }\n    79\t        throw new IllegalArgumentException(\"Missing property: \" + propertyName);\n    80\t    }\n    81\t\n    82\t    private static AnnotatedMethod roundTripThroughJavaSerialization(AnnotatedMethod method) throws Exception {\n    83\t        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n    84\t        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n    85\t            output.writeObject(method);\n    86\t        }\n    87\t\n    88\t        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n    89\t            return (AnnotatedMethod) input.readObject();\n    90\t        }\n    91\t    }\n    92\t\n    93\t    public static class NoArgumentFactoryBean {\n    94\t        private final String value;\n    95\t\n    96\t        private NoArgumentFactoryBean(String value) {\n    97\t            this.value = value;\n    98\t        }\n    99\t\n   100\t        @JsonCreator\n   101\t        public static NoArgumentFactoryBean create() {\n   102\t            return new NoArgumentFactoryBean(\"created-without-arguments\");\n   103\t        }\n   104\t\n   105\t        public String getValue() {\n   106\t            return value;\n   107\t        }\n