eOf(Map.class)\n                .extracting(value -> ((Map<?, ?>) value).get(\"component\"))\n                .isEqualTo(\"rpc\");\n    }\n\n    public static class TraceAnnotations {\n        public String spanId;\n        private final Map<String, Object> attributes = new LinkedHashMap<>();\n\n        @JsonAnySetter\n        public void addAttribute(String name, Object value) {\n            attributes.put(name, value);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 609, "output": 756, "cacheRead": 16896, "cacheWrite": 0, "totalTokens": 18261, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777661181074, "responseId": "resp_08b68d1ddb2843800169f4f4fd6c1481a29f5ac006c22b3918"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_F8wgVvSudjRaxMtfs7gynKxo|fc_08b68d1ddb2843800169f4f508d95881a2b857ecee2a94e4e1", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1766 bytes to tests/src/org.apache.htrace/htrace-core/3.1.0-incubating/src/test/java/org_apache_htrace/htrace_core/SettableAnyPropertyTest.java"}], "isError": false, "timestamp": 1777661194251}]}
