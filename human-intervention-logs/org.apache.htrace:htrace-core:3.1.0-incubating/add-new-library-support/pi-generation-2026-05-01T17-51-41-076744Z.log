efaultConstructibleBean createdBean = ClassUtil.createInstance(DefaultConstructibleBean.class, false);\n\n        assertThat(createdBean.value()).isEqualTo(\"created\");\n    }\n\n    public static class DefaultConstructibleBean {\n        private final String value;\n\n        public DefaultConstructibleBean() {\n            this.value = \"created\";\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n}\n"}
