ther) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof TraceTopicKey)) {\n                return false;\n            }\n            TraceTopicKey that = (TraceTopicKey) other;\n            return Objects.equals(topic, that.topic);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(topic);\n        }\n    }\n}\n"}
