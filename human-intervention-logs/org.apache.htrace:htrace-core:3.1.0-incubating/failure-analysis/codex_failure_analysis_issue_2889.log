",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_htrace.htrace_core;\\n\\nimport org.apache.htrace.commons.logging.Log;\\nimport org.apache.htrace.commons.logging.LogConfigurationException;\\nimport org.apache.htrace.commons.logging.LogFactory;\\nimport org.apache.htrace.commons.logging.impl.LogFactoryImpl;\\nimport org.apache.htrace.commons.logging.impl.NoOpLog;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.util.concurrent.atomic.AtomicInteger;\\nimport java.util.concurrent.atomic.AtomicReference;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\npublic class LogFactoryImplTest {\\n    private static final String DIAGNOSTICS_PROPERTY = \\\"org.apache.htrace.commons.logging.diagnostics.dest\\\";\\n    private static final String LOG_PROPERTY = \\\"org.apache.htrace.commons.logging.Log\\\";\\n    private static final String ALLOW_FLAWED_CONTEXT_PROPERTY =\\n            \\\"org.apache.htrace.commons.logging.Log.allowFlawedContext\\\";\\n    private static final String ALLOW_FLAWED_DISCOVERY_PROPERTY =\\n            \\\"org.apache.htrace.commons.logging.Log.allowFlawedDiscovery\\\";\\n    private static final String ALLOW_FLAWED_HIERARCHY_PROPERTY =\\n            \\\"org.apache.htrace.commons.logging.Log.allowFlawedHierarchy\\\";\\n\\n    @Test\\n    void discoversCustomLogImplementationAndReusesCachedConstructor() {\\n        String originalDiagnostics = System.getProperty(DIAGNOSTICS_PROPERTY);\\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\\n        System.setProperty(DIAGNOSTICS_PROPERTY, \\\"STDOUT\\\");\\n        Thread.currentThread().setContextClassLoader(new IsolatedClassLoader());\\n        RecordingLog.reset();\\n\\n        try {\\n            LogFactoryImpl factory = new LogFactoryImpl();\\n            factory.setAttribute(ALLOW_FLAWED_CONTEXT_PROPERTY, \\\"true\\\");\\n            factory.setAttribute(LOG_PROPERTY, RecordingLog.class.getName());\\n\\n            Log firstLog = factory.getInstance(\\\"first-category\\\");\\n            Log secondLog = factory.getInstance(\\\"second-category\\\");\\n\\n            assertThat(firstLog).isInstanceOf(RecordingLog.class);\\n            assertThat(secondLog).isInstanceOf(RecordingLog.class);\\n            assertThat(((RecordingLog) firstLog).category()).isEqualTo(\\\"first-category\\\");\\n            assertThat(((RecordingLog) secondLog).category()).isEqualTo(\\\"second-category\\\");\\n            assertThat(RecordingLog.constructorCalls()).isEqualTo(2);\\n            assertThat(RecordingLog.setLogFactoryCalls()).isEqualTo(2);\\n            assertThat(RecordingLog.lastFactory()).isSameAs(factory);\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n            restoreSystemProperty(DIAGNOSTICS_PROPERTY, originalDiagnostics);\\n        }\\n    }\\n\\n    @Test\\n    void diagnosticsProbeResourcesWhileRejectingNonLogAdapter() {\\n        String originalDiagnostics = System.getProperty(DIAGNOSTICS_PROPERTY);\\n        System.setProperty(DIAGNOSTICS_PROPERTY, \\\"STDOUT\\\");\\n\\n        try {\\n            LogFactoryImpl factory = new LogFactoryImpl();\\n            factory.setAttribute(ALLOW_FLAWED_DISCOVERY_PROPERTY, \\\"true\\\");\\n            factory.setAttribute(ALLOW_FLAWED_HIERARCHY_PROPERTY, \\\"true\\\");\\n            factory.setAttribute(LOG_PROPERTY, String.class.getName());\\n\\n            assertThatThrownBy(() -> factory.getInstance(\\\"not-a-log-adapter\\\"))\\n                    .isInstanceOf(LogConfigurationException.class)\\n                    .hasMessageContaining(String.class.getName());\\n        } finally {\\n            restoreSystemProperty(DIAGNOSTICS_PROPERTY, originalDiagnostics);\\n        }\\n    }\\n\\n    private static void restoreSystemProperty(String name, String originalValue) {\\n        if (originalValue == null) {\\n            System.clearProperty(name);\\n        } else {\\n            System.setProperty(name, originalValue);\\n        }\\n    }\\n\\n    private static final class IsolatedClassLoader extends ClassLoader {\\n        IsolatedClassLoader() {\\n            super(null);\\n        }\\n    }\\n\\n    public static final class RecordingLog extends NoOpLog {\\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\\n        private static final AtomicInteger SET_LOG_FACTORY_CALLS = new AtomicInteger();\\n        private static final AtomicReference<LogFactory> LAST_FACTORY = new AtomicReference<>();\\n\\n        private final String category;\\n\\n        public RecordingLog(String category) {\\n            super(category);\\n            this.category = category;\\n            CONSTRUCTOR_CALLS.incrementAndGet();\\n        }\\n\\n        public void setLogFactory(LogFactory logFactory) {\\n            LAST_FACTORY.set(logFactory);\\n            SET_LOG_FACTORY_CALLS.incrementAndGet();\\n        }\\n\\n        String category() {\\n            return category;\\n        }\\n\\n        static int constructorCalls() {\\n            return CONSTRUCTOR_CALLS.get();\\n        }\\n\\n        static int setLogFactoryCalls() {\\n            return SET_LOG_FACTORY_CALLS.get();\\n        }\\n\\n        static LogFactory lastFactory() {\\n            return LAST_FACTORY.get();\\n        }\\n\\n        static void reset() {\\n            CONSTRUCTOR_CALLS.set(0);\\n            SET_LOG_FACTORY_CALLS.set(0);\\n            LAST_FACTORY.set(null);\\n        }\\n    }\\n}\\n\"}\n5364:  5364\t[tool-call] end id=call_U2Sy8BVyo1OZT7Tcnh2LfQr2|fc_096547c64b0e67700169f93d1919ac819db33ac97d1c761d33 name=write args={\"path\": \"tests/src/org.apache.htrace/htrace-core/3.1.0-incubat