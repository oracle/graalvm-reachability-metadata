{"type":"item.started","item":{"id":"item_28","type":"command_execution","command":"/usr/bin/bash -lc \"python - <<'PY'\nimport json\nfrom collections import Counter\np='tests/src/org.apache.htrace/htrace-core/3.1.0-incubating/build/reports/dynamic-access/dynamic-access-coverage.json'\nwith open(p) as f:\n    data=json.load(f)\nclasses=data['classes']\ncovered=sum(c['coveredCalls'] for c in classes)\ntotal=sum(c['totalCalls'] for c in classes)\nprefix=Counter()\nfor c in classes:\n    name=c['className']\n    if name.startswith('org.apache.htrace.fasterxml.jackson'):\n        prefix['jackson'] += c['totalCalls']\n    elif name.startswith('org.apache.htrace.commons.logging'):\n        prefix['commons_logging'] += c['totalCalls']\n    elif name.startswith('org.apache.htrace'):\n        prefix['htrace_other'] += c['totalCalls']\n    else:\n        prefix['other'] += c['totalCalls']\nprint('covered', covered, 'total', total)\nprint(prefix)\nprint('uncovered:')\nfor c in classes:\n    for cs in c['callSites']:\n        if not cs['covered']:\n            print(c['className'], '::', cs['trackedApi'], '<-', cs['frame'])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
