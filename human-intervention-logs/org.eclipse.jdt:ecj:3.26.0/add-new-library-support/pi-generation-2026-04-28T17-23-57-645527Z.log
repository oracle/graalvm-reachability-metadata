              task.call();
          }
  
          assertThat(processor.getFailure()).isNull();
          assertThat(processor.hasProcessedFixture())
                  .describedAs(formatDiagnostics(diagnostics))
                  .isTrue();
      }
  
      private Path fixtureSourceFile() throws IOException {
