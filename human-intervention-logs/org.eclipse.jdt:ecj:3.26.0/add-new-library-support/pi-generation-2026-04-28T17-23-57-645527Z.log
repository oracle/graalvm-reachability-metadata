  public class ErrorTypeImplTest {
      private static final String FIXTURE_NAME = "org_eclipse_jdt.ecj.ErrorTypeImplFixture";
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void missingFieldTypeReturnsEmptyAnnotationArray() throws IOException {
          JavaCompiler compiler = new EclipseCompiler();
          DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();
          ErrorTypeProcessor processor = new ErrorTypeProcessor();
          Path outputDirectory = this.temporaryDirectory.resolve("classes");
          Files.createDirectories(outputDirectory);
  
          try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(diagnostics, Locale.ROOT,
