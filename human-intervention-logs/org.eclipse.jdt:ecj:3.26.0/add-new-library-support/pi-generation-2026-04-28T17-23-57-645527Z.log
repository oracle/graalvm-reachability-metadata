                  require(missingType.getKind() == TypeKind.ERROR, "Expected unresolved field type to be an error type");
  
                  ErrorTypeProbe[] probeAnnotations = missingType.getAnnotationsByType(ErrorTypeProbe.class);
                  require(probeAnnotations.length == 0, "Expected missing type to have no probe annotations");
