/org.osgi/org.osgi.core/index.json:23:    \"description\" : \"This artifact provides the core OSGi Service Platform Release 4.3 interfaces and classes. It defines the Framework APIs for bundles, lifecycle management, module wiring, and services used when compiling OSGi-based applications.\",\nmetadata/org.hibernate.validator/hibernate-validator/7.0.4.Final/reachability-metadata.json:41:        \"typeReached\": \"org.hibernate.validator.messageinterpolation.ResourceBundleMessageInterpolator\"\nmetadata/org.hibernate.validator/hibernate-validator/7.0.4.Final/reachability-metadata.json:376:        \"typeReached\": \"org.hibernate.validator.resourceloading.PlatformResourceBundleLocator\"\nmetadata/org.hibernate.validator/hibernate-validator/7.0.4.Final/reachability-metadata.json:478:        \"typeReached\": \"org.hibernate.validator.resourceloading.PlatformResourceBundleLocator\"\nmetadata/jline/jline/2.14.6/reachability-metadata.json:83:      \"glob\" : \"META-INF/services/java.util.spi.ResourceBundleControlProvider\"\nmetadata/org.osgi/org.osgi.resource/index.json:9:    \"description\" : \"org.osgi.resource provides the OSGi Resource API, a set of interfaces for describing resources, their capabilities, requirements, wires, and wirings. It is used by OSGi frameworks and related services to model dependency resolution and the resolved wiring state of bundles or repository resources.\",\nmetadata/com.mchange/mchange-commons-java/0.2.15/reachability-metadata.json:1929:      \"glob\" : \"META-INF/services/java.util.spi.ResourceBundleControlProvider\"\nmetadata/org.osgi/org.osgi.service.serviceloader/index.json:9:    \"description\" : \"This OSGi companion API defines the Service Loader capability and requirement namespace used to advertise Java ServiceLoader providers in OSGi bundles. It provides constants and package metadata that let OSGi runtimes mediate and register service-provider implementations as OSGi services.\",\nmetadata/library-and-framework-list.json:967:   