69f72f2cdc5c81968b0b9fe1fb4fc68b\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage net_sf_saxon.Saxon_HE;\\n\\nimport java.io.InputStream;\\nimport java.net.URL;\\nimport java.util.ArrayList;\\nimport java.util.List;\\n\\nimport javax.xml.transform.stream.StreamSource;\\n\\nimport net.sf.saxon.Configuration;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatNullPointerException;\\n\\npublic class ConfigurationTest {\\n\\n    private static final String CONFIGURATION_CLASS_NAME = \\\"net.sf.saxon.Configuration\\\";\\n    private static final String DATA_RESOURCE = \\\"casevariants.xml\\\";\\n    private static final String DATA_RESOURCE_PATH = \\\"net/sf/saxon/data/\\\" + DATA_RESOURCE;\\n    private static final String MISSING_DATA_RESOURCE = \\\"saxon-configuration-test-missing-resource.xml\\\";\\n    private static final String MISSING_RESOURCE_PATH = \\\"net/sf/saxon/data/\\\" + MISSING_DATA_RESOURCE;\\n\\n    @Test\\n    void createsDefaultConfigurationWithFactoryMethod() {\\n        Configuration configuration = Configuration.newConfiguration();\\n\\n        assertThat(configuration).isExactlyInstanceOf(Configuration.class);\\n    }\\n\\n    @Test\\n    void instantiatesConfigurationWithProvidedClassLoader() throws Exception {\\n        ClassLoader classLoader = new DelegatingClassLoader(Configuration.class.getClassLoader());\\n\\n        Configuration configuration = Configuration.instantiateConfiguration(CONFIGURATION_CLASS_NAME, classLoader);\\n\\n        assertThat(configuration).isExactlyInstanceOf(Configuration.class);\\n    }\\n\\n    @Test\\n    void instantiatesConfigurationWithClassForNameFallbackWhenProvidedClassLoaderFails() throws Exception {\\n        ClassLoader classLoader = new FailingConfigurationClassLoader(Configuration.class.getClassLoader());\\n\\n        Configuration configuration = Configuration.instantiateConfiguration(CONFIGURATION_CLASS_NAME, classLoader);\\n\\n        assertThat(configuration).isExactlyInstanceOf(Configuration.class);\\n    }\\n\\n    @Test\\n    void instantiatesConfigurationWithClassForNameWhenContextClassLoaderIsNull() throws Exception {\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        currentThread.setContextClassLoader(null);\\n        try {\\n            Configuration configuration = Configuration.instantiateConfiguration(CONFIGURATION_CLASS_NAME, null);\\n\\n            assertThat(configuration).isExactlyInstanceOf(Configuration.class);\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void locatesPackagedDataResourceWithContextClassLoader() throws Exception {\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        currentThread.setContextClassLoader(ConfigurationTest.class.getClassLoader());\\n        try {\\n            List<String> messages = new ArrayList<>();\\n            List<ClassLoader> loaders = new ArrayList<>();\\n\\n            try (InputStream input = Configuration.locateResource(DATA_RESOURCE, messages, loaders)) {\\n                assertThat(input).isNotNull();\\n                assertThat(loaders).hasSize(1);\\n                assertThat(loaders.get(0)).isSameAs(ConfigurationTest.class.getClassLoader());\\n            }\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void reportsMissingDataResourceAfterTryingFallbackClassLoaders() throws Except