n    void instantiatesConfigurationWithProvidedClassLoader() throws Exception {\\n        ClassLoader classLoader = new DelegatingClassLoader(Configuration.class.getClassLoader());\\n\\n        Configuration configuration = Configuration.instantiateConfiguration(CONFIGURATION_CLASS_NAME, classLoader);\\n\\n        assertThat(configuration).isExactlyInstanceOf(Configuration.class);\\n    }\\n\\n    @Test\\n    void instantiatesConfigurationWithClassForNameFallbackWhenProvidedClassLoaderFails() throws Exception {\\n        ClassLoader classLoader = new FailingConfigurationClassLoader(Configuration.class.getClassLoader());\\n\\n        Configuration configuration = Configuration.instantiateConfiguration(CONFIGURATION_CLASS_NAME, classLoader);\\n\\n        assertThat(configuration).isExactlyInstanceOf(Configuration.class);\\n    }\\n\\n    @Test\\n    void instantiatesConfigurationWithClassForNameWhenContextClassLoaderIsNull() throws Exception {\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        currentThread.setContextClassLoader(null);\\n        try {\\n            Configuration configuration = Configuration.instantiateConfiguration(CONFIGURATION_CLASS_NAME, null);\\n\\n            assertThat(configuration).isExactlyInstanceOf(Configuration.class);\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void locatesPackagedDataResourceWithContextClassLoader() throws Exception {\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        currentThread.setContextClassLoader(ConfigurationTest.class.getClassLoader());\\n        try {\\n            List<String> messages = new ArrayList<>();\\n            List<ClassLoader> loaders = new ArrayList<>();\\n\\n            try (InputStream input = Configuration.locateResource(DATA_RESOURCE, messages, loaders)) {\\n                assertThat(input).isNotNull();\\n                assertThat(loaders).hasSize(1);\\n                assertThat(loaders.get(0)).isSameAs(ConfigurationTest.class.getClassLoader());\\n            }\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void reportsMissingDataResourceAfterTryingFallbackClassLoaders() throws Exception {\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        currentThread.setContextClassLoader(new NoResourceClassLoader(Configuration.class.getClassLoader()));\\n        try {\\n            List<String> messages = new ArrayList<>();\\n            List<ClassLoader> loaders = new ArrayList<>();\\n\\n            InputStream input = Configuration.locateResource(MISSING_DATA_RESOURCE, messages, loaders);\\n\\n            assertThat(input).isNull();\\n            assertThat(loaders).hasSize(1);\\n            assertThat(messages).anySatisfy(message -> assertThat(message).contains(MISSING_RESOURCE_PATH));\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void locatesResourceSourceWithContextClassLoader() throws Exception {\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        currentThread.setContextClassLoader(ConfigurationTest.class.getClassLoader());\\n        try {\\n            List<String> messages = new ArrayList<>();\\n            List<ClassLoader> loaders = new ArrayList<>();\\n\\n            StreamSource source = Configuration.locateResourceSource(DATA_RESOURCE_PATH, messages, loaders);\\n            try (InputStream input = source.getInputStream()) {\\n                assertThat(input).isNotNull();\\n                assertThat(source.getSystemId()).contains(DATA_RESOURCE_PATH);\\n                assertThat(loaders).hasSize(1);\\n                assertThat(loaders.get(0)).isSameAs(ConfigurationTest.class.getClassLoader());\\n            }\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void resourceSourceAttemptsFallbackClassLoaderForMissingResource() {\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        currentThread.setContextClassLoader(new NoResourceClassLoader(Configuration.class.getClassLoader()));\\n        try {\\n            List<String> messages = new ArrayList<>();\\n            List<ClassLoader> loaders = new ArrayList<>();\\n\\n            assertThatNullPointerException()\\n                    .isThrownBy(() -> Configuration.locateResourceSource(MISSING_RESOURCE_PATH, messages, loaders));\\n\\n            assertThat(messages).anySatisfy(message -> assertThat(message).contains(MISSING_RESOURCE_PATH));\\n            assertThat(loaders).isEmpty();\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    private static final class DelegatingClassLoader extends ClassLoader {\\n        private DelegatingClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n    }\\n\\n    private static final class FailingConfigurationClassLoader extends ClassLoader {\\n        private FailingConfigurationClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\\n            if (CONFIGURATION_CLASS_NAME.equals(name)) {\\n                throw new ClassNotFoundException(name);\\n            }\\n            return super.loadClass(name);\\n        }\\n    }\\n\\n    private static final class NoResourceClassLoade