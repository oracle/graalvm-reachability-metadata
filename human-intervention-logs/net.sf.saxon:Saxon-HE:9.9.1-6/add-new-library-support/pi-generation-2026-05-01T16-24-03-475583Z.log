  package net.sf.saxon.pull;
  
  
  import net.sf.saxon.event.PipelineConfiguration;
  import net.sf.saxon.event.ReceiverOptions;
  import net.sf.saxon.expr.parser.ExplicitLocation;
  import net.sf.saxon.om.*;
