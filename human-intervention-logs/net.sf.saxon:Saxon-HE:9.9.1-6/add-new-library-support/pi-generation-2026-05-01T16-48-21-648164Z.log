                  String uri = getURIForPrefix(s, false);
                  if (uri == null) {
                      compileError("Namespace prefix " + s + " is undeclared", "XTSE1430");
                      extensionNamespaces[count++] = NamespaceConstant.SAXON;  // for recovery
