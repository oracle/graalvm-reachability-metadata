     193	            return "saxon9-sql.jar";
     194	        } else if (className.startsWith("com.saxonica.StatsTransform")) {
     195	            return "saxon9-stats.jar";
     196	        } else if (className.startsWith("com.ibm.icu.")) {
     197	            return "saxon9-icu.jar";
     198	        } else if (className.startsWith("com.saxonica")) {
     199	            return "saxon9ee.jar";
     200	        } else {
     201	            return null;
     202	        }
     203	    }
     204	
     205	    private String getMissingJarFileMessage(String className) {
     206	        String jar = getJarFileForClass(className);
     207	        return jar==null ? "" : ". Check that " + jar + " is on the classpath";
     208	    }
     209	
     210	    public InputStream getResourceAsStream(String name) {
     211	        ClassLoader loader = getClassLoader();
     212	        if (loader == null) {
     213	            loader = Thread.currentThread().getContextClassLoader();
     214	        }
     215	        return loader.getResourceAsStream(name);
     216	    }
     217	
     218	
     219	}
