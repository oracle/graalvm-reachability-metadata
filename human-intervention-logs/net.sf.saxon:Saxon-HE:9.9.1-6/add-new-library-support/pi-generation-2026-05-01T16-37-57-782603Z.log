  package net_sf_saxon.Saxon_HE;
  
  import net.sf.saxon.Configuration;
  import net.sf.saxon.expr.PJConverter;
  import net.sf.saxon.expr.StaticProperty;
  import net.sf.saxon.s9api.XdmAtomicValue;
  import net.sf.saxon.type.BuiltInAtomicType;
  import net.sf.saxon.value.UntypedAtomicValue;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PJConverterTest {
      @Test
      void untypedAtomicValueConvertsUsingPublicStringConstructor() throws Exception {
          Configuration configuration = Configuration.newConfiguration();
          PJConverter converter = PJConverter.allocate(
                  configuration,
                  BuiltInAtomicType.UNTYPED_ATOMIC,
                  StaticProperty.EXACTLY_ONE,
                  XdmAtomicValue.class);
          UntypedAtomicValue value = new UntypedAtomicValue("Saxon converter value");
  
          Object convertedValue = converter.convert(value, XdmAtomicValue.class, null);
  
          assertThat(convertedValue).isInstanceOf(XdmAtomicValue.class);
          XdmAtomicValue atomicValue = (XdmAtomicValue) convertedValue;
          assertThat(atomicValue.getStringValue()).isEqualTo("Saxon converter value");
      }
  }
