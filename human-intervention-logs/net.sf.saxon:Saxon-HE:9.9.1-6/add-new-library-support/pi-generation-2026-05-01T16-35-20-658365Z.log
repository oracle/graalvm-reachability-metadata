figuration configuration = Configuration.newConfiguration();\n        PJConverter converter = PJConverter.allocate(\n                configuration,\n                BuiltInAtomicType.STRING,\n                StaticProperty.ALLOWS_ONE_OR_MORE,\n                LinkedList.class);\n        XPathContext context = new Controller(configuration).newXPathContext();\n        SequenceExtent<StringValue> sequence = new SequenceExtent<>(new StringValue[] {\n            new StringValue(\"alpha\"),\n            new StringValue(\"beta\"),\n            new StringValue(\"gamma\")\n        });\n\n        Object convertedValue = converter.convert(sequence, LinkedList.class, context);\n\n        assertThat(convertedValue).isInstanceOf(LinkedList.class);\n        assertThat((LinkedList<?>) convertedValue).containsExactly(\"alpha\", \"beta\", \"gamma\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 828, "output": 958, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 35066, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777653301060, "responseId": "resp_00984f91b492c4f80169f4d635899c81969bf3c706554f0719"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_j9tqZnt8mufrlYmaVo3EhKsI|fc_00984f91b492c4f80169f4d63f056c8196872695defb8a188c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1651 bytes to tests/src/net.sf.saxon/Saxon-HE/9.9.1-6/src/test/java/net_sf_saxon/Saxon_HE/PJConverterInnerToCollectionTest.java"}], "isError": false, "timestamp": 1777653313485}]}
