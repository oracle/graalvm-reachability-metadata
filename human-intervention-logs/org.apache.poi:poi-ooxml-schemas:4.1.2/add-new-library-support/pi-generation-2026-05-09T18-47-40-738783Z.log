  package org_apache_poi.poi_ooxml_schemas;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.InputStream;
  
  import org.apache.xmlbeans.SchemaTypeSystem;
  import org.apache.xmlbeans.impl.schema.BuiltinSchemaTypeSystem;
  import org.apache.xmlbeans.impl.schema.PathResourceLoader;
  import org.apache.xmlbeans.impl.schema.SchemaTypeLoaderImpl;
  import org.apache.xmlbeans.impl.schema.SchemaTypeSystemCompiler;
  import org.apache.xmlbeans.impl.store.Locale;
  import org.junit.jupiter.api.Test;
  import schemaorg_apache_xmlbeans.system.s8C3F193EE11A2F798ACF65489B9E6078.TypeSystemHolder;
  
  public class SchemaorgApacheXmlbeansSystemS8C3F193EE11A2F798ACF65489B9E6078TypeSystemHolderTest {
      private static final String TYPE_SYSTEM_NAME = "schemaorg_apache_xmlbeans.system.s8C3F193EE11A2F798ACF65489B9E6078";
      private static final String TYPE_SYSTEM_INDEX_RESOURCE = "schemaorg_apache_xmlbeans/system/s8C3F193EE11A2F798ACF65489B9E6078/index.xsb";
  
      @Test
      public void loadsTypeSystemFromGeneratedHolder() throws Exception {
          assertXmlBeansRuntimeSupportClassesAreReachable();
          assertTypeSystemIndexResourceIsReachable();
  
          SchemaTypeSystem typeSystem = TypeSystemHolder.typeSystem;
  
          assertThat(typeSystem.getName()).isEqualTo(TYPE_SYSTEM_NAME);
          assertThat(typeSystem.getClassLoader()).isSameAs(TypeSystemHolder.class.getClassLoader());
      }
  
      private static void assertTypeSystemIndexResourceIsReachable() throws Exception {
          try (InputStream index = TypeSystemHolder.class.getClassLoader().getResourceAsStream(TYPE_SYSTEM_INDEX_RESOURCE)) {
              assertThat(index).isNotNull();
              assertThat(index.read()).isNotEqualTo(-1);
          }
      }
  
      private static void assertXmlBeansRuntimeSupportClassesAreReachable() {
          Class<?>[] xmlBeansRuntimeSupportClasses = {
              SchemaTypeLoaderImpl.class,
              BuiltinSchemaTypeSystem.class,
              SchemaTypeSystemCompiler.class,
              Locale.class,
              PathResourceLoader.class
          };
  
          assertThat(xmlBeansRuntimeSupportClasses)
                  .extracting(Class::getName)
                  .contains(
                          "org.apache.xmlbeans.impl.schema.SchemaTypeLoaderImpl",
                          "org.apache.xmlbeans.impl.schema.BuiltinSchemaTypeSystem",
                          "org.apache.xmlbeans.impl.schema.SchemaTypeSystemCompiler",
                          "org.apache.xmlbeans.impl.store.Locale",
                          "org.apache.xmlbeans.impl.schema.PathResourceLoader");
      }
  }
