ptionDocument.Factory.parse(document.xmlText());\n        CTKeyData parsedKeyData = parsedDocument.getEncryption().getKeyData();\n\n        assertThat(parsedKeyData.getSaltSize()).isEqualTo(16);\n        assertThat(parsedKeyData.getBlockSize()).isEqualTo(16);\n        assertThat(parsedKeyData.getKeyBits()).isEqualTo(256);\n        assertThat(parsedKeyData.getHashSize()).isEqualTo(32);\n        assertThat(parsedKeyData.getCipherAlgorithm()).isEqualTo(STCipherAlgorithm.AES);\n        assertThat(parsedKeyData.getCipherChaining()).isEqualTo(STCipherChaining.CHAINING_MODE_CBC);\n        assertThat(parsedKeyData.getHashAlgorithm()).isEqualTo(STHashAlgorithm.SHA_256);\n        assertThat(parsedKeyData.getSaltValue()).containsExactly(new byte[] {1, 2, 3, 4});\n    }\n","newText":"public class SchemaorgApacheXmlbeansSystemS8C3F193EE11A2F798ACF65489B9E6078TypeSystemHolderTest {\n    @Test\n    public void loadsTypeSystemFromGeneratedHolder() throws Exception {\n        assertXmlBeansRuntimeSupportClassesAreReachable();\n        assertTypeSystemIndexResourceIsReachable();\n\n        SchemaTypeSystem typeSystem = TypeSystemHolder.typeSystem;\n\n        assertThat(typeSystem.getName()).isEqualTo(\"schemaorg_apache_xmlbeans.system.s8C3F193EE11A2F798ACF65489B9E6078\");\n        assertThat(typeSystem.getClassLoader()).isSameAs(TypeSystemHolder.class.getClassLoader());\n    }\n"},{"oldText":"    private static void assertXmlBeansRuntimeSupportClassesAreReachable() {\n","newText":"    private static void assertTypeSystemIndexResourceIsReachable() throws Exception {\n        try (InputStream index = TypeSystemHolder.class.getResourceAsStream(\"index.xsb\")) {\n            assertThat(index).isNotNull();\n            assertThat(index.read()).isNotEqualTo(-1);\n        }\n    }\n\n    private static void assertXmlBeansRuntimeSupportClassesAreReachable() {\n"}]}
