ass);\n        assertThat(encryptionDocumentType).isSameAs(EncryptionDocument.type);\n\n        EncryptionDocument document = EncryptionDocument.Factory.newInstance();\n        CTKeyData keyData = document.addNewEncryption().addNewKeyData();\n        keyData.setSaltSize(16);\n        keyData.setBlockSize(16);\n        keyData.setKeyBits(256);\n        keyData.setHashSize(32);\n        keyData.setCipherAlgorithm(STCipherAlgorithm.AES);\n        keyData.setCipherChaining(STCipherChaining.CHAINING_MODE_CBC);\n        keyData.setHashAlgorithm(STHashAlgorithm.SHA_256);\n        keyData.setSaltValue(new byte[] {1, 2, 3, 4});\n\n        EncryptionDocument parsedDocument = EncryptionDocument.Factory.parse(document.xmlText());\n        CTKeyData parsedKeyData = parsedDocument.getEncryption().getKeyData();\n\n        assertThat(parsedKeyData.getSaltSize()).isEqualTo(16);\n        assertThat(parsedKeyData.getBlockSize()).isEqualTo(16);\n        assertThat(parsedKeyData.getKeyBits()).isEqualTo(256);\n        assertThat(parsedKeyData.getHashSize()).isEqualTo(32);\n        assertThat(parsedKeyData.getCipherAlgorithm()).isEqualTo(STCipherAlgorithm.AES);\n        assertThat(parsedKeyData.getCipherChaining()).isEqualTo(STCipherChaining.CHAINING_MODE_CBC);\n        assertThat(parsedKeyData.getHashAlgorithm()).isEqualTo(STHashAlgorithm.SHA_256);\n        assertThat(parsedKeyData.getSaltValue()).containsExactly(new byte[] {1, 2, 3, 4});\n    }\n\n    private static void assertXmlBeansRuntimeSupportClassesAreReachable() {\n        Class<?>[] xmlBeansRuntimeSupportClasses = {\n            SchemaTypeLoaderImpl.class,\n            BuiltinSchemaTypeSystem.class,\n            SchemaTypeSystemCompiler.class,\n            Locale.class,\n            PathResourceLoader.class\n        };\n\n        assertThat(xmlBeansRuntimeSupportClasses)\n                .extracting(Class::getName)\n                .contains(\n                        \"org.apache.xmlbeans.impl.schema.SchemaTypeLoaderImpl\",\n                        \"org.apache.xmlbeans.impl.schema.BuiltinSchemaTypeSystem\",\n                        \"org.apache.xmlbeans.impl.schema.SchemaTypeSystemCompiler\",\n                        \"org.apache.xmlbeans.impl.store.Locale\",\n                        \"org.apache.xmlbeans.impl.schema.PathResourceLoader\");\n    }\n}\n"}], "isError": false, "timestamp": 1778352645290}]}
