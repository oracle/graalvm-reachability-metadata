[tool-call] delta {"path":"tests/src/org.apache.poi/poi-ooxml-schemas/4.1.2/src/test/java/org_apache_poi/poi_ooxml_schemas/SchemaorgApacheXmlbeansSystemS8C3F193EE11A2F798ACF65489B9E6078TypeSystemHolderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_poi.poi_ooxml_schemas;\n\nimport com.microsoft.schemas.office.x2006.encryption.CTEncryption;\nimport com.microsoft.schemas.office.x2006.encryption.CTKeyData;\nimport com.microsoft.schemas.office.x2006.encryption.EncryptionDocument;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SchemaorgApacheXmlbeansSystemS8C3F193EE11A2F798ACF65489B9E6078TypeSystemHolderTest {\n    @Test\n    void createsEncryptionSchemaDocument() {\n        EncryptionDocument document = EncryptionDocument.Factory.newInstance();\n\n        CTEncryption encryption = document.addNewEncryption();\n        CTKeyData keyData = encryption.addNewKeyData();\n\n        assertThat(document.getEncryption()).isSameAs(encryption);\n        assertThat(encryption.getKeyData()).isSameAs(keyData);\n        assertThat(document.xmlText()).contains(\"encryption\");\n    }\n}\n"}
