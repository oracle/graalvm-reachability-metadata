23\");\n        assertThat(document.getString(\"full_name\").getValue()).isEqualTo(\"Ada\");\n        assertThat(document.getInt32(\"quantity\").getValue()).isEqualTo(7);\n    }\n\n    private static <T> Codec<T> codecFor(final Class<T> type) {\n        final CodecRegistry registry = fromProviders(new ValueCodecProvider(), new RecordCodecProvider());\n        return registry.get(type);\n    }\n\n    public record AnnotatedRecord(\n            @org.bson.codecs.pojo.annotations.BsonId String id,\n            @org.bson.codecs.pojo.annotations.BsonProperty(\"full_name\") String name,\n            int quantity) {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1600, "output": 1010, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 21042, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778395180153, "responseId": "resp_05aa8f8eb78004ee016a00282c9a488195abd2fec6d0079a3f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_vMCKOBgMV8f7Ow7qZq2cLzOf|fc_05aa8f8eb78004ee016a0028357dbc8195853767bfc1dd4956", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1765 bytes to tests/src/org.mongodb/bson-record-codec/4.11.1/src/test/java/org_mongodb/bson_record_codec/RecordCodecInnerComponentModelTest.java"}], "isError": false, "timestamp": 1778395192645}]}
