{\n        final PulsarAdminBuilder builder = DefaultImplementation.newAdminClientBuilder();\n\n        assertThat(builder).isNotNull();\n        assertThat(builder.serviceHttpUrl(\"http://127.0.0.1:8080\")).isSameAs(builder);\n    }\n\n    @Test\n    void newOffloadProcessStatusInstantiatesConfiguredImplementation() {\n        final OffloadProcessStatus status = DefaultImplementation.newOffloadProcessStatus(\n                LongRunningProcessStatus.Status.ERROR, \"offload failed\", MessageId.earliest);\n\n        assertThat(status.getStatus()).isEqualTo(LongRunningProcessStatus.Status.ERROR);\n        assertThat(status.getLastError()).isEqualTo(\"offload failed\");\n        assertThat(status.getFirstUnoffloadedMessage()).isEqualTo(MessageId.earliest);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 597, "output": 1060, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31353, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778167020883, "responseId": "resp_03e514c408199c990169fcacedd99c819f951f1f20921349be"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_BUy8VTQ4K4CUS6gOpjz2eWR8|fc_03e514c408199c990169fcacf8796c819fb5eb2fa875cfca79", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1518 bytes to tests/src/org.apache.pulsar/pulsar-client-admin-api/4.2.1/src/test/java/org_apache_pulsar/pulsar_client_admin_api/DefaultImplementationTest.java"}], "isError": false, "timestamp": 1778167033982}]}
