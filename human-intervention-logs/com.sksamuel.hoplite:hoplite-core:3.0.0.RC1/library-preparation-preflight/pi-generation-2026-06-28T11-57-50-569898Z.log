      is Element -> when {
        value != null && values.isEmpty() -> value?.transform(path, sourceKey) ?: Undefined
        else -> MapNode(
          map = values.takeUnless { it.isEmpty() }?.mapValues { it.value.transform(path.with(it.key), sourceKey) }.orEmpty(),
