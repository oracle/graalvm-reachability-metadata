onfigLoaderBuilder.default()\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/resolver/context/ContextResolver.kt:23: * For example, the [EnvVarContextResolver] will replace ${{ env:name }} with the env variable `name`,\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/resolver/context/ContextResolver.kt:24: * and the [SystemPropertyContextResolver] will replace ${{ sysprop:name }} with the system property `name`.\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/PrefixTest.kt:13:      val config = ConfigLoaderBuilder.default()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/PrefixTest.kt:40:      val config = ConfigLoaderBuilder.default()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/PrefixTest.kt:60:      val config = ConfigLoaderBuilder.default()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/PrefixTest.kt:85:      val config = ConfigLoaderBuilder.default()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/PrefixTest.kt:112:        val config = ConfigLoaderBuilder.default()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/PrefixTest.kt:140:        val config = ConfigLoaderBuilder.defaultWithoutPropertySources()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/PrefixTest.kt:153:      val config = ConfigLoaderBuilder.defaultWithoutPropertySources()\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/decoder/DataClassDecoder.kt:90:        // use parameter mappers to retrieve alternative names, then try each one in turn\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/decoder/DataClassDecoder.kt:105:        // every alternative name is marked as used so strict can detect that overrides were 'used' too.\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/resolver/Resolver.kt:13: * or apply environmental variable overrides (see [EnvVarContextResolver]), or it may resolve secrets by looking\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/DecoderContext.kt:34:  val environment: Environment? = null,\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/resolver/context/EnvVarContextResolver.kt:10: * Replaces strings of the form ${{ env:name }} by looking up the name as an environment variable.\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/resolver/context/EnvVarContextResolver.kt:13:object EnvVarContextResolver : ContextResolver() {\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/preprocessor/PropsPreprocessorTest.kt:16:      val config = ConfigLoaderBuilder.default()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/preprocessor/PropsPreprocessorTest.kt:31:        val config = ConfigLoaderBuilder.default()\nhoplite-core/src/test/kotlin/com/sksamuel/hoplite/preprocessor/IterationsTest.kt:32:      val config = ConfigLoaderBuilder.default()\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:11:import com.sksamuel.hoplite.preprocessor.EnvOrSystemPropertyPreprocessor\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:19:import com.sksamuel.hoplite.resolver.context.EnvVarContextResolver\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:25:import com.sksamuel.hoplite.resolver.context.SystemPropertyContextResolver\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:68:  private var environment: Environment? = null\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:167:   * Sets the current environment, eg prod or dev.\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:169:  fun withEnvironment(environment: Environment) = apply { this.environment = environment }\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:435:      environment = environment,\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:459:  EnvOrSystemPropertyPreprocessor,\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:469:  EnvVarContextResolver,\nhoplite-core/src/main/kotlin/com/sksamuel/hoplite/ConfigLoaderBuilder.kt:470:  SystemProperty