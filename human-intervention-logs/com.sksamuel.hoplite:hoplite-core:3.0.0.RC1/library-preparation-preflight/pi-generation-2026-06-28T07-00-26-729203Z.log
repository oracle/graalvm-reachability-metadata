e\nimport com.sksamuel.hoplite.parsers.PropsPropertySource\nimport io.kotest.assertions.throwables.shouldThrowAny\nimport io.kotest.core.extensions.install\nimport io.kotest.core.spec.style.FunSpec\nimport io.kotest.extensions.testcontainers.JdbcTestContainerExtension\nimport io.kotest.matchers.shouldBe\nimport io.kotest.matchers.string.shouldInclude\nimport org.testcontainers.containers.PostgreSQLContainer\nimport java.util.Properties\n\n@OptIn(ExperimentalHoplite::class)\nclass JdbcHostnameValidatorTest : FunSpec({\n\n  install(JdbcTestContainerExtension(postgreSQLContainer))\n  data class Config(val url: String)\n\n  test(\"jdbc validation for valid host\") {\n\n    val props = Properties()\n    props[\"url\"] = postgreSQLContainer.jdbcUrl\n\n    val config = ConfigLoaderBuilder.newBuilder()\n      .addPropertySource(PropsPropertySource(props))\n      .addResolver(JdbcHostnameValidator())\n      .build()\n      .loadConfigOrThrow<Config>()\n\n    config.url shouldBe postgreSQLContainer.jdbcUrl\n  }\n\n  test(\"jdbc validation for invalid host\") {\n\n    val props = Properties()\n    props[\"url\"] = \"jdbc:postgres://invalidhostname\"\n\n    shouldThrowAny {\n      ConfigLoaderBuilder.newBuilder()\n        .addPropertySource(PropsPropertySource(props))\n        .addResolver(JdbcHostnameValidator())\n        .build()\n        .loadConfigOrThrow<Config>()\n    }.message shouldInclude \"JDBC hostname `invalidhostname` not reachable at (props)\"\n  }\n})\n\nval postgreSQLContainer = PostgreSQLContainer<Nothing>(\"postgres:13.7\").apply {\n  withUsername(\"postgres\")\n  withPassword(\"letmein\")\n  startupAttempts = 1\n  withUrlParam(\"connectionTimeZone\", \"Z\")\n  withUrlParam(\"zeroDateTimeBehavior\", \"convertToNull\")\n}\n--- Version catalog\nsettings.gradle.kts:103:         library(\"postgresql\", \"org.postgresql:postgresql:42.7.3\")\nsettings.gradle.kts:109:         val testcontainers = \"1.19.8\"\nsettings.gradle.kts:110:         library(\"testcontainers\", \"org.testcontainers:testcontainers:$testcontainers\")\nsettings.gradle.kts:111:         library(\"testcontainers-postgresql\", \"org.testcontainers:postgresql:$testcontainers\")\nsettings.gradle.kts:112:         library(\"testcontainers-mysql\", \"org.testcontainers:mysql:$testcontainers\")\nsettings.gradle.kts:113:         library(\"testcontainers-localstack\", \"org.testcontainers:localstack:$testcontainers\")\nsettings.gradle.kts:114:         library(\"testcontainers-vault\", \"org.testcontainers:vault:$testcontainers\")\nsettings.gradle.kts:116:         library(\"kotest-extensions-testcontainers\", \"io.kotest.extensions:kotest-extensions-testcontainers:2.0.2\")\n./hoplite-core/src/test/kotlin/com/sksamuel/hoplite/resolver/validator/JdbcHostnameValidatorTest.kt:9:import io.kotest.extensions.testcontainers.JdbcTestContainerExtension\n./hoplite-core/src/test/kotlin/com/sksamuel/hoplite/resolver/validator/JdbcHostnameValidatorTest.kt:12:import org.testcontainers.containers.PostgreSQLContainer\n./hoplite-core/src/test/kotlin/com/sksamuel/hoplite/resolver/validator/HostnameValidatorTest.kt:9:import io.kotest.extensions.testcontainers.JdbcTestContainerExtension\n./hoplite-core/build.gradle.kts:3:   testImplementation(libs.postgresql)\n./hoplite-core/build.gradle.kts:6:   testImplementation(libs.kotest.extensions.testcontainers)\n./hoplite-core/build.gradle.kts:7:   testImplementation(libs.testcontainers)\n./hoplite-core/build.gradle.kts:8:   testImplementation(libs.testcontainers.postgresql)\n./hoplite-aws/src/test/kotlin/com/sksamuel/hoplite/aws/AwsSecretsManagerContextResolverTest.kt:17:import io.kotest.extensions.testcontainers.ContainerExtension\n./hoplite-aws/src/test/kotlin/com/sksamuel/hoplite/aws/AwsSecretsManagerContextResolverTest.kt:22:import org.testcontainers.containers.localstack.LocalStackContainer\n./hoplite-aws/src/test/kotlin/com/sksamuel/hoplite/aws/AwsSecretsManagerContextResolverTest.kt:23:import org.testcontainers.utility.DockerImageName\n./ho