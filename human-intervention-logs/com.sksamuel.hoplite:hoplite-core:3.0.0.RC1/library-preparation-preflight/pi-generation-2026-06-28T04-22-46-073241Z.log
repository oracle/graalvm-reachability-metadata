    fun addFileExtensionMappings(map: Map<String, Parser>): ConfigLoaderBuilder = apply {
      map.forEach {
        val (ext, parser) = it
        this.parsers[ext] = parser
      }
    }
  
    fun addDefaultParsers() = apply {
      ServiceLoader.load(Parser::class.java, classLoader).toList().forEach { parser ->
