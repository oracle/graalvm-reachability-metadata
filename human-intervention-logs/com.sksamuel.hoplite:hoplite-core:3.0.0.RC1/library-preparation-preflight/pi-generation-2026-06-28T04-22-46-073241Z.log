    fun addOnFailureCallback(f: (Throwable) -> Unit): ConfigLoaderBuilder = apply {
      this.failureCallbacks.add(f)
    }
  
    @ExperimentalHoplite
    fun flattenArraysToString(): ConfigLoaderBuilder = apply { this.flattenArraysToString = true }
  
