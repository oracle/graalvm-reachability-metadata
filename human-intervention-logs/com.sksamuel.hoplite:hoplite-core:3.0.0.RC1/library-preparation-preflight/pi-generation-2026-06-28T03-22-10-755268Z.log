ample to avoid certain decoders or sources, then\n    94\t     * use [empty] to obtain an empty ConfigLoaderBuilder and call the various addDefault methods manually.\n    95\t     */\n    96\t    fun defaultWithoutPropertySources(configure: ConfigLoaderBuilder.() -> Unit = { }): ConfigLoaderBuilder {\n    97\t      return empty()\n    98\t        .addDefaultDecoders()\n    99\t        .addDefaultPreprocessors()\n   100\t        .addDefaultNodeTransformers()\n   101\t        .addDefaultParamMappers()\n   102\t        .addDefaultParsers()\n   103\t        .apply(configure)\n   104\t    }\n   105\t\n   106\t    /**\n   107\t     * Returns a [ConfigLoaderBuilder] with all defaults applied, using resolvers in place of preprocessors.\n   108\t     *\n   109\t     * This means that the default [Decoder]s, [Resolver]s, [NodeTransformer]s, [ParameterMapper]s, [PropertySource]s,\n   110\t     * and [Parser]s are all registered.\n   111\t     *\n   112\t     * If you wish to avoid adding defaults, for example to avoid certain decoders or sources, then\n   113\t     * use [empty] to obtain an empty ConfigLoaderBuilder and call the various addDefault methods manually.\n   114\t     *\n   115\t     * Note: This new builder is experimental and may require breaking changes to your config files.\n   116\t     * This builder will become the default in 3.0\n   117\t     */\n   118\t    @ExperimentalHoplite\n   119\t    fun newBuilder(): ConfigLoaderBuilder {\n   120\t      return newBuilderWithoutPropertySources().addDefaultPropertySources()\n   121\t    }\n   122\t\n   123\t    /**\n   124\t     * Returns a [ConfigLoaderBuilder] with all defaults applied, using resolvers in place of preprocessors,\n   125\t     * but without any [PropertySource]s.\n   126\t     *\n   127\t     * This means that the default [Decoder]s, [Resolver]s, [NodeTransformer]s, [ParameterMapper]s,\n   128\t     * and [Parser]s are all registered.\n   129\t     *\n   130\t     * If you wish to avoid adding defaults, for example to avoid certain decoders or sources, then\n   131\t     * use [empty] to obtain an empty ConfigLoaderBuilder and call the various addDefault methods manually.\n   132\t     *\n   133\t     * Note: This new builder is experimental and may require breaking changes to your config files.\n   134\t     * This builder will become the default in 3.0\n   135\t     */\n   136\t    @ExperimentalHoplite\n   137\t    fun newBuilderWithoutPropertySources(): ConfigLoaderBuilder {\n   138\t      return empty()\n   139\t        .addDefaultDecoders()\n   140\t        .addDefaultResolvers()\n   141\t        .addDefaultNodeTransformers()\n   142\t        .addDefaultParamMappers()\n   143\t        .addDefaultParsers()\n   144\t    }\n   145\t\n   146\t    /**\n   147\t     * Returns a [ConfigLoaderBuilder] with no defaults applied.\n   148\t     */\n   149\t    fun empty(): ConfigLoaderBuilder = ConfigLoaderBuilder()\n   150\t\n   151\t    /**\n   152\t     * Returns a [ConfigLoaderBuilder] with no defaults applied and the given [configure]\n   153\t     * function applied to the builder.\n   154\t     */\n   155\t    fun empty(configure: ConfigLoaderBuilder.() -> Unit): ConfigLoaderBuilder {\n   180\t\n   181\t\n   182\t  fun addParameterMapper(paramMapper: ParameterMapper) = addParameterMappers(listOf(paramMapper))\n   183\t  fun addParameterMappers(paramMappers: Iterable<ParameterMapper>): ConfigLoaderBuilder = apply {\n   184\t    this.paramMappers.addAll(paramMappers)\n   185\t  }\n   186\t\n   187\t  fun addDefaultParamMappers() = apply {\n   188\t    this.paramMappers.addAll(defaultParamMappers())\n   189\t  }\n   190\t\n   191\t  fun addDecoder(decoder: Decoder<*>) = addDecoders(listOf(decoder))\n   192\t  fun addDecoders(decoders: Iterable<Decoder<*>>) = apply {\n   193\t    this.decoders.addAll(decoders)\n   194\t  }\n   195\t\n   196\t  /**\n   197\t   * Adds all default [Decoder]s into this builder.\n   198\t   * The decoders are located via java's [ServiceLocator] framework.\n   199\t   */\n   200\t  fun addDefaultDecoders() = addDecoders(ServiceLoader.load(Decoder::class.java, classLoader))\n   201\t\n   202\t  /**\n   203\t   * Adds the default [Resolver]s to the end of the resolvers list.\n   204\t   * Adding a resolver removes all preprocessors as the two do not work together.\n   205\t   */\n   206\t  fun addDefaultResolvers() = addResolvers(defaultResolvers())\n   207\t\n   208\t  /**\n   209\t   * Adds the given [Resolver] to the end of the resolvers list.\n   210\t   * Adding a resolver removes all preprocessors as the two do not work together.\n   211\t   */\n   212\t  fun addResolver(resolver: Resolver) = addResolvers(setOf(resolver))\n   213\t\n   214\t  /**\n   215\t   * Adds the given [Resolver]s to the end of the resolvers list.\n   216\t   */\n   217\t  fun addResolvers(resolvers: Iterable<Resolver>): ConfigLoaderBuilder = apply {\n   218\t    require(preprocessors.isEmpty()) {\n   219\t      \"Preprocessors cannot be used alongside resolvers. \" +\n   220\t        \"Call removePreprocessors() before adding any resolver or create a ConfigLoaderBuilder using newBuilder() instead of default(). \" +\n   221\t        \"Preprocessors will be removed in Hoplite 3.0\"\n   222\t    }\n   223\t    this.resolvers.addAll(resolvers)\n   224\t  }\n   225\t\n   226\t  fun removePreprocessors() = apply {\n   227\t    preprocessors.clear()\n   228\t  }\n   229\t\n   230\t  /**\n   440\t      contextResolverMode = contextResolverMode,\n   441\t    )\n   442\t  }\n   443\t}\n   444\t\n   445\tfun defaultPropertySources(): List<PropertySource> = listOfNotNull(\n   446\t  EnvironmentVariablesPropertySource(),\n   447\t  SystemPropertiesPropertySource,\n   448\t  UserSettingsPropertySource,\n   449\t  XdgConfigPropertySource,\n   450\t)\n   451\t\n   452\tfun emptyByDefaultPropertySources(): List<PropertySource> = listOfNotNull(\n   453\t  SystemPropertiesPropertySource,\n   454\t  UserSettingsPropertySource,\n   455\t  XdgConfigPropertySource,\n   456\t)\n   457\t\n   458\tfun defaultPreprocessors(): List<Preprocessor> = listOf(\n   459\t  EnvOrSystemPropertyPreprocessor,\n   460\t  RandomPreprocessor,\n   461\t  LookupPreprocessor,\n   462\t)\n   463\t\n   464\tfun defaultNodeTransformers(): List<NodeTransformer> = listOf(\n   465\t  PathNormalizer,\n   466\t)\n   467\t\n   468\tfun defaultResolvers(): List<Resolver> = listOf(\n   469\t  EnvVarContextResolver,\n   470\t  SystemPropertyContextResolver,\n   471\t  ReferenceContextResolver,\n   472\t  HopliteContextResolver,\n   473\t  SystemContextResolver,\n   474\t  ManifestContextResolver,\n   475\t  RandomContextResolver,\n   476\t)\n   477\t\n   478\tfun defaultParamMappers(): List<ParameterMapper> = listOf(\n   479\t  DefaultParamMapper,\n   480\t  LowercaseParamMapper,\n   481\t  AliasAnnotationParamMapper,\n   482\t)\n   483\t\n   484\tval defaultDecoders = listOf(\n   485\t  com.sksamuel.hoplite.decoder.UUIDDecoder(),\n     1\tpackage com.sksamuel.hoplite.sources\n     2\t\n     3\timport com.sksamuel.hoplite.ConfigResult\n     4\timport com.sksamuel.hoplite.Node\n     5\timport com.sksamuel.hoplite.PropertySource\n     6\timport com.sksamuel.hoplite.PropertySourceContext\n     7\timport com.sksamuel.hoplite.Undefined\n     8\timport com.sksamuel.hoplite.fp.valid\n     9\timport java.nio.file.Path\n    10\timport java.nio.file.Paths\n    11\timport kotlin.io.path.exists\n    12\timport kotlin.io.path.inputStream\n    13\t\n    14\t/**\n    15\t * An implementation of [PropertySource] that provides config through a config file\n    16\t * defined at ~/.userconfig.ext\n    17\t *\n    18\t * This file must use either the java properties format, or another format that you\n    19\t * have included the correct module for.\n    20\t *\n    21\t * Eg, if you have included hoplite-yaml module in your build, then your file can be\n    22\t * ~/.userconfig.yaml\n    23\t */\n    24\tobject UserSettingsPropertySource : PropertySource {\n    25\t\n    26\t  override fun source(): String = System.getProperty(\"user.home\") + \"/.userconfig.<ext>\"\n    27\t\n    28\t  private fun path(ext: String): Path = Paths.get(System.getProperty(\"user.home\")).resolve(\".userconfig.$ext\")\n    29\t\n    30\t  override fun node(context: PropertySourceContext): ConfigResult<Node> {\n    31\t    val ext = context.parsers.registeredExtensions().firstOrNull {\n    32\t      path(it).exists()\n    33\t    }\n    34\t    return if (ext == null) Undefined.valid() else {\n    35\t      val path = path(ext)\n    36\t      val input = path.inputStream()\n    37\t      context.parsers.locate(ext).map {\n    38\t        it.load(input, path.toString())\n    39\t      }\n    40\t    }\n    41\t  }\n    42\t}\n     1\tpackage com.sksamuel.hoplite.sources\n     2\t\n     3\timport com.sksamuel.hoplite.ConfigResult\n     4\timport com.sksamuel.hoplite.Node\n     5\timport com.sksamuel.hoplite.PropertySource\n     6\timport com.sksamuel.hoplite.PropertySourceContext\n     7\timport com.sksamuel.hoplite.Undefined\n     8\timport com.sksamuel.hoplite.fp.valid\n     9\timport java.nio.file.Path\n    10\timport java.nio.file.Paths\n    11\timport kotlin.io.path.exists\n    12\timport kotlin.io.path.extension\n    13\timport kotlin.io.path.inputStream\n    14\t\n    15\t/**\n    16\t * An implementation of [PropertySource] that provides config through a config file\n    17\t * defined at $XDG_CONFIG_HOME/.userconfig.ext\n    18\t *\n    19\t * This file must use either the java properties format, or another format that you\n    20\t * have included the correct module for.\n    21\t *\n    22\t * Eg, if you have included hoplite-yaml module in your build, then your file can be\n    23\t * $XDG_CONFIG_HOME/.userconfig.yaml\n    24\t */\n    25\tobject XdgConfigPropertySource : PropertySource {\n    26\t\n    27\t  override fun source(): String = \"\\$XDG_CONFIG_HOME/hoplite.<ext>\"\n    28\t\n    29\t  private fun path(ext: String): Path? {\n    30\t    val xdg = System.getenv(\"XDG_CONFIG_HOME\")\n    31\t    return if (xdg.isNullOrBlank()) null else Paths.get(xdg).resolve(\"hoplite.$ext\")\n    32\t  }\n    33\t\n    34\t  override fun node(context: PropertySourceContext): ConfigResult<Node> {\n    35\t    val path = context.parsers.registeredExtensions().firstNotNullOfOrNull { ext ->\n    36\t      path(ext).takeIf { it?.exists() ?: false }\n    37\t    }\n    38\t    return if (path == null) Undefined.valid() else {\n    39\t      val input = path.inputStream()\n    40\t      context.parsers.locate(path.extension).map {\n    41\t        it.load(input, path.toString())\n    42\t      }\n    43\t    }\n    44\t  }\n    45\t}\n"}], "isError": false, "timestamp": 1782616920818}]}
