          )
        )
        .build()
        .loadConfigOrThrow<TestConfig>()
  
      config shouldBe TestConfig(listOf(
        "value_a",
        "value_A",
        "value_abc",
      ))
    }
  
    test("build env source can create intermediate lists") {
