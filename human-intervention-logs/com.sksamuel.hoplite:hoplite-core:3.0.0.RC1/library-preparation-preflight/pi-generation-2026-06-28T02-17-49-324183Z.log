              }
            )
          )
          addPropertySource(
            PropertySource.string(
              """
            a = A value
            b = 42
            """.trimIndent(), "props"
            )
          )
        }.loadConfigOrThrow<TestConfig>()
  
        config shouldBe TestConfig("Overridden by system prop", 42)
      }
  
      test("reads from real system props") {
        data class TestConfig(val a: String, val b: Int)
  
