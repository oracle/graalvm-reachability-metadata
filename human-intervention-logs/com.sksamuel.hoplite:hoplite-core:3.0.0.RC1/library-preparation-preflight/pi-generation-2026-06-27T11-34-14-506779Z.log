       */
      fun empty(configure: ConfigLoaderBuilder.() -> Unit): ConfigLoaderBuilder {
        val builder = ConfigLoaderBuilder()
        builder.configure()
        return builder
      }
    }
  
    fun withClassLoader(classLoader: ClassLoader): ConfigLoaderBuilder = apply {
      this.classLoader = classLoader
    }
  
    /**
