       */
      fun default(): ConfigLoaderBuilder {
        return defaultWithoutPropertySources()
          .addDefaultPropertySources()
      }
  
      /**
       * Returns a [ConfigLoaderBuilder] with all defaults applied, except for [PropertySource]s.
       *
