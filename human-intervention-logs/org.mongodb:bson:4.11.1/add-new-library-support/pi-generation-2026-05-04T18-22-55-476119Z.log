ngValues.class, decoded.getValues());\n        assertEquals(Arrays.asList(\"alpha\", null, \"bravo\"), decoded.getValues());\n    }\n\n    private static <T> T decode(final Class<T> type, final BsonDocument document) {\n        final PojoCodecProvider pojoCodecProvider = PojoCodecProvider.builder().register(type).build();\n        final CodecRegistry registry = fromProviders(new ValueCodecProvider(), pojoCodecProvider);\n        final Codec<T> codec = registry.get(type);\n\n        return codec.decode(new BsonDocumentReader(document), DecoderContext.builder().build());\n    }\n\n    public static final class CollectionHolder {\n        private StringValues<String> values;\n\n        public CollectionHolder() {\n        }\n\n        public StringValues<String> getValues() {\n            return values;\n        }\n\n        public void setValues(final StringValues<String> values) {\n            this.values = values;\n        }\n    }\n\n    public static final class StringValues<T> extends ArrayList<T> {\n        private static final long serialVersionUID = 1L;\n\n        public StringValues() {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1523, "output": 1625, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 22604, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777918882821, "responseId": "resp_02cb96c8b6c3378c0169f8e3a35fd8819c82381540d86499b6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Qds8z5qxvGeu5MDJmFbURrNg|fc_02cb96c8b6c3378c0169f8e3b19ce0819c878390402a1d594c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2417 bytes to tests/src/org.mongodb/bson/4.11.1/src/test/java/org_mongodb/bson/CollectionPropertyCodecProviderInnerCollectionCodecTest.java"}], "isError": false, "timestamp": 1777918901699}]}
