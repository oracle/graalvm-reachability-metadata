      public Object[] toArray() {
          Object[] retVal = new Object[size()];
          for (int i = 0; i < size(); i++) {
              retVal[i] = intToString(i);
          }
          return retVal;
      }
  
      @Override
      @SuppressWarnings("unchecked")
      public <T> T[] toArray(final T[] a) {
          T[] retVal = a.length >= size()
