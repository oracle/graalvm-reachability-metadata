turn document;\n    }\n\n    private static <T> T decode(BsonDocument document, Class<T> type) {\n        Codec<T> codec = CODEC_REGISTRY.get(type);\n        return codec.decode(new BsonDocumentReader(document), DecoderContext.builder().build());\n    }\n\n    public static class MapHolder {\n        private OrderedLabels<String> labels;\n\n        public MapHolder() {\n        }\n\n        public OrderedLabels<String> getLabels() {\n            return labels;\n        }\n\n        public void setLabels(OrderedLabels<String> labels) {\n            this.labels = labels;\n        }\n    }\n\n    public static class OrderedLabels<T> extends LinkedHashMap<String, T> {\n        private static final long serialVersionUID = 1L;\n    }\n}\n"}
