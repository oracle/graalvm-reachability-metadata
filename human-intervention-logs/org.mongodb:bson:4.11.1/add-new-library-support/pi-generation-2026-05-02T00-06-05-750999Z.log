          }
  
          public void setTags(final ConstructorBackedCollection<String> tags) {
              this.tags = tags;
          }
      }
  
      public static final class ConstructorBackedCollection<T> extends ArrayList<T> {
          public ConstructorBackedCollection() {
          }
      }
  }
