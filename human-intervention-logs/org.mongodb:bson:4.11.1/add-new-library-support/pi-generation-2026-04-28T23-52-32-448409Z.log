ocument document = new BsonDocument();\n        document.append(\"name\", new BsonString(name));\n        return document;\n    }\n\n    private static <T> BsonDocument encode(T value, Class<T> type) {\n        BsonDocument document = new BsonDocument();\n        Codec<T> codec = CODEC_REGISTRY.get(type);\n        codec.encode(new BsonDocumentWriter(document), value, EncoderContext.builder().build());\n        return document;\n    }\n\n    private static <T> T decode(BsonDocument document, Class<T> type) {\n        Codec<T> codec = CODEC_REGISTRY.get(type);\n        return codec.decode(new BsonDocumentReader(document), DecoderContext.builder().build());\n    }\n\n    public static class GetterBackedPojo {\n        private String name;\n\n        public GetterBackedPojo() {\n        }\n\n        public GetterBackedPojo(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n    }\n\n    public static class PublicFieldBackedPojo {\n        public String name;\n    }\n}\n"}], "isError": false, "timestamp": 1777420285709}, {"role": "toolResult", "toolCallId": "call_PcRvvTPi6xxFcIpYfmO9svQy|fc_0f1c1ef9a6fce2de0169f147fd77c0819189fdd470c20ebef4", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"rules\": [\n    {\n      \"excludeClasses\": \"**\"\n    },\n    {\n      \"includeClasses\": \"org.bson.**\"\n    }\n  ]\n}\n"}], "isError": false, "timestamp": 1777420285710}]}
