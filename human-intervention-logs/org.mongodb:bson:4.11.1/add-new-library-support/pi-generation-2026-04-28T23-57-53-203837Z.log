n        assertThat(decoded.getValues()).isInstanceOf(OrderedValues.class);\n        assertThat(decoded.getValues()).containsExactly(\"alpha\", null, \"omega\");\n    }\n\n    private static BsonDocument documentWithValues() {\n        BsonArray values = new BsonArray();\n        values.add(new BsonString(\"alpha\"));\n        values.add(BsonNull.VALUE);\n        values.add(new BsonString(\"omega\"));\n\n        BsonDocument document = new BsonDocument();\n        document.append(\"values\", values);\n        return document;\n    }\n\n    private static <T> T decode(BsonDocument document, Class<T> type) {\n        Codec<T> codec = CODEC_REGISTRY.get(type);\n        return codec.decode(new BsonDocumentReader(document), DecoderContext.builder().build());\n    }\n\n    public static class CollectionHolder {\n        private OrderedValues<String> values;\n\n        public CollectionHolder() {\n        }\n\n        public OrderedValues<String> getValues() {\n            return values;\n        }\n\n        public void setValues(OrderedValues<String> values) {\n            this.values = values;\n        }\n    }\n\n    public static class OrderedValues<T> extends ArrayList<T> {\n        private static final long serialVersionUID = 1L;\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.mongodb/bson/4.11.1/src/test/java/org_mongodb/bson/CollectionPropertyCodecProviderInnerCollectionCodecTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_mongodb.bson;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.bson.codecs.configuration.CodecRegistries.fromProviders;\\nimport static org.bson.codecs.configuration.CodecRegistries.fromRegistries;\\n\\nimport java.util.ArrayList;\\n\\nimport org.bson.BsonArray;\\nimport org.bson.BsonDocument;\\nimport 