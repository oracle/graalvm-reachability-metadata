      @SuppressWarnings("unchecked")
      private <T> void processCreatorAnnotation(final ClassModelBuilder<T> classModelBuilder) {
          Class<T> clazz = classModelBuilder.getType();
          CreatorExecutable<T> creatorExecutable = null;
