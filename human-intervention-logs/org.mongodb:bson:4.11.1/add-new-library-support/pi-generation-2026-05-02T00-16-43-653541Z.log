ublicdomain/zero/1.0/>.\n */\npackage org_mongodb.bson;\n\nimport org.bson.codecs.pojo.ClassModel;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.List;\nimport java.util.stream.Collectors;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PropertyReflectionUtilsTest {\n    @Test\n    void classModelDiscoversPojoPropertiesFromDeclaredMethods() {\n        final ClassModel<MethodBackedPojo> classModel = ClassModel.builder(MethodBackedPojo.class).build();\n\n        final List<String> propertyNames = classModel.getPropertyModels().stream()\n                .map(propertyModel -> propertyModel.getName())\n                .collect(Collectors.toList());\n\n        assertThat(propertyNames).contains(\"active\", \"name\");\n        assertThat(classModel.getPropertyModel(\"name\").getTypeData().getType()).isEqualTo(String.class);\n        assertThat(classModel.getPropertyModel(\"active\").getTypeData().getType()).isEqualTo(Boolean.class);\n    }\n\n    public static final class MethodBackedPojo {\n        private String name;\n        private boolean active;\n\n        public MethodBackedPojo() {\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(final String name) {\n            this.name = name;\n        }\n\n        public boolean isActive() {\n            return active;\n        }\n\n        public void setActive(final boolean active) {\n            this.active = active;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1353, "output": 961, "cacheRead": 16384, "cacheWrite": 0, "totalTokens": 18698, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777680931645, "responseId": "resp_06ac0d4453f570b60169f542241a0881a2a6ba9e2a2c7bd686"}}
