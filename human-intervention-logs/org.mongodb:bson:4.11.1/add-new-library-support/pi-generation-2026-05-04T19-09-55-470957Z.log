  package org_mongodb.bson;
  
  import org.bson.codecs.pojo.ClassModel;
  import org.bson.codecs.pojo.PropertyModel;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PropertyReflectionUtilsTest {
      @Test
      void classModelDiscoversPropertiesFromDeclaredMethods() {
          final ClassModel<DiscriminatorLookupTest.Animal> classModel = ClassModel
                  .builder(DiscriminatorLookupTest.Animal.class)
                  .build();
  
          final PropertyModel<?> propertyModel = classModel.getPropertyModel("name");
  
          assertThat(classModel.getType()).isEqualTo(DiscriminatorLookupTest.Animal.class);
          assertThat(propertyModel).isNotNull();
          assertThat(propertyModel.getName()).isEqualTo("name");
          assertThat(propertyModel.getReadName()).isEqualTo("name");
          assertThat(propertyModel.getWriteName()).isEqualTo("name");
          assertThat(propertyModel.isReadable()).isTrue();
          assertThat(propertyModel.isWritable()).isTrue();
      }
  }
