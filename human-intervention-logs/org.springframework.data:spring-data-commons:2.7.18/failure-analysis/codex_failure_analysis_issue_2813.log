ayNode movedEntries = objectMapper.createArrayNode();\\n        for (JsonNode entry : sourceEntries) {\\n            if (isTestOnlyEntry(entry, testPackages)) {\\n                movedEntries.add(entry.deepCopy());\\n            } else {\\n                keptEntries.add(entry);\\n            }\\n        }\\n\\n        applySplitResult(source, moved, fieldName, keptEntries, movedEntries);\\n    }\\n\\n    private boolean isTestOnlyEntry(JsonNode entry, Set<String> testPackages) {\\n        if (entry == null || !entry.isObject()) {\\n            return false;\\n        }\\n        if (typeReferencesTestPackage(entry.get(\\\"type\\\"), testPackages)) {\\n            return true;\\n        }\\n        JsonNode condition = entry.get(\\\"condition\\\");\\n        if (condition != null && condition.isObject()) {\\n            JsonNode typeReached = condition.get(\\\"typeReached\\\");\\n            if (typeReached != null && typeReached.isTextual()\\n                    && referencesAnyTestPackage(typeReached.asText(), testPackages)) {\\n                return true;\\n            }\\n        }\\n        return false;\\n    }\\n\\n    private boolean typeReferencesTestPackage(JsonNode typeNode, Set<String> testPackages) {\\n        if (typeNode == null) {\\n            return false;\\n        }\\n        if (typeNode.isTextual()) {\\n            return referencesAnyTestPackage(typeNode.asText(), testPackages);\\n        }\\n        if (typeNode.isObject()) {\\n            JsonNode proxyNode = typeNode.get(\\\"proxy\\\");\\n            if (!(proxyNode instanceof ArrayNode proxyArray) || proxyArray.isEmpty()) {\\n                return false;\\n            }\\n            boolean any = false;\\n            for (JsonNode proxyType : proxyArray) {\\n                if (!proxyType.isTextual()) {\\n                    return false;\\n                }\\n                if (referencesAnyTestPackage(proxyType.asText(), testPackages)) {\\n                    any = true;\\n                }\\n            }\\n            return any;\\n        }\\n        return false;\\n    }\\n\\n    private boolean referencesAnyTestPackage(String value, Set<String> testPackages) {\\n        return testPackages.stream().anyMatch(testPackage -> referencesTestPackage(value, testPackage));\\n    }\\n\\n    private void splitResources(ObjectNode source, ObjectNode moved, Set<String> testPackages, Set<String> testResources) {\\n        JsonNode field = source.get(\\\"resources\\\");\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nhuman-intervention-logs/org.springframework.data:spring-data-commons:2.7.18/metadata-fix/codex.log:80:{\"type\":\"item.started\",\"item\":{\"id\":\"item_44\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"find tests/src -path '*/src/test/resources/META-INF/native-image/reachability-metadata.json' | head -n 40\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\nhuman-intervention-logs/org.springframework.data:spring-data-commons:2.7.18/metadata-fix/codex.log:81:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_44\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"find tests/src -path '*/src/test/resources/META-INF/native-image/reachability-metadata.json' | head -n 40\\\"\",\"aggregated_output\":\"tests/src/org.eclipse.jetty/jetty-servlet/9.4.0.M0/src/test/resources/META-INF/native-image/reachability-metadata.json\\ntests/src/org.eclipse.jetty/jetty-servlet/9.3.19.v20170502/src/test/resources/META-INF/native-image/reachability-metadata.json\\ntests/src/org.eclipse.jetty/jetty-session/12.0.10/src/test/resources/META-INF/native-image/reachability-metadata.json\\ntests/src/org.eclipse.jetty/jetty-util-ajax/9.4.38.v20210224/src/test/resources/META-INF/native-image/reachability-metadata.json\\ntests/src/org.eclipse.jetty/jetty-util-ajax/10.0.0/src/test/resources/META-INF/native-image/reachability-metadata.json\\ntests/src/org.scalatest/scalatest-matchers-core_2.13/3.2.19/src/t