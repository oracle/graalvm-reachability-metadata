  	public static boolean canInvoke(Method declaredMethod, Method baseClassMethod) {
  		return RepositoryFragmentMethodInvoker.CoroutineAdapterInformation.create(declaredMethod, baseClassMethod)
  				.canInvoke();
  	}
  
  	/**
