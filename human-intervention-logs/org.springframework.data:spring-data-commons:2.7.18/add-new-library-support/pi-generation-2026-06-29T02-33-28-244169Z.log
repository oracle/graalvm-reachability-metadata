  		return new RepositoryMethodInvocation(captured.getRepositoryInterface(), method, captured.getCapturedResult(),
  				captured.getDuration());
  	}
  
  	interface Invokable {
  
  		@Nullable
  		Object invoke(Object[] args) throws ReflectiveOperationException;
  	}
  
