[tool-call] delta {"path":"tests/src/org.springframework.data/spring-data-commons/2.7.18/src/test/java/org_springframework_data/spring_data_commons/RepositoryMethodInvokerInnerRepositoryFragmentMethodInvokerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_data.spring_data_commons;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\n\nimport kotlin.coroutines.Continuation;\nimport kotlin.coroutines.CoroutineContext;\nimport kotlin.coroutines.EmptyCoroutineContext;\nimport kotlin.coroutines.intrinsics.IntrinsicsKt;\nimport org.junit.jupiter.api.Test;\nimport org.springframework.data.repository.core.support.RepositoryComposition;\nimport org.springframework.data.repository.core.support.RepositoryComposition.RepositoryFragments;\nimport org.springframework.data.repository.kotlin.CoroutineCrudRepository;\nimport reactor.core.publisher.Mono;\n\npublic class RepositoryMethodInvokerInnerRepositoryFragmentMethodInvokerTest {\n\n    @Test\n    void invokesMatchingFragmentMethod() throws Throwable {\n        RepositoryComposition composition = RepositoryComposition.just(new GreetingFragment());\n        Method repositoryMethod = GreetingOperations.class.getMethod(\"greet\", String.class);\n\n        Object result = composition.invoke(repositoryMethod, \"Ada\");\n\n        assertThat(result).isEqualTo(\"Hello Ada\");\n    }\n\n    @Test\n    void invokesReactiveFragmentMethodForKotlinCoroutineRepositoryMethod() throws Throwable {\n        RepositoryFragments fragments = RepositoryFragments.just(new ReactiveEntityFragment());\n        Method coroutineMethod = CoroutineCrudRepository.class.getMethod(\"findById\", Object.class, Continuation.class);\n        Method reactiveMethod = ReactiveEntityFragment.class.getMethod(\"findById\", Object.class);\n        CapturingContinuation continuation = new CapturingContinuation();\n\n        Object result = fragments.invoke(coroutineMethod, reactiveMethod, new Object[] { 42L, continuation });\n\n        if (result == IntrinsicsKt.getCOROUTINE_SUSPENDED()) {\n            assertThat(continuation.awaitResult()).isEqualTo(new SampleEntity(42L));\n        } else {\n            assertThat(result).isEqualTo(new SampleEntity(42L));\n        }\n    }\n\n    public interface GreetingOperations {\n\n        String greet(String name);\n    }\n\n    public static class GreetingFragment implements GreetingOperations {\n\n        @Override\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n\n    public static class ReactiveEntityFragment {\n\n        public Mono<SampleEntity> findById(Object id) {\n            return Mono.just(new SampleEntity((Long) id));\n        }\n    }\n\n    public static final class SampleEntity {\n\n        private final Long id;\n\n        private SampleEntity(Long id) {\n            this.id = id;\n        }\n\n        @Override\n        public boolean equals(Object obj) {\n            if (this == obj) {\n                return true;\n            }\n            if (!(obj instanceof SampleEntity)) {\n                return false;\n            }\n            SampleEntity that = (SampleEntity) obj;\n            return id.equals(that.id);\n        }\n\n        @Override\n        public int hashCode() {\n            return id.hashCode();\n        }\n    }\n\n    private static final class CapturingContinuation implements Continuation<Object> {\n\n        private final CountDownLatch latch = new CountDownLatch(1);\n        private volatile Object result;\n\n        @Override\n        public CoroutineContext getContext() {\n            return EmptyCoroutineContext.INSTANCE;\n        }\n\n        @Override\n        public void resumeWith(Object result) {\n            this.result = result;\n            latch.countDown();\n        }\n\n        Object awaitResult() throws InterruptedException {\n            assertThat(latch.await(10, TimeUnit.SECONDS)).isTrue();\n            return result;\n        }\n    }\n}\n"}
