[tool-call] delta {"path":"tests/src/org.springframework.data/spring-data-commons/2.7.18/src/test/java/org_springframework_data/spring_data_commons/DefaultRepositoryInformationTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_data.spring_data_commons;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\nimport java.util.Set;\nimport java.util.stream.Collectors;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.data.repository.Repository;\nimport org.springframework.data.repository.core.EntityInformation;\nimport org.springframework.data.repository.core.RepositoryInformation;\nimport org.springframework.data.repository.core.RepositoryMetadata;\nimport org.springframework.data.repository.core.support.RepositoryComposition.RepositoryFragments;\nimport org.springframework.data.repository.core.support.RepositoryFactorySupport;\n\npublic class DefaultRepositoryInformationTest {\n\n    @Test\n    void discoversQueryMethodsFromRepositoryInterface() {\n        RepositoryInformation information = new TestRepositoryFactory().getInformation(SampleRepository.class,\n                RepositoryFragments.empty());\n\n        Set<String> queryMethodNames = information.getQueryMethods().stream()\n                .map(Method::getName)\n                .collect(Collectors.toSet());\n\n        assertThat(queryMethodNames).contains(\"findByName\");\n        assertThat(queryMethodNames).doesNotContain(\"customizedName\");\n    }\n\n    @Test\n    void detectsCustomFragmentMethodsOnRepositoryInterface() {\n        RepositoryInformation information = new TestRepositoryFactory().getInformation(SampleRepository.class,\n                RepositoryFragments.just(new SampleRepositoryCustomizationImpl()));\n\n        assertThat(information.hasCustomMethod()).isTrue();\n    }\n\n    interface SampleRepository extends Repository<SampleEntity, Long>, SampleRepositoryCustomization {\n\n        SampleEntity findByName(String name);\n    }\n\n    interface SampleRepositoryCustomization {\n\n        String customizedName(Long id);\n    }\n\n    static class SampleRepositoryCustomizationImpl implements SampleRepositoryCustomization {\n\n        @Override\n        public String customizedName(Long id) {\n            return \"entity-\" + id;\n        }\n    }\n\n    static class SampleEntity {\n\n    }\n\n    static class RepositoryBase {\n\n    }\n\n    static class TestRepositoryFactory extends RepositoryFactorySupport {\n\n        RepositoryInformation getInformation(Class<?> repositoryInterface, RepositoryFragments fragments) {\n            return getRepositoryInformation(getRepositoryMetadata(repositoryInterface), fragments);\n        }\n\n        @Override\n        public <T, ID> EntityInformation<T, ID> getEntityInformation(Class<T> domainClass) {\n            throw new UnsupportedOperationException(\"Entity information is not needed by this test\");\n        }\n\n        @Override\n        protected Object getTargetRepository(RepositoryInformation metadata) {\n            throw new UnsupportedOperationException(\"Repository targets are not needed by this test\");\n        }\n\n        @Override\n        protected Class<?> getRepositoryBaseClass(RepositoryMetadata metadata) {\n            return RepositoryBase.class;\n        }\n    }\n}\n"}
