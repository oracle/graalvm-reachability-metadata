  package org_springframework_data.spring_data_commons;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.Optional;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.data.domain.PageRequest;
  import org.springframework.data.domain.Sort;
  import org.springframework.data.repository.CrudRepository;
  import org.springframework.data.util.ReflectionUtils;
  
  public class ReflectionUtilsTest {
  
      @Test
      void findsDeclaredFieldUsingDescribedFilter() {
          Field field = ReflectionUtils.findField(PageRequest.class, new ReflectionUtils.DescribedFieldFilter() {
  
              @Override
              public boolean matches(Field candidate) {
                  return "sort".equals(candidate.getName());
              }
  
              @Override
              public String getDescription() {
                  return "PageRequest sort field";
              }
          });
  
          assertThat(field).isNotNull();
          assertThat(field.getDeclaringClass()).isEqualTo(PageRequest.class);
          assertThat(field.getType()).isEqualTo(Sort.class);
      }
  
      @Test
      void findsDeclaredConstructorMatchingRuntimeArguments() {
          Optional<Constructor<?>> constructor = ReflectionUtils.findConstructor(PageRequest.class, 0, 20, Sort.unsorted());
  
          assertThat(constructor).isPresent();
          assertThat(constructor.get().getDeclaringClass()).isEqualTo(PageRequest.class);
          assertThat(constructor.get().getParameterTypes()).containsExactly(int.class, int.class, Sort.class);
      }
  
      @Test
      void findsRequiredMethodDeclaredOnInterface() {
          Method method = ReflectionUtils.findRequiredMethod(CrudRepository.class, "findById", Object.class);
  
          assertThat(method.getDeclaringClass()).isEqualTo(CrudRepository.class);
          assertThat(method.getReturnType()).isEqualTo(Optional.class);
      }
  }
