  package org_springframework_data.spring_data_commons;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.data.spel.spi.Function;
  
  public class FunctionTest {
  
      @Test
      void invokesMethodWhenArgumentCountMatches() throws Exception {
          Function function = new Function(FunctionTest.class.getMethod("bracket", String.class));
  
          Object result = function.invoke(new Object[] { "spring" });
  
          assertThat(result).isEqualTo("[spring]");
      }
  
      @Test
      void invokesVarArgsMethodByPackingArgumentsIntoTailArray() throws Exception {
          Function function = new Function(FunctionTest.class.getMethod("joinWithPrefix", String.class, String[].class));
  
          Object result = function.invoke(new Object[] { "prefix", "one", "two" });
  
          assertThat(result).isEqualTo("prefix:one,two");
      }
  
      public static String bracket(String value) {
          return "[" + value + "]";
      }
  
      public static String joinWithPrefix(String prefix, String... values) {
          return prefix + ":" + String.join(",", values);
      }
  }
