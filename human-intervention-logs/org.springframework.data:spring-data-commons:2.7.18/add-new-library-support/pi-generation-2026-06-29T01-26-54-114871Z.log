  package org_springframework_data.spring_data_commons;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.reflect.Method;
  import java.util.Arrays;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.data.projection.DefaultMethodInvokingMethodInterceptor;
  import org.springframework.data.projection.SpelAwareProxyProjectionFactory;
  
  public class DefaultMethodInvokingMethodInterceptorInnerMethodHandleLookupTest {
  
      @Test
      void invokesProjectionInterfaceDefaultMethod() {
          SpelAwareProxyProjectionFactory factory = new SpelAwareProxyProjectionFactory();
          DisplayNameProjection projection = factory.createProjection(DisplayNameProjection.class,
                  Map.of("firstName", "Ada", "lastName", "Lovelace"));
  
          assertThat(projection.getDisplayName()).isEqualTo("Ada Lovelace");
      }
  
      @Test
      void invokesStaticInterfaceMethodLookup() throws Throwable {
          Class<?> lookupType = methodHandleLookupType();
          Method getMethodHandleLookup = lookupType.getDeclaredMethod("getMethodHandleLookup");
          Method lookup = lookupType.getDeclaredMethod("lookup", Method.class);
          getMethodHandleLookup.setAccessible(true);
          lookup.setAccessible(true);
  
          Object methodHandleLookup = getMethodHandleLookup.invoke(null);
          Method staticMethod = StaticMethodProjection.class.getMethod("formatName", String.class);
  
          MethodHandle methodHandle = (MethodHandle) lookup.invoke(methodHandleLookup, staticMethod);
  
          assertThat(methodHandle.invokeWithArguments("spring")).isEqualTo("[spring]");
      }
  
      private static Class<?> methodHandleLookupType() {
          return Arrays.stream(DefaultMethodInvokingMethodInterceptor.class.getDeclaredClasses())
                  .filter(type -> type.getSimpleName().equals("MethodHandleLookup"))
                  .findFirst()
                  .orElseThrow(IllegalStateException::new);
      }
  
      interface DisplayNameProjection {
  
          String getFirstName();
  
          String getLastName();
  
          default String getDisplayName() {
              return getFirstName() + " " + getLastName();
          }
      }
  
      interface StaticMethodProjection {
  
          static String formatName(String name) {
              return "[" + name + "]";
          }
      }
  }
