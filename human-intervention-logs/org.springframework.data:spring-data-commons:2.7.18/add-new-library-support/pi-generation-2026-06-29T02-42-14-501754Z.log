  package org_springframework_data.spring_data_commons;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Method;
  import java.util.Set;
  import java.util.stream.Collectors;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.data.repository.Repository;
  import org.springframework.data.repository.core.EntityInformation;
  import org.springframework.data.repository.core.RepositoryInformation;
  import org.springframework.data.repository.core.RepositoryMetadata;
  import org.springframework.data.repository.core.support.RepositoryComposition.RepositoryFragments;
  import org.springframework.data.repository.core.support.RepositoryFactorySupport;
  
  public class DefaultRepositoryInformationTest {
  
      @Test
      void discoversQueryMethodsFromRepositoryInterface() {
          RepositoryInformation information = new TestRepositoryFactory().getInformation(SampleRepository.class,
                  RepositoryFragments.just(new SampleRepositoryCustomizationImpl()));
  
          Set<String> queryMethodNames = information.getQueryMethods().stream()
                  .map(Method::getName)
                  .collect(Collectors.toSet());
  
          assertThat(queryMethodNames).contains("findByName");
          assertThat(queryMethodNames).doesNotContain("customizedName");
      }
  
      @Test
      void detectsCustomFragmentMethodsOnRepositoryInterface() {
          RepositoryInformation information = new TestRepositoryFactory().getInformation(SampleRepository.class,
                  RepositoryFragments.just(new SampleRepositoryCustomizationImpl()));
  
          assertThat(information.hasCustomMethod()).isTrue();
      }
  
      public interface SampleRepository extends Repository<SampleEntity, Long>, SampleRepositoryCustomization {
  
          SampleEntity findByName(String name);
      }
  
      public interface SampleRepositoryCustomization {
  
          String customizedName(Long id);
      }
  
      public static class SampleRepositoryCustomizationImpl implements SampleRepositoryCustomization {
  
          @Override
          public String customizedName(Long id) {
              return "entity-" + id;
          }
      }
  
      public static class SampleEntity {
  
      }
  
      public static class RepositoryBase {
  
      }
  
      public static class TestRepositoryFactory extends RepositoryFactorySupport {
  
          RepositoryInformation getInformation(Class<?> repositoryInterface, RepositoryFragments fragments) {
              return getRepositoryInformation(getRepositoryMetadata(repositoryInterface), fragments);
          }
  
          @Override
          public <T, ID> EntityInformation<T, ID> getEntityInformation(Class<T> domainClass) {
              throw new UnsupportedOperationException("Entity information is not needed by this test");
          }
  
          @Override
          protected Object getTargetRepository(RepositoryInformation metadata) {
              throw new UnsupportedOperationException("Repository targets are not needed by this test");
          }
  
          @Override
          protected Class<?> getRepositoryBaseClass(RepositoryMetadata metadata) {
              return RepositoryBase.class;
          }
      }
  }
