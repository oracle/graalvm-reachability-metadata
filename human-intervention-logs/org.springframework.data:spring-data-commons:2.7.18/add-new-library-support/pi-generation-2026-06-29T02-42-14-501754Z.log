  		if (resourceLoader == null) {
  			throw new IllegalArgumentException("Could not obtain ResourceLoader from XmlReaderContext");
  		}
  
  		return resourceLoader;
  	}
  
  	/**
  	 * Returns the {@link ClassLoader} used by the given {@link XmlReaderContext}.
  	 *
