galcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_data.spring_data_commons;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.data.projection.DefaultMethodInvokingMethodInterceptor;\n\npublic class DefaultMethodInvokingMethodInterceptorInnerMethodHandleLookupAnonymous2Test {\n\n    @Test\n    void invokesDefaultMethodThroughOpenMethodHandleLookup() throws Throwable {\n        Object openLookup = methodHandleLookupConstant(\"OPEN\");\n        Method lookup = openLookup.getClass().getDeclaredMethod(\"lookup\", Method.class);\n        lookup.setAccessible(true);\n\n        Method defaultMethod = GreetingProjection.class.getMethod(\"getGreeting\", String.class);\n        MethodHandle methodHandle = (MethodHandle) lookup.invoke(openLookup, defaultMethod);\n\n        GreetingProjection projection = () -> \"Hello\";\n\n        assertThat(methodHandle.bindTo(projection).invokeWithArguments(\"Spring Data\")).isEqualTo(\"Hello, Spring Data\");\n    }\n\n    private static Object methodHandleLookupConstant(String name) {\n        return Arrays.stream(methodHandleLookupType().getEnumConstants())\n                .map(Enum.class::cast)\n                .filter(constant -> constant.name().equals(name))\n                .findFirst()\n                .orElseThrow(IllegalStateException::new);\n    }\n\n    private static Class<?> methodHandleLookupType() {\n        return Arrays.stream(DefaultMethodInvokingMethodInterceptor.class.getDeclaredClasses())\n                .filter(type -> type.getSimpleName().equals(\"MethodHandleLookup\"))\n                .findFirst()\n                .orElseThrow(IllegalStateException::new);\n    }\n\n    interface GreetingProjection {\n\n        String getSalutation();\n\n        default String getGreeting(String subject) {\n            return getSalutation() + \", \" + subject;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 21637, "output": 1415, "cacheRead": 0, "cacheWrite": 0, "totalTokens": 23052, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782699823900, "responseId": "resp_092e08667b0a5230016a41d7305fbc81968ee18bc92ac0fd11"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_45XKo2fZhCAUAk6W7CgkDv0l|fc_092e08667b0a5230016a41d73d75d881969c99501b134ff206", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2140 bytes to tests/src/org.springframework.data/spring-data-commons/2.7.18/src/test/java/org_springframework_data/spring_data_commons/DefaultMethodInvokingMethodInterceptorInnerMethodHandleLookupAnonymous2Test.java"}], "isError": false, "timestamp": 1782699843393}]}
