[tool-call] delta {"path":"tests/src/org.springframework.data/spring-data-commons/2.7.18/src/test/java/org_springframework_data/spring_data_commons/ReflectionUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_data.spring_data_commons;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Optional;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.data.domain.PageRequest;\nimport org.springframework.data.domain.Sort;\nimport org.springframework.data.repository.CrudRepository;\nimport org.springframework.data.util.ReflectionUtils;\n\npublic class ReflectionUtilsTest {\n\n    @Test\n    void findsDeclaredFieldUsingDescribedFilter() {\n        Field field = ReflectionUtils.findField(PageRequest.class, new ReflectionUtils.DescribedFieldFilter() {\n\n            @Override\n            public boolean matches(Field candidate) {\n                return \"sort\".equals(candidate.getName());\n            }\n\n            @Override\n            public String getDescription() {\n                return \"PageRequest sort field\";\n            }\n        });\n\n        assertThat(field).isNotNull();\n        assertThat(field.getDeclaringClass()).isEqualTo(PageRequest.class);\n        assertThat(field.getType()).isEqualTo(Sort.class);\n    }\n\n    @Test\n    void findsDeclaredConstructorMatchingRuntimeArguments() {\n        Optional<Constructor<?>> constructor = ReflectionUtils.findConstructor(PageRequest.class, 0, 20, Sort.unsorted());\n\n        assertThat(constructor).isPresent();\n        assertThat(constructor.get().getDeclaringClass()).isEqualTo(PageRequest.class);\n        assertThat(constructor.get().getParameterTypes()).containsExactly(int.class, int.class, Sort.class);\n    }\n\n    @Test\n    void findsRequiredMethodDeclaredOnInterface() {\n        Method method = ReflectionUtils.findRequiredMethod(CrudRepository.class, \"findById\", Object.class);\n\n        assertThat(method.getDeclaringClass()).isEqualTo(CrudRepository.class);\n        assertThat(method.getReturnType()).isEqualTo(Optional.class);\n    }\n}\n"}
