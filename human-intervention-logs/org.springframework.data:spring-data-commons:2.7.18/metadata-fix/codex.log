d coroutineMethod = CoroutineCrudRepository.class.getMethod(\"findById\", Object.class, Continuation.class);\n        Method reactiveMethod = ReactiveEntityFragment.class.getMethod(\"findById\", Object.class);\n        CapturingContinuation continuation = new CapturingContinuation();\n\n        Object result = fragments.invoke(coroutineMethod, reactiveMethod, new Object[] { 42L, continuation });\n\n        if (result == IntrinsicsKt.getCOROUTINE_SUSPENDED()) {\n            assertThat(continuation.awaitResult()).isEqualTo(new SampleEntity(42L));\n        } else {\n            assertThat(result).isEqualTo(new SampleEntity(42L));\n        }\n    }\n\n    public interface GreetingOperations {\n\n        String greet(String name);\n    }\n\n    public static class GreetingFragment implements GreetingOperations {\n\n        @Override\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n\n    public static class ReactiveEntityFragment {\n\n        public Mono<SampleEntity> findById(Object id) {\n            return Mono.just(new SampleEntity((Long) id));\n        }\n    }\n\n    public static final class SampleEntity {\n\n        private final Long id;\n\n        private SampleEntity(Long id) {\n            this.id = id;\n        }\n\n        @Override\n        public boolean equals(Object obj) {\n            if (this == obj) {\n                return true;\n            }\n            if (!(obj instanceof SampleEntity)) {\n                return false;\n            }\n            SampleEntity that = (SampleEntity) obj;\n            return id.equals(that.id);\n        }\n\n        @Override\n        public int hashCode() {\n            return id.hashCode();\n        }\n    }\n\n    private static final class CapturingContinuation implements Continuation<Object> {\n\n        private final CountDownLatch latch = new CountDownLatch(1);\n        private volatile Object result;\n\n        @Override\n        public CoroutineContext getContext() {\n            return EmptyCoroutineContext.INSTANCE;\n        }\n\n        @Override\n        public void resumeWith(Object result) {\n            this.result = result;\n            latch.countDown();\n        }\n\n        Object awaitResult() throws InterruptedException {\n            assertThat(latch.await(10, TimeUnit.SECONDS)).isTrue();\n            return result;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
