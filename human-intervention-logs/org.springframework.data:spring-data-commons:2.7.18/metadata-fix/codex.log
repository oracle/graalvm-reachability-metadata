aticMethodProjection.class.getMethod(\"formatName\", String.class);\n\n        MethodHandle methodHandle = (MethodHandle) lookup.invoke(methodHandleLookup, staticMethod);\n\n        assertThat(methodHandle.invokeWithArguments(\"spring\")).isEqualTo(\"[spring]\");\n    }\n\n    private static Class<?> methodHandleLookupType() {\n        return Arrays.stream(DefaultMethodInvokingMethodInterceptor.class.getDeclaredClasses())\n                .filter(type -> type.getSimpleName().equals(\"MethodHandleLookup\"))\n                .findFirst()\n                .orElseThrow(IllegalStateException::new);\n    }\n\n    interface DisplayNameProjection {\n\n        String getFirstName();\n\n        String getLastName();\n\n        default String getDisplayName() {\n            return getFirstName() + \" \" + getLastName();\n        }\n    }\n\n    public interface StaticMethodProjection {\n\n        static String formatName(String name) {\n            return \"[\" + name + \"]\";\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
