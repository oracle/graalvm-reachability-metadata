  <body>
  <h1>testing goog.dom.query()</h1>
  <div id="t">
    <h3>h3 <span>span</span> endh3 </h3>
    <!-- comment to throw things off -->
    <div class="foo bar" id="_foo">
      <h3>h3</h3>
      <span id="foo"></span>
      <span></span>
    </div>
    <h3>h3</h3>
    <h3 class="baz" title="thud">h3</h3>
