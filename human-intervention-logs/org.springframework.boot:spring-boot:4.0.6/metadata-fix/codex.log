{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.springframework.boot/spring-boot/4.0.6/src/test/java/org_springframework_boot/spring_boot/SpringApplicationAotProcessorTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Arrays;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport org.springframework.boot.Banner.Mode;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringApplicationAotProcessor;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SpringApplicationAotProcessorTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void mainProcessesApplicationWithStringArrayMainMethod() throws Exception {\n        StringArgsAotApplication.arguments = null;\n\n        SpringApplicationAotProcessor.main(processorArguments(StringArgsAotApplication.class, \"string-args-app\",\n                \"--sample.argument=available\"));\n\n        assertThat(StringArgsAotApplication.arguments).contains(\"--sample.argument=available\");\n        Path nativeImageProperties = nativeImageProperties(\"string-args-app\");\n        assertThat(nativeImageProperties).exists();\n        assertThat(Files.readString(nativeImageProperties))\n                .contains(\"-H:Class=\" + StringArgsAotApplication.class.getName());\n    }\n\n    @Test\n    void mainProcessesApplicationWithNoArgsMainMethod() throws Exception {\n        NoArgsAotApplication.called = false;\n\n        SpringApplicationAotProcessor.main(processorArguments(NoArgsAotApplication.class, \"no-args-app\"));\n\n        assertThat(NoArgsAotApplication.called).isTrue();\n        Path nativeImageProperties = nativeImageProperties(\"no-args-app\");\n        assertThat(nativeImageProperties).exists();\n        assertThat(Files.readString(nativeImageProperties))\n                .contains(\"-H:Class=\" + NoArgsAotApplication.class.getName());\n    }\n\n    private String[] processorArguments(Class<?> application, String artifactId, String... applicationArguments)\n            throws Exception {\n\n        Path output = Files.createDirectories(this.tempDir.resolve(artifactId));\n        String[] requiredArguments = new String[] {\n                application.getName(),\n                output.resolve(\"sources\").toString(),\n                output.resolve(\"resources\").toString(),\n                output.resolve(\"classes\").toString(),\n                \"org.example\",\n                artifactId\n        };\n        String[] arguments = Arrays.copyOf(requiredArguments, requiredArguments.length + applicationArguments.length);\n        System.arraycopy(applicationArguments, 0, arguments, requiredArguments.length, applicationArguments.length);\n        return arguments;\n    }\n\n    private Path nativeImageProperties(String artifactId) {\n        return this.tempDir.resolve(artifactId)\n                .resolve(\"resources/META-INF/native-image/org.example\")\n                .resolve(artifactId)\n                .resolve(\"native-image.properties\");\n    }\n}\n\nclass StringArgsAotApplication {\n    static String[] arguments;\n\n    public static void main(String[] args) {\n        arguments = args.clone();\n        runApplication(StringArgsAotApplication.class, args);\n    }\n\n    static void runApplication(Class<?> source, String[] args) {\n        SpringApplication application = new SpringApplication(source);\n        application.setBannerMode(Mode.OFF);\n        application.setLogStartupInfo(false);\n        application.run(args);\n    }\n}\n\nclass NoArgsAotApplication {\n    static boolean cal