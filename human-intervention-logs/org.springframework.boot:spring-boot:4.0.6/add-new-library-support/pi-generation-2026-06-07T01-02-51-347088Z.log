toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.boot.ApplicationContextFactory;\nimport org.springframework.boot.Banner.Mode;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.WebApplicationType;\nimport org.springframework.context.ConfigurableApplicationContext;\nimport org.springframework.context.support.GenericApplicationContext;\nimport org.springframework.core.env.ConfigurableEnvironment;\nimport org.springframework.core.env.StandardEnvironment;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnvironmentConverterTest {\n    @Test\n    void springApplicationConvertsFactoryEnvironmentToRequestedEnvironmentType() {\n        SpringApplication application = new SpringApplication(EnvironmentConverterApplication.class);\n        application.setApplicationContextFactory(new ConvertingApplicationContextFactory());\n        application.setBannerMode(Mode.OFF);\n        application.setLogStartupInfo(false);\n        application.setDefaultProperties(Map.<String, Object>of(\"environment.converter.test\", \"copied\"));\n\n        try (ConfigurableApplicationContext context = application.run(\"--spring.profiles.active=converted\")) {\n            assertThat(context.getEnvironment()).isInstanceOf(ConvertedEnvironment.class);\n            assertThat(context.getEnvironment().getActiveProfiles()).containsExactly(\"converted\");\n            assertThat(context.getEnvironment().getProperty(\"environment.converter.test\")).isEqualTo(\"copied\");\n        }\n    }\n\n    public static class ConvertedEnvironment extends StandardEnvironment {\n    }\n\n    private static final class ConvertingApplicationContextFactory implements ApplicationContextFactory {\n        @Override\n        public Class<? extends ConfigurableEnvironment> getEnvironmentType(WebApplicationType webApplicationType) {\n            return ConvertedEnvironment.class;\n        }\n\n        @Override\n        public ConfigurableEnvironment createEnvironment(WebApplicationType webApplicationType) {\n            return new StandardEnvironment();\n        }\n\n        @Override\n        public ConfigurableApplicationContext create(WebApplicationType webApplicationType) {\n            return new GenericApplicationContext();\n        }\n    }\n}\n\nclass EnvironmentConverterApplication {\n}\n"}], "isError": false, "timestamp": 1780794081648}, {"role": "toolResult", "toolCallId": "call_OVs40Ixl70y3j6eski2OxyOm|fc_0e441c3541944f76016a24c2e16ae08195ad03d3e2127d7069", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.boot.Banner.Mode;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.context.ConfigurableApplicationContext;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClearCachesApplicationListenerTest {\n    @Test\n    void springApplicationClearsThreadContextClassLoaderCaches() {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        CacheClearingClassLoader classLoader = new CacheClearingClassLoader(originalClassLoader);\n        Thread.currentThread().setContextClassLoader(classLoader);\n        try (ConfigurableApplicationContext context = runApplication()) {\n            assertThat(context.isActive()).isTrue();\n            assertThat(classLoader.clearCacheCalled).isTrue();\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private ConfigurableApplicationContext runApplication() {\n        SpringApplication application = new SpringApplication(CacheClearingApplication.class);\n        application.setBannerMode(Mode.OFF);\n        application.setLogStartupInfo(false);\n        return application.run();\n    }\n\n    public static class CacheClearingClassLoader extends ClassLoader {\n        private boolean clearCacheCalled;\n\n        CacheClearingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public void clearCache() {\n            this.clearCacheCalled = true;\n        }\n    }\n}\n\nclass CacheClearingApplication {\n}\n"}], "isError": false, "timestamp": 1780794081649}, {"role": "toolResult", "toolCallId": "call_UpSb8OtL0BoFLJAyfzbrZGuu|fc_0e441c3541944f76016a24c2e16ae881959ea6647218f2799e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.springframework.boot:spring-boot:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780794081649}]}
