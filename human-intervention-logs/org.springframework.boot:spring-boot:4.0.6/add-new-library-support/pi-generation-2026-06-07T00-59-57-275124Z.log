  package org_springframework_boot.spring_boot;
  
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Arrays;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import org.springframework.boot.Banner.Mode;
  import org.springframework.boot.SpringApplication;
  import org.springframework.boot.SpringApplicationAotProcessor;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SpringApplicationAotProcessorTest {
      @TempDir
      Path tempDir;
  
      @Test
      void mainProcessesApplicationWithStringArrayMainMethod() throws Exception {
          StringArgsAotApplication.arguments = null;
  
          SpringApplicationAotProcessor.main(processorArguments(StringArgsAotApplication.class, "string-args-app",
                  "--sample.argument=available"));
  
          assertThat(StringArgsAotApplication.arguments).contains("--sample.argument=available");
          Path nativeImageProperties = nativeImageProperties("string-args-app");
          assertThat(nativeImageProperties).exists();
          assertThat(Files.readString(nativeImageProperties))
                  .contains("-H:Class=" + StringArgsAotApplication.class.getName());
      }
  
      @Test
      void mainProcessesApplicationWithNoArgsMainMethod() throws Exception {
          NoArgsAotApplication.called = false;
  
          SpringApplicationAotProcessor.main(processorArguments(NoArgsAotApplication.class, "no-args-app"));
  
          assertThat(NoArgsAotApplication.called).isTrue();
          Path nativeImageProperties = nativeImageProperties("no-args-app");
          assertThat(nativeImageProperties).exists();
          assertThat(Files.readString(nativeImageProperties))
                  .contains("-H:Class=" + NoArgsAotApplication.class.getName());
      }
  
      private String[] processorArguments(Class<?> application, String artifactId, String... applicationArguments)
              throws Exception {
  
          Path output = Files.createDirectories(this.tempDir.resolve(artifactId));
          String[] requiredArguments = new String[] {
                  application.getName(),
                  output.resolve("sources").toString(),
                  output.resolve("resources").toString(),
                  output.resolve("classes").toString(),
                  "org.example",
                  artifactId
          };
          String[] arguments = Arrays.copyOf(requiredArguments, requiredArguments.length + applicationArguments.length);
          System.arraycopy(applicationArguments, 0, arguments, requiredArguments.length, applicationArguments.length);
          return arguments;
      }
  
      private Path nativeImageProperties(String artifactId) {
          return this.tempDir.resolve(artifactId)
                  .resolve("resources/META-INF/native-image/org.example")
                  .resolve(artifactId)
                  .resolve("native-image.properties");
      }
  }
  
  class StringArgsAotApplication {
      static String[] arguments;
  
      public static void main(String[] args) {
          arguments = args.clone();
          runApplication(StringArgsAotApplication.class, args);
      }
  
      static void runApplication(Class<?> source, String[] args) {
          SpringApplication application = new SpringApplication(source);
          application.setBannerMode(Mode.OFF);
          application.setLogStartupInfo(false);
          application.run(args);
      }
  }
  
  class NoArgsAotApplication {
      static boolean called;
  
      public static void main() {
          called = true;
          StringArgsAotApplication.runApplication(NoArgsAotApplication.class, new String[0]);
      }
  }
