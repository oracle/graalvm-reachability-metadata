  package org_springframework_boot.spring_boot;
  
  import org.junit.jupiter.api.Test;
  
  import org.springframework.boot.Banner.Mode;
  import org.springframework.boot.SpringApplication;
  import org.springframework.context.ConfigurableApplicationContext;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClearCachesApplicationListenerTest {
      @Test
      void springApplicationClearsThreadContextClassLoaderCaches() {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          CacheClearingClassLoader classLoader = new CacheClearingClassLoader(originalClassLoader);
          Thread.currentThread().setContextClassLoader(classLoader);
          try (ConfigurableApplicationContext context = runApplication()) {
              assertThat(context.isActive()).isTrue();
              assertThat(classLoader.clearCacheCalled).isTrue();
          }
          finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      private ConfigurableApplicationContext runApplication() {
          SpringApplication application = new SpringApplication(CacheClearingApplication.class);
          application.setBannerMode(Mode.OFF);
          application.setLogStartupInfo(false);
          return application.run();
      }
  
      public static class CacheClearingClassLoader extends ClassLoader {
          private boolean clearCacheCalled;
  
          CacheClearingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          public void clearCache() {
              this.clearCacheCalled = true;
          }
      }
  }
  
  class CacheClearingApplication {
  }
