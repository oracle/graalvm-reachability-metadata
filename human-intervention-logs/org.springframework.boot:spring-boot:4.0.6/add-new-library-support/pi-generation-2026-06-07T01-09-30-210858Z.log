  	SIMPLE("^([+-]?\\d+)([a-zA-Z]{0,2})$") {
  
  		@Override
  		public Duration parse(String value, @Nullable ChronoUnit unit) {
  			try {
  				Matcher matcher = matcher(value);
  				Assert.state(matcher.matches(), "Does not match simple duration pattern");
