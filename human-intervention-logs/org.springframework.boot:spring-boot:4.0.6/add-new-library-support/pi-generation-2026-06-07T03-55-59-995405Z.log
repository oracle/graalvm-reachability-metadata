  public final class Bindable<T> {
  
  	private static final Annotation[] NO_ANNOTATIONS = {};
  
  	private static final EnumSet<BindRestriction> NO_BIND_RESTRICTIONS = EnumSet.noneOf(BindRestriction.class);
  
