pplication.withHook`, which still requires a SpringApplication.\"}]}"}, {"type": "toolCall", "id": "call_3sjQgfCo2TbkAZGJApjCWuvY|fc_02910d8b2c0c8ff6016a24bef28fc081908035adff44a0f273", "name": "write", "arguments": {"path": "tests/src/org.springframework.boot/spring-boot/4.0.6/src/test/java/org_springframework_boot/spring_boot/SpringApplicationAotProcessorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Arrays;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport org.springframework.boot.Banner.Mode;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringApplicationAotProcessor;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SpringApplicationAotProcessorTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void mainProcessesApplicationWithStringArrayMainMethod() throws Exception {\n        StringArgsAotApplication.arguments = null;\n\n        SpringApplicationAotProcessor.main(processorArguments(StringArgsAotApplication.class, \"string-args-app\",\n                \"--sample.argument=available\"));\n\n        assertThat(StringArgsAotApplication.arguments).contains(\"--sample.argument=available\");\n        assertThat(nativeImageProperties(\"string-args-app\"))\n                .exists()\n                .content()\n                .contains(\"-H:Class=\" + StringArgsAotApplication.class.getName());\n    }\n\n    @Test\n    void mainProcessesApplicationWithNoArgsMainMethod() throws Exception {\n        NoArgsAotApplication.called = false;\n\n        SpringApplicationAotProcessor.main(processorArguments(NoArgsAotApplication.class, \"no-args-app\"));\n\n        assertThat(NoArgsAotApplication.called).isTrue();\n        assertThat(nativeImageProperties(\"no-args-app\"))\n                .exists()\n                .content()\n                .contains(\"-H:Class=\" + NoArgsAotApplication.class.getName());\n    }\n\n    private String[] processorArguments(Class<?> application, String artifactId, String... applicationArguments)\n            throws Exception {\n\n        Path output = Files.createDirectories(this.tempDir.resolve(artifactId));\n        String[] requiredArguments = new String[] {\n                application.getName(),\n                output.resolve(\"sources\").toString(),\n                output.resolve(\"resources\").toString(),\n                output.resolve(\"classes\").toString(),\n                \"org.example\",\n                artifactId\n        };\n        String[] arguments = Arrays.copyOf(requiredArguments, requiredArguments.length + applicationArguments.length);\n        System.arraycopy(applicationArguments, 0, arguments, requiredArguments.length, applicationArguments.length);\n        return arguments;\n    }\n\n    private Path nativeImageProperties(String artifactId) {\n        return this.tempDir.resolve(artifactId)\n                .resolve(\"resources/META-INF/native-image/org.example\")\n                .resolve(artifactId)\n                .resolve(\"native-image.properties\");\n    }\n}\n\nclass StringArgsAotApplication {\n    static String[] arguments;\n\n    public static void main(String[] args) {\n        arguments = args.clone();\n        runApplication(StringArgsAotApplication.class, args);\n    }\n\n    static void runApplication(Class<?> source, String[] args) {\n        SpringApplication application = new SpringApplication(source);\n        application.setBannerMode(Mode.OFF);\n        application.setLogStartupInfo(false);\n        application.run(args);\n    }\n}\n\nclass NoArgsAotApplication {\n    static boolean called;\n\n    public static void main() {\n        called = true;\n        StringArgsAotApplication.runApplication(NoArgsAotApplication.class, new String[0]);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1976, "output": 2130, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 26122, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780793041427, "responseId": "resp_02910d8b2c0c8ff6016a24bed1eec481909f108c493306d5b6"}}
