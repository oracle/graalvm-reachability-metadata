4.0.6/src/test/java/org_springframework_boot/spring_boot/ClearCachesApplicationListenerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport org.junit.jupiter.api.Test;\n\nimport org.springframework.boot.Banner.Mode;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.context.ConfigurableApplicationContext;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClearCachesApplicationListenerTest {\n    @Test\n    void springApplicationClearsThreadContextClassLoaderCaches() {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        CacheClearingClassLoader classLoader = new CacheClearingClassLoader(originalClassLoader);\n        Thread.currentThread().setContextClassLoader(classLoader);\n        try (ConfigurableApplicationContext context = runApplication()) {\n            assertThat(context.isActive()).isTrue();\n            assertThat(classLoader.clearCacheCalled).isTrue();\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private ConfigurableApplicationContext runApplication() {\n        SpringApplication application = new SpringApplication(CacheClearingApplication.class);\n        application.setBannerMode(Mode.OFF);\n        application.setLogStartupInfo(false);\n        return application.run();\n    }\n\n    public static class CacheClearingClassLoader extends ClassLoader {\n        private boolean clearCacheCalled;\n\n        CacheClearingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public void clearCache() {\n            this.clearCacheCalled = true;\n        }\n    }\n}\n\nclass CacheClearingApplication {\n}\n"}}]