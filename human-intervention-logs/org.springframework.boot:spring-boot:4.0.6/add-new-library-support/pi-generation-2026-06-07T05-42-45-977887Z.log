w GenericApplicationContext()) {\n            application.loadInto(context, PACKAGE_SOURCE);\n\n            assertThat(context.containsBeanDefinition(\"beanDefinitionLoaderPackageComponent\")).isTrue();\n        }\n    }\n\n    private static final class ExposedSpringApplication extends SpringApplication {\n\n        void loadInto(GenericApplicationContext context, String source) {\n            load(context, new Object[] { source });\n        }\n\n    }\n\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 4067, "output": 1211, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 33950, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780810867729, "responseId": "resp_0c10cbc4c9e09abd016a25047436588190baa4a141cb87670a"}}
