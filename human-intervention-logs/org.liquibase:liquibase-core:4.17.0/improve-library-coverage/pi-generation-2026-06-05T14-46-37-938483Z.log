      String GENERIC_SNAPSHOT_EXTENSION_NAMESPACE = "http://www.liquibase.org/xml/ns/snapshot-ext";
  
      public enum SerializationType {
          NAMED_FIELD,
          NESTED_OBJECT,
          DIRECT_VALUE
      }
  
      String getSerializedObjectName();
  
