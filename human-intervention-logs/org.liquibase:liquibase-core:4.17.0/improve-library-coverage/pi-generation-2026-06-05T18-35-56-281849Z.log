              @Override
              public int compare(Set<DatabaseObject> o1, Set<DatabaseObject> o2) {
                  int sizeComparison = Integer.valueOf(o1.size()).compareTo(o2.size());
                  if (sizeComparison == 0) {
                      return o1.toString().compareTo(o2.toString());
                  }
                  return sizeComparison;
