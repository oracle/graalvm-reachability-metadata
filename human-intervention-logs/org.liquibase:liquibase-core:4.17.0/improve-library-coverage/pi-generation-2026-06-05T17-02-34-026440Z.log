              if (newValue.isEmpty()) {
                  //do nothing
              } else if (newValue.size() == 1) {
                  this.value = newValue.get(0);
              } else {
                  this.value = newValue;
              }
          } else if (value instanceof Map) {
              addChildren(((Map) value));
          } else {
              this.value = value;
          }
