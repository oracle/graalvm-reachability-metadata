       */
      String getDatabaseProductName();
  
      String getDatabaseProductVersion() throws DatabaseException;
  
      int getDatabaseMajorVersion() throws DatabaseException;
  
      int getDatabaseMinorVersion() throws DatabaseException;
  
  
