  --- a/tests/src/org.liquibase/liquibase-core/4.17.0/build.gradle
  +++ b/tests/src/org.liquibase/liquibase-core/4.17.0/build.gradle
  @@ -18,6 +18,44 @@ dependencies {
       testImplementation 'org.osgi:org.osgi.util.tracker:1.5.4'
   }
   
  +Provider<Directory> liquibaseHomeDir = layout.buildDirectory.dir("liquibase-home")
  +
  +TaskProvider<Task> prepareLiquibaseHome = tasks.register("prepareLiquibaseHome") { task ->
  +    task.outputs.dir(liquibaseHomeDir)
  +    task.doLast {
  +        File internalLib = liquibaseHomeDir.get().file("internal/lib").asFile
  +        File externalLib = liquibaseHomeDir.get().file("lib").asFile
  +        internalLib.mkdirs()
  +        externalLib.mkdirs()
  +
  +        File liquibaseCoreJar = configurations.testRuntimeClasspath.files.find { File file ->
  +            file.name == "liquibase-core-${libraryVersion}.jar"
  +        }
  +        if (liquibaseCoreJar == null) {
  +            throw new GradleException("Could not resolve liquibase-core test runtime JAR")
  +        }
  +        copy {
  +            from liquibaseCoreJar
  +            into internalLib
  +            rename { "liquibase-core.jar" }
  +        }
  +    }
  +}
  +
  +tasks.withType(Test).configureEach { task ->
  +    task.dependsOn(prepareLiquibaseHome)
  +    task.doFirst {
  +        task.environment("LIQUIBASE_HOME", liquibaseHomeDir.get().asFile.absolutePath)
  +    }
  +}
  +
  +tasks.withType(org.graalvm.buildtools.gradle.tasks.NativeRunTask).configureEach { task ->
  +    task.dependsOn(prepareLiquibaseHome)
  +    task.environment.put("LIQUIBASE_HOME", liquibaseHomeDir.map { Directory directory ->
  +        directory.asFile.absolutePath
  +    })
  +}
  +
   graalvmNative {
       agent {
           defaultMode = "conditional"
