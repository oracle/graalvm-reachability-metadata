          </createIndex>
      </changeSet>
  
      <changeSet id="13" author="nvoxland">
          <dropIndex indexName="idx_person_lastname" tableName="person"/>
      </changeSet>
  
      <changeSet id="14" author="nvoxland">
          <createTable tableName="liquibaseRunInfo">
