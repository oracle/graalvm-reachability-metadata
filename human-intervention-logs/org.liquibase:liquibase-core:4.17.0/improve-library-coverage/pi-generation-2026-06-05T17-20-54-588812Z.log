                          }
                      }
                  }
                  // Ensure later copies overwrite earlier ones
                  c.duplicatesStrategy = DuplicatesStrategy.INCLUDE
              }
          }
      }
  
      r.classDirectories.setFrom(files(effectiveDirs))
      r.additionalClassDirs.setFrom()
  }
  
