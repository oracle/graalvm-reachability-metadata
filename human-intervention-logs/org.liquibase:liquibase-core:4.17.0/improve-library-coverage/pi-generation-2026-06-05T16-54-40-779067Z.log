dCause(throwable, ExitPreventedException.class);\n            assertThat(exit).isNotNull();\n            assertThat(exit.status).isZero();\n        } finally {\n            System.setSecurityManager(previousSecurityManager);\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    private static <T extends Throwable> T findCause(final Throwable throwable, final Class<T> type) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (type.isInstance(current)) {\n                return type.cast(current);\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    private static final class ExitPreventingSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(final Permission permission) {\n        }\n\n        @Override\n        public void checkPermission(final Permission permission, final Object context) {\n        }\n\n        @Override\n        public void checkExit(final int status) {\n            throw new ExitPreventedException(status);\n        }\n    }\n\n    private static final class ExitPreventedException extends SecurityException {\n        private final int status;\n\n        private ExitPreventedException(final int status) {\n            super(\"Prevented System.exit(\" + status + \")\");\n            this.status = status;\n        }\n    }\n}\n"}
