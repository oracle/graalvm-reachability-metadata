              return true;
          }
          SqlStatement[] statements = generateStatements(database);
          if (statements == null) {
              return true;
          }
          for (SqlStatement statement : statements) {
              if (!SqlGeneratorFactory.getInstance().supports(statement, database)) {
                  return false;
              }
          }
          return true;
