 readMethod = getReadMethod(object, propertyName);\n    71\t        if (readMethod == null) {\n    72\t            return null;\n    73\t        }\n    74\t        return readMethod.getReturnType();\n    75\t    }\n    76\t\n    77\t    /**\n    78\t     * Examines the given object's class and returns true if reader and writer methods both exist for the\n    79\t     * given property name.\n    80\t     * @param object the object for which the class should be examined\n    81\t     * @param propertyName the property name to search\n    82\t     * @return true if both reader and writer methods exist\n    83\t     */\n    84\t    public static boolean hasProperty(Object object, String propertyName) {\n    85\t        return hasReadProperty(object, propertyName) && hasWriteProperty(object, propertyName);\n    86\t    }\n    87\t\n    88\t    /**\n    89\t     * Examines the given object's class and returns true if a reader method exists for the\n    90\t     * given property name.\n    91\t     * @param object the object for which the class should be examined\n    92\t     * @param propertyName the property name to search\n    93\t     * @return true if a reader method exists\n    94\t     */\n    95\t    public static boolean hasReadProperty(Object object, String propertyName) {\n    96\t        return getReadMethod(object, propertyName) != null;\n    97\t    }\n    98\t\n    99\t    /**\n   100\t     * Examines the given object's class and returns true if a writer method exists for the\n   101\t     * given property name.\n   102\t     * @param object the object for which the class should be examined\n   103\t     * @param propertyName the property name to search\n   104\t     * @return true if a writer method exists\n   105\t     */\n   106\t    public static boolean hasWriteProperty(Object object, String propertyName) {\n   107\t        return getWriteMethod(object, propertyName) != null;\n   108\t    }\n   109\t\n   110\t    /**\n   111\t     * Tries to guess the \"real\" data type of propertyValue by the given propertyName, then sets the\n   112\t     * selected property of the given object to that value.\n   113\t     * @param object                        the object whose property should be set\n   114\t     * @param propertyName                  name of the property to set\n   115\t     * @param propertyValue                 new value of the property, as String\n   116\t     */\n   117\t    public static void setProperty(Object object, String propertyName, String propertyValue)  {\n   118\t        Method method = getWriteMethod(object, propertyName);\n   119\t        if (method == null) {\n   120\t            throw new UnexpectedLiquibaseException (\n   121\t                String.format(\"Property [%s] was not found for object type [%s]\", propertyName,\n   122\t                    object.getClass().getName()\n   123\t                ));\n   124\t        }\n   125\t\n   126\t        Class<?> parameterType = method.getParameterTypes()[0];\n   127\t        Object finalValue = propertyValue;\n   128\t        if (parameterType.equals(Boolean.class) || parameterType.equals(boolean.class)) {\n   129\t            finalValue = Boolean.valueOf(propertyValue);\n   130\t        } else if (parameterType.equals(Integer.class)) {\n   131\t            finalValue = Integer.valueOf(propertyValue);\n   132\t        } else if (parameterType.equals(Long.class)) {\n   133\t            finalValue = Long.valueOf(propertyValue);\n   134\t        } else if (parameterType.equals(BigInteger.class)) {\n   135\t            finalValue = new BigInteger(propertyValue);\n   136\t        } else if (parameterType.equals(BigDecimal.class)) {\n   137\t            finalValue = new BigDecimal(propertyValue);\n   138\t        } else if (parameterType.equals(DatabaseFunction.class)) {\n   139\t            finalValue = new DatabaseFunction(propertyValue);\n   140\t        } else if (parameterType.equals(SequenceNextValueFunction.class)) {\n   141\t            finalValue = new SequenceNextValueFunction(propertyValue);\n   142\t        } else if (parameterType.equals(SequenceCurrentValueFunction.class)) {\n   143\t            finalValue = new SequenceCurrentValueFunction(propertyValue);\n   144\t        } else if (Enum.class.isAssignableFrom(parameterType)) {\n   145\t            finalValue = Enum.valueOf((Class<Enum>) parameterType, propertyValue);\n   146\t        }\n   147\t        try {\n   148\t            method.invoke(object, finalValue);\n   149\t        } catch (IllegalAccessException | InvocationTargetException e) {\n   150\t            throw new UnexpectedLiquibaseException(e);\n   151\t        } catch (IllegalArgumentException e) {\n   152\t            if (finalValue != null) {\n   153\t                throw new UnexpectedLiquibaseException(\"Cannot call \" + method.toString()\n   154\t                        + \" with value of type \" + finalValue.getClass().getName());\n   155\t            } else {\n   156\t                throw new UnexpectedLiquibaseException(\"Cannot call \" + method.toString() + \" with a null argument\");\n   157\t            }\n   158\t        }\n   159\t    }\n   160\t\n   161\t    /**\n   162\t     * Sets the selected property of the given object to propertyValue. A run-time exception will occur if the\n   163\t     * type of value is incompatible with the reader/writer method signatures of the given propertyName.\n   164\t     * @param object                        the object whose property should be set\n   165\t     * @param propertyName                  name of the property to set\n   166\t     * @param propertyValue                 new value of the property\n   167\t     */\n   168\t    public static void setProperty(Object object, String propertyName, Object propertyValue) {\n   169\t        Method method = getWriteMethod(object, propertyName);\n   170\t        if (method == null) {\n   171\t            throw new UnexpectedLiquibaseException (\n   172\t                String.format(\"Property [%s] was not found for object type [%s]\", propertyName,\n   173\t                    object.getClass().getName()\n   174\t                ));\n   175\t        }\n   176\t\n   177\t        try {\n   178\t            if (propertyValue == null) {\n   179\t                setProperty(object, propertyName, null);\n   180\t                return;\n"}], "isError": false, "timestamp": 1780673674876}}
