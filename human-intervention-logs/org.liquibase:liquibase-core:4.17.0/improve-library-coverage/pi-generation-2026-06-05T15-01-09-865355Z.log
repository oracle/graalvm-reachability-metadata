  public class ExampleCustomTaskChange implements CustomTaskChange, CustomTaskRollback {
  
      private String helloTo;
  
      @SuppressWarnings({"UnusedDeclaration", "FieldCanBeLocal"})
      private ResourceAccessor resourceAccessor;
  
  
