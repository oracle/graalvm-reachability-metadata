alue(\"relatedTable\");\n\n        assertInstanceOf(Table.class, clone);\n        assertNotSame(relatedTable, clone);\n        assertEquals(\"customers\", clone.getName());\n        assertEquals(\"snapshot-customers\", clone.getSnapshotId());\n    }\n}\n"}
