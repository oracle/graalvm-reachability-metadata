      private static Method[] getAccessibleMethods( Class clazz )
      {
          Method[] methods = clazz.getMethods();
  
          /*
           *  Short circuit for the (hopefully) majority of cases where the
           *  clazz is public
           */
  
          if ( Modifier.isPublic( clazz.getModifiers() ) )
          {
