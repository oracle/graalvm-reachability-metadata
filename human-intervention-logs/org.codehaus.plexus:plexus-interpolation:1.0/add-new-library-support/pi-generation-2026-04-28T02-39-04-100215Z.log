              if ( upcastCount == l )
              {
                  return upcastCount;
              }
          }
  
          /*
           *   Examine superclass
           */
  
          Class superclazz = clazz.getSuperclass();
  
          if ( superclazz != null )
          {
              upcastCount = getAccessibleMethods( superclazz, methodInfos, upcastCount );
  
              /*
               *  Short circuit if all methods were upcast
