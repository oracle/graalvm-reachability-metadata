          Class[] interfaces = clazz.getInterfaces();
  
          for ( int i = interfaces.length; i-- > 0; )
          {
              upcastCount = getAccessibleMethods( interfaces[i], methodInfos, upcastCount );
  
              /*
               *  Short circuit if all methods were upcast
               */
  
              if ( upcastCount == l )
              {
                  return upcastCount;
              }
          }
  
          return upcastCount;
      }
  
      /**
