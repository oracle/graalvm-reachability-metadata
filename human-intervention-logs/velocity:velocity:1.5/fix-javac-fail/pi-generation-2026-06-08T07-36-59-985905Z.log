c void arithmeticOperationsReturnExpectedNumberTypes() {\n        Number widenedInteger = MathUtils.add(Integer.valueOf(Integer.MAX_VALUE), Short.valueOf((short) 1));\n        Number multipliedDecimal = MathUtils.multiply(Integer.valueOf(12), BigDecimal.valueOf(2));\n        Number dividedFloat = MathUtils.divide(Integer.valueOf(10), Float.valueOf(2.5f));\n        Number moduloInteger = MathUtils.modulo(BigInteger.valueOf(10), Short.valueOf((short) 4));\n\n        assertThat(widenedInteger)\n                .isInstanceOf(Long.class)\n                .isEqualTo(Long.valueOf((long) Integer.MAX_VALUE + 1));\n        assertThat(multipliedDecimal)\n                .isInstanceOf(BigDecimal.class)\n                .isEqualByComparingTo(BigDecimal.valueOf(24));\n        assertThat(dividedFloat)\n                .isInstanceOf(Float.class)\n                .isEqualTo(Float.valueOf(4.0f));\n        assertThat(moduloInteger)\n                .isInstanceOf(BigInteger.class)\n                .isEqualTo(BigInteger.valueOf(2));\n    }\n\n    @Test\n    public void comparisonAndZeroChecksSupportTemplateNumericSemantics() {\n        assertThat(MathUtils.compare(Integer.valueOf(7), Short.valueOf((short) 7))).isZero();\n        assertThat(MathUtils.compare(Double.valueOf(7), Short.valueOf((short) 8))).isNegative();\n        assertThat(MathUtils.isZero(BigDecimal.ZERO)).isTrue();\n        assertThat(MathUtils.isZero(Float.valueOf(0.125f))).isFalse();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 5689, "output": 961, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 30714, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780904132765, "responseId": "resp_09b42acd0eeaf205016a2670c532dc8197bd265346c8fe64dd"}}
