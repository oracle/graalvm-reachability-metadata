       */
      public void log(int level, String message, Throwable t)
      {
      }
  
      /**
       * @see org.apache.velocity.runtime.log.LogChute#isLevelEnabled(int)
       */
      public boolean isLevelEnabled(int level)
      {
          return false;
      }
  
  }
