          String cacheClassName = rsvc.getString(RuntimeConstants.RESOURCE_MANAGER_CACHE_CLASS);
  
          Object cacheObject = null;
  
          if (org.apache.commons.lang.StringUtils.isNotEmpty(cacheClassName))
