acheClassHasWrongType() throws Exception {\n        final ResourceManagerImpl resourceManager = new ResourceManagerImpl();\n\n        resourceManager.initialize(new CacheFallbackRuntime());\n\n        assertThat(resourceManager.getLoaderNameForResource(\"missing.vm\")).isNull();\n    }\n\n    private static final class CacheFallbackRuntime extends RuntimeInstance {\n        private final ExtendedProperties configuration = new ExtendedProperties();\n        private final Log log = new Log();\n\n        private CacheFallbackRuntime() {\n            configuration.setProperty(RuntimeConstants.RESOURCE_LOADER, new Vector());\n        }\n\n        @Override\n        public ExtendedProperties getConfiguration() {\n            return configuration;\n        }\n\n        @Override\n        public String getString(final String key) {\n            if (RuntimeConstants.RESOURCE_MANAGER_CACHE_CLASS.equals(key)) {\n                return ResourceManagerImpl.class.getName();\n            }\n            return null;\n        }\n\n        @Override\n        public boolean getBoolean(final String key, final boolean def) {\n            return def;\n        }\n\n        @Override\n        public int getInt(final String key, final int defaultValue) {\n            return defaultValue;\n        }\n\n        @Override\n        public Log getLog() {\n            return log;\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1565, "output": 821, "cacheRead": 33792, "cacheWrite": 0, "totalTokens": 36178, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780904636340, "responseId": "resp_0f2cc38c0041f9c2016a2672bcee808197ade0f2b4faf3b17d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Fbnqv22quysihE3EBoAfd40r|fc_0f2cc38c0041f9c2016a2672c0a15881979ff9e647f92b2f7c", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 1