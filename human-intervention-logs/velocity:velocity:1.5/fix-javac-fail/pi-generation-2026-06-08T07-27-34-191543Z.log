[tool-call] delta {"path":"tests/src/velocity/velocity/1.5/src/test/java/velocity/velocity/RuntimeInstanceTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage velocity.velocity;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.StringWriter;\n\nimport org.apache.velocity.VelocityContext;\nimport org.apache.velocity.app.VelocityEngine;\nimport org.apache.velocity.app.event.ReferenceInsertionEventHandler;\nimport org.apache.velocity.runtime.RuntimeConstants;\nimport org.junit.jupiter.api.Test;\n\npublic class RuntimeInstanceTest {\n    @Test\n    public void initializesConfiguredReferenceInsertionEventHandler() throws Exception {\n        final VelocityEngine engine = new VelocityEngine();\n        engine.setProperty(\n                RuntimeConstants.RUNTIME_LOG_LOGSYSTEM_CLASS,\n                \"org.apache.velocity.runtime.log.NullLogChute\");\n        engine.setProperty(\n                RuntimeConstants.EVENTHANDLER_REFERENCEINSERTION,\n                PrefixingReferenceInsertionEventHandler.class.getName());\n        engine.init();\n\n        final VelocityContext context = new VelocityContext();\n        context.put(\"name\", \"Velocity\");\n        final StringWriter writer = new StringWriter();\n\n        engine.evaluate(context, writer, \"runtime-instance-event-handler-test\", \"$name\");\n\n        assertThat(writer.toString()).isEqualTo(\"handled-Velocity\");\n    }\n\n    public static final class PrefixingReferenceInsertionEventHandler\n            implements ReferenceInsertionEventHandler {\n        public PrefixingReferenceInsertionEventHandler() {\n        }\n\n        @Override\n        public Object referenceInsert(final String reference, final Object value) {\n            return \"handled-\" + value;\n        }\n    }\n}\n"}
