  package velocity.velocity;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import org.apache.velocity.runtime.RuntimeConstants;
  import org.apache.velocity.runtime.RuntimeInstance;
  import org.apache.velocity.util.introspection.Uberspect;
  import org.junit.jupiter.api.Test;
  
  public class RuntimeInstanceTest {
      @Test
      public void rejectsConfiguredUberspectClassWithWrongType() {
          final RuntimeInstance runtime = new RuntimeInstance();
          runtime.setProperty(
                  RuntimeConstants.RUNTIME_LOG_LOGSYSTEM_CLASS,
                  "org.apache.velocity.runtime.log.NullLogChute");
          runtime.setProperty(RuntimeConstants.UBERSPECT_CLASSNAME, NonUberspect.class.getName());
  
          assertThatThrownBy(runtime::init)
                  .isInstanceOf(Exception.class)
                  .hasMessageContaining(NonUberspect.class.getName())
                  .hasMessageContaining(Uberspect.class.getName());
      }
  
      public static final class NonUberspect {
      }
  }
