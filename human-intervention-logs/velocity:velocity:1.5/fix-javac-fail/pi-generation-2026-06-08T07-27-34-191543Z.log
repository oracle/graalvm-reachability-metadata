               */
              String s = null;
  
              if( value != null )
              {
                  s = REFERENCE_VALUE;
              }
              else
              {
                  /*
                   * we only want to deal with $floobie - anything
                   *  else we let go
                   */
                  if ( reference.equals("$floobie") )
                  {
                      s = NO_REFERENCE_VALUE;
                  }
              }
              return s;
          }
  
          /**
