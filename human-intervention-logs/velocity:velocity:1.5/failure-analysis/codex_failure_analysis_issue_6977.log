e(String value, Set<String> testPackages) {\\n        return testPackages.stream().anyMatch(testPackage -> referencesTestPackage(value, testPackage));\\n    }\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_49\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'mergeReachabilityMetadata\\\\\\\\(' -n tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SplitTestOnlyMetadataTask.java && sed -n '260,520p' tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SplitTestOnlyMetadataTask.java\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_49\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'mergeReachabilityMetadata\\\\\\\\(' -n tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SplitTestOnlyMetadataTask.java && sed -n '260,520p' tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SplitTestOnlyMetadataTask.java\\\"\",\"aggregated_output\":\"109:        ObjectNode finalTestMetadata = mergeReachabilityMetadata(retainedTestMetadata, movedMetadata);\\n323:    private ObjectNode mergeReachabilityMetadata(ObjectNode existing, ObjectNode additions) {\\n    }\\n\\n    private void splitResources(ObjectNode source, ObjectNode moved, Set<String> testPackages, Set<String> testResources) {\\n        JsonNode field = source.get(\\\"resources\\\");\\n        if (!(field instanceof ArrayNode sourceEntries)) {\\n            return;\\n        }\\n\\n        ArrayNode keptEntries = objectMapper.createArrayNode();\\n        ArrayNode movedEntries = objectMapper.createArrayNode();\\n        for (JsonNode entry : sourceEntries) {\\n            JsonNode globNode = entry.isObject() ? entry.get(\\\"glob\\\") : null;\\n            boolean globIsTestResource = globNode != null && globNode.isTextual()\\n             