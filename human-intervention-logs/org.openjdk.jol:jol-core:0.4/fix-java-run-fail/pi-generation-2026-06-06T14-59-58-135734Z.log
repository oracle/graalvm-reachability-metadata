oughPublicApi() {\n        System.setProperty(\"jdk.attach.allowAttachSelf\", \"true\");\n\n        try {\n            Sample sample = new Sample(42, \"jol\");\n            ClassLayout layout = ClassLayout.parseInstance(sample);\n\n            String printable = layout.toPrintable();\n            int size = VMSupport.sizeOf(sample);\n\n            assertThat(printable)\n                    .contains(Sample.class.getName() + \" object internals:\")\n                    .contains(\"Instance size:\");\n            assertThat(size).isPositive();\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    static class Sample {\n        private final int number;\n        private final String text;\n\n        Sample(int number, String text) {\n            this.number = number;\n            this.text = text;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2800, "output": 733, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 35277, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780757923959, "responseId": "resp_009820b8aefa0f84016a2435a478508196ad9d63655834072f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6eogLhZ8k7NnFQymyNRz3UCy|fc_009820b8aefa0f84016a2435ab0d148196809a76b6ba7ede14", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1630 bytes to tests/src/org.openjdk.jol/jol-core/0.4/src/test/java/org_openjdk_jol/jol_core/InstrumentationSupportTest.java"}], "isError": false, "timestamp": 1780757935608}]}
