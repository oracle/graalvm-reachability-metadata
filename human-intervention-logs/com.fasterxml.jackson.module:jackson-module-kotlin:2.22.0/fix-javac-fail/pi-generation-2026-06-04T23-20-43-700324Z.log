  package com_fasterxml_jackson_module.jackson_module_kotlin;
  
  import com.fasterxml.jackson.databind.ObjectMapper;
  import com.fasterxml.jackson.databind.json.JsonMapper;
  import com.fasterxml.jackson.module.kotlin.KotlinModule;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  class ValueClassUnboxSerializerTest {
      @Test
      void serializesValueClassByUnboxingItsUnderlyingValue() throws Exception {
          ObjectMapper objectMapper = newObjectMapper();
  
          String json = objectMapper.writeValueAsString(
                  ValueClassUnboxSerializerFixtures.boxedUnboxExample("alpha"));
  
          assertThat(json).isEqualTo("\"alpha\"");
      }
  
      @Test
      void serializesNullWhenUnderlyingValueIsNull() throws Exception {
          ObjectMapper objectMapper = newObjectMapper();
  
          String json = objectMapper.writeValueAsString(
                  ValueClassUnboxSerializerFixtures.boxedNullableUnboxExample(null));
  
          assertThat(json).isEqualTo("null");
      }
  
      private static ObjectMapper newObjectMapper() {
          return JsonMapper.builder()
                  .addModule(new KotlinModule.Builder().build())
                  .build();
      }
  }
