          assertThat(
                          org_osgi.org_osgi_compendium.vendor.deploymentadmin
                                  .DeploymentCustomizerPermission.lastCreatedName)
                  .isEqualTo("(name=example.bundle)");
          assertThat(
                          org_osgi.org_osgi_compendium.vendor.deploymentadmin
                                  .DeploymentCustomizerPermission.lastCreatedActions)
                  .isEqualTo("privatearea");
      }
  }
