              boundDescriptor = null;
              boundApplicationId = null;
              locked = false;
              isLockedCalls = 0;
              lockCalls = 0;
              unlockCalls = 0;
              scheduleCalls = 0;
              launchCalls = 0;
              lastScheduleId = null;
              lastArguments = null;
              lastTopic = null;
              lastEventFilter = null;
              lastRecurring = false;
              lastScheduledApplication = null;
              lastLaunchArguments = null;
