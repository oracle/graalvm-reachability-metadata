ava", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_osgi.osgi_cmpn;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.HashMap;\nimport java.util.Map;\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\nimport org.osgi.service.application.ApplicationDescriptor;\nimport org.osgi.service.application.ApplicationHandle;\n\npublic class ApplicationHandleInnerDelegateAnonymous1Test {\n    private static final String DESCRIPTOR_IMPLEMENTATION_PROPERTY =\n            \"org.osgi.vendor.application.ApplicationDescriptor\";\n    private static final String HANDLE_IMPLEMENTATION_PROPERTY =\n            \"org.osgi.vendor.application.ApplicationHandle\";\n\n    private static String previousDescriptorImplementation;\n    private static String previousHandleImplementation;\n\n    @BeforeAll\n    static void setUpVendorImplementations() {\n        previousDescriptorImplementation = System.getProperty(DESCRIPTOR_IMPLEMENTATION_PROPERTY);\n        previousHandleImplementation = System.getProperty(HANDLE_IMPLEMENTATION_PROPERTY);\n        System.setProperty(\n                DESCRIPTOR_IMPLEMENTATION_PROPERTY,\n                ApplicationDescriptorInnerDelegateAnonymous1Test\n                        .VendorApplicationDescriptor.class.getName());\n        System.setProperty(HANDLE_IMPLEMENTATION_PROPERTY, VendorApplicationHandle.class.getName());\n    }\n\n    @AfterAll\n    static void restoreVendorImplementations() {\n        if (previousDescriptorImplementation == null) {\n            System.clearProperty(DESCRIPTOR_IMPLEMENTATION_PROPERTY);\n        } else {\n            System.setProperty(DESCRIPTOR_IMPLEMENTATION_PROPERTY, previousDescriptorImplementation);\n        }\n\n        if (previousHandleImplementation == null) {\n            System.clearProperty(HANDLE_IMPLEMENTATION_PROPERTY);\n        } else {\n            System.setProperty(HANDLE_IMPLEMENTATION_PROPERTY, previousHandleImplementation);\n        }\n    }\n\n    @BeforeEach\n    void resetVendorState() {\n        ApplicationDescriptorInnerDelegateAnonymous1Test.VendorApplicationDescriptor.reset();\n        VendorApplicationHandle.reset();\n    }\n\n    @Test\n    void constructorLoadsVendorDelegateImplementationFromSystemProperty() {\n        TestApplicationDescriptor descriptor =\n                new TestApplicationDescriptor(\"example.application\");\n\n        TestApplicationHandle handle =\n                new TestApplicationHandle(\"example.application.1\", descriptor);\n\n        assertThat(handle.getInstanceId()).isEqualTo(\"example.application.1\");\n        assertThat(handle.getApplicationDescriptor()).isSameAs(descriptor);\n        assertThat(VendorApplicationHandle.boundHandle).isSameAs(handle);\n        assertThat(VendorApplicationHandle.boundDescriptorDelegate).isNotNull();\n    }\n\n    @Test\n    void destroyDelegatesToVendorImplementation() {\n        TestApplicationDescriptor descriptor =\n                new TestApplicationDescriptor(\"example.application\");\n        TestApplicationHandle handle =\n                new TestApplicationHandle(\"example.application.1\", descriptor);\n\n        handle.destroy();\n\n        assertThat(VendorApplicationHandle.destroyCalls).isEqualTo(1);\n        assertThat(handle.destroySpecificCalls).isEqualTo(1);\n    }\n\n    public static final class VendorApplicationHandle {\n        private static ApplicationHandle boundHandle;\n        private static Object boundDescriptorDelegate;\n        private static int destroyCalls;\n\n        public static void reset() {\n            boundHandle = null;\n            boundDescriptorDelegate = null;\n            destroyCalls = 0;\n        }\n\n        public void setApplicationHandle(ApplicationHandle handle, Object descriptorDelegate) {\n            boundHandle = handle;\n            boundDescriptorDelegate = descriptorDelegate;\n        }\n\n        public void destroy() {\n            destroyCalls++;\n        }\n    }\n\n    private static final class TestApplicationDescriptor extends ApplicationDescriptor {\n        private TestApplicationDescriptor(String applicationId) {\n            super(applicationId);\n        }\n\n        @Override\n        public boolean matchDNChain(String pattern) {\n            return false;\n        }\n\n        @Override\n        protected Map getPropertiesSpecific(String locale) {\n            return new HashMap();\n        }\n\n        @Override\n        protected ApplicationHandle launchSpecific(Map arguments) {\n            throw new AssertionError(\"launchSpecific should not be invoked by this coverage test\");\n        }\n\n        @Override\n        protected boolean isLaunchableSpecific() {\n            return true;\n        }\n\n        @Override\n        protected void lockSpecific() {\n        }\n\n        @Override\n        protected void unlockSpecific() {\n        }\n    }\n\n    private static final class TestApplicationHandle extends ApplicationHandle {\n        private int destroySpecificCalls;\n\n        private TestApplicationHandle(String instanceId, ApplicationDescriptor descriptor) {\n            super(instanceId, descriptor);\n        }\n\n        @Override\n        public String getState() {\n            return RUNNING;\n        }\n\n        @Override\n        protected void destroySpecific() {\n            destroySpecificCalls++;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.osgi/osgi.cmpn/6.0.0/src/test/java/org_osgi/osgi_cmpn/ApplicationHandleInnerDelegateAnonymous1Test.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_osgi.osgi_cmpn;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.util.HashMap;\\nimport java.util.Map;\\nimport org.junit.jupiter.api.AfterAll;\\nimport org.junit.jupiter.api.BeforeAll;\\nimport org.junit.jupiter.api.BeforeEach;\\nimport org.junit.jupiter.api.Test;\\nimport org.osgi.service.application.ApplicationDescriptor;\\nimport org.osgi.service.application.ApplicationHandle;\\n\\npublic class ApplicationHandleInnerDelegateAnonymous1Test {\\n    private static final String DESCRIPTOR_IMPLEMENTATION_PROPERTY =\\n            \\\"org.osgi.vendor.application.ApplicationDescriptor\\\";\\n    private static final String HANDLE_IMPLEMENTATION_PROPERTY =\\n            \\\"org.osgi.vendor.application.ApplicationHandle\\\";\\n\\n    private static String previousDescriptorImplementation;\\n    private static String previousHandleImplementation;\\n\\n    @BeforeAll\\n    static void setUpVendorImplementations() {\\n        previousDescriptorImplementation = System.getProperty(DESCRIPTOR_IMPLEMENTATION_PROPERTY);\\n        previousHandleImplementation = System.getProperty(HANDLE_IMPLEMENTATION_PROPERTY);\\n        System.setProperty(\\n                DESCRIPTOR_IMPLEMENTATION_PROPERTY,\\n                ApplicationDescriptorInnerDelegateAnonymous1Test\\n                        .VendorApplicationDescriptor.class.getName());\\n        System.setProperty(HANDLE_IMPLEMENTATION_PROPERTY, VendorApplicationHandle.class.getName());\\n    }\\n\\n    @AfterAll\\n    static void restoreVendorImplementations() {\\n        if (previousDescriptorImplementation == null) {\\n            System.clearProperty(DESCRIPTOR_IMPLEMENTATION_PROPERTY);\\n        } else {\\n            System.setProperty(DESCRIPTOR_IMPLEMENTATION_PROPERTY, previousDescriptorImplementation);\\n        }\\n\\n        if (previousHandleImplementation == null) {\\n            System.clearProperty(HANDLE_IMPLEMENTATION_PROPERTY);\\n        } else {\\n            System.setProperty(HANDLE_IMPLEMENTATION_PROPERTY, previousHandleImplementation);\\n        }\\n    }\\n\\n    @BeforeEach\\n    void resetVendorState() {\\n        ApplicationDescriptorInnerDelegateAnonymous1Test.VendorApplicationDescriptor.reset();\\n        VendorApplicationHandle.reset();\\n    }\\n\\n    @Test\\n    void constructorLoadsVendorDelegateImplementationFromSystemProperty() {\\n        TestApplicationDescriptor descriptor =\\n                new TestApplicationDescriptor(\\\"example.application\\\");\\n\\n        TestApplicationHandle handle =\\n                new TestApplicationHandle(\\\"example.application.1\\\", descriptor);\\n\\n        assertThat(handle.getInstanceId()).isEqualTo(\\\"example.application.1\\\");\\n        assertThat(handle.getApplicationDescriptor()).isSameAs(descriptor);\\n        assertThat(VendorApplicationHandle.boundHandle).isSameAs(handle);\\n        assertThat(VendorApplicationHandle.boundDescriptorDelegate).isNotNull();\\n    }\\n\\n    @Test\\n    void destroyDelegatesToVendorImplementation() {\\n        TestApplicationDescriptor descriptor =\\n                new TestApplicationDescriptor(\\\"example.application\\\");\\n        TestApplicationHandle handle =\\n                new TestApplicationHandle(\\\"example.application.1\\\", descriptor);\\n\\n        handle.destroy();\\n\\n        assertThat(VendorApplicationHandle.destroyCalls).isEqualTo(1);\\n        assertThat(handle.destroySpecificCalls).isEqualTo(1);\\n    }\\n\\n    public static final class VendorApplicationHandle {\\n        private static ApplicationHandle boundHandle;\\n        private static Object boundDescriptorDelegate;\\n        private static int destroyCalls;\\n\\n        public static void reset() {\\n            boundHandle = null;\\n            boundDescriptorDelegate = null;\\n            destroyCalls = 0;\\n        }\\n\\n        public void setApplicationHandle(ApplicationHandle handle, Object descriptorDelegate) {\\n            boundHandle = handle;\\n            boundDescriptorDelegate = descriptorDelegate;\\n        }\\n\\n        public void destroy() {\\n            destroyCalls++;\\n        }\\n    }\\n\\n    private static final class TestApplicationDescriptor extends ApplicationDescriptor {\\n        private TestApplicationDescriptor(String applicationId) {\\n            super(applicationId);\\n        }\\n\\n        @Override\\n        public boolean matchDNChain(String pattern) {\\n            return false;\\n        }\\n\\n        @Override\\n        protected Map getPropertiesSpecific(String locale) {\\n            return new HashMap();\\n        }\\n\\n        @Override\\n        protected ApplicationHandle launchSpecific(Map arguments) {\\n            throw new AssertionError(\\\"launchSpecific should not be invoked by this coverage test\\\");\\n        }\\n\\n        @Override\\n        protected boolean isLaunchableSpecific() {\\n            return true;\\n        }\\n\\n        @Override\\n        protected void lockSpecific() {\\n        }\\n\\n        @Override\\n        protected void unlockSpecific() {\\n        }\\n    }\\n\\n    private static final class TestApplicationHandle extends ApplicationHandle {\\n        private int destroySpecificCalls;\\n\\n        private TestApplicationHandle(String instanceId, ApplicationDescriptor descriptor) {\\n            super(instanceId, descriptor);\\n        }\\n\\n        @Override\\n        public String getState() {\\n            return RUNNING;\\n        }\\n\\n        @Override\\n        protected void destroySpecific() {\\n            destroySpecificCalls++;\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 294, "output": 1902, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25748, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777415467931, "respon