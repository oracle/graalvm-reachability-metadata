n        ConstructableService.CONSTRUCTOR_CALLS.set(0);\\n        MethodHandle explicitClassLoaderNewInstance = explicitClassLoaderNewInstanceMethod();\\n\\n        Object created = explicitClassLoaderNewInstance.invoke(\\n                ConstructableService.class.getName(),\\n                new Class<?>[] {String.class},\\n                new Object[] {\\\"created through SecurityActions\\\"},\\n                ConstructableContract.class,\\n                ConstructableService.class.getClassLoader());\\n\\n        assertThat(created).isInstanceOf(ConstructableService.class);\\n        assertThat(((ConstructableService) created).description()).isEqualTo(\\\"created through SecurityActions\\\");\\n        assertThat(ConstructableService.CONSTRUCTOR_CALLS).hasValue(1);\\n    }\\n\\n    private static MethodHandle explicitClassLoaderNewInstanceMethod() throws Exception {\\n        Class<?> securityActionsClass = Class.forName(SECURITY_ACTIONS_CLASS);\\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(securityActionsClass, MethodHandles.lookup());\\n        MethodType methodType = MethodType.methodType(\\n                Object.class,\\n                String.class,\\n                Class[].class,\\n                Object[].class,\\n                Class.class,\\n                ClassLoader.class);\\n        return lookup.findStatic(securityActionsClass, \\\"newInstance\\\", methodType);\\n    }\\n\\n    public interface ConstructableContract {\\n        String description();\\n    }\\n\\n    public static final class ConstructableService implements ConstructableContract {\\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\\n\\n        private final String description;\\n\\n        public ConstructableService(String description) {\\n            this.description = description;\\n            CONSTRUCTOR_CALLS.incrementAndGet();\\n        }\\n\\n        @Override\\n        public String description() {\\n           