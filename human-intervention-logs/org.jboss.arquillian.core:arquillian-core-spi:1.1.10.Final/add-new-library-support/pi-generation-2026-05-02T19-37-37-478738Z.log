 {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\n        String targetClassName = SecurityActionsFallbackLoadClassTarget.class.getName();\n        ClassLoader blockingClassLoader = new BlockingClassLoader(originalClassLoader, targetClassName);\n\n        try {\n            currentThread.setContextClassLoader(blockingClassLoader);\n\n            Class<?> loadedClass = invokeLoadClass(targetClassName);\n\n            assertThat(loadedClass).isSameAs(SecurityActionsFallbackLoadClassTarget.class);\n        } finally {\n            currentThread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    public void newInstanceWithDefaultLoaderCreatesTypedInstance() throws Exception {\n        SecurityActionsCreatedService service = invokeNewInstance(\n                SecurityActionsCreatedServiceImpl.class.getName(),\n                new Class<?>[] {String.class},\n                new Object[] {\"default-loader\"},\n                SecurityActionsCreatedService.class);\n\n        assertThat(service.message()).isEqualTo(\"default-loader\");\n    }\n\n    @Test\n    public void newInstanceWithExplicitLoaderCreatesTypedInstance() throws Exception {\n        SecurityActionsCreatedService service = invokeNewInstance(\n                SecurityActionsCreatedServiceImpl.class.getName(),\n                new Class<?>[] {String.class},\n                new Object[] {\"explicit-loader\"},\n                SecurityActionsCreatedService.class,\n                SecurityActionsCreatedServiceImpl.class.getClassLoader());\n\n        assertThat(service.message()).isEqualTo(\"explicit-loader\");\n    }\n\n    private static Class<?> invokeLoadClass(String className) throws Exception {\n        Method method = securityActionsClass().getDeclaredMethod(\"loadClass\", String.class);\n        method.setAccessible(true);\n        return (Class<?>) method.invoke(null, className);\n    }\n\n    private static <T> T invokeNewInstance(\n            String className,\n            Class<?>[] argumentTypes,\n            Object[] arguments,\n            Class<T> expectedType) throws Exception {\n        Method method = securityActionsClass().getDeclaredMethod(\n                \"newInstance\", String.class, Class[].class, Object[].class, Class.class);\n        method.setAccessible(true);\n        Object instance = method.invoke(null, className, argumentTypes, arguments, expectedType);\n        return expectedType.cast(instance);\n    }\n\n    private static <T> T invokeNewInstance(\n            String className,\n            Class<?>[] argumentTypes,\n            Object[] arguments,\n            Class<T> expectedType,\n            ClassLoader classLoader) throws Exception {\n        Method method = securityActionsClass().getDeclaredMethod(\n                \"newInstance\", String.class, Class[].class, Object[].class, Class.class, ClassLoader.class);\n        method.setAccessible(true);\n        Object instance = method.invoke(null, className, argumentTypes, arguments, expectedType, classLoader);\n        return expectedType.cast(instance);\n    }\n\n    private static Class<?> securityActionsClass() throws ClassNotFoundException {\n        return Class.forName(SECURITY_ACTIONS_CLASS_NAME);\n    }\n}\n\ninterface SecurityActionsCreatedService {\n    String message();\n}\n\nclass SecurityActionsCreatedServiceImpl implements SecurityActionsCreatedService {\n    private final String message;\n\n    public SecurityActionsCreatedServiceImpl(String message) {\n        this.message = message;\n    }\n\n    @Override\n    public String message() {\n        return message;\n    }\n}\n\nclass SecurityActionsLoadClassTarget {\n}\n\nclass SecurityActionsFallbackLoadClassTarget {\n}\n\nclass BlockingClassLoader extends ClassLoader {\n    private final String blockedClassName;\n\n    BlockingClassLoader(ClassLoader parent, String blockedClassName) {\n        super(parent);\n        this.blockedClassName = blockedClassName;\n    }\n\n    @Override\n    protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n        if (blockedClassName.equals(name)) {\n            throw new ClassNotFoundException(name);\n        }\n        return super.loadClass(name, resolve);\n    }\n}\n"}], "isError": false, "timestamp": 1777750631885}]}
