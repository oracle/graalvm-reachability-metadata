:622:        showResult(\"error\", \"Invalid coordinates\", message, [], []);\n./docs/support/index.html:625:      function showUnsupported(coordinates) {\n./docs/support/index.html:629:          `${coordinates.gav} is not currently listed in this repository.`,\n./docs/support/index.html:631:            metadataValue(\"Group\", coordinates.group),\n./docs/support/index.html:632:            metadataValue(\"Artifact\", coordinates.artifact)\n./docs/support/index.html:635:            action(\"Request new metadata\", issueUrl(\"01_support_new_library.yml\", `Support for ${coordinates.gav}`), \"warning\")\n./docs/support/index.html:640:      function showKnownButUntested(coordinates, entries) {\n./docs/support/index.html:647:          `${coordinates.group}:${coordinates.artifact} exists here, but ${coordinates.version} is not in the tested version list.`,\n./docs/support/index.html:653:            action(\"Request a version update\", issueUrl(\"02_update_existing_library.yml\", `Update metadata for ${coordinates.gav}`), \"warning\"),\n./docs/support/index.html:654:            action(\"View metadata index\", metadataIndexUrl(coordinates.group, coordinates.artifact), \"secondary\")\n./docs/support/index.html:659:      function showSupported(coordinates, entries) {\n./docs/support/index.html:664:          `${coordinates.gav} is covered by tested reachability metadata in this repository.`,\n./docs/support/index.html:670:            action(\"Report a metadata problem\", issueUrl(\"02_update_existing_library.yml\", `Update metadata for ${coordinates.gav}`), \"secondary\"),\n./docs/support/index.html:671:            action(\"View metadata index\", metadataIndexUrl(coordinates.group, coordinates.artifact), \"secondary\")\n./docs/support/index.html:682:          const coordinates = parseCoordinates(elements.coordinates.value);\n./docs/support/index.html:683:          const entries = await fetchIndex(coordinates);\n./docs/support/index.html:685:          url.searchParams.set(\"coo