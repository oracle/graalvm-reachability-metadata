  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  @SuppressWarnings({"deprecation", "rawtypes"})
  public class HibernateJpaSessionFactoryBeanTest {
      @Test
      void getObjectReflectivelyInvokesGetSessionFactoryOnConfiguredEntityManagerFactory() {
          HibernateJpaSessionFactoryBean factoryBean = new HibernateJpaSessionFactoryBean();
          EntityManagerFactoryWithSessionFactory entityManagerFactory = new EntityManagerFactoryWithSessionFactory();
          factoryBean.setEntityManagerFactory(entityManagerFactory);
  
          SessionFactory sessionFactory = factoryBean.getObject();
  
          assertNull(sessionFactory);
          assertEquals(1, entityManagerFactory.getSessionFactoryCalls());
          assertSame(SessionFactory.class, factoryBean.getObjectType());
          assertTrue(factoryBean.isSingleton());
      }
  
      public static final class EntityManagerFactoryWithSessionFactory implements EntityManagerFactory {
          private int getSessionFactoryCalls;
  
          public SessionFactory getSessionFactory() {
              this.getSessionFactoryCalls++;
              return null;
          }
  
          int getSessionFactoryCalls() {
              return this.getSessionFactoryCalls;
          }
  
