  	 * Return the JpaVendorAdapter implementation for this EntityManagerFactory,
  	 * or {@code null} if not known.
  	 */
  	@Nullable
  	public JpaVendorAdapter getJpaVendorAdapter() {
  		return this.jpaVendorAdapter;
  	}
  
