  					doJoinTransaction(true);
  					return null;
  				case "isJoinedToTransaction":
  					// Handle JPA 2.1 isJoinedToTransaction method for the non-JTA case.
  					if (!this.jta) {
  						return TransactionSynchronizationManager.hasResource(this.target);
  					}
  					break;
