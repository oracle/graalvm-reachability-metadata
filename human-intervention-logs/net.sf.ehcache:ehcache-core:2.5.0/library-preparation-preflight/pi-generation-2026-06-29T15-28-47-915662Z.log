      protected long measureSizeOf(Object obj) {
          return Math.max(CURRENT_JVM_INFORMATION.getMinimumObjectSize(),
                  AgentLoader.agentSizeOf(obj) + CURRENT_JVM_INFORMATION.getAgentSizeOfAdjustment());
      }
  }
  
  
