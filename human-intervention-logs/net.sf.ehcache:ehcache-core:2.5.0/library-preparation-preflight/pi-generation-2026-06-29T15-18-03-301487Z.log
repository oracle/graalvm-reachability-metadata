                        def getLastChangedRevision(path) {
                          fullPath = path.getCanonicalPath()
                          outProp = "svninfo" + fullPath.hashCode();
                          ant.exec(executable : 'svn', outputproperty: outProp ,
                                   dir: fullPath, resultproperty: 'svnexitcode',
