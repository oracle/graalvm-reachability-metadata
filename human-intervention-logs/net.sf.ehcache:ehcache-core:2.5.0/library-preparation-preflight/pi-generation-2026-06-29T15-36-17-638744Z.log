groupId>\n            <artifactId>bsh</artifactId>\n            <version>1.3.0</version>\n            <scope>test</scope>\n        </dependency>\n    </dependencies>\n\n    <build>\n        <resources>\n            <resource>\n                <directory>src/main/resources</directory>\n                <filtering>true</filtering>\n            </resource>\n        </resources>\n        <testSourceDirectory>${basedir}/${testDir}</testSourceDirectory>\n        <testResources>\n            <testResource>\n                <directory>${basedir}/src/main/config/jcache</directory>\n            </testResource>\n            <testResource>\n                <directory>${basedir}/${testResources}</directory>\n            </testResource>\n        </testResources>\n\n        <plugins>\n            <plugin>\n                <artifactId>maven-compiler-plugin</artifactId>\n                <configuration>\n                    <source>1.5</source>\n                    <target>1.5</target>\n                </configuration>\n                <executions>\n                    <execution>\n                        <id>compile_for_javadoc</id>\n                        <phase>pre-site</phase>\n                        <goals>\n                            <goal>compile</goal>\n                        </goals>\n                    </execution>\n                </executions>\n            </plugin>\n\n\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-javadoc-plugin</artifactId>\n                <version>2.7</version>\n\n                <configuration>\n                    <author>true</author>\n                    <bottom>true</bottom>\n                    <!--<destDir>${project.build.directory}/site/javadoc</destDir>-->\n                    <header><![CDATA[<a href=\"/\" target=\"_top\">ehcache</a>]]></header>\n                    <minmemory>128m</minmemory>\n                    <maxmemory>512</maxmemory>\n                    <over