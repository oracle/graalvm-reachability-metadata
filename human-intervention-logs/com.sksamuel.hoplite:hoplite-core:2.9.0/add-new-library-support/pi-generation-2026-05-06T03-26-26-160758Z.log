 ConfigResult<Node> = when (node) {\n    is MapNode -> {\n      node.map.map { (k, v) -> process(v, context).map { k to it } }.sequence()\n        .mapInvalid { ConfigFailure.MultipleFailures(it) }\n        .map { it.toMap() }.flatMap { map ->\n          val value = if (node.value is PrimitiveNode) handle(node.value, context) else node.value.valid()\n          value.map { v ->\n            MapNode(map, node.pos, node.path, v, sourceKey = node.sourceKey)\n          }\n        }\n    }\n    is ArrayNode -> {\n      node.elements.map { process(it, context) }.sequence()\n        .mapInvalid { ConfigFailure.MultipleFailures(it) }\n        .map { ArrayNode(it, node.pos, node.path, sourceKey = node.sourceKey) }\n    }\n    is PrimitiveNode -> handle(node, context)\n    else -> node.valid()\n  }\n}\n"}], "isError": false, "timestamp": 1778037950235}, {"role": "toolResult", "toolCallId": "call_wQjcOzwc1qFaRfklHvhpTPg0|fc_0ff3c9dd7fcb95a00169fab4bdcc08819fb7b08fbb86578009", "toolName": "bash", "content": [{"type": "text", "text": "../../source_context/com.sksamuel.hoplite/hoplite-core/2.9.0/main/extracted/com/sksamuel/hoplite/ConfigLoaderBuilderExtensions.kt:20:fun ConfigLoaderBuilder.addResourceSource(\n../../source_context/com.sksamuel.hoplite/hoplite-core/2.9.0/main/extracted/com/sksamuel/hoplite/ConfigLoaderBuilderExtensions.kt:26:fun ConfigLoaderBuilder.addFileSource(\n../../source_context/com.sksamuel.hoplite/hoplite-core/2.9.0/main/extracted/com/sksamuel/hoplite/ConfigLoaderBuilderExtensions.kt:30:): ConfigLoaderBuilder = addFileSource(File(file), optional, allowEmpty)\n../../source_context/com.sksamuel.hoplite/hoplite-core/2.9.0/main/extracted/com/sksamuel/hoplite/ConfigLoaderBuilderExtensions.kt:38:fun ConfigLoaderBuilder.addFileSource(\n../../source_context/com.sksamuel.hoplite/hoplite-core/2.9.0/main/extracted/com/sksamuel/hoplite/ConfigLoaderBuilderExtensions.kt:50:fun ConfigLoaderBuilder.addPathSource(\n../../source_context/com.sksamuel.hoplite/hoplite-core/2.9.0