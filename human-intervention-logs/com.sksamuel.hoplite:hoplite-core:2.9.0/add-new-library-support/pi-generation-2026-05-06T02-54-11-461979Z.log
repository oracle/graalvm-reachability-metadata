  package com_sksamuel_hoplite.hoplite_core
  
  import com.sksamuel.hoplite.ClasspathResourceLoader
  import com.sksamuel.hoplite.ClasspathResourceLoader.Companion.toClasspathResourceLoader
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import java.nio.charset.StandardCharsets
  
  public class ClasspathResourceLoaderInnerCompanionInnertoClasspathResourceLoaderAnonymous1Test {
      @Test
      fun classBasedResourceLoaderLoadsUrlAndStream(): Unit {
          val resourceClass: Class<ClasspathResourceLoaderInnerCompanionInnertoClasspathResourceLoaderAnonymous1Test> =
              ClasspathResourceLoaderInnerCompanionInnertoClasspathResourceLoaderAnonymous1Test::class.java
          val loader: ClasspathResourceLoader = resourceClass.toClasspathResourceLoader()
          val resourceName: String = "/hoplite/classpath-resource-loader-resource.txt"
  
          val resourceUrl = requireNotNull(loader.getResource(resourceName))
          val resourceText: String = requireNotNull(loader.getResourceAsStream(resourceName)).use { input ->
              input.readBytes().toString(StandardCharsets.UTF_8)
          }
  
          assertThat(resourceUrl).isNotNull()
          assertThat(resourceUrl.toString()).endsWith("hoplite/classpath-resource-loader-resource.txt")
          assertThat(resourceText).isEqualTo("loaded through Class.getResourceAsStream")
      }
  }
