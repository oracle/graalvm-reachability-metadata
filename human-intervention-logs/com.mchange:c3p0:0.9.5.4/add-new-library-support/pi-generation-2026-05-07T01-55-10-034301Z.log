  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.DriverManagerDataSource;
  import java.beans.PropertyChangeEvent;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.ArrayList;
  import java.util.List;
  import java.util.Properties;
  import org.junit.jupiter.api.Test;
  
  public class DriverManagerDataSourceBaseTest {
      @Test
      void serializationRoundTripReadsAndWritesBaseState() throws Exception {
          DriverManagerDataSource original = new DriverManagerDataSource(false);
          Properties connectionProperties = new Properties();
          connectionProperties.setProperty("applicationName", "driver-manager-data-source-base-test");
          connectionProperties.setProperty("user", "serialized-user");
          connectionProperties.setProperty("password", "serialized-password");
  
          original.setDescription("Serialized DriverManagerDataSource");
          original.setDriverClass("java.lang.String");
          original.setFactoryClassLocation("file:/tmp/c3p0-driver-manager-test");
          original.setForceUseNamedDriverClass(true);
          original.setIdentityToken("driver-manager-data-source-base-test-token");
          original.setJdbcUrl("jdbc:test:driver-manager-data-source-base");
          original.setProperties(connectionProperties);
  
          byte[] serialized = serialize(original);
          DriverManagerDataSource restored = deserialize(serialized, DriverManagerDataSource.class);
  
          assertThat(restored.getDescription()).isEqualTo("Serialized DriverManagerDataSource");
          assertThat(restored.getDriverClass()).isEqualTo("java.lang.String");
          assertThat(restored.getFactoryClassLocation()).isEqualTo("file:/tmp/c3p0-driver-manager-test");
          assertThat(restored.isForceUseNamedDriverClass()).isTrue();
          assertThat(restored.getIdentityToken()).isEqualTo("driver-manager-data-source-base-test-token");
          assertThat(restored.getJdbcUrl()).isEqualTo("jdbc:test:driver-manager-data-source-base");
          assertThat(restored.getProperties()).containsAllEntriesOf(connectionProperties);
  
          List<PropertyChangeEvent> events = new ArrayList<>();
          restored.addPropertyChangeListener(events::add);
          restored.setDriverClass("java.lang.Integer");
  
          assertThat(events)
                  .extracting(PropertyChangeEvent::getPropertyName)
                  .contains("driverClass");
      }
  
      private static byte[] serialize(DriverManagerDataSource dataSource) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(dataSource);
          }
          return bytes.toByteArray();
      }
  
      private static <T> T deserialize(byte[] serialized, Class<T> type) throws IOException, ClassNotFoundException {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              Object restored = input.readObject();
              assertThat(restored).isInstanceOf(type);
              return type.cast(restored);
          }
      }
  }
