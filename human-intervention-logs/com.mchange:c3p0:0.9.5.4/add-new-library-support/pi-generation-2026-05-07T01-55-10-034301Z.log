  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import com.mchange.v2.c3p0.impl.PoolBackedDataSourceBase;
  import java.beans.PropertyChangeEvent;
  import java.beans.PropertyVetoException;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.PrintWriter;
  import java.io.Serializable;
  import java.sql.SQLException;
  import java.sql.SQLFeatureNotSupportedException;
  import java.util.ArrayList;
  import java.util.HashMap;
  import java.util.List;
  import java.util.Map;
  import java.util.logging.Logger;
  import javax.naming.NamingException;
  import javax.naming.Reference;
  import javax.naming.Referenceable;
  import javax.sql.ConnectionPoolDataSource;
  import javax.sql.PooledConnection;
  import org.junit.jupiter.api.Test;
  
  public class PoolBackedDataSourceBaseTest {
      @Test
      void serializationRoundTripReadsAndWritesBaseState() throws Exception {
          PoolBackedDataSourceBase original = new PoolBackedDataSourceBase(false);
          Map<String, String> extensions = new HashMap<>();
          extensions.put("purpose", "pool-backed-data-source-base-test");
          extensions.put("mode", "direct-serialization");
  
          original.setConnectionPoolDataSource(new SerializableConnectionPoolDataSource());
          original.setDataSourceName("PoolBackedDataSourceBase serialization test");
          original.setExtensions(extensions);
          original.setFactoryClassLocation("file:/tmp/c3p0-pool-backed-test");
          original.setIdentityToken("pool-backed-data-source-base-test-token");
          original.setNumHelperThreads(6);
  
          byte[] serialized = serialize(original);
          PoolBackedDataSourceBase restored = deserialize(serialized, PoolBackedDataSourceBase.class);
  
          assertThat(restored.getConnectionPoolDataSource()).isInstanceOf(SerializableConnectionPoolDataSource.class);
          assertThat(restored.getDataSourceName()).isEqualTo("PoolBackedDataSourceBase serialization test");
          assertThat(restored.getExtensions()).containsAllEntriesOf(extensions);
          assertThat(restored.getFactoryClassLocation()).isEqualTo("file:/tmp/c3p0-pool-backed-test");
          assertThat(restored.getIdentityToken()).isEqualTo("pool-backed-data-source-base-test-token");
          assertThat(restored.getNumHelperThreads()).isEqualTo(6);
  
          List<PropertyChangeEvent> events = new ArrayList<>();
          restored.addPropertyChangeListener(events::add);
          restored.setDataSourceName("PoolBackedDataSourceBase restored instance");
  
          assertThat(events)
                  .extracting(PropertyChangeEvent::getPropertyName)
                  .contains("dataSourceName");
      }
  
      @Test
      void serializationWritesIndirectReferenceForNonSerializableConnectionPoolDataSource() throws Exception {
          PoolBackedDataSourceBase original = new PoolBackedDataSourceBase(false);
          original.setConnectionPoolDataSource(new ReferenceableConnectionPoolDataSource());
          original.setDataSourceName("PoolBackedDataSourceBase indirect connection pool data source test");
          original.setFactoryClassLocation("file:/tmp/c3p0-pool-backed-indirect-test");
          original.setIdentityToken("pool-backed-data-source-base-indirect-test-token");
  
          byte[] serialized = serialize(original);
  
          assertThat(serialized).isNotEmpty();
      }
  
      @Test
      void serializationRejectsNonSerializableExtensionValues() {
          PoolBackedDataSourceBase original = new PoolBackedDataSourceBase(false);
          Map<String, Object> extensions = new HashMap<>();
          extensions.put("nonSerializableReference", new ReferenceableExtensionValue());
          original.setExtensions(extensions);
  
          assertThatThrownBy(() -> serialize(original))
                  .isInstanceOf(IOException.class)
                  .hasMessageContaining("Problem indirectly serializing extensions");
      }
  
      private static byte[] serialize(PoolBackedDataSourceBase dataSource) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(dataSource);
          }
          return bytes.toByteArray();
      }
  
      private static <T> T deserialize(byte[] serialized, Class<T> type) throws IOException, ClassNotFoundException {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              Object restored = input.readObject();
              assertThat(restored).isInstanceOf(type);
              return type.cast(restored);
          }
      }
  
      private abstract static class UnsupportedConnectionPoolDataSource implements ConnectionPoolDataSource {
          protected UnsupportedConnectionPoolDataSource() {
          }
  
          @Override
          public PooledConnection getPooledConnection() throws SQLException {
              throw new SQLFeatureNotSupportedException("Connections are not needed for serialization coverage.");
          }
  
          @Override
          public PooledConnection getPooledConnection(String user, String password) throws SQLException {
              throw new SQLFeatureNotSupportedException("Connections are not needed for serialization coverage.");
          }
  
          @Override
          public PrintWriter getLogWriter() throws SQLException {
              return null;
          }
  
          @Override
          public void setLogWriter(PrintWriter out) throws SQLException {
          }
  
          @Override
          public void setLoginTimeout(int seconds) throws SQLException {
          }
  
          @Override
          public int getLoginTimeout() throws SQLException {
              return 0;
          }
  
          @Override
          public Logger getParentLogger() throws SQLFeatureNotSupportedException {
              throw new SQLFeatureNotSupportedException("Parent logger is not needed for serialization coverage.");
          }
      }
  
      private static final class SerializableConnectionPoolDataSource
              extends UnsupportedConnectionPoolDataSource
              implements Serializable {
          private static final long serialVersionUID = 1L;
      }
  
      private static final class ReferenceableConnectionPoolDataSource
              extends UnsupportedConnectionPoolDataSource
              implements Referenceable {
          @Override
          public Reference getReference() throws NamingException {
              return new Reference(ReferenceableConnectionPoolDataSource.class.getName());
          }
      }
  
      private static final class ReferenceableExtensionValue implements Referenceable {
          @Override
          public Reference getReference() throws NamingException {
              return new Reference(ReferenceableExtensionValue.class.getName());
          }
      }
