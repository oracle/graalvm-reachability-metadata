\n   878\t\n   879\t\t\t\t\t    return null;\n   880\t\t\t\t\t}\n   881\t\t\t\t    else if (mname.equals(\"createStatement\"))\n   882\t\t\t\t\t{\n   883\t\t\t\t\t    ensureOkay();\n   884\t\t\t\t\t    txn_known_resolved = false;\n   885\t\t\n   886\t\t\t\t\t    Object stmt = m.invoke( activeConnection, args );\n   887\t\t\t\t\t    return createProxyStatement( (Statement) stmt );\n   888\t\t\t\t\t}\n   889\t\t\t\t    else if (mname.equals(\"prepareStatement\"))\n   890\t\t\t\t\t{\n   891\t\t\t\t\t    ensureOkay();\n   892\t\t\t\t\t    txn_known_resolved = false;\n   893\t\t\n   894\t\t\t\t\t    Object pstmt;\n   895\t\t\t\t\t    if (scache == null)\n   896\t\t\t\t\t\t{\n   897\t\t\t\t\t\t    pstmt = m.invoke( activeConnection, args );\n   898\t\t\t\t\t\t    return createProxyStatement( (Statement) pstmt );\n   899\t\t\t\t\t\t}\n   900\t\t\t\t\t    else\n   901\t\t\t\t\t\t{\n   902\t\t\t\t\t\t    pstmt = scache.checkoutStatement( physicalConnection,\n   903\t\t\t\t\t\t\t\t\t\t      m, \n   904\t\t\t\t\t\t\t\t\t\t      args );\n   905\t\t\t\t\t\t    return createProxyStatement( true,\n   906\t\t\t\t\t\t\t\t\t\t (Statement) pstmt );\n   907\t\t\t\t\t\t}\n   908\t\t\t\t\t}\n   909\t\t\t\t    else if (mname.equals(\"prepareCall\"))\n   910\t\t\t\t\t{\n   911\t\t\t\t\t    ensureOkay();\n   912\t\t\t\t\t    txn_known_resolved = false;\n   913\t\t\n   914\t\t\t\t\t    Object cstmt;\n   915\t\t\t\t\t    if (scache == null)\n   916\t\t\t\t\t\t{\n   917\t\t\t\t\t\t    cstmt = m.invoke( activeConnection, args );\n   918\t\t\t\t\t\t    return createProxyStatement( (Statement) cstmt ); \n   919\t\t\t\t\t\t}\n   920\t\t\t\t\t    else\n   921\t\t\t\t\t\t{\n   922\t\t\t\t\t\t    cstmt = scache.checkoutStatement( physicalConnection, m, args );\n   923\t\t\t\t\t\t    return createProxyStatement( true,\n   924\t\t\t\t\t\t\t\t\t\t (Statement) cstmt );\n   925\t\t\t\t\t\t}\n   926\t\t\t\t\t}\n   927\t\t\t\t    else if (mname.equals(\"getMetaData\"))\n   928\t\t\t\t\t{\n   929\t\t\t\t\t    ensureOkay();\n   930\t\t\t\t\t    txn_known_resolved = false; //views of tables etc. might be txn dependent\n   931\t\t\n   932\t\t\t\t\t    DatabaseMetaData innerMd = activeConnection.getMetaData();\n   933\t\t\t\t\t    if (metaData == null)\n   934\t\t\t\t\t\t{\n   935\t\t\t\t\t\t    // exposedProxy is protected by C3P0PooledConnection.this' lock\n   936\t\t\t\t\t\t    synchronized (C3P0PooledConnection.this)\n   937\t\t\t\t\t\t\t{ metaData = new SetManagedDatabaseMetaData(innerMd, activeMetaDataResultSets, exposedProxy); }\n   938\t\t\t\t\t\t}\n   939\t\t\t\t\t    return metaData;\n   940\t\t\t\t\t}\n   941\t\t\t\t    else if (mname.equals(\"silentClose\"))\n   942\t\t\t\t\t{\n   943\t\t\t\t\t    //the PooledConnection doesn't have to be okay\n   944\t\t\n   945\t\t\t\t\t    doSilentClose( proxy, ((Boolean) args[0]).booleanValue(), this.txn_known_resolved );\n   946\t\t\t\t\t    return null;\n   947\t\t\t\t\t}\n   948\t\t\t\t    else if ( mname.equals(\"close\") )\n   949\t\t\t\t\t{\n   950\t\t\t\t\t    //the PooledConnection doesn't have to be okay\n   951\t\t\n   952\t\t\t\t\t    Exception e = doSilentClose( proxy, false, this.txn_known_resolved );\n   953\t\t\t\t\t    if (! connection_error_signaled)\n   954\t\t\t\t\t\tces.fireConnectionClosed();\n   955\t\t\t\t\t    //System.err.println(\"close() called on a ProxyConnection.\");\n   956\t\t\t\t\t    if (e != null)\n   957\t\t\t\t\t\t{\n   958\t\t\t\t\t\t    // \t\t\t\t\t    System.err.print(\"user close exception -- \");\n   959\t\t\t\t\t\t    // \t\t\t\t\t    e.printStackTrace();\n   960\t\t\t\t\t\t    throw e;\n   961\t\t\t\t\t\t}\n   962\t\t\t\t\t    else\n   963\t\t\t\t\t\treturn null;\n   964\t\t\t\t\t}\n   965\t// \t\t\t    else if ( mname.equals(\"finalize\") ) //REMOVE THIS CASE -- TMP DEBUG\n   966\t// \t\t\t\t{\n   967\t// \t\t\t\t    System.err.println(\"Connection apparently finalized!\");\n   968\t// \t\t\t\t    return m.invoke( activeConnection, args );\n   969\t// \t\t\t\t}\n   970\t\t\t\t    else\n   971\t\t\t\t\t{\n   972\t\t\t\t\t    ensureOkay();\n   973\t\t\t\t\t\t    \n   974\t\n   975\t\t\t\t\t    // we've disabled setting txn_known_resolved to true, ever, because\n   976\t\t\t\t\t    // we failed to deal with the case that clients would work with previously\n   977\t\t\t\t\t    // acquired Statements and ResultSets after a commit(), rollback(), or setAutoCommit().\n   978\t\t\t\t\t    // the new non-reflective proxies have been modified to deal with this case.\n   979\t\t\t\t\t    // here, with soon-to-be-deprecated in \"traditional reflective proxies mode\"\n   980\t\t\t\t\t    // we are reverting to the conservative, always-presume-you-have-to-rollback\n   981\t\t\t\t\t    // policy.\n   982\t\n   983\t\t\t\t\t    //txn_known_resolved = ( mname.equals(\"commit\") || mname.equals( \"rollback\" ) || mname.equals( \"setAutoCommit\" ) );\n   984\t\t\t\t\t    txn_known_resolved = false; \n   985\t\n   986\t\t\t\t\t    return m.invoke( activeConnection, args );\n   987\t\t\t\t\t}\n   988\t\t\t\t}\n   989\t\t\t    else\n   990\t\t\t\t{\n   991\t\t\t\t    if (mname.equals(\"close\") || \n   992\t\t\t\t\tmname.equals(\"silentClose\"))\n   993\t\t\t\t\treturn null;\n   994\t\t\t\t    else if (mname.equals(\"isClosed\"))\n   995\t\t\t\t\treturn Boolean.TRUE;\n   996\t\t\t\t    else\n   997\t\t\t\t\t{\n   998\t\t\t\t\t    throw new SQLException(\"You can't operate on \" +\n   999\t\t\t\t\t\t\t\t   \"a closed connection!!!\");\n  1000\t\t\t\t\t}\n"}], "isError": false, "timestamp": 1780843599620}]}
