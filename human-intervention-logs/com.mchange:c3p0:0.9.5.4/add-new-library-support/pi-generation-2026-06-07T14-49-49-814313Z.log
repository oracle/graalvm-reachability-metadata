  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.DriverManagerDataSource;
  import com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;
  import com.mchange.v2.naming.JavaBeanObjectFactory;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.PrintWriter;
  import java.sql.Connection;
  import java.sql.SQLException;
  import java.sql.SQLFeatureNotSupportedException;
  import java.util.logging.Logger;
  import javax.naming.NamingException;
  import javax.naming.Reference;
  import javax.naming.Referenceable;
  import javax.naming.StringRefAddr;
  import javax.sql.DataSource;
  import org.junit.jupiter.api.Test;
  
  public class WrapperConnectionPoolDataSourceBaseTest implements DataSource, Referenceable {
      private static final String OBJECT_FACTORY_WHITELIST_PROPERTY =
              "com.mchange.v2.naming.objectFactoryWhitelist";
      private static final String UNSUPPORTED_MESSAGE = "Test DataSource does not create connections.";
  
      private String token;
  
      @Test
      void serializesAndDeserializesDirectlySerializableNestedDataSource() throws Exception {
          WrapperConnectionPoolDataSource dataSource = configuredWrapper("direct-wrapper");
          DriverManagerDataSource nestedDataSource = new DriverManagerDataSource(false);
          nestedDataSource.setIdentityToken("direct-nested");
          nestedDataSource.setJdbcUrl("jdbc:c3p0-test:direct");
          nestedDataSource.setUser("direct-user");
          nestedDataSource.setPassword("direct-password");
          dataSource.setNestedDataSource(nestedDataSource);
  
          WrapperConnectionPoolDataSource copy = roundTrip(dataSource);
  
          assertThat(copy.getIdentityToken()).isEqualTo("direct-wrapper");
          assertThat(copy.getAutomaticTestTable()).isEqualTo("TEST_CONNECTIONS");
          assertThat(copy.getConnectionCustomizerClassName()).isEqualTo("com.example.ConnectionCustomizer");
          assertThat(copy.getContextClassLoaderSource()).isEqualTo("library");
          assertThat(copy.getFactoryClassLocation()).isEqualTo("file:/tmp/c3p0-test/");
          assertThat(copy.getOverrideDefaultUser()).isEqualTo("override-user");
          assertThat(copy.getOverrideDefaultPassword()).isEqualTo("override-password");
          assertThat(copy.getPreferredTestQuery()).isEqualTo("SELECT 1");
          assertThat(copy.getNestedDataSource()).isInstanceOf(DriverManagerDataSource.class);
  
          DriverManagerDataSource nestedCopy = (DriverManagerDataSource) copy.getNestedDataSource();
          assertThat(nestedCopy.getJdbcUrl()).isEqualTo("jdbc:c3p0-test:direct");
          assertThat(nestedCopy.getUser()).isEqualTo("direct-user");
          assertThat(nestedCopy.getPassword()).isEqualTo("direct-password");
      }
  
      @Test
      void serializesAndDeserializesReferenceableNestedDataSourceIndirectly() throws Exception {
          WrapperConnectionPoolDataSource dataSource = configuredWrapper("indirect-wrapper");
          WrapperConnectionPoolDataSourceBaseTest nestedDataSource = new WrapperConnectionPoolDataSourceBaseTest();
          nestedDataSource.setToken("indirect-token");
          dataSource.setNestedDataSource(nestedDataSource);
  
          String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
          System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());
          try {
              WrapperConnectionPoolDataSource copy = roundTrip(dataSource);
  
              assertThat(copy.getIdentityToken()).isEqualTo("indirect-wrapper");
              assertThat(copy.getNestedDataSource()).isInstanceOf(WrapperConnectionPoolDataSourceBaseTest.class);
              WrapperConnectionPoolDataSourceBaseTest nestedCopy =
                      (WrapperConnectionPoolDataSourceBaseTest) copy.getNestedDataSource();
              assertThat(nestedCopy.getToken()).isEqualTo("indirect-token");
          } finally {
              if (previousWhitelist == null) {
                  System.clearProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
              } else {
                  System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, previousWhitelist);
              }
          }
      }
  
      public String getToken() {
          return token;
      }
  
      public void setToken(String token) {
          this.token = token;
      }
  
      @Override
      public Reference getReference() throws NamingException {
          Reference reference = new Reference(getClass().getName(), JavaBeanObjectFactory.class.getName(), null);
          reference.add(new StringRefAddr("token", token));
          return reference;
      }
  
      @Override
      public Connection getConnection() throws SQLException {
          throw new SQLException(UNSUPPORTED_MESSAGE);
      }
  
      @Override
