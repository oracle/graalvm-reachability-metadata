  assertThat(copy.getOverrideDefaultUser()).isEqualTo(\"override-user\");\n        assertThat(copy.getOverrideDefaultPassword()).isEqualTo(\"override-password\");\n        assertThat(copy.getPreferredTestQuery()).isEqualTo(\"SELECT 1\");\n        assertThat(copy.getNestedDataSource()).isInstanceOf(DriverManagerDataSource.class);\n\n        DriverManagerDataSource nestedCopy = (DriverManagerDataSource) copy.getNestedDataSource();\n        assertThat(nestedCopy.getJdbcUrl()).isEqualTo(\"jdbc:c3p0-test:direct\");\n        assertThat(nestedCopy.getUser()).isEqualTo(\"direct-user\");\n        assertThat(nestedCopy.getPassword()).isEqualTo(\"direct-password\");\n    }\n\n    @Test\n    void serializesAndDeserializesReferenceableNestedDataSourceIndirectly() throws Exception {\n        WrapperConnectionPoolDataSource dataSource = configuredWrapper(\"indirect-wrapper\");\n        WrapperConnectionPoolDataSourceBaseTest nestedDataSource = new WrapperConnectionPoolDataSourceBaseTest();\n        nestedDataSource.setToken(\"indirect-token\");\n        dataSource.setNestedDataSource(nestedDataSource);\n\n        String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n        System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());\n        try {\n            WrapperConnectionPoolDataSource copy = roundTrip(dataSource);\n\n            assertThat(copy.getIdentityToken()).isEqualTo(\"indirect-wrapper\");\n            assertThat(copy.getNestedDataSource()).isInstanceOf(WrapperConnectionPoolDataSourceBaseTest.class);\n            WrapperConnectionPoolDataSourceBaseTest nestedCopy =\n                    (WrapperConnectionPoolDataSourceBaseTest) copy.getNestedDataSource();\n            assertThat(nestedCopy.getToken()).isEqualTo(\"indirect-token\");\n        } finally {\n            if (previousWhitelist == null) {\n                System.clearProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n            } else {\n             