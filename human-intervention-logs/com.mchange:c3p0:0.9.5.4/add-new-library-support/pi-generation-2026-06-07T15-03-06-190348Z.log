ect\");\n        ReferenceableJndiName jndiName = new ReferenceableJndiName();\n        jndiName.setName(\"java:comp/env/jdbc/indirect\");\n        dataSource.setJndiName(jndiName);\n\n        String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n        System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());\n        try {\n            JndiRefDataSourceBase copy = roundTrip(dataSource);\n\n            assertThat(copy.isCaching()).isFalse();\n            assertThat(copy.getFactoryClassLocation()).isEqualTo(\"file:/tmp/indirect/\");\n            assertThat(copy.getIdentityToken()).isEqualTo(\"indirect-token\");\n            assertThat(copy.getJndiEnv()).containsEntry(\"java.naming.factory.initial\", \"indirect.InitialContextFactory\");\n            assertThat(copy.getJndiName()).isInstanceOf(ReferenceableJndiName.class);\n\n            ReferenceableJndiName copiedJndiName = (ReferenceableJndiName) copy.getJndiName();\n            assertThat(copiedJndiName.getName()).isEqualTo(\"java:comp/env/jdbc/indirect\");\n        } finally {\n            restoreWhitelist(previousWhitelist);\n        }\n    }\n\n    private static JndiRefDataSourceBase configuredDataSource(String name) throws Exception {\n        JndiRefDataSourceBase dataSource = new JndiRefDataSourceBase(false);\n        dataSource.setCaching(false);\n        dataSource.setFactoryClassLocation(\"file:/tmp/\" + name + \"/\");\n        dataSource.setIdentityToken(name + \"-token\");\n        dataSource.setJndiEnv(jndiEnv(name));\n        return dataSource;\n    }\n\n    private static Hashtable<String, String> jndiEnv(String name) {\n        Hashtable<String, String> jndiEnv = new Hashtable<>();\n        jndiEnv.put(\"java.naming.factory.initial\", name + \".InitialContextFactory\");\n        return jndiEnv;\n    }\n\n    private static JndiRefDataSourceBase roundTrip(JndiRefDataSourceBase dataSource)\n            throws IOException, ClassNotFound