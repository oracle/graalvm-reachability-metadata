    WrapperConnectionPoolDataSource dataSource = new WrapperConnectionPoolDataSource(false);\n        dataSource.setIdentityToken(identityToken);\n        dataSource.setAcquireIncrement(3);\n        dataSource.setAcquireRetryAttempts(4);\n        dataSource.setAcquireRetryDelay(5);\n        dataSource.setAutoCommitOnClose(true);\n        dataSource.setAutomaticTestTable(\"TEST_CONNECTIONS\");\n        dataSource.setBreakAfterAcquireFailure(true);\n        dataSource.setCheckoutTimeout(6);\n        dataSource.setConnectionCustomizerClassName(\"com.example.ConnectionCustomizer\");\n        dataSource.setContextClassLoaderSource(\"library\");\n        dataSource.setDebugUnreturnedConnectionStackTraces(true);\n        dataSource.setFactoryClassLocation(\"file:/tmp/c3p0-test/\");\n        dataSource.setForceIgnoreUnresolvedTransactions(true);\n        dataSource.setForceSynchronousCheckins(true);\n        dataSource.setIdleConnectionTestPeriod(7);\n        dataSource.setInitialPoolSize(1);\n        dataSource.setMaxAdministrativeTaskTime(8);\n        dataSource.setMaxConnectionAge(9);\n        dataSource.setMaxIdleTime(10);\n        dataSource.setMaxIdleTimeExcessConnections(11);\n        dataSource.setMaxPoolSize(12);\n        dataSource.setMaxStatements(13);\n        dataSource.setMaxStatementsPerConnection(14);\n        dataSource.setMinPoolSize(1);\n        dataSource.setOverrideDefaultPassword(\"override-password\");\n        dataSource.setOverrideDefaultUser(\"override-user\");\n        dataSource.setPreferredTestQuery(\"SELECT 1\");\n        dataSource.setPrivilegeSpawnedThreads(true);\n        dataSource.setPropertyCycle(15);\n        dataSource.setStatementCacheNumDeferredCloseThreads(1);\n        dataSource.setTestConnectionOnCheckin(true);\n        dataSource.setTestConnectionOnCheckout(true);\n        dataSource.setUnreturnedConnectionTimeout(16);\n        dataSource.setUsesTraditionalReflectiveProxies(false);\n        return dataSource;\n    }\n\n    private static WrapperConnectionPoolDataSource roundTrip(WrapperConnectionPoolDataSource dataSource)\n            throws IOException, ClassNotFoundException {\n        byte[] serialized = serialize(dataSource);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (WrapperConnectionPoolDataSource) objectInputStream.readObject();\n        }\n    }\n\n    private static byte[] serialize(WrapperConnectionPoolDataSource dataSource) throws IOException {\n        ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteArrayOutputStream)) {\n            objectOutputStream.writeObject(dataSource);\n        }\n        return byteArrayOutputStream.toByteArray();\n    }\n}\n"}], "isError": false, "timestamp": 1780844523195}, {"role": "toolResult", "toolCallId": "call_OCegbruVYzMDkn9hv0nC40BS|fc_03bc1a33febe2134016a2587e946888196b1da8395f23f09d0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.ComboPooledDataSource;\nimport com.mchange.v2.c3p0.management.DynamicPooledDataSourceManagerMBean;\nimport java.util.Arrays;\nimport javax.management.Attribute;\nimport javax.management.MBeanAttributeInfo;\nimport javax.management.MBeanInfo;\nimport javax.management.MBeanServer;\nimport javax.management.MBeanServerFactory;\nimport javax.management.ObjectName;\nimport org.junit.jupiter.api.Test;\n\npublic class DynamicPooledDataSourceManagerMBeanTest {\n    @Test\n    void exposesAttributesAndOperationsForComboPooledDataSource() throws Exception {\n        MBeanServer mBeanServer = MBeanServerFactory.newMBeanServer();\n        ComboPooledDataSource dataSource = new ComboPooledDataSource(false);\n        String token = \"dynamicPdsManagerMBean\" + Long.toUnsignedString(System.nanoTime());\n        String objectNameString = \"com.mchange.v2.c3p0:type=PooledDataSource,identityToken=\" + token\n                + \",name=\" + token;\n        ObjectName objectName = new ObjectName(objectNameString);\n\n        try {\n            dataSource.setIdentityToken(token);\n            dataSource.setDataSourceName(token);\n            dataSource.setCheckoutTimeout(250);\n\n            new DynamicPooledDataSourceManagerMBean(dataSource, objectNameString, mBeanServer);\n\n            assertThat(mBeanServer.isRegistered(objectName)).isTrue();\n\n            MBeanInfo mBeanInfo = mBeanServer.getMBeanInfo(objectName);\n            assertThat(Arrays.stream(mBeanInfo.getAttributes())\n                            .map(MBeanAttributeInfo::getName))\n                    .contains(\"checkoutTimeout\");\n            assertThat(mBeanServer.getAttribute(objectName, \"checkoutTimeout\")).isEqualTo(250);\n\n            mBeanServer.setAttribute(objectName, new Attribute(\"checkoutTimeout\", 500));\n\n            assertThat(dataSource.getCheckoutTimeout()).isEqualTo(500);\n            assertThat(mBeanServer.getAttribute(objectName, \"checkoutTimeout\")).isEqualTo(500);\n            assertThat(mBeanServer.invoke(objectName, \"close\", new Object[0], new String[0])).isNull();\n        } finally {\n            if (mBeanServer.isRegistered(objectName)) {\n                mBeanServer.unregisterMBean(objectName);\n            }\n            dataSource.close();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780844523196}, {"role": "toolResult", "toolCallId": "call_wi69yEG31vO1QlQWa3MDumMM|fc_03bc1a33febe2134016a2587e9468c81968f28eef54adafaa5", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"rules\" : [\n    {\n      \"excludeClasses\" : \"**\"\n    },\n    {\n