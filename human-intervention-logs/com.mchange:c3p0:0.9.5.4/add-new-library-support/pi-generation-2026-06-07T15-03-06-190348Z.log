  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.ComboPooledDataSource;
  import com.mchange.v2.c3p0.management.DynamicPooledDataSourceManagerMBean;
  import java.util.Arrays;
  import javax.management.Attribute;
  import javax.management.MBeanAttributeInfo;
  import javax.management.MBeanInfo;
  import javax.management.MBeanServer;
  import javax.management.MBeanServerFactory;
  import javax.management.ObjectName;
  import org.junit.jupiter.api.Test;
  
  public class DynamicPooledDataSourceManagerMBeanTest {
      @Test
      void exposesAttributesAndOperationsForComboPooledDataSource() throws Exception {
          MBeanServer mBeanServer = MBeanServerFactory.newMBeanServer();
          ComboPooledDataSource dataSource = new ComboPooledDataSource(false);
          String token = "dynamicPdsManagerMBean" + Long.toUnsignedString(System.nanoTime());
          String objectNameString = "com.mchange.v2.c3p0:type=PooledDataSource,identityToken=" + token
                  + ",name=" + token;
          ObjectName objectName = new ObjectName(objectNameString);
  
          try {
              dataSource.setIdentityToken(token);
              dataSource.setDataSourceName(token);
              dataSource.setCheckoutTimeout(250);
  
              new DynamicPooledDataSourceManagerMBean(dataSource, objectNameString, mBeanServer);
  
              assertThat(mBeanServer.isRegistered(objectName)).isTrue();
  
              MBeanInfo mBeanInfo = mBeanServer.getMBeanInfo(objectName);
              assertThat(Arrays.stream(mBeanInfo.getAttributes())
                              .map(MBeanAttributeInfo::getName))
                      .contains("checkoutTimeout");
              assertThat(mBeanServer.getAttribute(objectName, "checkoutTimeout")).isEqualTo(250);
  
              mBeanServer.setAttribute(objectName, new Attribute("checkoutTimeout", 500));
  
              assertThat(dataSource.getCheckoutTimeout()).isEqualTo(500);
              assertThat(mBeanServer.getAttribute(objectName, "checkoutTimeout")).isEqualTo(500);
              assertThat(mBeanServer.invoke(objectName, "close", new Object[0], new String[0])).isNull();
          } finally {
              if (mBeanServer.isRegistered(objectName)) {
                  mBeanServer.unregisterMBean(objectName);
              }
              dataSource.close();
          }
      }
  }
