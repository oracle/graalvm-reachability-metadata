ntln(\"This is just a placeholder, implement your test\");\n    }\n}\n"}], "isError": false, "timestamp": 1780844479272}, {"role": "toolResult", "toolCallId": "call_If9OSz1aav4MrCNAYXZ8hD0I|fc_03bc1a33febe2134016a2587bf109481969debebb43fe0b8e5", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.PoolBackedDataSource;\nimport com.mchange.v2.cfg.PropertiesConfig;\nimport com.mchange.v2.naming.JavaBeanObjectFactory;\nimport com.mchange.v2.ser.IndirectlySerialized;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.PrintWriter;\nimport java.io.Serializable;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.AbstractMap;\nimport java.util.Collections;\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.logging.Logger;\nimport javax.naming.NamingException;\nimport javax.naming.Reference;\nimport javax.naming.Referenceable;\nimport javax.naming.StringRefAddr;\nimport javax.sql.ConnectionPoolDataSource;\nimport javax.sql.PooledConnection;\nimport org.junit.jupiter.api.Test;\n\npublic class PoolBackedDataSourceBaseTest {\n    private static final String OBJECT_FACTORY_WHITELIST_PROPERTY =\n            \"com.mchange.v2.naming.objectFactoryWhitelist\";\n    private static final String UNSUPPORTED_MESSAGE = \"Test ConnectionPoolDataSource does not create connections.\";\n\n    @Test\n    void serializesAndDeserializesDirectlySerializableConnectionPoolDataSource() throws Exception {\n        PoolBackedDataSource dataSource = configuredDataSource(\"direct-pool\", serializableConnectionPoolDataSource());\n\n        PoolBackedDataSource copy = roundTrip(dataSource);\n\n        assertThat(copy.getDataSourceName()).isEqualTo(\"direct-pool-name\");\n        assertThat(copy.getFactoryClassLocation()).isEqualTo(\"file:/tmp/direct-pool/\");\n        assertThat(copy.getIdentityToken()).isEqualTo(\"direct-pool-token\");\n        assertThat(copy.getNumHelperThreads()).isEqualTo(3);\n        assertThat(copy.getExtensions()).containsEntry(\"purpose\", \"direct-pool\");\n        assertThat(copy.getConnectionPoolDataSource()).isInstanceOf(SerializableConnectionPoolDataSource.class);\n\n        SerializableConnectionPoolDataSource connectionPoolDataSource =\n                (SerializableConnectionPoolDataSource) copy.getConnectionPoolDataSource();\n        assertThat(connectionPoolDataSource.getToken()).isEqualTo(\"serializable-cpds\");\n    }\n\n    @Test\n    void serializesAndDeserializesReferenceableConnectionPoolDataSourceIndirectly() throws Exception {\n        PoolBackedDataSource dataSource = configuredDataSource(\n                \"indirect-pool\", referenceableConnectionPoolDataSource());\n\n        String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n        System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());\n        try {\n            PoolBackedDataSource copy = roundTrip(dataSource);\n\n            assertThat(copy.getDataSourceName()).isEqualTo(\"indirect-pool-name\");\n            assertThat(copy.getFactoryClassLocation()).isEqualTo(\"file:/tmp/indirect-pool/\");\n            assertThat(copy.getIdentityToken()).isEqualTo(\"indirect-pool-token\");\n            assertThat(copy.getNumHelperThreads()).isEqualTo(3);\n            assertThat(copy.getExtensions()).containsEntry(\"purpose\", \"indirect-pool\");\n            assertThat(copy.getConnectionPoolDataSource()).isInstanceOf(ReferenceableConnectionPoolDataSource.class);\n\n            ReferenceableConnectionPoolDataSource connectionPoolDataSource =\n                    (ReferenceableConnectionPoolDataSource) copy.getConnectionPoolDataSource();\n            assertThat(connectionPoolDataSource.getToken()).isEqualTo(\"referenceable-cpds\");\n        } finally {\n            restoreWhitelist(previousWhitelist);\n        }\n    }\n\n    @Test\n    void serializesAndDeserializesReferenceableExtensionsIndirectly() throws Exception {\n        PoolBackedDataSource dataSource = configuredDataSource(\n                \"indirect-extensions-pool\", serializableConnectionPoolDataSource());\n\n        String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n        System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());\n        try {\n            byte[] seededBytes = serializeReplacingExtensions(dataSource);\n            PoolBackedDataSource seededDataSource = deserialize(seededBytes);\n\n            assertThat(seededDataSource.getExtensions())\n                    .containsEntry(\"purpose\", \"indirect-extensions-pool\");\n\n            PoolBackedDataSource copy = roundTrip(seededDataSource);\n\n            assertThat(copy.getDataSourceName()).isEqualTo(\"indirect-extensions-pool-name\");\n            assertThat(copy.getFactoryClassLocation()).isEqualTo(\"file:/tmp/indirect-extensions-pool/\");\n            assertThat(copy.getIdentityToken()).isEqualTo(\"indirect-extensions-pool-token\");\n            assertThat(copy.getNumHelperThreads()).isEqualTo(3);\n            assertThat(copy.getExtensions()).containsEntry(\"purpose\", \"indirect-extensions-pool\");\n            assertThat(copy.getConnectionPoolDataSource()).isInstanceOf(SerializableConnectionPoolDataSource.class);\n        } finally {\n            restoreWhitelist(previousWhitelist);\n        }\n    }\n\n    private static PoolBackedDataSource configuredDataSource(\n            String name, ConnectionPoolDataSource connectionPoolDataSource) throws Exception {\n        PoolBackedDataSource dataSource = new PoolBackedDataSource(false);\n        dataSource.setConnectionPoolDataSource(connectionPoolDataSource);\n        dataSource.setDataSourceName(name + \"-name\");\n        dataSource.setExtensions(extensions(name));\n        dataSource.setFactoryClassLocation(\"file:/tmp/\" + name + \"/\");\n        dataSource.setIdentityToken(name + \"-token\");\n        dataSource.setNumHelperThreads(3);\n        return dataSource;\n    }\n\n    private static Map<String, String> extensions(String purpose) {\n        Map<String, String> extensions = new HashMap<>();\n        extensions.put(\"purpose\", purpose);\n        return extensions;\n    }\n\n    private static SerializableConnectionPoolDataSource serializableConnectionPoolDataSource() {\n        SerializableConnectionPoolDataSource dataSource = new SerializableConnectionPoolDataSource();\n        dataSource.setToken(\"serializable-cpds\");\n        return dataSource;\n    }\n\n    private static ReferenceableConnectionPoolDataSource referenceableConnectionPoolDataSource() {\n        ReferenceableConnectionPoolDataSource dataSource = new ReferenceableConnectionPoolDataSource();\n        dataSource.setToken(\"referenceable-cpds\");\n        return dataSource;\n    }\n\n    private static PoolBackedDataSource roundTrip(PoolBackedDataSource dataSource)\n            throws IOException, ClassNotFoundException {\n        byte[] serialized = serialize(dataSource);\n        return deserialize(serialized);\n    }\n\n    private static PoolBackedDataSource deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (PoolBackedDataSource) objectInputStream.readObject();\n        }\n    }\n\n    private static byte[] serialize(PoolBackedDataSource dataSource) throws IOException {\n        ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteArrayOutputStream)) {\n            objectOutputStream.writeObject(dataSource);\n        }\n        return byteArrayOutputStream.toByteArray();\n    }\n\n    private static byte[] serializeReplacingExtensions(PoolBackedDataSource dataSource) throws IOException {\n        ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();\n        try (ExtensionReplacingObjectOutputStream objectOutputStream =\n                new ExtensionReplacingObjectOutputStream(byteArrayOutputStream)) {\n            objectOutputStream.writeObject(dataSource);\n        }\n        return byteArrayOutputStream.toByteArray();\n    }\n\n    private static void restoreWhitelist(String previousWhitelist) {\n        if (previousWhitelist == null) {\n            System.clearProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n        } else {\n            System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, previousWhitelist);\n        }\n    }\n\n    public static class ExtensionReplacingObjectOutputStream extends ObjectOutputStream {\n        public ExtensionReplacingObjectOutputStream(ByteArrayOutputStream out) throws IOException {\n            super(out);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) throws IOException {\n            if (object instanceof Map<?, ?> map && \"indirect-extensions-pool\".equals(map.get(\"purpose\"))) {\n                return new SerializedExtensions(\"indirect-extensions-pool\");\n            }\n            return super.replaceObject(object);\n        }\n    }\n\n    public static class SerializedExtensions implements IndirectlySerialized {\n        private static final long serialVersionUID = 1L;\n\n        private final String purpose;\n\n        public SerializedExtensions(String purpose) {\n            this.purpose = purpose;\n        }\n\n        @Override\n        public Object getObject() {\n            return new ReferenceableExtensions(purpose);\n        }\n\n        public Object getObject(PropertiesConfig propertiesConfig) {\n            return getObject();\n        }\n    }\n\n    public static class ReferenceableExtensions extends AbstractMap<String, String> implements Referenceable {\n        private String purpose;\n\n        public ReferenceableExtensions() {\n        }\n\n        public ReferenceableExtensions(String purpose) {\n            this.purpose = purpose;\n        }\n\n        public String getPurpose() {\n            return purpose;\n        }\n\n        public void setPurpose(String purpose) {\n            this.purpose = purpose;\n        }\n\n        @Override\n        public Set<Entry<String, String>> entrySet() {\n            return Collections.singleton(new SimpleImmutableEntry<>(\"purpose\", purpose));\n        }\n\n        @Override\n        public Reference getReference() throws NamingException {\n            Reference reference = new Reference(getClass().getName(), JavaBeanObjectFactory.class.getName(), null);\n            reference.add(new StringRefAddr(\"purpose\", purpose));\n            return reference;\n        }\n    }\n\n    public static class SerializableConnectionPoolDataSource\n            extends TestConnectionPoolDataSource implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private String token;\n\n        @Override\n        public String getToken() {\n            return token;\n        }\n\n        @Override\n        public void setToken(String token) {\n            this.token = token;\n        }\n    }\n\n    public static class ReferenceableConnectionPoolDataSource\n            extends TestConnectionPoolDataSource implements Referenceable {\n        private String token;\n\n        @Override\n        public String getToken() {\n            return token;\n        }\n\n        @Override\n        public void setToken(String token) {\n            this.token = token;\n        }\n\n        @Override\n        public Reference getReference() throws NamingException {\n            Reference reference = new Reference(getClass().getName(), JavaBeanObjectFactory.class.getName(), null);\n            reference.add(new StringRefAddr(\"token\", getToken()));\n            return reference;\n        }\n    }\n\n    public abstract static class TestConnectionPoolDataSource implements ConnectionPoolDataSource {\n        public abstract String getToken();\n\n        public abstract void setToken(String token);\n\n        @Override\n        public PooledConnection getPooledConnection() throws SQLException {\n            throw new SQLException(UNSUPPORTED_MESSAGE);\n        }\n\n        @Override\n        public PooledConnection getPooledConnection(String user, String password) throws SQLException {\n            throw new SQLException(UNSUPPORTED_MESSAGE);\n        }\n\n        @Override\n        public PrintWriter getLogWriter() throws SQLException {\n            throw new SQLException(UNSUPPORTED_MESSAGE);\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) throws SQLException {\n            throw new SQLException(UNSUPPORTED_MESSAGE);\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) throws SQLException {\n            throw new SQLException(UNSUPPORTED_MESSAGE);\n        }\n\n        @Override\n        public int getLoginTimeout() throws SQLException {\n            throw new SQLException(UNSUPPORTED_MESSAGE);\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException(UNSUPPORTED_MESSAGE);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780844479273}, {"role": "toolResult", "toolCallId": "call_Riwxff6dESqsJ8GMh4zlG4rB|fc_03bc1a33febe2134016a2587bf10a08196ab8d1b1d9df0edd8", "toolName": "read", "content": [{"