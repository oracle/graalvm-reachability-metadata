      private static class AttrRec
      {
          Object target;
          MBeanAttributeInfo attrInfo;
      
          AttrRec(Object target, MBeanAttributeInfo attrInfo)
          {
              this.target = target;
              this.attrInfo = attrInfo;
          }
      }
  
