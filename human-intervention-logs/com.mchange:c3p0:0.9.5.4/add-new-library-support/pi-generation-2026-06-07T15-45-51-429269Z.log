  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.impl.JndiRefDataSourceBase;
  import com.mchange.v2.naming.JavaBeanObjectFactory;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.Hashtable;
  import javax.naming.NamingException;
  import javax.naming.Reference;
  import javax.naming.Referenceable;
  import javax.naming.StringRefAddr;
  import org.junit.jupiter.api.Test;
  
  public class JndiRefDataSourceBaseTest {
      private static final String OBJECT_FACTORY_WHITELIST_PROPERTY =
              "com.mchange.v2.naming.objectFactoryWhitelist";
  
      @Test
      void serializesAndDeserializesSerializableJndiNameDirectly() throws Exception {
          JndiRefDataSourceBase dataSource = configuredDataSource("direct");
          dataSource.setJndiName("java:comp/env/jdbc/direct");
  
          JndiRefDataSourceBase copy = roundTrip(dataSource);
  
          assertThat(copy.isCaching()).isFalse();
          assertThat(copy.getFactoryClassLocation()).isEqualTo("file:/tmp/direct/");
          assertThat(copy.getIdentityToken()).isEqualTo("direct-token");
          assertThat(copy.getJndiEnv())
                  .containsEntry("java.naming.factory.initial", "direct.InitialContextFactory");
          assertThat(copy.getJndiName()).isEqualTo("java:comp/env/jdbc/direct");
      }
  
      @Test
      void serializesAndDeserializesReferenceableJndiNameIndirectly() throws Exception {
          JndiRefDataSourceBase dataSource = configuredDataSource("indirect");
          ReferenceableJndiName jndiName = new ReferenceableJndiName();
          jndiName.setName("java:comp/env/jdbc/indirect");
          dataSource.setJndiName(jndiName);
  
          String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
          System.setProperty(
                  OBJECT_FACTORY_WHITELIST_PROPERTY,
                  JavaBeanObjectFactory.class.getName());
          try {
              JndiRefDataSourceBase copy = roundTrip(dataSource);
  
              assertThat(copy.isCaching()).isFalse();
              assertThat(copy.getFactoryClassLocation()).isEqualTo("file:/tmp/indirect/");
              assertThat(copy.getIdentityToken()).isEqualTo("indirect-token");
              assertThat(copy.getJndiEnv())
                      .containsEntry("java.naming.factory.initial", "indirect.InitialContextFactory");
              assertThat(copy.getJndiName()).isInstanceOf(ReferenceableJndiName.class);
  
              ReferenceableJndiName copiedJndiName = (ReferenceableJndiName) copy.getJndiName();
              assertThat(copiedJndiName.getName()).isEqualTo("java:comp/env/jdbc/indirect");
          } finally {
              restoreWhitelist(previousWhitelist);
          }
      }
  
      private static JndiRefDataSourceBase configuredDataSource(String name) throws Exception {
          JndiRefDataSourceBase dataSource = new JndiRefDataSourceBase(false);
          dataSource.setCaching(false);
          dataSource.setFactoryClassLocation("file:/tmp/" + name + "/");
          dataSource.setIdentityToken(name + "-token");
          dataSource.setJndiEnv(jndiEnv(name));
          return dataSource;
      }
  
      private static Hashtable<String, String> jndiEnv(String name) {
          Hashtable<String, String> jndiEnv = new Hashtable<>();
          jndiEnv.put("java.naming.factory.initial", name + ".InitialContextFactory");
          return jndiEnv;
      }
  
      private static JndiRefDataSourceBase roundTrip(JndiRefDataSourceBase dataSource)
              throws IOException, ClassNotFoundException {
          byte[] serialized = serialize(dataSource);
          try (ObjectInputStream objectInputStream =
                  new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (JndiRefDataSourceBase) objectInputStream.readObject();
          }
      }
  
      private static byte[] serialize(JndiRefDataSourceBase dataSource) throws IOException {
          ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream =
                  new ObjectOutputStream(byteArrayOutputStream)) {
              objectOutputStream.writeObject(dataSource);
          }
          return byteArrayOutputStream.toByteArray();
      }
  
      private static void restoreWhitelist(String previousWhitelist) {
          if (previousWhitelist == null) {
              System.clearProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
          } else {
              System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, previousWhitelist);
          }
      }
  
      public static class ReferenceableJndiName implements Referenceable {
          private String name;
  
          public ReferenceableJndiName() {
          }
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          @Override
          public Reference getReference() throws NamingException {
              Reference reference = new Reference(
                      getClass().getName(),
                      JavaBeanObjectFactory.class.getName(),
                      null);
              reference.add(new StringRefAddr("name", name));
              return reference;
          }
      }
  }
