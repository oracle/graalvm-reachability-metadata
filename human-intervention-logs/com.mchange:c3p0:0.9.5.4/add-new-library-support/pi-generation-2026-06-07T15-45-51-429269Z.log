[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/C3P0JavaBeanObjectFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.DriverManagerDataSource;\nimport com.mchange.v2.c3p0.impl.C3P0JavaBeanObjectFactory;\nimport java.util.UUID;\nimport javax.naming.Reference;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0JavaBeanObjectFactoryTest {\n    @Test\n    void createsIdentityTokenizedBeanFromReferenceUsingBooleanConstructor() throws Exception {\n        DriverManagerDataSource original = new DriverManagerDataSource(false);\n        original.setIdentityToken(\"factory-test-\" + UUID.randomUUID());\n        original.setDescription(\"factory description\");\n        original.setJdbcUrl(\"jdbc:c3p0-test:factory\");\n        original.setUser(\"factory-user\");\n        original.setPassword(\"factory-password\");\n\n        Reference reference = original.getReference();\n        Object restoredObject = new C3P0JavaBeanObjectFactory()\n                .getObjectInstance(reference, null, null, null);\n\n        assertThat(restoredObject).isInstanceOf(DriverManagerDataSource.class);\n        DriverManagerDataSource restored = (DriverManagerDataSource) restoredObject;\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored.getIdentityToken()).isEqualTo(original.getIdentityToken());\n        assertThat(restored.getDescription()).isEqualTo(\"factory description\");\n        assertThat(restored.getJdbcUrl()).isEqualTo(\"jdbc:c3p0-test:factory\");\n        assertThat(restored.getUser()).isEqualTo(\"factory-user\");\n        assertThat(restored.getPassword()).isEqualTo(\"factory-password\");\n    }\n}\n"}
