  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.ConnectionCustomizer;
  import com.mchange.v2.c3p0.impl.WrapperConnectionPoolDataSourceBase;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.PrintWriter;
  import java.io.Serializable;
  import java.sql.Connection;
  import java.sql.SQLException;
  import java.sql.SQLFeatureNotSupportedException;
  import java.util.logging.Logger;
  import javax.naming.NamingException;
  import javax.naming.Reference;
  import javax.naming.Referenceable;
  import javax.sql.DataSource;
  import javax.sql.PooledConnection;
  import org.junit.jupiter.api.Test;
  
  public class WrapperConnectionPoolDataSourceBaseTest {
      @Test
      void serializationRoundTripReadsAndWritesBaseState() throws Exception {
          TestWrapperConnectionPoolDataSource original = new TestWrapperConnectionPoolDataSource();
          original.setAcquireIncrement(7);
          original.setAutomaticTestTable("SERIALIZATION_TEST_TABLE");
          original.setConnectionCustomizerClassName("example.ConnectionCustomizer");
          original.setContextClassLoaderSource("library");
          original.setFactoryClassLocation("file:/tmp/c3p0-test");
          original.setIdentityToken("wrapper-connection-pool-data-source-base-test");
          original.setOverrideDefaultPassword("test-password");
          original.setOverrideDefaultUser("test-user");
          original.setPreferredTestQuery("SELECT 1");
          original.setMaxPoolSize(12);
          original.setMinPoolSize(3);
          original.setTestConnectionOnCheckout(true);
          original.setNestedDataSource(new SerializableDataSource());
  
          byte[] serialized = serialize(original);
          TestWrapperConnectionPoolDataSource restored = deserialize(
                  serialized,
                  TestWrapperConnectionPoolDataSource.class);
  
          assertThat(restored.getAcquireIncrement()).isEqualTo(7);
          assertThat(restored.getAutomaticTestTable()).isEqualTo("SERIALIZATION_TEST_TABLE");
          assertThat(restored.getConnectionCustomizerClassName()).isEqualTo("example.ConnectionCustomizer");
          assertThat(restored.getContextClassLoaderSource()).isEqualTo("library");
          assertThat(restored.getFactoryClassLocation()).isEqualTo("file:/tmp/c3p0-test");
          assertThat(restored.getIdentityToken()).isEqualTo("wrapper-connection-pool-data-source-base-test");
          assertThat(restored.getOverrideDefaultPassword()).isEqualTo("test-password");
          assertThat(restored.getOverrideDefaultUser()).isEqualTo("test-user");
          assertThat(restored.getPreferredTestQuery()).isEqualTo("SELECT 1");
          assertThat(restored.getMaxPoolSize()).isEqualTo(12);
          assertThat(restored.getMinPoolSize()).isEqualTo(3);
          assertThat(restored.isTestConnectionOnCheckout()).isTrue();
          assertThat(restored.getNestedDataSource()).isInstanceOf(SerializableDataSource.class);
      }
  
      @Test
      void serializationWritesIndirectReferenceForNonSerializableNestedDataSource() throws Exception {
          TestWrapperConnectionPoolDataSource original = new TestWrapperConnectionPoolDataSource();
          original.setNestedDataSource(new ReferenceableDataSource());
  
          byte[] serialized = serialize(original);
  
          assertThat(serialized).isNotEmpty();
      }
  
      private static byte[] serialize(TestWrapperConnectionPoolDataSource dataSource) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(dataSource);
          }
          return bytes.toByteArray();
      }
  
      private static <T> T deserialize(byte[] serialized, Class<T> type) throws IOException, ClassNotFoundException {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              Object restored = input.readObject();
              assertThat(restored).isInstanceOf(type);
              return type.cast(restored);
          }
      }
  
      private static final class TestWrapperConnectionPoolDataSource extends WrapperConnectionPoolDataSourceBase {
          private static final long serialVersionUID = 1L;
  
          TestWrapperConnectionPoolDataSource() {
              super(false);
          }
  
          @Override
          protected PooledConnection getPooledConnection(ConnectionCustomizer connectionCustomizer, String identityToken)
                  throws SQLException {
              throw new SQLFeatureNotSupportedException("Connections are not needed for serialization coverage.");
          }
  
          @Override
          protected PooledConnection getPooledConnection(
                  String user,
                  String password,
                  ConnectionCustomizer connectionCustomizer,
                  String identityToken) throws SQLException {
              throw new SQLFeatureNotSupportedException("Connections are not needed for serialization coverage.");
          }
      }
  
      private abstract static class UnsupportedDataSource implements DataSource {
          protected UnsupportedDataSource() {
          }
  
          @Override
          public Connection getConnection() throws SQLException {
              throw new SQLFeatureNotSupportedException("Connections are not needed for serialization coverage.");
          }
  
          @Override
          public Connection getConnection(String username, String password) throws SQLException {
              throw new SQLFeatureNotSupportedException("Connections are not needed for serialization coverage.");
          }
  
          @Override
