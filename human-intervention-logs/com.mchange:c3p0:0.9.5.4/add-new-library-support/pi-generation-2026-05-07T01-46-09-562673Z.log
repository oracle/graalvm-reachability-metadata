[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/DynamicPooledDataSourceManagerMBeanTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.ComboPooledDataSource;\nimport com.mchange.v2.c3p0.management.DynamicPooledDataSourceManagerMBean;\nimport java.util.Set;\nimport javax.management.Attribute;\nimport javax.management.MBeanAttributeInfo;\nimport javax.management.MBeanInfo;\nimport javax.management.MBeanServer;\nimport javax.management.MBeanServerFactory;\nimport javax.management.ObjectName;\nimport org.junit.jupiter.api.Test;\n\npublic class DynamicPooledDataSourceManagerMBeanTest {\n    @Test\n    void dynamicMBeanReadsWritesAndInvokesPooledDataSourceMembers() throws Exception {\n        ComboPooledDataSource dataSource = new ComboPooledDataSource(false);\n        MBeanServer mBeanServer = MBeanServerFactory.createMBeanServer(\"c3p0-test\");\n        try {\n            dataSource.setDataSourceName(\"DynamicPooledDataSourceManagerMBeanInitial\");\n\n            DynamicPooledDataSourceManagerMBean manager = new DynamicPooledDataSourceManagerMBean(\n                    dataSource,\n                    \"com.mchange.v2.c3p0:type=PooledDataSource,name=placeholder\",\n                    mBeanServer);\n\n            MBeanInfo info = manager.getMBeanInfo();\n            assertThat(info.getConstructors()).hasSize(1);\n            assertThat(info.getOperations()).isNotEmpty();\n            assertThat(info.getAttributes())\n                    .extracting(MBeanAttributeInfo::getName)\n                    .contains(\"dataSourceName\");\n\n            assertThat(manager.getAttribute(\"dataSourceName\"))\n                    .isEqualTo(\"DynamicPooledDataSourceManagerMBeanInitial\");\n\n            manager.setAttribute(new Attribute(\"dataSourceName\", \"DynamicPooledDataSourceManagerMBeanUpdated\"));\n\n            assertThat(manager.getAttribute(\"dataSourceName\"))\n                    .isEqualTo(\"DynamicPooledDataSourceManagerMBeanUpdated\");\n            assertThat(manager.invoke(\"getDataSourceName\", new Object[0], new String[0]))\n                    .isEqualTo(\"DynamicPooledDataSourceManagerMBeanUpdated\");\n        } finally {\n            unregisterManagedDataSources(mBeanServer);\n            MBeanServerFactory.releaseMBeanServer(mBeanServer);\n            dataSource.close();\n        }\n    }\n\n    private static void unregisterManagedDataSources(MBeanServer mBeanServer) throws Exception {\n        ObjectName pooledDataSources = new ObjectName(\"com.mchange.v2.c3p0:type=PooledDataSource,*\");\n        Set<ObjectName> names = mBeanServer.queryNames(pooledDataSources, null);\n        for (ObjectName name : names) {\n            if (mBeanServer.isRegistered(name)) {\n                mBeanServer.unregisterMBean(name);\n            }\n        }\n    }\n}\n"}
