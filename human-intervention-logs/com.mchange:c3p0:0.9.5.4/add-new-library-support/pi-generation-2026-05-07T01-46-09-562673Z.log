  			    wcheckDs1.setFactoryClassLocation( strval );
  			    DataSource checkDs2 = wcheckDs1.getNestedDataSource();
  			    if (checkDs2 instanceof DriverManagerDataSource)
  				((DriverManagerDataSource) checkDs2).setFactoryClassLocation( strval );
