  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.util.TestUtils;
  import java.io.PrintWriter;
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.sql.Connection;
  import java.sql.SQLException;
  import java.sql.SQLFeatureNotSupportedException;
  import java.util.logging.Logger;
  import javax.sql.DataSource;
  import org.junit.jupiter.api.Test;
  
  public class TestUtilsInnerStupidDataSourceInvocationHandlerTest {
      @Test
      void wrapsConnectionsAndDelegatesOtherDataSourceMethods() throws Exception {
          RecordingDataSource target = new RecordingDataSource();
          target.setLoginTimeout(3);
  
          DataSource wrapped = TestUtils.unreliableCommitDataSource(target);
  
          assertThat(wrapped.getLoginTimeout()).isEqualTo(3);
          wrapped.setLoginTimeout(5);
          assertThat(target.getLoginTimeout()).isEqualTo(5);
  
          Connection connection = wrapped.getConnection();
          try {
              assertThat(target.getConnectionCalls()).isEqualTo(1);
              assertThat(connection).isInstanceOf(Connection.class);
              assertThat(connection).isNotSameAs(target.getLastConnection());
          } finally {
              connection.close();
          }
      }
  
      private static final class RecordingDataSource implements DataSource {
          private int loginTimeout;
          private int getConnectionCalls;
          private PrintWriter logWriter;
          private Connection lastConnection;
  
          int getConnectionCalls() {
              return getConnectionCalls;
          }
  
          Connection getLastConnection() {
              return lastConnection;
          }
  
          @Override
          public Connection getConnection() {
              getConnectionCalls++;
              lastConnection = newConnection();
              return lastConnection;
          }
  
          @Override
          public Connection getConnection(String username, String password) {
              return getConnection();
          }
  
          @Override
          public PrintWriter getLogWriter() {
              return logWriter;
          }
  
          @Override
          public void setLogWriter(PrintWriter out) {
              logWriter = out;
          }
  
          @Override
          public void setLoginTimeout(int seconds) {
              loginTimeout = seconds;
          }
  
          @Override
          public int getLoginTimeout() {
              return loginTimeout;
          }
  
          @Override
          public Logger getParentLogger() throws SQLFeatureNotSupportedException {
              throw new SQLFeatureNotSupportedException("No parent logger");
          }
  
          @Override
          public <T> T unwrap(Class<T> iface) throws SQLException {
              if (iface.isInstance(this)) {
                  return iface.cast(this);
              }
              throw new SQLException("Not a wrapper for " + iface.getName());
          }
  
          @Override
          public boolean isWrapperFor(Class<?> iface) {
              return iface.isInstance(this);
          }
  
          private Connection newConnection() {
              return Connection.class.cast(Proxy.newProxyInstance(
                      TestUtilsInnerStupidDataSourceInvocationHandlerTest.class.getClassLoader(),
                      new Class<?>[] {Connection.class},
                      new RecordingConnection()));
          }
      }
  
      private static final class RecordingConnection implements InvocationHandler {
          private boolean closed;
  
          @Override
          public Object invoke(Object proxy, Method method, Object[] args) {
              String methodName = method.getName();
              if (method.getDeclaringClass() == Object.class) {
                  return handleObjectMethod(proxy, methodName, args);
              }
              if ("close".equals(methodName)) {
                  closed = true;
                  return null;
              }
              if ("isClosed".equals(methodName)) {
                  return closed;
              }
              return defaultValue(method.getReturnType());
          }
  
          private Object handleObjectMethod(Object proxy, String methodName, Object[] args) {
              if ("toString".equals(methodName)) {
                  return "RecordingConnection";
              }
              if ("hashCode".equals(methodName)) {
                  return System.identityHashCode(proxy);
              }
              if ("equals".equals(methodName)) {
                  return args != null && args.length == 1 && proxy == args[0];
              }
              throw new UnsupportedOperationException(methodName);
          }
  
          private Object defaultValue(Class<?> returnType) {
              if (returnType == Void.TYPE) {
                  return null;
              }
              if (!returnType.isPrimitive()) {
                  return null;
              }
              if (returnType == Boolean.TYPE) {
                  return false;
              }
              if (returnType == Character.TYPE) {
                  return '\0';
              }
              if (returnType == Byte.TYPE) {
                  return (byte) 0;
              }
              if (returnType == Short.TYPE) {
                  return (short) 0;
              }
              if (returnType == Integer.TYPE) {
                  return 0;
              }
              if (returnType == Long.TYPE) {
                  return 0L;
              }
              if (returnType == Float.TYPE) {
                  return 0F;
              }
              if (returnType == Double.TYPE) {
                  return 0D;
              }
              throw new IllegalArgumentException("Unsupported primitive type " + returnType);
          }
      }
  }
