  public class DriverManagerDataSourceTest {
      private static final String JDBC_URL = "jdbc:c3p0-test:driver-manager-data-source";
  
      @BeforeEach
      void setUp() throws SQLException {
          RecordingDriver.reset();
          RecordingDriver.register();
      }
  
      @AfterEach
      void tearDown() throws SQLException {
          RecordingDriver.deregister();
      }
  
      @Test
      void loadsConfiguredDriverClassBeforeUsingDriverManager() throws Exception {
          DriverManagerDataSource dataSource = configuredDataSource(false);
          dataSource.setUser("driver-manager-user");
          dataSource.setPassword("driver-manager-password");
  
          try (Connection connection = dataSource.getConnection()) {
              assertThat(connection).isNotNull();
          }
  
          assertThat(RecordingDriver.connectCalls()).isEqualTo(1);
          assertThat(RecordingDriver.lastUrl()).isEqualTo(JDBC_URL);
          assertThat(RecordingDriver.lastProperties())
                  .containsEntry("user", "driver-manager-user")
                  .containsEntry("password", "driver-manager-password");
      }
  
      @Test
      void instantiatesConfiguredDriverWhenNamedDriverClassIsForced() throws Exception {
          DriverManagerDataSource dataSource = configuredDataSource(true);
  
          try (Connection connection = dataSource.getConnection("forced-user", "forced-password")) {
              assertThat(connection).isNotNull();
          }
  
          assertThat(RecordingDriver.constructed()).isGreaterThanOrEqualTo(1);
          assertThat(RecordingDriver.connectCalls()).isEqualTo(1);
          assertThat(RecordingDriver.lastUrl()).isEqualTo(JDBC_URL);
          assertThat(RecordingDriver.lastProperties())
                  .containsEntry("user", "forced-user")
                  .containsEntry("password", "forced-password");
      }
  
      private DriverManagerDataSource configuredDataSource(boolean forceUseNamedDriverClass) {
          DriverManagerDataSource dataSource = new DriverManagerDataSource(false);
          dataSource.setDriverClass(RecordingDriver.class.getName());
          dataSource.setJdbcUrl(JDBC_URL);
          dataSource.setForceUseNamedDriverClass(forceUseNamedDriverClass);
          return dataSource;
      }
  
