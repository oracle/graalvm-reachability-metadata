  import java.util.logging.Logger;
  import javax.naming.Reference;
  import javax.naming.Referenceable;
  import javax.sql.ConnectionPoolDataSource;
  import javax.sql.PooledConnection;
  import org.junit.jupiter.api.Test;
  
  public class PoolBackedDataSourceBaseTest {
      private static final String OBJECT_FACTORY_WHITELIST_PROPERTY =
              "com.mchange.v2.naming.objectFactoryWhitelist";
  
      @Test
      void serializesAndDeserializesPoolBackedConfiguration() throws Exception {
          String identityToken = "pool-backed-token-serializable";
          PoolBackedDataSource source = configuredPoolBackedDataSource(identityToken);
          source.setConnectionPoolDataSource(new SerializableConnectionPoolDataSource("serializable-cpds"));
  
          PoolBackedDataSource restored = roundTrip(source);
  
          assertThat(restored.getDataSourceName()).isEqualTo("test pool backed data source");
          assertThat(restored.getFactoryClassLocation()).isEqualTo("file:/tmp/c3p0-pool-factory/");
          assertThat(restored.getIdentityToken()).isEqualTo(identityToken);
          assertThat(restored.getNumHelperThreads()).isEqualTo(3);
          assertThat(restored.getExtensions()).containsEntry("applicationName", "pool-backed-test");
          assertThat(restored.getConnectionPoolDataSource())
                  .isInstanceOfSatisfying(
                          SerializableConnectionPoolDataSource.class,
                          dataSource -> assertThat(dataSource.getName()).isEqualTo("serializable-cpds"));
      }
  
      @Test
      void serializesReferenceableConnectionPoolDataSourceIndirectlyWhenItIsNotSerializable() throws Exception {
          PoolBackedDataSource source = configuredPoolBackedDataSource("pool-backed-token-indirect-cpds");
          source.setConnectionPoolDataSource(new ReferenceableConnectionPoolDataSource());
  
          byte[] serialized = serialize(source);
  
          assertThat(serialized).isNotEmpty();
          assertThatThrownBy(() -> serialize(source.getConnectionPoolDataSource())).isInstanceOf(IOException.class);
      }
  
      @Test
      void serializesIndirectlyRestoredReferenceableExtensionsIndirectly() throws Exception {
          PoolBackedDataSource source = configuredPoolBackedDataSource("pool-backed-token-indirect-extensions");
          source.setConnectionPoolDataSource(new SerializableConnectionPoolDataSource("indirect-extensions-cpds"));
  
          byte[] serialized = serializeReplacingExtensions(source, new ReferenceableExtensions());
          PoolBackedDataSource restored = deserializeWithObjectFactoryWhitelist(serialized);
  
          assertThat(restored.getExtensions()).isEmpty();
          assertThat(serialize(restored)).isNotEmpty();
      }
  
      private static PoolBackedDataSource configuredPoolBackedDataSource(String identityToken) {
          PoolBackedDataSource source = new PoolBackedDataSource(false);
          source.setDataSourceName("test pool backed data source");
          source.setFactoryClassLocation("file:/tmp/c3p0-pool-factory/");
          source.setIdentityToken(identityToken);
          source.setNumHelperThreads(3);
  
          Map<String, String> extensions = new LinkedHashMap<>();
          extensions.put("applicationName", "pool-backed-test");
          source.setExtensions(extensions);
          return source;
      }
  
      private static PoolBackedDataSource roundTrip(PoolBackedDataSource source) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialize(source)))) {
              return (PoolBackedDataSource) input.readObject();
          }
      }
  
      private static byte[] serialize(Object value) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static byte[] serializeReplacingExtensions(
              PoolBackedDataSource source, ReferenceableExtensions replacementExtensions) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ExtensionReplacingObjectOutputStream(bytes, replacementExtensions)) {
              output.writeObject(source);
          }
          return bytes.toByteArray();
      }
  
      private static PoolBackedDataSource deserializeWithObjectFactoryWhitelist(byte[] serialized) throws Exception {
          String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
          System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (PoolBackedDataSource) input.readObject();
          } finally {
              if (previousWhitelist == null) {
                  System.clearProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
              } else {
                  System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, previousWhitelist);
              }
          }
      }
  
      private static final class ExtensionReplacingObjectOutputStream extends ObjectOutputStream {
          private final ReferenceableExtensions replacementExtensions;
  
          ExtensionReplacingObjectOutputStream(OutputStream output, ReferenceableExtensions replacementExtensions)
                  throws IOException {
              super(output);
              this.replacementExtensions = replacementExtensions;
              enableReplaceObject(true);
          }
  
          @Override
          protected Object replaceObject(Object object) throws IOException {
              if (object instanceof Map<?, ?> && ((Map<?, ?>) object).containsKey("applicationName")) {
                  try {
                      return new ReferenceIndirector().indirectForm(replacementExtensions);
                  } catch (Exception e) {
                      throw new IOException("Could not prepare indirect extensions for serialization.", e);
