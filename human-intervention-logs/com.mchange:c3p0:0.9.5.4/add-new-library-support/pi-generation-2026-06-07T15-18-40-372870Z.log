rride\n        public int activeCheckConnectionNoQuery(Connection connection, Throwable[] rootCauseOutParamHolder) {\n            activeChecks++;\n            return AbstractConnectionTester.CONNECTION_IS_OKAY;\n        }\n\n        static void reset() {\n            constructed = 0;\n            activeChecks = 0;\n        }\n\n        static int constructed() {\n            return constructed;\n        }\n\n        static int activeChecks() {\n            return activeChecks;\n        }\n    }\n\n    private static final class RecordingConnection implements InvocationHandler {\n        private int isValidCalls;\n\n        private Connection proxy() {\n            Object proxy = Proxy.newProxyInstance(\n                    DefaultConnectionTesterTest.class.getClassLoader(),\n                    new Class<?>[] {Connection.class},\n                    this);\n            return Connection.class.cast(proxy);\n        }\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) {\n            String methodName = method.getName();\n            if (method.getDeclaringClass() == Object.class) {\n                return handleObjectMethod(proxy, methodName, args);\n            }\n            if (\"isValid\".equals(methodName)) {\n                isValidCalls++;\n                return true;\n            }\n            return defaultValue(method.getReturnType());\n        }\n\n        private Object handleObjectMethod(Object proxy, String methodName, Object[] args) {\n            if (\"toString\".equals(methodName)) {\n                return \"RecordingConnection\";\n            }\n            if (\"hashCode\".equals(methodName)) {\n                return System.identityHashCode(proxy);\n            }\n            if (\"equals\".equals(methodName)) {\n                return proxy == args[0];\n            }\n            throw new UnsupportedOperationException(methodName);\n        }\n\n        private Object defaultValue(Class<?> returnType) {\n            if (returnType == Void.TYPE) {\n                return null;\n            }\n            if (!returnType.isPrimitive()) {\n                return null;\n            }\n            if (returnType == Boolean.TYPE) {\n                return false;\n            }\n            if (returnType == Character.TYPE) {\n                return '\\0';\n            }\n            if (returnType == Byte.TYPE) {\n                return (byte) 0;\n            }\n            if (returnType == Short.TYPE) {\n                return (short) 0;\n            }\n            if (returnType == Integer.TYPE) {\n                return 0;\n            }\n            if (returnType == Long.TYPE) {\n                return 0L;\n            }\n            if (returnType == Float.TYPE) {\n                return 0F;\n            }\n            if (returnType == Double.TYPE) {\n                return 0D;\n            }\n            throw new IllegalArgumentException(\"Unsupported primitive return type \" + returnType.getName());\n        }\n\n        private int isValidCalls() {\n            return isValidCalls;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 802, "output": 1923, "cacheRead": 20992, "cacheWrite": 0, "totalTokens": 23717, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780845454644, "responseId": "resp_001b3824cdd3966a016a258b8f2bf48197af9bef402c5ad63b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_uUEOS601bVmweqrl9gUY0uEz|fc_001b3824cdd3966a016a258b9e1d388197aeb98152e0e1cff0", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6024 bytes to tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/DefaultConnectionTesterTest.java"}], "isError": false, "timestamp": 1780845483282}]}
