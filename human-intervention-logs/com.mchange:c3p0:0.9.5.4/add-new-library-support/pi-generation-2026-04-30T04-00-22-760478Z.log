Override\n        public void attemptManagePooledDataSource(PooledDataSource pooledDataSource) {\n        }\n\n        @Override\n        public void attemptUnmanagePooledDataSource(PooledDataSource pooledDataSource) {\n        }\n    }\n}\n"}
