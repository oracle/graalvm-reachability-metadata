  	    {
  		String prop = (String) ii.next();
  		if (! C3P0Defaults.isKnownProperty( prop ) && logger.isLoggable( MLevel.WARNING ))
  		    logger.log( MLevel.WARNING, "Unknown c3p0-config property: " + prop);
  	    }
      }
  
