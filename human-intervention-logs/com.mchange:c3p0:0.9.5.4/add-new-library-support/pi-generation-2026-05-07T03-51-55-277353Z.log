[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/C3P0PooledConnectionInnerProxyConnectionInvocationHandlerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\nimport java.sql.CallableStatement;\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.Statement;\n\nimport com.mchange.v2.c3p0.C3P0ProxyConnection;\nimport com.mchange.v2.c3p0.impl.C3P0PooledConnection;\nimport com.mchange.v2.c3p0.impl.DefaultConnectionTester;\nimport org.h2.jdbcx.JdbcDataSource;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0PooledConnectionInnerProxyConnectionInvocationHandlerTest {\n    @Test\n    void proxyConnectionInvocationHandlerDelegatesConnectionOperationsReflectively() throws Exception {\n        JdbcDataSource dataSource = new JdbcDataSource();\n        dataSource.setURL(\"jdbc:h2:mem:c3p0_proxy_connection_invocation_handler;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\");\n\n        C3P0PooledConnection pooledConnection = new C3P0PooledConnection(\n                dataSource.getConnection(),\n                new DefaultConnectionTester(),\n                false,\n                false,\n                null,\n                \"c3p0-proxy-connection-invocation-handler-test\"\n        );\n\n        try {\n            Connection connection = pooledConnection.getConnection();\n            assertThat(connection).isInstanceOf(C3P0ProxyConnection.class);\n            C3P0ProxyConnection proxyConnection = (C3P0ProxyConnection) connection;\n\n            assertThat(connection.toString()).contains(\"C3P0ProxyConnection\");\n            assertThat(rawNativeSql(proxyConnection)).isEqualTo(\"SELECT 1\");\n\n            connection.setTransactionIsolation(Connection.TRANSACTION_SERIALIZABLE);\n            assertThat(connection.getTransactionIsolation()).isEqualTo(Connection.TRANSACTION_SERIALIZABLE);\n\n            String catalog = connection.getCatalog();\n            connection.setCatalog(catalog);\n            assertThat(connection.getCatalog()).isEqualTo(catalog);\n\n            int holdability = connection.getHoldability();\n            connection.setHoldability(holdability);\n            assertThat(connection.getHoldability()).isEqualTo(holdability);\n\n            try (Statement statement = connection.createStatement()) {\n                assertThat(selectOne(statement)).isEqualTo(1);\n            }\n\n            try (Statement preparedStatement = connection.prepareStatement(\"SELECT 1\")) {\n                assertThat(preparedStatement).isNotNull();\n            }\n\n            try (CallableStatement callableStatement = connection.prepareCall(\"CALL 1\")) {\n                assertThat(callableStatement.execute()).isTrue();\n            }\n\n            connection.setAutoCommit(false);\n            assertThat(connection.getAutoCommit()).isFalse();\n            connection.commit();\n            connection.close();\n        } finally {\n            pooledConnection.close();\n        }\n    }\n\n    private static String rawNativeSql(C3P0ProxyConnection proxyConnection) throws Exception {\n        Method nativeSql = Connection.class.getMethod(\"nativeSQL\", String.class);\n        return (String) proxyConnection.rawConnectionOperation(\n                nativeSql,\n                C3P0ProxyConnection.RAW_CONNECTION,\n                new Object[] {\"SELECT 1\"}\n        );\n    }\n\n    private static int selectOne(Statement statement) throws Exception {\n        try (ResultSet resultSet = statement.executeQuery(\"SELECT 1\")) {\n            assertThat(resultSet.next()).isTrue();\n            return resultSet.getInt(1);\n        }\n    }\n}\n"}
[tool-call] end id=call_Oq8e0BaDjpRJBhkkW53XqDC1|fc_0e680ab0b91b12950169fc0c0cf494819da40a36b4d3325b44 name=write args={"path": "tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/C3P0PooledConnectionInnerProxyConnectionInvocationHandlerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\nimport java.sql.CallableStatement;\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.Statement;\n\nimport com.mchange.v2.c3p0.C3P0ProxyConnection;\nimport com.mchange.v2.c3p0.impl.C3P0PooledConnection;\nimport com.mchange.v2.c3p0.impl.DefaultConnectionTester;\nimport org.h2.jdbcx.JdbcDataSource;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0PooledConnectionInnerProxyConnectionInvocationHandlerTest {\n    @Test\n    void proxyConnectionInvocationHandlerDelegatesConnectionOperationsReflectively() throws Exception {\n        JdbcDataSource dataSource = new JdbcDataSource();\n        dataSource.setURL(\"jdbc:h2:mem:c3p0_proxy_connection_invocation_handler;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\");\n\n        C3P0PooledConnection pooledConnection = new C3P0PooledConnection(\n                dataSource.getConnection(),\n                new DefaultConnectionTester(),\n                false,\n                false,\n                null,\n                \"c3p0-proxy-connection-invocation-handler-test\"\n        );\n\n        try {\n            Connection connection = pooledConnection.getConnection();\n            assertThat(connection).isInstanceOf(C3P0ProxyConnection.class);\n            C3P0ProxyConnection proxyConnection = (C3P0ProxyConnection) connection;\n\n            assertThat(connection.toString()).contains(\"C3P0ProxyConnection\")