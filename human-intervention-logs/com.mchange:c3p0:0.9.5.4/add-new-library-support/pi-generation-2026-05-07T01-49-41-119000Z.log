ass);\n\n        assertThat(restored.getDescription()).isEqualTo(\"Serialized DriverManagerDataSource\");\n        assertThat(restored.getDriverClass()).isEqualTo(\"java.lang.String\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-driver-manager-test\");\n        assertThat(restored.isForceUseNamedDriverClass()).isTrue();\n        assertThat(restored.getIdentityToken()).isEqualTo(\"driver-manager-data-source-base-test-token\");\n        assertThat(restored.getJdbcUrl()).isEqualTo(\"jdbc:test:driver-manager-data-source-base\");\n        assertThat(restored.getProperties()).containsAllEntriesOf(connectionProperties);\n\n        List<PropertyChangeEvent> events = new ArrayList<>();\n        restored.addPropertyChangeListener(events::add);\n        restored.setDriverClass(\"java.lang.Integer\");\n\n        assertThat(events)\n                .extracting(PropertyChangeEvent::getPropertyName)\n                .contains(\"driverClass\");\n    }\n\n    private static byte[] serialize(DriverManagerDataSource dataSource) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(dataSource);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static <T> T deserialize(byte[] serialized, Class<T> type) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = input.readObject();\n            assertThat(restored).isInstanceOf(type);\n            return type.cast(restored);\n        }\n    }\n}\n"}
