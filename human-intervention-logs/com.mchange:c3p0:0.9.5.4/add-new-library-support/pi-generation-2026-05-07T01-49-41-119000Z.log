  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.ComboPooledDataSource;
  import com.mchange.v2.c3p0.management.DynamicPooledDataSourceManagerMBean;
  import java.util.Set;
  import javax.management.Attribute;
  import javax.management.MBeanAttributeInfo;
  import javax.management.MBeanInfo;
  import javax.management.MBeanServer;
  import javax.management.MBeanServerFactory;
  import javax.management.ObjectName;
  import org.junit.jupiter.api.Test;
  
  public class DynamicPooledDataSourceManagerMBeanTest {
      @Test
      void dynamicMBeanReadsWritesAndInvokesPooledDataSourceMembers() throws Exception {
          ComboPooledDataSource dataSource = new ComboPooledDataSource(false);
          MBeanServer mBeanServer = MBeanServerFactory.createMBeanServer("c3p0-test");
          try {
              dataSource.setIdentityToken("DynamicPooledDataSourceManagerMBeanToken");
              dataSource.setDataSourceName("DynamicPooledDataSourceManagerMBeanInitial");
  
              DynamicPooledDataSourceManagerMBean manager = new DynamicPooledDataSourceManagerMBean(
                      dataSource,
                      "com.mchange.v2.c3p0:type=PooledDataSource,name=placeholder",
                      mBeanServer);
  
              MBeanInfo info = manager.getMBeanInfo();
              assertThat(info.getConstructors()).hasSize(1);
              assertThat(info.getOperations()).isNotEmpty();
              assertThat(info.getAttributes())
                      .extracting(MBeanAttributeInfo::getName)
                      .contains("dataSourceName");
  
              assertThat(manager.getAttribute("dataSourceName"))
                      .isEqualTo("DynamicPooledDataSourceManagerMBeanInitial");
  
              manager.setAttribute(new Attribute("dataSourceName", "DynamicPooledDataSourceManagerMBeanUpdated"));
  
              assertThat(manager.getAttribute("dataSourceName"))
                      .isEqualTo("DynamicPooledDataSourceManagerMBeanUpdated");
              assertThat(manager.invoke("getDataSourceName", new Object[0], new String[0]))
                      .isEqualTo("DynamicPooledDataSourceManagerMBeanUpdated");
          } finally {
              unregisterManagedDataSources(mBeanServer);
              MBeanServerFactory.releaseMBeanServer(mBeanServer);
              dataSource.close();
          }
      }
  
      private static void unregisterManagedDataSources(MBeanServer mBeanServer) throws Exception {
          ObjectName pooledDataSources = new ObjectName("com.mchange.v2.c3p0:type=PooledDataSource,*");
          Set<ObjectName> names = mBeanServer.queryNames(pooledDataSources, null);
          for (ObjectName name : names) {
              if (mBeanServer.isRegistered(name)) {
                  mBeanServer.unregisterMBean(name);
              }
          }
      }
  }
