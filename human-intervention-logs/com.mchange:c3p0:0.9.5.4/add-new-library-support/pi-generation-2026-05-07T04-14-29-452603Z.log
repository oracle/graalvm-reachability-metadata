  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.C3P0Registry;
  import com.mchange.v2.c3p0.ConnectionCustomizer;
  import com.mchange.v2.c3p0.ConnectionTester;
  import org.junit.jupiter.api.MethodOrderer.OrderAnnotation;
  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.TestMethodOrder;
  
  @TestMethodOrder(OrderAnnotation.class)
  public class C3P0RegistryTest {
      private static final String MANAGEMENT_COORDINATOR_PROPERTY =
              "com.mchange.v2.c3p0.management.ManagementCoordinator";
      private static final String NULL_MANAGEMENT_COORDINATOR =
              "com.mchange.v2.c3p0.management.NullManagementCoordinator";
      private static final String EXAMPLE_CONNECTION_CUSTOMIZER =
              "com.mchange.v2.c3p0.example.InitSqlConnectionCustomizer";
      private static final String EXAMPLE_CONNECTION_TESTER =
              "com.mchange.v2.c3p0.example.IsValidOnlyConnectionTester30";
  
      @Test
      @Order(1)
      void registryInitializesWithConfiguredManagementCoordinatorAndLoadsCustomStrategies() throws Exception {
          System.setProperty(MANAGEMENT_COORDINATOR_PROPERTY, NULL_MANAGEMENT_COORDINATOR);
          try {
              assertThat(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER))
                      .isInstanceOf(ConnectionTester.class)
                      .hasSameClassAs(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER));
              assertThat(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER))
                      .isInstanceOf(ConnectionCustomizer.class)
                      .hasSameClassAs(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER));
          } finally {
              System.clearProperty(MANAGEMENT_COORDINATOR_PROPERTY);
          }
      }
  
      @Test
      @Order(2)
      void registryInitializesWithDefaultManagementCoordinatorAndLoadsCustomStrategies() throws Exception {
          System.clearProperty(MANAGEMENT_COORDINATOR_PROPERTY);
  
          assertThat(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER))
                  .isInstanceOf(ConnectionTester.class)
                  .hasSameClassAs(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER));
          assertThat(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER))
                  .isInstanceOf(ConnectionCustomizer.class)
                  .hasSameClassAs(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER));
      }
  }
