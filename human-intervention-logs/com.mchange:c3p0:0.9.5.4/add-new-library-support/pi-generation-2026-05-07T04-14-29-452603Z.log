[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/C3P0ConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.cfg.C3P0Config;\nimport com.mchange.v2.c3p0.cfg.C3P0ConfigFinder;\nimport com.mchange.v2.c3p0.cfg.C3P0ConfigUtils;\nimport com.mchange.v2.cfg.MultiPropertiesConfig;\nimport java.util.HashMap;\nimport java.util.Properties;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0ConfigTest {\n    private static final String FINDER_PROPERTY = \"com.mchange.v2.c3p0.cfg.finder\";\n    private static final String CONFIGURED_PROPERTY = \"maxPoolSize\";\n    private static final String CONFIGURED_VALUE = \"7\";\n\n    @Test\n    void refreshMainConfigLoadsConfiguredFinderReflectively() {\n        Properties properties = new Properties();\n        properties.setProperty(FINDER_PROPERTY, TestConfigFinder.class.getName());\n        MultiPropertiesConfig overrideConfig = MultiPropertiesConfig.fromProperties(\"test-c3p0-config\", properties);\n\n        try {\n            C3P0Config.refreshMainConfig(new MultiPropertiesConfig[] {overrideConfig}, \"test finder override\");\n\n            assertThat(C3P0Config.getUnspecifiedUserProperty(CONFIGURED_PROPERTY, null)).isEqualTo(CONFIGURED_VALUE);\n        } finally {\n            C3P0Config.refreshMainConfig();\n        }\n    }\n\n    @Test\n    void bindUserOverridesAsStringInvokesPublicSetterReflectively() throws Exception {\n        UserOverridesBean bean = new UserOverridesBean();\n\n        C3P0Config.bindUserOverridesAsString(bean, \"serialized-overrides\");\n\n        assertThat(bean.userOverridesAsString()).isEqualTo(\"serialized-overrides\");\n    }\n\n    public static final class TestConfigFinder implements C3P0ConfigFinder {\n        @Override\n        public C3P0Config findConfig() {\n            HashMap<String, String> flatDefaults = new HashMap<>();\n            flatDefaults.put(CONFIGURED_PROPERTY, CONFIGURED_VALUE);\n            return C3P0ConfigUtils.configFromFlatDefaults(flatDefaults);\n        }\n    }\n\n    public static final class UserOverridesBean {\n        private String userOverridesAsString;\n\n        public void setUserOverridesAsString(String userOverridesAsString) {\n            this.userOverridesAsString = userOverridesAsString;\n        }\n\n        String userOverridesAsString() {\n            return userOverridesAsString;\n        }\n    }\n}\n"}
