on()).isEqualTo(\"file:/tmp/c3p0-jndi-ref-test\");\n        assertThat(restored.getIdentityToken()).isEqualTo(\"jndi-ref-data-source-base-test-token\");\n        assertThat(restored.getJndiEnv()).containsAllEntriesOf(jndiEnv);\n        assertThat(restored.getJndiName()).isEqualTo(\"jdbc/c3p0/jndi-ref-data-source-base-test\");\n\n        List<PropertyChangeEvent> events = new ArrayList<>();\n        restored.addPropertyChangeListener(events::add);\n        restored.setCaching(true);\n\n        assertThat(events)\n                .extracting(PropertyChangeEvent::getPropertyName)\n                .contains(\"caching\");\n    }\n\n    @Test\n    void serializationWritesIndirectReferenceForNonSerializableJndiName() throws Exception {\n        JndiRefDataSourceBase original = new JndiRefDataSourceBase(false);\n        original.setFactoryClassLocation(\"file:/tmp/c3p0-jndi-ref-indirect-test\");\n        original.setIdentityToken(\"jndi-ref-data-source-base-indirect-test-token\");\n        original.setJndiName(new ReferenceableJndiName());\n\n        byte[] serialized = serialize(original);\n\n        assertThat(serialized).isNotEmpty();\n    }\n\n    private static byte[] serialize(JndiRefDataSourceBase dataSource) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(dataSource);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static <T> T deserialize(byte[] serialized, Class<T> type) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = input.readObject();\n            assertThat(restored).isInstanceOf(type);\n            return type.cast(restored);\n        }\n    }\n\n    private static final class ReferenceableJndiName implements Referenceable {\n        @Override\n        public Reference getReference() throws NamingException {\n            return new Reference(ReferenceableJndiName.class.getName());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2738, "output": 1428, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 41030, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778126152989, "responseId": "resp_04dc5b7042b6521a0169fc0d4973848194a76a14b4a67117cc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_GfrdSENHijEV1x7sy5uenorC|fc_04dc5b7042b6521a0169fc0d4fd80c8194891dc5bce749cff0", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3832 bytes to tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/JndiRefDataSourceBaseTest.java"}], "isError": false, "timestamp": 1778126167282}]}
