ndirect-test-token\");\n\n        byte[] serialized = serialize(original);\n\n        assertThat(serialized).isNotEmpty();\n    }\n\n    @Test\n    void serializationWritesIndirectReferenceForNonSerializableExtensions() throws Exception {\n        PoolBackedDataSourceBase original = new PoolBackedDataSourceBase(false);\n        Map<String, String> serializableExtensions = new HashMap<>();\n        serializableExtensions.put(\"replacement\", \"indirect-reference\");\n        original.setExtensions(serializableExtensions);\n        original.setIdentityToken(\"pool-backed-data-source-base-indirect-extensions-test-token\");\n\n        byte[] withIndirectExtensions = serializeWithReplacement(\n                original,\n                original.getExtensions(),\n                new IndirectlySerializedExtensionMap());\n        PoolBackedDataSourceBase restored = deserialize(withIndirectExtensions, PoolBackedDataSourceBase.class);\n\n        byte[] serialized = serialize(restored);\n\n        assertThat(serialized).isNotEmpty();\n    }\n\n    @Test\n    void serializationRejectsNonSerializableExtensionValues() {\n        PoolBackedDataSourceBase original = new PoolBackedDataSourceBase(false);\n        Map<String, Object> extensions = new HashMap<>();\n        extensions.put(\"nonSerializableReference\", new ReferenceableExtensionValue());\n        original.setExtensions(extensions);\n\n        assertThatThrownBy(() -> serialize(original))\n                .isInstanceOf(IOException.class)\n                .hasMessageContaining(\"Problem indirectly serializing extensions\");\n    }\n\n    private static byte[] serialize(PoolBackedDataSourceBase dataSource) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(dataSource);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serializeWithReplacement(\n   