  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.ConnectionTester;
  import com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;
  import java.beans.PropertyVetoException;
  import java.sql.Connection;
  import org.junit.jupiter.api.Test;
  
  public class WrapperConnectionPoolDataSourceTest {
      @Test
      void configuresConnectionTesterByClassName() throws PropertyVetoException {
          RecordingConnectionTester.reset();
          WrapperConnectionPoolDataSource dataSource = new WrapperConnectionPoolDataSource(false);
  
          dataSource.setConnectionTesterClassName(RecordingConnectionTester.class.getName());
  
          assertThat(dataSource.getConnectionTesterClassName())
                  .isEqualTo(RecordingConnectionTester.class.getName());
          assertThat(RecordingConnectionTester.constructed()).isEqualTo(1);
      }
  
      public static class RecordingConnectionTester implements ConnectionTester {
          private static int constructed;
  
          public RecordingConnectionTester() {
              constructed++;
          }
  
          @Override
          public int activeCheckConnection(Connection connection) {
              return CONNECTION_IS_OKAY;
          }
  
          @Override
          public int statusOnException(Connection connection, Throwable throwable) {
              return CONNECTION_IS_INVALID;
          }
  
          @Override
          public boolean equals(Object object) {
              return object instanceof RecordingConnectionTester;
          }
  
          @Override
          public int hashCode() {
              return RecordingConnectionTester.class.hashCode();
          }
  
          static void reset() {
              constructed = 0;
          }
  
          static int constructed() {
              return constructed;
          }
      }
  }
