[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/C3P0PooledConnectionPoolManagerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.PoolBackedDataSource;\nimport com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0PooledConnectionPoolManagerTest {\n    @Test\n    void initializesPoolManagerFromConnectionPoolDataSourceBeanProperties() throws Exception {\n        WrapperConnectionPoolDataSource connectionPoolDataSource = new WrapperConnectionPoolDataSource(false);\n        connectionPoolDataSource.setContextClassLoaderSource(\"caller\");\n        connectionPoolDataSource.setMaxAdministrativeTaskTime(0);\n        connectionPoolDataSource.setPrivilegeSpawnedThreads(false);\n        connectionPoolDataSource.setStatementCacheNumDeferredCloseThreads(0);\n        connectionPoolDataSource.setUserOverridesAsString(null);\n\n        PoolBackedDataSource dataSource = new PoolBackedDataSource(false);\n        dataSource.setConnectionPoolDataSource(connectionPoolDataSource);\n        dataSource.setNumHelperThreads(1);\n\n        try {\n            assertThat(dataSource.getThreadPoolSize()).isEqualTo(1);\n            assertThat(dataSource.getStatementDestroyerNumThreads()).isEqualTo(-1);\n        } finally {\n            dataSource.close();\n        }\n    }\n}\n"}
