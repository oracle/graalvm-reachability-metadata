  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.AbstractConnectionCustomizer;
  import com.mchange.v2.c3p0.AbstractConnectionTester;
  import com.mchange.v2.c3p0.C3P0Registry;
  import com.mchange.v2.c3p0.ConnectionCustomizer;
  import com.mchange.v2.c3p0.ConnectionTester;
  import com.mchange.v2.c3p0.PooledDataSource;
  import com.mchange.v2.c3p0.management.ManagementCoordinator;
  import com.mchange.v2.log.MLog;
  import java.io.File;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.file.Path;
  import java.security.CodeSource;
  import java.sql.Connection;
  import java.util.Arrays;
  import java.util.LinkedHashSet;
  import java.util.Set;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class C3P0RegistryTest {
      private static final String MANAGEMENT_COORDINATOR_PROPERTY =
              "com.mchange.v2.c3p0.management.ManagementCoordinator";
  
      @Test
      void createsAndCachesConnectionTesterByConfiguredClassName() {
          C3P0Registry.markConfigRefreshed();
  
          ConnectionTester tester = C3P0Registry.getConnectionTester(RecordingConnectionTester.class.getName());
          ConnectionTester cachedTester = C3P0Registry.getConnectionTester(RecordingConnectionTester.class.getName());
  
          assertThat(tester).isInstanceOf(RecordingConnectionTester.class);
          assertThat(cachedTester).isSameAs(tester);
          assertThat(tester.activeCheckConnection(null)).isEqualTo(ConnectionTester.CONNECTION_IS_OKAY);
      }
  
      @Test
      void createsAndCachesConnectionCustomizerByConfiguredClassName() throws Exception {
          ConnectionCustomizer customizer = C3P0Registry.getConnectionCustomizer(
                  RecordingConnectionCustomizer.class.getName());
          ConnectionCustomizer cachedCustomizer = C3P0Registry.getConnectionCustomizer(
                  RecordingConnectionCustomizer.class.getName());
  
          assertThat(customizer).isInstanceOf(RecordingConnectionCustomizer.class);
          assertThat(cachedCustomizer).isSameAs(customizer);
      }
  
      @Test
      void initializesConfiguredManagementCoordinatorInFreshRegistry() throws Exception {
          String previous = System.getProperty(MANAGEMENT_COORDINATOR_PROPERTY);
          System.setProperty(MANAGEMENT_COORDINATOR_PROPERTY, RecordingManagementCoordinator.class.getName());
          try {
              assertThat(initializeRegistryWithFreshClassLoader()).isEqualTo(1);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              restoreProperty(previous);
          }
      }
  
      private static int initializeRegistryWithFreshClassLoader() throws Exception {
          try (URLClassLoader classLoader = new URLClassLoader(
                  classPathUrls(),
                  ClassLoader.getPlatformClassLoader())) {
              Class<?> initializerClass = Class.forName(
                      IsolatedRegistryInitializer.class.getName(),
                      true,
                      classLoader);
              Method initialize = initializerClass.getMethod("initialize");
              try {
                  return (Integer) initialize.invoke(null);
              } catch (InvocationTargetException exception) {
                  Throwable cause = exception.getCause();
                  if (cause instanceof Error error) {
                      throw error;
                  }
                  if (cause instanceof Exception checkedException) {
                      throw checkedException;
                  }
                  throw new AssertionError(cause);
              }
          }
      }
  
      private static URL[] classPathUrls() {
          Set<URL> urls = new LinkedHashSet<>();
          addCodeSource(urls, C3P0RegistryTest.class);
          addCodeSource(urls, C3P0Registry.class);
          addCodeSource(urls, MLog.class);
          Arrays.stream(System.getProperty("java.class.path").split(File.pathSeparator))
                  .map(Path::of)
                  .map(C3P0RegistryTest::toUrl)
                  .forEach(urls::add);
          ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();
