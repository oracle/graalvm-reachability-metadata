[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/WrapperConnectionPoolDataSourceBaseTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.ConnectionCustomizer;\nimport com.mchange.v2.c3p0.impl.WrapperConnectionPoolDataSourceBase;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.PrintWriter;\nimport java.io.Serializable;\nimport java.sql.Connection;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.logging.Logger;\nimport javax.naming.NamingException;\nimport javax.naming.Reference;\nimport javax.naming.Referenceable;\nimport javax.sql.DataSource;\nimport javax.sql.PooledConnection;\nimport org.junit.jupiter.api.Test;\n\npublic class WrapperConnectionPoolDataSourceBaseTest {\n    @Test\n    void serializationRoundTripReadsAndWritesBaseState() throws Exception {\n        TestWrapperConnectionPoolDataSource original = new TestWrapperConnectionPoolDataSource();\n        original.setAcquireIncrement(7);\n        original.setAutomaticTestTable(\"SERIALIZATION_TEST_TABLE\");\n        original.setConnectionCustomizerClassName(\"example.ConnectionCustomizer\");\n        original.setContextClassLoaderSource(\"library\");\n        original.setFactoryClassLocation(\"file:/tmp/c3p0-test\");\n        original.setIdentityToken(\"wrapper-connection-pool-data-source-base-test\");\n        original.setOverrideDefaultPassword(\"test-password\");\n        original.setOverrideDefaultUser(\"test-user\");\n        original.setPreferredTestQuery(\"SELECT 1\");\n        original.setMaxPoolSize(12);\n        original.setMinPoolSize(3);\n        original.setTestConnectionOnCheckout(true);\n\n        byte[] serialized = serialize(original);\n        TestWrapperConnectionPoolDataSource restored = deserialize(\n                serialized,\n                TestWrapperConnectionPoolDataSource.class);\n\n        assertThat(restored.getAcquireIncrement()).isEqualTo(7);\n        assertThat(restored.getAutomaticTestTable()).isEqualTo(\"SERIALIZATION_TEST_TABLE\");\n        assertThat(restored.getConnectionCustomizerClassName()).isEqualTo(\"example.ConnectionCustomizer\");\n        assertThat(restored.getContextClassLoaderSource()).isEqualTo(\"library\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-test\");\n        assertThat(restored.getIdentityToken()).isEqualTo(\"wrapper-connection-pool-data-source-base-test\");\n        assertThat(restored.getOverrideDefaultPassword()).isEqualTo(\"test-password\");\n        assertThat(restored.getOverrideDefaultUser()).isEqualTo(\"test-user\");\n        assertThat(restored.getPreferredTestQuery()).isEqualTo(\"SELECT 1\");\n        assertThat(restored.getMaxPoolSize()).isEqualTo(12);\n        assertThat(restored.getMinPoolSize()).isEqualTo(3);\n        assertThat(restored.isTestConnectionOnCheckout()).isTrue();\n    }\n\n    @Test\n    void serializationWritesIndirectReferenceForNonSerializableNestedDataSource() throws Exception {\n        TestWrapperConnectionPoolDataSource original = new TestWrapperConnectionPoolDataSource();\n        original.setNestedDataSource(new ReferenceableDataSource());\n\n        byte[] serialized = serialize(original);\n\n        assertThat(serialized).isNotEmpty();\n    }\n\n    private static byte[] serialize(TestWrapperConnectionPoolDataSource dataSource) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(dataSource);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static <T> T deserialize(byte[] serialized, Class<T> type) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = input.readObject();\n            assertThat(restored).isInstanceOf(type);\n            return type.cast(restored);\n        }\n    }\n\n    private static final class TestWrapperConnectionPoolDataSource extends WrapperConnectionPoolDataSourceBase {\n        TestWrapperConnectionPoolDataSource() {\n            super(false);\n        }\n\n        @Override\n        protected PooledConnection getPooledConnection(ConnectionCustomizer connectionCustomizer, String identityToken)\n                throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Connections are not needed for serialization coverage.\");\n        }\n\n        @Override\n        protected PooledConnection getPooledConnection(\n                String user,\n                String password,\n                ConnectionCustomizer connectionCustomizer,\n                String identityToken) throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Connections are not needed for serialization coverage.\");\n        }\n    }\n\n    private static final class ReferenceableDataSource implements DataSource, Referenceable {\n        @Override\n        public Reference getReference() throws NamingException {\n            return new Reference(ReferenceableDataSource.class.getName());\n        }\n\n        @Override\n        public Connection getConnection() throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Connections are not needed for serialization coverage.\");\n        }\n\n        @Override\n        public Connection getConnection(String username, String password) throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Connections are not needed for serialization coverage.\");\n        }\n\n        @Override\n        public PrintWriter getLogWriter() throws SQLException {\n            return null;\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) throws SQLException {\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) throws SQLException {\n        }\n\n        @Override\n        public int getLoginTimeout() throws SQLException {\n            return 0;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException(\"Parent logger is not needed for serialization coverage.\");\n        }\n\n        @Override\n        public <T> T unwrap(Class<T> iface) throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Unwrapping is not needed for serialization coverage.\");\n        }\n\n        @Override\n        public boolean isWrapperFor(Class<?> iface) throws SQLException {\n            return false;\n        }\n    }\n\n    private static final class SerializableDataSource implements DataSource, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Connection getConnection() throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Connections are not needed for serialization coverage.\");\n        }\n\n        @Override\n        public Connection getConnection(String username, String password) throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Connections are not needed for serialization coverage.\");\n        }\n\n        @Override\n        public PrintWriter getLogWriter() throws SQLException {\n            return null;\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) throws SQLException {\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) throws SQLException {\n        }\n\n        @Override\n        public int getLoginTimeout() throws SQLException {\n            return 0;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException(\"Parent logger is not needed for serialization coverage.\");\n        }\n\n        @Override\n        public <T> T unwrap(Class<T> iface) throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Unwrapping is not needed for serialization coverage.\");\n        }\n\n        @Override\n        public boolean isWrapperFor(Class<?> iface) throws SQLException {\n            return false;\n        }\n    }\n}\n"}
