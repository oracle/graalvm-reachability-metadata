  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.ComboPooledDataSource;
  import com.mchange.v2.c3p0.management.DynamicPooledDataSourceManagerMBean;
  import java.util.Set;
  import javax.management.Attribute;
  import javax.management.MBeanAttributeInfo;
  import javax.management.MBeanInfo;
  import javax.management.MBeanOperationInfo;
  import javax.management.MBeanServer;
  import javax.management.MBeanServerFactory;
  import javax.management.ObjectName;
  import org.junit.jupiter.api.Test;
  
  public class DynamicPooledDataSourceManagerMBeanTest {
      @Test
      void exposesPooledDataSourceAttributesAndOperationsThroughDynamicMBean() throws Exception {
          MBeanServer server = MBeanServerFactory.createMBeanServer();
          ComboPooledDataSource dataSource = new ComboPooledDataSource(false);
          dataSource.setIdentityToken("dynamicPooledDataSourceManagerMBeanTestToken");
          dataSource.setDataSourceName("dynamicPooledDataSourceManagerMBeanTest");
          dataSource.setDescription("before-management");
  
          try {
              new DynamicPooledDataSourceManagerMBean(
                      dataSource, "com_mchange.c3p0:type=InitialDynamicPooledDataSource", server);
              ObjectName objectName = findManagedPooledDataSource(server);
  
              MBeanInfo info = server.getMBeanInfo(objectName);
              assertThat(info.getAttributes()).extracting(MBeanAttributeInfo::getName).contains("description");
              assertThat(info.getOperations()).extracting(MBeanOperationInfo::getName).contains("hardReset");
  
              assertThat(server.getAttribute(objectName, "description")).isEqualTo("before-management");
  
              server.setAttribute(objectName, new Attribute("description", "after-management"));
              assertThat(dataSource.getDescription()).isEqualTo("after-management");
  
              Object description = server.invoke(
                      objectName,
                      "getDescription",
                      new Object[0],
                      new String[0]);
              assertThat(description).isEqualTo("after-management");
          } finally {
              dataSource.close();
              MBeanServerFactory.releaseMBeanServer(server);
          }
      }
  
      private static ObjectName findManagedPooledDataSource(MBeanServer server) throws Exception {
          Set<ObjectName> objectNames = server.queryNames(
                  new ObjectName("com.mchange.v2.c3p0:type=PooledDataSource,*"), null);
          assertThat(objectNames).hasSize(1);
          return objectNames.iterator().next();
      }
  }
