[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/DriverManagerDataSourceBaseTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.DriverManagerDataSource;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.Properties;\nimport org.junit.jupiter.api.Test;\n\npublic class DriverManagerDataSourceBaseTest {\n    @Test\n    void serializesAndDeserializesDriverManagerConfiguration() throws Exception {\n        DriverManagerDataSource source = configuredDataSource();\n\n        DriverManagerDataSource restored = roundTrip(source);\n\n        assertThat(restored.getDescription()).isEqualTo(\"test driver manager data source\");\n        assertThat(restored.getDriverClass()).isEqualTo(\"com.example.Driver\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-driver-factory/\");\n        assertThat(restored.isForceUseNamedDriverClass()).isTrue();\n        assertThat(restored.getIdentityToken()).isEqualTo(\"driver-manager-token\");\n        assertThat(restored.getJdbcUrl()).isEqualTo(\"jdbc:example:database\");\n        assertThat(restored.getUser()).isEqualTo(\"dbuser\");\n        assertThat(restored.getPassword()).isEqualTo(\"secret\");\n        assertThat(restored.getProperties()).containsEntry(\"applicationName\", \"c3p0-test\");\n    }\n\n    private static DriverManagerDataSource configuredDataSource() {\n        DriverManagerDataSource source = new DriverManagerDataSource(false);\n        source.setDescription(\"test driver manager data source\");\n        source.setDriverClass(\"com.example.Driver\");\n        source.setFactoryClassLocation(\"file:/tmp/c3p0-driver-factory/\");\n        source.setForceUseNamedDriverClass(true);\n        source.setIdentityToken(\"driver-manager-token\");\n        source.setJdbcUrl(\"jdbc:example:database\");\n        source.setUser(\"dbuser\");\n        source.setPassword(\"secret\");\n\n        Properties properties = source.getProperties();\n        properties.setProperty(\"applicationName\", \"c3p0-test\");\n        source.setProperties(properties);\n        return source;\n    }\n\n    private static DriverManagerDataSource roundTrip(DriverManagerDataSource source) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialize(source)))) {\n            return (DriverManagerDataSource) input.readObject();\n        }\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n}\n"}
