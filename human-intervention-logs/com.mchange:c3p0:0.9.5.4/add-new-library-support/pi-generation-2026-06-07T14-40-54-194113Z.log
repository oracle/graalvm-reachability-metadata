  import org.junit.jupiter.api.Test;
  
  public class PoolBackedDataSourceBaseTest {
      private static final String OBJECT_FACTORY_WHITELIST_PROPERTY =
              "com.mchange.v2.naming.objectFactoryWhitelist";
      private static final String UNSUPPORTED_MESSAGE = "Test ConnectionPoolDataSource does not create connections.";
  
      @Test
      void serializesAndDeserializesDirectlySerializableConnectionPoolDataSource() throws Exception {
          PoolBackedDataSource dataSource = configuredDataSource("direct-pool", serializableConnectionPoolDataSource());
  
          PoolBackedDataSource copy = roundTrip(dataSource);
  
          assertThat(copy.getDataSourceName()).isEqualTo("direct-pool-name");
          assertThat(copy.getFactoryClassLocation()).isEqualTo("file:/tmp/direct-pool/");
          assertThat(copy.getIdentityToken()).isEqualTo("direct-pool-token");
          assertThat(copy.getNumHelperThreads()).isEqualTo(3);
          assertThat(copy.getExtensions()).containsEntry("purpose", "direct-pool");
          assertThat(copy.getConnectionPoolDataSource()).isInstanceOf(SerializableConnectionPoolDataSource.class);
  
          SerializableConnectionPoolDataSource connectionPoolDataSource =
                  (SerializableConnectionPoolDataSource) copy.getConnectionPoolDataSource();
          assertThat(connectionPoolDataSource.getToken()).isEqualTo("serializable-cpds");
      }
  
      @Test
      void serializesAndDeserializesReferenceableConnectionPoolDataSourceIndirectly() throws Exception {
          PoolBackedDataSource dataSource = configuredDataSource(
                  "indirect-pool", referenceableConnectionPoolDataSource());
  
          String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
          System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());
          try {
              PoolBackedDataSource copy = roundTrip(dataSource);
  
              assertThat(copy.getDataSourceName()).isEqualTo("indirect-pool-name");
              assertThat(copy.getFactoryClassLocation()).isEqualTo("file:/tmp/indirect-pool/");
              assertThat(copy.getIdentityToken()).isEqualTo("indirect-pool-token");
              assertThat(copy.getNumHelperThreads()).isEqualTo(3);
              assertThat(copy.getExtensions()).containsEntry("purpose", "indirect-pool");
              assertThat(copy.getConnectionPoolDataSource()).isInstanceOf(ReferenceableConnectionPoolDataSource.class);
  
              ReferenceableConnectionPoolDataSource connectionPoolDataSource =
                      (ReferenceableConnectionPoolDataSource) copy.getConnectionPoolDataSource();
              assertThat(connectionPoolDataSource.getToken()).isEqualTo("referenceable-cpds");
          } finally {
              restoreWhitelist(previousWhitelist);
          }
      }
  
      @Test
      void serializesAndDeserializesReferenceableExtensionsIndirectly() throws Exception {
          PoolBackedDataSource dataSource = configuredDataSource(
                  "indirect-extensions-pool", serializableConnectionPoolDataSource());
  
          String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
          System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());
          try {
              byte[] seededBytes = serializeReplacingExtensions(dataSource);
              PoolBackedDataSource seededDataSource = deserialize(seededBytes);
  
              assertThat(seededDataSource.getExtensions())
                      .containsEntry("purpose", "indirect-extensions-pool");
  
              PoolBackedDataSource copy = roundTrip(seededDataSource);
  
              assertThat(copy.getDataSourceName()).isEqualTo("indirect-extensions-pool-name");
              assertThat(copy.getFactoryClassLocation()).isEqualTo("file:/tmp/indirect-extensions-pool/");
              assertThat(copy.getIdentityToken()).isEqualTo("indirect-extensions-pool-token");
              assertThat(copy.getNumHelperThreads()).isEqualTo(3);
              assertThat(copy.getExtensions()).containsEntry("purpose", "indirect-extensions-pool");
              assertThat(copy.getConnectionPoolDataSource()).isInstanceOf(SerializableConnectionPoolDataSource.class);
          } finally {
              restoreWhitelist(previousWhitelist);
          }
      }
  
      private static PoolBackedDataSource configuredDataSource(
              String name, ConnectionPoolDataSource connectionPoolDataSource) throws Exception {
          PoolBackedDataSource dataSource = new PoolBackedDataSource(false);
          dataSource.setConnectionPoolDataSource(connectionPoolDataSource);
          dataSource.setDataSourceName(name + "-name");
          dataSource.setExtensions(extensions(name));
          dataSource.setFactoryClassLocation("file:/tmp/" + name + "/");
          dataSource.setIdentityToken(name + "-token");
          dataSource.setNumHelperThreads(3);
          return dataSource;
      }
  
      private static Map<String, String> extensions(String purpose) {
          Map<String, String> extensions = new HashMap<>();
          extensions.put("purpose", purpose);
          return extensions;
      }
  
      private static SerializableConnectionPoolDataSource serializableConnectionPoolDataSource() {
          SerializableConnectionPoolDataSource dataSource = new SerializableConnectionPoolDataSource();
          dataSource.setToken("serializable-cpds");
          return dataSource;
      }
  
      private static ReferenceableConnectionPoolDataSource referenceableConnectionPoolDataSource() {
          ReferenceableConnectionPoolDataSource dataSource = new ReferenceableConnectionPoolDataSource();
          dataSource.setToken("referenceable-cpds");
          return dataSource;
      }
  
      private static PoolBackedDataSource roundTrip(PoolBackedDataSource dataSource)
              throws IOException, ClassNotFoundException {
          byte[] serialized = serialize(dataSource);
          return deserialize(serialized);
      }
  
      private static PoolBackedDataSource deserialize(byte[] serialized) throws IOException, ClassNotFoundException {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (PoolBackedDataSource) objectInputStream.readObject();
          }
      }
  
      private static byte[] serialize(PoolBackedDataSource dataSource) throws IOException {
          ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteArrayOutputStream)) {
              objectOutputStream.writeObject(dataSource);
          }
          return byteArrayOutputStream.toByteArray();
      }
  
      private static byte[] serializeReplacingExtensions(PoolBackedDataSource dataSource) throws IOException {
          ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();
          try (ExtensionReplacingObjectOutputStream objectOutputStream =
                  new ExtensionReplacingObjectOutputStream(byteArrayOutputStream)) {
              objectOutputStream.writeObject(dataSource);
          }
          return byteArrayOutputStream.toByteArray();
      }
  
      private static void restoreWhitelist(String previousWhitelist) {
          if (previousWhitelist == null) {
              System.clearProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);
          } else {
              System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, previousWhitelist);
          }
      }
  
      public static class ExtensionReplacingObjectOutputStream extends ObjectOutputStream {
          public ExtensionReplacingObjectOutputStream(ByteArrayOutputStream out) throws IOException {
              super(out);
              enableReplaceObject(true);
          }
  
          @Override
          protected Object replaceObject(Object object) throws IOException {
              if (object instanceof Map<?, ?> map && "indirect-extensions-pool".equals(map.get("purpose"))) {
                  return new SerializedExtensions("indirect-extensions-pool");
              }
              return super.replaceObject(object);
          }
      }
  
      public static class SerializedExtensions implements IndirectlySerialized {
          private static final long serialVersionUID = 1L;
  
          private final String purpose;
  
          public SerializedExtensions(String purpose) {
              this.purpose = purpose;
          }
  
          @Override
          public Object getObject() {
              return new ReferenceableExtensions(purpose);
          }
  
          @Override
          public Object getObject(PropertiesConfig propertiesConfig) {
              return getObject();
          }
      }
  
      public static class ReferenceableExtensions extends AbstractMap<String, String> implements Referenceable {
          private String purpose;
  
          public ReferenceableExtensions() {
          }
  
          public ReferenceableExtensions(String purpose) {
              this.purpose = purpose;
          }
  
          public String getPurpose() {
              return purpose;
          }
  
          public void setPurpose(String purpose) {
              this.purpose = purpose;
          }
  
          @Override
          public Set<Entry<String, String>> entrySet() {
              return Collections.singleton(new SimpleImmutableEntry<>("purpose", purpose));
          }
  
          @Override
          public Reference getReference() throws NamingException {
              Reference reference = new Reference(getClass().getName(), JavaBeanObjectFactory.class.getName(), null);
              reference.add(new StringRefAddr("purpose", purpose));
              return reference;
          }
      }
  
