;\nimport java.beans.PropertyChangeEvent;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Properties;\nimport org.junit.jupiter.api.Test;\n\npublic class DriverManagerDataSourceBaseTest {\n    @Test\n    void serializationRoundTripReadsAndWritesBaseState() throws Exception {\n        DriverManagerDataSource original = new DriverManagerDataSource(false);\n        Properties connectionProperties = new Properties();\n        connectionProperties.setProperty(\"applicationName\", \"driver-manager-data-source-base-test\");\n        connectionProperties.setProperty(\"user\", \"serialized-user\");\n        connectionProperties.setProperty(\"password\", \"serialized-password\");\n\n        original.setDescription(\"Serialized DriverManagerDataSource\");\n        original.setDriverClass(\"java.lang.String\");\n        original.setFactoryClassLocation(\"file:/tmp/c3p0-driver-manager-test\");\n        original.setForceUseNamedDriverClass(true);\n        original.setIdentityToken(\"driver-manager-data-source-base-test-token\");\n        original.setJdbcUrl(\"jdbc:test:driver-manager-data-source-base\");\n        original.setProperties(connectionProperties);\n\n        byte[] serialized = serialize(original);\n        DriverManagerDataSource restored = deserialize(serialized, DriverManagerDataSource.class);\n\n        assertThat(restored.getDescription()).isEqualTo(\"Serialized DriverManagerDataSource\");\n        assertThat(restored.getDriverClass()).isEqualTo(\"java.lang.String\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-driver-manager-test\");\n        assertThat(restored.isForceUseNamedDriverClass()).isTrue();\n        assertThat(restored.getIdentityToken()).isEqualTo(\"driver-manager-data-source-base-test-token\");\n        assertThat(restored.getJdbcUrl()).isEqualTo(\"jdbc:test:driver-manager-data-source-base\");\n        assertThat(restored.getProperties()).containsAllEntriesOf(connectionProperties);\n\n        List<PropertyChangeEvent> events = new ArrayList<>();\n        restored.addPropertyChangeListener(events::add);\n        restored.setDriverClass(\"java.lang.Integer\");\n\n        assertThat(events)\n                .extracting(PropertyChangeEvent::getPropertyName)\n                .contains(\"driverClass\");\n    }\n\n    private static byte[] serialize(DriverManagerDataSource dataSource) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(dataSource);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static <T> T deserialize(byte[] serialized, Class<T> type) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = input.readObject();\n            assertThat(restored).isInstanceOf(type);\n            return type.cast(restored);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778126377774}]}
