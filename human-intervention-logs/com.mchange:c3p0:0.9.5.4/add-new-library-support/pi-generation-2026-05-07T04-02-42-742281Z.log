  DynamicPooledDataSourceManagerMBean manager = new DynamicPooledDataSourceManagerMBean(\n                    dataSource,\n                    \"com.mchange.v2.c3p0:type=PooledDataSource,name=placeholder\",\n                    mBeanServer);\n\n            MBeanInfo info = manager.getMBeanInfo();\n            assertThat(info.getConstructors()).hasSize(1);\n            assertThat(info.getOperations()).isNotEmpty();\n            assertThat(info.getAttributes())\n                    .extracting(MBeanAttributeInfo::getName)\n                    .contains(\"dataSourceName\");\n\n            assertThat(manager.getAttribute(\"dataSourceName\"))\n                    .isEqualTo(\"DynamicPooledDataSourceManagerMBeanInitial\");\n\n            manager.setAttribute(new Attribute(\"dataSourceName\", \"DynamicPooledDataSourceManagerMBeanUpdated\"));\n\n            assertThat(manager.getAttribute(\"dataSourceName\"))\n                    .isEqualTo(\"DynamicPooledDataSourceManagerMBeanUpdated\");\n            assertThat(manager.invoke(\"getDataSourceName\", new Object[0], new String[0]))\n                    .isEqualTo(\"DynamicPooledDataSourceManagerMBeanUpdated\");\n        } finally {\n            unregisterManagedDataSources(mBeanServer);\n            MBeanServerFactory.releaseMBeanServer(mBeanServer);\n            dataSource.close();\n        }\n    }\n\n    private static void unregisterManagedDataSources(MBeanServer mBeanServer) throws Exception {\n        ObjectName pooledDataSources = new ObjectName(\"com.mchange.v2.c3p0:type=PooledDataSource,*\");\n        Set<ObjectName> names = mBeanServer.queryNames(pooledDataSources, null);\n        for (ObjectName name : names) {\n            if (mBeanServer.isRegistered(name)) {\n                mBeanServer.unregisterMBean(name);\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778126449395}]}
