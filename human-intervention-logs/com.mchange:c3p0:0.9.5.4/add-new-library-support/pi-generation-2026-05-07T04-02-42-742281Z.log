com_mchange/c3p0/C3P0PooledConnectionInnerProxyConnectionInvocationHandlerTest.java", "limit": 220}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 44245, "output": 1145, "cacheRead": 7168, "cacheWrite": 0, "totalTokens": 52558, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778126692415, "responseId": "resp_0a8b8711862d4de20169fc0f65564081918a280041d127196d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_BbbY9AGz4lLiF9a7saQnaxX3|fc_0a8b8711862d4de20169fc0f80bbd08191ab1c7a02dc0124de", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.C3P0ProxyConnection;\nimport com.mchange.v2.c3p0.impl.C3P0PooledConnection;\nimport com.mchange.v2.c3p0.impl.DefaultConnectionTester;\nimport java.lang.reflect.Method;\nimport java.sql.CallableStatement;\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.Statement;\nimport org.h2.jdbcx.JdbcDataSource;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0PooledConnectionInnerProxyConnectionInvocationHandlerTest {\n    @Test\n    void proxyConnectionInvocationHandlerDelegatesConnectionOperationsReflectively() throws Exception {\n        JdbcDataSource dataSource = new JdbcDataSource();\n        dataSource.setURL(\"jdbc:h2:mem:c3p0_proxy_connection_invocation_handler;\"\n                + \"DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\");\n\n        C3P0PooledConnection pooledConnection = new C3P0PooledConnection(\n                dataSource.getConnection(),\n                new DefaultConnectionTester(),\n                false,\n                false,\n                null,\n                \"c3p0-proxy-connection-invocation-handler-test\"\n        );\n\n        try {\n            Connection connection = pooledConnection.getConnection();\n            assertThat(connection).isInstanceOf(C3P0ProxyConnection.class);\n            C3P0ProxyConnection proxyConnection = (C3P0ProxyConnection) connection;\n\n            assertThat(connection.toString()).contains(\"C3P0ProxyConnection\");\n            assertThat(rawNativeSql(proxyConnection)).isEqualTo(\"SELECT 1\");\n\n            connection.setTransactionIsolation(Connection.TRANSACTION_SERIALIZABLE);\n            assertThat(connection.getTransactionIsolation()).isEqualTo(Connection.TRANSACTION_SERIALIZABLE);\n\n            String catalog = connection.getCatalog();\n            connection.setCatalog(catalog);\n            assertThat(connection.getCatalog()).isEqualTo(catalog);\n\n            int holdability = connection.getHoldability();\n            connection.setHoldability(holdability);\n            assertThat(connection.getHoldability()).isEqualTo(holdability);\n\n            try (Statement statement = connection.createStatement()) {\n                assertThat(selectOne(statement)).isEqualTo(1);\n            }\n\n            try (Statement preparedStatement = connection.prepareStatement(\"SELECT 1\")) {\n                assertThat(preparedStatement).isNotNull();\n            }\n\n            try (CallableStatement callableStatement = connection.prepareCall(\"CALL 1\")) {\n                assertThat(callableStatement).isNotNull();\n            }\n\n            connection.setAutoCommit(false);\n            assertThat(connection.getAutoCommit()).isFalse();\n            connection.commit();\n            connection.close();\n        } finally {\n            pooledConnection.close();\n        }\n    }\n\n    private static String rawNativeSql(C3P0ProxyConnection proxyConnection) throws Exception {\n        Method nativeSql = Connection.class.getMethod(\"nativeSQL\", String.class);\n        return (String) proxyConnection.rawConnectionOperation(\n                nativeSql,\n                C3P0ProxyConnection.RAW_CONNECTION,\n                new Object[] {\"SELECT 1\"}\n        );\n    }\n\n    private static int selectOne(Statement statement) throws Exception {\n        try (ResultSet resultSet = statement.executeQuery(\"SELECT 1\")) {\n            assertThat(resultSet.next()).isTrue();\n            return resultSet.getInt(1);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778126721430}]}
