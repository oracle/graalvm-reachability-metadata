CONNECTION_CUSTOMIZER));\n        } finally {\n            System.clearProperty(MANAGEMENT_COORDINATOR_PROPERTY);\n        }\n    }\n\n    @Test\n    void registryInitializesWithDefaultManagementCoordinatorAndLoadsCustomStrategies() throws Exception {\n        System.clearProperty(MANAGEMENT_COORDINATOR_PROPERTY);\n\n        assertThat(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER))\n                .isInstanceOf(ConnectionTester.class)\n                .hasSameClassAs(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER));\n        assertThat(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER))\n                .isInstanceOf(ConnectionCustomizer.class)\n                .hasSameClassAs(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER));\n    }\n}\n"}
