wNativeSql(proxyConnection)).isEqualTo(\"SELECT 1\");\n\n            connection.setTransactionIsolation(Connection.TRANSACTION_SERIALIZABLE);\n            assertThat(connection.getTransactionIsolation()).isEqualTo(Connection.TRANSACTION_SERIALIZABLE);\n\n            String catalog = connection.getCatalog();\n            connection.setCatalog(catalog);\n            assertThat(connection.getCatalog()).isEqualTo(catalog);\n\n            int holdability = connection.getHoldability();\n            connection.setHoldability(holdability);\n            assertThat(connection.getHoldability()).isEqualTo(holdability);\n\n            try (Statement statement = connection.createStatement()) {\n                assertThat(selectOne(statement)).isEqualTo(1);\n            }\n\n            try (Statement preparedStatement = connection.prepareStatement(\"SELECT 1\")) {\n                assertThat(preparedStatement).isNotNull();\n            }\n\n            try (CallableStatement callableStatement = connection.prepareCall(\"CALL 1\")) {\n                assertThat(callableStatement).isNotNull();\n            }\n\n            connection.setAutoCommit(false);\n            assertThat(connection.getAutoCommit()).isFalse();\n            connection.commit();\n            connection.close();\n        } finally {\n            pooledConnection.close();\n        }\n    }\n\n    private static String rawNativeSql(C3P0ProxyConnection proxyConnection) throws Exception {\n        Method nativeSql = Connection.class.getMethod(\"nativeSQL\", String.class);\n        return (String) proxyConnection.rawConnectionOperation(\n                nativeSql,\n                C3P0ProxyConnection.RAW_CONNECTION,\n                new Object[] {\"SELECT 1\"}\n        );\n    }\n\n    private static int selectOne(Statement statement) throws Exception {\n        try (ResultSet resultSet = statement.executeQuery(\"SELECT 1\")) {\n            assertThat(resultSet.next()).isTrue();\n            return resultSet.getInt(1);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778126721430}}
