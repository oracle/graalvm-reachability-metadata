[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/C3P0RegistryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.C3P0Registry;\nimport com.mchange.v2.c3p0.ConnectionCustomizer;\nimport com.mchange.v2.c3p0.ConnectionTester;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0RegistryTest {\n    private static final String MANAGEMENT_COORDINATOR_PROPERTY =\n            \"com.mchange.v2.c3p0.management.ManagementCoordinator\";\n    private static final String NULL_MANAGEMENT_COORDINATOR =\n            \"com.mchange.v2.c3p0.management.NullManagementCoordinator\";\n    private static final String EXAMPLE_CONNECTION_CUSTOMIZER =\n            \"com.mchange.v2.c3p0.example.InitSqlConnectionCustomizer\";\n    private static final String EXAMPLE_CONNECTION_TESTER =\n            \"com.mchange.v2.c3p0.example.IsValidOnlyConnectionTester30\";\n\n    @Test\n    void registryInitializesWithConfiguredManagementCoordinatorAndLoadsCustomStrategies() throws Exception {\n        System.setProperty(MANAGEMENT_COORDINATOR_PROPERTY, NULL_MANAGEMENT_COORDINATOR);\n        try {\n            assertThat(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER))\n                    .isInstanceOf(ConnectionTester.class)\n                    .hasSameClassAs(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER));\n            assertThat(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER))\n                    .isInstanceOf(ConnectionCustomizer.class)\n                    .hasSameClassAs(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER));\n        } finally {\n            System.clearProperty(MANAGEMENT_COORDINATOR_PROPERTY);\n        }\n    }\n\n    @Test\n    void registryInitializesWithDefaultManagementCoordinatorAndLoadsCustomStrategies() throws Exception {\n        System.clearProperty(MANAGEMENT_COORDINATOR_PROPERTY);\n\n        assertThat(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER))\n                .isInstanceOf(ConnectionTester.class)\n                .hasSameClassAs(C3P0Registry.getConnectionTester(EXAMPLE_CONNECTION_TESTER));\n        assertThat(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER))\n                .isInstanceOf(ConnectionCustomizer.class)\n                .hasSameClassAs(C3P0Registry.getConnectionCustomizer(EXAMPLE_CONNECTION_CUSTOMIZER));\n    }\n}\n"}
