  public class C3P0PooledConnectionInnerProxyConnectionInvocationHandlerTest {
      private static final String DEFAULT_CATALOG = "DEFAULT_CATALOG";
  
      @Test
      void traditionalProxyConnectionDelegatesJdbcOperationsToPhysicalConnection() throws Exception {
          RecordingDataSource nestedDataSource = new RecordingDataSource();
          WrapperConnectionPoolDataSource poolDataSource = new WrapperConnectionPoolDataSource(false);
          poolDataSource.setNestedDataSource(nestedDataSource);
          poolDataSource.setUsesTraditionalReflectiveProxies(true);
  
