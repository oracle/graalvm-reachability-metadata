  	String[] defaults = {"/mchange-commons.properties", "/mchange-log.properties"};
  	String[] preempts = {"hocon:/reference,/application,/c3p0,/","/c3p0.properties", "/"};
  
  	return MConfig.readVmConfig( defaults, preempts );
      }
  
