          try {
              WrapperConnectionPoolDataSource copy = roundTrip(dataSource);
  
              assertThat(copy.getIdentityToken()).isEqualTo("indirect-wrapper");
              assertThat(copy.getNestedDataSource()).isInstanceOf(WrapperConnectionPoolDataSourceBaseTest.class);
              WrapperConnectionPoolDataSourceBaseTest nestedCopy =
