 private static void restoreProperty(String previous) {","newText":"    private static URL[] classPathUrls() {\n        Set<URL> urls = new LinkedHashSet<>();\n        addCodeSource(urls, C3P0RegistryTest.class);\n        addCodeSource(urls, C3P0Registry.class);\n        addCodeSource(urls, MLog.class);\n        Arrays.stream(System.getProperty(\"java.class.path\").split(File.pathSeparator))\n                .map(Path::of)\n                .map(C3P0RegistryTest::toUrl)\n                .forEach(urls::add);\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader instanceof URLClassLoader urlClassLoader) {\n            urls.addAll(Arrays.asList(urlClassLoader.getURLs()));\n        }\n        return urls.toArray(URL[]::new);\n    }\n\n    private static void addCodeSource(Set<URL> urls, Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        if (codeSource != null && codeSource.getLocation() != null) {\n            urls.add(codeSource.getLocation());\n        }\n    }\n\n    private static URL toUrl(Path path) {\n        try {\n            return path.toUri().toURL();\n        } catch (Exception exception) {\n            throw new IllegalArgumentException(\"Invalid classpath entry: \" + path, exception);\n        }\n    }\n\n    private static void restoreProperty(String previous) {"}]}
