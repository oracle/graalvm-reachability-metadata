  	catch (ParserConfigurationException e)
  	{
  	    if ( logger.isLoggable( MLevel.FINE ) )
  		logger.log(MLevel.FINE, "Attempted but failed to set presumably unsupported feature '" + featureUri + "' to " + setting + ".");
