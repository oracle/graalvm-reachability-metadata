  	    String extensionsKey = fullKey.substring( PROP_STYLE_EXTENSIONS_PFX_LEN + 1 ); 
  	    extensions.put( extensionsKey, props.get( fullKey ) );
  	}
  
  	return extensions;
      }
  
  
