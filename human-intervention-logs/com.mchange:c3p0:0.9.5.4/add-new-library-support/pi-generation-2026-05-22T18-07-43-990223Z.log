bc:c3p0-serialization-test\");\n    }\n", "newText": "    void serializesAndDeserializesWrapperConfiguration() throws Exception {\n        WrapperConnectionPoolDataSource source = configuredWrapper();\n\n        WrapperConnectionPoolDataSource restored = roundTrip(source);\n\n        assertThat(restored.getAutomaticTestTable()).isEqualTo(\"connection_check\");\n        assertThat(restored.getConnectionCustomizerClassName()).isEqualTo(\"com.example.ConnectionCustomizer\");\n        assertThat(restored.getContextClassLoaderSource()).isEqualTo(\"library\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-factory/\");\n        assertThat(restored.getIdentityToken()).isEqualTo(\"wrapper-token\");\n        assertThat(restored.getOverrideDefaultPassword()).isEqualTo(\"secret\");\n        assertThat(restored.getOverrideDefaultUser()).isEqualTo(\"dbuser\");\n        assertThat(restored.getPreferredTestQuery()).isEqualTo(\"SELECT 1\");\n        assertThat(restored.getNestedDataSource()).isNull();\n    }\n"}]}
