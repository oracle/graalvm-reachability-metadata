[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/WrapperConnectionPoolDataSourceBaseTest.java","edits":[{"oldText":"import com.mchange.v2.c3p0.DriverManagerDataSource;\nimport com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;\n","newText":"import com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;\n"},{"oldText":"    void serializesAndDeserializesWrapperWithSerializableNestedDataSource() throws Exception {\n        WrapperConnectionPoolDataSource source = configuredWrapper();\n        DriverManagerDataSource nested = new DriverManagerDataSource(false);\n        nested.setIdentityToken(\"nested-token\");\n        nested.setJdbcUrl(\"jdbc:c3p0-serialization-test\");\n        source.setNestedDataSource(nested);\n\n        WrapperConnectionPoolDataSource restored = roundTrip(source);\n\n        assertThat(restored.getAutomaticTestTable()).isEqualTo(\"connection_check\");\n        assertThat(restored.getConnectionCustomizerClassName()).isEqualTo(\"com.example.ConnectionCustomizer\");\n        assertThat(restored.getContextClassLoaderSource()).isEqualTo(\"library\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-factory/\");\n        assertThat(restored.getIdentityToken()).isEqualTo(\"wrapper-token\");\n        assertThat(restored.getOverrideDefaultPassword()).isEqualTo(\"secret\");\n        assertThat(restored.getOverrideDefaultUser()).isEqualTo(\"dbuser\");\n        assertThat(restored.getPreferredTestQuery()).isEqualTo(\"SELECT 1\");\n        assertThat(restored.getNestedDataSource()).isInstanceOf(DriverManagerDataSource.class);\n        DriverManagerDataSource restoredNested = (DriverManagerDataSource) restored.getNestedDataSource();\n        assertThat(restoredNested.getIdentityToken()).isEqualTo(\"nested-token\");\n        assertThat(restoredNested.getJdbcUrl()).isEqualTo(\"jdbc:c3p0-serialization-test\");\n    }\n","newText":"    void serializesAndDeserializesWrapperConfiguration() throws Exception {\n        WrapperConnectionPoolDataSource source = configuredWrapper();\n\n        WrapperConnectionPoolDataSource restored = roundTrip(source);\n\n        assertThat(restored.getAutomaticTestTable()).isEqualTo(\"connection_check\");\n        assertThat(restored.getConnectionCustomizerClassName()).isEqualTo(\"com.example.ConnectionCustomizer\");\n        assertThat(restored.getContextClassLoaderSource()).isEqualTo(\"library\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-factory/\");\n        assertThat(restored.getIdentityToken()).isEqualTo(\"wrapper-token\");\n        assertThat(restored.getOverrideDefaultPassword()).isEqualTo(\"secret\");\n        assertThat(restored.getOverrideDefaultUser()).isEqualTo(\"dbuser\");\n        assertThat(restored.getPreferredTestQuery()).isEqualTo(\"SELECT 1\");\n        assertThat(restored.getNestedDataSource()).isNull();\n    }\n"}]}
