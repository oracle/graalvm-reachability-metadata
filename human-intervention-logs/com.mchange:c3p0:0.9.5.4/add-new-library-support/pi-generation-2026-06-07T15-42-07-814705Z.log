r.activeCheckConnection(connection.proxy(), null, null);\n\n            assertThat(status).isEqualTo(AbstractConnectionTester.CONNECTION_IS_OKAY);\n            assertThat(connection.isValidCalls()).isEqualTo(1);\n        } finally {\n            C3P0Config.refreshMainConfig();\n        }\n    }\n\n    private static void configureQuerylessTestRunner(String runnerValue) {\n        Properties properties = new Properties();\n        properties.setProperty(QUERYLESS_TEST_RUNNER_PROPERTY, runnerValue);\n        MultiPropertiesConfig override = MultiPropertiesConfig.fromProperties(\n                \"default-connection-tester.properties\",\n                properties);\n        C3P0Config.refreshMainConfig(\n                new MultiPropertiesConfig[] {override},\n                \"default connection tester override\");\n    }\n\n    public static class RecordingQuerylessTestRunner implements DefaultConnectionTester.QuerylessTestRunner {\n        private static int constructed;\n        private static int activeChecks;\n\n        public RecordingQuerylessTestRunner() {\n            constructed++;\n        }\n\n        @Override\n        public int activeCheckConnectionNoQuery(Connection connection, Throwable[] rootCauseOutParamHolder) {\n            activeChecks++;\n            return AbstractConnectionTester.CONNECTION_IS_OKAY;\n        }\n\n        static void reset() {\n            constructed = 0;\n            activeChecks = 0;\n        }\n\n        static int constructed() {\n            return constructed;\n        }\n\n        static int activeChecks() {\n            return activeChecks;\n        }\n    }\n\n    private static final class RecordingConnection implements InvocationHandler {\n        private int isValidCalls;\n\n        private Connection proxy() {\n            Object proxy = Proxy.newProxyInstance(\n                    DefaultConnectionTesterTest.class.getClassLoader(),\n                    new Class<?>[] {Connection.class},\n                    this