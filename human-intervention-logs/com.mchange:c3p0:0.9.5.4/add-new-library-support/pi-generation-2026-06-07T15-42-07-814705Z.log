s\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.ConnectionTester;\nimport com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;\nimport java.beans.PropertyVetoException;\nimport java.sql.Connection;\nimport org.junit.jupiter.api.Test;\n\npublic class WrapperConnectionPoolDataSourceTest {\n    @Test\n    void configuresConnectionTesterByClassName() throws PropertyVetoException {\n        RecordingConnectionTester.reset();\n        WrapperConnectionPoolDataSource dataSource = new WrapperConnectionPoolDataSource(false);\n\n        dataSource.setConnectionTesterClassName(RecordingConnectionTester.class.getName());\n\n        assertThat(dataSource.getConnectionTesterClassName()).isEqualTo(RecordingConnectionTester.class.getName());\n        assertThat(RecordingConnectionTester.constructed()).isEqualTo(1);\n    }\n\n    public static class RecordingConnectionTester implements ConnectionTester {\n        private static int constructed;\n\n        public RecordingConnectionTester() {\n            constructed++;\n        }\n\n        @Override\n        public int activeCheckConnection(Connection connection) {\n            return CONNECTION_IS_OKAY;\n        }\n\n        @Override\n        public int statusOnException(Connection connection, Throwable throwable) {\n            return CONNECTION_IS_INVALID;\n        }\n\n        @Override\n        public boolean equals(Object object) {\n            return object instanceof RecordingConnectionTester;\n        }\n\n        @Override\n        public int hashCode() {\n            return RecordingConnectionTester.class.hashCode();\n        }\n\n        static void reset() {\n            constructed = 0;\n        }\n\n        static int constructed() {\n            return constructed;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usa