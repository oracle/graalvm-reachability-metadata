  package com_mchange.c3p0;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.mchange.v2.c3p0.AbstractConnectionTester;
  import com.mchange.v2.c3p0.cfg.C3P0Config;
  import com.mchange.v2.c3p0.impl.DefaultConnectionTester;
  import com.mchange.v2.cfg.MultiPropertiesConfig;
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.sql.Connection;
  import java.util.Properties;
  import org.junit.jupiter.api.Test;
  
  public class DefaultConnectionTesterTest {
      private static final String QUERYLESS_TEST_RUNNER_PROPERTY =
              "com.mchange.v2.c3p0.impl.DefaultConnectionTester.querylessTestRunner";
  
      @Test
      void loadsConfiguredQuerylessTestRunnerByClassName() {
          RecordingQuerylessTestRunner.reset();
          configureQuerylessTestRunner(RecordingQuerylessTestRunner.class.getName());
  
          try {
              DefaultConnectionTester tester = new DefaultConnectionTester();
              int status = tester.activeCheckConnection(null, null, null);
  
              assertThat(status).isEqualTo(AbstractConnectionTester.CONNECTION_IS_OKAY);
              assertThat(RecordingQuerylessTestRunner.constructed()).isGreaterThanOrEqualTo(1);
              assertThat(RecordingQuerylessTestRunner.activeChecks()).isEqualTo(1);
          } finally {
              C3P0Config.refreshMainConfig();
          }
      }
  
      @Test
      void loadsConfiguredQuerylessTestRunnerFromBuiltInStaticField() {
          RecordingConnection connection = new RecordingConnection();
          configureQuerylessTestRunner("IS_VALID");
  
          try {
              DefaultConnectionTester tester = new DefaultConnectionTester();
              int status = tester.activeCheckConnection(connection.proxy(), null, null);
  
              assertThat(status).isEqualTo(AbstractConnectionTester.CONNECTION_IS_OKAY);
              assertThat(connection.isValidCalls()).isEqualTo(1);
          } finally {
              C3P0Config.refreshMainConfig();
          }
      }
  
      private static void configureQuerylessTestRunner(String runnerValue) {
          Properties properties = new Properties();
          properties.setProperty(QUERYLESS_TEST_RUNNER_PROPERTY, runnerValue);
          MultiPropertiesConfig override = MultiPropertiesConfig.fromProperties(
                  "default-connection-tester.properties",
                  properties);
          C3P0Config.refreshMainConfig(
                  new MultiPropertiesConfig[] {override},
                  "default connection tester override");
      }
  
      public static class RecordingQuerylessTestRunner implements DefaultConnectionTester.QuerylessTestRunner {
          private static int constructed;
          private static int activeChecks;
  
          public RecordingQuerylessTestRunner() {
              constructed++;
          }
  
          @Override
          public int activeCheckConnectionNoQuery(Connection connection, Throwable[] rootCauseOutParamHolder) {
              activeChecks++;
              return AbstractConnectionTester.CONNECTION_IS_OKAY;
          }
  
          static void reset() {
              constructed = 0;
              activeChecks = 0;
          }
  
          static int constructed() {
              return constructed;
          }
  
          static int activeChecks() {
              return activeChecks;
          }
      }
  
      private static final class RecordingConnection implements InvocationHandler {
          private int isValidCalls;
  
          private Connection proxy() {
              Object proxy = Proxy.newProxyInstance(
                      DefaultConnectionTesterTest.class.getClassLoader(),
                      new Class<?>[] {Connection.class},
                      this);
              return Connection.class.cast(proxy);
          }
  
          @Override
          public Object invoke(Object proxy, Method method, Object[] args) {
              String methodName = method.getName();
              if (method.getDeclaringClass() == Object.class) {
                  return handleObjectMethod(proxy, methodName, args);
              }
              if ("isValid".equals(methodName)) {
                  isValidCalls++;
                  return true;
              }
              return defaultValue(method.getReturnType());
          }
  
          private Object handleObjectMethod(Object proxy, String methodName, Object[] args) {
              if ("toString".equals(methodName)) {
                  return "RecordingConnection";
              }
              if ("hashCode".equals(methodName)) {
                  return System.identityHashCode(proxy);
              }
              if ("equals".equals(methodName)) {
                  return proxy == args[0];
              }
              throw new UnsupportedOperationException(methodName);
          }
  
          private Object defaultValue(Class<?> returnType) {
              if (returnType == Void.TYPE) {
                  return null;
              }
              if (!returnType.isPrimitive()) {
                  return null;
              }
              if (returnType == Boolean.TYPE) {
                  return false;
              }
              if (returnType == Character.TYPE) {
                  return '\0';
              }
              if (returnType == Byte.TYPE) {
                  return (byte) 0;
              }
              if (returnType == Short.TYPE) {
                  return (short) 0;
              }
              if (returnType == Integer.TYPE) {
                  return 0;
              }
              if (returnType == Long.TYPE) {
                  return 0L;
              }
              if (returnType == Float.TYPE) {
                  return 0F;
              }
              if (returnType == Double.TYPE) {
                  return 0D;
              }
              throw new IllegalArgumentException("Unsupported primitive return type " + returnType.getName());
          }
  
          private int isValidCalls() {
              return isValidCalls;
          }
      }
  }
