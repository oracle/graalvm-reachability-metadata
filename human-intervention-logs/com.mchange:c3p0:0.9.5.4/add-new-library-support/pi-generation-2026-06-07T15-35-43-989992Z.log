static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.DriverManagerDataSource;\nimport java.lang.reflect.InvocationHandler;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Proxy;\nimport java.sql.Connection;\nimport java.sql.Driver;\nimport java.sql.DriverManager;\nimport java.sql.DriverPropertyInfo;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.Properties;\nimport java.util.logging.Logger;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class DriverManagerDataSourceTest {\n    private static final String JDBC_URL = \"jdbc:c3p0-test:driver-manager-data-source\";\n\n    @BeforeEach\n    void setUp() throws SQLException {\n        RecordingDriver.reset();\n        RecordingDriver.register();\n    }\n\n    @AfterEach\n    void tearDown() throws SQLException {\n        RecordingDriver.deregister();\n    }\n\n    @Test\n    void loadsConfiguredDriverClassBeforeUsingDriverManager() throws Exception {\n        DriverManagerDataSource dataSource = configuredDataSource(false);\n        dataSource.setUser(\"driver-manager-user\");\n        dataSource.setPassword(\"driver-manager-password\");\n\n        try (Connection connection = dataSource.getConnection()) {\n            assertThat(connection).isNotNull();\n        }\n\n        assertThat(RecordingDriver.connectCalls()).isEqualTo(1);\n        assertThat(RecordingDriver.lastUrl()).isEqualTo(JDBC_URL);\n        assertThat(RecordingDriver.lastProperties())\n                .containsEntry(\"user\", \"driver-manager-user\")\n                .containsEntry(\"password\", \"driver-manager-password\");\n    }\n\n    @Test\n    void instantiatesConfiguredDriverWhenNamedDriverClassIsForced() throws Exception {\n        DriverManagerDataSource dataSource = configuredDataSource(true);\n\n        try (Connection connection = dataSource.getConnection(\"forced-user\", \"forced-password\")) {\n            assertThat(connection).isNotNull();\n        }\n\n        assertThat(RecordingDriver.constructed()).isGreaterThanOrEqualTo(1);\n        assertThat(RecordingDriver.connectCalls()).isEqualTo(1);\n        assertThat(RecordingDriver.lastUrl()).isEqualTo(JDBC_URL);\n        assertThat(RecordingDriver.lastProperties())\n                .containsEntry(\"user\", \"forced-user\")\n                .containsEntry(\"password\", \"forced-password\");\n    }\n\n    private DriverManagerDataSource configuredDataSource(boolean forceUseNamedDriverClass) {\n        DriverManagerDataSource dataSource = new DriverManagerDataSource(false);\n        dataSource.setDriverClass(RecordingDriver.class.getName());\n        dataSource.setJdbcUrl(JDBC_URL);\n        dataSource.setForceUseNamedDriverClass(forceUseNamedDriverClass);\n        return dataSource;\n    }\n\n    public static final class RecordingDriver implements Driver {\n        private static final RecordingDriver REGISTERED_DRIVER = new RecordingDriver();\n\n        private static boolean registered;\n        private static int constructed;\n        private static int connectCalls;\n        private static String lastUrl;\n        private static Properties lastProperties;\n\n        public RecordingDriver() {\n            constructed++;\n        }\n\n        static void reset() {\n            constructed = 0;\n            connectCalls = 0;\n            lastUrl = null;\n            lastProperties = null;\n        }\n\n        static void register() throws SQLException {\n            if (!registered) {\n                DriverManager.registerDriver(REGISTERED_DRIVER);\n                registered = true;\n            }\n        }\n\n        static void deregister() throws SQLException {\n            if (registered) {\n                DriverManager.deregisterDriver(REGISTERED_DRIVER);\n                registered = false;\n            }\n        }\n\n        static int constructed() {\n            return constructed;\n        }\n\n        static int connectCalls() {\n            return connectCalls;\n        }\n\n        static String lastUrl() {\n            return lastUrl;\n        }\n\n        static Properties lastProperties() {\n            return lastProperties;\n        }\n\n        @Override\n        public Connection connect(String url, Properties info) throws SQLException {\n            if (!acceptsURL(url)) {\n                return null;\n            }\n            connectCalls++;\n            lastUrl = url;\n            lastProperties = (Properties) info.clone();\n            return Connection.class.cast(Proxy.newProxyInstance(\n                    DriverManagerDataSourceTest.class.getClassLoader(),\n                    new Class<?>[] {Connection.class},\n                    new RecordingConnection()));\n        }\n\n        @Override\n        public boolean acceptsURL(String url) {\n            return JDBC_URL.equals(url);\n        }\n\n        @Override\n        public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {\n            return new DriverPropertyInfo[0];\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 1;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public boolean jdbcCompliant() {\n            return false;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException(\"No parent logger\");\n        }\n    }\n\n    private static final class RecordingConnection implements InvocationHandler {\n        private boolean closed;\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) {\n            String methodName = method.getName();\n            if (method.getDeclaringClass() == Object.class) {\n                return handleObjectMethod(proxy, methodName, args);\n            }\n            if (\"close\".equals(methodName)) {\n                closed = true;\n                return null;\n            }\n            if (\"isClosed\".equals(methodName)) {\n                return closed;\n            }\n            return defaultValue(method.getReturnType());\n        }\n\n        private Object handleObjectMethod(Object proxy, String methodName, Object[] args) {\n            if (\"toString\".equals(methodName)) {\n                return \"RecordingConnection\";\n            }\n            if (\"hashCode\".equals(methodName)) {\n                return System.identityHashCode(proxy);\n            }\n            if (\"equals\".equals(methodName)) {\n                return proxy == args[0];\n            }\n            throw new UnsupportedOperationException(methodName);\n        }\n\n        private Object defaultValue(Class<?> returnType) {\n            if (returnType == Void.TYPE) {\n                return null;\n            }\n            if (!returnType.isPrimitive()) {\n                return null;\n            }\n            if (returnType == Boolean.TYPE) {\n                return false;\n            }\n            if (returnType == Character.TYPE) {\n                return '\\0';\n            }\n            if (returnType == Byte.TYPE) {\n                return (byte) 0;\n            }\n            if (returnType == Short.TYPE) {\n                return (short) 0;\n            }\n            if (returnType == Integer.TYPE) {\n                return 0;\n            }\n            if (returnType == Long.TYPE) {\n                return 0L;\n            }\n            if (returnType == Float.TYPE) {\n                return 0F;\n            }\n            if (returnType == Double.TYPE) {\n                return 0D;\n            }\n            throw new IllegalArgumentException(\"Unsupported primitive return type \" + returnType.getName());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", 