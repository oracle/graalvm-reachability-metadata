[tool-call] delta {"path":"tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/DbAuthTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.impl.DbAuth;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport org.junit.jupiter.api.Test;\n\npublic class DbAuthTest {\n    @Test\n    void serializesAndDeserializesCredentials() throws Exception {\n        DbAuth auth = new DbAuth(\"database-user\", \"database-password\");\n\n        DbAuth copy = roundTrip(auth);\n\n        assertThat(copy).isEqualTo(auth);\n        assertThat(copy.getUser()).isEqualTo(\"database-user\");\n        assertThat(copy.getPassword()).isEqualTo(\"database-password\");\n        assertThat(copy.getMaskedUserString()).isEqualTo(\"da******\");\n    }\n\n    private static DbAuth roundTrip(DbAuth auth) throws IOException, ClassNotFoundException {\n        byte[] serialized = serialize(auth);\n        return deserialize(serialized);\n    }\n\n    private static byte[] serialize(DbAuth auth) throws IOException {\n        ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteArrayOutputStream)) {\n            objectOutputStream.writeObject(auth);\n        }\n        return byteArrayOutputStream.toByteArray();\n    }\n\n    private static DbAuth deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (DbAuth) objectInputStream.readObject();\n        }\n    }\n}\n"}
