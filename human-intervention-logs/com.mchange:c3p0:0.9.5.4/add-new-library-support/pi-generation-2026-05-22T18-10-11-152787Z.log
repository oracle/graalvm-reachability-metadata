      public synchronized AttributeList setAttributes(AttributeList al)
      {
          AttributeList out = new AttributeList();
          for (int i = 0, len = al.size(); i < len; ++i)
          {
              Attribute attrObj = (Attribute) al.get(i);
              
              try
              {
                  this.setAttribute( attrObj );
                  out.add(attrObj);
