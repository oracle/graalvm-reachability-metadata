{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/usr/bin/bash -lc \"find tests/src/com.mchange/c3p0/0.9.5.4/src/test/java -maxdepth 3 -type f | sort | xargs -r -I{} sh -c 'printf \\\"===== %s =====\\\\n\\\" \\\"\"'$1\"; sed -n \"1,220p\" \"$1\"'\"' sh {}\"","aggregated_output":"===== tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/DriverManagerDataSourceBaseTest.java =====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.DriverManagerDataSource;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.Properties;\nimport org.junit.jupiter.api.Test;\n\npublic class DriverManagerDataSourceBaseTest {\n    @Test\n    void serializesAndDeserializesDriverManagerConfiguration() throws Exception {\n        DriverManagerDataSource source = configuredDataSource();\n\n        DriverManagerDataSource restored = roundTrip(source);\n\n        assertThat(restored.getDescription()).isEqualTo(\"test driver manager data source\");\n        assertThat(restored.getDriverClass()).isEqualTo(\"com.example.Driver\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-driver-factory/\");\n        assertThat(restored.isForceUseNamedDriverClass()).isTrue();\n        assertThat(restored.getIdentityToken()).isEqualTo(\"driver-manager-token\");\n        assertThat(restored.getJdbcUrl()).isEqualTo(\"jdbc:example:database\");\n        assertThat(restored.getUser()).isEqualTo(\"dbuser\");\n        assertThat(restored.getPassword()).isEqualTo(\"secret\");\n        assertThat(restored.getProperties()).containsEntry(\"applicationName\", \"c3p0-test\");\n    }\n\n    private static DriverManagerDataSource configuredDataSource() {\n        DriverManagerDataSource source = new DriverManagerDataSource(false);\n        source.setDescription(\"test driver manager data source\");\n        source.setDriverClass(\"com.example.Driver\");\n        source.setFactoryClassLocation(\"file:/tmp/c3p0-driver-factory/\");\n        source.setForceUseNamedDriverClass(true);\n        source.setIdentityToken(\"driver-manager-token\");\n        source.setJdbcUrl(\"jdbc:example:database\");\n        source.setUser(\"dbuser\");\n        source.setPassword(\"secret\");\n\n        Properties properties = source.getProperties();\n        properties.setProperty(\"applicationName\", \"c3p0-test\");\n        source.setProperties(properties);\n        return source;\n    }\n\n    private static DriverManagerDataSource roundTrip(DriverManagerDataSource source) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialize(source)))) {\n            return (DriverManagerDataSource) input.readObject();\n        }\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n}\n===== tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/DynamicPooledDataSourceManagerMBeanTest.java =====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.ComboPooledDataSource;\nimport com.mchange.v2.c3p0.management.DynamicPooledDataSourceManagerMBean;\nimport java.util.Set;\nimport javax.management.Attribute;\nimport javax.management.MBeanAttributeInfo;\nimport javax.management.MBeanInfo;\nimport javax.management.MBeanOperationInfo;\nimport javax.management.MBeanServer;\nimport javax.management.MBeanServerFactory;\nimport javax.management.ObjectName;\nimport org.junit.jupiter.api.Test;\n\npublic class DynamicPooledDataSourceManagerMBeanTest {\n    @Test\n    void exposesPooledDataSourceAttributesAndOperationsThroughDynamicMBean() throws Exception {\n        MBeanServer server = MBeanServerFactory.createMBeanServer();\n        ComboPooledDataSource dataSource = new ComboPooledDataSource(false);\n        dataSource.setIdentityToken(\"dynamicPooledDataSourceManagerMBeanTestToken\");\n        dataSource.setDataSourceName(\"dynamicPooledDataSourceManagerMBeanTest\");\n        dataSource.setDescription(\"before-management\");\n\n        try {\n            new DynamicPooledDataSourceManagerMBean(\n                    dataSource, \"com_mchange.c3p0:type=InitialDynamicPooledDataSource\", server);\n            ObjectName objectName = findManagedPooledDataSource(server);\n\n            MBeanInfo info = server.getMBeanInfo(objectName);\n            assertThat(info.getAttributes()).extracting(MBeanAttributeInfo::getName).contains(\"description\");\n            assertThat(info.getOperations()).extracting(MBeanOperationInfo::getName).contains(\"hardReset\");\n\n            assertThat(server.getAttribute(objectName, \"description\")).isEqualTo(\"before-management\");\n\n            server.setAttribute(objectName, new Attribute(\"description\", \"after-management\"));\n            assertThat(dataSource.getDescription()).isEqualTo(\"after-management\");\n\n            Object description = server.invoke(\n                    objectName,\n                    \"getDescription\",\n                    new Object[0],\n                    new String[0]);\n            assertThat(description).isEqualTo(\"after-management\");\n        } finally {\n            dataSource.close();\n            MBeanServerFactory.releaseMBeanServer(server);\n        }\n    }\n\n    private static ObjectName findManagedPooledDataSource(MBeanServer server) throws Exception {\n        Set<ObjectName> objectNames = server.queryNames(\n                new ObjectName(\"com.mchange.v2.c3p0:type=PooledDataSource,*\"), null);\n        assertThat(objectNames).hasSize(1);\n        return objectNames.iterator().next();\n    }\n}\n===== tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/PoolBackedDataSourceBaseTest.java =====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport com.mchange.v2.c3p0.PoolBackedDataSource;\nimport com.mchange.v2.naming.JavaBeanObjectFactory;\nimport com.mchange.v2.naming.ReferenceIndirector;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.OutputStream;\nimport java.io.PrintWriter;\nimport java.io.Serializable;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.AbstractMap;\nimport java.util.Collections;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.logging.Logger;\nimport javax.naming.Reference;\nimport javax.naming.Referenceable;\nimport javax.sql.ConnectionPoolDataSource;\nimport javax.sql.PooledConnection;\nimport org.junit.jupiter.api.Test;\n\npublic class PoolBackedDataSourceBaseTest {\n    private static final String OBJECT_FACTORY_WHITELIST_PROPERTY =\n            \"com.mchange.v2.naming.objectFactoryWhitelist\";\n\n    @Test\n    void serializesAndDeserializesPoolBackedConfiguration() throws Exception {\n        String identityToken = \"pool-backed-token-serializable\";\n        PoolBackedDataSource source = configuredPoolBackedDataSource(identityToken);\n        source.setConnectionPoolDataSource(new SerializableConnectionPoolDataSource(\"serializable-cpds\"));\n\n        PoolBackedDataSource restored = roundTrip(source);\n\n        assertThat(restored.getDataSourceName()).isEqualTo(\"test pool backed data source\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-pool-factory/\");\n        assertThat(restored.getIdentityToken()).isEqualTo(identityToken);\n        assertThat(restored.getNumHelperThreads()).isEqualTo(3);\n        assertThat(restored.getExtensions()).containsEntry(\"applicationName\", \"pool-backed-test\");\n        assertThat(restored.getConnectionPoolDataSource())\n                .isInstanceOfSatisfying(\n                        SerializableConnectionPoolDataSource.class,\n                        dataSource -> assertThat(dataSource.getName()).isEqualTo(\"serializable-cpds\"));\n    }\n\n    @Test\n    void serializesReferenceableConnectionPoolDataSourceIndirectlyWhenItIsNotSerializable() throws Exception {\n        PoolBackedDataSource source = configuredPoolBackedDataSource(\"pool-backed-token-indirect-cpds\");\n        source.setConnectionPoolDataSource(new ReferenceableConnectionPoolDataSource());\n\n        byte[] serialized = serialize(source);\n\n        assertThat(serialized).isNotEmpty();\n        assertThatThrownBy(() -> serialize(source.getConnectionPoolDataSource())).isInstanceOf(IOException.class);\n    }\n\n    @Test\n    void serializesIndirectlyRestoredReferenceableExtensionsIndirectly() throws Exception {\n        PoolBackedDataSource source = configuredPoolBackedDataSource(\"pool-backed-token-indirect-extensions\");\n        source.setConnectionPoolDataSource(new SerializableConnectionPoolDataSource(\"indirect-extensions-cpds\"));\n\n        byte[] serialized = serializeReplacingExtensions(source, new ReferenceableExtensions());\n        PoolBackedDataSource restored = deserializeWithObjectFactoryWhitelist(serialized);\n\n        assertThat(restored.getExtensions()).isEmpty();\n        assertThat(serialize(restored)).isNotEmpty();\n    }\n\n    private static PoolBackedDataSource configuredPoolBackedDataSource(String identityToken) {\n        PoolBackedDataSource source = new PoolBackedDataSource(false);\n        source.setDataSourceName(\"test pool backed data source\");\n        source.setFactoryClassLocation(\"file:/tmp/c3p0-pool-factory/\");\n        source.setIdentityToken(identityToken);\n        source.setNumHelperThreads(3);\n\n        Map<String, String> extensions = new LinkedHashMap<>();\n        extensions.put(\"applicationName\", \"pool-backed-test\");\n        source.setExtensions(extensions);\n        return source;\n    }\n\n    private static PoolBackedDataSource roundTrip(PoolBackedDataSource source) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialize(source)))) {\n            return (PoolBackedDataSource) input.readObject();\n        }\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serializeReplacingExtensions(\n            PoolBackedDataSource source, ReferenceableExtensions replacementExtensions) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ExtensionReplacingObjectOutputStream(bytes, replacementExtensions)) {\n            output.writeObject(source);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static PoolBackedDataSource deserializeWithObjectFactoryWhitelist(byte[] serialized) throws Exception {\n        String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n        System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, JavaBeanObjectFactory.class.getName());\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (PoolBackedDataSource) input.readObject();\n        } finally {\n            if (previousWhitelist == null) {\n                System.clearProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n            } else {\n                System.setProperty(OBJECT_FACTORY_WHITELIST_PROPERTY, previousWhitelist);\n            }\n        }\n    }\n\n    private static final class ExtensionReplacingObjectOutputStream extends ObjectOutputStream {\n        private final ReferenceableExtensions replacementExtensions;\n\n        ExtensionReplacingObjectOutputStream(OutputStream output, ReferenceableExtensions replacementExtensions)\n                throws IOException {\n            super(output);\n            this.replacementExtensions = replacementExtensions;\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) throws IOException {\n            if (object instanceof Map<?, ?> && ((Map<?, ?>) object).containsKey(\"applicationName\")) {\n                try {\n                    return new ReferenceIndirector().indirectForm(replacementExtensions);\n                } catch (Exception e) {\n                    throw new IOException(\"Could not prepare indirect extensions for serialization.\", e);\n                }\n            }\n            return object;\n        }\n    }\n\n    public static final class ReferenceableExtensions extends AbstractMap<String, String> implements Referenceable {\n        @Override\n        public Set<Entry<String, String>> entrySet() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Reference getReference() {\n            return new Reference(ReferenceableExtensions.class.getName(), JavaBeanObjectFactory.class.getName(), null);\n        }\n    }\n\n    public static final class SerializableConnectionPoolDataSource implements ConnectionPoolDataSource, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String name;\n\n        SerializableConnectionPoolDataSource(String name) {\n            this.name = name;\n        }\n\n        String getName() {\n            return name;\n        }\n\n        @Override\n        public PooledConnection getPooledConnection() throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Test data source does not create pooled connections.\");\n        }\n\n        @Override\n        public PooledConnection getPooledConnection(String user, String password) throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Test data source does not create pooled connections.\");\n        }\n\n        @Override\n        public PrintWriter getLogWriter() throws SQLException {\n            return null;\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) throws SQLException {\n            // The test data source stores no mutable connection configuration.\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) throws SQLException {\n            // The test data source stores no mutable connection configuration.\n        }\n\n        @Override\n        public int getLoginTimeout() throws SQLException {\n            return 0;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException(\"Test data source does not expose a parent logger.\");\n        }\n    }\n\n    public static final class ReferenceableConnectionPoolDataSource implements ConnectionPoolDataSource, Referenceable {\n        @Override\n        public Reference getReference() {\n            return new Reference(\n===== tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/WrapperConnectionPoolDataSourceBaseTest.java =====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;\nimport com.mchange.v2.naming.JavaBeanObjectFactory;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.PrintWriter;\nimport java.sql.Connection;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.logging.Logger;\nimport javax.naming.Reference;\nimport javax.naming.Referenceable;\nimport javax.sql.DataSource;\nimport org.junit.jupiter.api.Test;\n\npublic class WrapperConnectionPoolDataSourceBaseTest {\n    @Test\n    void serializesAndDeserializesWrapperConfiguration() throws Exception {\n        WrapperConnectionPoolDataSource source = configuredWrapper();\n\n        WrapperConnectionPoolDataSource restored = roundTrip(source);\n\n        assertThat(restored.getAutomaticTestTable()).isEqualTo(\"connection_check\");\n        assertThat(restored.getConnectionCustomizerClassName()).isEqualTo(\"com.example.ConnectionCustomizer\");\n        assertThat(restored.getContextClassLoaderSource()).isEqualTo(\"library\");\n        assertThat(restored.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-factory/\");\n        assertThat(restored.getIdentityToken()).isEqualTo(\"wrapper-token\");\n        assertThat(restored.getOverrideDefaultPassword()).isEqualTo(\"secret\");\n        assertThat(restored.getOverrideDefaultUser()).isEqualTo(\"dbuser\");\n        assertThat(restored.getPreferredTestQuery()).isEqualTo(\"SELECT 1\");\n        assertThat(restored.getNestedDataSource()).isNull();\n    }\n\n    @Test\n    void serializesReferenceableNestedDataSourceIndirectlyWhenItIsNotSerializable() throws Exception {\n        WrapperConnectionPoolDataSource source = configuredWrapper();\n        source.setNestedDataSource(new ReferenceableDataSource());\n\n        byte[] serialized = serialize(source);\n\n        assertThat(serialized).isNotEmpty();\n        assertThatThrownBy(() -> serialize(source.getNestedDataSource())).isInstanceOf(IOException.class);\n    }\n\n    private static WrapperConnectionPoolDataSource configuredWrapper() {\n        WrapperConnectionPoolDataSource source = new WrapperConnectionPoolDataSource(false);\n        source.setAutomaticTestTable(\"connection_check\");\n        source.setConnectionCustomizerClassName(\"com.example.ConnectionCustomizer\");\n        source.setContextClassLoaderSource(\"library\");\n        source.setFactoryClassLocation(\"file:/tmp/c3p0-factory/\");\n        source.setIdentityToken(\"wrapper-token\");\n        source.setOverrideDefaultPassword(\"secret\");\n        source.setOverrideDefaultUser(\"dbuser\");\n        source.setPreferredTestQuery(\"SELECT 1\");\n        return source;\n    }\n\n    private static WrapperConnectionPoolDataSource roundTrip(WrapperConnectionPoolDataSource source) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialize(source)))) {\n            return (WrapperConnectionPoolDataSource) input.readObject();\n        }\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    public static final class ReferenceableDataSource implements DataSource, Referenceable {\n        @Override\n        public Reference getReference() {\n            return new Reference(\n                    ReferenceableDataSource.class.getName(), JavaBeanObjectFactory.class.getName(), null);\n        }\n\n        @Override\n        public Connection getConnection() throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Test DataSource does not open connections.\");\n        }\n\n        @Override\n        public Connection getConnection(String username, String password) throws SQLException {\n            throw new SQLFeatureNotSupportedException(\"Test DataSource does not open connections.\");\n        }\n\n        @Override\n        public PrintWriter getLogWriter() throws SQLException {\n            return null;\n        }\n\n        @Override\n        public void setLogWriter(PrintWriter out) throws SQLException {\n            // The test data source stores no mutable connection configuration.\n        }\n\n        @Override\n        public void setLoginTimeout(int seconds) throws SQLException {\n            // The test data source stores no mutable connection configuration.\n        }\n\n        @Override\n        public int getLoginTimeout() throws SQLException {\n            return 0;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException(\"Test DataSource does not expose a parent logger.\");\n        }\n\n        @Override\n        public <T> T unwrap(Class<T> iface) throws SQLException {\n            throw new SQLException(\"Not a wrapper for \" + iface.getName());\n        }\n\n        @Override\n        public boolean isWrapperFor(Class<?> iface) throws SQLException {\n            return false;\n       