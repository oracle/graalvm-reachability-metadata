{"type":"item.completed","item":{"id":"item_171","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/WrapperConnectionPoolDataSourceBaseTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.DriverManagerDataSource;\nimport com.mchange.v2.c3p0.WrapperConnectionPoolDataSource;\nimport com.mchange.v2.naming.JavaBeanObjectFactory;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.PrintWriter;\nimport java.sql.Connection;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.logging.Logger;\nimport javax.naming.NamingException;\nimport javax.naming.Reference;\nimport javax.naming.Referenceable;\nimport javax.naming.StringRefAddr;\nimport javax.sql.DataSource;\nimport org.junit.jupiter.api.Test;\n\npublic class WrapperConnectionPoolDataSourceBaseTest implements DataSource, Referenceable {\n    private static final String OBJECT_FACTORY_WHITELIST_PROPERTY =\n            \"com.mchange.v2.naming.objectFactoryWhitelist\";\n    private static final String UNSUPPORTED_MESSAGE = \"Test DataSource does not create connections.\";\n\n    private String token;\n\n    @Test\n    void serializesAndDeserializesDirectlySerializableNestedDataSource() throws Exception {\n        WrapperConnectionPoolDataSource dataSource = configuredWrapper(\"direct-wrapper\");\n        DriverManagerDataSource nestedDataSource = new DriverManagerDataSource(false);\n        nestedDataSource.setIdentityToken(\"direct-nested\");\n        nestedDataSource.setJdbcUrl(\"jdbc:c3p0-test:direct\");\n        nestedDataSource.setUser(\"direct-user\");\n        nestedDataSource.setPassword(\"direct-password\");\n        dataSource.setNestedDataSource(nestedDataSource);\n\n        WrapperConnectionPoolDataSource copy = roundTrip(dataSource);\n\n        assertThat(copy.getIdentityToken()).isEqualTo(\"direct-wrapper\");\n        assertThat(copy.getAutomaticTestTable()).isEqualTo(\"TEST_CONNECTIONS\");\n        assertThat(copy.getConnectionCustomizerClassName()).isEqualTo(\"com.example.ConnectionCustomizer\");\n        assertThat(copy.getContextClassLoaderSource()).isEqualTo(\"library\");\n        assertThat(copy.getFactoryClassLocation()).isEqualTo(\"file:/tmp/c3p0-test/\");\n        assertThat(copy.getOverrideDefaultUser()).isEqualTo(\"override-user\");\n        assertThat(copy.getOverrideDefaultPassword()).isEqualTo(\"override-password\");\n        assertThat(copy.getPreferredTestQuery()).isEqualTo(\"SELECT 1\");\n        assertThat(copy.getNestedDataSource()).isInstanceOf(DriverManagerDataSource.class);\n\n        DriverManagerDataSource nestedCopy = (DriverManagerDataSource) copy.getNestedDataSource();\n        assertThat(nestedCopy.getJdbcUrl()).isEqualTo(\"jdbc:c3p0-test:direct\");\n        assertThat(nestedCopy.getUser()).isEqualTo(\"direct-user\");\n        assertThat(nestedCopy.getPassword()).isEqualTo(\"direct-password\");\n    }\n\n    @Test\n    void serializesAndDeserializesReferenceableNestedDataSourceIndirectly() throws Exception {\n        WrapperConnectionPoolDataSource dataSource = configuredWrapper(\"indirect-wrapper\");\n        WrapperConnectionPoolDataSourceBaseTest nestedDataSource = new WrapperConnectionPoolDataSourceBaseTest();\n        nestedDataSource.setToken(\"indirect-token\");\n        dataSource.setNestedDataSource(nestedDataSource);\n\n        String previousWhitelist = System.getProperty(OBJECT_FACTORY_WHITELIST_PROPERTY);\n        System.setProperty(OBJECT_FACTORY_WHITELIST_P