{"type":"item.completed","item":{"id":"item_135","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/com.mchange/c3p0/0.9.5.4/src/test/java/com_mchange/c3p0/C3P0RegistryTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_mchange.c3p0;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.mchange.v2.c3p0.AbstractConnectionCustomizer;\nimport com.mchange.v2.c3p0.AbstractConnectionTester;\nimport com.mchange.v2.c3p0.C3P0Registry;\nimport com.mchange.v2.c3p0.ConnectionCustomizer;\nimport com.mchange.v2.c3p0.ConnectionTester;\nimport com.mchange.v2.c3p0.PooledDataSource;\nimport com.mchange.v2.c3p0.management.ManagementCoordinator;\nimport com.mchange.v2.log.MLog;\nimport java.io.File;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.file.Path;\nimport java.security.CodeSource;\nimport java.sql.Connection;\nimport java.util.Arrays;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class C3P0RegistryTest {\n    private static final String MANAGEMENT_COORDINATOR_PROPERTY =\n            \"com.mchange.v2.c3p0.management.ManagementCoordinator\";\n\n    @Test\n    void createsAndCachesConnectionTesterByConfiguredClassName() {\n        C3P0Registry.markConfigRefreshed();\n\n        ConnectionTester tester = C3P0Registry.getConnectionTester(RecordingConnectionTester.class.getName());\n        ConnectionTester cachedTester = C3P0Registry.getConnectionTester(RecordingConnectionTester.class.getName());\n\n        assertThat(tester).isInstanceOf(RecordingConnectionTester.class);\n        assertThat(cachedTester).isSameAs(tester);\n        assertThat(tester.activeCheckConnection(null)).isEqualTo(ConnectionTester.CONNECTION_IS_OKAY);\n    }\n\n    @Test\n    void createsAndCachesConnectionCustomizerByConfiguredClassName() throws Exception {\n        ConnectionCustomizer customizer = C3P0Registry.getConnectionCustomizer(\n                RecordingConnectionCustomizer.class.getName());\n        ConnectionCustomizer cachedCustomizer = C3P0Registry.getConnectionCustomizer(\n                RecordingConnectionCustomizer.class.getName());\n\n        assertThat(customizer).isInstanceOf(RecordingConnectionCustomizer.class);\n        assertThat(cachedCustomizer).isSameAs(customizer);\n    }\n\n    @Test\n    void initializesConfiguredManagementCoordinatorInFreshRegistry() throws Exception {\n        String previous = System.getProperty(MANAGEMENT_COORDINATOR_PROPERTY);\n        System.setProperty(MANAGEMENT_COORDINATOR_PROPERTY, RecordingManagementCoordinator.class.getName());\n        try {\n            assertThat(initializeRegistryWithFreshClassLoader()).isEqualTo(1);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            restoreProperty(previous);\n        }\n    }\n\n    private static int initializeRegistryWithFreshClassLoader() throws Exception {\n        try (URLClassLoader classLoader = new URLClassLoader(\n                classPathUrls(),\n                ClassLoader.getPlatformClassLoader())) {\n            Class<?> initializerClass = Class.forName(\n                    IsolatedRegistryInitializer.class.getName(),\n                    true,\n                    classLoader);\n            Method initialize = initializerClass.getMethod(\"initialize\");\n            try {\n                return (Integer) initialize.invoke(null);\n            } catch (InvocationTargetException exception) {\n                Throwable cause = exception.getCause();\n                if (cause instanceof Error error) {\n                    throw error;\n                }\n                if (cause instanceof Exception checkedException) {\n                    throw checkedException;\n                }\n                throw new AssertionError(cause);\n            }\n        }\n    }\n\n    private static URL[] classPathUrls() {\n        Set<URL> urls = new LinkedHashSet<>();\n        addCodeSource(urls, C3P0RegistryTest.class);\n        addCodeSource(urls, C3P0Registry.class);\n        addCodeSource(urls, MLog.class);\n        Arrays.stream(System.getProperty(\"java.class.path\").split(File.pathSeparator))\n                .map(Path::of)\n                .map(C3P0RegistryTest::toUrl)\n                .forEach(urls::add);\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader instanceof URLClassLoader urlClassLoader) {\n            urls.addAll(Arrays.asList(urlClassLoader.getURLs()));\n        }\n        return urls.toArray(URL[]::new);\n    }\n\n    private static void addCodeSource(Set<URL> urls, Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        if (codeSource != null && codeSource.getLocation() != null) {\n            urls.add(codeSource.getLocation());\n        }\n    }\n\n    private static URL toUrl(Path path) {\n        try {\n            return path.toUri().toURL();\n        } catch (Exception exception) {\n            throw new IllegalArgumentException(\"Invalid classpath entry: \" + path, exception);\n        }\n    }\n\n    private static void restoreProperty(String previous) {\n        if (previous == null) {\n            System.clearProperty(MANAGEMENT_COORDINATOR_PROPERTY);\n        } else {\n            System.setProperty(MANAGEMENT_COORDINATOR_PROPERTY, previous);\n        }\n    }\n\n    public static class IsolatedRegistryInitializer {\n        public static int initialize() {\n            C3P0Registry.getNumPooledDataSources();\n            return RecordingManagementCoordinator.constructed();\n        }\n    }\n\n    public static class RecordingManagementCoordinator implements ManagementCoordinator {\n        private static int constructed;\n\n        public RecordingManagementCoordinator() {\n            constructed++;\n        }\n\n        public static int constructed() {\n            return constructed;\n        }\n\n        @Override\n        public void attemptManageC3P0Registry() {\n        }\n\n        @Override\n        public void attemptUnmanageC3P0Registry() {\n        }\n\n        @Override\n        public void attemptManagePooledDataSource(PooledDataSource dataSource) {\n        }\n\n        @Override\n        public void attemptUnmanagePooledDataSource(PooledDataSource dataSource) {\n        }\n    }\n\n    public static class RecordingConnectionTester extends AbstractConnectionTester {\n        @Override\n        public int activeCheckConnection(\n                Connection connection,\n                String preferredTestQuery,\n                Throwable[] rootCauseOutParamHolder) {\n            return CONNECTION_IS_OKAY;\n        }\n\n        @Override\n        public int statusOnException(\n                Connection connection,\n                Throwable throwable,\n                String preferredTestQuery,\n                Throwable[] rootCauseOutParamHolder) {\n            return CONNECTION_IS_INVALID;\n        }\n\n        @Override\n        public boolean equals(Object object) {\n            return object instanceof RecordingConnectionTester;\n        }\n\n        @Override\n        public int hashCode() {\n            return RecordingConnectionTester.class.hashCode();\n        }\n    }\n\n    public static class RecordingConnectionCustomizer extends AbstractConnectionCustomizer {\n    }\n}\n","exit_code":0,"status":"completed"}}
