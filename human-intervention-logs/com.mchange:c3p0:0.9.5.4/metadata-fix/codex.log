\n        static void register() throws SQLException {\n            if (!registered) {\n                DriverManager.registerDriver(REGISTERED_DRIVER);\n                registered = true;\n            }\n        }\n\n        static void deregister() throws SQLException {\n            if (registered) {\n                DriverManager.deregisterDriver(REGISTERED_DRIVER);\n                registered = false;\n            }\n        }\n\n        static int constructed() {\n            return constructed;\n        }\n\n        static int connectCalls() {\n            return connectCalls;\n        }\n\n        static String lastUrl() {\n            return lastUrl;\n        }\n\n        static Properties lastProperties() {\n            return lastProperties;\n        }\n\n        @Override\n        public Connection connect(String url, Properties info) throws SQLException {\n            if (!acceptsURL(url)) {\n                return null;\n            }\n            connectCalls++;\n            lastUrl = url;\n            lastProperties = (Properties) info.clone();\n            return Connection.class.cast(Proxy.newProxyInstance(\n                    DriverManagerDataSourceTest.class.getClassLoader(),\n                    new Class<?>[] {Connection.class},\n                    new RecordingConnection()));\n        }\n\n        @Override\n        public boolean acceptsURL(String url) {\n            return JDBC_URL.equals(url);\n        }\n\n        @Override\n        public DriverPropertyInfo[] getPropertyInfo(String url, Properties info) {\n            return new DriverPropertyInfo[0];\n        }\n\n        @Override\n        public int getMajorVersion() {\n            return 1;\n        }\n\n        @Override\n        public int getMinorVersion() {\n            return 0;\n        }\n\n        @Override\n        public boolean jdbcCompliant() {\n            return false;\n        }\n\n        @Override\n        public Logger getParentLogger() throws SQLFeatureNotSupportedException {\n            throw new SQLFeatureNotSupportedException(\"No parent logger\");\n        }\n    }\n\n    private static final class RecordingConnection implements InvocationHandler {\n        private boolean closed;\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) {\n            String methodName = method.getName();\n            if (method.getDeclaringClass() == Object.class) {\n                return handleObjectMethod(proxy, methodName, args);\n            }\n            if (\"close\".equals(methodName)) {\n                closed = true;\n                return null;\n            }\n            if (\"isClosed\".equals(methodName)) {\n                return closed;\n            }\n            return defaultValue(method.getReturnType());\n        }\n\n        private Object handleObjectMethod(Object proxy, String methodName, Object[] args) {\n            if (\"toString\".equals(methodName)) {\n                return \"RecordingConnection\";\n            }\n            if (\"hashCode\".equals(methodName)) {\n                return System.identityHashCode(proxy);\n            }\n            if (\"equals\".equals(methodName)) {\n                return proxy == args[0];\n            }\n            throw new UnsupportedOperationException(methodName);\n        }\n\n        private Object defaultValue(Class<?> returnType) {\n            if (returnType == Void.TYPE) {\n                return null;\n            }\n            if (!returnType.isPrimitive()) {\n                return null;\n            }\n            if (returnType == Boolean.TYPE) {\n                return false;\n            }\n            if (returnType == Character.TYPE) {\n                return '\\0';\n","exit_code":0,"status":"completed"}}
