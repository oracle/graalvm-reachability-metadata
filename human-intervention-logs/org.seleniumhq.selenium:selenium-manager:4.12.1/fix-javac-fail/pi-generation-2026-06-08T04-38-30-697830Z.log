          jsonOutput
              .getLogs()
              .forEach(
                  logged -> {
                    Level currentLevel =
                        logged.getLevel() == Level.INFO ? Level.FINE : logged.getLevel();
                    LOG.log(currentLevel, logged.getMessage());
                  });
          dump = jsonOutput.getResult().getMessage();
        } catch (JsonException e) {
          failedToParse = e;
        }
