aalvm/internal/tck/stats/ReadmeBadgeSummarySupport.java:1282:            BigDecimal coveragePercent,\n./skills/review-library-bulk-update/SKILL.md:8:These PRs are created by the scheduled compatibility workflow and are expected to update supported library versions by changing `metadata/**/index.json`. They may also refresh the generated root `COVERAGE.md` when tested-version changes affect the coverage table.\nforge/tests/test_git_worktree_regressions.py:241:                    return_value=\"ai/test/human-intervention/issue-1412\",\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:464:                normalizeRatio(dynamicAccess.coverageRatio()),\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:479:                normalizeRatio(breakdown.coverageRatio())\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:496:            LibraryStatsModels.CoverageMetricValue coverageMetricValue\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:498:        if (coverageMetricValue == null || !coverageMetricValue.isAvailable()) {\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:502:        BigDecimal ratio = coverageMetricValue.total() == 0L\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:504:                : normalizeRatio(coverageMetricValue.ratio());\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:506:                coverageMetricValue.covered(),\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:507:                coverageMetricValue.missed(),\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:508:                coverageMetricValue.total(),\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:774:                    coverageMetricOrNa(rootCounters, \"LINE\"),\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:775:                    coverageMetricOrNa(rootCounters, \"INSTRUCTION\"),\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:776:                    coverageMetricOrNa(rootCounters, \"METHOD\")\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:829:    private static LibraryStatsModels.CoverageMetricValue coverageMetricOrNa(\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:833:        LibraryStatsModels.CoverageMetric coverageMetric = counters.get(type);\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:834:        if (coverageMetric == null) {\n./tests/tck-build-logic/src/main/java/org/graalvm/internal/tck/stats/LibraryStatsSupport.java:837:        return LibraryStatsModels.CoverageMetricValue.available(coverageMetric);\nforge/docs/functional-spec.md:4:service of §GOAL-maximize-library-coverage and\nforge/docs/functional-spec.md:34:§GOAL-maximize-library-coverage.\nforge/docs/functional-spec.md:39:2. **Coverage improvement** — increase dynamic-access coverage of\nforge/docs/functional-spec.md:41:3. **Code coverage improvement** — planned workflow that creates new tests for\nforge/docs/functional-spec.md:43:   ordinary API and execution coverage beyond dynamic-access call coverage, as\nforge/docs/functional-spec.md:44:   defined by §FS-forge-code-coverage-improvement.\nforge/docs/functional-spec.md:73:### FS-forge-code-coverage-improvement: Code coverage improvement\nforge/docs/functional-spec.md:76:code coverage, not only dynamic-access coverage (see\nforge/docs/functional-spec.md:77:§WF-code-coverage-improvement), broadening the library coverage outcome\nforge/docs/functional-spec.md:78:described in §GOAL-maximize-library-coverage. The workflow creates or improves\nforge/docs/functional-spec.md:82:Those tests must live in a separate code coverage test suite, not in the test\nforge/docs/functional-spec.md:86:dynamic-access coverage workflow defined in §WF-improve-library-coverage.\nforge/docs/functional-spec.md:88:coverage asks whether tests exercise calls that require reachability metadata;\nforge/docs/functional-spec.md:89:code coverage improvement asks whether tests exercise the broader library API\nforge/docs/functional-spec.md:92:metadata-relevant coverage from broader behavior coverage.\nforge/docs/functional-spec.md:107:| **Human intervention** | A maintainer follow-up signal applied through the `human-intervention` issue or PR label when Forge has evidence that generated work, repository automation, or library execution semantics require human judgment. It is distinct from post-generation intervention, which is an automated recovery step. The policy is defined in §FS-human-intervention-policy. |\nforge/docs/functional-spec.md:109:| **Dynamic-access report** | JSON written by Gradle task `generateDynamicAccessCoverageReport` to `tests/src/<group>/<artifact>/<version>/build/reports/dynamic-access/dynamic-access-coverage.json`, listing classes and per-class call sites that require dynamic-access metadata, marked covered/uncovered. |\nforge/docs/functional-spec.md:110:| **Dynamic-access exhaust report** | Durable coordinate-scoped JSON state for chunked dynamic-access work. It records the coordinate, issue number, class threshold, processed/exhausted/failed classes, and the latest published chunk PR/commit. It is stored in a stable location derived from the target test suite (for example under `tests/src/<group>/<artifact>/<version>/`) so orchestration scripts can find it from the coordinate alone. It does not predefine all chunks; each resume regenerates the current dynamic-access report and filters out exhausted classes. Specified by §WF-dynamic-access-exhaust-report. |\nforge/docs/functional-spec.md:111:| **Chunked dynamic-access workflow** | Dynamic-access generation mode for oversized `library-new-request` and `library-update-request` issues. `forge_metadata.py` owns the class threshold decision and passes the current chunk size to the workflow. The workflow processes at most that many uncovered classes, publishes that chunk, then resumes after the chunk PR merges. PR linking rules are in §WF-chunked-dynamic-access-pr-linking. |\nforge/docs/functional-spec.md:113:| **Library update target** | The metadata and test directories selected for a `library-update-request` coordinate (§WF-improve-library-coverage.3). Resolution records the requested coordinate, match type (`tested-version`, `metadata-version`, `default-for`, or `new-version`), matched index entry, resolved metadata version, resolved test version, and edit directories. |\nforge/docs/functional-spec.md:142:- `--keep-tests-without-dynamic-access` — only honored by dynamic-access\nforge/docs/functional-spec.md:143:  workflows (§WF-dynamic-access-workflow).\nforge/docs/functional-spec.md:170:  If the current dynamic-access report has more uncovered classes than this\nforge/docs/functional-spec.md:178:  testing, dynamic-access reporting, native metadata exploration, metadata\nforge/docs/functional-spec.md:206:  `improve-coverage-…`, `fix-javac-…`, `fix-java-run-…`,\nforge/docs/functional-spec.md:215:coverage, and status evidence stays attached to the library version it describes\nforge/docs/functional-spec.md:216:(§GOAL-maximize-library-coverage). During a run, in-flight metrics are staged\nforge/docs/functional-spec.md:296:change, and the human-intervention classification that detects changes outside\nforge/docs/functional-spec.md:315:`human-intervention` and the verification metrics and PR description must list\nforge/docs/functional-spec.md:317:§FS-human-intervention-policy.\nforge/docs/functional-spec.md:319:### FS-human-intervention-policy: Human intervention policy\nforge/docs/functional-spec.md:321:The `human-intervention` label is a maintainer follow-up signal, not a generic\nforge/docs/functional-spec.md:326:Valid human-intervention cases are semantic or generation failures inside\nforge/docs/functional-spec.md:335:- Dynamic-access coverage remains missing or suspiciously low after a\nforge/docs/functional-spec.md:340:- Publication detects a severe metadata, test, or coverage anomaly that makes\nforge/docs/functional-spec.md:343:Forge must not use `human-intervention` for failures that are only external or\nforge/docs/functional-spec.md:345:download failures, GitHub API/status failures, rate limits, runner outages,\nforge/docs/functional-spec.md:348:appropriate, and left without the `human-intervention` label unless later\nforge/docs/functional-spec.md:356:`human-intervention-fixed` PR label means a maintainer has addressed the manual\nforge/docs/functional-spec.md:363:`human-intervention` label unless the result also meets one of the policy cases\nforge/docs/functional-spec.md:380:Review automation must skip PRs already labeled `human-intervention`. That\nforge/docs/functional-spec.md:382:continue, per §FS-human-intervention-policy. A PR labeled\nforge/docs/functional-spec.md:383:`human-intervention-fixed` is the explicit maintainer signal that manual\nforge/docs/functional-spec.md:389:Automated review may add or request the `human-intervention` PR label only when\nforge/docs/functional-spec.md:392:noise, GitHub status/API failures, Maven download failures, or other external\nforge/docs/functional-spec.md:393:infrastructure errors must not be converted into `human-intervention` unless\nforge/docs/functional-spec.md:396:(§FS-human-intervention-policy).\nforge/docs/functional-spec.md:422:`human-intervention` for these fixable index bucket inconsistencies\nforge/docs/functional-spec.md:423:(§FS-human-intervention-policy).\nforge/docs/functional-spec.md:440:| `SUCCESS_WITH_INTERVENTION_STATUS` | Tests succeeded after the built-in post-generation recovery modified the working tree (a Codex metadata fix, then Pi removing failing tests as a last resort), and the local CI-equivalent verification (§FS-local-ci-equivalent-verification) passed. The intervention's record is included in the run-metrics and PR description. PR-eligible; distinct from the `human-intervention` label unless §FS-human-intervention-policy separately requires that label. |\nforge/docs/functional-spec.md:441:| `RUN_STATUS_CHUNK_READY` | A chunked dynamic-access run reached a reviewable class boundary and §FS-local-ci-equivalent-verification passed for the current part. The current part is PR-eligible, and the issue must not be resumed until the part PR has merged. |\nforge/docs/functional-spec.md:444:The exit code is `0` for PR-eligible statuses and `1` for failure.\nforge/docs/functional-spec.md:449:must run or refresh the dynamic-access report before choosing the execution\nforge/docs/functional-spec.md:450:mode. If the current report has more uncovered dynamic-access classes than the\nforge/docs/functional-spec.md:459:`chunked-dynamic-access` label. The normal project status remains the run-state\nforge/docs/functional-spec.md:465:by §WF-dynamic-access-exhaust-report.\nforge/docs/functional-spec.md:471:(§WF-chunked-dynamic-access-pr-linking).\nforge/docs/functional-spec.md:483:| `library-new-request` | `add_new_library_support.py` | new library support (§WF-add-new-library-support), which runs dynamic-access generation plus native metadata tracing and verification |\nforge/docs/functional-spec.md:484:| `library-update-request` | `improve_library_coverage.py`, or the missing-version router | dynamic-access coverage improvement (§WF-improve-library-coverage) |\nforge/docs/functional-spec.md:488:| code coverage improvement (planned) | — | code coverage improvement (§WF-code-coverage-improvement) |\nforge/docs/functional-spec.md:492:separate queue: it is the most basic workflow and the fallback the dynamic-access\nforge/docs/functional-spec.md:503:§GOAL-minimize-generation-cost), token, iteration, LOC, coverage (in service\nforge/docs/functional-spec.md:504:of §GOAL-maximize-library-coverage), dynamic-access, and metadata metrics.\nforge/docs/functional-spec.md:507:starting with fixture-backed E2E coverage for the orchestration boundary; see\n./skills/review-fixes-java-run-fail/SKILL.md:3:description: Review pull requests with the `fixes-java-run-fail` label in graalvm-reachability-metadata. Use when asked to review or triage a PR described as `fixes-java-run-fail` or one that fixes Java/JVM runtime test failures for an existing library version update. Focus on validating the Java runtime fix, keeping the diff scoped, and ensuring dynamic-access coverage does not drop between the previously tested version and the new version.\n./skills/review-fixes-java-run-fail/SKILL.md:9:These PRs repair tests, dependencies, or narrow runtime setup after an existing library version compiles, but the JVM-based test fails when it runs. Review them more lightly than `library-new-request` PRs: the library already exists, so the goal is to restore Java runtime behavior for the new version while preserving meaningful test and dynamic-access coverage.\n./skills/review-fixes-java-run-fail/SKILL.md:17:- Be more relaxed than `library-new-request`: do not reject only because a test resembles older coverage, stays in an existing package layout, or contains compatibility branches for multiple supported versions.\n./skills/review-fixes-java-run-fail/SKILL.md:18:- Do not accept changes that remove meaningful test coverage just to make `java` pass.\n./skills/review-fixes-java-run-fail/SKILL.md:20:- Treat dynamic-access coverage preservation as the main quality gate. The new version should not report lower dynamic-access coverage than the previously tested version unless the PR gives a concrete, credible reason.\n./skills/review-fixes-java-run-fail/SKILL.md:21:- For numeric gates, compare the reported evidence as-is. Do not inspect generation filters, agent configuration, or metadata contents to second-guess why dynamic-access or metadata-count numbers are what they are.\n./skills/review-fixes-java-run-fail/SKILL.md:56:4. Check dynamic-access coverage across versions.\n./skills/review-fixes-java-run-fail/SKILL.md:58:   - Compare `dynamicAccess.coverageRatio`, `coveredCalls`, `totalCalls`, and the `dynamicAccess.breakdown` entries for reflection, resources, proxies, serialization, JNI, or any other present report type.\n./skills/review-fixes-java-run-fail/SKILL.md:59:   - Do not use `user-code-filter.json`, agent configuration, or metadata file contents to argue that the reported dynamic-access values are not comparable. Use the stats values as reported unless the stats are missing or stale.\n./skills/review-fixes-java-run-fail/SKILL.md:60:   - A lower `coverageRatio` or lower `coveredCalls` for the new version is blocking unless the total dynamic-access surface changed and the PR explains why the reduction is expected.\n./skills/review-fixes-java-run-fail/SKILL.md:61:   - If `totalCalls` increases while `coveredCalls` stays flat or the ratio drops, ask for additional test coverage or metadata unless the uncovered calls are clearly outside the library behavior under test.\n./skills/review-fixes-java-run-fail/SKILL.md:69:   - Do not require an exact match. Differences are normal when upstream APIs move, generated metadata is cleaned up, or dynamic-access totals change.\n./skills/review-fixes-java-run-fail/SKILL.md:71:   - When the new total is below 25% of the original and the tests and dynamic-access stats still claim comparable coverage, ask for restored metadata or a concrete explanation of the API/runtime-surface change.\n./skills/review-fixes-java-run-fail/SKILL.md:77:   - Prefer seeing the full target `test` lane green because a Java runtime fix can still reduce native-image coverage.\n./skills/review-fixes-java-run-fail/SKILL.md:79:   - If CI is flaky but the diff and coverage comparison are sound, ask for a rerun instead of blocking on speculation.\n./skills/review-fixes-java-run-fail/SKILL.md:87:- Dynamic-access coverage does not drop between the previous and new tested versions, or any apparent drop is convincingly explained by a changed upstream API/runtime surface.\n./skills/review-fixes-java-run-fail/SKILL.md:95:- Dynamic-access coverage drops without a credible explanation and replacement coverage.\n./skills/review-fixes-java-run-fail/SKILL.md:103:- The API or runtime behavior change is plausible but the PR does not explain why a coverage drop is expected.\n./skills/review-fixes-java-run-fail/SKILL.md:110:- For coverage drops: say that dynamic-access coverage must not regress between tested versions, cite the old and new values, and ask for either restored coverage or a concrete explanation.\n./skills/review-fixes-java-run-fail/SKILL.md:112:- For deleted or bypassed coverage: say that the PR fixes Java runtime execution by removing coverage and should instead adapt the test to the new runtime behavior.\n./skills/review-fixes-java-run-fail/SKILL.md:114:- For native skips that does not depend on the open-ended dynamic class loading: say that the PR avoids the failing native path instead of fixing it, so it does not demonstrate native-image runtime coverage.\nforge/docs/README.md:63:- [workflows/dynamic-access.md](workflows/dynamic-access.md) — `WF-dynamic-access-workflow`.\nforge/docs/README.md:64:- [workflows/improve-library-coverage.md](workflows/improve-library-coverage.md) — `WF-improve-library-coverage`.\nforge/docs/README.md:68:- [workflows/code-coverage-improvement.md](workflows/code-coverage-improvement.md) — `WF-code-coverage-improvement` and `WF-code-coverage-improvement-architecture`: planned code coverage workflow, behavior and architecture in one file.\nforge/docs/README.md:72:code coverage workflow above do.\nforge/prompt_templates/fix-java-run/initial-with-sources.md:15