      val json: Json = invoice.asJson
  
      assertThat(json.hcursor.get[String]("id")).isEqualTo(Right("invoice-1"))
      assertThat(json.hcursor.downField("customer").get[String]("name")).isEqualTo(Right("Ada Lovelace"))
