        flags = Map("email" -> true, "sms" -> false)
      )
      val envelope: AutoEnvelope = AutoEnvelope(registration, priority = 3)
  
      val json: Json = envelope.asJson
  
      assertThat(json.hcursor.downField("registration").downField("owner").get[String]("name"))
  
