  trait Decoder[A] extends Serializable { self =>
  
    /**
     * Decode the given [[HCursor]].
     */
    def apply(c: HCursor): Decoder.Result[A]
  
    def decodeAccumulating(c: HCursor): Decoder.AccumulatingResult[A] = apply(c) match {
