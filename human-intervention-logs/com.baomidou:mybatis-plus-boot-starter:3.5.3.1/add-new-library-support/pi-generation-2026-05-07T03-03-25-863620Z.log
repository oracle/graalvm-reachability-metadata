       * @param consumer 消费
       * @param <T>      泛型
       */
      private <T> void getBeanThen(Class<T> clazz, Consumer<T> consumer) {
          if (this.applicationContext.getBeanNamesForType(clazz, false, false).length > 0) {
              consumer.accept(this.applicationContext.getBean(clazz));
          }
      }
  
