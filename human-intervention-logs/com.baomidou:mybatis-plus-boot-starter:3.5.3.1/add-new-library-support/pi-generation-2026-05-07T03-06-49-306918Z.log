[tool-call] delta {"path":"tests/src/com.baomidou/mybatis-plus-boot-starter/3.5.3.1/src/test/java/com_baomidou/mybatis_plus_boot_starter/Mybatis_plus_boot_starterTest.java","edits":[{"oldText":"import com.baomidou.mybatisplus.annotation.IdType;\nimport com.baomidou.mybatisplus.annotation.TableId;\nimport com.baomidou.mybatisplus.annotation.TableName;","newText":"import com.baomidou.mybatisplus.annotation.DbType;\nimport com.baomidou.mybatisplus.annotation.IdType;\nimport com.baomidou.mybatisplus.annotation.TableId;\nimport com.baomidou.mybatisplus.annotation.TableName;"},{"oldText":"import com.baomidou.mybatisplus.extension.ddl.IDdl;","newText":"import com.baomidou.mybatisplus.extension.ddl.IDdl;\nimport com.baomidou.mybatisplus.extension.plugins.MybatisPlusInterceptor;\nimport com.baomidou.mybatisplus.extension.plugins.inner.PaginationInnerInterceptor;\nimport com.baomidou.mybatisplus.extension.plugins.pagination.Page;"},{"oldText":"    @Test\n    void propertiesResolveMapperLocationsAndCanBeCustomized() {","newText":"    @Test\n    void interceptorBeanIsAppliedToPaginatedMapperQueries() {\n        try (ConfigurableApplicationContext context = new SpringApplicationBuilder(PaginationInterceptorApplication.class)\n                .web(WebApplicationType.NONE)\n                .properties(Map.of(\n                        \"spring.datasource.url\", \"jdbc:h2:mem:mybatisPlusBootStarterPagination;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\",\n                        \"spring.datasource.driver-class-name\", \"org.h2.Driver\",\n                        \"spring.datasource.hikari.maximum-pool-size\", \"2\",\n                        \"spring.datasource.hikari.connection-timeout\", \"2000\",\n                        \"spring.main.banner-mode\", \"off\",\n                        \"logging.level.root\", \"WARN\"))\n                .run()) {\n            JdbcTemplate jdbcTemplate = context.getBean(JdbcTemplate.class);\n            jdbcTemplate.execute(\"\"\"\n                    CREATE TABLE account (\n                        id BIGINT PRIMARY KEY,\n                        user_name VARCHAR(64) NOT NULL,\n                        age INTEGER NOT NULL\n                    )\n                    \"\"\");\n            jdbcTemplate.update(\"INSERT INTO account (id, user_name, age) VALUES (?, ?, ?)\", 1L, \"Ada Lovelace\", 36);\n            jdbcTemplate.update(\"INSERT INTO account (id, user_name, age) VALUES (?, ?, ?)\", 2L, \"Grace Hopper\", 85);\n            jdbcTemplate.update(\"INSERT INTO account (id, user_name, age) VALUES (?, ?, ?)\", 3L, \"Katherine Johnson\", 101);\n\n            AccountMapper mapper = context.getBean(AccountMapper.class);\n            Page<Account> page = mapper.selectPage(new Page<>(2, 1), Wrappers.<Account>query().orderByAsc(\"id\"));\n\n            assertThat(page.getTotal()).isEqualTo(3);\n            assertThat(page.getPages()).isEqualTo(3);\n            assertThat(page.getRecords())\n                    .extracting(Account::getUserName)\n                    .containsExactly(\"Grace Hopper\");\n        }\n    }\n\n    @Test\n    void propertiesResolveMapperLocationsAndCanBeCustomized() {"},{"oldText":"    @SpringBootConfiguration\n    @EnableAutoConfiguration\n    public static class FactoryBeanCustomizerApplication {","newText":"    @SpringBootConfiguration\n    @EnableAutoConfiguration\n    public static class PaginationInterceptorApplication {\n\n        @Bean\n        MapperFactoryBean<AccountMapper> accountMapper(SqlSessionFactory sqlSessionFactory) {\n            MapperFactoryBean<AccountMapper> mapperFactoryBean = new MapperFactoryBean<>(AccountMapper.class);\n            mapperFactoryBean.setSqlSessionFactory(sqlSessionFactory);\n            return mapperFactoryBean;\n        }\n\n        @Bean\n        MybatisPlusInterceptor mybatisPlusInterceptor() {\n            MybatisPlusInterceptor interceptor = new MybatisPlusInterceptor();\n            interceptor.addInnerInterceptor(new PaginationInnerInterceptor(DbType.H2));\n            return interceptor;\n        }\n    }\n\n    @SpringBootConfiguration\n    @EnableAutoConfiguration\n    public static class FactoryBeanCustomizerApplication {"}]}
[tool-call] end id=call_POmDqrmwNNSqebpRQyQHKGA9|fc_020143651f9d735f0169fc0193c2ec819e84558bec87e09743 name=edit args={"path": "tests/src/com.baomidou/mybatis-plus-boot-starter/3.5.3.1/src/test/java/com_baomidou/mybatis_plus_boot_starter/Mybatis_plus_boot_starterTest.java", "edits": [{"oldText": "import com.baomidou.mybatisplus.annotation.IdType;\nimport com.baomidou.mybatisplus.annotation.TableId;\nimport com.baomidou.mybatisplus.annotation.TableName;", "newText": "import com.baomidou.mybatisplus.annotation.DbType;\nimport com.baomidou.mybatisplus.annotation.IdType;\nimport com.baomidou.mybatisplus.annotation.TableId;\nimport com.baomidou.mybatisplus.annotation.TableName;"}, {"oldText": "import com.baomidou.mybatisplus.extension.ddl.IDdl;", "newText": "import com.baomidou.mybatisplus.extension.ddl.IDdl;\nimport com.baomidou.mybatisplus.extension.plugins.MybatisPlusInterceptor;\nimport com.baomidou.mybatisplus.extension.plugins.inner.PaginationInnerInterceptor;\nimport com.baomidou.mybatisplus.extension.plugins.pagination.Page;"}, {"oldText": "    @Test\n    void propertiesResolveMapperLocationsAndCanBeCustomized() {", "newText": "    @Test\n    void interceptorBeanIsAppliedToPaginatedMapperQueries() {\n        try (ConfigurableApplicationContext context = new SpringApplicationBuilder(PaginationInterceptorApplication.class)\n                .web(WebApplicationType.NONE)\n                .properties(Map.of(\n                        \"spring.datasource.url\", \"jdbc:h2:mem:mybatisPlusBootStarterPagination;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\",\n                        \"spring.datasource.driver-class-name\", \"org.h2.Driver\",\n                        \"spring.datasource.hikari.maximum-pool-size\", \"2\",\n                        \"spring.datasource.hikari.connection-timeout\", \"2000\",\n                        \"spring.main.banner-mode\", \"off\",\n                        \"logging.level.root\", \"WARN\"))\n                .run()) {\n            JdbcTemplate jdbcTemplate = context.getBean(JdbcTemplate.class);\n            jdbcTemplate.execute(\"\"\"\n                    CREATE TABLE account (\n                        id BIGINT PRIMARY KEY,\n                        user_name VARCHAR(64) NOT NULL,\n                        age INTEGER NOT NULL\n                    )\n                    \"\"\");\n            jdbcTemplate.update(\"INSERT INTO account (id, user_name, age) VALUES (?, ?, ?)\", 1L, \"Ada Lovelace\", 36);\n            jdbcTemplate.update(\"INSERT INTO account (id, user_name, age) VALUES (?, ?, ?)\", 2L, \"Grace Hopper\", 85);\n            jdbcTemplate.update(\"INSERT INTO account (id, user_name, age) VALUES (?, ?, ?)\", 3L, \"Katherine Johnson\", 101);\n\n            AccountMapper mapper = context.getBean(AccountMapper.class);\n            Page<Account> page = mapper.selectPage(new Page<>(2, 1), Wrappers.<Account>query().orderByAsc(\"id\"));\n\n            assertThat(page.getTotal()).isEqualTo(3);\n            assertThat(page.getPages()).isEqualTo(3);\n            assertThat(page.getRecords())\n                    .extracting(Account::getUserName)\n                    .containsExactly(\"Grace Hopper\");\n        }\n    }\n\n    @Test\n    void propertiesResolveMapperLocationsAndCanBeCustomized() {"}, {"oldText": "    @SpringBootConfiguration\n    @EnableAutoConfiguration\n    public static class FactoryBeanCustomizerApplication {", "newText": "    @SpringBootConfiguration\n    @EnableAutoConfiguration\n    public static class PaginationInterceptorApplication {\n\n        @Bean\n        MapperFactoryBean<AccountMapper> accountMapper(SqlSessionFactory sqlSessionFactory) {\n            MapperFactoryBean<AccountMapper> mapperFactoryBean = new MapperFactoryBean<>(AccountMapper.class);\n            mapperFactoryBean.setSqlSessionFactory(sqlSessionFactory);\n            return mapperFactoryBean;\n        }\n\n        @Bean\n        MybatisPlusInterceptor mybatisPlusInterceptor() {\n            MybatisPlusInterceptor inte