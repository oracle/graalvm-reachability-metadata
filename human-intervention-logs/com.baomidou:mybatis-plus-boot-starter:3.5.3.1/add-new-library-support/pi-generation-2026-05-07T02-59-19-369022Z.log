               */
              ddlList.forEach(ddl -> ddl.runScript(dataSource -> DdlHelper.runScript(ddl.getDdlGenerator(),
                      dataSource, ddl.getSqlFiles(), true)));
          }
          log.debug("  ...  DDL end create  ...  ");
