melConsumer.start();\n\n            List<TaskHealthState> healthStates = waitForHealthStateChecks(camelConsumer);\n\n            assertThat(healthStates).hasSize(1);\n            assertThat(healthStates.get(0).getClientId()).isEqualTo(FIELD_CLIENT_ID);\n            assertThat(clientFactory.consumer).isNotNull();\n        } finally {\n            if (camelConsumer != null) {\n                camelConsumer.stop();\n            }\n            context.stop();\n        }\n    }\n\n    @Test\n    void healthStateChecksKafkaConsumerNetworkClientReadiness() throws Exception {"}, {"oldText": "    private static final class NativeKafkaClientFactory implements KafkaClientFactory {", "newText": "    private static final class FieldClientIdKafkaClientFactory implements KafkaClientFactory {\n        private ClientIdMockConsumer consumer;\n\n        @Override\n        public Producer<Object, Object> getProducer(Properties kafkaProps) {\n            throw new UnsupportedOperationException(\"Producer creation is not used by this consumer test\");\n        }\n\n        @Override\n        public Consumer<Object, Object> getConsumer(Properties kafkaProps) {\n            kafkaProps.remove(ConsumerConfig.CLIENT_ID_CONFIG);\n            consumer = new ClientIdMockConsumer();\n            return consumer;\n        }\n\n        @Override\n        public String getBrokers(KafkaConfiguration configuration) {\n            return configuration.getBrokers();\n        }\n    }\n\n    private static final class ClientIdMockConsumer extends MockConsumer<Object, Object> {\n        private final String clientId = FIELD_CLIENT_ID;\n\n        private ClientIdMockConsumer() {\n            super(OffsetResetStrategy.EARLIEST);\n        }\n    }\n\n    private static final class NativeKafkaClientFactory implements KafkaClientFactory {"}]}
