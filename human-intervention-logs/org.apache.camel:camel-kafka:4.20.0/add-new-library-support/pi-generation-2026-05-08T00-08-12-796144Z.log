[tool-call] delta {"path":"tests/src/org.apache.camel/camel-kafka/4.20.0/src/test/java/org_apache_camel/camel_kafka/KafkaFetchRecordsTest.java","edits":[{"oldText":"import org.apache.kafka.clients.consumer.ConsumerConfig;\nimport org.apache.kafka.clients.producer.Producer;","newText":"import org.apache.kafka.clients.consumer.ConsumerConfig;\nimport org.apache.kafka.clients.consumer.MockConsumer;\nimport org.apache.kafka.clients.consumer.OffsetResetStrategy;\nimport org.apache.kafka.clients.producer.Producer;"},{"oldText":"    private static final long HEALTH_CHECK_DEADLINE_MILLIS = 10_000L;\n    private static final long HEALTH_CHECK_INTERVAL_MILLIS = 50L;\n\n    @Test","newText":"    private static final long HEALTH_CHECK_DEADLINE_MILLIS = 10_000L;\n    private static final long HEALTH_CHECK_INTERVAL_MILLIS = 50L;\n    private static final String FIELD_CLIENT_ID = \"client-id-from-consumer-field\";\n\n    @Test"},{"oldText":"    @Test\n    void healthStateChecksKafkaConsumerNetworkClientReadiness() throws Exception {","newText":"    @Test\n    void createConsumerReadsClientIdFromKafkaConsumerFieldWhenPropertyIsAbsent() throws Exception {\n        FieldClientIdKafkaClientFactory clientFactory = new FieldClientIdKafkaClientFactory();\n        DefaultCamelContext context = new DefaultCamelContext();\n        KafkaConsumer camelConsumer = null;\n\n        try {\n            KafkaComponent component = new KafkaComponent(context);\n            component.setKafkaClientFactory(clientFactory);\n            context.addComponent(\"kafka\", component);\n            context.start();\n\n            KafkaEndpoint endpoint = context.getEndpoint(consumerUri(), KafkaEndpoint.class);\n            endpoint.setKafkaClientFactory(clientFactory);\n            camelConsumer = (KafkaConsumer) endpoint.createConsumer(exchange -> assertThat(exchange).isNotNull());\n            camelConsumer.start();\n\n            List<TaskHealthState> healthStates = waitForHealthStateChecks(camelConsumer);\n\n            assertThat(healthStates).hasSize(1);\n            assertThat(healthStates.get(0).getClientId()).isEqualTo(FIELD_CLIENT_ID);\n            assertThat(clientFactory.consumer).isNotNull();\n        } finally {\n            if (camelConsumer != null) {\n                camelConsumer.stop();\n            }\n            context.stop();\n        }\n    }\n\n    @Test\n    void healthStateChecksKafkaConsumerNetworkClientReadiness() throws Exception {"},{"oldText":"    private static final class NativeKafkaClientFactory implements KafkaClientFactory {","newText":"    private static final class FieldClientIdKafkaClientFactory implements KafkaClientFactory {\n        private ClientIdMockConsumer consumer;\n\n        @Override\n        public Producer<Object, Object> getProducer(Properties kafkaProps) {\n            throw new UnsupportedOperationException(\"Producer creation is not used by this consumer test\");\n        }\n\n        @Override\n        public Consumer<Object, Object> getConsumer(Properties kafkaProps) {\n            kafkaProps.remove(ConsumerConfig.CLIENT_ID_CONFIG);\n            consumer = new ClientIdMockConsumer();\n            return consumer;\n        }\n\n        @Override\n        public String getBrokers(KafkaConfiguration configuration) {\n            return configuration.getBrokers();\n        }\n    }\n\n    private static final class ClientIdMockConsumer extends MockConsumer<Object, Object> {\n        private final String clientId = FIELD_CLIENT_ID;\n\n        private ClientIdMockConsumer() {\n            super(OffsetResetStrategy.EARLIEST);\n        }\n    }\n\n    private static final class NativeKafkaClientFactory implements KafkaClientFactory {"}]}
