 private static final String FIELD_CLIENT_ID = \"client-id-from-consumer-field\";\n\n    @Test"}, {"oldText": "    @Test\n    void healthStateChecksKafkaConsumerNetworkClientReadiness() throws Exception {", "newText": "    @Test\n    void createConsumerReadsClientIdFromKafkaConsumerFieldWhenPropertyIsAbsent() throws Exception {\n        FieldClientIdKafkaClientFactory clientFactory = new FieldClientIdKafkaClientFactory();\n        DefaultCamelContext context = new DefaultCamelContext();\n        KafkaConsumer camelConsumer = null;\n\n        try {\n            KafkaComponent component = new KafkaComponent(context);\n            component.setKafkaClientFactory(clientFactory);\n            context.addComponent(\"kafka\", component);\n            context.start();\n\n            KafkaEndpoint endpoint = context.getEndpoint(consumerUri(), KafkaEndpoint.class);\n            endpoint.setKafkaClientFactory(clientFactory);\n            camelConsumer = (KafkaConsumer) endpoint.createConsumer(exchange -> assertThat(exchange).isNotNull());\n            camelConsumer.start();\n\n            List<TaskHealthState> healthStates = waitForHealthStateChecks(camelConsumer);\n\n            assertThat(healthStates).hasSize(1);\n            assertThat(healthStates.get(0).getClientId()).isEqualTo(FIELD_CLIENT_ID);\n            assertThat(clientFactory.consumer).isNotNull();\n        } finally {\n            if (camelConsumer != null) {\n                camelConsumer.stop();\n            }\n            context.stop();\n        }\n    }\n\n    @Test\n    void healthStateChecksKafkaConsumerNetworkClientReadiness() throws Exception {"}, {"oldText": "    private static final class NativeKafkaClientFactory implements KafkaClientFactory {", "newText": "    private static final class FieldClientIdKafkaClientFactory implements KafkaClientFactory {\n        private ClientIdMockConsumer consumer;\n\n        @Override\n        public Producer<Object, Object> getProducer(Properties kafkaProps) {\n     