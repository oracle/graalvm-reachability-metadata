[tool-call] delta {"path":"tests/src/org.apache.camel/camel-kafka/4.20.0/src/test/java/org_apache_camel/camel_kafka/KafkaFetchRecordsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_kafka;\n\nimport java.util.List;\nimport java.util.Properties;\n\nimport org.apache.camel.component.kafka.KafkaClientFactory;\nimport org.apache.camel.component.kafka.KafkaComponent;\nimport org.apache.camel.component.kafka.KafkaEndpoint;\nimport org.apache.camel.component.kafka.TaskHealthState;\nimport org.apache.camel.impl.DefaultCamelContext;\nimport org.apache.kafka.clients.consumer.ConsumerConfig;\nimport org.apache.kafka.clients.producer.Producer;\nimport org.apache.kafka.common.serialization.StringDeserializer;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class KafkaFetchRecordsTest {\n\n    private static final long HEALTH_CHECK_DEADLINE_MILLIS = 10_000L;\n    private static final long HEALTH_CHECK_INTERVAL_MILLIS = 50L;\n\n    @Test\n    void healthStateChecksKafkaConsumerNetworkClientReadiness() throws Exception {\n        NativeKafkaClientFactory clientFactory = new NativeKafkaClientFactory();\n        DefaultCamelContext context = new DefaultCamelContext();\n        org.apache.camel.component.kafka.KafkaConsumer camelConsumer = null;\n\n        try {\n            KafkaComponent component = new KafkaComponent(context);\n            component.setKafkaClientFactory(clientFactory);\n            context.addComponent(\"kafka\", component);\n            context.start();\n\n            KafkaEndpoint endpoint = context.getEndpoint(consumerUri(), KafkaEndpoint.class);\n            endpoint.setKafkaClientFactory(clientFactory);\n            camelConsumer = (org.apache.camel.component.kafka.KafkaConsumer) endpoint.createConsumer(exchange -> {\n            });\n            camelConsumer.start();\n\n            List<TaskHealthState> healthStates = waitForHealthStateChecks(camelConsumer);\n\n            assertThat(healthStates).hasSize(1);\n            assertThat(healthStates.get(0).getClientId()).isNotNull();\n            assertThat(clientFactory.consumer).isNotNull();\n        } finally {\n            if (camelConsumer != null) {\n                camelConsumer.stop();\n            }\n            context.stop();\n        }\n    }\n\n    private static String consumerUri() {\n        return \"kafka:test-topic\"\n                + \"?brokers=localhost:65535\"\n                + \"&groupId=KafkaFetchRecordsTest\"\n                + \"&keyDeserializer=\" + StringDeserializer.class.getName()\n                + \"&valueDeserializer=\" + StringDeserializer.class.getName()\n                + \"&autoOffsetReset=earliest\"\n                + \"&autoCommitEnable=false\"\n                + \"&consumersCount=1\"\n                + \"&pollTimeoutMs=50\"\n                + \"&requestTimeoutMs=1000\"\n                + \"&sessionTimeoutMs=1000\"\n                + \"&heartbeatIntervalMs=300\"\n                + \"&shutdownTimeout=1000\";\n    }\n\n    private static List<TaskHealthState> waitForHealthStateChecks(\n            org.apache.camel.component.kafka.KafkaConsumer camelConsumer) throws InterruptedException {\n        long deadline = System.currentTimeMillis() + HEALTH_CHECK_DEADLINE_MILLIS;\n        List<TaskHealthState> healthStates = List.of();\n        boolean clientIdObserved = false;\n\n        while (System.currentTimeMillis() < deadline) {\n            healthStates = camelConsumer.healthStates();\n            if (!healthStates.isEmpty() && healthStates.get(0).getClientId() != null) {\n                clientIdObserved = true;\n            }\n            if (clientIdObserved) {\n                for (int i = 0; i < 10; i++) {\n                    healthStates = camelConsumer.healthStates();\n                    Thread.sleep(HEALTH_CHECK_INTERVAL_MILLIS);\n                }\n                return healthStates;\n            }\n            Thread.sleep(HEALTH_CHECK_INTERVAL_MILLIS);\n        }\n\n        return healthStates;\n    }\n\n    private static final class NativeKafkaClientFactory implements KafkaClientFactory {\n        private org.apache.kafka.clients.consumer.KafkaConsumer<Object, Object> consumer;\n\n        @Override\n        public Producer getProducer(Properties kafkaProps) {\n            throw new UnsupportedOperationException(\"Producer creation is not used by this consumer test\");\n        }\n\n        @Override\n        public org.apache.kafka.clients.consumer.Consumer getConsumer(Properties kafkaProps) {\n            kafkaProps.putIfAbsent(ConsumerConfig.KEY_DESERIALIZER_CLASS_CONFIG, StringDeserializer.class);\n            kafkaProps.putIfAbsent(ConsumerConfig.VALUE_DESERIALIZER_CLASS_CONFIG, StringDeserializer.class);\n            consumer = new org.apache.kafka.clients.consumer.KafkaConsumer<>(kafkaProps);\n            return consumer;\n        }\n\n        @Override\n        public String getBrokers(org.apache.camel.component.kafka.KafkaConfiguration configuration) {\n            return configuration.getBrokers();\n        }\n    }\n}\n"}
