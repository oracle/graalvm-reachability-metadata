[tool-call] delta {"path":"tests/src/org.apache.camel/camel-kafka/4.20.0/src/test/java/org_apache_camel/camel_kafka/KafkaProducerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_camel.camel_kafka;\n\nimport java.time.Duration;\nimport java.util.Properties;\n\nimport org.apache.camel.Producer;\nimport org.apache.camel.component.kafka.KafkaClientFactory;\nimport org.apache.camel.component.kafka.KafkaComponent;\nimport org.apache.camel.component.kafka.KafkaConfiguration;\nimport org.apache.camel.component.kafka.KafkaEndpoint;\nimport org.apache.camel.impl.DefaultCamelContext;\nimport org.apache.kafka.clients.consumer.Consumer;\nimport org.apache.kafka.clients.producer.MockProducer;\nimport org.apache.kafka.clients.producer.ProducerConfig;\nimport org.apache.kafka.common.serialization.StringSerializer;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class KafkaProducerTest {\n\n    private static final String BROKERS = \"localhost:65535\";\n    private static final String FIELD_CLIENT_ID = \"client-id-from-producer-field\";\n\n    @Test\n    void startReadsClientIdFromKafkaProducerFieldWhenPropertyIsAbsent() throws Exception {\n        FieldClientIdKafkaClientFactory clientFactory = new FieldClientIdKafkaClientFactory();\n        DefaultCamelContext context = new DefaultCamelContext();\n        Producer camelProducer = null;\n\n        try {\n            KafkaComponent component = new KafkaComponent(context);\n            component.setKafkaClientFactory(clientFactory);\n            context.addComponent(\"kafka\", component);\n            context.start();\n\n            KafkaEndpoint endpoint = context.getEndpoint(producerUri(), KafkaEndpoint.class);\n            endpoint.setKafkaClientFactory(clientFactory);\n            camelProducer = endpoint.createProducer();\n            camelProducer.start();\n\n            assertThat(clientFactory.producer).isNotNull();\n            assertThat(clientFactory.producer.closed()).isFalse();\n        } finally {\n            if (camelProducer != null) {\n                camelProducer.stop();\n            }\n            context.stop();\n        }\n    }\n\n    @Test\n    void readinessChecksNativeKafkaProducerNetworkClient() {\n        org.apache.kafka.clients.producer.KafkaProducer<Object, Object> nativeProducer = createNativeProducer();\n        try {\n            KafkaEndpoint endpoint = new KafkaEndpoint(\"kafka:test-topic\", new KafkaComponent());\n            org.apache.camel.component.kafka.KafkaProducer camelProducer\n                    = new org.apache.camel.component.kafka.KafkaProducer(endpoint);\n            camelProducer.setKafkaProducer(nativeProducer);\n\n            assertThat(camelProducer.isReady()).isFalse();\n        } finally {\n            nativeProducer.close(Duration.ofSeconds(1));\n        }\n    }\n\n    private static String producerUri() {\n        return \"kafka:test-topic\"\n                + \"?brokers=\" + BROKERS\n                + \"&synchronous=true\"\n                + \"&shutdownTimeout=1000\";\n    }\n\n    private static org.apache.kafka.clients.producer.KafkaProducer<Object, Object> createNativeProducer() {\n        Properties properties = new Properties();\n        properties.put(ProducerConfig.BOOTSTRAP_SERVERS_CONFIG, BROKERS);\n        properties.put(ProducerConfig.CLIENT_ID_CONFIG, \"KafkaProducerTest\");\n        properties.put(ProducerConfig.KEY_SERIALIZER_CLASS_CONFIG, StringSerializer.class);\n        properties.put(ProducerConfig.VALUE_SERIALIZER_CLASS_CONFIG, StringSerializer.class);\n        properties.put(ProducerConfig.MAX_BLOCK_MS_CONFIG, \"1000\");\n        properties.put(ProducerConfig.REQUEST_TIMEOUT_MS_CONFIG, \"1000\");\n        properties.put(ProducerConfig.RECONNECT_BACKOFF_MS_CONFIG, \"50\");\n        properties.put(ProducerConfig.RECONNECT_BACKOFF_MAX_MS_CONFIG, \"50\");\n        return new org.apache.kafka.clients.producer.KafkaProducer<>(properties);\n    }\n\n    private static final class FieldClientIdKafkaClientFactory implements KafkaClientFactory {\n        private ClientIdMockProducer producer;\n\n        @Override\n        public org.apache.kafka.clients.producer.Producer<Object, Object> getProducer(Properties kafkaProps) {\n            kafkaProps.remove(ProducerConfig.CLIENT_ID_CONFIG);\n            producer = new ClientIdMockProducer();\n            return producer;\n        }\n\n        @Override\n        public Consumer<Object, Object> getConsumer(Properties kafkaProps) {\n            throw new UnsupportedOperationException(\"Consumer creation is not used by this producer test\");\n        }\n\n        @Override\n        public String getBrokers(KafkaConfiguration configuration) {\n            return configuration.getBrokers();\n        }\n    }\n\n    private static final class ClientIdMockProducer extends MockProducer<Object, Object> {\n        private final String clientId = FIELD_CLIENT_ID;\n    }\n}\n"}
