  package org_apache_camel.camel_kafka;
  
  import java.util.List;
  import java.util.Properties;
  
  import org.apache.camel.component.kafka.KafkaClientFactory;
  import org.apache.camel.component.kafka.KafkaComponent;
  import org.apache.camel.component.kafka.KafkaConfiguration;
  import org.apache.camel.component.kafka.KafkaConsumer;
  import org.apache.camel.component.kafka.KafkaEndpoint;
  import org.apache.camel.component.kafka.TaskHealthState;
  import org.apache.camel.impl.DefaultCamelContext;
  import org.apache.kafka.clients.consumer.Consumer;
  import org.apache.kafka.clients.consumer.ConsumerConfig;
  import org.apache.kafka.clients.consumer.MockConsumer;
  import org.apache.kafka.clients.consumer.OffsetResetStrategy;
  import org.apache.kafka.clients.producer.Producer;
  import org.apache.kafka.common.serialization.StringDeserializer;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class KafkaFetchRecordsTest {
  
      private static final long HEALTH_CHECK_DEADLINE_MILLIS = 10_000L;
      private static final long HEALTH_CHECK_INTERVAL_MILLIS = 50L;
      private static final String FIELD_CLIENT_ID = "client-id-from-consumer-field";
  
      @Test
      void createConsumerReadsClientIdFromKafkaConsumerFieldWhenPropertyIsAbsent() throws Exception {
          FieldClientIdKafkaClientFactory clientFactory = new FieldClientIdKafkaClientFactory();
          DefaultCamelContext context = new DefaultCamelContext();
          KafkaConsumer camelConsumer = null;
  
          try {
              KafkaComponent component = new KafkaComponent(context);
              component.setKafkaClientFactory(clientFactory);
              context.addComponent("kafka", component);
              context.start();
  
              KafkaEndpoint endpoint = context.getEndpoint(consumerUri(), KafkaEndpoint.class);
              endpoint.setKafkaClientFactory(clientFactory);
              camelConsumer = (KafkaConsumer) endpoint.createConsumer(exchange -> assertThat(exchange).isNotNull());
              camelConsumer.start();
  
              List<TaskHealthState> healthStates = waitForHealthStateChecks(camelConsumer);
  
              assertThat(healthStates).hasSize(1);
              assertThat(healthStates.get(0).getClientId()).isEqualTo(FIELD_CLIENT_ID);
              assertThat(clientFactory.consumer).isNotNull();
          } finally {
              if (camelConsumer != null) {
                  camelConsumer.stop();
              }
              context.stop();
          }
      }
  
      @Test
      void healthStateChecksKafkaConsumerNetworkClientReadiness() throws Exception {
          NativeKafkaClientFactory clientFactory = new NativeKafkaClientFactory();
          DefaultCamelContext context = new DefaultCamelContext();
          KafkaConsumer camelConsumer = null;
  
          try {
              KafkaComponent component = new KafkaComponent(context);
              component.setKafkaClientFactory(clientFactory);
              context.addComponent("kafka", component);
              context.start();
  
              KafkaEndpoint endpoint = context.getEndpoint(consumerUri(), KafkaEndpoint.class);
              endpoint.setKafkaClientFactory(clientFactory);
              camelConsumer = (KafkaConsumer) endpoint.createConsumer(exchange -> assertThat(exchange).isNotNull());
              camelConsumer.start();
  
              List<TaskHealthState> healthStates = waitForHealthStateChecks(camelConsumer);
  
              assertThat(healthStates).hasSize(1);
              assertThat(healthStates.get(0).getClientId()).isNotNull();
              assertThat(clientFactory.consumer).isNotNull();
          } finally {
              if (camelConsumer != null) {
                  camelConsumer.stop();
              }
              context.stop();
          }
      }
  
      private static String consumerUri() {
          return "kafka:test-topic"
                  + "?brokers=localhost:65535"
                  + "&groupId=KafkaFetchRecordsTest"
                  + "&keyDeserializer=" + StringDeserializer.class.getName()
                  + "&valueDeserializer=" + StringDeserializer.class.getName()
                  + "&autoOffsetReset=earliest"
                  + "&autoCommitEnable=false"
                  + "&consumersCount=1"
                  + "&pollTimeoutMs=50"
                  + "&requestTimeoutMs=1000"
                  + "&sessionTimeoutMs=1000"
                  + "&heartbeatIntervalMs=300"
                  + "&shutdownTimeout=1000";
      }
  
      private static List<TaskHealthState> waitForHealthStateChecks(KafkaConsumer camelConsumer)
              throws InterruptedException {
          long deadline = System.currentTimeMillis() + HEALTH_CHECK_DEADLINE_MILLIS;
          List<TaskHealthState> healthStates = List.of();
          boolean clientIdObserved = false;
  
          while (System.currentTimeMillis() < deadline) {
              healthStates = camelConsumer.healthStates();
              if (!healthStates.isEmpty() && healthStates.get(0).getClientId() != null) {
                  clientIdObserved = true;
              }
              if (clientIdObserved) {
                  for (int i = 0; i < 10; i++) {
                      healthStates = camelConsumer.healthStates();
                      Thread.sleep(HEALTH_CHECK_INTERVAL_MILLIS);
                  }
                  return healthStates;
              }
              Thread.sleep(HEALTH_CHECK_INTERVAL_MILLIS);
          }
  
          return healthStates;
      }
  
      private static final class FieldClientIdKafkaClientFactory implements KafkaClientFactory {
          private ClientIdMockConsumer consumer;
  
          @Override
          public Producer<Object, Object> getProducer(Properties kafkaProps) {
              throw new UnsupportedOperationException("Producer creation is not used by this consumer test");
          }
  
          @Override
          public Consumer<Object, Object> getConsumer(Properties kafkaProps) {
              kafkaProps.remove(ConsumerConfig.CLIENT_ID_CONFIG);
              consumer = new ClientIdMockConsumer();
              return consumer;
          }
  
          @Override
          public String getBrokers(KafkaConfiguration configuration) {
              return configuration.getBrokers();
          }
      }
  
      private static final class ClientIdMockConsumer extends MockConsumer<Object, Object> {
          private final String clientId = FIELD_CLIENT_ID;
  
          private ClientIdMockConsumer() {
              super(OffsetResetStrategy.EARLIEST);
          }
      }
  
      private static final class NativeKafkaClientFactory implements KafkaClientFactory {
          private org.apache.kafka.clients.consumer.KafkaConsumer<Object, Object> consumer;
  
          @Override
          public Producer<Object, Object> getProducer(Properties kafkaProps) {
              throw new UnsupportedOperationException("Producer creation is not used by this consumer test");
          }
  
          @Override
          public Consumer<Object, Object> getConsumer(Properties kafkaProps) {
              kafkaProps.putIfAbsent(ConsumerConfig.KEY_DESERIALIZER_CLASS_CONFIG, StringDeserializer.class);
              kafkaProps.putIfAbsent(ConsumerConfig.VALUE_DESERIALIZER_CLASS_CONFIG, StringDeserializer.class);
              kafkaProps.put(ConsumerConfig.DEFAULT_API_TIMEOUT_MS_CONFIG, "1000");
              kafkaProps.put(ConsumerConfig.RECONNECT_BACKOFF_MS_CONFIG, "50");
              kafkaProps.put(ConsumerConfig.RECONNECT_BACKOFF_MAX_MS_CONFIG, "50");
              consumer = new org.apache.kafka.clients.consumer.KafkaConsumer<>(kafkaProps);
              kafkaProps.remove(ConsumerConfig.CLIENT_ID_CONFIG);
              return consumer;
          }
  
          @Override
          public String getBrokers(KafkaConfiguration configuration) {
              return configuration.getBrokers();
          }
      }
  }
