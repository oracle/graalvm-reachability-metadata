e() {\\n        return state.get().name();\\n    }\\n\\n    private class PausePreservingRebalanceListener implements ConsumerRebalanceListener {\\n        private final ConsumerRebalanceListener delegate;\\n\\n        PausePreservingRebalanceListener(ConsumerRebalanceListener delegate) {\\n            this.delegate = delegate;\\n        }\\n\\n        @Override\\n        public void onPartitionsRevoked(Collection<TopicPartition> partitions) {\\n            delegate.onPartitionsRevoked(partitions);\\n        }\\n\\n        @Override\\n        public void onPartitionsAssigned(Collection<TopicPartition> partitions) {\\n            if (state.compareAndSet(State.PAUSED, State.PAUSE_REQUESTED)) {\\n                LOG.debug(\\\"Partitions were assigned while paused, the consumer will be re-paused\\\");\\n            }\\n            delegate.onPartitionsAssigned(partitions);\\n        }\\n\\n        @Override\\n        public void onPartitionsLost(Collection<TopicPartition> partitions) {\\n            delegate.onPartitionsLost(partitions);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778198614140}]}\nhuman-intervention-logs/org.apache.camel:camel-kafka:4.20.0/add-new-library-support/pi-generation-2026-05-08T00-08-12-796144Z.log:1157:      void testProduceAndConsume() throws Exception {\nhuman-intervention-logs/org.apache.camel:camel-kafka:4.20.0/add-new-library-support/pi-generation-2026-05-08T00-08-12-796144Z.log:1331:                      .isNotInstanceOf(UnsupportedOperationException.class);\nhuman-intervention-logs/org.apache.camel:camel-kafka:4.20.0/add-new-library-support/pi-generation-2026-05-08T00-08-12-796144Z.log:1350:                      .isNotInstanceOf(UnsupportedOperationException.class);\nhuman-intervention-logs/org.apache.camel:camel-kafka:4.20.0/add-new-library-support/pi-generation-2026-05-08T00-08-12-796144Z.log:1355:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_9lbJneVUvTwZBY