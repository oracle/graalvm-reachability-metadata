ducer.stop();\\n            }\\n            context.stop();\\n        }\\n    }\\n\\n    @Test\\n    void readinessChecksNativeKafkaProducerNetworkClient() {\\n        org.apache.kafka.clients.producer.KafkaProducer<Object, Object> nativeProducer = createNativeProducer();\\n        try {\\n            KafkaEndpoint endpoint = new KafkaEndpoint(\\\"kafka:test-topic\\\", new KafkaComponent());\\n            org.apache.camel.component.kafka.KafkaProducer camelProducer\\n                    = new org.apache.camel.component.kafka.KafkaProducer(endpoint);\\n            camelProducer.setKafkaProducer(nativeProducer);\\n\\n            assertThat(camelProducer.isReady()).isFalse();\\n        } finally {\\n            nativeProducer.close(Duration.ofSeconds(1));\\n        }\\n    }\\n\\n    private static String producerUri() {\\n        return \\\"kafka:test-topic\\\"\\n                + \\\"?brokers=\\\" + BROKERS\\n                + \\\"&synchronous=true\\\"\\n                + \\\"&shutdownTimeout=1000\\\";\\n    }\\n\\n    private static org.apache.kafka.clients.producer.KafkaProducer<Object, Object> createNativeProducer() {\\n        Properties properties = new Properties();\\n        properties.put(ProducerConfig.BOOTSTRAP_SERVERS_CONFIG, BROKERS);\\n        properties.put(ProducerConfig.CLIENT_ID_CONFIG, \\\"KafkaProducerTest\\\");\\n        properties.put(ProducerConfig.KEY_SERIALIZER_CLASS_CONFIG, StringSerializer.class);\\n        properties.put(ProducerConfig.VALUE_SERIALIZER_CLASS_CONFIG, StringSerializer.class);\\n        properties.put(ProducerConfig.MAX_BLOCK_MS_CONFIG, \\\"1000\\\");\\n        properties.put(ProducerConfig.REQUEST_TIMEOUT_MS_CONFIG, \\\"1000\\\");\\n        properties.put(ProducerConfig.RECONNECT_BACKOFF_MS_CONFIG, \\\"50\\\");\\n        properties.put(ProducerConfig.RECONNECT_BACKOFF_MAX_MS_CONFIG, \\\"50\\\");\\n        return new org.apache.kafka.clients.producer.KafkaProducer<>(properties);\\n    }\\n\\n    private static final class FieldClientIdKafkaClientFactory implements KafkaClientFactory {\\n        private ClientIdMockProducer producer;\\n\\n        @Override\\n        public org.apache.kafka.clients.producer.Producer<Object, Object> getProducer(Properties kafkaProps) {\\n            kafkaProps.remove(ProducerConfig.CLIENT_ID_CONFIG);\\n            producer = new ClientIdMockProducer();\\n            return producer;\\n        }\\n\\n        @Override\\n        public Consumer<Object, Object> getConsumer(Properties kafkaProps) {\\n            throw new UnsupportedOperationException(\\\"Consumer creation is not used by this producer test\\\");\\n        }\\n\\n        @Override\\n        public String getBrokers(KafkaConfiguration configuration) {\\n            return configuration.getBrokers();\\n        }\\n    }\\n\\n    private static final class ClientIdMockProducer extends MockProducer<Object, Object> {\\n        private final String clientId = FIELD_CLIENT_ID;\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778199618968}]}\nhuman-intervention-logs/org.apache.camel:camel-kafka:4.20.0/add-new-library-support/pi-generation-2026-05-08T00-08-12-796144Z.log:203:      void test() throws Exception {\nhuman-intervention-logs/org.apache.camel:camel-kafka:4.20.0/add-new-library-support/pi-generation-2026-05-08T00-08-12-796144Z.log:204:          System.out.println(\"This is just a placeholder, implement your test\");\nhuman-intervention-logs/org.apache.camel:camel-kafka:4.20.0/add-new-library-support/pi-generation-2026-05-08T00-08-12-796144Z.log:207:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_B81iIQ6w6F6dLV4Jh2j2nhH4|fc_08622516edf788ea0169fd284b9dbc81a085e42279c9e5baa9\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/