{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/net.sf.ehcache/ehcache-core/2.4.4/src/test/java/net_sf_ehcache/ehcache_core/BeanHandlerTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sf_ehcache.ehcache_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.lang.reflect.Constructor;\nimport java.nio.charset.StandardCharsets;\n\nimport javax.xml.parsers.SAXParser;\nimport javax.xml.parsers.SAXParserFactory;\n\nimport net.sf.ehcache.config.CacheConfiguration;\nimport net.sf.ehcache.config.Configuration;\nimport net.sf.ehcache.config.ConfigurationFactory;\nimport net.sf.ehcache.config.FactoryConfiguration;\nimport net.sf.ehcache.config.SearchAttribute;\nimport net.sf.ehcache.config.Searchable;\nimport net.sf.ehcache.config.TerracottaClientConfiguration;\n\nimport org.junit.jupiter.api.Test;\nimport org.xml.sax.helpers.DefaultHandler;\n\npublic class BeanHandlerTest {\n    @Test\n    void parsesConfigurationElementsAttributesAndExtractedTerracottaSubtree() {\n        Configuration configuration = parseConfiguration(\"\"\"\n                <ehcache name=\"bean-handler-test\" updateCheck=\"false\" dynamicConfig=\"false\"\n                         monitoring=\"off\" defaultTransactionTimeoutInSeconds=\"21\">\n                  <diskStore path=\"java.io.tmpdir/ehcache-bean-handler\"/>\n                  <terracottaConfig rejoin=\"true\">\n                    <tc-config>\n                      <servers>\n                        <server host=\"localhost\" name=\"server-one\">\n                          <dso-port>9510</dso-port>\n                        </server>\n                      </servers>\n                    </tc-config>\n                  </terracottaConfig>\n                  <cacheManagerPeerProviderFactory\n                      class=\"net.sf.ehcache.distribution.RMICacheManagerPeerProviderFactory\"\n                      properties=\"peerDiscovery=manual\" propertySeparator=\",\"/>\n                  <defaultCache maxElementsInMemory=\"5\" eternal=\"false\" timeToIdleSeconds=\"1\"\n                      timeToLiveSeconds=\"2\" overflowToDisk=\"false\" memoryStoreEvictionPolicy=\"LRU\">\n                    <cacheEventListenerFactory class=\"example.ListenerFactory\" properties=\"listen=true\"/>\n                    <cacheLoaderFactory class=\"example.LoaderFactory\" properties=\"loader=true\"/>\n                    <bootstrapCacheLoaderFactory class=\"example.BootstrapFactory\" properties=\"bootstrap=true\"/>\n                    <cacheExceptionHandlerFactory class=\"example.ExceptionHandlerFactory\" properties=\"handler=true\"/>\n                    <cacheExtensionFactory class=\"example.ExtensionFactory\" properties=\"extension=true\"/>\n                    <cacheDecoratorFactory class=\"example.DecoratorFactory\" properties=\"decorator=true\"/>\n                    <cacheWriter writeMode=\"write_behind\" notifyListenersOnException=\"true\"\n                        minWriteDelay=\"1\" maxWriteDelay=\"2\" writeBatching=\"true\" writeBatchSize=\"3\"\n                        retryAttempts=\"4\" retryAttemptDelaySeconds=\"5\" rateLimitPerSecond=\"6\"\n                        writeCoalescing=\"true\" writeBehindConcurrency=\"1\" writeBehindMaxQueueSize=\"10\">\n                      <cacheWriterFactory class=\"example.WriterFactory\" properties=\"writer=true\"/>\n                    </cacheWriter>\n                    <searchable keys=\"true\" values=\"false\">\n                      <searchAttribute name=\"color\" expression=\"value.color\"/>\n                    </searchable>\n                    <terracotta clustered=\"false\" consistency=\"eventual\"/>\n                  </defaultCache>\n                  <cache name=\"sample\" maxElementsInMemory=\"11\" eternal=\"false\" timeToIdleSeconds=\"3\"\n                      timeToLiveSeconds=\"4\" overflowToDisk=\"true\" diskPersistent=\"false\"\n                      memoryStoreEvictionPolicy=\"LFU\" clearOnFlush=\"true\"/>\n                </ehcache>\n                \"\"\");\n\n        assertThat(configuration.getName()).isEqualTo(\"bean-handler-test\");\n        assertThat(configuration.getUpdateCheck()).isFalse();\n        assertThat(configuration.getDynamicConfig()).isFalse();\n        assertThat(configuration.getDefaultTransactionTimeoutInSeconds()).isEqualTo(21);\n        assertThat(configuration.getDiskStoreConfiguration().getOriginalPath())\n                .isEqualTo(\"java.io.tmpdir/ehcache-bean-handler\");\n\n        TerracottaClientConfiguration terracottaClientConfiguration = configuration.getTerracottaConfiguration();\n        assertThat(terracottaClientConfiguration).isNotNull();\n        assertThat(terracottaClientConfiguration.isRejoin()).isTrue();\n        assertThat(terracottaClientConfiguration.getOriginalEmbeddedConfig()).contains(\"server-one\");\n\n        FactoryConfiguration peerProviderConfiguration = configuration.getCacheManagerPeerProviderFactoryConfiguration()\n                .get(0);\n        assertThat(peerProviderConfiguration.getFullyQualifiedClassPath())\n                .isEqualTo(\"net.sf.ehcache.distribution.RMICacheManagerPeerProviderFactory\");\n        assertThat(peerProviderConfiguration.getProperties()).isEqualTo(\"peerDiscovery=manual\");\n\n        CacheConfiguration defaultCacheConfiguration = configuration.getDefaultCacheConfiguration();\n        assertThat(defaultCacheConfiguration.getMaxElementsInMemory()).isEqualTo(5);\n        assertThat(defaultCacheConfiguration.getTimeToIdleSeconds()).isEqualTo(1);\n        assertThat(defaultCacheConfiguration.getTimeToLiveSeconds()).isEqualTo(2);\n        assertThat(defaultCacheConfiguration.getCacheEventListenerConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getCacheLoaderConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getBootstrapCacheLoaderFactoryConfiguration()).isNotNull();\n        assertThat(defaultCacheConfiguration.getCacheExceptionHandlerFactoryConfiguration()).isNotNull();\n        assertThat(defaultCacheConfiguration.getCacheExtensionConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getCacheDecoratorConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getCacheWriterConfiguration()\n                .getCacheWriterFactoryConfiguration()).isNotNull();\n        assertThat(defaultCacheConfiguration.getTerracottaConfiguration()).isNotNull();\n\n        Searchable searchable = defaultCacheConfiguration.getSearchable();\n        assertThat(searchable.keys()).isTrue();\n        assertThat(searchable.values()).isFalse();\n        SearchAttribute colorAttribute = searchable.getUserDefinedSearchAttributes().get(\"color\");\n        assertThat(colorAttribute.getExpression()).isEqualTo(\"value.color\");\n\n        CacheConfiguration sampleCacheConfiguration = configuration.getCacheConfigurations().get(\"sample\");\n        assertThat(sampleCacheConfiguration).isNotNull();\n        assertThat(sampleCacheConfiguration.getMaxElementsInMemory()).isEqualTo(11);\n        assertThat(sampleCacheConfiguration.isOverflowToDisk()).isTrue();\n        assertThat(sampleCacheConfiguration.isDiskPersistent()).isFalse();\n    }\n\n    @Test\n    void handlesCreateMethodsAndParentConstructedChildren() throws Exception {\n        BeanHandlerRootBean rootBean = new BeanHandlerRootBean();\n\n        parseWithBeanHandler(rootBean, \"\"\"\n                <root title=\"configured-root\">\n                  <createdChild value=\"created-by-factory\"/>\n                  <parentConstructedChild number=\"42\"/>\n                </root>\n                \"\"\");\n\n        assertThat(rootBean.title).isEqualTo(\"configured-root\");\n        assertThat(rootBean.createdChild).isNotNull();\n        assertThat(rootBean.createdChild.value).isEqualTo(\"created-by-factory\");\n        assertThat(rootBean.parentConstructedChild).isNotNull();\n        assertThat(rootBean.parentConstructedChild.parent).isSameAs(rootBean);\n        assertThat(rootBean.parentConstructedChild.number).isEqualTo(42);\n    }\n\n    private static Configuration parseConfiguration(String xml) {\n        ByteArrayInputStream inputStream = new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8));\n        return ConfigurationFactory.parseConfiguration(inputStream);\n    }\n\n    private static void parseWithBeanHandler(Object bean, String xml) throws Exception {\n        SAXParser parser = SAXParserFactory.newInstance().newSAXParser();\n        ByteArrayInputStream inputStream = new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8));\n        parser.parse(inputStream, newBeanHandler(bean));\n    }\n\n    private static DefaultHandler newBeanHandler(Object bean) throws Exception {\n        Class<?> handlerClass = Class.forName(\"net.sf.ehcache.config.BeanHandler\");\n        Constructor<?> constructor = handlerClass.getDeclaredConstructor(Object.class);\n        constructor.setAccessible(true);\n        return (DefaultHandler) constructor.newInstance(bean);\n    }\n\n    public static class BeanHandlerRootBean {\n        String title;\n        BeanHandlerCreatedChild createdChild;\n        BeanHandlerParentConstructedChild parentConstructedChild;\n\n        public void setTitle(String title) {\n            this.title = title;\n        }\n\n        public BeanHandlerCreatedChild createCreatedChild() {\n            createdChild = new BeanHandlerCreatedChild();\n            return createdChild;\n        }\n\n        public void addParentConstructedChild(BeanHandlerParentConstructedChild child) {\n            parentConstructedChild = child;\n        }\n    }\n\n    public static class BeanHandlerCreatedChild {\n        String value;\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n    }\n\n    public static class BeanHandlerParentConstructedChild {\n        final BeanHandlerRootBean parent;\n        int number;\n\n        public BeanHandlerParentConstructedChild(BeanHandlerRootBean parent) {\n            this.parent = parent;\n        }\n\n        public void setNumber(int number) {\n            this.number = number;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
