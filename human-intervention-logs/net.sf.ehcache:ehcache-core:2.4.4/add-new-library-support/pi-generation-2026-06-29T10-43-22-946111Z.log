      map.put(\"bravo\", \"two\");\n\n        byte[] serialized = serialize(map);\n        ConcurrentHashMap<String, String> deserialized = deserialize(serialized);\n\n        assertThat(deserialized).containsExactlyInAnyOrderEntriesOf(Map.of(\n                \"alpha\", \"one\",\n                \"bravo\", \"two\"));\n        assertThat(deserialized.putIfAbsent(\"charlie\", \"three\")).isNull();\n        assertThat(deserialized.get(\"charlie\")).isEqualTo(\"three\");\n    }\n\n    private static byte[] serialize(ConcurrentHashMap<String, String> map) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(map);\n        }\n        return bytes.toByteArray();\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static ConcurrentHashMap<String, String> deserialize(byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        ByteArrayInputStream bytes = new ByteArrayInputStream(serialized);\n        try (ObjectInputStream inputStream = new ObjectInputStream(bytes)) {\n            return (ConcurrentHashMap<String, String>) inputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782729698949}]}
