edConfig()).contains(\"server-one\");\n\n        FactoryConfiguration peerProviderConfiguration = configuration.getCacheManagerPeerProviderFactoryConfiguration()\n                .get(0);\n        assertThat(peerProviderConfiguration.getFullyQualifiedClassPath())\n                .isEqualTo(\"net.sf.ehcache.distribution.RMICacheManagerPeerProviderFactory\");\n        assertThat(peerProviderConfiguration.getProperties()).isEqualTo(\"peerDiscovery=manual\");\n\n        CacheConfiguration defaultCacheConfiguration = configuration.getDefaultCacheConfiguration();\n        assertThat(defaultCacheConfiguration.getMaxElementsInMemory()).isEqualTo(5);\n        assertThat(defaultCacheConfiguration.getTimeToIdleSeconds()).isEqualTo(1);\n        assertThat(defaultCacheConfiguration.getTimeToLiveSeconds()).isEqualTo(2);\n        assertThat(defaultCacheConfiguration.getCacheEventListenerConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getCacheLoaderConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getBootstrapCacheLoaderFactoryConfiguration()).isNotNull();\n        assertThat(defaultCacheConfiguration.getCacheExceptionHandlerFactoryConfiguration()).isNotNull();\n        assertThat(defaultCacheConfiguration.getCacheExtensionConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getCacheDecoratorConfigurations()).hasSize(1);\n        assertThat(defaultCacheConfiguration.getCacheWriterConfiguration()\n                .getCacheWriterFactoryConfiguration()).isNotNull();\n        assertThat(defaultCacheConfiguration.getTerracottaConfiguration()).isNotNull();\n\n        Searchable searchable = defaultCacheConfiguration.getSearchable();\n        assertThat(searchable.keys()).isTrue();\n        assertThat(searchable.values()).isFalse();\n        SearchAttribute colorAttribute = searchable.getUserDefinedSearchAttributes().get(\"color\");\n        assertThat(colorAttribute.getExpression()).isEqualTo(\"value.color\");\n\n        CacheConfiguration sampleCacheConfiguration = configuration.getCacheConfigurations().get(\"sample\");\n        assertThat(sampleCacheConfiguration).isNotNull();\n        assertThat(sampleCacheConfiguration.getMaxElementsInMemory()).isEqualTo(11);\n        assertThat(sampleCacheConfiguration.isOverflowToDisk()).isTrue();\n        assertThat(sampleCacheConfiguration.isDiskPersistent()).isFalse();\n    }\n\n    @Test\n    void handlesCreateMethodsAndParentConstructedChildren() throws Exception {\n        BeanHandlerRootBean rootBean = new BeanHandlerRootBean();\n\n        parseWithBeanHandler(rootBean, \"\"\"\n                <root title=\"configured-root\">\n                  <createdChild value=\"created-by-factory\"/>\n                  <parentConstructedChild number=\"42\"/>\n                </root>\n                \"\"\");\n\n        assertThat(rootBean.title).isEqualTo(\"configured-root\");\n        assertThat(rootBean.createdChild).isNotNull();\n        assertThat(rootBean.createdChild.value).isEqualTo(\"created-by-factory\");\n        assertThat(rootBean.parentConstructedChild).isNotNull();\n        assertThat(rootBean.parentConstructedChild.parent).isSameAs(rootBean);\n        assertThat(rootBean.parentConstructedChild.number).isEqualTo(42);\n    }\n\n    private static Configuration parseConfiguration(String xml) {\n        ByteArrayInputStream inputStream = new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8));\n        return ConfigurationFactory.parseConfiguration(inputStream);\n    }\n\n    private static void parseWithBeanHandler(Object bean, String xml) throws Exception {\n        SAXParser parser = SAXParserFactory.newInstance().newSAXParser();\n        ByteArrayInputStream inputStream = new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8));\n        parser.parse(inputStream, newBeanHandler(bean));\n    }\n\n    private static DefaultHandler newBeanHandler(Object bean) throws Exception {\n        Class<?> handlerClass = Class.forName(\"net.sf.ehcache.config.BeanHandler\");\n        Constructor<?> constructor = handlerClass.getDeclaredConstructor(Object.class);\n        constructor.setAccessible(true);\n        return (DefaultHandler) constructor.newInstance(bean);\n    }\n\n    public static class BeanHandlerRootBean {\n        String title;\n        BeanHandlerCreatedChild createdChild;\n        BeanHandlerParentConstructedChild parentConstructedChild;\n\n        public void setTitle(String title) {\n            this.title = title;\n        }\n\n        public BeanHandlerCreatedChild createCreatedChild() {\n            createdChild = new BeanHandlerCreatedChild();\n            return createdChild;\n        }\n\n        public void addParentConstructedChild(BeanHandlerParentConstructedChild child) {\n            parentConstructedChild = child;\n        }\n    }\n\n    public static class BeanHandlerCreatedChild {\n        String value;\n\n        public void setValue(String value) {\n            this.value = value;\n        }\n    }\n\n    public static class BeanHandlerParentConstructedChild {\n        final BeanHandlerRootBean parent;\n        int number;\n\n        public BeanHandlerParentConstructedChild(BeanHandlerRootBean parent) {\n            this.parent = parent;\n        }\n\n        public void setNumber(int number) {\n            this.number = number;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782729599265}]}
