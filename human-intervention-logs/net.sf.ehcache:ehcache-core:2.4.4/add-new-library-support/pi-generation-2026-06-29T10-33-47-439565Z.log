  package net_sf_ehcache.ehcache_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.lang.reflect.Constructor;
  import java.nio.charset.StandardCharsets;
  
  import javax.xml.parsers.SAXParser;
  import javax.xml.parsers.SAXParserFactory;
  
  import net.sf.ehcache.config.CacheConfiguration;
  import net.sf.ehcache.config.Configuration;
  import net.sf.ehcache.config.ConfigurationFactory;
  import net.sf.ehcache.config.FactoryConfiguration;
  import net.sf.ehcache.config.SearchAttribute;
  import net.sf.ehcache.config.Searchable;
  import net.sf.ehcache.config.TerracottaClientConfiguration;
  
  import org.junit.jupiter.api.Test;
  import org.xml.sax.helpers.DefaultHandler;
  
  public class BeanHandlerTest {
      @Test
      void parsesConfigurationElementsAttributesAndExtractedTerracottaSubtree() {
          Configuration configuration = parseConfiguration("""
                  <ehcache name="bean-handler-test" updateCheck="false" dynamicConfig="false"
                           monitoring="off" defaultTransactionTimeoutInSeconds="21">
                    <diskStore path="java.io.tmpdir/ehcache-bean-handler"/>
                    <terracottaConfig rejoin="true">
                      <tc-config>
                        <servers>
                          <server host="localhost" name="server-one">
                            <dso-port>9510</dso-port>
                          </server>
                        </servers>
                      </tc-config>
                    </terracottaConfig>
                    <cacheManagerPeerProviderFactory
                        class="net.sf.ehcache.distribution.RMICacheManagerPeerProviderFactory"
                        properties="peerDiscovery=manual" propertySeparator=","/>
                    <defaultCache maxElementsInMemory="5" eternal="false" timeToIdleSeconds="1"
                        timeToLiveSeconds="2" overflowToDisk="false" memoryStoreEvictionPolicy="LRU">
                      <cacheEventListenerFactory class="example.ListenerFactory" properties="listen=true"/>
                      <cacheLoaderFactory class="example.LoaderFactory" properties="loader=true"/>
                      <bootstrapCacheLoaderFactory class="example.BootstrapFactory" properties="bootstrap=true"/>
                      <cacheExceptionHandlerFactory class="example.ExceptionHandlerFactory" properties="handler=true"/>
                      <cacheExtensionFactory class="example.ExtensionFactory" properties="extension=true"/>
                      <cacheDecoratorFactory class="example.DecoratorFactory" properties="decorator=true"/>
                      <cacheWriter writeMode="write_behind" notifyListenersOnException="true"
                          minWriteDelay="1" maxWriteDelay="2" writeBatching="true" writeBatchSize="3"
                          retryAttempts="4" retryAttemptDelaySeconds="5" rateLimitPerSecond="6"
                          writeCoalescing="true" writeBehindConcurrency="1" writeBehindMaxQueueSize="10">
                        <cacheWriterFactory class="example.WriterFactory" properties="writer=true"/>
                      </cacheWriter>
                      <searchable keys="true" values="false">
                        <searchAttribute name="color" expression="value.color"/>
                      </searchable>
                      <terracotta clustered="false" consistency="eventual"/>
                    </defaultCache>
                    <cache name="sample" maxElementsInMemory="11" eternal="false" timeToIdleSeconds="3"
                        timeToLiveSeconds="4" overflowToDisk="true" diskPersistent="false"
                        memoryStoreEvictionPolicy="LFU" clearOnFlush="true"/>
                  </ehcache>
                  """);
  
          assertThat(configuration.getName()).isEqualTo("bean-handler-test");
          assertThat(configuration.getUpdateCheck()).isFalse();
          assertThat(configuration.getDynamicConfig()).isFalse();
          assertThat(configuration.getDefaultTransactionTimeoutInSeconds()).isEqualTo(21);
          assertThat(configuration.getDiskStoreConfiguration().getOriginalPath())
                  .isEqualTo("java.io.tmpdir/ehcache-bean-handler");
  
          TerracottaClientConfiguration terracottaClientConfiguration = configuration.getTerracottaConfiguration();
          assertThat(terracottaClientConfiguration).isNotNull();
          assertThat(terracottaClientConfiguration.isRejoin()).isTrue();
          assertThat(terracottaClientConfiguration.getOriginalEmbeddedConfig()).contains("server-one");
  
          FactoryConfiguration peerProviderConfiguration = configuration.getCacheManagerPeerProviderFactoryConfiguration()
                  .get(0);
          assertThat(peerProviderConfiguration.getFullyQualifiedClassPath())
                  .isEqualTo("net.sf.ehcache.distribution.RMICacheManagerPeerProviderFactory");
          assertThat(peerProviderConfiguration.getProperties()).isEqualTo("peerDiscovery=manual");
  
          CacheConfiguration defaultCacheConfiguration = configuration.getDefaultCacheConfiguration();
          assertThat(defaultCacheConfiguration.getMaxElementsInMemory()).isEqualTo(5);
          assertThat(defaultCacheConfiguration.getTimeToIdleSeconds()).isEqualTo(1);
          assertThat(defaultCacheConfiguration.getTimeToLiveSeconds()).isEqualTo(2);
          assertThat(defaultCacheConfiguration.getCacheEventListenerConfigurations()).hasSize(1);
          assertThat(defaultCacheConfiguration.getCacheLoaderConfigurations()).hasSize(1);
          assertThat(defaultCacheConfiguration.getBootstrapCacheLoaderFactoryConfiguration()).isNotNull();
          assertThat(defaultCacheConfiguration.getCacheExceptionHandlerFactoryConfiguration()).isNotNull();
          assertThat(defaultCacheConfiguration.getCacheExtensionConfigurations()).hasSize(1);
          assertThat(defaultCacheConfiguration.getCacheDecoratorConfigurations()).hasSize(1);
          assertThat(defaultCacheConfiguration.getCacheWriterConfiguration()
                  .getCacheWriterFactoryConfiguration()).isNotNull();
          assertThat(defaultCacheConfiguration.getTerracottaConfiguration()).isNotNull();
  
          Searchable searchable = defaultCacheConfiguration.getSearchable();
          assertThat(searchable.keys()).isTrue();
          assertThat(searchable.values()).isFalse();
          SearchAttribute colorAttribute = searchable.getUserDefinedSearchAttributes().get("color");
          assertThat(colorAttribute.getExpression()).isEqualTo("value.color");
  
          CacheConfiguration sampleCacheConfiguration = configuration.getCacheConfigurations().get("sample");
          assertThat(sampleCacheConfiguration).isNotNull();
          assertThat(sampleCacheConfiguration.getMaxElementsInMemory()).isEqualTo(11);
          assertThat(sampleCacheConfiguration.isOverflowToDisk()).isTrue();
          assertThat(sampleCacheConfiguration.isDiskPersistent()).isFalse();
      }
  
      @Test
      void handlesCreateMethodsAndParentConstructedChildren() throws Exception {
          BeanHandlerRootBean rootBean = new BeanHandlerRootBean();
  
          parseWithBeanHandler(rootBean, """
                  <root title="configured-root">
                    <createdChild value="created-by-factory"/>
                    <parentConstructedChild number="42"/>
                  </root>
                  """);
  
          assertThat(rootBean.title).isEqualTo("configured-root");
          assertThat(rootBean.createdChild).isNotNull();
          assertThat(rootBean.createdChild.value).isEqualTo("created-by-factory");
          assertThat(rootBean.parentConstructedChild).isNotNull();
          assertThat(rootBean.parentConstructedChild.parent).isSameAs(rootBean);
          assertThat(rootBean.parentConstructedChild.number).isEqualTo(42);
      }
  
      private static Configuration parseConfiguration(String xml) {
          ByteArrayInputStream inputStream = new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8));
          return ConfigurationFactory.parseConfiguration(inputStream);
      }
  
      private static void parseWithBeanHandler(Object bean, String xml) throws Exception {
          SAXParser parser = SAXParserFactory.newInstance().newSAXParser();
          ByteArrayInputStream inputStream = new ByteArrayInputStream(xml.getBytes(StandardCharsets.UTF_8));
          parser.parse(inputStream, newBeanHandler(bean));
      }
  
      private static DefaultHandler newBeanHandler(Object bean) throws Exception {
          Class<?> handlerClass = Class.forName("net.sf.ehcache.config.BeanHandler");
          Constructor<?> constructor = handlerClass.getDeclaredConstructor(Object.class);
          constructor.setAccessible(true);
          return (DefaultHandler) constructor.newInstance(bean);
      }
  
      public static class BeanHandlerRootBean {
          String title;
          BeanHandlerCreatedChild createdChild;
          BeanHandlerParentConstructedChild parentConstructedChild;
  
          public void setTitle(String title) {
              this.title = title;
          }
  
          public BeanHandlerCreatedChild createCreatedChild() {
              createdChild = new BeanHandlerCreatedChild();
              return createdChild;
          }
  
          public void addParentConstructedChild(BeanHandlerParentConstructedChild child) {
              parentConstructedChild = child;
          }
      }
  
      public static class BeanHandlerCreatedChild {
          String value;
  
          public void setValue(String value) {
              this.value = value;
          }
      }
  
      public static class BeanHandlerParentConstructedChild {
          final BeanHandlerRootBean parent;
          int number;
  
          public BeanHandlerParentConstructedChild(BeanHandlerRootBean parent) {
              this.parent = parent;
          }
  
          public void setNumber(int number) {
              this.number = number;
          }
      }
  }
