ntProfile(String tier) {\n            this.tier = tier;\n        }\n    }\n\n    private static final class PremiumAccountProfile extends BaseAccountProfile {\n        PremiumAccountProfile(String tier) {\n            super(tier);\n        }\n    }\n}\n"}
