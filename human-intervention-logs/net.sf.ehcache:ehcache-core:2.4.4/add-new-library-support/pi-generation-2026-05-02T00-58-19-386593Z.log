                                       rateLimitPerSecond="3"
                                       writeCoalescing="true"
                                       writeBatching="true"
                                       writeBatchSize="4"
                                       retryAttempts="2"
                                       retryAttemptDelaySeconds="1"
                                       writeBehindMaxQueueSize="8">
                              <cacheWriterFactory class="java.lang.String" properties="writer=true"/>
                          </cacheWriter>
                      </cache>
