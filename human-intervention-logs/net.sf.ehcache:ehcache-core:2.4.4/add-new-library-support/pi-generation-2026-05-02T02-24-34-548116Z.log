[tool-call] delta {"path":"tests/src/net.sf.ehcache/ehcache-core/2.4.4/src/test/java/net_sf_ehcache/ehcache_core/AbstractEhcacheProviderTest.java","edits":[{"oldText":"import java.util.Properties;\n\nimport net.sf.ehcache.hibernate.EhCacheProvider;","newText":"import java.net.URL;\nimport java.util.Properties;\n\nimport net.sf.ehcache.hibernate.EhCacheProvider;"},{"oldText":"        Properties properties = new Properties();\n        properties.setProperty(EhCacheProvider.NET_SF_EHCACHE_CONFIGURATION_RESOURCE_NAME, CONFIGURATION_RESOURCE);\n        EhCacheProvider provider = new EhCacheProvider();\n\n        try {\n            provider.start(properties);\n\n            Cache cache = provider.buildCache(CACHE_NAME, properties);\n            cache.put(\"key\", \"value\");\n\n            assertThat(cache.get(\"key\")).isEqualTo(\"value\");\n            assertThat(provider.isMinimalPutsEnabledByDefault()).isTrue();\n            assertThat(provider.nextTimestamp()).isPositive();\n        } finally {\n            provider.stop();\n        }\n    }\n}","newText":"        Properties properties = new Properties();\n        properties.setProperty(EhCacheProvider.NET_SF_EHCACHE_CONFIGURATION_RESOURCE_NAME, CONFIGURATION_RESOURCE);\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        MissingResourceClassLoader resourceClassLoader = new MissingResourceClassLoader(originalContextClassLoader);\n        EhCacheProvider provider = new EhCacheProvider();\n\n        Thread.currentThread().setContextClassLoader(resourceClassLoader);\n        try {\n            provider.start(properties);\n\n            Cache cache = provider.buildCache(CACHE_NAME, properties);\n            cache.put(\"key\", \"value\");\n\n            assertThat(resourceClassLoader.wasConfigurationRequested()).isTrue();\n            assertThat(cache.get(\"key\")).isEqualTo(\"value\");\n            assertThat(provider.isMinimalPutsEnabledByDefault()).isTrue();\n            assertThat(provider.nextTimestamp()).isPositive();\n        } finally {\n            provider.stop();\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static final class MissingResourceClassLoader extends ClassLoader {\n        private boolean configurationRequested;\n\n        private MissingResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (CONFIGURATION_RESOURCE.equals(name)) {\n                configurationRequested = true;\n                return null;\n            }\n            return super.getResource(name);\n        }\n\n        private boolean wasConfigurationRequested() {\n            return configurationRequested;\n        }\n    }\n}"}]}
[tool-call] end id=call_vV8hJVobclQB048IPem0Ezrn|fc_01707524ed412ed30169f5604f7d5c81a1bf2c4ed0edcd362a name=edit args={"path": "tests/src/net.sf.ehcache/ehcache-core/2.4.4/src/test/java/net_sf_ehcache/ehcache_core/AbstractEhcacheProviderTest.java", "edits": [{"oldText": "import java.util.Properties;\n\nimport net.sf.ehcache.hibernate.EhCacheProvider;", "newText": "import java.net.URL;\nimport java.util.Properties;\n\nimport net.sf.ehcache.hibernate.EhCacheProvider;"}, {"oldText": "        Properties properties = new Properties();\n        properties.setProperty(EhCacheProvider.NET_SF_EHCACHE_CONFIGURATION_RESOURCE_NAME, CONFIGURATION_RESOURCE);\n        EhCacheProvider provider = new EhCacheProvider();\n\n        try {\n            provider.start(properties);\n\n            Cache cache = provider.buildCache(CACHE_NAME, properties);\n            cache.put(\"key\", \"value\");\n\n            assertThat(cache.get(\"key\")).isEqualTo(\"value\");\n            assertThat(provider.isMinimalPutsEnabledByDefault()).isTrue();\n            assertThat(provider.nextTimestamp()).isPositive();\n        } finally {\n            provider.stop();\n        }\n    }\n}", "newText": "        Properties properties = new Properties();\n        properties.setProperty(EhCacheProvider.NET_SF_EHCACHE_CONFIGURATION_RESOURCE_NAME, CONFIGURATION_RESOURCE);\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        MissingResourceClassLoader resourceClassLoader = new MissingResourceClassLoader(originalContextClassLoader);\n        EhCacheProvider provider = new EhCacheProvider();\n\n        Thread.currentThread().setContextClassLoader(resourceClassLoader);\n        try {\n            provider.start(properties);\n\n            Cache cache = provider.buildCache(CACHE_NAME, properties);\n            cache.put(\"key\", \"value\");\n\n            assertThat(resourceClassLoader.wasConfigurationRequested()).isTrue();\n            assertThat(cache.get(\"key\")).isEqualTo(\"value\");\n            assertThat(provider.isMinimalPutsEnabledByDefault()).isTrue();\n            assertThat(provider.nextTimestamp()).isPositive();\n        } finally {\n            provider.stop();\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static final class MissingResourceClassLoader extends ClassLoader {\n        private boolean configurationRequested;\n\n        private MissingResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (CONFIGURATION_RESOURCE.equals(name)) {\n                configurationRequested = true;\n                return null;\n            }\n            return super.getResource(name);\n        }\n\n        private boolean wasConfigurationRequested() {\n            return configurationRequested;\n        }\n    }\n}"}]}
