write", "arguments": {"path": "tests/src/net.sf.ehcache/ehcache-core/2.4.4/src/test/java/net_sf_ehcache/ehcache_core/DiskStoreAnonymous1Test.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sf_ehcache.ehcache_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.file.Path;\n\nimport net.sf.ehcache.Cache;\nimport net.sf.ehcache.Element;\nimport net.sf.ehcache.config.CacheConfiguration;\nimport net.sf.ehcache.store.DiskStore;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class DiskStoreAnonymous1Test {\n    @TempDir\n    Path diskStoreDirectory;\n\n    @Test\n    void fallsBackToObjectInputStreamResolutionWhenContextClassLoaderCannotLoadElement() {\n        String cacheName = \"disk-store-context-loader-fallback\";\n        DiskStore diskStore = DiskStore.create(newPersistentCache(cacheName), diskStoreDirectory.toString());\n        try {\n            diskStore.put(new Element(\"disk-key\", \"disk-value\"));\n        } finally {\n            diskStore.dispose();\n        }\n\n        DiskStore reloadedDiskStore = DiskStore.create(newPersistentCache(cacheName), diskStoreDirectory.toString());\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n            Element element = reloadedDiskStore.get(\"disk-key\");\n\n            assertThat(element).isNotNull();\n            assertThat(element.getObjectValue()).isEqualTo(\"disk-value\");\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n            reloadedDiskStore.dispose();\n        }\n    }\n\n    private Cache newPersistentCache(String cacheName) {\n        CacheConfiguration configuration = new CacheConfiguration(cacheName, 1)\n                .overflowToDisk(true)\n                .diskPersistent(true)\n                .diskStorePath(diskStoreDirectory.toString())\n                .eternal(true)\n                .diskExpiryThreadIntervalSeconds(120);\n        return new Cache(configuration);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3293, "output": 1640, "cacheRead": 11264, "cacheWrite": 0, "totalTokens": 16197, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777689634396, "responseId": "resp_06dc7c8c03a0ece00169f56422c8a481a1aa133b5497aad3f9"}}
