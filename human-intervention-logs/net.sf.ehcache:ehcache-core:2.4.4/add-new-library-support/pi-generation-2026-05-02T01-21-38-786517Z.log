  package net.sf.ehcache;
  
  
  import net.sf.ehcache.config.CacheConfiguration;
  import net.sf.ehcache.util.TimeUtil;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
