     408	    @Test
     409	    void modelObjectsExposeEndpointMetadataAndNameBasedEquality() {
     410	        EndpointPath path = new EndpointPath(
     411	                "directory",
     412	                "java.lang.String",
     413	                "true",
     414	                "/tmp",
     415	                "Input directory.",
     416	                true,
     417	                "common",
     418	                "file",
     419	                true,
     420	                linkedSet("inbox", "outbox"));
     421	        EndpointOption option = new EndpointOption(
     422	                "delay",
     423	                "long",
     424	                "false",
     425	                "1000",
     426	                " milliseconds",
     427	                "Delay between polls",
     428	                "consumer.",
     429	                "scheduler.",
     430	                true,
     431	                false,
     432	                "consumer",
     433	                "consumer",
     434	                false,
     435	                Collections.emptySet());
     436	        ComponentOption componentOption = new ComponentOption(
     437	                "bridgeErrorHandler",
     438	                "boolean",
     439	                "false",
     440	                "false",
     441	                " routes exceptions to Camel error handler",
     442	                "Bridge consumer errors",
     443	                false,
     444	                "consumer",
     445	                "consumer",
     446	                false,
     447	                Collections.emptySet());
     448	
     449	        assertThat(path.getName()).isEqualTo("directory");
     450	        assertThat(path.getType()).isEqualTo("java.lang.String");
     451	        assertThat(path.getRequired()).isEqualTo("true");
     452	        assertThat(path.getDefaultValue()).isEqualTo("/tmp");
     453	        assertThat(path.isDeprecated()).isTrue();
     454	        assertThat(path.getGroup()).isEqualTo("common");
     455	        assertThat(path.getLabel()).isEqualTo("file");
     456	        assertThat(path.isEnumType()).isTrue();
     457	        assertThat(path.getEnumValuesAsHtml()).isEqualTo("inbox<br/>outbox");
     458	        assertThat(path).isEqualTo(new EndpointPath(
     459	                "directory", "int", "false", "", "", false, "advanced", "advanced", false, Collections.emptySet()));
     460	        assertThat(path).hasSameHashCodeAs(new EndpointPath(
     461	                "directory", "int", "false", "", "", false, "advanced", "advanced", false, Collections.emptySet()));
     462	
     463	        assertThat(option.getOptionalPrefix()).isEqualTo("consumer.");
     464	        assertThat(option.getPrefix()).isEqualTo("scheduler.");
     465	        assertThat(option.isMultiValue()).isTrue();
     466	        assertThat(option.getDocumentationWithNotes())
     467	                .isEqualTo("Delay between polls. Default value notice:  milliseconds");
     468	        assertThat(option).isEqualTo(new EndpointOption(
     469	                "delay", "int", "false", "", "", "", "", "", false, false, "common", "common", false,
     470	                Collections.emptySet()));
     471	
     472	        assertThat(componentOption.getName()).isEqualTo("bridgeErrorHandler");
     473	        assertThat(componentOption.getDocumentationWithNotes())
     474	                .isEqualTo("Bridge consumer errors. Default value notice:  routes exceptions to Camel error handler");
     475	        assertThat(componentOption).isEqualTo(new ComponentOption(
     476	                "bridgeErrorHandler", "boolean", "false", "", "", "", false, "common", "common", false,
     477	                Collections.emptySet()));
     478	    }
