    override def equals(that: Any): Boolean = that match {
      case that: URL =>
        val left  = self.normalize
        val right = that.normalize
  
        left.kind == right.kind &&
        left.path == right.path &&
        left.queryParams == right.queryParams &&
        left.fragment == right.fragment
  
      case _ => false
