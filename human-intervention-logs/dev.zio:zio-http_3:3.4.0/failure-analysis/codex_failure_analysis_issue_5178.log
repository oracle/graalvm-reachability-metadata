That(textBody.knownContentLength).isEqualTo(Some(14L))\n    48\t    assertThat(unsafeRun(textBody.asString(StandardCharsets.UTF_8))).isEqualTo(\"hello zio-http\")\n    49\t\n    50\t    val streamedBody: Body = Body.fromStreamChunked(\n    51\t      ZStream.fromChunk(Chunk.fromArray(\"streamed\".getBytes(StandardCharsets.UTF_8))),\n    52\t    )\n    53\t    val collectedStream: Body = unsafeRun(streamedBody.materialize)\n    54\t    assertThat(unsafeRun(collectedStream.asString(StandardCharsets.UTF_8))).isEqualTo(\"streamed\")\n    55\t    assertThat(collectedStream.isComplete).isTrue()\n    56\t\n    57\t    val form: Form = Form.fromStrings(\"name\" -> \"zio\", \"kind\" -> \"http\")\n    58\t    val encodedFormBody: Body = Body.fromURLEncodedForm(form)\n    59\t    val decodedForm: Form = unsafeRun(encodedFormBody.asURLEncodedForm)\n    60\t    assertThat(decodedForm.get(\"name\").contains(FormField.Simple(\"name\", \"zio\"))).isTrue()\n    61\t    assertThat(decodedForm.toQueryParams.getAll(\"kind\")).isEqualTo(Chunk(\"http\"))\n    62\t  }\n    63\t\n    64\t  @Test\n    65\t  def multipartFormsEncodeAndDecodeTextAndBinaryParts(): Unit = {\n    66\t    val binaryData: Chunk[Byte] = Chunk.fromArray(\"file-content\".getBytes(StandardCharsets.UTF_8))\n    67\t    val form: Form = Form(\n    68\t      Chunk[FormField](\n    69\t        FormField.simpleField(\"description\", \"native friendly\"),\n    70\t        FormField.binaryField(\"attachment\", binaryData, MediaType.text.plain, None, Some(\"note.txt\")),\n    71\t      ),\n    72\t    )\n    73\t    val boundary: Boundary = Boundary(\"zio-http-test-boundary\")\n    74\t    val multipartBody: Body = Body.fromMultipartForm(form, boundary)\n    75\t\n    76\t    assertThat(multipartBody.mediaType).isEqualTo(Some(MediaType.multipart.`form-data`))\n    77\t    assertThat(multipartBody.contentType.flatMap(_.boundary).map(_.id)).isEqualTo(Some(\"zio-http-test-boundary\"))\n    78\t\n    79\t    val decodedForm: Form = unsafeRun(multipartBody.asMultipartForm)\n    80\t    assertThat(decodedForm.formData.size).isEqualTo(2)\n    81\t    assertThat(unsafeRun(decodedForm.get(\"description\").get.asText)).isEqualTo(\"native friendly\")\n    82\t\n    83\t    val attachment: FormField = decodedForm.get(\"attachment\").get\n    84\t    assertThat(attachment.filename).isEqualTo(Some(\"note.txt\"))\n    85\t    assertThat(attachment.contentType).isEqualTo(MediaType.text.plain)\n    86\t    assertThat(unsafeRun(attachment.asChunk)).isEqualTo(binaryData)\n    87\t  }\n    88\t\n    89\t  @Test\n    90\t  def urlsPathsAndQueryParamsRoundTripAndResolve(): Unit = {\n    91\t    val queryParams: QueryParams = QueryParams(\"tag\" -> Chunk(\"zio http\", \"native\"), \"empty\" -> Chunk.empty)\n    92\t    assertThat(queryParams.normalize.map.contains(\"empty\")).isFalse()\n    93\t    assertThat(QueryParams.decode(queryParams.encode).getAll(\"tag\")).isEqualTo(Chunk(\"zio http\", \"native\"))\n    94\t\n    95\t    val path: Path = (Path.root / \"api\" / \"v1\" / \"items\" / \"\").dropTrailingSlash\n    96\t    assertThat(path.encode).isEqualTo(\"/api/v1/items\")\n    97\t    assertThat((Path(\"/api\") ++ Path(\"v1/./items/../items\")).removeDotSegments.encode).isEqualTo(\"/api/v1/items\")\n    98\t    assertThat(Path(\"/api/v1/items\").unnest(Path(\"/api\")).encode).isEqualTo(\"v1/items\")\n    99\t\n   100\t    val decodedUrl: URL = URL.decode(\"https://example.com:8443/api/v1/items?tag=zio%20http&tag=native#details\").toOption.get\n   101\t    assertThat(decodedUrl.isAbsolute).isTrue()\n   102\t    assertThat(decodedUrl.scheme.map(_.encode)).isEqualTo(Some(\"https\"))\n   103\t    assertThat(decodedUrl.hostPort).isEqualTo(Some(\"example.com:8443\"))\n   104\t    assertThat(decodedUrl.queryParams.getAll(\"tag\")).isEqualTo(Chunk(\"zio http\", \"native\"))\n   105\t    assertThat(decodedUrl.fragment.map(_.decoded)).isEqualTo(Some(\"details\"))\n   106\t\n   107\t    val baseUrl: URL = URL.decode(\"https://example.com/docs/reference/index.html?lang=en\").toOption.get\n   108\t    val resolvedUrl: URL = baseUrl.resolve(URL.decode(\"../guide/start.html?lang=scala\").toOption.get).toOption.get\n   109\t    assertThat(resolvedUrl.encode).isEqualTo(\"https://example.com/docs/guide/start.html?lang=scala\")\n   110\t  }\n   111\t\n   112\t  @Test\n   113\t  def requestsHeadersCookiesAndResponsesCompose(): Unit = {\n   114\t    val request: Request = Request\n   115\t      .post(\"/submit\", Body.fromString(\"payload\"))\n   116\t      .addCookie(Cookie.Request(\"session\", \"abc\"))\n   117\t      .addCookies(Cookie.Request(\"theme\", \"dark\"))\n   118\t      .addHeader(Header.Accept(MediaType.application.json))\n   119\t      .addQueryParam(\"debug\", \"true\")\n   120\t\n   121\t    assertThat(request.method).isEqualTo(Method.POST)\n   122\t    assertThat(request.cookie(\"session\").map(_.content)).isEqualTo(Some(\"abc\"))\n   123\t    assertThat(request.cookies.map(_.name)).isEqualTo(Chunk(\"session\", \"theme\"))\n   124\t    assertThat(request.header(Header.Accept).map(_.mimeTypes.head.mediaType)).isEqualTo(Some(MediaType.application.json))\n   125\t    assertThat(request.queryParam(\"debug\")).isEqualTo(Some(\"true\"))\n   126\t    assertThat(unsafeRun(request.body.asString)).isEqualTo(\"payload\")\n   127\t\n   128\t    val responseCookie: Cookie.Response = Cookie\n   129\t      .Request(\"session\", \"abc\")\n   130\t      .toResponse(path = Some(Path.root), isHttpOnly = true, sameSite = Some(Cookie.SameSite.Strict))\n   131\t    val response: Response = Response\n   132\t      .json(\"{\\\"ok\\\":true}\")\n   133\t      .addCookie(responseCookie)\n   134\t      .patch(Response.Patch.status(Status.Created) ++ Response.Patch.addHeader(\"x-test\", \"yes\"))\n   135\t\n   136\t    assertThat(response.status).isEqualTo(Status.Created)\n   137\t    assertThat(response.header(Header.ContentType).map(_.mediaType)).isEqualTo(Some(MediaType.application.json))\n   138\t    assertThat(response.rawHeader(\"x-test\")).isEqualTo(Some(\"yes\"))\n   139\t    val setCookies: Chunk[Header.SetCookie] = response.headers(Header.SetCookie)\n   140\t    assertThat(setCookies.size).isEqualTo(1)\n   141\t    assertThat(setCookies.head.value.isHttpOnly).isTrue()\n   142\t    assertThat(setCookies.head.value.sameSite).isEqualTo(Some(Cookie.SameSite.Strict))\n   143\t    assertThat(unsafeRun(response.body.asString)).isEqualTo(\"{\\\"ok\\\":true}\")\n   144\t\n   145\t    val updatedHeaders: Headers = response.headers.removeHeader(\"x-test\").addHeader(\"x-replacement\", \"present\")\n   146\t    assertThat(updatedHeaders.contains(\"x-test\")).isFalse()\n   147\t    assertThat(updatedHeaders.get(\"x-replacement\")).isEqualTo(Some(\"present\"))\n   148\t  }\n   149\t\n   150\t  @Test\n   151\t  def routesDispatchPathParametersBodiesAndErrors(): Unit = {\n   152\t    val routes: Routes[Any, Nothing] = Routes(\n   153\t      Method.GET / \"users\" / int(\"id\") -> handler { (id: Int, request: Request) =>\n   154\t        val tab: String = request.queryParamOrElse(\"tab\", \"summary\")\n   155\t        Response.text(s\"user=$id tab=$tab\")\n   156\t      },\n   157\t      Method.POST / \"echo\" -> handler { (request: Request) =>\n   158\t        request.body.asString.map(body => Response.text(body.reverse))\n   159\t      },\n   160\t      Method.GET / \"boom\" -> handler { (_: Request) =>\n   161\t        ZIO.fail(new IllegalArgumentException(\"bad input\"))\n   162\t      },\n   163\t    ).handleError { error =>\n   164\t      Response.badRequest(error.getMessage)\n   165\t    }\n   166\t\n   167\t    assertThat(routes.isDefinedAt(Request.get(\"/users/42\"))).isTrue()\n   168\t    assertThat(routes.isDefinedAt(Request.get(\"/missing\"))).isFalse()\n   169\t\n   170\t    val userResponse: Response = unsafeRun(\n","exit_code":0,"status":"completed"}}
