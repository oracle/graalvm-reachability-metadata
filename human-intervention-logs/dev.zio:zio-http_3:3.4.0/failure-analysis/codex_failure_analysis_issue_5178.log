.getAll(\"tag\")).isEqualTo(Chunk(\"zio http\", \"native\"))\n   105\t    assertThat(decodedUrl.fragment.map(_.decoded)).isEqualTo(Some(\"details\"))\n   106\t\n   107\t    val baseUrl: URL = URL.decode(\"https://example.com/docs/reference/index.html?lang=en\").toOption.get\n   108\t    val resolvedUrl: URL = baseUrl.resolve(URL.decode(\"../guide/start.html?lang=scala\").toOption.get).toOption.get\n   109\t    assertThat(resolvedUrl.encode).isEqualTo(\"https://example.com/docs/guide/start.html?lang=scala\")\n   110\t  }\n   111\t\n   112\t  @Test\n   113\t  def requestsHeadersCookiesAndResponsesCompose(): Unit = {\n   114\t    val request: Request = Request\n   115\t      .post(\"/submit\", Body.fromString(\"payload\"))\n   116\t      .addCookie(Cookie.Request(\"session\", \"abc\"))\n   117\t      .addCookies(Cookie.Request(\"theme\", \"dark\"))\n   118\t      .addHeader(Header.Accept(MediaType.application.json))\n   119\t      .addQueryParam(\"debug\", \"true\")\n   120\t\n   121\t    assertThat(request.method).isEqualTo(Method.POST)\n   122\t    assertThat(request.cookie(\"session\").map(_.content)).isEqualTo(Some(\"abc\"))\n   123\t    assertThat(request.cookies.map(_.name)).isEqualTo(Chunk(\"session\", \"theme\"))\n   124\t    assertThat(request.header(Header.Accept).map(_.mimeTypes.head.mediaType)).isEqualTo(Some(MediaType.application.json))\n   125\t    assertThat(request.queryParam(\"debug\")).isEqualTo(Some(\"true\"))\n","exit_code":0,"status":"completed"}}
