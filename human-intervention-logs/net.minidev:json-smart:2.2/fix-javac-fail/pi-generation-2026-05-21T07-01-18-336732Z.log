                  .map(ParsedDynamicAccessCallSite::sourceFile)
                  .filter(value -> value != null && !value.isBlank())
                  .findFirst()
                  .orElse(null);
  
          return new LibraryStatsModels.DynamicAccessClassCoverage(
                  className,
                  sourceFile,
                  callSites.size(),
                  coveredCalls,
  
