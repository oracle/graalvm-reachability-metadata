     167				} catch (Exception e) {
     168				}
     169			}
     170	
     171			if (this.field == null && getter == null && setter == null)
     172				return;
     173	
     174			if (getter != null && !filter.canUse(field, getter))
     175				getter = null;
     176	
     177			if (setter != null && !filter.canUse(field, setter))
     178				setter = null;
     179	
