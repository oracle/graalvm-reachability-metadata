ClassName);\n   101\t\t\t} catch (ClassNotFoundException ignored) {\n   102\t\t\t}\n   103\t\n   104\t\t\tLinkedList<Class<?>> parentClasses = getParents(type);\n   105\t\n   106\t\t\t// if the class do not exists build it\n   107\t\t\tif (accessClass == null) {\n   108\t\t\t\tBeansAccessBuilder builder = new BeansAccessBuilder(type, accs, loader);\n   109\t\t\t\tfor (Class<?> c : parentClasses)\n   110\t\t\t\t\tbuilder.addConversion(BeansAccessConfig.classMapper.get(c));\n   111\t\t\t\taccessClass = builder.bulid();\n   112\t\t\t}\n   113\t\t\ttry {\n   114\t\t\t\t@SuppressWarnings(\"unchecked\")\n   115\t\t\t\tBeansAccess<P> access = (BeansAccess<P>) accessClass.newInstance();\n   116\t\t\t\taccess.setAccessor(accs);\n   117\t\t\t\tcache.putIfAbsent(type, access);\n   118\t\t\t\t// add fieldname alias\n   119\t\t\t\tfor (Class<?> c : parentClasses)\n   120\t\t\t\t\taddAlias(access, BeansAccessConfig.classFiledNameMapper.get(c));\n   121\t\t\t\treturn access;\n   122\t\t\t} catch (Exception ex) {\n   123\t\t\t\tthrow new RuntimeException(\"Error constructing accessor class: \" + accessClassName, ex);\n   124\t\t\t}\n   125\t\t}\n   126\t\n   127\t\tprivate static LinkedList<Class<?>> getParents(Class<?> type) {\n   128\t\t\tLinkedList<Class<?>> m = new LinkedList<Class<?>>();\n   129\t\t\twhile (type != null && !type.equals(Object.class)) {\n   130\t\t\t\tm.addLast(type);\n   131\t\t\t\tfor (Class<?> c : type.getInterfaces())\n   132\t\t\t\t\tm.addLast(c);\n   133\t\t\t\ttype = type.getSuperclass();\n   134\t\t\t}\n   135\t\t\tm.addLast(Object.class);\n   136\t\t\treturn m;\n   137\t\t}\n   138\t\n   139\t\t/**\n   140\t\t * \n   141\t\t */\n   142\t\tprivate static void addAlias(BeansAccess<?> access, HashMap<String, String> m) {\n   143\t\t\t// HashMap<String, String> m =\n   144\t\t\t// BeansAccessConfig.classFiledNameMapper.get(type);\n   145\t\t\tif (m == null)\n   146\t\t\t\treturn;\n   147\t\t\tHashMap<String, Accessor> changes = new HashMap<String, Accessor>();\n   148\t\t\tfor (Entry<String, String> e : m.entrySet()) {\n   149\t\t\t\tAccessor a1 = access.map.get(e.getValue());\n   150\t\t\t\tif (a1 != null)\n   151\t\t\t\t\tchanges.put(e.getValue(), a1);\n   152\t\t\t}\n   153\t\t\taccess.map.putAll(changes);\n   154\t\t}\n   155\t\n   156\t\t/**\n   157\t\t * set field value by field index\n   158\t\t */\n   159\t\tabstract public void set(T object, int methodIndex, Object value);\n   160\t\n   161\t\t/**\n   162\t\t * get field value by field index\n   163\t\t */\n   164\t\tabstract public Object get(T object, int methodIndex);\n   165\t\n   166\t\t/**\n   167\t\t * create a new targeted object\n   168\t\t */\n   169\t\tabstract public T newInstance();\n   170\t\n   171\t\t/**\n   172\t\t * set field value by fieldname\n   173\t\t */\n   174\t\tpublic void set(T object, String methodName, Object value) {\n   175\t\t\tint i = getIndex(methodName);\n   176\t\t\tif (i == -1)\n   177\t\t\t\tthrow new net.minidev.asm.ex.NoSuchFieldException(methodName + \" in \" + object.getClass() + \" to put value : \" + value);\n   178\t\t\tset(object, i, value);\n   179\t\t}\n   180\t\n   181\t\t/**\n   182\t\t * get field value by fieldname\n   183\t\t */\n   184\t\tpublic Object get(T object, String methodName) {\n   185\t\t\treturn get(object, getIndex(methodName));\n   186\t\t}\n   187\t\n   188\t\t/**\n   189\t\t * Returns the index of the field accessor.\n   190\t\t */\n   191\t\tpublic int getIndex(String name) {\n   192\t\t\tAccessor ac = map.get(name);\n   193\t\t\tif (ac == null)\n   194\t\t\t\treturn -1;\n   195\t\t\treturn ac.index;\n   196\t\t}\n   197\t}\n     1\tpackage net.minidev.asm;\n     2\t\n     3\t/*\n     4\t *    Copyright 2011 JSON-SMART authors\n     5\t *\n     6\t * Licensed under the Apache License, Version 2.0 (the \"License\");\n     7\t * you may not use this file except in compliance with the License.\n     8\t * You may obtain a copy of the License at\n     9\t *\n    10\t * http://www.apache.org/licenses/LICENSE-2.0\n    11\t *\n    12\t * Unless required by applicable law or agreed to in writing, software\n    13\t * distributed under the License is distributed on an \"AS IS\" BASIS,\n    14\t * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    15\t * See the License for the specific language governing permissions and\n    16\t * limitations under the License.\n    17\t */\n    18\timport static org.objectweb.asm.Opcodes.CHECKCAST;\n    19\timport static org.objectweb.asm.Opcodes.INVOKESTATIC;\n    20\timport static org.objectweb.asm.Opcodes.INVOKEVIRTUAL;\n    21\t\n    22\timport java.lang.reflect.Field;\n    23\timport java.util.HashMap;\n    24\t\n    25\timport org.objectweb.asm.Label;\n    26\timport org.objectweb.asm.MethodVisitor;\n    27\timport org.objectweb.asm.Type;\n    28\t\n    29\t/**\n    30\t * ASM Utils used to simplify class generation\n    31\t * \n    32\t * @author uriel Chemouni\n    33\t */\n    34\tpublic class ASMUtil {\n    35\t\t/**\n    36\t\t * Append the call of proper autoboxing method for the given primitif type.\n    37\t\t */\n    38\t\tpublic static void autoBoxing(MethodVisitor mv, Class<?> clz) {\n    39\t\t\tautoBoxing(mv, Type.getType(clz));\n    40\t\t}\n    41\t\n    42\t\t/**\n    43\t\t * Extract all Accessor for the field of the given class.\n    44\t\t * \n    45\t\t * @param type\n    46\t\t * @return all Accessor available\n    47\t\t */\n    48\t\tstatic public Accessor[] getAccessors(Class<?> type, FieldFilter filter) {\n    49\t\t\tClass<?> nextClass = type;\n    50\t\t\tHashMap<String, Accessor> map = new HashMap<String, Accessor>();\n    51\t\t\tif (filter == null)\n    52\t\t\t\tfilter = BasicFiledFilter.SINGLETON;\n    53\t\t\twhile (nextClass != Object.class) {\n    54\t\t\t\tField[] declaredFields = nextClass.getDeclaredFields();\n    55\t\n    56\t\t\t\tfor (Field field : declaredFields) {\n    57\t\t\t\t\tString fn = field.getName();\n    58\t\t\t\t\tif (map.containsKey(fn))\n    59\t\t\t\t\t\tcontinue;\n    60\t\t\t\t\tAccessor acc = new Accessor(nextClass, field, filter);\n    61\t\t\t\t\tif (!acc.isUsable())\n    62\t\t\t\t\t\tcontinue;\n    63\t\t\t\t\tmap.put(fn, acc);\n    64\t\t\t\t}\n    65\t\t\t\tnextClass = nextClass.getSuperclass();\n    66\t\t\t}\n    67\t\t\treturn map.values().toArray(new Accessor[map.size()]);\n    68\t\t}\n    69\t\n    70\t\t/**\n    71\t\t * Append the call of proper autoboxing method for the given primitif type.\n    72\t\t */\n    73\t\tprotected static void autoBoxing(MethodVisitor mv, Type fieldType) {\n    74\t\t\tswitch (fieldType.getSort()) {\n    75\t\t\tcase Type.BOOLEAN:\n    76\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Boolean\", \"valueOf\", \"(Z)Ljava/lang/Boolean;\");\n    77\t\t\t\tbreak;\n    78\t\t\tcase Type.BYTE:\n    79\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Byte\", \"valueOf\", \"(B)Ljava/lang/Byte;\");\n    80\t\t\t\tbreak;\n    81\t\t\tcase Type.CHAR:\n    82\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Character\", \"valueOf\", \"(C)Ljava/lang/Character;\");\n    83\t\t\t\tbreak;\n    84\t\t\tcase Type.SHORT:\n    85\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Short\", \"valueOf\", \"(S)Ljava/lang/Short;\");\n    86\t\t\t\tbreak;\n    87\t\t\tcase Type.INT:\n    88\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Integer\", \"valueOf\", \"(I)Ljava/lang/Integer;\");\n    89\t\t\t\tbreak;\n    90\t\t\tcase Type.FLOAT:\n    91\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Float\", \"valueOf\", \"(F)Ljava/lang/Float;\");\n    92\t\t\t\tbreak;\n    93\t\t\tcase Type.LONG:\n    94\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Long\", \"valueOf\", \"(J)Ljava/lang/Long;\");\n    95\t\t\t\tbreak;\n    96\t\t\tcase Type.DOUBLE:\n    97\t\t\t\tmv.visitMethodInsn(INVOKESTATIC, \"java/lang/Double\", \"valueOf\", \"(D)Ljava/lang/Double;\");\n    98\t\t\t\tbreak;\n    99\t\t\t}\n   100\t\t}\n   101\t\n   102\t\t/**\n   103\t\t * Append the call of proper extract primitive type of an boxed object.\n   104\t\t */\n   105\t\tprotected static void autoUnBoxing1(MethodVisitor mv, Type fieldType) {\n   106\t\t\tswitch (fieldType.getSort()) {\n   107\t\t\tcase Type.BOOLEAN:\n   108\t\t\t\tmv.visitTypeInsn(CHECKCAST, \"java/lang/Boolean\");\n   109\t\t\t\tmv.visitMethodInsn(INVOKEVIRTUAL, \"java/lang/Boolean\", \"booleanValue\", \"()Z\");\n   110\t\t\t\tbreak;\n   111\t\t\tcase Type.BYTE:\n   112\t\t\t\tmv.visitTypeInsn(CHECKCAST, \"java/lang/Byte\");\n   113\t\t\t\tmv.visitMethodInsn(INVOKEVIRTUAL, \"java/lang/Byte\", \"byteValue\", \"()B\");\n   114\t\t\t\tbreak;\n   115\t\t\tcase Type.CHAR:\n   116\t\t\t\tmv.visitTypeInsn(CHECKCAST, \"java/lang/Character\");\n   117\t\t\t\tmv.visitMethodInsn(INVOKEVIRTUAL, \"java/lang/Character\", \"charValue\", \"()C\");\n   118\t\t\t\tbreak;\n   119\t\t\tcase Type.SHORT:\n   120\t\t\t\tmv.visitTypeInsn(CHECKCAST, \"java/lang/Short\");\n"}], "isError": false, "timestamp": 1779346174992}}
