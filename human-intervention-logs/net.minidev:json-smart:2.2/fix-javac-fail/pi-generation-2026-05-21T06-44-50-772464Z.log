          assertThat(navi.getCurrentObject())
                  .isInstanceOf(AccessibleJsonObject.class)
                  .isEqualTo(expectedMap());
      }
  
      private static AccessibleJsonObject expectedMap() {
          AccessibleJsonObject expected = new AccessibleJsonObject();
          expected.put("one", 1);
          expected.put("two", 2);
          return expected;
      }
  
