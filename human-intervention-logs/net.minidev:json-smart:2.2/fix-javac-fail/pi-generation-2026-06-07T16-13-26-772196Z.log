r (Accessor acc : accs) {\n    38\t\t\t\tacc.index = i++;\n    39\t\t\t\tmap.put(acc.getName(), acc);\n    40\t\t\t}\n    41\t\t}\n    42\t\n    43\t\tpublic HashMap<String, Accessor> getMap() {\n    44\t\t\treturn map;\n    45\t\t}\n    46\t\n    47\t\tpublic Accessor[] getAccessors() {\n    48\t\t\treturn accs;\n    49\t\t}\n    50\t\n    51\t\t/**\n    52\t\t * cache used to store built BeansAccess\n    53\t\t */\n    54\t\tprivate static ConcurrentHashMap<Class<?>, BeansAccess<?>> cache = new ConcurrentHashMap<Class<?>, BeansAccess<?>>();\n    55\t\n    56\t\t// private final static ConcurrentHashMap<Type, AMapper<?>> cache;\n    57\t\n    58\t\t/**\n    59\t\t * return the BeansAccess corresponding to a type\n    60\t\t * \n    61\t\t * @param type\n    62\t\t *            to be access\n    63\t\t * @return the BeansAccess\n    64\t\t */\n    65\t\tstatic public <P> BeansAccess<P> get(Class<P> type) {\n    66\t\t\treturn get(type, null);\n    67\t\t}\n    68\t\n    69\t\t/**\n    70\t\t * return the BeansAccess corresponding to a type\n    71\t\t * \n    72\t\t * @param type\n    73\t\t *            to be access\n    74\t\t * @return the BeansAccess\n    75\t\t */\n    76\t\tstatic public <P> BeansAccess<P> get(Class<P> type, FieldFilter filter) {\n    77\t\t\t{\n    78\t\t\t\t@SuppressWarnings(\"unchecked\")\n    79\t\t\t\tBeansAccess<P> access = (BeansAccess<P>) cache.get(type);\n    80\t\t\t\tif (access != null)\n    81\t\t\t\t\treturn access;\n    82\t\t\t}\n    83\t\t\t// extract all access methodes\n    84\t\t\tAccessor[] accs = ASMUtil.getAccessors(type, filter);\n    85\t\n    86\t\n    87\t\t\t// create new class name\n    88\t\t\tString className = type.getName();\n    89\t\t\tString accessClassName;\n    90\t\t\tif (className.startsWith(\"java.util.\"))\n    91\t\t\t\taccessClassName = \"net.minidev.asm.\" + className + \"AccAccess\";\n    92\t\t\telse\n    93\t\t\t\taccessClassName = className.concat(\"AccAccess\");\t\t\n    94\t\t\t\n    95\t\t\t//