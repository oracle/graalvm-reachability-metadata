     112		 */
     113		public boolean isUsable() {
     114			return field != null || getter != null || setter != null;
     115		}
     116	
     117		/**
     118		 * @return true if the field can be read
     119		 */
     120		public boolean isReadable() {
     121			return field != null || getter != null;
     122		}
