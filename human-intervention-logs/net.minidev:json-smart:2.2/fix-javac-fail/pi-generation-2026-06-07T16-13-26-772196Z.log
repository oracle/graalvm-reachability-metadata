      45		 */
      46		protected Method getter;
      47		/**
      48		 * Filed index in object
      49		 */
      50		protected int index;
      51		/**
      52		 * Filed Class
      53		 */
      54		protected Class<?> type;
      55		/**
      56		 * Filed Type using JDK 5+ generics if available
      57		 */
      58		protected Type genericType;
      59	
      60		protected String fieldName;
      61	
      62		/**
      63		 * getter for index
      64		 * @return Index
      65		 */
      66		public int getIndex() {
      67			return index;
      68		}
      69	
      70		/**
      71		 * is the field access using Field access type
      72		 * @return if Accessor is public
      73		 */
      74		public boolean isPublic() {
      75			return setter == null;
      76		}
      77	
      78		/**
      79		 * is the field is an enum field
      80		 * @return if Accessor return an Enum Class
      81		 */
      82		public boolean isEnum() {
      83			return type.isEnum();
      84		}
      85	
      86		/**
      87		 * return the field name
      88	 	 * @return the field name
      89		 */
      90		public String getName() {
      91			return fieldName;
      92		}
      93	
      94		/**
      95		 * return field Class
      96		 * @return field Class
      97		 */
      98		public Class<?> getType() {
      99			return type;
     100		}
     101	
