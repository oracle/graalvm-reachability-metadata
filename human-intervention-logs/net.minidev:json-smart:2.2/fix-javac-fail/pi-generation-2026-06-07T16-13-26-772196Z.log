      18	import java.lang.reflect.Method;
      19	
      20	/**
      21	 * Simple extension from ClassLoader overiding the loadClass(String name,
      22	 * boolean resolve) method and allowing to register new classes
      23	 * 
      24	 * @author uriel
      25	 * 
      26	 */
      27	class DynamicClassLoader extends ClassLoader {
      28		DynamicClassLoader(ClassLoader parent) {
      29			super(parent);
      30		}
      31	
      32		private final static String BEAN_AC = BeansAccess.class.getName();
      33		/**
      34		 * Predefined define defineClass method signature (name, bytes, offset,
      35		 * length)
      36		 */
      37		private final static Class<?>[] DEF_CLASS_SIG = new Class[] { String.class, byte[].class, int.class, int.class };
      38	
      39		/**
      40		 * 
      41		 * @param parent used to choose the ClassLoader
      42		 * @param clsName C
      43		 * @param clsData
      44		 * @return
      45		 */
      46		public static <T> Class<T> directLoad(Class<? extends T> parent, String clsName, byte[] clsData) {
      47			DynamicClassLoader loader = new DynamicClassLoader(parent.getClassLoader());
      48			@SuppressWarnings("unchecked")
      49			Class<T> clzz = (Class<T>) loader.defineClass(clsName, clsData);
      50			return clzz;
      51		}
      52	
      53		public static <T> T directInstance(Class<? extends T> parent, String clsName, byte[] clsData) throws InstantiationException, IllegalAccessException {
      54			Class<T> clzz = directLoad(parent, clsName, clsData);
      55			return clzz.newInstance();
      56		}
      57	
      58		@Override
      59		protected synchronized java.lang.Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
      60			/*
      61			 * check class by fullname as String.
      62			 */
      63			if (name.equals(BEAN_AC))
      64				return BeansAccess.class;
      65			/*
      66			 * Use default class loader
      67			 */
      68			return super.loadClass(name, resolve);
      69		}
      70	
      71		/**
      72		 * Call defineClass into the parent classLoader using the
      73		 * method.setAccessible(boolean) hack
      74		 * 
      75		 * @see ClassLoader#defineClass(String, byte[], int, int)
      76		 */
      77		Class<?> defineClass(String name, byte[] bytes) throws ClassFormatError {
      78			try {
      79				// Attempt to load the access class in the same loader, which makes
      80				// protected and default access members accessible.
      81				Method method = ClassLoader.class.getDeclaredMethod("defineClass", DEF_CLASS_SIG);
      82				method.setAccessible(true);
      83				return (Class<?>) method.invoke(getParent(), new Object[] { name, bytes, Integer.valueOf(0), Integer.valueOf(bytes.length) });
      84			} catch (Exception ignored) {
      85			}
      86			return defineClass(name, bytes, 0, bytes.length);
      87		}
      88	}
