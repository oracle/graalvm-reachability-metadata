     137		 *            the field to access
     138		 */
     139		public Accessor(Class<?> c, Field field, FieldFilter filter) {
     140			this.fieldName = field.getName();
     141			int m = field.getModifiers();
     142	
     143			if ((m & (Modifier.STATIC | Modifier.TRANSIENT)) > 0)
     144				return;
     145	
     146			if ((m & Modifier.PUBLIC) > 0)
     147				this.field = field;
     148	
     149			String name = ASMUtil.getSetterName(field.getName());
     150			try {
     151				setter = c.getDeclaredMethod(name, field.getType());
     152			} catch (Exception e) {
     153			}
     154			boolean isBool = field.getType().equals(Boolean.TYPE);
     155			if (isBool) {
     156				name = ASMUtil.getIsName(field.getName());
     157			} else {
     158				name = ASMUtil.getGetterName(field.getName());
     159			}
     160			try {
     161				getter = c.getDeclaredMethod(name);
     162			} catch (Exception e) {
     163			}
     164			if (getter == null && isBool) {
     165				try {
     166					getter = c.getDeclaredMethod(ASMUtil.getGetterName(field.getName()));
     167				} catch (Exception e) {
     168				}
     169			}
     170	
     171			if (this.field == null && getter == null && setter == null)
     172				return;
     173	
     174			if (getter != null && !filter.canUse(field, getter))
     175				getter = null;
     176	
     177			if (setter != null && !filter.canUse(field, setter))
     178				setter = null;
     179	
     180			// disable
     181			if (getter == null && setter == null && this.field == null)
     182				return;
     183	
     184			this.type = field.getType();
     185			this.genericType = field.getGenericType();
     186		}
     187	}
