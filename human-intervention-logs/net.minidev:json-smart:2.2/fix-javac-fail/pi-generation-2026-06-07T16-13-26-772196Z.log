      20	import java.util.Map.Entry;
      21	import java.util.concurrent.ConcurrentHashMap;
      22	
      23	/**
      24	 * Allow access reflect field using runtime generated accessor. BeansAccessor is
      25	 * faster than java.lang.reflect.Method.invoke()
      26	 * 
      27	 * @author uriel Chemouni
      28	 */
      29	public abstract class BeansAccess<T> {
      30		private HashMap<String, Accessor> map;
      31		private Accessor[] accs;
      32	
      33		protected void setAccessor(Accessor[] accs) {
      34			int i = 0;
      35			this.accs = accs;
      36			map = new HashMap<String, Accessor>();
      37			for (Accessor acc : accs) {
      38				acc.index = i++;
      39				map.put(acc.getName(), acc);
      40			}
      41		}
      42	
      43		public HashMap<String, Accessor> getMap() {
      44			return map;
      45		}
      46	
      47		public Accessor[] getAccessors() {
      48			return accs;
      49		}
      50	
      51		/**
      52		 * cache used to store built BeansAccess
      53		 */
      54		private static ConcurrentHashMap<Class<?>, BeansAccess<?>> cache = new ConcurrentHashMap<Class<?>, BeansAccess<?>>();
      55	
      56		// private final static ConcurrentHashMap<Type, AMapper<?>> cache;
      57	
      58		/**
      59		 * return the BeansAccess corresponding to a type
      60		 * 
      61		 * @param type
      62		 *            to be access
      63		 * @return the BeansAccess
      64		 */
      65		static public <P> BeansAccess<P> get(Class<P> type) {
      66			return get(type, null);
      67		}
      68	
      69		/**
      70		 * return the BeansAccess corresponding to a type
      71		 * 
      72		 * @param type
      73		 *            to be access
      74		 * @return the BeansAccess
      75		 */
      76		static public <P> BeansAccess<P> get(Class<P> type, FieldFilter filter) {
      77			{
      78				@SuppressWarnings("unchecked")
      79				BeansAccess<P> access = (BeansAccess<P>) cache.get(type);
      80				if (access != null)
      81					return access;
      82			}
      83			// extract all access methodes
      84			Accessor[] accs = ASMUtil.getAccessors(type, filter);
      85	
      86	
      87			// create new class name
      88			String className = type.getName();
      89			String accessClassName;
      90			if (className.startsWith("java.util."))
      91				accessClassName = "net.minidev.asm." + className + "AccAccess";
      92			else
      93				accessClassName = className.concat("AccAccess");		
      94			
      95			// extend class base loader
      96			DynamicClassLoader loader = new DynamicClassLoader(type.getClassLoader());
      97			// try to load existing class
      98			Class<?> accessClass = null;
      99			try {
     100				accessClass = loader.loadClass(accessClassName);
     101			} catch (ClassNotFoundException ignored) {
     102			}
     103	
     104			LinkedList<Class<?>> parentClasses = getParents(type);
     105	
     106			// if the class do not exists build it
     107			if (accessClass == null) {
     108				BeansAccessBuilder builder = new BeansAccessBuilder(type, accs, loader);
     109				for (Class<?> c : parentClasses)
     110					builder.addConversion(BeansAccessConfig.classMapper.get(c));
     111				accessClass = builder.bulid();
     112			}
     113			try {
     114				@SuppressWarnings("unchecked")
     115				BeansAccess<P> access = (BeansAccess<P>) accessClass.newInstance();
     116				access.setAccessor(accs);
     117				cache.putIfAbsent(type, access);
     118				// add fieldname alias
     119				for (Class<?> c : parentClasses)
     120					addAlias(access, BeansAccessConfig.classFiledNameMapper.get(c));
     121				return access;
     122			} catch (Exception ex) {
     123				throw new RuntimeException("Error constructing accessor class: " + accessClassName, ex);
     124			}
     125		}
     126	
     127		private static LinkedList<Class<?>> getParents(Class<?> type) {
     128			LinkedList<Class<?>> m = new LinkedList<Class<?>>();
     129			while (type != null && !type.equals(Object.class)) {
     130				m.addLast(type);
     131				for (Class<?> c : type.getInterfaces())
     132					m.addLast(c);
     133				type = type.getSuperclass();
     134			}
     135			m.addLast(Object.class);
     136			return m;
     137		}
     138	
     139		/**
     140		 * 
     141		 */
     142		private static void addAlias(BeansAccess<?> access, HashMap<String, String> m) {
     143			// HashMap<String, String> m =
     144			// BeansAccessConfig.classFiledNameMapper.get(type);
     145			if (m == null)
     146				return;
     147			HashMap<String, Accessor> changes = new HashMap<String, Accessor>();
     148			for (Entry<String, String> e : m.entrySet()) {
     149				Accessor a1 = access.map.get(e.getValue());
     150				if (a1 != null)
     151					changes.put(e.getValue(), a1);
     152			}
     153			access.map.putAll(changes);
     154		}
     155	
     156		/**
     157		 * set field value by field index
     158		 */
     159		abstract public void set(T object, int methodIndex, Object value);
     160	
     161		/**
     162		 * get field value by field index
     163		 */
     164		abstract public Object get(T object, int methodIndex);
     165	
     166		/**
     167		 * create a new targeted object
     168		 */
     169		abstract public T newInstance();
     170	
     171		/**
     172		 * set field value by fieldname
     173		 */
     174		public void set(T object, String methodName, Object value) {
     175			int i = getIndex(methodName);
     176			if (i == -1)
     177				throw new net.minidev.asm.ex.NoSuchFieldException(methodName + " in " + object.getClass() + " to put value : " + value);
     178			set(object, i, value);
     179		}
     180	
     181		/**
     182		 * get field value by fieldname
     183		 */
     184		public Object get(T object, String methodName) {
     185			return get(object, getIndex(methodName));
     186		}
     187	
     188		/**
     189		 * Returns the index of the field accessor.
     190		 */
     191		public int getIndex(String name) {
     192			Accessor ac = map.get(name);
     193			if (ac == null)
     194				return -1;
     195			return ac.index;
     196		}
     197	}
      35		/**
      36		 * Append the call of proper autoboxing method for the given primitif type.
      37		 */
      38		public static void autoBoxing(MethodVisitor mv, Class<?> clz) {
      39			autoBoxing(mv, Type.getType(clz));
      40		}
      41	
      42		/**
      43		 * Extract all Accessor for the field of the given class.
      44		 * 
      45		 * @param type
      46		 * @return all Accessor available
      47		 */
      48		static public Accessor[] getAccessors(Class<?> type, FieldFilter filter) {
      49			Class<?> nextClass = type;
      50			HashMap<String, Accessor> map = new HashMap<String, Accessor>();
      51			if (filter == null)
      52				filter = BasicFiledFilter.SINGLETON;
      53			while (nextClass != Object.class) {
      54				Field[] declaredFields = nextClass.getDeclaredFields();
      55	
      56				for (Field field : declaredFields) {
      57					String fn = field.getName();
      58					if (map.containsKey(fn))
      59						continue;
      60					Accessor acc = new Accessor(nextClass, field, filter);
      61					if (!acc.isUsable())
      62						continue;
      63					map.put(fn, acc);
      64				}
      65				nextClass = nextClass.getSuperclass();
      66			}
      67			return map.values().toArray(new Accessor[map.size()]);
      68		}
      69	
      70		/**
      71		 * Append the call of proper autoboxing method for the given primitif type.
      72		 */
      73		protected static void autoBoxing(MethodVisitor mv, Type fieldType) {
      74			switch (fieldType.getSort()) {
      75			case Type.BOOLEAN:
      76				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Boolean", "valueOf", "(Z)Ljava/lang/Boolean;");
      77				break;
      78			case Type.BYTE:
      79				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Byte", "valueOf", "(B)Ljava/lang/Byte;");
      80				break;
      81			case Type.CHAR:
      82				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Character", "valueOf", "(C)Ljava/lang/Character;");
      83				break;
      84			case Type.SHORT:
      85				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Short", "valueOf", "(S)Ljava/lang/Short;");
      86				break;
      87			case Type.INT:
      88				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Integer", "valueOf", "(I)Ljava/lang/Integer;");
      89				break;
      90			case Type.FLOAT:
      91				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Float", "valueOf", "(F)Ljava/lang/Float;");
      92				break;
      93			case Type.LONG:
      94				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Long", "valueOf", "(J)Ljava/lang/Long;");
      95				break;
      96			case Type.DOUBLE:
      97				mv.visitMethodInsn(INVOKESTATIC, "java/lang/Double", "valueOf", "(D)Ljava/lang/Double;");
      98				break;
      99			}
     100		}
