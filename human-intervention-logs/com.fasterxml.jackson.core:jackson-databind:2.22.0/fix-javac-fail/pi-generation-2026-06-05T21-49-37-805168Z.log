, I don’t think the ObjectMapper structure matters much here. I need to ensure the child loader can delegate everything except for one blocked type; otherwise, I could run into a `NoClassDefFoundError`. The context loader will load ObjectMapper successfully, allowing me to access its class bytes from the library resource without needing to define a test class.\"}]}"}, {"type": "toolCall", "id": "call_3V82ljuf1ljKarOPPC7TD8kp|fc_083c416a393ae45c016a2343f38fe481969f60d89f4fe0e9de", "name": "write", "arguments": {"path": "tests/src/com.fasterxml.jackson.core/jackson-databind/2.22.0/src/test/java/com_fasterxml_jackson_core/jackson_databind/JacksonClassUtilTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_fasterxml_jackson_core.jackson_databind;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.lang.annotation.ElementType;\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\nimport java.lang.annotation.Target;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Arrays;\n\nimport com.fasterxml.jackson.databind.util.ClassUtil;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JacksonClassUtilTest {\n\n    private static final String METHOD_CARRIER_CLASS_NAME = MethodCarrier.class.getName();\n    private static final String METHOD_DEPENDENCY_CLASS_NAME = MethodDependency.class.getName();\n\n    @Test\n    void findsAnnotatedEnumValueByInspectingDeclaredFields() {\n        Enum<?> value = ClassUtil.findFirstAnnotatedEnumValue(enumClass(AnnotatedChoice.class), Preferred.class);\n\n        assertThat(value).isSameAs(AnnotatedChoice.PRIMARY);\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void exposesDeclaredFieldsThroughClassUtil() {\n        Field[] fields = ClassUtil.getDeclaredFields(FieldCarrier.class);\n\n        assertThat(Arrays.stream(fields).map(Field::getName))\n                .contains(\"name\", \"count\");\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void exposesDeclaredMethodsThroughClassUtil() {\n        Method[] methods = ClassUtil.getDeclaredMethods(MethodCarrier.class);\n\n        assertThat(Arrays.stream(methods).map(Method::getName))\n                .contains(\"greeting\", \"dependency\");\n    }\n\n    @Test\n    void fallsBackToContextClassLoaderWhenDeclaredMethodsNeedMissingType() throws Exception {\n        ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(JacksonClassUtilTest.class.getClassLoader());\n        try {\n            try {\n                Class<?> isolatedClass = new MissingDependencyClassLoader().loadClass(METHOD_CARRIER_CLASS_NAME);\n\n                Method[] methods = ClassUtil.getClassMethods(isolatedClass);\n\n                assertThat(Arrays.stream(methods).map(Method::getName))\n                        .contains(\"greeting\", \"dependency\");\n                assertThat(Arrays.stream(methods).map(Method::getDeclaringClass))\n                        .contains(MethodCarrier.class);\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalLoader);\n        }\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static Class<Enum<?>> enumClass(Class<? extends Enum<?>> enumClass) {\n        return (Class<Enum<?>>) (Class<?>) enumClass;\n    }\n\n    private static byte[] readClassBytes(String className) throws IOException {\n        String resourceName = className.replace('.', '/') + \".class\";\n        ClassLoader loader = JacksonClassUtilTest.class.getClassLoader();\n        try (InputStream input = loader.getResourceAsStream(resourceName)) {\n            if (input == null) {\n                throw new IOException(\"Class resource not found: \" + resourceName);\n            }\n            ByteArrayOutputStream output = new ByteArrayOutputStream();\n            byte[] buffer = new byte[4096];\n            int read;\n            while ((read = input.read(buffer)) != -1) {\n                output.write(buffer, 0, read);\n            }\n            return output.toByteArray();\n        }\n    }\n\n    private static final class MissingDependencyClassLoader extends ClassLoader {\n\n        private MissingDependencyClassLoader() {\n            super(JacksonClassUtilTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (METHOD_DEPENDENCY_CLASS_NAME.equals(name)) {\n                    throw new ClassNotFoundException(name);\n                }\n                if (METHOD_CARRIER_CLASS_NAME.equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        try {\n                            byte[] bytes = readClassBytes(name);\n                            loadedClass = defineClass(name, bytes, 0, bytes.length);\n                        } catch (IOException exception) {\n                            throw new ClassNotFoundException(name, exception);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n    }\n}\n\n@Retention(RetentionPolicy.RUNTIME)\n@Target(ElementType.FIELD)\n@interface Preferred {\n}\n\nenum AnnotatedChoice {\n    @Preferred\n    PRIMARY,\n    SECONDARY\n}\n\nfinal class FieldCarrier {\n    public String name;\n    private int count;\n}\n\nfinal class MethodDependency {\n}\n\nfinal class MethodCarrier {\n    public String greeting() {\n        return \"hello\";\n    }\n\n    public MethodDependency dependency() {\n        return new MethodDependency();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1465, "output": 2861, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 30438, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780696008904, "responseId": "resp_083c416a393ae45c016a2343c95bfc8196bfe84142df3e045f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_3V82ljuf1ljKarOPPC7TD8kp|fc_083c416a393ae45c016a2343f38fe481969f60d89f4fe0e9de", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5633 bytes to tests/src/com.fasterxml.jackson.core/jackson-databind/2.22.0/src/test/java/com_fasterxml_jackson_core/jackson_databind/JacksonClassUtilTest.java"}], "isError": false, "timestamp": 1780696064528}]}
