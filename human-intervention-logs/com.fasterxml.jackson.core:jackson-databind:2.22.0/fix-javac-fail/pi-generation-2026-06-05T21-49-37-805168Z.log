String METHOD_DEPENDENCY_CLASS_NAME = MethodDependency.class.getName();\n\n    @Test\n    void findsAnnotatedEnumValueByInspectingDeclaredFields() {\n        Enum<?> value = ClassUtil.findFirstAnnotatedEnumValue(enumClass(AnnotatedChoice.class), Preferred.class);\n\n        assertThat(value).isSameAs(AnnotatedChoice.PRIMARY);\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void exposesDeclaredFieldsThroughClassUtil() {\n        Field[] fields = ClassUtil.getDeclaredFields(FieldCarrier.class);\n\n        assertThat(Arrays.stream(fields).map(Field::getName))\n                .contains(\"name\", \"count\");\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void exposesDeclaredMethodsThroughClassUtil() {\n        Method[] methods = ClassUtil.getDeclaredMethods(MethodCarrier.class);\n\n        assertThat(Arrays.stream(methods).map(Method::getName))\n                .contains(\"greeting\", \"dependency\");\n    }\n\n    @Test\n    void fallsBackToContextClassLoaderWhenDeclaredMethodsNeedMissingType() throws Exception {\n        ClassLoader originalLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(JacksonClassUtilTest.class.getClassLoader());\n        try {\n            try {\n                Class<?> isolatedClass = new MissingDependencyClassLoader().loadClass(METHOD_CARRIER_CLASS_NAME);\n\n                Method[] methods = ClassUtil.getClassMethods(isolatedClass);\n\n                assertThat(Arrays.stream(methods).map(Method::getName))\n                        .contains(\"greeting\", \"dependency\");\n                assertThat(Arrays.stream(methods).map(Method::getDeclaringClass))\n                        .contains(MethodCarrier.class);\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalLoader);\n        }\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static Class<Enum<?>> enumClass(Class<? extends Enum<?>> enumClass) {\n        return (Class<Enum<?>>) (Class<?>) enumClass;\n    }\n\n    private static byte[] methodCarrierClassBytes() throws Exception {\n        String carrierName = METHOD_CARRIER_CLASS_NAME.replace('.', '/');\n        String dependencyDescriptor = \"L\" + METHOD_DEPENDENCY_CLASS_NAME.replace('.', '/') + \";\";\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(bytes);\n\n        output.writeInt(0xCAFEBABE);\n        output.writeShort(0);\n        output.writeShort(52);\n        output.writeShort(18);\n        writeMethodRef(output, 2, 3);\n        writeClass(output, 4);\n        writeNameAndType(output, 5, 6);\n        writeUtf(output, \"java/lang/Object\");\n        writeUtf(output, \"<init>\");\n        writeUtf(output, \"()V\");\n        writeClass(output, 8);\n        writeUtf(output, carrierName);\n        writeUtf(output, \"Code\");\n        writeUtf(output, \"greeting\");\n        writeUtf(output, \"()Ljava/lang/String;\");\n        writeString(output, 13);\n        writeUtf(output, \"hello\");\n        writeUtf(output, \"dependency\");\n        writeUtf(output, \"()\" + dependencyDescriptor);\n        writeUtf(output, \"SourceFile\");\n        writeUtf(output, \"MethodCarrier.java\");\n\n        output.writeShort(0x0031);\n        output.writeShort(7);\n        output.writeShort(2);\n        output.writeShort(0);\n        output.writeShort(0);\n        output.writeShort(3);\n        writeCodeMethod(output, 0x0001, 5, 6, new byte[] {(byte) 0x2A, (byte) 0xB7, 0, 1, (byte) 0xB1});\n        writeCodeMethod(output, 0x0001, 10, 11, new byte[] {(byte) 0x12, 12, (byte) 0xB0});\n        writeCodeMethod(output, 0x0001, 14, 15, new byte[] {(byte) 0x01, (byte) 0xB0});\n        output.writeShort(1);\n        output.writeShort(16);\n        output.writeInt(2);\n        output.writeShort(17);\n        return bytes.toByteArray();\n    }\n\n    private static void writeMethodRef(DataOutputStream output, int classIndex, int nameAndTypeIndex) throws Exception {\n        output.writeByte(10);\n        output.writeShort(classIndex);\n        output.writeShort(nameAndTypeIndex);\n    }\n\n    private static void writeClass(DataOutputStream output, int nameIndex) throws Exception {\n        output.writeByte(7);\n        output.writeShort(nameIndex);\n    }\n\n    private static void writeNameAndType(DataOutputStream output, int nameIndex, int descriptorIndex) throws Exception {\n        output.writeByte(12);\n        output.writeShort(nameIndex);\n        output.writeShort(descriptorIndex);\n    }\n\n    private static void writeUtf(DataOutputStream output, String value) throws Exception {\n        output.writeByte(1);\n        output.writeUTF(value);\n    }\n\n    private static void writeString(DataOutputStream output, int stringIndex) throws Exception {\n        output.writeByte(8);\n        output.writeShort(stringIndex);\n    }\n\n    private static void writeCodeMethod(DataOutputStream output, int access, int nameIndex, int descriptorIndex,\n            byte[] code) throws Exception {\n        output.writeShort(access);\n        output.writeShort(nameIndex);\n        output.writeShort(descriptorIndex);\n        output.writeShort(1);\n        output.writeShort(9);\n        output.writeInt(12 + code.length);\n        output.writeShort(1);\n        output.writeShort(1);\n        output.writeInt(code.length);\n        output.write(code);\n        output.writeShort(0);\n        output.writeShort(0);\n    }\n\n    private static final class MissingDependencyClassLoader extends ClassLoader {\n\n        private MissingDependencyClassLoader() {\n            super(JacksonClassUtilTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                if (METHOD_DEPENDENCY_CLASS_NAME.equals(name)) {\n                    throw new ClassNotFoundException(name);\n                }\n                if (METHOD_CARRIER_CLASS_NAME.equals(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        try {\n                            byte[] bytes = methodCarrierClassBytes();\n                            loadedClass = defineClass(name, bytes, 0, bytes.length);\n                        } catch (Exception exception) {\n                            throw new ClassNotFoundException(name, exception);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n                return super.loadClass(name, resolve);\n            }\n        }\n    }\n}\n\n@Retention(RetentionPolicy.RUNTIME)\n@Target(ElementType.FIELD)\n@interface Preferred {\n}\n\nenum AnnotatedChoice {\n    @Preferred\n    PRIMARY,\n    SECONDARY\n}\n\nfinal class FieldCarrier {\n    public String name;\n    private int count;\n}\n\nfinal class MethodDependency {\n}\n\nfinal class MethodCarrier {\n    public String greeting() {\n        return \"hello\";\n    }\n\n    public MethodDependency dependency() {\n        return new MethodDependency();\n    }\n}\n"}], "isError": false, "timestamp": 1780696142419}]}
