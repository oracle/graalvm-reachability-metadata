}\n                \"\"\", FieldBackedBuilderValue.class);\n\n        assertThat(value.getName()).isEqualTo(\"builder\");\n    }\n\n    @Test\n    void setsFieldPropertyThroughSettableBeanPropertyApi() throws Exception {\n        SettableBeanProperty property = findProperty(FieldBackedBean.class, \"name\");\n        assertThat(property).isInstanceOf(FieldProperty.class);\n\n        FieldBackedBean bean = new FieldBackedBean();\n        property.set(bean, \"set\");\n        assertThat(bean.name).isEqualTo(\"set\");\n\n        Object returned = property.setAndReturn(bean, \"returned\");\n        assertThat(returned).isSameAs(bean);\n        assertThat(bean.name).isEqualTo(\"returned\");\n    }\n\n    private static SettableBeanProperty findProperty(Class<?> beanType, String propertyName) throws Exception {\n        AtomicReference<SettableBeanProperty> propertyRef = new AtomicReference<>();\n        ObjectMapper mapper = new ObjectMapper();\n        SimpleModule module = new SimpleModule();\n        module.setDeserializerModifier(new BeanDeserializerModifier() {\n            @Override\n            public BeanDeserializerBuilder updateBuilder(DeserializationConfig config,\n                    BeanDescription beanDescription, BeanDeserializerBuilder builder) {\n                if (beanDescription.getBeanClass().equals(beanType)) {\n                    propertyRef.set(findProperty(builder, propertyName));\n                }\n                return builder;\n            }\n        });\n        mapper.registerModule(module);\n        mapper.readValue(\"{}\", beanType);\n\n        SettableBeanProperty property = propertyRef.get();\n        assertThat(property).as(\"field-backed property %s\", propertyName).isNotNull();\n        return property;\n    }\n\n    private static SettableBeanProperty findProperty(BeanDeserializerBuilder builder, String propertyName) {\n        Iterator<SettableBeanProperty> properties = builder.getProperties();\n        while (properties.hasNext()) {\n            SettableBeanProperty property = properties.next();\n            if (property.getName().equals(propertyName)) {\n                return property;\n            }\n        }\n        throw new AssertionError(\"Missing property: \" + propertyName);\n    }\n\n    public static final class FieldBackedBean {\n        public String name;\n    }\n\n    @JsonDeserialize(builder = FieldBackedBuilderValue.Builder.class)\n    public static final class FieldBackedBuilderValue {\n        private final String name;\n\n        private FieldBackedBuilderValue(Builder builder) {\n            this.name = builder.name;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        @JsonPOJOBuilder(withPrefix = \"\")\n        public static final class Builder {\n            public String name;\n\n            public FieldBackedBuilderValue build() {\n                return new FieldBackedBuilderValue(this);\n            }\n        }\n    }\n}\n"}
