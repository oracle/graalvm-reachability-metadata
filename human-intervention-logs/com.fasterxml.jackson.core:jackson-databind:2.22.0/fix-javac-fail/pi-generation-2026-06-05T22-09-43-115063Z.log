              calendar.setTime(d);
              TimeZone tz = ctxt.getTimeZone();
              if (tz != null) {
                  calendar.setTimeZone(tz);
              }
              return _dataTypeFactory.newXMLGregorianCalendar(calendar);
          }
      }
  }
