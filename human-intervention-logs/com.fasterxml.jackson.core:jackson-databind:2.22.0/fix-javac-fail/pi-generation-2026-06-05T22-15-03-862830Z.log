              try {
                  contextClass = loader.loadClass(cls.getName());
              } catch (ClassNotFoundException e) {
                  ex.addSuppressed(e);
                  return _failGetClassMethods(cls, ex);
              }
              try {
                  return contextClass.getDeclaredMethods(); // Cross fingers
              } catch (Exception t) {
                  return _failGetClassMethods(cls, t);
              }
