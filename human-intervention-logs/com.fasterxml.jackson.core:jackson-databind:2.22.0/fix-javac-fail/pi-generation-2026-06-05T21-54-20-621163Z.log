\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_fasterxml_jackson_core.jackson_databind;\n\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport com.fasterxml.jackson.annotation.JsonFormat;\nimport com.fasterxml.jackson.databind.BeanDescription;\nimport com.fasterxml.jackson.databind.ObjectMapper;\nimport com.fasterxml.jackson.databind.SerializationConfig;\nimport com.fasterxml.jackson.databind.module.SimpleModule;\nimport com.fasterxml.jackson.databind.ser.BeanPropertyWriter;\nimport com.fasterxml.jackson.databind.ser.BeanSerializerModifier;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BeanPropertyWriterTest {\n\n    private static final ObjectMapper MAPPER = new ObjectMapper();\n\n    @Test\n    void readsFieldBackedPropertyThroughBeanPropertyWriterGet() throws Exception {\n        FieldBackedPojo bean = new FieldBackedPojo(\"field-get\");\n        BeanPropertyWriter writer = findWriter(FieldBackedPojo.class, \"value\");\n\n        assertThat(writer.get(bean)).isEqualTo(\"field-get\");\n    }\n\n    @Test\n    void invokesGetterBackedPropertyThroughBeanPropertyWriterGet() throws Exception {\n        GetterBackedPojo bean = new GetterBackedPojo(\"getter-get\");\n        BeanPropertyWriter writer = findWriter(GetterBackedPojo.class, \"value\");\n\n        assertThat(writer.get(bean)).isEqualTo(\"getter-get\");\n    }\n\n    @Test\n    void serializesFieldBackedPropertyAsArrayElement() throws Exception {\n        String json = MAPPER.writeValueAsString(new ArrayFieldBackedPojo(\"field-element\"));\n\n        assertThat(json).isEqualTo(\"[\\\"field-element\\\"]\");\n    }\n\n    @Test\n    void serializesGetterBackedPropertyAsArrayElement() throws Exception {\n        String json = MAPPER.writeValueAsString(new ArrayGetterBackedPojo(\"getter-element\"));\n\n        assertThat(json).isEqualTo(\"[\\\"getter-element\\\"]\");\n    }\n\n    private static BeanPropertyWriter findWriter(Class<?> beanType, String propertyName) throws Exception {\n        AtomicReference<BeanPropertyWriter> writerRef = new AtomicReference<>();\n        ObjectMapper mapper = new ObjectMapper();\n        SimpleModule module = new SimpleModule();\n        module.setSerializerModifier(new BeanSerializerModifier() {\n            @Override\n            public List<BeanPropertyWriter> changeProperties(SerializationConfig config,\n                    BeanDescription beanDescription, List<BeanPropertyWriter> beanProperties) {\n                if (beanDescription.getBeanClass().equals(beanType)) {\n                    writerRef.set(findWriter(beanProperties, propertyName));\n                }\n                return beanProperties;\n            }\n        });\n        mapper.registerModule(module);\n        mapper.writeValueAsString(newInstance(beanType));\n\n        BeanPropertyWriter writer = writerRef.get();\n        assertThat(writer).as(\"bean property writer %s\", propertyName).isNotNull();\n        return writer;\n    }\n\n    private static BeanPropertyWriter findWriter(List<BeanPropertyWriter> writers, String propertyName) {\n        return writers.stream()\n                .filter(writer -> writer.getName().equals(propertyName))\n                .findFirst()\n                .orElseThrow(() -> new AssertionError(\"Missing property writer: \" + propertyName));\n    }\n\n    private static Object newInstance(Class<?> beanType) {\n        if (beanType.equals(FieldBackedPojo.class)) {\n            return new FieldBackedPojo(\"capture\");\n        }\n        if (beanType.equals(GetterBackedPojo.class)) {\n            return new GetterBackedPojo(\"capture\");\n        }\n        throw new IllegalArgumentException(\"Unsupported bean type: \" + beanType.getName());\n    }\n\n    public static final class FieldBackedPojo {\n        public final String value;\n\n        public FieldBackedPojo(String value) {\n            this.value = value;\n        }\n    }\n\n    public static final class GetterBackedPojo {\n        private final String value;\n\n        public GetterBackedPojo(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n\n    @JsonFormat(shape = JsonFormat.Shape.ARRAY)\n    public static final class ArrayFieldBackedPojo {\n        public final String value;\n\n        public ArrayFieldBackedPojo(String value) {\n            this.value = value;\n        }\n    }\n\n    @JsonFormat(shape = JsonFormat.Shape.ARRAY)\n    public static final class ArrayGetterBackedPojo {\n        private final String value;\n\n        public ArrayGetterBackedPojo(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 673, "output": 1530, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 30875, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780696872569, "responseId": "resp_07e31f0fbd993153016a2347291dc88195956df9d22e326ed1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_VgiLegnWKBIoO6XchyaxwgQB|fc_07e31f0fbd993153016a234733b72c819591f10a379c8da25d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4836 bytes to tests/src/com.fasterxml.jackson.core/jackson-databind/2.22.0/src/test/java/com_fasterxml_jackson_core/jackson_databind/BeanPropertyWriterTest.java"}], "isError": false, "timestamp": 1780696896096}]}
