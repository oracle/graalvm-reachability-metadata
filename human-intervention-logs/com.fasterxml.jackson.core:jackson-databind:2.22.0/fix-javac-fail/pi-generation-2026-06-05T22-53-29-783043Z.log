ption {\n        ObjectMapper mapper = new ObjectMapper();\n        mapper.addMixIn(Object.class, ObjectHashCodeMixIn.class);\n        HashCodeTarget target = new HashCodeTarget();\n\n        JsonNode json = mapper.readTree(mapper.writeValueAsString(target));\n\n        assertThat(json.get(\"objectHash\").intValue()).isEqualTo(target.hashCode());\n    }\n\n    public static final class MixInTarget {\n        private final String name;\n\n        public MixInTarget(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    public abstract static class RenamingMixIn {\n        @JsonProperty(\"renamedName\")\n        public abstract String getName();\n    }\n\n    public static final class HashCodeTarget {\n        @Override\n        public int hashCode() {\n            return 1138;\n        }\n    }\n\n    public abstract static class ObjectHashCodeMixIn {\n        @JsonProperty(\"objectHash\")\n        public abstract int hashCode();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 6108, "output": 1335, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 32019, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780699935922, "responseId": "resp_0e1f7c67e82a798c016a23532065208190b0a3937f90e4eb4c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_gp1jhGRSPx7KPqlgHb5C5fUp|fc_0e1f7c67e82a798c016a23533959208190ac1aa1af4e9ef2c3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2051 bytes to tests/src/com.fasterxml.jackson.core/jackson-databind/2.22.0/src/test/java/com_fasterxml_jackson_core/jackson_databind/AnnotatedMethodCollectorTest.java"}], "isError": false, "timestamp": 1780699967995}]}
