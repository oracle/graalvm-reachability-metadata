er(objectMapper));\n        module.addSerializer(Date.class, new SqlDateSerializer());\n        module.addSerializer(Time.class, new SqlTimeSerializer());\n        module.addSerializer(Blob.class, new SqlBlobSerializer());\n        module.addSerializer(Node.class, new DOMSerializer());\n        module.addSerializer(XMLGregorianCalendar.class, new CoreXMLSerializers.XMLGregorianCalendarSerializer());\n        objectMapper.registerModule(module);\n        return objectMapper;\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static JsonDeserializer<? extends XMLGregorianCalendar> xmlGregorianCalendarDeserializer(\n            ObjectMapper objectMapper) {\n        JsonDeserializer<?> deserializer = new CoreXMLDeserializers().findBeanDeserializer(\n                objectMapper.constructType(XMLGregorianCalendar.class), objectMapper.getDeserializationConfig(), null);\n        if (deserializer == null) {\n            throw new IllegalStateException(\"Missing XMLGregorianCalendar deserializer\");\n        }\n        return (JsonDeserializer<? extends XMLGregorianCalendar>) deserializer;\n    }\n"}]}
