reed to in writing, software distributed under the License\\n    is distributed on an \\\"AS IS\\\" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express\\n    or implied. See the License for the specific language governing permissions and limitations under\\n    the License.\\n\\n-->\\n<project xmlns=\\\"http://maven.apache.org/POM/4.0.0\\\" xmlns:xsi=\\\"http://www.w3.org/2001/XMLSchema-instance\\\" xsi:schemaLocation=\\\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\\\">\\n  <modelVersion>4.0.0</modelVersion>\\n\\n  <parent>\\n    <groupId>io.zipkin.reporter2</groupId>\\n    <artifactId>zipkin-reporter-parent</artifactId>\\n    <version>3.0.0</version>\\n  </parent>\\n\\n  <artifactId>zipkin-sender-okhttp3</artifactId>\\n  <name>Zipkin Sender: OkHttp 3</name>\\n\\n  <properties>\\n    <!-- Matches Export-Package in bnd.bnd -->\\n    <module.name>zipkin2.reporter.okhttp3</module.name>\\n\\n    <main.basedir>${project.basedir}/..</main.basedir>\\n    <!-- pre-1.8, pre-kotlin, and last version before Call.timeout. -->\\n    <old-okhttp.version>3.11.0</old-okhttp.version>\\n  </properties>\\n\\n  <dependencies>\\n    <dependency>\\n      <groupId>${project.groupId}</groupId>\\n      <artifactId>zipkin-reporter</artifactId>\\n      <version>${project.version}</version>\\n      <!-- Senders don't use zipkin types. Excluding allows brave users to\\n           avoid them by default. -->\\n      <exclusions>\\n        <exclusion>\\n          <groupId>io.zipkin.zipkin2</groupId>\\n          <artifactId>zipkin</artifactId>\\n        </exclusion>\\n      </exclusions>\\n    </dependency>\\n\\n    <dependency>\\n      <groupId>com.squareup.okhttp3</groupId>\\n      <artifactId>okhttp</artifactId>\\n      <version>${okhttp.version}</version>\\n    </dependency>\\n\\n    <dependency>\\n      <groupId>com.squareup.okhttp3</groupId>\\n      <artifactId>mockwebserver</artifactId>\\n      <version>${okhttp.version}</version>\\n      <scope>test</scope>\\n    </dependency>\\n  </dependencies>\\n\\n  <build>\\n    <plugins>\\n      <plugin>\\n        <artifactId>maven-invoker-plugin</artifactId>\\n      </plugin>\\n      <plugin>\\n        <groupId>de.qaware.maven</groupId>\\n        <artifactId>go-offline-maven-plugin</artifactId>\\n        <executions>\\n          <execution>\\n            <phase>package</phase>\\n            <goals>\\n              <goal>resolve-dependencies</goal>\\n            </goals>\\n          </execution>\\n        </executions>\\n        <configuration>\\n          <!-- Add dependencies specific to invoker tests so that they cache on go-offline -->\\n          <dynamicDependencies>\\n            <DynamicDependency>\\n              <groupId>com.squareup.okhttp3</groupId>\\n              <artifactId>mockwebserver</artifactId>\\n              <version>${old-okhttp.version}</version>\\n              <repositoryType>MAIN</repositoryType>\\n              <type>jar</type>\\n            </DynamicDependency>\\n          </dynamicDependencies>\\n        </configuration>\\n      </plugin>\\n    </plugins>\\n  </build>\\n\\n  <profiles>\\n    <profile>\\n      <id>release</id>\\n      <properties>\\n        <!-- OkHttp 3.x is Java 1.7 bytecode -->\\n        <maven.compiler.source>1.7</maven.compiler.source>\\n        <maven.compiler.target>1.7</maven.compiler.target>\\n        <maven.compiler.release>7</maven.compiler.release>\\n      </properties>\\n      <build>\\n        <plugins>\\n          <plugin>\\n            <artifactId>maven-enforcer-plugin</artifactId>\\n            <version>${maven-enforcer-plugin.version}</version>\\n            <executions>\\n              <execution>\\n                <id>enforce-java</id>\\n                <goals>\\n                  <goal>enforce</goal>\\n                </goals>\\n                <configuration>\\n                  <rules>\\n                    <!-- The only LTS JDK we support that can compile 1.6 bytecode is 11.\\n                