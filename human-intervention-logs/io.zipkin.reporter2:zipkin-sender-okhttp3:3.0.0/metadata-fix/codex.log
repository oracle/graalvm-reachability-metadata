ow(exception);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <E extends Throwable> void sneakyThrow(Throwable throwable) throws E {\n        throw (E) throwable;\n    }\n}\n","exit_code":0,"status":"completed"}}
