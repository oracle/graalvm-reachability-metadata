  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "io.zipkin.reporter2:zipkin-sender-okhttp3:$libraryVersion"
      testImplementation "io.zipkin.zipkin2:zipkin:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      binaries {
          test {
              // okhttp3.internal.Util eagerly resolves UTF-32 charsets during static init.
              buildArgs.add("-H:+AddAllCharsets")
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
