preferred)\n    41\t * - --coordinates=<filter>\n    42\t * The filter can be <code>group:artifact:version</code> or a fractional batch in the form <code>k/n</code> (e.g., 1/16), or 'all'.\n    43\t */\n    44\tpublic abstract class ComputeAndPullAllowedDockerImagesTask extends DefaultTask {\n    45\t\n    46\t    @Input\n    47\t    @Optional\n    48\t    public abstract Property<@NotNull String> getCoordinates();\n    49\t\n    50\t    @Option(option = \"coordinates\", description = \"Coordinate filter (group[:artifact[:version]] or k/n fractional batch)\")\n    51\t    public void setCoordinatesOption(String value) {\n    52\t        getCoordinates().set(value);\n    53\t    }\n    54\t\n    55\t    @Inject\n    56\t    protected abstract ExecOperations getExecOperations();\n    57\t\n    58\t    protected String effectiveCoordinateFilter() {\n    59\t        // Prefer task option, fallback to -Pcoordinates, then empty string (all)\n    60\t        String opt = getCoordinates().getOrNull();\n    61\t        if (opt != null) {\n    62\t            return opt;\n    63\t        }\n    64\t        Object prop = getProject().findProperty(\"coordinates\");\n    65\t        return prop == null ? \"\" : prop.toString();\n    66\t    }\n    67\t\n    68\t    @TaskAction\n    69\t    public void run() throws IOException {\n    70\t        TckExtension tck = Objects.requireNonNull(getProject().getExtensions().findByType(TckExtension.class));\n    71\t\n    72\t        // Resolve coordinates\n    73\t        String filter = effectiveCoordinateFilter();\n    74\t\n    75\t        List<String> matching;\n    76\t        if (CoordinateUtils.isFractionalBatch(filter)) {\n    77\t            int[] frac = CoordinateUtils.parseFraction(filter);\n    78\t            assert frac != null : \"Already checked\";\n    79\t            List<String> all = tck.getMatchingCoordinatesStrict(\"all\");\n    80\t            matching = CoordinateUtils.computeBatchedCoordinates(all, frac[0], frac[1]);\n    81\t        } else {\n    82\t            matching = tck.getMatchingCoordinates(filter);\n    83\t        }\n    84\t\n    85\t        if (matching == null || matching.isEmpty()) {\n    86\t            throw new GradleException(\"No matching coordinates found. Provide --coordinates=<filter> (preferred) or -Pcoordinates=<filter>, or a fractional batch 'k/n'.\");\n    87\t        }\n    88\t\n    89\t        // Collect union of required docker images\n    90\t        Set<String> requiredImages = new LinkedHashSet<>();\n    91\t\n    92\t        for (String c : matching) {\n    93\t            String[] parts = c.split(\":\");\n    94\t            if (parts.length < 3) {\n    95\t                throw new GradleException(\"Invalid coordinates: \" + c);\n    96\t            }\n    97\t            String group = parts[0];\n    98\t            String artifact = parts[1];\n    99\t            String version = parts[2];\n   100\t\n   101\t            Path indexPath = getProject().getProjectDir().toPath()\n   102\t                    .resolve(\"metadata\")\n   103\t                    .resolve(group)\n   104\t                    .resolve(artifact)\n   105\t                    .resolve(\"index.json\");\n   106\t            String testVersion = resolveTestVersion(indexPath, version);\n   107\t            if (testVersion != null) {\n   108\t                Path dockerImagesPath = getProject().getProjectDir().toPath()\n   109\t                        .resolve(\"tests/src\")\n   110\t                        .resolve(group)\n   111\t                        .resolve(artifact)\n   112\t                        .resolve(testVersion)\n   113\t                        .resolve(\"required-docker-images.txt\");\n   114\t\n   115\t                File f = getProject().file(dockerImagesPath);\n   116\t                if (f.exists()) {\n   117\t                    Files.readAllLines(f.toPath()).stream()\n   118\t                            .map(String::trim)\n   119\t                            .filter(s -> !s.isEmpty())\n   120\t                            .filter(s -> !s.startsWith(\"#\"))\n   121\t                            .forEach(requiredImages::add);\n   122\t                }\n   123\t            }\n   124\t        }\n   125\t\n   126\t        // Validate against allowed images\n   127\t        validateRequiredImages(requiredImages);\n   128\t\n   129\t        // Pull images immediately\n   130\t        for (String image : requiredImages) {\n   131\t            getLogger().lifecycle(\"Pulling docker image {}\", image);\n   132\t            try {\n   133\t                getExecOperations().exec(spec -> {\n   134\t                    spec.setExecutable(\"docker\");\n   135\t                    spec.args(\"pull\", image);\n   136\t                });\n   137\t            } catch (Exception e) {\n   138\t                throw new GradleException(\"Failed to pull image \" + image + \": \" + e.getMessage(), e);\n   139\t            }\n   140\t        }\n   141\t\n   142\t        if (requiredImages.isEmpty()) {\n   143\t            getLogger().lifecycle(\"No required docker images found for coordinates filter '{}'. If your tests use docker, please read: {}\", filter,\n   144\t                    URI.create(\"https://github.com/oracle/graalvm-reachability-metadata/blob/master/CONTRIBUTING.md#providing-the-tests-that-use-docker\"));\n   145\t        }\n   146\t    }\n   147\t\n   148\t    static String resolveTestVersion(Path indexPath, String version) throws IOException {\n   149\t        List<Map<String, Object>> entries = readIndexEntries(indexPath);\n   150\t\n   151\t        // 1) Primary: when a tested-version is provided, find the entry whose tested-versions contains it.\n   152\t        for (Map<String, Object> entry : entries) {\n   153\t            Object rawTestedVersions = entry.get(\"tested-versions\");\n   154\t            if (rawTestedVersions instanceof List<?> testedVersions && testedVersions.contains(version)) {\n   155\t                return effectiveTestVersion(entry);\n   156\t            }\n   157\t        }\n   158\t\n   159\t        // 2) Fallback: if the coordinate version is itself a metadata-version, match it directly.\n   160\t        for (Map<String, Object> entry : entries) {\n   161\t            Object rawMetadataVersion = entry.get(\"metadata-version\");\n   162\t            if (version.equals(rawMetadataVersion)) {\n   163\t                return effectiveTestVersion(entry);\n   164\t            }\n   165\t        }\n   166\t\n   167\t        return null;\n   168\t    }\n   169\t\n   170\t    private static List<Map<String, Object>> readIndexEntries(Path indexPath) throws IOException {\n   171\t        if (!Files.exists(indexPath)) {\n   172\t            throw new GradleException(\"Cannot find index file at: \" + indexPath);\n   173\t        }\n   174\t\n   175\t        String content = Files.readString(indexPath, StandardCharsets.UTF_8);\n   176\t        if (content.isBlank()) {\n   177\t            throw new GradleException(\"Cannot find index file at: \" + indexPath);\n   178\t        }\n   179\t\n   180\t        Object parsed = new JsonSlurper().parseText(content);\n   181\t        if (!(parsed instanceof List<?> rawEntries)) {\n   182\t            throw new GradleException(\"Invalid index file at: \" + indexPath + \": expected a JSON array.\");\n   183\t        }\n   184\t\n   185\t        List<Map<String, Object>> entries = new ArrayList<>();\n   186\t        for (Object rawEntry : rawEntries) {\n   187\t            if (!(rawEntry instanceof Map<?, ?> rawMap)) {\n   188\t                throw new GradleException(\"Invalid index entry in \" + indexPath + \": expected a JSON object.\");\n   189\t            }\n   190\t            Map<String, Object> normalizedEntry = new LinkedHashMap<>();\n   191\t            rawMap.forEach((key, value) -> normalizedEntry.put(String.valueOf(key), value));\n   192\t            entries.add(normalizedEntry);\n   193\t        }\n   194\t        return entries;\n   195\t    }\n   196\t\n   197\t    private static String effectiveTestVersion(Map<String, Object> entry) {\n   198\t        Object rawTestVersion = entry.get(\"test-version\");\n   199\t        if (rawTestVersion instanceof String testVersion && !testVersion.isBlank()) {\n   200\t            return testVersion;\n   201\t        }\n   202\t\n   203\t        Object rawMetadataVersion = entry.get(\"metadata-version\");\n   204\t        if (rawMetadataVersion instanceof String metadataVersion && !metadataVersion.isBlank()) {\n   205\t            return metadataVersion;\n   206\t        }\n   207\t\n   208\t        return null;\n   209\t    }\n   210\t\n   211\t    private static void validateRequiredImages(Set<String> requiredImages) {\n   212\t        Set<String> allowed = DockerUtils.getAllAllowedImages();\n   213\t        List<String> notAllowed = new ArrayList<>();\n   214\t        for (String img : requiredImages) {\n   215\t            if (!allowed.contains(img)) {\n   216\t                notAllowed.add(img);\n   217\t            }\n   218\t        }\n   219\t        if (!notAllowed.isEmpty()) {\n   220\t            throw new GradleException(\"\"\"\n   221\t                    The following images are not in the allowed list: %s. \\\n   222\t                    If you need them, add Dockerfiles under tests/tck-build-logic/src/main/resources/allowed-docker-images \\\n   223\t                    per docs/CONTRIBUTING.md, or adjust required-docker-images.txt files.\n   224\t                    \"\"\".formatted(notAllowed));\n   225\t        }\n   226\t    }\n   227\t}\n","exit_code":0,"status":"completed"}}
