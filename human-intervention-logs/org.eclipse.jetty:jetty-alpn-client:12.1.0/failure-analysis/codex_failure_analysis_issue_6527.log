    2\\t * Copyright and related rights waived via CC0\\n     3\\t *\\n     4\\t * You should have received a copy of the CC0 legalcode along with this\\n     5\\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n     6\\t */\\n     7\\tpackage org.graalvm.internal.tck.harness.tasks;\\n     8\\t\\n     9\\timport groovy.json.JsonSlurper;\\n    10\\timport org.graalvm.internal.tck.DockerUtils;\\n    11\\timport org.graalvm.internal.tck.harness.TckExtension;\\n    12\\timport org.graalvm.internal.tck.utils.CoordinateUtils;\\n    13\\timport org.gradle.api.DefaultTask;\\n    14\\timport org.gradle.api.GradleException;\\n    15\\timport org.gradle.api.provider.Property;\\n    16\\timport org.gradle.api.tasks.Input;\\n    17\\timport org.gradle.api.tasks.Optional;\\n    18\\timport org.gradle.api.tasks.TaskAction;\\n    19\\timport org.gradle.api.tasks.options.Option;\\n    20\\timport org.gradle.process.ExecOperations;\\n    21\\timport org.jetbrains.annotations.NotNull;\\n    22\\t\\n    23\\timport javax.inject.Inject;\\n    24\\timport java.io.File;\\n    25\\timport java.io.IOException;\\n    26\\timport java.net.URI;\\n    27\\timport java.nio.charset.StandardCharsets;\\n    28\\timport java.nio.file.Files;\\n    29\\timport java.nio.file.Path;\\n    30\\timport java.util.*;\\n    31\\t\\n    32\\t/**\\n    33\\t * Single task that:\\n    34\\t * 1) Computes the union of required docker images across selected coordinates (supports fractional batching k/n)\\n    35\\t * 2) Validates them against the allowed-docker-images list\\n    36\\t * 3) Writes them to the provided output file\\n    37\\t * 4) Immediately pulls those images\\n    38\\t * </p>\\n    39\\t * Coordinates can be provided via:\\n    40\\t * - -Pcoordinates=<filter> (preferred)\\n    41\\t * - --coordinates=<filter>\\n    42\\t * The filter can be <code>group:artifact:version</code> or a fractional batch in the form <code>k/n</code> (e.g., 1/16), or 'all'.\\n    43\\t */\\n    44\\tpublic abstract class ComputeAndPullAllowedDockerImagesTask extends DefaultTask {\\n    45\\t\\n    46\\t    @Input\\n    47\\t    @Optional\\n    48\\t    public abstract Property<@NotNull String> getCoordinates();\\n    49\\t\\n    50\\t    @Option(option = \\\"coordinates\\\", description = \\\"Coordinate filter (group[:artifact[:version]] or k/n fractional batch)\\\")\\n    51\\t    public void setCoordinatesOption(String value) {\\n    52\\t        getCoordinates().set(value);\\n    53\\t    }\\n    54\\t\\n    55\\t    @Inject\\n    56\\t    protected abstract ExecOperations getExecOperations();\\n    57\\t\\n    58\\t    protected String effectiveCoordinateFilter() {\\n    59\\t        // Prefer task option, fallback to -Pcoordinates, then empty string (all)\\n    60\\t        String opt = getCoordinates().getOrNull();\\n    61\\t        if (opt != null) {\\n    62\\t            return opt;\\n    63\\t        }\\n    64\\t        Object prop = getProject().findProperty(\\\"coordinates\\\");\\n    65\\t        return prop == null ? \\\"\\\" : prop.toString();\\n    66\\t    }\\n    67\\t\\n    68\\t    @TaskAction\\n    69\\t    public void run() throws IOException {\\n    70\\t        TckExtension tck = Objects.requireNonNull(getProject().getExtensions().findByType(TckExtension.class));\\n    71\\t\\n    72\\t        // Resolve coordinates\\n    73\\t        String filter = effectiveCoordinateFilter();\\n    74\\t\\n    75\\t        List<String> matching;\\n    76\\t        if (CoordinateUtils.isFractionalBatch(filter)) {\\n    77\\t            int[] frac = CoordinateUtils.parseFraction(filter);\\n    78\\t            assert frac != null : \\\"Already checked\\\";\\n    79\\t            List<String> all = tck.getMatchingCoordinatesStrict(\\\"all\\\");\\n    80\\t            matching = CoordinateUtils.computeBatchedCoordinates(all, frac[0], frac[1]);\\n    81\\t        } else {\\n    82\\t            matching = tck.getMatchingCoordinates(filter);\\n    83\\t        }\\n    84\\t\\n    85\\t        if (matching == null || matching.isEmpty()) {\\n    86\\t            throw new GradleException(\\\"No matching coordinates found. Provide --coordinates=<filter> (preferred) or -Pcoordinates=<filter>, or a fractional batch 'k/n'.\\\");\\n    87\\t        }\\n    88\\t\\n    89\\t        // Collect union of required docker images\\n    90\\t        Set<String> requiredImages = new LinkedHashSet<>();\\n    91\\t\\n    92\\t        for (String c : matching) {\\n    93\\t            String[] parts = c.split(\\\":\\\");\\n    94\\t            if (parts.length < 3) {\\n    95\\t                throw new GradleException(\\\"Invalid coordinates: \\\" + c);\\n    96\\t            }\\n    97\\t            String group = parts[0];\\n    98\\t            String artifact = parts[1];\\n    99\\t            String version = parts[2];\\n   100\\t\\n   101\\t            Path indexPath = getProject().getProjectDir().toPath()\\n   102\\t                    .resolve(\\\"metadata\\\")\\n   103\\t                    .resolve(group)\\n   104\\t                    .resolve(artifact)\\n   105\\t                    .resolve(\\\"index.json\\\");\\n   106\\t            String testVersion = resolveTestVersion(indexPath, version);\\n   107\\t            if (testVersion != null) {\\n   108\\t                Path dockerImagesPath = getProject().getProjectDir().toPath()\\n   109\\t                        .resolve(\\\"tests/src\\\")\\n   110\\t                        .resolve(group)\\n   111\\t                        .resolve(artifact)\\n   112\\t                        .resolve(testVersion)\\n   113\\t                        .resolve(\\\"required-docker-images.txt\\\");\\n   114\\t\\n   115\\t                File f = getProject().file(dockerImagesPath);\\n   116\\t                if (f.exists()) {\\n   117\\t                    Files.readAllLines(f.toPath()).stream()\\n   118\\t                            .map(String::trim)\\n   119\\t                            .filter(s -> !s.isEmpty())\\n   120\\t                            .filter(s -> !s.startsWith(\\\"#\\\"))\\n   121\\t                            .forEach(requiredImages::add);\\n   122\\t                }\\n   123\\t            }\\n   124\\t        }\\n   125\\t\\n   126\\t        // Validate against allowed images\\n   127\\t        validateRequiredImages(requiredImages);\\n   128\\t\\n   129\\t        // Pull images immediately\\n   130\\t        for (String image : requiredImages) {\\n   131\\t            getLogger().lifecycle(\\\"Pulling docker image {}\\\", image);\\n   132\\t            try {\\n   133\\t                getExecOperations().exec(spec -> {\\n   134\\t                    spec.setExecutable(\\\"docker\\\");\\n   135\\t                    spec.args(\\\"pull\\\", image);\\n   136\\t                });\\n   137\\t            } catch (Exception e) {\\n   138\\t                throw new GradleException(\\\"Failed to pull image \\\" + image + \\\": \\\" + e.getMessage(), e);\\n   139\\t            }\\n   140\\t        }\\n   141\\t\\n   142\\t        if (requiredImages.isEmpty()) {\\n   143\\t            getLogger().lifecycle(\\\"No required docker images found for coordinates filter '{}'. If your tests use docker, please read: {}\\\", filter,\\n   144\\t                    URI.create(\\\"https://github.com/oracle/graalvm-reachability-metadata/blob/master/CONTRIBUTING.md#providing-the-tests-that-use-docker\\\"));\\n   145\\t        }\\n   146\\t    }\\n   147\\t\\n   148\\t    static String resolveTestVersion(Path indexPath, String version) throws IOException {\\n   149\\t        List<Map<String, Object>> entries = readIndexEntries(indexPath);\\n   150\\t\\n   151\\t        // 1) Primary: when a tested-version is provided, find the entry whose tested-versions contains it.\\n   152\\t        for (Map<String, Object> entry : entries) {\\n   153\\t            Object rawTestedVersions = entry.get(\\\"tested-versions\\\");\\n   154\\t            if (