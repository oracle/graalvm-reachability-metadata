    private static Class<?> getClassForSerialization(Object instance) {
      assert (instance != null);
  
      if (instance instanceof Enum<?>) {
        Enum<?> e = (Enum<?>) instance;
        return e.getDeclaringClass();
      } else {
        return instance.getClass();
      }
    }
  
