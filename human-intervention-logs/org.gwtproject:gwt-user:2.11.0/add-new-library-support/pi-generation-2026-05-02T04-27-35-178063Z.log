      }
  
      @Override
      public String getTag() {
        return "-junit";
      }
  
      @Override
      public String[] getTagArgs() {
        return new String[] {"pathToJUnitJar"};
      }
  
      @Override
      public boolean isRequired() {
        return false;
      }
  
      @Override
      public boolean setString(String str) {
        File f = new File(str);
