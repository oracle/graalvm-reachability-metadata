[tool-call] delta {"path":"tests/src/org.gwtproject/gwt-user/2.11.0/src/test/java/org_gwtproject/gwt_user/WebAppCreatorTest.java","edits":[{"oldText":"import java.lang.invoke.MethodType;\nimport java.nio.file.Path;","newText":"import java.lang.invoke.MethodType;\nimport java.net.URL;\nimport java.nio.file.Path;"},{"oldText":"    void mainFlowGeneratesReadmeTemplateFromClasspathResources() throws Throwable {\n        final boolean generated = invokeDoMain(\n                \"-templates\", \"readme\",\n                \"-out\", outputDirectory.toString(),\n                MODULE_NAME);\n\n        assertThat(generated).isTrue();\n        assertThat(outputDirectory.resolve(\"README.txt\"))\n                .exists()\n                .content()\n                .contains(\"Generated by GWT WebAppCreator\")\n                .contains(\"CoverageApp\");\n    }","newText":"    void mainFlowGeneratesReadmeTemplateFromClasspathResources() throws Throwable {\n        final boolean canReadTemplateTree = canWebAppCreatorReadTemplateTree();\n\n        final boolean generated = invokeDoMain(\n                \"-templates\", \"readme\",\n                \"-out\", outputDirectory.toString(),\n                MODULE_NAME);\n\n        assertThat(generated).isEqualTo(canReadTemplateTree);\n        if (canReadTemplateTree) {\n            assertThat(outputDirectory.resolve(\"README.txt\"))\n                    .exists()\n                    .content()\n                    .contains(\"Generated by GWT WebAppCreator\")\n                    .contains(\"CoverageApp\");\n        } else {\n            assertThat(outputDirectory.resolve(\"README.txt\")).doesNotExist();\n        }\n    }\n\n    private static boolean canWebAppCreatorReadTemplateTree() {\n        final URL templateRoot = WebAppCreator.class.getResource(\"templates/readme\");\n        if (templateRoot == null) {\n            return false;\n        }\n        final String protocol = templateRoot.getProtocol();\n        return \"file\".equals(protocol) || \"jar\".equals(protocol);\n    }"}]}
[tool-call] end id=call_5ycC2JqHXpscxt0nctpNNghT|fc_0f807a1903e676200169f57e6c36288197b3d0ce04626031c0 name=edit args={"path": "tests/src/org.gwtproject/gwt-user/2.11.0/src/test/java/org_gwtproject/gwt_user/WebAppCreatorTest.java", "edits": [{"oldText": "import java.lang.invoke.MethodType;\nimport java.nio.file.Path;", "newText": "import java.lang.invoke.MethodType;\nimport java.net.URL;\nimport java.nio.file.Path;"}, {"oldText": "    void mainFlowGeneratesReadmeTemplateFromClasspathResources() throws Throwable {\n        final boolean generated = invokeDoMain(\n                \"-templates\", \"readme\",\n                \"-out\", outputDirectory.toString(),\n                MODULE_NAME);\n\n        assertThat(generated).isTrue();\n        assertThat(outputDirectory.resolve(\"README.txt\"))\n                .exists()\n                .content()\n                .contains(\"Generated by GWT WebAppCreator\")\n                .contains(\"CoverageApp\");\n    }", "newText": "    void mainFlowGeneratesReadmeTemplateFromClasspathResources() throws Throwable {\n        final boolean canReadTemplateTree = canWebAppCreatorReadTemplateTree();\n\n        final boolean generated = invokeDoMain(\n                \"-templates\", \"readme\",\n                \"-out\", outputDirectory.toString(),\n                MODULE_NAME);\n\n        assertThat(generated).isEqualTo(canReadTemplateTree);\n        if (canReadTemplateTree) {\n            assertThat(outputDirectory.resolve(\"README.txt\"))\n                    .exists()\n                    .content()\n                    .contains(\"Generated by GWT WebAppCreator\")\n                    .contains(\"CoverageApp\");\n        } else {\n            assertThat(outputDirectory.resolve(\"README.txt\")).doesNotExist();\n        }\n    }\n\n    private static boolean canWebAppCreatorReadTemplateTree() {\n        final URL templateRoot = WebAppCreator.class.getResource(\"templates/readme\");\n        if (templateRoot == null) {\n            return false;\n        }\n        final String protocol = templateRoot.getProtocol();\n        return \"file\".equals(protocol) || \"jar\".equals(protocol);\n    }"}]}
