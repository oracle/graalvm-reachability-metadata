[tool-call] delta {"path":"tests/src/org.gwtproject/gwt-user/2.11.0/src/test/java/org_gwtproject/gwt_user/WebAppCreatorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_gwtproject.gwt_user;\n\nimport com.google.gwt.user.tools.WebAppCreator;\n\nimport java.net.URL;\nimport java.nio.file.Path;\nimport java.security.Permission;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class WebAppCreatorTest {\n    private static final String MODULE_NAME = \"org_gwtproject.gwt_user.coverage.CoverageApp\";\n\n    @TempDir\n    Path outputDirectory;\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void mainGeneratesReadmeTemplateFromClasspathResources() {\n        final URL readmeTemplateRoot = WebAppCreator.class.getResource(\"templates/readme\");\n        assertThat(readmeTemplateRoot).isNotNull();\n\n        final SecurityManager previousSecurityManager = System.getSecurityManager();\n        final ExitTrappingSecurityManager securityManager = new ExitTrappingSecurityManager();\n        if (!installSecurityManagerIfSupported(securityManager)) {\n            return;\n        }\n\n        try {\n            assertThatThrownBy(() -> WebAppCreator.main(new String[] {\n                    \"-templates\", \"readme\",\n                    \"-out\", outputDirectory.toString(),\n                    MODULE_NAME\n            }))\n                    .isInstanceOf(ExitException.class)\n                    .extracting(exception -> ((ExitException) exception).statusCode())\n                    .isEqualTo(expectedExitStatus(readmeTemplateRoot));\n\n            if (expectedExitStatus(readmeTemplateRoot) == 0) {\n                assertThat(outputDirectory.resolve(\"README.txt\"))\n                        .exists()\n                        .content()\n                        .contains(\"Generated by GWT WebAppCreator\")\n                        .contains(\"CoverageApp\");\n            } else {\n                assertThat(outputDirectory.resolve(\"README.txt\")).doesNotExist();\n            }\n        } finally {\n            System.setSecurityManager(previousSecurityManager);\n        }\n    }\n\n    private static int expectedExitStatus(final URL readmeTemplateRoot) {\n        final String protocol = readmeTemplateRoot.getProtocol();\n        return \"jar\".equals(protocol) || \"file\".equals(protocol) ? 0 : 1;\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static boolean installSecurityManagerIfSupported(final SecurityManager securityManager) {\n        try {\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (final UnsupportedOperationException unsupportedOperationException) {\n            return false;\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class ExitTrappingSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(final Permission permission) {\n        }\n\n        @Override\n        public void checkExit(final int statusCode) {\n            throw new ExitException(statusCode);\n        }\n    }\n\n    private static final class ExitException extends SecurityException {\n        private final int statusCode;\n\n        private ExitException(final int statusCode) {\n            super(\"Intercepted System.exit(\" + statusCode + \")\");\n            this.statusCode = statusCode;\n        }\n\n        private int statusCode() {\n            return statusCode;\n        }\n    }\n}\n"}
