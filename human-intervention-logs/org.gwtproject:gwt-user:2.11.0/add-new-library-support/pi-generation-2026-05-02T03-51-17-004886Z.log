        this.suffix = null;
      }
  
      public DotPathValue(String path, String suffix) {
        assert path != null : "path";
        assert suffix != null : "suffix";
        this.path = path;
        this.suffix = suffix;
      }
  
      @Override
      public String getExpression() {
        StringBuilder toReturn = new StringBuilder();
        toReturn.append(path.replace(".", "()."));
        toReturn.append("()");
        if (suffix != null) {
