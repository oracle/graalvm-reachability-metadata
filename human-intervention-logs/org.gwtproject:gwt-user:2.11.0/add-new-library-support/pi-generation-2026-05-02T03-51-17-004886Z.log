        return Arrays.asList(path.split("\\."));
      }
  
      public String getPath() {
        return path;
      }
  
      public String getSuffix() {
        return suffix;
      }
  
      @Override
      public DotPathValue isDotPathValue() {
        return this;
      }
  
      @Override
      public boolean isStatic() {
        return false;
      }
  
      @Override
      public String toCss() {
        return "value(\"" + path + "\""
