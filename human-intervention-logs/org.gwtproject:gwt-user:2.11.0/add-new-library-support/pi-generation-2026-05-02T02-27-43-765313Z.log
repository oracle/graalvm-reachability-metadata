        if (fieldWriter != null) {
          // ownerField is a widget.
          JClassType type = fieldWriter.getInstantiableType();
          if (type != null) {
            maybeWriteFieldSetter(niceWriter, ownerField, fieldWriter.getInstantiableType(),
                fieldName);
          } else {
            // Must be a generated type
