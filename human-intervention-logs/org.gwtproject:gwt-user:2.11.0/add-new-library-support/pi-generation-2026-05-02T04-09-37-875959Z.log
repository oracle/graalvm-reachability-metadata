      s.defaultReadObject();
      // Read in size (number of Mappings)
      int numberOfMappings = s.readInt();
      // Read the keys and values, and put the mappings in the HashMap
      for (int i = 0; i < numberOfMappings; i++) {
        s.readObject(); // key
        s.readObject(); // value
      }
