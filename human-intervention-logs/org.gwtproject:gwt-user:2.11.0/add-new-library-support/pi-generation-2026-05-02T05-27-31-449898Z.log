     */
    static final Comparator<JType> JTYPE_COMPARATOR = new Comparator<JType>() {
      @Override
      public int compare(JType t1, JType t2) {
        return t1.getQualifiedSourceName().compareTo(t2.getQualifiedSourceName());
      }
    };
  
    /**
