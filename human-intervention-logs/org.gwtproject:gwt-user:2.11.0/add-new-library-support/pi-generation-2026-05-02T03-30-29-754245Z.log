    @Override
    public Class<?> resolveDomainClass(Class<?> clazz) {
      if (List.class.equals(clazz)) {
        return List.class;
      } else if (Set.class.equals(clazz)) {
        return Set.class;
      } else if (Map.class.equals(clazz)) {
        return Map.class;
      } else if (BaseProxy.class.isAssignableFrom(clazz)) {
