ge(GWTBridge bridge) {\n    com.google.gwt.core.shared.GWT.setBridge(bridge);\n    if (bridge != null) {\n      setUncaughtExceptionHandler(new DefaultUncaughtExceptionHandler());\n    }\n  }\n\n  private static native String getVersion0() /*-{\n    return $gwt_version;\n  }-*/;\n}\n"}], "isError": false, "timestamp": 1777698607880}]}
