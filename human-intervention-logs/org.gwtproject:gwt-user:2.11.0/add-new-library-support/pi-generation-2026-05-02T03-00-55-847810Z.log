      }
      Iterable<ArgumentInfo> arguments = annotResource.argumentsIterator(key);
      StringBuffer buf = new StringBuffer();
      if (arguments != null) {
        int i = 0;
        for (ArgumentInfo argInfo : arguments) {
  
