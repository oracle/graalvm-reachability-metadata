  import java.util.Set;
  
  import javax.validation.ConstraintViolation;
  
  public final class GwtSpecificValidatorCreatorEntryPoint implements EntryPoint {
      @Override
      public void onModuleLoad() {
          GwtSpecificValidatorCreatorCoveredValidator validator =
