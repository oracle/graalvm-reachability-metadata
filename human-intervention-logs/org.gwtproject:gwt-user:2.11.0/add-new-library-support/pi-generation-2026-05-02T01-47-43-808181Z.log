     */
    public static final int FLAG_ELIDE_TYPE_NAMES = 0x1;
    
    /**
     * Indicates that RPC token is included in the RPC payload.
     */
    public static final int FLAG_RPC_TOKEN_INCLUDED = 0x2;
    
    /**
