     * 
     * @param receiver a {@link Receiver} instance
     * @throws IllegalArgumentException if <code>receiver</code> is
     *           <code>null</code>
     */
    void fire(Receiver<Void> receiver);
  
    /**
     * Returns the {@link RequestFactory} that created the RequestContext.
