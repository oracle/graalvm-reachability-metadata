  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "org.gwtproject:gwt-user:$libraryVersion"
      testImplementation "org.gwtproject:gwt-dev:$libraryVersion"
