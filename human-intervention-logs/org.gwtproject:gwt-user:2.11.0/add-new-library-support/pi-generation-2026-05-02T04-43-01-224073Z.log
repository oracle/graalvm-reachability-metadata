      int length = name.length();
      if (length == 0 || (length > 1 && Character.isUpperCase(name.charAt(1)))) {
        return name;
      }
      StringBuilder sb = new StringBuilder(length);
      sb.append(Character.toLowerCase(name.charAt(0)));
      sb.append(name.substring(1));
      return sb.toString();
  
