        <scope>compile</scope>
        <optional>true</optional>
      </dependency>
  
      <!-- Testing Dependencies -->
      <dependency>
        <groupId>io.fabric8</groupId>
        <artifactId>mockwebserver</artifactId>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.junit.jupiter</groupId>
