kubernetes.client.internal,\n      io.fabric8.kubernetes.client.handlers,\n      io.fabric8.kubernetes.client.dsl.base,\n      io.fabric8.kubernetes.client.dsl.internal\n    </osgi.private>\n  </properties>\n\n  <dependencies>\n    <dependency>\n      <groupId>io.fabric8</groupId>\n      <artifactId>kubernetes-client-api</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>io.fabric8</groupId>\n      <artifactId>kubernetes-client-api</artifactId>\n      <type>test-jar</type>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>io.fabric8</groupId>\n      <artifactId>kubernetes-httpclient-vertx</artifactId>\n      <scope>runtime</scope>\n    </dependency>\n\n    <dependency>\n      <groupId>io.fabric8</groupId>\n      <artifactId>zjsonpatch</artifactId>\n    </dependency>\n\n    <dependency>\n      <groupId>org.apache.commons</groupId>\n      <artifactId>commons-compress</artifactId>\n      <optional>true</optional>\n    </dependency>\n\n    <!-- Compile Only Dependencies -->\n    <dependency>\n      <groupId>io.sundr</groupId>\n      <artifactId>builder-annotations</artifactId>\n      <scope>provided</scope>\n    </dependency>\n    <dependency>\n      <groupId>io.sundr</groupId>\n      <artifactId>transform-annotations</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>org.projectlombok</groupId>\n      <artifactId>lombok</artifactId>\n    </dependency>\n    <dependency>\n      <groupId>org.osgi</groupId>\n      <artifactId>org.osgi.service.component.annotations</artifactId>\n      <scope>compile</scope>\n      <optional>true</optional>\n    </dependency>\n\n    <!-- Testing Dependencies -->\n    <dependency>\n      <groupId>io.fabric8</groupId>\n      <artifactId>mockwebserver</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.junit.jupiter</groupId>\n      <artifactId>junit-jupiter-engine</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.junit.jupiter</groupId>\n      <artifactId>junit-jupiter-params</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.slf4j</groupId>\n      <artifactId>slf4j-simple</artifactId>\n      <version>${slf4j.version}</version>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.mockito</groupId>\n      <artifactId>mockito-core</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.assertj</groupId>\n      <artifactId>assertj-core</artifactId>\n      <scope>test</scope>\n    </dependency>\n    <dependency>\n      <groupId>org.awaitility</groupId>\n      <artifactId>awaitility</artifactId>\n    </dependency>\n  </dependencies>\n\n  <build>\n    <plugins>\n      <plugin>\n        <groupId>org.apache.maven.plugins</groupId>\n        <artifactId>maven-surefire-plugin</artifactId>\n        <configuration>\n          <forkCount>1</forkCount>\n          <reuseForks>false</reuseForks>\n          <!-- We cleanup system properties an env vars, so that we can test in a predictable env -->\n          <environmentVariables>\n            <KUBERNETES_MASTER />\n            <KUBERNETES_API_VERSION />\n            <KUBERNETES_TRUST_CERTIFICATES />\n            <KUBERNETES_CERTS_CA_FILE />\n            <KUBERNETES_CERTS_CA_DATA />\n            <KUBERNETES_CERTS_CLIENT_FILE />\n            <KUBERNETES_CERTS_CLIENT_DATA />\n            <KUBERNETES_CERTS_CLIENT_KEY_FILE />\n            <KUBERNETES_CERTS_CLIENT_KEY_DATA />\n            <KUBERNETES_CERTS_CLIENT_KEY_ALGO />\n            <KUBERNETES_CERTS_CLIENT_KEY_PASSPHRASE />\n            <KUBERNETES_AUTH_BASIC_USERNAME />\n            <KUBERNETES_AUTH_BASIC_PASSWORD />\n            <KUBERNETES_AUTH_TRYKUBECONFIG />\n            <KUBERNETES_AUTH_TRYSERVICEACCOUNT />\n            <KUBERNETES_AUTH_TOKEN />\n            <KUBERNETES_WATCH_RECONNECTINTERVAL />\n            <KUBERNETES_WATCH_RECONNECTLIMIT />\n            <KUBERNETES_REQUEST_TIMEOUT />\n            <KUBERNETES_MAX_CONCURRENT_REQUESTS_PER_HOST />\n            <KUBERNETES_NAMESPACE />\n            <KUBERNETES_TLS_VERSIONS />\n          </environmentVariables>\n        </configuration>\n      </plugin>\n      <plugin>\n        <groupId>org.apache.maven.plugins</groupId>\n        <artifactId>maven-jar-plugin</artifactId>\n        <configuration>\n          <excludes>\n            <exclude>resource-*.vm</exclude>\n          </excludes>\n        </configuration>\n        <executions>\n          <execution>\n            <goals>\n              <goal>test-jar</goal>\n            </goals>\n          </execution>\n        </executions>\n      </plugin>\n      <plugin>\n        <groupId>org.apache.felix</groupId>\n        <artifactId>maven-bundle-plugin</artifactId>\n        <version>${maven.bundle.plugin.version}</version>\n        <executions>\n          <execution>\n            <id>bundle</id>\n            <phase>package</phase>\n            <goals>\n              <goal>bundle</goal>\n            </goals>\n            <configuration>\n              <excludeDependencies>\n                kubernetes-httpclient-vertx\n              </excludeDependencies>\n              <instructions>\n                <Bundle-Name>${project.name}</Bundle-Name>\n                <Bundle-SymbolicName>${project.groupId}.${project.artifactId}</Bundle-SymbolicName>\n                <Export-Package>${osgi.export}</Export-Package>\n                <Import-Package>${osgi.import}</Import-Package>\n                <DynamicImport-Package>${osgi.dynamic.import}</DynamicImport-Package>\n                <Require-Capability>${osgi.require-capability}</Require-Capability>\n                <Provide-Capability>${osgi.provide-capability}</Provide-Capability>\n                <Private-Package>${osgi.private}</Private-Package>\n                <Require-Bundle>${osgi.bundles}</Require-Bundle>\n                <Bundle-Activator>${osgi.activator}</Bundle-Activator>\n                <Export-Service>${osgi.export.service}</Export-Service>\n                <Include-Resource>\n                  /META-INF/services/io.fabric8.kubernetes.client.ServiceToURLProvider=target/classes/META-INF/services/io.fabric8.kubernetes.client.ServiceToURLProvider\n                </Include-Resource>\n              </instructions>\n              <classifier>bundle</classifier>\n            </configuration>\n          </execution>\n        </executions>\n      </plugin>\n      <plugin>\n        <groupId>org.codehaus.mojo</groupId>\n        <artifactId>templating-maven-plugin</artifactId>\n        <version>3.0.0</version>\n        <executions>\n          <execution>\n            <goals>\n              <goal>filter-sources</goal>\n            </goals>\n          </execution>\n        </executions>\n      </plugin>\n    </plugins>\n  </build>\n\n</project>\n"}], "isError": false, "timestamp": 1783794011090}, {"role": "toolResult", "toolCallId": "call_8wcWbc4qvAu8fXPikX7Equ2r|fc_0d8374adc63883f3016a52895a270881989aadb95f77d66e59", "toolName": "bash", "content": [{"type": "text", "text": "288-Note that when using adapt() both the adaptee and the target will share the same resources (underlying http client, thread pools etc).\n289-This means that close() is not required to be used on every single instance created via adapt.\n290-Calling close() on any of the adapt() managed instances or the original instance, will properly clean up all the resources and thus none of the instances will be usable any longer.\n291-\n292-\n293:## Mocking Kubernetes\n294-\n295-Along with the client this project also provides a Kubernetes Mock Server that you can use for testing purposes.\n296-\n297-The Mock Web Server has two modes of operation:\n298-\n299-- Expectations mode\n300-- CRUD mode\n301-\n302-### Expectations mode\n303-\n304-In this mode, you can set up expectations for the server to respond to HTTP and websocket requests.\n305-\n306-This mode has been extensively used for testing the client itself.\n307-Make sure you check [kubernetes-test](kubernetes-tests/src/test/java/io/fabric8/kubernetes/client/mock).\n308-\n309-To add a Kubernetes server to your test:\n310-```java\n311-@EnableKubernetesMockClient\n312-class MyTestSuite {\n313-  KubernetesMockServer server;\n314-}\n315-```\n316-\n317-Then you can use the server to define the expectations and the client to perform the regular kubernetes operations:\n318-```java\n319-class MyTestSuite {\n320-  KubernetesMockServer server;\n321-  KubernetesClient client;\n322-\n323-  @Test\n324-  void myTest() {\n325-    server.expect().get()\n326-      .withPath(\"/api/v1/namespaces/my-namespace/pods/my-pod\")\n327-      .andReturn(200, new PodBuilder().build())\n328-      .always();\n329-    Pod pod = client.pods().inNamespace(\"my-namespace\").withName(\"my-pod\").get();\n330-  }\n331-}\n332-```\n333-\n334-### CRUD mode\n335-\n336-Defining every single request and response can become tiresome.\n337-Given that in most cases the Mock Server is mostly used to perform simple CRUD based operations, a CRUD mode is also available.\n338-\n339-When using the CRUD mode, the mock web server will store, read, update and delete kubernetes resources using an in memory map and will appear as a real API server.\n340-\n341-To add a Kubernetes Server in crud mode to your test:\n342-```java\n343-@EnableKubernetesMockClient(crud = true)\n344-class MyTestSuite {\n345-  KubernetesClient client;\n346-}\n347-```\n348-\n349-Then you can use the client to perform the regular kubernetes operations:\n350-```java\n351-class MyTestSuite {\n352-  KubernetesClient client;\n353-\n354-  @Test\n355-  public void myCrudTest() {\n356-    //CREATE\n357-    client.pods().inNamespace(\"ns1\").create(new PodBuilder().withNewMetadata().withName(\"pod1\").endMetadata().build());\n358-\n359-    //READ\n360-    podList = client.pods().inNamespace(\"ns1\").list();\n361-    assertNotNull(podList);\n362-    assertEquals(1, podList.getItems().size());\n363-  }\n364-}\n365-```\n366-\n367-## Testing Against real Kubernetes API Server with Kube API Test\n368-\n369-In order to test against real Kubernetes API the project provides a lightweight approach, thus starting up Kubernetes API Server and etcd binaries.\n370-\n371-```java\n372-@EnableKubeAPIServer\n373-class KubeAPITestSample {\n374-\n375-  static KubernetesClient client;\n376-  \n377-  @Test\n378-  void testWithClient() {\n379-    // test using the client against real K8S API Server   \n380-  }\n381-}\n382-```\n383-\n384-For details see docs for [Kube API Test](doc/kube-api-test.md).\n385-\n386-## Compatibility\n387-\n388-### Kubernetes\n389-\n390-Starting from v5.5, the Kubernetes Client should be compatible with **any** supported Kubernetes cluster version.\n391-We provide DSL methods (for example `client.pods()`, `client.namespaces()`, and so on) for the most commonly used Kubernetes resources. If the resource you're looking for is not available through the DSL, you can always use the generic `client.resource()` method to interact with it. You can also open a [new issue](https://github.com/fabric8io/kubernetes-client/issues/new/choose) to request the addition of a new resource to the DSL.\n392-\n393-We provide Kubernetes Java model types (for example `Pod`) and their corresponding builders (for example `PodBuilder`) for every vanilla Kubernetes resource (and some extensions). If you don't find a specific resource, and you think that it should be part of the Kubernetes Client, please open a [new issue](https://github.com/fabric8io/kubernetes-client/issues/new/choose).\n62-    <dependency>\n63-      <groupId>io.fabric8</groupId>\n64-      <artifactId>kubernetes-client-api</artifactId>\n65:      <type>test-jar</type>\n66:      <scope>test</scope>\n67-    </dependency>\n68-    <dependency>\n69-      <groupId>io.fabric8</groupId>\n--\n103-      <optional>true</optional>\n104-    </dependency>\n105-\n106:    <!-- Testing Dependencies -->\n107- 