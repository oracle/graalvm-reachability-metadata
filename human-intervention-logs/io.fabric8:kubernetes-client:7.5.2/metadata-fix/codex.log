{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/io.fabric8/kubernetes-client/7.5.2/build.gradle && printf '\\\\n---FILE---\\\\n' && sed -n '1,240p' tests/src/io.fabric8/kubernetes-client/7.5.2/src/test/java/io_fabric8/kubernetes_client/Kubernetes_clientTest.java && printf '\\\\n---FILE---\\\\n' && sed -n '1,240p' tests/src/io.fabric8/kubernetes-client/7.5.2/src/test/java/io_fabric8/kubernetes_client/ResourceHandlerImplTest.java && printf '\\\\n---FILE---\\\\n' && sed -n '1,240p' tests/src/io.fabric8/kubernetes-client/7.5.2/src/test/java/io_fabric8/kubernetes_client/FilterNestedImplTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.fabric8:kubernetes-client:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n\n---FILE---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fabric8.kubernetes_client;\n\nimport org.junit.jupiter.api.Test;\n\nclass Kubernetes_clientTest {\n    @Test\n    void test() throws Exception {\n        System.out.println(\"This is just a placeholder, implement your test\");\n    }\n}\n\n---FILE---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fabric8.kubernetes_client;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.fabric8.kubernetes.api.model.ObjectMetaBuilder;\nimport io.fabric8.kubernetes.api.model.Pod;\nimport io.fabric8.kubernetes.client.Config;\nimport io.fabric8.kubernetes.client.ConfigBuilder;\nimport io.fabric8.kubernetes.client.KubernetesClient;\nimport io.fabric8.kubernetes.client.KubernetesClientBuilder;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ResourceHandlerImplTest {\n    private static final String POD_PATH = \"/api/v1/namespaces/testing/pods/example\";\n\n    @Test\n    void visitorEditBuildsPatchedPodThroughResourceHandler() throws Exception {\n        AtomicReference<String> patchBody = new AtomicReference<>();\n        AtomicReference<String> patchContentType = new AtomicReference<>();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/\", exchange -> respond(exchange, patchBody, patchContentType));\n        server.start();\n\n        try (KubernetesClient client = new KubernetesClientBuilder().withConfig(configFor(server)).build()) {\n            Pod edited = client.pods()\n                    .inNamespace(\"testing\")\n                    .withName(\"example\")\n                    .edit(ObjectMetaBuilder.class, metadata -> metadata.addToLabels(\"edited\", \"true\"));\n\n            assertThat(edited.getMetadata().getLabels()).containsEntry(\"edited\", \"true\");\n            assertThat(patchContentType.get()).contains(\"application/json-patch+json\");\n            assertThat(patchBody.get()).contains(\"edited\").contains(\"true\");\n        } finally {\n            server.stop(0);\n        }\n    }\n\n    private static Config configFor(HttpServer server) {\n        String masterUrl = \"http://127.0.0.1:\" + server.getAddress().getPort();\n        return new ConfigBuilder()\n                .withMasterUrl(masterUrl)\n                .withConnectionTimeout(5_000)\n                .withRequestTimeout(5_000)\n                .build();\n    }\n\n    private static void respond(\n            HttpExchange exchange,\n            AtomicReference<String> patchBody,\n            AtomicReference<String> patchContentType) throws IOException {\n        if (POD_PATH.equals(exchange.getRequestURI().getPath()) && \"GET\".equals(exchange.getRequestMethod())) {\n            sendJson(exchange, \"\"\"\n                    {\n                      \"apiVersion\": \"v1\",\n                      \"kind\": \"Pod\",\n                      \"metadata\": {\n                        \"name\": \"example\",\n                        \"namespace\": \"testing\",\n                        \"resourceVersion\": \"1\",\n                        \"labels\": {\"app\": \"demo\"}\n                      },\n                      \"spec\": {\"containers\": [{\"name\": \"main\", \"image\": \"busybox\"}]}\n                    }\n                    \"\"\");\n            return;\n        }\n        if (POD_PATH.equals(exchange.getRequestURI().getPath()) && \"PATCH\".equals(exchange.getRequestMethod())) {\n            patchContentType.set(exchange.getRequestHeaders().getFirst(\"Content-Type\"));\n            patchBody.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n            sendJson(exchange, \"\"\"\n                    {\n                      \"apiVersion\": \"v1\",\n                      \"kind\": \"Pod\",\n                      \"metadata\": {\n                        \"name\": \"example\",\n                        \"namespace\": \"testing\",\n                        \"resourceVersion\": \"2\",\n                        \"labels\": {\"app\": \"demo\", \"edited\": \"true\"}\n                      },\n                      \"spec\": {\"containers\": [{\"name\": \"main\", \"image\": \"busybox\"}]}\n                    }\n                    \"\"\");\n            return;\n        }\n        sendJson(exchange, 404, \"{}\\n\");\n    }\n\n    private static void sendJson(HttpExchange exchange, String response) throws IOException {\n        sendJson(exchange, 200, response);\n    }\n\n    private static void sendJson(HttpExchange exchange, int statusCode, String response) throws IOException {\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n        exchange.getResponseHeaders().set(\"Content-Type\", \"application/json\");\n        exchange.sendResponseHeaders(statusCode, responseBytes.length);\n        try (OutputStream output = exchange.getResponseBody()) {\n            output.write(responseBytes);\n        }\n    }\n}\n\n---FILE---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_fabric8.kubernetes_client;\n\nimport java.io.IOException;\nimport java.io.OutputStream;\nimport java.net.InetSocketAddress;\nimport java.net.URLDecoder;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport com.sun.net.httpserver.HttpExchange;\nimport com.sun.net.httpserver.HttpServer;\nimport io.fabric8.kubernetes.api.model.PodList;\nimport io.fabric8.kubernetes.client.Config;\nimport io.fabric8.kubernetes.client.ConfigBuilder;\nimport io.fabric8.kubernetes.client.KubernetesClient;\nimport io.fabric8.kubernetes.client.KubernetesClientBuilder;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FilterNestedImplTest {\n    @Test\n    void repeatedNegativeLabelAndFieldFiltersAreIncludedInListRequest() throws Exception {\n        AtomicReference<String> requestedQuery = new AtomicReference<>();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/\", exchange -> respond(exchange, requestedQuery));\n        server.start();\n\n        try (KubernetesClient client = new KubernetesClientBuilder().withConfig(configFor(server)).build()) {\n            PodList pods = client.pods()\n                    .inNamespace(\"testing\")\n                    .withoutLabel(\"app\", \"frontend\")\n                    .withoutLabel(\"app\", \"backend\")\n                    .withoutField(\"status.phase\", \"Pending\")\n                    .withoutField(\"status.phase\", \"Running\")\n                    .list();\n\n            assertThat(pods.getItems()).isEmpty();\n            String decodedQuery = URLDecoder.decode(requestedQuery.get(), StandardCharsets.UTF_8);\n            assertThat(decodedQuery)\n                    .contains(\"labelSelector=app!=frontend,app!=backend\")\n                    .contains(\"fieldSelector=status.phase!=Pending,status.phase!=Running\");\n        } finally {\n            server.stop(0);\n        }\n    }\n\n    private static Config configFor(HttpServer server) {\n        String masterUrl = \"http://127.0.0.1:\" + server.getAddress().getPort();\n        return new ConfigBuilder()\n                .withMasterUrl(masterUrl)\n                .withConnectionTimeout(5_000)\n                .withRequestTimeout(5_000)\n                .build();\n    }\n\n    private static void respond(HttpExchange exchange, AtomicReference<String> requestedQuery) throws IOException {\n        if (\"/api/v1/namespaces/testing/pods\".equals(exchange.getRequestURI().getPath())) {\n            requestedQuery.set(exchange.getRequestURI().getRawQuery());\n            sendJson(exchange, \"\"\"\n                    {\"apiVersion\":\"v1\",\"kind\":\"PodList\",\"metadata\":{\"resourceVersion\":\"1\"},\"items\":[]}\n                    \"\"\");\n            return;\n        }\n        sendJson(exchange, 404, \"{}\\n\");\n    }\n\n    private static void sendJson(HttpExchange exchange, String response) throws IOException {\n        sendJson(exchange, 200, response);\n    }\n\n    private static void sendJson(HttpExchange exchange, int statusCode, String response) throws IOException {\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n        exchange.getResponseHeaders().set(\"Content-Type\", \"application/json\");\n        exchange.sendResponseHeaders(statusCode, responseBytes.length);\n        try (OutputStream output = exchange.getResponseBody()) {\n            output.write(responseBytes);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
