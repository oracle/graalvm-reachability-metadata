erride\n        public Class<ContainerBuilder> getType() {\n            return ContainerBuilder.class;\n        }\n\n        @Override\n        public void visit(ContainerBuilder container) {\n            container.withImage(\"example.test/application:2\");\n        }\n    }\n}\n"}
