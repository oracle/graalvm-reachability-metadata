    @Override\n        public Class<ContainerBuilder> getType() {\n            return ContainerBuilder.class;\n        }\n\n        @Override\n        public void visit(ContainerBuilder container) {\n            container.withImage(\"example.test/application:2\");\n        }\n    }\n}\n"}}], "api": "openai-codex-responses", "provider": "openai-codex", "model": "gpt-5.6-terra", "usage": {"input": 495, "output": 1529, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 32232, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1783795348822, "responseId": "resp_0e1322d3bec23c58016a528e958964819189c10a22145d06af"}}
