RequestBody().readAllBytes(), StandardCharsets.UTF_8));\n            sendJson(exchange, \"\"\"\n                    {\n                      \"apiVersion\": \"v1\",\n                      \"kind\": \"Pod\",\n                      \"metadata\": {\n                        \"name\": \"example\",\n                        \"namespace\": \"testing\",\n                        \"resourceVersion\": \"2\",\n                        \"labels\": {\"app\": \"demo\", \"edited\": \"true\"}\n                      },\n                      \"spec\": {\"containers\": [{\"name\": \"main\", \"image\": \"busybox\"}]}\n                    }\n                    \"\"\");\n            return;\n        }\n        sendJson(exchange, 404, \"{}\\n\");\n    }\n\n    private static void sendJson(HttpExchange exchange, String response) throws IOException {\n        sendJson(exchange, 200, response);\n    }\n\n    private static void sendJson(HttpExchange exchange, int statusCode, String response) throws IOException {\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n        exchange.getResponseHeaders().set(\"Content-Type\", \"application/json\");\n        exchange.sendResponseHeaders(statusCode, responseBytes.length);\n        try (OutputStream output = exchange.getResponseBody()) {\n            output.write(responseBytes);\n        }\n    }\n}\n"}
