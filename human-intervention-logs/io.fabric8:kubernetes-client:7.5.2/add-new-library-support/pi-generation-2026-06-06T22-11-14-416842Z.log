    @Override
    public <V> T edit(final Class<V> visitorType, final Visitor<V> visitor) {
      return edit(new TypedVisitor<V>() {
        @Override
        public Class<V> getType() {
          return visitorType;
        }
  
        @Override
        public void visit(V item) {
          visitor.visit(item);
        }
      });
    }
  
