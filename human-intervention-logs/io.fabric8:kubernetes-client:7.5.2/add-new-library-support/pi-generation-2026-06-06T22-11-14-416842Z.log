le\";\n\n    @Test\n    void visitorEditBuildsPatchedPodThroughResourceHandler() throws Exception {\n        AtomicReference<String> patchBody = new AtomicReference<>();\n        AtomicReference<String> patchContentType = new AtomicReference<>();\n        HttpServer server = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        server.createContext(\"/\", exchange -> respond(exchange, patchBody, patchContentType));\n        server.start();\n\n        try (KubernetesClient client = new KubernetesClientBuilder().withConfig(configFor(server)).build()) {\n            Pod edited = client.pods()\n                    .inNamespace(\"testing\")\n                    .withName(\"example\")\n                    .edit(ObjectMeta.class, metadata -> metadata.getLabels().put(\"edited\", \"true\"));\n\n            assertThat(edited.getMetadata().getLabels()).containsEntry(\"edited\", \"true\");\n            assertThat(patchContentType.get()).contains(\"application/json-patch+json\");\n            assertThat(patchBody.get()).contains(\"edited\").contains(\"true\");\n        } finally {\n            server.stop(0);\n        }\n    }\n\n    private static Config configFor(HttpServer server) {\n        String masterUrl = \"http://127.0.0.1:\" + server.getAddress().getPort();\n        return new ConfigBuilder()\n                .withMasterUrl(masterUrl)\n                .withConnectionTimeout(5_000)\n                .withRequestTimeout(5_000)\n                .build();\n    }\n\n    private static void respond(\n            HttpExchange exchange,\n            AtomicReference<String> patchBody,\n            AtomicReference<String> patchContentType) throws IOException {\n        if (POD_PATH.equals(exchange.getRequestURI().getPath()) && \"GET\".equals(exchange.getRequestMethod())) {\n            sendJson(exchange, \"\"\"\n                    {\n                      \"apiVersion\": \"v1\",\n                      \"kind\": \"Pod\",\n                      \"metadata\": {\n                        \"name\": \"example\",\n                        \"namespace\": \"testing\",\n                        \"resourceVersion\": \"1\",\n                        \"labels\": {\"app\": \"demo\"}\n                      },\n                      \"spec\": {\"containers\": [{\"name\": \"main\", \"image\": \"busybox\"}]}\n                    }\n                    \"\"\");\n            return;\n        }\n        if (POD_PATH.equals(exchange.getRequestURI().getPath()) && \"PATCH\".equals(exchange.getRequestMethod())) {\n            patchContentType.set(exchange.getRequestHeaders().getFirst(\"Content-Type\"));\n            patchBody.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n            sendJson(exchange, \"\"\"\n                    {\n                      \"apiVersion\": \"v1\",\n                      \"kind\": \"Pod\",\n                      \"metadata\": {\n                        \"name\": \"example\",\n                        \"namespace\": \"testing\",\n                        \"resourceVersion\": \"2\",\n                        \"labels\": {\"app\": \"demo\", \"edited\": \"true\"}\n                      },\n                      \"spec\": {\"containers\": [{\"name\": \"main\", \"image\": \"busybox\"}]}\n                    }\n                    \"\"\");\n            return;\n        }\n        sendJson(exchange, 404, \"{}\\n\");\n    }\n\n    private static void sendJson(HttpExchange exchange, String response) throws IOException {\n        sendJson(exchange, 200, response);\n    }\n\n    private static void sendJson(HttpExchange exchange, int statusCode, String response) throws IOException {\n        byte[] responseBytes = response.getBytes(StandardCharsets.UTF_8);\n        exchange.getResponseHeaders().set(\"Content-Type\", \"application/json\");\n        exchange.sendResponseHeaders(statusCode, responseBytes.length);\n        try (OutputStream output = exchange.getResponseBody()) {\n            output.writ