edDispatcher;\nimport io.fabric8.kubernetes.client.server.mock.KubernetesMockServer;\nimport io.fabric8.kubernetes.client.utils.Serialization;\nimport io.fabric8.mockwebserver.Context;\nimport io.fabric8.mockwebserver.MockWebServer;\nimport io.fabric8.mockwebserver.ServerRequest;\nimport io.fabric8.mockwebserver.ServerResponse;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.HashMap;\nimport java.util.Map;\nimport java.util.Queue;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ResourceHandlerImplTest {\n    @Test\n    void visitorEditUsesInferredResourceBuilderForPod() {\n        Map<ServerRequest, Queue<ServerResponse>> responses = new HashMap<>();\n        KubernetesMockServer server = new KubernetesMockServer(\n                new Context(Serialization.jsonMapper()),\n                new MockWebServer(),\n                responses,\n                new KubernetesMixedDispatcher(responses),\n                true);\n        server.init();\n        try (NamespacedKubernetesClient client = server.createClient()) {\n            Pod pod = new PodBuilder()\n                    .withNewMetadata()\n                    .withName(\"visitor-edit\")\n                    .withNamespace(\"test\")\n                    .addToLabels(\"app\", \"demo\")\n                    .endMetadata()\n                    .withNewSpec()\n                    .addNewContainer()\n                    .withName(\"main\")\n                    .withImage(\"busybox\")\n                    .endContainer()\n                    .endSpec()\n                    .build();\n            client.pods().inNamespace(\"test\").resource(pod).create();\n\n            Pod edited = client.pods().inNamespace(\"test\").withName(\"visitor-edit\").edit(new Visitor<ObjectMeta>() {\n                @Override\n                public void visit(ObjectMeta metadata) {\n                    metadata.getLabels().put(\"edited\", \"true\");\n                }\n            });\n\n            assertThat(edited.getMetadata().getLabels())\n                    .containsEntry(\"app\", \"demo\")\n                    .containsEntry(\"edited\", \"true\");\n        } finally {\n            server.destroy();\n        }\n    }\n}\n"}}], "api": "openai-codex-responses", "provider": "openai-codex", "model": "gpt-5.5", "usage": {"input": 1004, "output": 926, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 20874, "cost": {"input": 0.00502, "output": 0.02778, "cacheRead": 0.009472, "cacheWrite": 0, "total": 0.042272}}, "stopReason": "toolUse", "timestamp": 1784849698956, "responseId": "resp_028e35bb3194f36a016a62a523e6548191a9cfba4f20726fb2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_H3gNo1ChUChPhPOeZZQqNw1w|fc_028e35bb3194f36a016a62a529406081918316de318a823a8f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2704 bytes to tests/src/io.fabric8/kubernetes-client/7.5.2/src/test/java/io_fabric8/kubernetes_client/ResourceHandlerImplTest.java"}], "isError": false, "timestamp": 1784849716667}]}
