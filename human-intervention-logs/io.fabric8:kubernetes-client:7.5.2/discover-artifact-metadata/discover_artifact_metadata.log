  <artifactId>kubernetes-client</artifactId>
  <packaging>jar</packaging>
  <name>Fabric8 :: Kubernetes :: Java Client</name>

  <properties>
    <osgi.require-capability>
      osgi.extender;
      filter:="(osgi.extender=osgi.serviceloader.processor)",
    </osgi.require-capability>
