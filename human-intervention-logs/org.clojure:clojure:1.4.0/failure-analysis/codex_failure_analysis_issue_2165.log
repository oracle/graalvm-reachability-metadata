d = RT.seqToPassedArray(values, passed);\\n\\n        assertThat(expanded)\\n                .isInstanceOf(String[].class)\\n                .isNotSameAs(passed)\\n                .containsExactly(\\\"alpha\\\", \\\"beta\\\", \\\"gamma\\\");\\n    }\\n\\n    @Test\\n    void seqToTypedArrayCreatesArrayWithRequestedComponentType() {\\n        ISeq values = RT.seq(Arrays.asList(\\\"delta\\\", \\\"epsilon\\\"));\\n\\n        Object typedArray = RT.seqToTypedArray(String.class, values);\\n\\n        assertThat(typedArray).isInstanceOf(String[].class);\\n        assertThat((String[]) typedArray).containsExactly(\\\"delta\\\", \\\"epsilon\\\");\\n    }\\n\\n    @Test\\n    void systemResourceLookupFindsResourceWhenLoaderIsNull() throws IOException {\\n        URL url = RT.getResource(null, RESOURCE_NAME);\\n        assertThat(url).isNotNull();\\n\\n        try (InputStream input = RT.resourceAsStream(null, RESOURCE_NAME)) {\\n            assertThat(input).isNotNull();\\n            assertThat(new String(input.readAllBytes(), StandardCharsets.UTF_8)).contains(\\\"RT system resource\\\");\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n272:2026-05-11T18:01:54.652905Z ERROR codex_core::tools::router: error=write_stdin failed: stdin is closed for this session; rerun exec_command with tty=true to keep stdin open\n274:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_143\",\"type\":\"agent_message\",\"text\":\"I’ve confirmed the generated resource config is empty, so the resource inclusion is coming only from the checked-in metadata. Next I’m pulling the native failure stack and the resolved Clojure JAR to verify exactly what `RT` is trying to load.\"}}\n276:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_144\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,240p' tests/src/org.clojure/clojure/1.4.0/test-results-native/test/TEST-junit-jupiter.xml\\\"\",\"aggregated_output\":\"<?xml version=\\\"1.0\\\" encoding=\\\"UT