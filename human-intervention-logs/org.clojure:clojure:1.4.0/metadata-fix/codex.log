{"type":"item.completed","item":{"id":"item_43","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.clojure/clojure/1.4.0/src/test/java/org_clojure/clojure/FnLoaderThunkTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_clojure.clojure;\n\nimport clojure.lang.AFn;\nimport clojure.lang.FnLoaderThunk;\nimport clojure.lang.RT;\nimport clojure.lang.Var;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FnLoaderThunkTest {\n    @Test\n    void loadsFunctionClassWithBoundFunctionLoaderBeforeInvoking() {\n        Var target = Var.create();\n\n        Var.pushThreadBindings(RT.map(\n                RT.var(\"clojure.core\", \"*fn-loader*\"), FnLoaderThunkTest.class.getClassLoader()));\n        try {\n            FnLoaderThunk thunk = new FnLoaderThunk(target, LoadedFunction.class.getName());\n\n            assertThat(thunk.invoke(\"value\")).isEqualTo(\"loaded:value\");\n            assertThat(target.getRawRoot()).isInstanceOf(LoadedFunction.class);\n        } finally {\n            Var.popThreadBindings();\n        }\n    }\n\n    public static class LoadedFunction extends AFn {\n        @Override\n        public Object invoke(Object arg1) {\n            return \"loaded:\" + arg1;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
