{"type":"item.completed","item":{"id":"item_189","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,180p' /home/vjovanov/c/g/vj/GR-75222-deprecate-ConfigurationGenerateFiltersCommand/ee/substratevm-enterprise/src/com.oracle.svm.enterprise.test.config/src/com/oracle/svm/enterprise/test/config/predefined/generate.py\"","aggregated_output":"#!/usr/bin/env python3\n\n# These test classes are intended for use with class predefinition, so they cannot also be on the\n# regular class path. These classes must also be declared public or the tests will run into access\n# violations with the module system.\n#\n# Run this script to compile the classes with different debug levels and populate ../config-dir.\n# Set environment variable JAVA8_HOME to a Java 8 SDK, which is needed so that the class files\n# are compatible with Java 8.\n\nimport subprocess\nimport hashlib\nimport glob\nimport shutil\nimport os\nimport json\n\nwith open('ExtendedIntBinaryOperator.java', 'w') as f:\n    f.write(\"\"\"package com.oracle.svm.enterprise.test.config.predefined;\n\npublic interface ExtendedIntBinaryOperator extends java.util.function.IntBinaryOperator {\n    default int zero() {\n        return 0;\n    }\n}\n\ninterface InternalIntBinaryOp {\n    int compute(int left, int right);\n}\n\"\"\")\n\nwith open('Subtractor.java', 'w') as f:\n    f.write(\"\"\"package com.oracle.svm.enterprise.test.config.predefined;\n\npublic class Subtractor implements java.util.function.IntBinaryOperator {\n    private final InternalIntBinaryOp delegate = new SubtractorDelegate();\n    private final InternalIntBinaryOp unit = new SubtractorUnit();\n\n    @Override\n    public int applyAsInt(int left, int right) {\n        return delegate.compute(left, right);\n    }\n\n    public class SubtractorDelegate implements InternalIntBinaryOp {\n        public int compute(int left, int right) {\n            return unit.compute(left, right);\n        }\n    }\n\n    public static class SubtractorUnit implements InternalIntBinaryOp {\n        public int compute(int left, int right) {\n            return left - right;\n        }\n    }\n}\n\"\"\")\n\nwith open('Adder.java', 'w') as f:\n    f.write(\"\"\"package com.oracle.svm.enterprise.test.config.predefined;\n\npublic final class Adder extends Subtractor implements ExtendedIntBinaryOperator {\n    private InternalIntBinaryOp anonymous = new InternalIntBinaryOp() {\n        @Override\n        public int compute(int left, int right) {\n            return Adder.super.applyAsInt(left, Adder.super.applyAsInt(zero(), right));\n        }\n    };\n\n    @Override\n    public int applyAsInt(int left, int right) {\n        return new InternalIntBinaryOp() { // anonymous class with enclosing method\n            @Override\n            public int compute(int left, int right) {\n                return anonymous.compute(left, right);\n            }\n        }.compute(left, right);\n    }\n}\n\"\"\")\n\nfor n in glob.glob('../config-dir/agent-extracted-predefined-classes/*.classdata'):\n    os.remove(n)\n\nconfig_classes = []\nconfig = [{\"type\": \"agent-extracted\", \"classes\": config_classes}]\n\nfor args in [], ['-g'], ['-g:none']:\n    subprocess.run([f'{os.environ[\"JAVA8_HOME\"]}/bin/javac'] + args + glob.glob('*.java'))\n    for name in glob.glob('*.class'):\n        qualifiedName = f'com/oracle/svm/enterprise/test/config/predefined/{name[:-6]}'\n        with open(name, 'rb') as f:\n            h = hashlib.sha256(f.read()).hexdigest()\n        existing = [c for c in config_classes if c['hash'] == h]\n        if existing:\n            conflict = [c for c in existing if c['nameInfo'] != qualifiedName]\n            if conflict:\n                raise Exception(f'Hash conflict for {qualifiedName}: {conflict}')\n            continue\n        shutil.move(name, f'../config-dir/agent-extracted-predefined-classes/{h}.classdata')\n        config_classes.append({'nameInfo': qualifiedName, 'hash': h})\n\nwith open('../config-dir/predefined-classes-config.json', 'w') as f:\n    json.dump(config, f, indent=2)\n\nos.remove('ExtendedIntBinaryOperator.java')\nos.remove('Subtractor.java')\nos.remove('Adder.java')\n","exit_code":0,"status":"completed"}}
