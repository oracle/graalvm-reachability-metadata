{"type":"item.completed","item":{"id":"item_127","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' build/codex/CaptureClojurePredefinedClasses.java\"","aggregated_output":"import java.lang.reflect.Method;\nimport java.net.URL;\nimport java.net.URLClassLoader;\n\npublic final class CaptureClojurePredefinedClasses {\n    private CaptureClojurePredefinedClasses() {\n    }\n\n    public static void main(String[] args) throws Exception {\n        if (args.length != 1) {\n            throw new IllegalArgumentException(\"Expected one argument: path to clojure jar\");\n        }\n\n        URL clojureJar = new URL(\"file\", \"\", args[0]);\n        try (FilteringClassLoader loader = new FilteringClassLoader(new URL[]{clojureJar}, ClassLoader.getPlatformClassLoader())) {\n            Thread.currentThread().setContextClassLoader(loader);\n            Class<?> rtClass = Class.forName(\"clojure.lang.RT\", true, loader);\n            Method init = rtClass.getMethod(\"init\");\n            init.invoke(null);\n        }\n    }\n\n    private static final class FilteringClassLoader extends URLClassLoader {\n        private FilteringClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (shouldHideClass(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (shouldHideResource(name)) {\n                return null;\n            }\n            return super.getResource(name);\n        }\n\n        private static boolean shouldHideClass(String name) {\n            if (!name.startsWith(\"clojure.\") || name.startsWith(\"clojure.lang.\") || name.startsWith(\"clojure.asm.\")) {\n                return false;\n            }\n            return name.endsWith(\"__init\") || name.contains(\"$\") || Character.isLowerCase(name.charAt(\"clojure.\".length()));\n        }\n\n        private static boolean shouldHideResource(String name) {\n            if (!name.startsWith(\"clojure/\") || !name.endsWith(\".class\")\n                    || name.startsWith(\"clojure/lang/\") || name.startsWith(\"clojure/asm/\")) {\n                return false;\n            }\n            String className = name.substring(0, name.length() - \".class\".length()).replace('/', '.');\n            return shouldHideClass(className);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
