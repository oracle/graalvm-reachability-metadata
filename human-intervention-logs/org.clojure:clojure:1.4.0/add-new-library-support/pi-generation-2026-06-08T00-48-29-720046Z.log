;\n\n    @Test\n    void genClassCollectsInheritedMethodsWhileEmittingClassFile() throws Exception {\n        boolean bindingsPushed = false;\n        try {\n            Var.pushThreadBindings(RT.map(\n                    Compiler.COMPILE_FILES,\n                    Boolean.TRUE,\n                    Compiler.COMPILE_PATH,\n                    compilePath.toString()));\n            bindingsPushed = true;\n\n            Compiler.load(new StringReader(\"\"\"\n                    (ns org-clojure.clojure.generated-sample)\n                    (gen-class\n                      :name org_clojure.clojure.GeneratedSample\n                      :methods [[sample [] String]]\n                      :load-impl-ns false)\n                    \"\"\"));\n\n            Path generatedClass = compilePath.resolve(\"org_clojure/clojure/GeneratedSample.class\");\n            assertThat(generatedClass).exists();\n            assertThat(Files.size(generatedClass)).isPositive();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            if (bindingsPushed) {\n                Var.popThreadBindings();\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2317, "output": 1090, "cacheRead": 27136, "cacheWrite": 0, "totalTokens": 30543, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780879664807, "responseId": "resp_062ec5f8bae5b71a016a2611313cf08196941aa2db9fb4b667"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_RS64vzRR8bFpgkPspqGFEyAZ|fc_062ec5f8bae5b71a016a26113fa1f081969b6bd4c5fe4a5872", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1898 bytes to tests/src/org.clojure/clojure/1.4.0/src/test/java/org_clojure/clojure/ClojureCoreInnerNon_private_methodsInnerFn__5358Test.java"