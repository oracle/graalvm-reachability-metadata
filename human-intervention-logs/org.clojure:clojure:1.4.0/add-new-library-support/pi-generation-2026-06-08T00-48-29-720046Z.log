[tool-call] delta {"path":"tests/src/org.clojure/clojure/1.4.0/src/test/java/org_clojure/clojure/ClojureCoreInnerNon_private_methodsInnerFn__5358Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_clojure.clojure;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport clojure.lang.Compiler;\nimport clojure.lang.RT;\nimport clojure.lang.Var;\nimport java.io.StringReader;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class ClojureCoreInnerNon_private_methodsInnerFn__5358Test {\n    @TempDir\n    Path compilePath;\n\n    @Test\n    void genClassCollectsInheritedMethodsWhileEmittingClassFile() throws Exception {\n        boolean bindingsPushed = false;\n        try {\n            Var.pushThreadBindings(RT.map(\n                    Compiler.COMPILE_FILES,\n                    Boolean.TRUE,\n                    Compiler.COMPILE_PATH,\n                    compilePath.toString()));\n            bindingsPushed = true;\n\n            Compiler.load(new StringReader(\"\"\"\n                    (ns org-clojure.clojure.generated-sample)\n                    (gen-class\n                      :name org_clojure.clojure.GeneratedSample\n                      :methods [[sample [] String]]\n                      :load-impl-ns false)\n                    \"\"\"));\n\n            Path generatedClass = compilePath.resolve(\"org_clojure/clojure/GeneratedSample.class\");\n            assertThat(generatedClass).exists();\n            assertThat(Files.size(generatedClass)).isPositive();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            if (bindingsPushed) {\n                Var.popThreadBindings();\n            }\n        }\n    }\n}\n"}
