  public class ClojureCoreInnerGenerate_proxyInnerFn__5072InnerFn__5074Test {
      @Test
      void createsProxyClassForPublicBaseAndInterface() throws Exception {
          DynamicClassLoader loader = null;
          boolean bindingsPushed = false;
          try {
              loader = new DynamicClassLoader(getClass().getClassLoader());
              Var.pushThreadBindings(RT.map(
                      clojure.lang.Compiler.LOADER,
                      loader,
                      RT.CURRENT_NS,
