      private static void close(DynamicClassLoader loader) throws IOException {
          loader.close();
      }
  
      public interface ProxyMarker {
          String markerName();
      }
  
      public static class ProxyBase {
          public ProxyBase() {
          }
  
          public String publicName() {
              return "base";
          }
  
          protected int protectedValue() {
              return 42;
          }
      }
  }
