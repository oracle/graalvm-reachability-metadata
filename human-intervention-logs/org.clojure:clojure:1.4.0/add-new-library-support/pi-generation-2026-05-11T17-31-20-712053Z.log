  package org_clojure.clojure;
  
  import clojure.asm.ClassReader;
  import org.junit.jupiter.api.Test;
  
  import java.io.IOException;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassReaderTest {
      @Test
      void readsClassBytesFromSystemResourceByClassName() throws IOException {
          ClassReader reader = new ClassReader("clojure.lang.RT");
  
          assertThat(reader.getClassName()).isEqualTo("clojure/lang/RT");
          assertThat(reader.getSuperName()).isEqualTo("java/lang/Object");
      }
  }
