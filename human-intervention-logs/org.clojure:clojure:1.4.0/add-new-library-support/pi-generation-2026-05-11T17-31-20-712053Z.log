                        :exposes {inheritedState {:get getInheritedState :set setInheritedState}}
                        :load-impl-ns false)
                      """));
          } finally {
              Var.popThreadBindings();
          }
      }
  
      public static class FieldDeclaringParent {
          protected String inheritedState = "initial";
      }
  
      public static class FieldExposingBase extends FieldDeclaringParent {
      }
  }
