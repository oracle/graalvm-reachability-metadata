  package org_clojure.clojure;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import clojure.lang.Compiler;
  import clojure.lang.DynamicClassLoader;
  import clojure.lang.RT;
  import clojure.lang.Var;
  import java.io.IOException;
  import java.util.concurrent.Callable;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class CompilerInnerNewInstanceExprTest {
      @Test
      void reifyImplementsPublicInterfaces() throws Exception {
          DynamicClassLoader loader = null;
          boolean bindingsPushed = false;
          try {
              loader = new DynamicClassLoader(getClass().getClassLoader());
              Var.pushThreadBindings(RT.map(Compiler.LOADER, loader));
              bindingsPushed = true;
  
              Object instance = Compiler.eval(RT.readString("""
                      (reify
                        java.lang.Runnable
                        (run [this] nil)
                        java.util.concurrent.Callable
                        (call [this] "callable-result"))
                      """));
  
              assertThat(instance).isInstanceOf(Runnable.class).isInstanceOf(Callable.class);
              ((Runnable) instance).run();
              assertThat(((Callable<?>) instance).call()).isEqualTo("callable-result");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              if (bindingsPushed) {
                  Var.popThreadBindings();
              }
              if (loader != null) {
                  close(loader);
              }
          }
      }
  
      private static void close(DynamicClassLoader loader) throws IOException {
          loader.close();
      }
  }
