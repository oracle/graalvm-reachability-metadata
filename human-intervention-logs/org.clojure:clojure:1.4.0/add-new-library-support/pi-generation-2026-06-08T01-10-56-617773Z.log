  package org_clojure.clojure;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import clojure.lang.Compiler;
  import clojure.lang.RT;
  import clojure.lang.Var;
  import org.junit.jupiter.api.Test;
  
  public class CompilerInnerNewExprTest {
      @Test
      void evaluatesNewExpressionInDefInitializer() {
          Object form = RT.readString("(def compiler-new-expr-target (java.lang.StringBuilder. \"clojure\"))");
  
          Var var = (Var) Compiler.eval(form);
          Object value = var.deref();
  
          assertThat(value).isInstanceOf(StringBuilder.class).hasToString("clojure");
      }
  }
