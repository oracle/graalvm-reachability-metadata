  private static Expr analyzeSeq(C context, ISeq form, String name) {
  	Integer line = (Integer) LINE.deref();
  	if(RT.meta(form) != null && RT.meta(form).containsKey(RT.LINE_KEY))
  		line = (Integer) RT.meta(form).valAt(RT.LINE_KEY);
