  package org_clojure.clojure;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import clojure.lang.Reflector;
  import java.util.List;
  import org.junit.jupiter.api.Test;
  
  public class ReflectorTest {
      @Test
      void invokesConstructorsAndMethods() {
          SingleConstructorTarget single = (SingleConstructorTarget) Reflector.invokeConstructor(
                  SingleConstructorTarget.class, new Object[] {"single"});
          assertThat(single.value).isEqualTo("single");
  
          OverloadedConstructorTarget overloaded = (OverloadedConstructorTarget) Reflector.invokeConstructor(
                  OverloadedConstructorTarget.class, new Object[] {42});
          assertThat(overloaded.value).isEqualTo("integer:42");
  
          StringBuilder builder = (StringBuilder) Reflector.invokeConstructor(
                  StringBuilder.class, new Object[] {"clo"});
          Object appended = Reflector.invokeInstanceMethod(builder, "append", new Object[] {"jure"});
          assertThat(appended).isSameAs(builder);
          assertThat(builder.toString()).isEqualTo("clojure");
  
          Object joined = Reflector.invokeStaticMethod(
                  StaticMethodTarget.class, "combine", new Object[] {"o", "k"});
          assertThat(joined).isEqualTo("ok");
      }
  
      @Test
      void readsAndWritesPublicFields() {
          StaticFieldTarget.staticText = "before";
          assertThat(Reflector.getStaticField(StaticFieldTarget.class, "staticText")).isEqualTo("before");
          assertThat(Reflector.setStaticField(StaticFieldTarget.class, "staticText", "after"))
                  .isEqualTo("after");
          assertThat(StaticFieldTarget.staticText).isEqualTo("after");
  
          InstanceFieldTarget target = new InstanceFieldTarget();
