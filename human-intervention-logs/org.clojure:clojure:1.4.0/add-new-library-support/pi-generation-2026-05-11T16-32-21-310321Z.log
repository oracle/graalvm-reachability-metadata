[tool-call] delta {"path":"tests/src/org.clojure/clojure/1.4.0/src/test/java/org_clojure/clojure/ClojureCoreInnerGenerateProxyInnerFn5072InnerFn5074Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_clojure.clojure;\n\nimport clojure.lang.IFn;\nimport clojure.lang.RT;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClojureCoreInnerGenerateProxyInnerFn5072InnerFn5074Test {\n    @Test\n    void getProxyClassScansSuperclassDeclaredAndInheritedMethods() throws Exception {\n        try {\n            Class<?> proxyClass = generateProxyClass();\n\n            assertThat(ProxyBase.class.isAssignableFrom(proxyClass)).isTrue();\n            assertThat(ProxyMarker.class.isAssignableFrom(proxyClass)).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Class<?> generateProxyClass() throws Exception {\n        IFn getProxyClass = RT.var(\"clojure.core\", \"get-proxy-class\");\n        return (Class<?>) getProxyClass.invoke(ProxyBase.class, ProxyMarker.class);\n    }\n\n    public static class ProxyBase {\n        private final String prefix;\n\n        public ProxyBase() {\n            this(\"default\");\n        }\n\n        public ProxyBase(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String declaredGreeting(String name) {\n            return prefix + \":\" + name;\n        }\n    }\n\n    public interface ProxyMarker {\n        String markerValue();\n    }\n}\n"}
