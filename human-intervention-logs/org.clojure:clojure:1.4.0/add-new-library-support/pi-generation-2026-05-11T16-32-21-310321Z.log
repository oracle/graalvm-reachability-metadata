  			objx.constants = (PersistentVector) CONSTANTS.deref();
  			expr.emit(C.EXPRESSION, objx, gen);
  			expr.eval();
  			}
  		}
  	finally
  		{
  		Var.popThreadBindings();
  		}
  }
  
