  package org_clojure.clojure;
  
  import clojure.lang.ISeq;
  import clojure.lang.RT;
  import org.junit.jupiter.api.Test;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.URL;
  import java.nio.charset.StandardCharsets;
  import java.util.Arrays;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RTTest {
      private static final String RESOURCE_NAME = "org_clojure/clojure/rt-system-resource.txt";
  
      @Test
      void classForNameInitializesClassWithBaseLoader() {
          assertThat(RT.classForName("java.lang.String")).isSameAs(String.class);
      }
  
      @Test
      void seqToPassedArrayExpandsUndersizedTypedArray() {
          ISeq values = RT.seq(Arrays.asList("alpha", "beta", "gamma"));
          String[] passed = new String[1];
  
          Object[] expanded = RT.seqToPassedArray(values, passed);
  
          assertThat(expanded)
                  .isInstanceOf(String[].class)
                  .isNotSameAs(passed)
                  .containsExactly("alpha", "beta", "gamma");
      }
  
      @Test
      void seqToTypedArrayCreatesArrayWithRequestedComponentType() {
          ISeq values = RT.seq(Arrays.asList("delta", "epsilon"));
  
