  package org_clojure.clojure;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import clojure.asm.ClassWriter;
  import clojure.asm.Label;
  import clojure.asm.MethodVisitor;
  import clojure.asm.Opcodes;
  import org.junit.jupiter.api.Test;
  
  public class ClassWriterTest {
      @Test
      void computesCommonSuperClassWhileBuildingStackMapFrames() {
          ClassWriter classWriter = new ClassWriter(ClassWriter.COMPUTE_FRAMES);
          classWriter.visit(
                  Opcodes.V1_6,
                  Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,
                  "org_clojure/clojure/generated/MergedCollectionFactory",
                  null,
                  "java/lang/Object",
                  null);
  
          writeDefaultConstructor(classWriter);
          writeBranchingFactoryMethod(classWriter);
          classWriter.visitEnd();
  
          byte[] classBytes = classWriter.toByteArray();
          assertThat(classBytes).startsWith((byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE);
          assertThat(classBytes).hasSizeGreaterThan(0);
      }
  
      private static void writeDefaultConstructor(ClassWriter classWriter) {
          MethodVisitor constructor = classWriter.visitMethod(Opcodes.ACC_PUBLIC, "<init>", "()V", null, null);
          constructor.visitCode();
          constructor.visitVarInsn(Opcodes.ALOAD, 0);
          constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, "java/lang/Object", "<init>", "()V");
          constructor.visitInsn(Opcodes.RETURN);
          constructor.visitMaxs(0, 0);
          constructor.visitEnd();
      }
  
      private static void writeBranchingFactoryMethod(ClassWriter classWriter) {
          MethodVisitor method = classWriter.visitMethod(
                  Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,
                  "choose",
                  "(Z)Ljava/util/AbstractList;",
                  null,
                  null);
          Label elseBranch = new Label();
          Label mergePoint = new Label();
  
          method.visitCode();
          method.visitVarInsn(Opcodes.ILOAD, 0);
          method.visitJumpInsn(Opcodes.IFEQ, elseBranch);
          writeNewInstance(method, "java/util/ArrayList");
          method.visitVarInsn(Opcodes.ASTORE, 1);
          method.visitJumpInsn(Opcodes.GOTO, mergePoint);
          method.visitLabel(elseBranch);
          writeNewInstance(method, "java/util/LinkedList");
          method.visitVarInsn(Opcodes.ASTORE, 1);
          method.visitLabel(mergePoint);
          method.visitVarInsn(Opcodes.ALOAD, 1);
          method.visitInsn(Opcodes.ARETURN);
          method.visitMaxs(0, 0);
          method.visitEnd();
      }
  
      private static void writeNewInstance(MethodVisitor method, String internalName) {
          method.visitTypeInsn(Opcodes.NEW, internalName);
          method.visitInsn(Opcodes.DUP);
          method.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName, "<init>", "()V");
      }
  }
