  package org_clojure.clojure;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import clojure.lang.AFn;
  import clojure.lang.Compiler;
  import clojure.lang.FnLoaderThunk;
  import clojure.lang.Var;
  import org.junit.jupiter.api.Test;
  
  public class FnLoaderThunkTest extends AFn {
      @Test
      void loadsDeferredFunctionClassOnFirstInvocation() {
          Compiler.pushNSandLoader(FnLoaderThunkTest.class.getClassLoader());
          try {
              final Var var = Var.create();
              final FnLoaderThunk thunk = new FnLoaderThunk(var, FnLoaderThunkTest.class.getName());
  
              assertThat(thunk.invoke("value")).isEqualTo("loaded:value");
              assertThat(var.deref()).isInstanceOf(FnLoaderThunkTest.class);
          } finally {
              Var.popThreadBindings();
          }
      }
  
      @Override
      public Object invoke(Object arg1) {
          return "loaded:" + arg1;
      }
  }
