PassedArray(values, passed);\n\n        assertThat(expanded)\n                .isInstanceOf(String[].class)\n                .isNotSameAs(passed)\n                .containsExactly(\"alpha\", \"beta\", \"gamma\");\n    }\n\n    @Test\n    void seqToTypedArrayCreatesArrayWithRequestedComponentType() {\n        ISeq values = RT.seq(Arrays.asList(\"delta\", \"epsilon\"));\n\n        Object typedArray = RT.seqToTypedArray(String.class, values);\n\n        assertThat(typedArray)\n                .isInstanceOf(String[].class)\n                .isEqualTo(new String[] {\"delta\", \"epsilon\"});\n    }\n\n    @Test\n    void systemResourceLookupFindsResourceWhenLoaderIsNull() throws IOException {\n        URL url = RT.getResource(null, RESOURCE_NAME);\n        assertThat(url).isNotNull();\n\n        try (InputStream input = RT.resourceAsStream(null, RESOURCE_NAME)) {\n            assertThat(input).isNotNull();\n            assertThat(new String(input.readAllBytes(), StandardCharsets.UTF_8)).contains(\"RT system resource\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 430, "output": 1105, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 16895, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778516726572, "responseId": "resp_0a77fbc13b425dd7016a0202f6ee7c8194801f18246582a261"}}
