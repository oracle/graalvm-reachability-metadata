[tool-call] delta {"path":"tests/src/org.clojure/clojure/1.4.0/src/test/java/org_clojure/clojure/ClojureCoreInnerBeanInnerFn5177InnerFn5178Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_clojure.clojure;\n\nimport clojure.lang.ILookup;\nimport clojure.lang.Keyword;\nimport clojure.lang.RT;\nimport clojure.lang.Var;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClojureCoreInnerBeanInnerFn5177InnerFn5178Test {\n    @Test\n    void beanPropertyLookupInvokesJavaBeanReadMethod() {\n        BeanTarget target = new BeanTarget(\"clojure-bean-value\");\n        Var beanFunction = RT.var(\"clojure.core\", \"bean\");\n\n        ILookup beanMap = (ILookup) beanFunction.invoke(target);\n\n        assertThat(target.getReadCount()).isZero();\n        assertThat(beanMap.valAt(Keyword.intern(\"name\"))).isEqualTo(\"clojure-bean-value\");\n        assertThat(target.getReadCount()).isEqualTo(1);\n    }\n\n    public static final class BeanTarget {\n        private final String name;\n        private int readCount;\n\n        public BeanTarget(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            readCount++;\n            return name;\n        }\n\n        public int getReadCount() {\n            return readCount;\n        }\n    }\n}\n"}
