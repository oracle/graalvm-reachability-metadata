        (without [k] (dissoc (snapshot) k))
        (seq [] ((fn thisfn [plseq]
  		  (lazy-seq
                     (when-let [pseq (seq plseq)]
                       (cons (new clojure.lang.MapEntry (first pseq) (v (first pseq)))
                             (thisfn (rest pseq)))))) (keys pmap))))))
  
  
  
