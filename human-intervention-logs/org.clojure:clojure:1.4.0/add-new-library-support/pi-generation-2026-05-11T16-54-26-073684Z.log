t {\n    @Test\n    void findsCommonSuperclassByLoadingInternalClassNames() {\n        ExposedClassWriter writer = new ExposedClassWriter();\n\n        String commonSuperclass = writer.commonSuperClass(\"java/util/ArrayList\", \"java/util/LinkedList\");\n\n        assertThat(commonSuperclass).isEqualTo(\"java/util/AbstractList\");\n    }\n\n    @Test\n    void prefersAssignableTypeWhenComputingCommonSuperclass() {\n        ExposedClassWriter writer = new ExposedClassWriter();\n\n        String commonSuperclass = writer.commonSuperClass(\"java/lang/CharSequence\", \"java/lang/String\");\n\n        assertThat(commonSuperclass).isEqualTo(\"java/lang/CharSequence\");\n    }\n\n    private static final class ExposedClassWriter extends ClassWriter {\n        private ExposedClassWriter() {\n            super(0);\n        }\n\n        private String commonSuperClass(String type1, String type2) {\n            return getCommonSuperClass(type1, type2);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778518377394}, {"role": "toolResult", "toolCallId": "call_zuSunbYiX0XBHz5LYGPYBPuY|fc_03112c148500631b016a020968e980819d966cbd443113ba4d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_clojure.clojure;\n\nimport clojure.lang.ISeq;\nimport clojure.lang.RT;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Arrays;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RTTest {\n    private static final String RESOURCE_NAME = \"org_clojure/clojure/rt-system-resource.txt\";\n\n    @Test\n    void classForNameInitializesClassWithBaseLoader() {\n        assertThat(RT.classForName(\"java.lang.String\")).isSameAs(String.class);\n    }\n\n    @Test\n    void seqToPassedArrayExpandsUndersizedTypedArray() {\n        ISeq values = RT.seq(Arrays.asList(\"alpha\", \"beta\", \"gamma\"));\n        String[] passed = new String[1];\n\n        Object[] expanded = RT.seqToPassedArray(values, passed);\n\n        assertThat(expanded)\n                .isInstanceOf(String[].class)\n                .isNotSameAs(passed)\n                .containsExactly(\"alpha\", \"beta\", \"gamma\");\n    }\n\n    @Test\n    void seqToTypedArrayCreatesArrayWithRequestedComponentType() {\n        ISeq values = RT.seq(Arrays.asList(\"delta\", \"epsilon\"));\n\n        Object typedArray = RT.seqToTypedArray(String.class, values);\n\n        assertThat(typedArray).isInstanceOf(String[].class);\n        assertThat((String[]) typedArray).containsExactly(\"delta\", \"epsilon\");\n    }\n\n    @Test\n    void systemResourceLookupFindsResourceWhenLoaderIsNull() throws IOException {\n        URL url = RT.getResource(null, RESOURCE_NAME);\n        assertThat(url).isNotNull();\n\n        try (InputStream input = RT.resourceAsStream(null, RESOURCE_NAME)) {\n            assertThat(input).isNotNull();\n            assertThat(new String(input.readAllBytes(), StandardCharsets.UTF_8)).contains(\"RT system resource\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778518377394}, {"role": "toolResult", "toolCallId": "call_AtOu1xSsrMLdcDiuxE4A8oWG|fc_03112c148500631b016a020968e98c819d81aa83f83d3bbbbc", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.clojure:clojure:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.