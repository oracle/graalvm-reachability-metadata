  package org_clojure.clojure;
  
  import clojure.lang.ILookup;
  import clojure.lang.Keyword;
  import clojure.lang.RT;
  import clojure.lang.Var;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClojureCoreInnerBeanInnerFn5177InnerFn5178Test {
      @Test
      void beanPropertyLookupInvokesJavaBeanReadMethod() {
          BeanTarget target = new BeanTarget("clojure-bean-value");
          Var beanFunction = RT.var("clojure.core", "bean");
  
          ILookup beanMap = (ILookup) beanFunction.invoke(target);
  
          assertThat(target.getReadCount()).isZero();
          assertThat(beanMap.valAt(Keyword.intern("name"))).isEqualTo("clojure-bean-value");
          assertThat(target.getReadCount()).isEqualTo(1);
      }
  
      public static final class BeanTarget {
          private final String name;
          private int readCount;
  
          public BeanTarget(String name) {
              this.name = name;
          }
  
          public String getName() {
              readCount++;
              return name;
          }
  
          public int getReadCount() {
              return readCount;
          }
      }
  }
