      }
  
      @Test
      void convertsSequencesToTypedArrays() {
          ISeq oversizedSequence = RT.seq(Arrays.asList("alpha", "beta"));
          Object[] grown = RT.seqToPassedArray(oversizedSequence, new String[0]);
          assertThat(grown)
                  .isInstanceOf(String[].class)
                  .containsExactly("alpha", "beta");
  
          ISeq typedSequence = RT.seq(Arrays.asList("left", "right"));
          Object typed = RT.seqToTypedArray(String.class, typedSequence);
          assertThat(typed).isInstanceOf(String[].class);
          assertThat((String[]) typed).containsExactly("left", "right");
      }
  
      @Test
      void resolvesResourcesFromSystemClassLoaderWhenNoLoaderIsProvided() throws Exception {
          URL resource = RT.getResource(null, "clojure/core.clj");
          assertThat(resource).isNotNull();
  
          try (InputStream stream = RT.resourceAsStream(null, "clojure/core.clj")) {
              assertThat(stream).isNotNull();
              assertThat(stream.read()).isNotEqualTo(-1);
          }
      }
  }
