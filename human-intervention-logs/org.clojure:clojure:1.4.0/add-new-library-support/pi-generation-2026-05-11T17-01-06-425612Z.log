  package org_clojure.clojure;
  
  import clojure.lang.AFn;
  import clojure.lang.FnLoaderThunk;
  import clojure.lang.RT;
  import clojure.lang.Var;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FnLoaderThunkTest {
      @Test
      void loadsFunctionClassWithBoundFunctionLoaderBeforeInvoking() {
          Var target = Var.create();
  
          Var.pushThreadBindings(RT.map(
                  RT.var("clojure.core", "*fn-loader*"), FnLoaderThunkTest.class.getClassLoader()));
          try {
              FnLoaderThunk thunk = new FnLoaderThunk(target, LoadedFunction.class.getName());
  
              assertThat(thunk.invoke("value")).isEqualTo("loaded:value");
              assertThat(target.getRawRoot()).isInstanceOf(LoadedFunction.class);
          } finally {
              Var.popThreadBindings();
          }
      }
  
      public static class LoadedFunction extends AFn {
          @Override
          public Object invoke(Object arg1) {
              return "loaded:" + arg1;
          }
