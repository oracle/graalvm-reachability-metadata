  private static Symbol tagOf(Object o){
  	Object tag = RT.get(RT.meta(o), RT.TAG_KEY);
  	if(tag instanceof Symbol)
  		return (Symbol) tag;
  	else if(tag instanceof String)
  		return Symbol.intern(null, (String) tag);
  	return null;
  }
  
