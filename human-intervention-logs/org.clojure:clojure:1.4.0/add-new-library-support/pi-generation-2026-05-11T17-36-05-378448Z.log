  package org_clojure.clojure;
  
  import clojure.lang.Compiler;
  import clojure.lang.Var;
  import org.junit.jupiter.api.Test;
  
  import java.io.StringReader;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CompilerInnerNewExprTest {
      @Test
      void evaluatesNewExpressionUsingResolvedPublicConstructor() {
          Var var = (Var) Compiler.load(new StringReader("""
                  (def compiler-new-expr-value
                    (new java.lang.StringBuilder "covered"))
                  """));
  
          Object value = var.deref();
  
          assertThat(value).isInstanceOf(StringBuilder.class);
          assertThat(value.toString()).isEqualTo("covered");
      }
  }
