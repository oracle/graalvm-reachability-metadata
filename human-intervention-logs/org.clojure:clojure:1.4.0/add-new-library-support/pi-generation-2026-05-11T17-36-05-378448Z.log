  package org_clojure.clojure;
  
  import clojure.lang.Compiler;
  import clojure.lang.Var;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import java.io.StringReader;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CompilerInnerNewInstanceExprTest {
      @Test
      void reifyScansObjectAndInterfaceMethodsBeforeGeneratingClass() {
          try {
              Var var = (Var) Compiler.load(new StringReader("""
                      (def compiler-new-instance-expr-runnable
                        (reify java.lang.Runnable
                          (run [this]
                            nil)))
                      """));
  
              Object value = var.deref();
  
              assertThat(value).isInstanceOf(Runnable.class);
              ((Runnable) value).run();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
