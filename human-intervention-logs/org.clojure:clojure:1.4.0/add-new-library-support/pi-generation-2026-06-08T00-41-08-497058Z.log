  // int ALOAD_0 = 42; // -
  // int ALOAD_1 = 43; // -
  // int ALOAD_2 = 44; // -
  // int ALOAD_3 = 45; // -
  int IALOAD = 46; // visitInsn
  int LALOAD = 47; // -
  int FALOAD = 48; // -
  int DALOAD = 49; // -
  int AALOAD = 50; // -
  int BALOAD = 51; // -
  int CALOAD = 52; // -
  int SALOAD = 53; // -
  int ISTORE = 54; // visitVarInsn
  int LSTORE = 55; // -
  int FSTORE = 56; // -
  int DSTORE = 57; // -
  int ASTORE = 58; // -
  // int ISTORE_0 = 59; // -
  // int ISTORE_1 = 60; // -
  // int ISTORE_2 = 61; // -
