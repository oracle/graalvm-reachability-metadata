  package org_clojure.clojure;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import clojure.lang.Reflector;
  import java.util.List;
  import org.junit.jupiter.api.Test;
  
  public class ReflectorTest {
      @Test
      void invokesConstructorsAndMethods() {
          SingleConstructorTarget single = (SingleConstructorTarget) Reflector.invokeConstructor(
                  SingleConstructorTarget.class, new Object[] {"single"});
          assertThat(single.value).isEqualTo("single");
  
          OverloadedConstructorTarget overloaded = (OverloadedConstructorTarget) Reflector.invokeConstructor(
                  OverloadedConstructorTarget.class, new Object[] {42});
          assertThat(overloaded.value).isEqualTo("integer:42");
  
          StringBuilder builder = (StringBuilder) Reflector.invokeConstructor(
                  StringBuilder.class, new Object[] {"clo"});
          Object appended = Reflector.invokeInstanceMethod(builder, "append", new Object[] {"jure"});
          assertThat(appended).isSameAs(builder);
          assertThat(builder.toString()).isEqualTo("clojure");
  
          Object joined = Reflector.invokeStaticMethod(
                  StaticMethodTarget.class, "combine", new Object[] {"o", "k"});
          assertThat(joined).isEqualTo("ok");
      }
  
      @Test
      void readsAndWritesPublicFields() {
          StaticFieldTarget.staticText = "before";
          assertThat(Reflector.getStaticField(StaticFieldTarget.class, "staticText")).isEqualTo("before");
          assertThat(Reflector.setStaticField(StaticFieldTarget.class, "staticText", "after"))
                  .isEqualTo("after");
          assertThat(StaticFieldTarget.staticText).isEqualTo("after");
  
          InstanceFieldTarget target = new InstanceFieldTarget();
          assertThat(Reflector.getInstanceField(target, "text")).isEqualTo("initial");
          assertThat(Reflector.setInstanceField(target, "text", "changed")).isEqualTo("changed");
          assertThat(target.text).isEqualTo("changed");
  
          assertThat(Reflector.invokeInstanceMember(target, "text")).isEqualTo("changed");
          assertThat(Reflector.invokeInstanceMember("text", target, "member-set")).isEqualTo("member-set");
          assertThat(target.text).isEqualTo("member-set");
      }
  
      @Test
      void resolvesPublicInterfaceAndBaseMethodsFromNonPublicImplementations() {
          Greeter interfaceGreeter = new HiddenInterfaceGreeter();
          assertThat(Reflector.invokeInstanceMethod(interfaceGreeter, "greet", new Object[] {"Ada"}))
                  .isEqualTo("hello Ada");
  
          PublicBaseGreeter baseGreeter = new HiddenBaseGreeter();
          assertThat(Reflector.invokeInstanceMethod(baseGreeter, "greet", new Object[] {"Grace"}))
                  .isEqualTo("hi Grace");
      }
  
      @Test
      void enumeratesObjectMethodsForInterfaces() {
          List<?> methods = Reflector.getMethods(Runnable.class, 0, "toString", false);
          assertThat(methods).isNotEmpty();
      }
  
      public static final class SingleConstructorTarget {
          public final String value;
  
          public SingleConstructorTarget(String value) {
              this.value = value;
          }
      }
  
      public static final class OverloadedConstructorTarget {
          public final String value;
  
          public OverloadedConstructorTarget(String value) {
              this.value = "string:" + value;
          }
  
          public OverloadedConstructorTarget(Integer value) {
              this.value = "integer:" + value;
          }
      }
  
      public static final class StaticFieldTarget {
          public static String staticText = "before";
  
          private StaticFieldTarget() {
          }
      }
  
      public static final class StaticMethodTarget {
          private StaticMethodTarget() {
          }
  
          public static String combine(String left, String right) {
              return left + right;
          }
      }
  
      public static final class InstanceFieldTarget {
          public String text = "initial";
      }
  
      public interface Greeter {
          String greet(String name);
      }
  
      private static final class HiddenInterfaceGreeter implements Greeter {
          @Override
          public String greet(String name) {
              return "hello " + name;
          }
      }
  
      public static class PublicBaseGreeter {
          public String greet(String name) {
              return "base " + name;
          }
      }
  
      private static final class HiddenBaseGreeter extends PublicBaseGreeter {
          @Override
          public String greet(String name) {
              return "hi " + name;
          }
      }
  }
