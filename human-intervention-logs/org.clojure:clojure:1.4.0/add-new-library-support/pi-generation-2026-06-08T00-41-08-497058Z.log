[tool-call] delta {"path":"tests/src/org.clojure/clojure/1.4.0/src/test/java/org_clojure/clojure/ClassWriterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_clojure.clojure;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport clojure.asm.ClassWriter;\nimport clojure.asm.Label;\nimport clojure.asm.MethodVisitor;\nimport clojure.asm.Opcodes;\nimport org.junit.jupiter.api.Test;\n\npublic class ClassWriterTest {\n    @Test\n    void computesCommonSuperClassWhileBuildingStackMapFrames() {\n        ClassWriter classWriter = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        classWriter.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                \"org_clojure/clojure/generated/MergedCollectionFactory\",\n                null,\n                \"java/lang/Object\",\n                null);\n\n        writeDefaultConstructor(classWriter);\n        writeBranchingFactoryMethod(classWriter);\n        classWriter.visitEnd();\n\n        byte[] classBytes = classWriter.toByteArray();\n        assertThat(classBytes).startsWith((byte) 0xCA, (byte) 0xFE, (byte) 0xBA, (byte) 0xBE);\n        assertThat(classBytes).hasSizeGreaterThan(0);\n    }\n\n    private static void writeDefaultConstructor(ClassWriter classWriter) {\n        MethodVisitor constructor = classWriter.visitMethod(Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(0, 0);\n        constructor.visitEnd();\n    }\n\n    private static void writeBranchingFactoryMethod(ClassWriter classWriter) {\n        MethodVisitor method = classWriter.visitMethod(\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,\n                \"choose\",\n                \"(Z)Ljava/util/AbstractList;\",\n                null,\n                null);\n        Label elseBranch = new Label();\n        Label mergePoint = new Label();\n\n        method.visitCode();\n        method.visitVarInsn(Opcodes.ILOAD, 0);\n        method.visitJumpInsn(Opcodes.IFEQ, elseBranch);\n        writeNewInstance(method, \"java/util/ArrayList\");\n        method.visitVarInsn(Opcodes.ASTORE, 1);\n        method.visitJumpInsn(Opcodes.GOTO, mergePoint);\n        method.visitLabel(elseBranch);\n        writeNewInstance(method, \"java/util/LinkedList\");\n        method.visitVarInsn(Opcodes.ASTORE, 1);\n        method.visitLabel(mergePoint);\n        method.visitVarInsn(Opcodes.ALOAD, 1);\n        method.visitInsn(Opcodes.ARETURN);\n        method.visitMaxs(0, 0);\n        method.visitEnd();\n    }\n\n    private static void writeNewInstance(MethodVisitor method, String internalName) {\n        method.visitTypeInsn(Opcodes.NEW, internalName);\n        method.visitInsn(Opcodes.DUP);\n        method.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName, \"<init>\", \"()V\");\n    }\n}\n"}
