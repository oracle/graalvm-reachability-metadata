   *                    of this class. See {@link #COMPUTE_MAXS}, {@link #COMPUTE_FRAMES}.
   */
  public ClassWriter(final ClassReader classReader, final int flags){
  	this(flags);
  	classReader.copyPool(this);
  	this.cr = classReader;
  }
  
