  package org_clojure.clojure;
  
  import clojure.lang.Reflector;
  import org.junit.jupiter.api.Test;
  
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectorTest {
      @Test
      void invokesSingleAndOverloadedConstructors() {
          Object single = Reflector.invokeConstructor(SingleConstructorTarget.class, new Object[] {"alpha"});
          assertThat(single).isInstanceOf(SingleConstructorTarget.class);
          assertThat(((SingleConstructorTarget) single).value).isEqualTo("alpha");
  
          Object overloaded = Reflector.invokeConstructor(OverloadedConstructorTarget.class, new Object[] {"beta"});
          assertThat(overloaded).isInstanceOf(OverloadedConstructorTarget.class);
          assertThat(((OverloadedConstructorTarget) overloaded).value).isEqualTo("string:beta");
      }
  
      @Test
      void getsAndSetsStaticAndInstanceFields() {
          FieldTarget.staticText = "initial";
          FieldTarget target = new FieldTarget();
          target.count = 7;
  
          assertThat(Reflector.getStaticField(FieldTarget.class, "staticText")).isEqualTo("initial");
          assertThat(Reflector.setStaticField(FieldTarget.class, "staticText", "updated")).isEqualTo("updated");
          assertThat(FieldTarget.staticText).isEqualTo("updated");
  
          assertThat(Reflector.getInstanceField(target, "count")).isEqualTo(7);
          assertThat(Reflector.setInstanceField(target, "count", 11)).isEqualTo(11);
          assertThat(target.count).isEqualTo(11);
      }
  
      @Test
      void invokesInstanceMemberFieldAccessors() {
          FieldTarget target = new FieldTarget();
          target.name = "before";
  
          assertThat(Reflector.invokeInstanceMember(target, "name")).isEqualTo("before");
          assertThat(Reflector.invokeInstanceMember("name", target, "after")).isEqualTo("after");
          assertThat(target.name).isEqualTo("after");
      }
  
      @Test
      void invokesMatchingInstanceStaticAndBridgeMethods() {
          MethodTarget target = new MethodTarget("prefix");
  
          assertThat(Reflector.invokeInstanceMethod(target, "join", new Object[] {"value"}))
