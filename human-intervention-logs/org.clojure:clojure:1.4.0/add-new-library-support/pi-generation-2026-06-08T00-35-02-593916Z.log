icField(StaticFieldTarget.class, \"staticText\", \"after\"))\n                .isEqualTo(\"after\");\n        assertThat(StaticFieldTarget.staticText).isEqualTo(\"after\");\n\n        InstanceFieldTarget target = new InstanceFieldTarget();\n        assertThat(Reflector.getInstanceField(target, \"text\")).isEqualTo(\"initial\");\n        assertThat(Reflector.setInstanceField(target, \"text\", \"changed\")).isEqualTo(\"changed\");\n        assertThat(target.text).isEqualTo(\"changed\");\n\n        assertThat(Reflector.invokeInstanceMember(target, \"text\")).isEqualTo(\"changed\");\n        assertThat(Reflector.invokeInstanceMember(\"text\", target, \"member-set\")).isEqualTo(\"member-set\");\n        assertThat(target.text).isEqualTo(\"member-set\");\n    }\n\n    @Test\n    void resolvesPublicInterfaceAndBaseMethodsFromNonPublicImplementations() {\n        Greeter interfaceGreeter = new HiddenInterfaceGreeter();\n        assertThat(Reflector.invokeInstanceMethod(interfaceGreeter, \"greet\", new Object[] {\"Ada\"}))\n                .isEqualTo(\"hello Ada\");\n\n        PublicBaseGreeter baseGreeter = new HiddenBaseGreeter();\n        assertThat(Reflector.invokeInstanceMethod(baseGreeter, \"greet\", new Object[] {\"Grace\"}))\n                .isEqualTo(\"hi Grace\");\n    }\n\n    @Test\n    void enumeratesObjectMethodsForInterfaces() {\n        List methods = Reflector.getMethods(Runnable.class, 0, \"toString\", false);\n        assertThat(methods).isNotEmpty();\n    }\n\n    public static final class SingleConstructorTarget {\n        public final String value;\n\n        public SingleConstructorTarget(String value) {\n            this.value = value;\n        }\n    }\n\n    public static final class OverloadedConstructorTarget {\n        public final String value;\n\n        public OverloadedConstructorTarget(String value) {\n            this.value = \"string:\" + value;\n        }\n\n        public OverloadedConstructorTarget(Integer value) {\n            this.value = \"integer:\" + value;\n        }\n    }\n\n    public static final class StaticFieldTarget {\n        public static String staticText = \"before\";\n\n        private StaticFieldTarget() {\n        }\n    }\n\n    public static final class InstanceFieldTarget {\n        public String text = \"initial\";\n    }\n\n    public interface Greeter {\n        String greet(String name);\n    }\n\n    private static final class HiddenInterfaceGreeter implements Greeter {\n        @Override\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    public static class PublicBaseGreeter {\n        public String greet(String name) {\n            return \"base \" + name;\n        }\n    }\n\n    private static final class HiddenBaseGreeter extends PublicBaseGreeter {\n        @Override\n        public String greet(String name) {\n            return \"hi \" + name;\n        }\n    }\n}\n"}
