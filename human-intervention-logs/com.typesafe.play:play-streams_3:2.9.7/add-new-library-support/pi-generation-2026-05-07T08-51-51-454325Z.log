              case other             => flowActor ! other
            }
  
            override def supervisorStrategy: SupervisorStrategy = OneForOneStrategy() {
              case _ => SupervisorStrategy.Stop
            }
          })),
          Status.Success(())
        ),
        Source.fromPublisher(publisher)
      )
    }
  }
