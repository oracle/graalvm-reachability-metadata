oot-persistence/4.0.2/gradle.properties\n./tests/src/org.springframework.boot/spring-boot-persistence/4.0.2/user-code-filter.json\n./stats/org.springframework.boot/spring-boot-persistence/4.0.2/execution-metrics.json\n","exit_code":0,"status":"completed"}}
