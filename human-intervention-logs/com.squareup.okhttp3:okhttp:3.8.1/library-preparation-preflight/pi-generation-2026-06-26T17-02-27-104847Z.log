    public static void closeQuietly(ServerSocket serverSocket) {
      if (serverSocket != null) {
        try {
          serverSocket.close();
        } catch (RuntimeException rethrown) {
          throw rethrown;
        } catch (Exception ignored) {
        }
      }
    }
  
    /**
