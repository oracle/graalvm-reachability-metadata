reup.okhttp3/logging-interceptor/index.json:9:    \"description\" : \"OkHttp Logging Interceptor is an OkHttp interceptor that logs HTTP request and response data. It supports configurable log levels, custom log sinks, and header redaction so clients can inspect HTTP traffic during development or controlled debugging.\",\nmetadata/com.squareup.okhttp3/logging-interceptor/index.json:28:      \"okhttp3.logging\"\nmetadata/io.ktor/ktor-client-okhttp-jvm/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/ktor/ktor-client-okhttp-jvm/$version$/ktor-client-okhttp-jvm-$version$-sources.jar\",\nmetadata/io.ktor/ktor-client-okhttp-jvm/index.json:7:    \"test-code-url\" : \"https://github.com/ktorio/ktor/tree/$version$/ktor-client/ktor-client-okhttp/jvm/test\",\nmetadata/io.ktor/ktor-client-okhttp-jvm/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/ktor/ktor-client-okhttp-jvm/$version$/ktor-client-okhttp-jvm-$version$-javadoc.jar\",\nmetadata/io.ktor/ktor-client-okhttp-jvm/index.json:9:    \"description\" : \"Ktor Client OkHttp is the JVM engine adapter that lets Ktor's HTTP client run on Square's OkHttp implementation. It provides the OkHttp-backed engine, configuration hooks, and WebSocket/streaming support used by Kotlin JVM applications that choose OkHttp as their Ktor client transport.\",\nmetadata/io.ktor/ktor-client-okhttp-jvm/index.json:19:      \"io.ktor.client.engine.okhttp\"\nmetadata/io.ktor/ktor-client-core-jvm/index.json:9:    \"description\" : \"Ktor Client Core JVM is the JVM artifact for Ktor's asynchronous HTTP client API, providing request builders, response handling, plugins, cookies, caching, redirects, timeouts, SSE, and WebSocket support. It supplies the shared client pipeline and JVM integrations used by Kotlin applications together with a concrete Ktor client engine such as CIO, Java, OkHttp, or Apache.\",\nmetadata/com.diffplug.spotless/spotless-lib-extra/2.45.0/reachability-metadata.json:157:      \"type\" : \"okhttp3.CipherSuite[]\"\nmetadata/com.diffplug.spotless/spotless-lib-extra/2.45.0/reachability-metadata.json:163:      \"type\" : \"okhttp3.ConnectionSpec[]\"\nmetadata/com.diffplug.spotless/spotless-lib-extra/2.45.0/reachability-metadata.json:169:      \"type\" : \"okhttp3.Protocol[]\"\nmetadata/com.diffplug.spotless/spotless-lib-extra/3.0.0/reachability-metadata.json:164:      \"type\" : \"okhttp3.CipherSuite[]\"\nmetadata/com.diffplug.spotless/spotless-lib-extra/3.0.0/reachability-metadata.json:170:      \"type\" : \"okhttp3.ConnectionSpec[]\"\nmetadata/com.diffplug.spotless/spotless-lib-extra/3.0.0/reachability-metadata.json:176:      \"type\" : \"okhttp3.Protocol[]\"\nmetadata/com.diffplug.spotless/spotless-lib-extra/3.0.0/reachability-metadata.json:182:      \"type\" : \"okhttp3.internal.cache.DiskLruCache$Entry[]\"\nmetadata/com.squareup.retrofit2/retrofit/index.json:9:    \"description\" : \"Retrofit is a type-safe HTTP client for Java and Android that turns annotated interfaces into network API clients. It integrates with OkHttp and pluggable converters/adapters to execute requests and marshal request and response bodies.\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/zipkin/reporter2/zipkin-sender-okhttp3/$version$/zipkin-sender-okhttp3-$version$-sources.jar\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:7:    \"test-code-url\" : \"https://github.com/openzipkin/zipkin-reporter-java/tree/$version$/okhttp3/src/test/java\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/io/zipkin/reporter2/zipkin-sender-okhttp3/$version$/zipkin-sender-okhttp3-$version$-javadoc.jar\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:9:    \"description\" : \"Zipkin Sender OkHttp 3 sends encoded spans to a Zipkin collector over HTTP using OkHttp 3. It implements