om.squareup.retrofit2/retrofit/index.json:9:    \"description\" : \"Retrofit is a type-safe HTTP client for Java and Android that turns annotated interfaces into network API clients. It integrates with OkHttp and pluggable converters/adapters to execute requests and marshal request and response bodies.\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/zipkin/reporter2/zipkin-sender-okhttp3/$version$/zipkin-sender-okhttp3-$version$-sources.jar\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:7:    \"test-code-url\" : \"https://github.com/openzipkin/zipkin-reporter-java/tree/$version$/okhttp3/src/test/java\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/io/zipkin/reporter2/zipkin-sender-okhttp3/$version$/zipkin-sender-okhttp3-$version$-javadoc.jar\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:9:    \"description\" : \"Zipkin Sender OkHttp 3 sends encoded spans to a Zipkin collector over HTTP using OkHttp 3. It implements the Zipkin Reporter sender interface for asynchronous span delivery and integrates with the core zipkin-reporter buffering and metrics APIs.\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:20:      \"zipkin2.reporter.okhttp3\"\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:25:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/zipkin/reporter2/zipkin-sender-okhttp3/$version$/zipkin-sender-okhttp3-$version$-sources.jar\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:27:    \"test-code-url\" : \"https://github.com/openzipkin/zipkin-reporter-java/tree/$version$/okhttp3/src/test/java\",\nmetadata/io.zipkin.reporter2/zipkin-sender-okhttp3/index.json:28:    \"documentation-url\" : \"https://repo1.maven.org/maven2/io/zipkin/reporter2/zipkin-sender-okhttp3/$version$/zipkin-sender-okhttp3-$version$-javado