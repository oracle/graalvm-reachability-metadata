                  .put(OtelAttributes.OTEL_SCOPE_VERSION, "1.0.0")
                  .put(OtelAttributes.OTEL_STATUS_CODE, OtelStatusCodeValues.ERROR)
                  .put(OtelAttributes.OTEL_STATUS_DESCRIPTION, "request failed")
