  io/opentelemetry/api/incubator/config/DeclarativeConfigException.java
  io/opentelemetry/api/incubator/config/DeclarativeConfigProperties.java
  io/opentelemetry/api/incubator/config/DeclarativeConfigPropertyUtil.java
