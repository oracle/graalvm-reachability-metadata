  	 */
  	public void reset() {
  		this.expectationManager.reset();
  	}
  
  
  	/**
  	 * Return a builder for a {@code MockRestServiceServer} that should be used
  	 * to reply to the {@code RestClient} for the given {@code RestClient.Builder}.
  	 * @since 6.1
