NSTANCE;\n\n        @Override\n        public Iterable<String> keys(Map<String, String> carrier) {\n            return carrier.keySet();\n        }\n\n        @Override\n        public String get(Map<String, String> carrier, String key) {\n            return carrier.get(key);\n        }\n    }\n}\n"}
