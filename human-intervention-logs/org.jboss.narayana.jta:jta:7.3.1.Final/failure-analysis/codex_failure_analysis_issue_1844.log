es/1844-345f4fb6/tests/src/org.jboss.narayana.jta/jta/7.3.1.Final/build/native/generated/generateTestResourcesConfigFile,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.opentest4j/opentest4j/1.2.0,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.junit.platform/junit-platform-commons/1.8.2,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.junit.platform/junit-platform-engine/1.10.4,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.junit.platform/junit-platform-launcher/1.9.2,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.hamcrest/hamcrest-core/1.3,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.jboss.narayana.jta/jta/7.3.1.Final,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/jakarta.annotation/jakarta.annotation-api/2.0.0,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.jboss.logging/jboss-logging/3.5.0.Final,/home/vjovanov/c/forge/forge9/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1844-345f4fb6/metadata/org.jboss.spec.javax.transaction/jboss-transaction-api_1.2_spec/1.1.1.Final \\\\\\n  -H:Optimize@user+api=b \\\\\\n  -H:+ReportExceptionStackTraces@user \\\\\\n  -H:Features@user+api=org.graalvm.junit.platform.JUnitPlatformFeature \\\\\\n  '-H:Class@explicit main-class=org.graalvm.junit.platform.NativeImageJUnitLauncher' \\\\\\n  -H:ImageBuildID@driver=187255f6-312d-d8c0-2c4a-8c72b7d333f6 \\\\\\n  '-H:Features@jar:file:/