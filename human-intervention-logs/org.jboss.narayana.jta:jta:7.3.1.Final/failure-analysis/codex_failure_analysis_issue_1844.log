Id>\\n  <packaging>jar</packaging>\\n  <name>Narayana: ArjunaJTA jta</name>\\n  <description>Narayana: ArjunaJTA jta</description>\\n\\n  <properties>\\n    <byteman.agent.support>-Djboss.modules.system.pkgs=com.sun.tools.attach,org.jboss.byteman -Djdk.attach.allowAttachSelf=true</byteman.agent.support>\\n    <checkstyle.skip>true</checkstyle.skip>\\n    <!-- java.net.preferIPv6Addresses=false is a workaround to (not) solve the bug in arquillian-extension-byteman -->\\n    <ipv6.server.jvm.args>-Djboss.bind.address=[::1] -Djboss.bind.address.management=[::1]\\n      -Djboss.bind.address.unsecure=[::1] -Djava.net.preferIPv4Stack=false -Djava.net.preferIPv6Addresses=false</ipv6.server.jvm.args>\\n    <!-- required for VM attach under JDK 11-->\\n    <surefire.argline>-Djdk.attach.allowAttachSelf=true</surefire.argline>\\n  </properties>\\n\\n  <dependencyManagement>\\n    <dependencies>\\n      <dependency>\\n        <groupId>org.jboss.narayana</groupId>\\n        <artifactId>test-dependency-management</artifactId>\\n        <version>${project.version}</version>\\n        <type>pom</type>\\n        <scope>import</scope>\\n      </dependency>\\n    </dependencies>\\n  </dependencyManagement>\\n  <dependencies>\\n    <!-- JTA (local: ArjunaJTA/jta and remote: ArjunaJTS/jtax) needs:\\n     * Jakarta Transaction API (jakarta.transaction-api)\\n     * Jakarta Connectors (for tx inflow) API (jakarta.resource-api) -->\\n    <dependency>\\n      <groupId>jakarta.transaction</groupId>\\n      <artifactId>jakarta.transaction-api</artifactId>\\n    </dependency>\\n    <dependency>\\n      <groupId>jakarta.resource</groupId>\\n      <artifactId>jakarta.resource-api</artifactId>\\n    </dependency>\\n    <dependency>\\n      <groupId>jakarta.interceptor</groupId>\\n      <artifactId>jakarta.interceptor-api</artifactId>\\n      <scope>provided</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>jakarta.inject</groupId>\\n      <artifactId>jakarta.inject-api</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.jboss</groupId>\\n      <artifactId>jboss-transaction-spi</artifactId>\\n      <scope>provided</scope>\\n      <exclusions>\\n        <exclusion>\\n          <groupId>org.jboss.logging</groupId>\\n          <artifactId>jboss-logging-spi</artifactId>\\n        </exclusion>\\n      </exclusions>\\n    </dependency>\\n\\n    <dependency>\\n      <groupId>org.jboss.narayana</groupId>\\n      <artifactId>common</artifactId>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.jboss.narayana.arjunacore</groupId>\\n      <artifactId>arjuna</artifactId>\\n    </dependency>\\n    <!--JUnit Jupiter Engine to depend on the JUnit5 engine and JUnit 5 API -->\\n    <dependency>\\n      <groupId>org.junit.jupiter</groupId>\\n      <artifactId>junit-jupiter-engine</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <!--JUnit Jupiter Engine to depend on the JUnit4 engine and JUnit 4 API  -->\\n    <dependency>\\n      <groupId>org.junit.vintage</groupId>\\n      <artifactId>junit-vintage-engine</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.jboss.byteman</groupId>\\n      <artifactId>byteman</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.jboss.byteman</groupId>\\n      <artifactId>byteman-install</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.jboss.byteman</groupId>\\n      <artifactId>byteman-submit</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.jboss.byteman</groupId>\\n      <artifactId>byteman-bmunit</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.jboss.byteman</groupId>\\n      <artifactId>byteman-bmunit5</artifactId>\\n      <scope>test</scope>\\n    </dependency>\\n    <dependency>\\n      <groupId>org.