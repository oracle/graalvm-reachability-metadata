anov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/src/main/resources/scaffold/Test.kt.template\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/src/main/resources/scaffold/settings.gradle.template\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/src/main/resources/scaffold/build.gradle.scala3.template\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/src/main/resources/scaffold/build.gradle.scala2.template\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/src/main/resources/scaffold/build.gradle.kotlin.template\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/src/main/resources/scaffold/Test.java.template\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/docs/CONTRIBUTING.md\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/skills/ipr/SKILL.md\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/skills/review-library-update-request/SKILL.md\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/scripts/spring-aot-impact-scan.gradle\\n/home/vjovanov/c/forge/forge10/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5308-8ee44aed/tests/tck-build-logic/src/main/resources/allowed-docker-images/Dockerfile-greenmail_standalone\\n/home/vjovanov/c/forge