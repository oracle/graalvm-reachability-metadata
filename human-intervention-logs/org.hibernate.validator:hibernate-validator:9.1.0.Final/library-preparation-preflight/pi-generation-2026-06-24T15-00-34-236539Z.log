[assistant]       "reason": "Required EL implementation for Hibernate Validator's default message interpolation in Java SE tests; Hibernate Validator 9.1.0.Final does not bring an EL implementation transitively."
[assistant]     }
[assistant]   ],
[assistant]   "agent_guidance": "No environment variables or system properties are needed. Generated tests should exercise the standard Jakarta Validation bootstrap/default ValidatorFactory path and should not switch to ParameterMessageInterpolator, since that bypasses the specification-compliant EL interpolation path.",
[assistant]   "risks": [
