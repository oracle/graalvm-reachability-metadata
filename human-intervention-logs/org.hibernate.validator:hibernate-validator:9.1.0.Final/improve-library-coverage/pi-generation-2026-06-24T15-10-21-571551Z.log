  		try {
  			ExpressionFactory.newInstance();
  			return true;
  		}
  		catch (Throwable e) {
  			LOG.debugv( e, "Failed to load expression factory via classloader {0}", GetClassLoader.fromContext() );
  			return false;
  		}
  	}
  }
