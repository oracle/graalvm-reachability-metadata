  					return ( (Class<?>) loadClass.invoke( bundle, "com.sun.el.ExpressionFactoryImpl" ) ).getClassLoader();
  				}
  				catch (Exception e) {
  					//
  				}
  			}
  		}
  		return null;
  	}
  
