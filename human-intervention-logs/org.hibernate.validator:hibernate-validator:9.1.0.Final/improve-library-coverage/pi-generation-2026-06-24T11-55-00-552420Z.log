deNameProvider\");\n    }\n\n    @Test\n    void loadsUserClassFromConfiguredExternalClassLoader() {\n        ClassLoader externalClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try (ValidatorFactory validatorFactory = configuration()\n                .externalClassLoader(externalClassLoader)\n                .addProperty(PROPERTY_NODE_NAME_PROVIDER, ExternalClassLoaderPropertyNodeNameProvider.class.getName())\n                .buildValidatorFactory()) {\n            assertThat(validatorFactory.getValidator()).isNotNull();\n        }\n    }\n\n    @Test\n    void loadsUserClassFromThreadContextClassLoader() {\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        try (ValidatorFactory validatorFactory = propertyNodeNameProviderFactory(\n                ThreadContextClassLoaderPropertyNodeNameProvider.class.getName())) {\n            assertThat(validatorFactory.getValidator()).isNotNull();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsUserClassFromHibernateValidatorFallbackClassLoader() {\n        String providerClassName = FallbackClassLoaderPropertyNodeNameProvider.class.getName();\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        ClassLoader filteringClassLoader = new FilteringClassLoader(originalContextClassLoader, providerClassName);\n\n        Thread.currentThread().setContextClassLoader(filteringClassLoader);\n        try (ValidatorFactory validatorFactory = configuration()\n                .externalClassLoader(filteringClassLoader)\n                .addProperty(PROPERTY_NODE_NAME_PROVIDER, providerClassName)\n                .buildValidatorFactory()) {\n            assertThat(validatorFactory.getValidator()).isNotNull();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static ValidatorFactory propertyNodeNameProviderFactory(String providerClassName) {\n        return configuration()\n                .addProperty(PROPERTY_NODE_NAME_PROVIDER, providerClassName)\n                .buildValidatorFactory();\n    }\n\n    private static HibernateValidatorConfiguration configuration() {\n        return Validation.byProvider(HibernateValidator.class)\n                .configure()\n                .ignoreXmlConfiguration();\n    }\n\n    public static class ExternalClassLoaderPropertyNodeNameProvider implements PropertyNodeNameProvider {\n        @Override\n        public String getName(Property property) {\n            return property.getName();\n        }\n    }\n\n    public static class ThreadContextClassLoaderPropertyNodeNameProvider implements PropertyNodeNameProvider {\n        @Override\n        public String getName(Property property) {\n            return property.getName();\n        }\n    }\n\n    public static class FallbackClassLoaderPropertyNodeNameProvider implements PropertyNodeNameProvider {\n        @Override\n        public String getName(Property property) {\n            return property.getName();\n        }\n    }\n\n    private static final class FilteringClassLoader extends ClassLoader {\n        private final String hiddenClassName;\n\n        private FilteringClassLoader(ClassLoader parent, String hiddenClassName) {\n            super(parent);\n            this.hiddenClassName = hiddenClassName;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (hiddenClassName.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n}\n"}
