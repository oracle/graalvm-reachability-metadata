  package org.graalvm.reachability.hibernate.validator;
  
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Proxy;
  import java.net.MalformedURLException;
  import java.net.URI;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.CodeSource;
  import java.util.Collections;
  import java.util.Enumeration;
  
  import jakarta.el.ELManager;
  import jakarta.validation.MessageInterpolator;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.hibernate.validator.HibernateValidator;
  import org.hibernate.validator.messageinterpolation.ResourceBundleMessageInterpolator;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.Timeout;
  import org.osgi.framework.Bundle;
  import org.osgi.framework.BundleContext;
  import org.osgi.framework.BundleReference;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ResourceBundleMessageInterpolatorTest {
      private static final String INTERPOLATOR_CLASS_NAME = ResourceBundleMessageInterpolator.class.getName();
      private static final String EXPRESSION_FACTORY_IMPL_CLASS_NAME = "com.sun.el.ExpressionFactoryImpl";
      private static final String EXPRESSION_FACTORY_IMPL_RESOURCE = "com/sun/el/ExpressionFactoryImpl.class";
      private static final String EXPRESSION_FACTORY_SERVICE = "META-INF/services/jakarta.el.ExpressionFactory";
  
      @Test
      @Timeout(59)
      void initializesExpressionFactoryFromOsgiImplementationBundle() throws Exception {
          try {
              createInterpolatorWithOsgiBundleClassLoader();
          } catch (Error e) {
              if (!NativeImageSupport.isUnsupportedFeatureError(e)) {
                  throw e;
              }
          }
      }
  
      private static void createInterpolatorWithOsgiBundleClassLoader() throws Exception {
          URL hibernateValidatorJar = bundleUrl(HibernateValidator.class);
          URL elApiJar = bundleUrl(ELManager.class);
          URL elImplementationJar = bundleUrl(EXPRESSION_FACTORY_IMPL_RESOURCE);
          ClassLoader parentClassLoader = Thread.currentThread().getContextClassLoader();
          try (OsgiBundleClassLoader bundleClassLoader = new OsgiBundleClassLoader(
                  new URL[] { hibernateValidatorJar, elApiJar }, parentClassLoader);
                  URLClassLoader expressionFactoryClassLoader = new URLClassLoader(
                          new URL[] { elImplementationJar }, bundleClassLoader)) {
              Bundle bundle = bundle(bundleContext(expressionFactoryClassLoader), expressionFactoryClassLoader,
                      EXPRESSION_FACTORY_IMPL_CLASS_NAME);
              bundleClassLoader.setBundle(bundle);
  
              Class<?> interpolatorType = bundleClassLoader.loadClass(INTERPOLATOR_CLASS_NAME);
              assertThat(interpolatorType.getClassLoader()).isSameAs(bundleClassLoader);
  
              ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
              Thread.currentThread().setContextClassLoader(bundleClassLoader);
              try {
                  Object interpolator = interpolatorType.getConstructor().newInstance();
                  assertThat(interpolator).isInstanceOf(MessageInterpolator.class);
              } finally {
                  Thread.currentThread().setContextClassLoader(originalContextClassLoader);
              }
          }
      }
  
      private static BundleContext bundleContext(ClassLoader expressionFactoryClassLoader) {
          Bundle[] bundles = new Bundle[1];
          BundleContext context = proxy(BundleContext.class, (proxy, method, args) -> {
              if ("getBundles".equals(method.getName())) {
                  return bundles.clone();
              }
              return defaultValue(method.getReturnType());
          });
          bundles[0] = bundle(context, expressionFactoryClassLoader, EXPRESSION_FACTORY_IMPL_CLASS_NAME);
          return context;
      }
  
      private static Bundle bundle(BundleContext context, ClassLoader classLoader, String loadableClassName) {
          return proxy(Bundle.class, (proxy, method, args) -> {
              if ("getBundleContext".equals(method.getName())) {
                  return context;
              }
              if ("loadClass".equals(method.getName()) && loadableClassName.equals(args[0])) {
                  return classLoader.loadClass(loadableClassName);
              }
              return defaultValue(method.getReturnType());
          });
      }
  
      private static Object defaultValue(Class<?> returnType) {
          if (!returnType.isPrimitive()) {
              return null;
          }
          if (returnType == boolean.class) {
              return false;
          }
          if (returnType == void.class) {
              return null;
          }
          return 0;
      }
  
      private static <T> T proxy(Class<T> interfaceType, InvocationHandler invocationHandler) {
          Object proxy = Proxy.newProxyInstance(
                  interfaceType.getClassLoader(),
                  new Class<?>[] { interfaceType },
                  invocationHandler
          );
          return interfaceType.cast(proxy);
      }
  
      private static URL bundleUrl(Class<?> type) {
          CodeSource codeSource = type.getProtectionDomain().getCodeSource();
          if (codeSource == null) {
              throw new IllegalStateException("No code source for " + type.getName());
          }
          return codeSource.getLocation();
      }
  
      private static URL bundleUrl(String resourceName) throws MalformedURLException {
          URL resource = Thread.currentThread().getContextClassLoader().getResource(resourceName);
          if (resource == null) {
              throw new IllegalStateException("Resource not found: " + resourceName);
          }
          String resourceUrl = resource.toExternalForm();
          int separator = resourceUrl.indexOf("!/");
          if (!resourceUrl.startsWith("jar:") || separator < 0) {
              throw new IllegalStateException("Resource is not located in a jar: " + resourceUrl);
          }
          return URI.create(resourceUrl.substring("jar:".length(), separator)).toURL();
      }
  
      private static final class OsgiBundleClassLoader extends URLClassLoader implements BundleReference {
          private Bundle bundle;
  
          private OsgiBundleClassLoader(URL[] bundleUrls, ClassLoader parentClassLoader) {
              super(bundleUrls, parentClassLoader);
          }
  
          private void setBundle(Bundle bundle) {
              this.bundle = bundle;
          }
  
          @Override
          public Bundle getBundle() {
              return bundle;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null && name.startsWith("com.sun.el.")) {
                      throw new ClassNotFoundException(name);
                  }
                  if (loadedClass == null && shouldLoadFromBundle(name)) {
                      try {
                          loadedClass = findClass(name);
                      } catch (ClassNotFoundException e) {
                          // Delegate non-bundle classes to the parent class loader.
                      }
                  }
                  if (loadedClass == null) {
                      loadedClass = super.loadClass(name, false);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          @Override
          public URL getResource(String name) {
              if (EXPRESSION_FACTORY_SERVICE.equals(name)) {
                  return null;
              }
              return super.getResource(name);
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws java.io.IOException {
              if (EXPRESSION_FACTORY_SERVICE.equals(name)) {
                  return Collections.emptyEnumeration();
              }
              return super.getResources(name);
          }
  
          private static boolean shouldLoadFromBundle(String name) {
              return name.startsWith("org.hibernate.validator.") || name.startsWith("jakarta.el.");
          }
      }
  }
