  					"Found %s on classpath, but no method '%s'. Assuming JPA 1 environment. All properties will per default be traversable.",
  					PERSISTENCE_CLASS_NAME,
  					PERSISTENCE_UTIL_METHOD
  			);
  			return getTraverseAllTraversableResolver();
  		}
  
