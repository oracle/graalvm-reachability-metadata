ctory()) {\n            Validator validator = factory.getValidator();\n            Set<ConstraintViolation<MeasuredValue>> violations = validator.validate(new MeasuredValue(3));\n\n            assertThat(violations).singleElement().satisfies(violation -> {\n                assertThat(violation.getPropertyPath()).hasToString(\"value\");\n                assertThat(violation.getMessage()).isEqualTo(\"value must be at least 5; actual value is 3\");\n            });\n        }\n    }\n\n    @Test\n    void reportsConfigurationFailureAfterCheckingOsgiBundleContextWhenExpressionFactoryIsMisconfigured() {\n        String previousExpressionFactory = System.getProperty(EXPRESSION_FACTORY_PROPERTY);\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            System.setProperty(DISABLE_EXPRESSION_FACTORY_PROPERTY, Boolean.TRUE.toString());\n            System.setProperty(EXPRESSION_FACTORY_PROPERTY, SwitchableExpressionFactory.class.getName());\n            Thread.currentThread().setContextClassLoader(ResourceBundleMessageInterpolatorTest.class.getClassLoader());\n\n            assertThatThrownBy(ResourceBundleMessageInterpolator::new)\n                    .isInstanceOf(ValidationException.class)\n                    .hasMessageContaining(\"Unable to initialize 'jakarta.el.ExpressionFactory'\");\n        }\n        finally {\n            System.clearProperty(DISABLE_EXPRESSION_FACTORY_PROPERTY);\n            restoreProperty(previousExpressionFactory);\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    private static void restoreProperty(String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(EXPRESSION_FACTORY_PROPERTY);\n        }\n        else {\n            System.setProperty(EXPRESSION_FACTORY_PROPERTY, previousValue);\n        }\n    }\n\n    public static final class SwitchableExpressionFactory extends ExpressionFactory {\n        private final ExpressionFactory delegate;\n\n        public SwitchableExpressionFactory() {\n            if (Boolean.getBoolean(DISABLE_EXPRESSION_FACTORY_PROPERTY)) {\n                throw new IllegalStateException(\"Expression factory intentionally unavailable\");\n            }\n            this.delegate = new ExpressionFactoryImpl();\n        }\n\n        @Override\n        public <T> T coerceToType(Object object, Class<T> targetType) {\n            return delegate.coerceToType(object, targetType);\n        }\n\n        @Override\n        public MethodExpression createMethodExpression(\n                ELContext context,\n                String expression,\n                Class<?> expectedReturnType,\n                Class<?>[] expectedParamTypes\n        ) {\n            return delegate.createMethodExpression(context, expression, expectedReturnType, expectedParamTypes);\n        }\n\n        @Override\n        public ValueExpression createValueExpression(ELContext context, String expression, Class<?> expectedType) {\n            return delegate.createValueExpression(context, expression, expectedType);\n        }\n\n        @Override\n        public ValueExpression createValueExpression(Object instance, Class<?> expectedType) {\n            return delegate.createValueExpression(instance, expectedType);\n        }\n\n        @Override\n        public ELResolver getStreamELResolver() {\n            return delegate.getStreamELResolver();\n        }\n\n        @Override\n        public Map<String, Method> getInitFunctionMap() {\n            return delegate.getInitFunctionMap();\n        }\n    }\n\n    private static final class MeasuredValue {\n        @Min(value = 5, message = \"value must be at least {value}; actual value is ${validatedValue}\")\n        private final int value;\n\n        private MeasuredValue(int value) {\n            this.value = value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782315203754}}
