  	Class<?> getReturnType();
  
  	/**
  	 * @return the name of the method represented by this {@code ConstrainableExecutable} object
  	 */
  	String getName();
  
  	/**
  	 * @return the parameter types for the executable this object represents
  	 */
  	Class<?>[] getParameterTypes();
  }
