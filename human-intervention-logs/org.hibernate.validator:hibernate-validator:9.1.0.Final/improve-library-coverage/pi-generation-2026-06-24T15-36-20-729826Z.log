,\n                        propertyNodeNameProviderClassName)\n                .buildValidatorFactory();\n    }\n\n    private static void assertConfiguredPropertyNodeNameProvider(ValidatorFactory factory) {\n        Validator validator = factory.getValidator();\n        Set<ConstraintViolation<NamedBean>> violations = validator.validate(new NamedBean(null));\n\n        assertThat(violations).singleElement().satisfies(violation -> {\n            assertThat(violation.getPropertyPath()).hasToString(\"configured-name\");\n            assertThat(violation.getMessageTemplate()).isEqualTo(\"{jakarta.validation.constraints.NotNull.message}\");\n        });\n    }\n\n    public static final class ConfiguredPropertyNodeNameProvider implements PropertyNodeNameProvider {\n        @Override\n        public String getName(Property property) {\n            return \"configured-\" + property.getName();\n        }\n    }\n\n    private static final class DenyingPropertyNodeNameProviderClassLoader extends ClassLoader {\n        private final String deniedClassName;\n\n        private DenyingPropertyNodeNameProviderClassLoader(ClassLoader parent, String deniedClassName) {\n            super(parent);\n            this.deniedClassName = deniedClassName;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (deniedClassName.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n\n    private static final class NamedBean {\n        @NotNull\n        private final String name;\n\n        private NamedBean(String name) {\n            this.name = name;\n        }\n    }\n\n    private static final class MeasuredValue {\n        @Min(value = 5, message = \"minimum is {value} and submitted value is ${validatedValue}\")\n        private final int value;\n\n        private MeasuredValue(int value) {\n            this.value = value;\n        }\n    }\n}\n"}
