              "org.hibernate.validator.MissingGetterPropertySelectionStrategy";
  
      @Test
      void bootstrapsDefaultValidatorFactoryWithExpressionLanguageInterpolation() {
          try (ValidatorFactory factory = Validation.buildDefaultValidatorFactory()) {
              Validator validator = factory.getValidator();
              Set<ConstraintViolation<MeasuredValue>> violations = validator.validate(new MeasuredValue(3));
  
              assertThat(violations).singleElement().satisfies(violation -> {
                  assertThat(violation.getPropertyPath()).hasToString("value");
                  assertThat(violation.getMessage()).isEqualTo("minimum is 5 and submitted value is 3");
              });
          }
      }
  
      @Test
      void loadsValidatorNamespaceConfigurationClassFromHibernateValidatorClassLoader() {
          try (ValidatorFactory factory = validatorFactory(DEFAULT_GETTER_PROPERTY_SELECTION_STRATEGY)) {
              Validator validator = factory.getValidator();
              Set<ConstraintViolation<NamedBean>> violations = validator.validate(new NamedBean(null));
  
              assertThat(violations).singleElement().satisfies(violation -> {
                  assertThat(violation.getPropertyPath()).hasToString("name");
                  assertThat(violation.getMessageTemplate())
                          .isEqualTo("{jakarta.validation.constraints.NotNull.message}");
              });
          }
      }
  
      @Test
      void reportsMissingValidatorNamespaceConfigurationClassAfterTryingThreadContextClassLoader() {
          ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
          ClassLoader denyingContextClassLoader = new DenyingClassLoader(
                  LoadClassTest.class.getClassLoader(), MISSING_VALIDATOR_NAMESPACE_STRATEGY);
  
          try {
              Thread.currentThread().setContextClassLoader(denyingContextClassLoader);
  
              assertThatThrownBy(() -> validatorFactory(MISSING_VALIDATOR_NAMESPACE_STRATEGY).close())
                      .isInstanceOf(ValidationException.class)
                      .hasMessageContaining("Unable to instantiate getter property selection strategy class")
                      .hasMessageContaining(MISSING_VALIDATOR_NAMESPACE_STRATEGY);
          }
          finally {
              Thread.currentThread().setContextClassLoader(previousContextClassLoader);
          }
      }
  
      @Test
      void loadsNonValidatorConfigurationClassFromExternalClassLoader() {
          try (ValidatorFactory factory = Validation.byProvider(HibernateValidator.class)
                  .configure()
                  .externalClassLoader(LoadClassTest.class.getClassLoader())
                  .addProperty(HibernateValidatorConfiguration.GETTER_PROPERTY_SELECTION_STRATEGY_CLASSNAME,
                          CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY)
                  .buildValidatorFactory()) {
              assertConfiguredGetterPropertySelectionStrategy(factory);
          }
      }
  
      @Test
      void loadsNonValidatorConfigurationClassFromThreadContextClassLoader() {
          ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
  
          try {
              Thread.currentThread().setContextClassLoader(LoadClassTest.class.getClassLoader());
  
              try (ValidatorFactory factory = validatorFactory(CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY)) {
                  assertConfiguredGetterPropertySelectionStrategy(factory);
              }
          }
          finally {
              Thread.currentThread().setContextClassLoader(previousContextClassLoader);
          }
      }
  
      @Test
      void loadsNonValidatorConfigurationClassFromHibernateValidatorFallbackClassLoader() {
          ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
          ClassLoader denyingContextClassLoader = new DenyingClassLoader(
                  LoadClassTest.class.getClassLoader(), CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY);
  
          try {
              Thread.currentThread().setContextClassLoader(denyingContextClassLoader);
  
              try (ValidatorFactory factory = validatorFactory(CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY)) {
                  assertConfiguredGetterPropertySelectionStrategy(factory);
              }
          }
          finally {
              Thread.currentThread().setContextClassLoader(previousContextClassLoader);
          }
      }
  
      private static ValidatorFactory validatorFactory(String getterPropertySelectionStrategyClassName) {
          BaseHibernateValidatorConfiguration<?> configuration = Validation.byProvider(HibernateValidator.class)
                  .configure();
          return configuration
                  .addProperty(HibernateValidatorConfiguration.GETTER_PROPERTY_SELECTION_STRATEGY_CLASSNAME,
                          getterPropertySelectionStrategyClassName)
                  .buildValidatorFactory();
      }
  
      private static void assertConfiguredGetterPropertySelectionStrategy(ValidatorFactory factory) {
          Validator validator = factory.getValidator();
          Set<ConstraintViolation<GetterBean>> violations = validator.validate(new GetterBean(null));
  
          assertThat(violations).singleElement().satisfies(violation -> {
              assertThat(violation.getPropertyPath()).hasToString("configuredName");
              assertThat(violation.getMessageTemplate()).isEqualTo("{jakarta.validation.constraints.NotNull.message}");
          });
      }
  
      public static final class ConfiguredGetterPropertySelectionStrategy implements GetterPropertySelectionStrategy {
          @Override
          public Optional<String> getProperty(ConstrainableExecutable executable) {
              if (executable.getParameterTypes().length == 0 && "validatedName".equals(executable.getName())) {
                  return Optional.of("configuredName");
              }
              return Optional.empty();
          }
  
          @Override
          public List<String> getGetterMethodNameCandidates(String propertyName) {
              return List.of("validatedName");
          }
      }
  
      private static final class DenyingClassLoader extends ClassLoader {
          private final String deniedClassName;
  
          private DenyingClassLoader(ClassLoader parent, String deniedClassName) {
              super(parent);
              this.deniedClassName = deniedClassName;
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (deniedClassName.equals(name)) {
                  throw new ClassNotFoundException(name);
              }
              return super.loadClass(name, resolve);
          }
      }
  
      private static final class NamedBean {
          @NotNull
          private final String name;
  
          private NamedBean(String name) {
              this.name = name;
          }
      }
  
      private static final class GetterBean {
          private final String name;
  
          private GetterBean(String name) {
              this.name = name;
          }
  
          @NotNull
          public String validatedName() {
              return name;
          }
      }
  
      private static final class MeasuredValue {
          @Min(value = 5, message = "minimum is {value} and submitted value is ${validatedValue}")
          private final int value;
  
          private MeasuredValue(int value) {
              this.value = value;
          }
      }
  }
