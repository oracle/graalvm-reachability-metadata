[tool-exec] end id=call_4VYVjDk8Ru35plCckan9OU5P|fc_0e4bcf423b8a473e016a3bfe75f0c88196bc847c689e3a7fcf name=read status=success
  /*
   * SPDX-License-Identifier: Apache-2.0
   * Copyright Red Hat Inc. and Hibernate Authors
