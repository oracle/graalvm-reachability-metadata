ivate static void createInterpolatorWithOsgiBundleClassLoader() throws Exception {\n        URL hibernateValidatorJar = bundleUrl(HibernateValidator.class);\n        ClassLoader parentClassLoader = Thread.currentThread().getContextClassLoader();\n        try (OsgiBundleClassLoader bundleClassLoader = new OsgiBundleClassLoader(hibernateValidatorJar, parentClassLoader)) {\n            Bundle bundle = bundle(bundleContext(), EXPRESSION_FACTORY_IMPL_CLASS_NAME);\n            bundleClassLoader.setBundle(bundle);\n\n            Class<?> interpolatorType = bundleClassLoader.loadClass(INTERPOLATOR_CLASS_NAME);\n            assertThat(interpolatorType.getClassLoader()).isSameAs(bundleClassLoader);\n\n            ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n            Thread.currentThread().setContextClassLoader(bundleClassLoader);\n            try {\n                Object interpolator = interpolatorType.getConstructor().newInstance();\n                assertThat(interpolator).isInstanceOf(MessageInterpolator.class);\n            } finally {\n                Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n            }\n        }\n    }\n\n    private static BundleContext bundleContext() {\n        Bundle[] bundles = new Bundle[1];\n        BundleContext context = proxy(BundleContext.class, (proxy, method, args) -> {\n            if (\"getBundles\".equals(method.getName())) {\n                return bundles.clone();\n            }\n            return defaultValue(method.getReturnType());\n        });\n        bundles[0] = bundle(context, EXPRESSION_FACTORY_IMPL_CLASS_NAME);\n        return context;\n    }\n\n    private static Bundle bundle(BundleContext context, String loadableClassName) {\n        return proxy(Bundle.class, (proxy, method, args) -> {\n            if (\"getBundleContext\".equals(method.getName())) {\n                return context;\n            }\n            if (\"loadClass\".equals(method.getName()) && loadableClassName.equals(args[0])) {\n                return Class.forName(loadableClassName);\n            }\n            return defaultValue(method.getReturnType());\n        });\n    }\n\n    private static Object defaultValue(Class<?> returnType) {\n        if (!returnType.isPrimitive()) {\n            return null;\n        }\n        if (returnType == boolean.class) {\n            return false;\n        }\n        if (returnType == void.class) {\n            return null;\n        }\n        return 0;\n    }\n\n    private static <T> T proxy(Class<T> interfaceType, InvocationHandler invocationHandler) {\n        Object proxy = Proxy.newProxyInstance(\n                interfaceType.getClassLoader(),\n                new Class<?>[] { interfaceType },\n                invocationHandler\n        );\n        return interfaceType.cast(proxy);\n    }\n\n    private static URL bundleUrl(Class<?> type) throws URISyntaxException {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        if (codeSource == null) {\n            throw new IllegalStateException(\"No code source for \" + type.getName());\n        }\n        URI uri = codeSource.getLocation().toURI();\n        return Path.of(uri).toUri().toURL();\n    }\n\n    private static final class OsgiBundleClassLoader extends URLClassLoader implements BundleReference {\n        private Bundle bundle;\n\n        private OsgiBundleClassLoader(URL hibernateValidatorJar, ClassLoader parentClassLoader) {\n            super(new URL[] { hibernateValidatorJar }, parentClassLoader);\n        }\n\n        private void setBundle(Bundle bundle) {\n            this.bundle = bundle;\n        }\n\n        @Override\n        public Bundle getBundle() {\n            return bundle;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?>