N_MULTIPLE\n        ));\n    }\n\n    private static Bundle installBundles(BundleContext context) throws Exception {\n        Bundle hibernateValidator = null;\n        for (String location : bundleLocations()) {\n            Bundle bundle = context.installBundle(location);\n            if (INTERPOLATOR_CLASS_NAME.equals(ResourceBundleMessageInterpolator.class.getName())\n                    && location.equals(bundleLocation(ResourceBundleMessageInterpolator.class))) {\n                hibernateValidator = bundle;\n            }\n        }\n        if (hibernateValidator == null) {\n            throw new IllegalStateException(\"Hibernate Validator bundle was not installed\");\n        }\n        return hibernateValidator;\n    }\n\n    private static void startInstalledBundles(BundleContext context) throws Exception {\n        List<Bundle> bundles = new ArrayList<>(List.of(context.getBundles()));\n        for (Bundle bundle : bundles) {\n            if (bundle.getBundleId() != 0 && !isFragment(bundle)) {\n                bundle.start();\n            }\n        }\n    }\n\n    private static boolean isFragment(Bundle bundle) {\n        return bundle.getHeaders().get(Constants.FRAGMENT_HOST) != null;\n    }\n\n    private static Set<String> bundleLocations() throws URISyntaxException {\n        Set<String> locations = new LinkedHashSet<>();\n        locations.add(bundleLocation(Validation.class));\n        locations.add(bundleLocation(Logger.class));\n        locations.add(bundleLocation(TypeResolver.class));\n        locations.add(bundleLocation(ELManager.class));\n        locations.add(bundleLocation(EXPRESSION_FACTORY_IMPL_RESOURCE));\n        locations.add(bundleLocation(ResourceBundleMessageInterpolator.class));\n        return locations;\n    }\n\n    private static String bundleLocation(Class<?> type) throws URISyntaxException {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        if (codeSource == null) {\n            throw new