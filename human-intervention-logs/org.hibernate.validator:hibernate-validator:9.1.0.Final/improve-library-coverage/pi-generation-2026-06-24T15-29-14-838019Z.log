  	public ConcurrentReferenceHashMap(int initialCapacity,
  			float loadFactor, int concurrencyLevel) {
  		this( initialCapacity, loadFactor, concurrencyLevel,
  				DEFAULT_KEY_TYPE, DEFAULT_VALUE_TYPE, null );
  	}
  
  	/**
