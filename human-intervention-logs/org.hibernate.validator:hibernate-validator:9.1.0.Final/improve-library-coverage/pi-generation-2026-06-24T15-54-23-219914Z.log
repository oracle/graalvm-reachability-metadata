  package com.example.hibernatevalidator;
  
  import jakarta.validation.ConstraintViolation;
  import jakarta.validation.Validation;
  import jakarta.validation.Validator;
  import jakarta.validation.ValidatorFactory;
  import jakarta.validation.constraints.Pattern;
  import org.junit.jupiter.api.Test;
  
  import java.util.Set;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class GetAnnotationAttributeTest {
      @Test
      void validatesConstraintsDeclaredByMultiValueConstraintAnnotation() {
          try (ValidatorFactory factory = Validation.buildDefaultValidatorFactory()) {
              Validator validator = factory.getValidator();
              Set<ConstraintViolation<CodeHolder>> violations = validator.validate(new CodeHolder("ab1"));
  
              assertThat(violations).hasSize(2);
              assertThat(violations)
                      .extracting(violation -> violation.getPropertyPath().toString())
                      .containsOnly("code");
              assertThat(violations)
                      .extracting(ConstraintViolation::getMessage)
                      .containsExactlyInAnyOrder(
                              "code must contain only uppercase letters; actual value is ab1",
                              "code must contain only digits; actual value is ab1"
                      );
          }
      }
  
      private static final class CodeHolder {
          @Pattern.List({
                  @Pattern(
                          regexp = "[A-Z]+",
                          message = "code must contain only uppercase letters; actual value is ${validatedValue}"
                  ),
                  @Pattern(
                          regexp = "\\d+",
                          message = "code must contain only digits; actual value is ${validatedValue}"
                  )
          })
          private final String code;
  
          private CodeHolder(String code) {
              this.code = code;
          }
      }
  }
