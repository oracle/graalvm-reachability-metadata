>.\n */\npackage com.example.hibernatevalidator;\n\nimport jakarta.validation.ConstraintViolation;\nimport jakarta.validation.Validation;\nimport jakarta.validation.ValidationException;\nimport jakarta.validation.Validator;\nimport jakarta.validation.ValidatorFactory;\nimport jakarta.validation.constraints.Min;\nimport jakarta.validation.constraints.NotNull;\nimport org.hibernate.validator.BaseHibernateValidatorConfiguration;\nimport org.hibernate.validator.HibernateValidator;\nimport org.hibernate.validator.HibernateValidatorConfiguration;\nimport org.hibernate.validator.spi.properties.ConstrainableExecutable;\nimport org.hibernate.validator.spi.properties.GetterPropertySelectionStrategy;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.List;\nimport java.util.Optional;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class LoadClassTest {\n    private static final String CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY =\n            \"com.example.hibernatevalidator.LoadClassTest$ConfiguredGetterPropertySelectionStrategy\";\n    private static final String DEFAULT_GETTER_PROPERTY_SELECTION_STRATEGY =\n            \"org.hibernate.validator.internal.properties.DefaultGetterPropertySelectionStrategy\";\n    private static final String MISSING_VALIDATOR_NAMESPACE_STRATEGY =\n            \"org.hibernate.validator.MissingGetterPropertySelectionStrategy\";\n\n    @Test\n    void bootstrapsDefaultValidatorFactoryWithExpressionLanguageInterpolation() {\n        try (ValidatorFactory factory = Validation.buildDefaultValidatorFactory()) {\n            Validator validator = factory.getValidator();\n            Set<ConstraintViolation<MeasuredValue>> violations = validator.validate(new MeasuredValue(3));\n\n            assertThat(violations).singleElement().satisfies(violation -> {\n                assertThat(violation.getPropertyPath()).hasToString(\"value\");\n                assertThat(violation.getMessage()).isEqualTo(\"minimum is 5 and submitted value is 3\");\n            });\n        }\n    }\n\n    @Test\n    void loadsValidatorNamespaceConfigurationClassFromHibernateValidatorClassLoader() {\n        try (ValidatorFactory factory = validatorFactory(DEFAULT_GETTER_PROPERTY_SELECTION_STRATEGY)) {\n            Validator validator = factory.getValidator();\n            Set<ConstraintViolation<NamedBean>> violations = validator.validate(new NamedBean(null));\n\n            assertThat(violations).singleElement().satisfies(violation -> {\n                assertThat(violation.getPropertyPath()).hasToString(\"name\");\n                assertThat(violation.getMessageTemplate())\n                        .isEqualTo(\"{jakarta.validation.constraints.NotNull.message}\");\n            });\n        }\n    }\n\n    @Test\n    void reportsMissingValidatorNamespaceConfigurationClassAfterTryingThreadContextClassLoader() {\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n        ClassLoader denyingContextClassLoader = new DenyingClassLoader(\n                LoadClassTest.class.getClassLoader(), MISSING_VALIDATOR_NAMESPACE_STRATEGY);\n\n        try {\n            Thread.currentThread().setContextClassLoader(denyingContextClassLoader);\n\n            assertThatThrownBy(() -> validatorFactory(MISSING_VALIDATOR_NAMESPACE_STRATEGY).close())\n                    .isInstanceOf(ValidationException.class)\n                    .hasMessageContaining(\"Unable to instantiate getter property selection strategy class\")\n                    .hasMessageContaining(MISSING_VALIDATOR_NAMESPACE_STRATEGY);\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsNonValidatorConfigurationClassFromExternalClassLoader() {\n        try (ValidatorFactory factory = Validation.byProvider(HibernateValidator.class)\n                .configure()\n                .externalClassLoader(LoadClassTest.class.getClassLoader())\n                .addProperty(HibernateValidatorConfiguration.GETTER_PROPERTY_SELECTION_STRATEGY_CLASSNAME,\n                        CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY)\n                .buildValidatorFactory()) {\n            assertConfiguredGetterPropertySelectionStrategy(factory);\n        }\n    }\n\n    @Test\n    void loadsNonValidatorConfigurationClassFromThreadContextClassLoader() {\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            Thread.currentThread().setContextClassLoader(LoadClassTest.class.getClassLoader());\n\n            try (ValidatorFactory factory = validatorFactory(CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY)) {\n                assertConfiguredGetterPropertySelectionStrategy(factory);\n            }\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsNonValidatorConfigurationClassFromHibernateValidatorFallbackClassLoader() {\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n        ClassLoader denyingContextClassLoader = new DenyingClassLoader(\n                LoadClassTest.class.getClassLoader(), CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY);\n\n        try {\n            Thread.currentThread().setContextClassLoader(denyingContextClassLoader);\n\n            try (ValidatorFactory factory = validatorFactory(CUSTOM_GETTER_PROPERTY_SELECTION_STRATEGY)) {\n                assertConfiguredGetterPropertySelectionStrategy(factory);\n            }\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    private static ValidatorFactory validatorFactory(String getterPropertySelectionStrategyClassName) {\n        BaseHibernateValidatorConfiguration<?> configuration = Validation.byProvider(HibernateValidator.class)\n                .configure();\n        return configuration\n                .addProperty(HibernateValidatorConfiguration.GETTER_PROPERTY_SELECTION_STRATEGY_CLASSNAME,\n                        getterPropertySelectionStrategyClassName)\n                .buildValidatorFactory();\n    }\n\n    private static void assertConfiguredGetterPropertySelectionStrategy(ValidatorFactory factory) {\n        Validator validator = factory.getValidator();\n        Set<ConstraintViolation<GetterBean>> violations = validator.validate(new GetterBean(null));\n\n        assertThat(violations).singleElement().satisfies(violation -> {\n            assertThat(violation.getPropertyPath()).hasToString(\"configuredName\");\n            assertThat(violation.getMessageTemplate()).isEqualTo(\"{jakarta.validation.constraints.NotNull.message}\");\n        });\n    }\n\n    public static final class ConfiguredGetterPropertySelectionStrategy implements GetterPropertySelectionStrategy {\n        @Override\n        public Optional<String> getProperty(ConstrainableExecutable executable) {\n            if (executable.getParameterTypes().length == 0 && \"validatedName\".equals(executable.getName())) {\n                return Optional.of(\"configuredName\");\n            }\n            return Optional.empty();\n        }\n\n        @Override\n        public List<String> getGetterMethodNameCandidates(String propertyName) {\n            return List.of(\"validatedName\");\n        }\n    }\n\n    private static final class DenyingClassLoader extends ClassLoader {\n        private final String deniedClassName;\n\n        private DenyingClassLoader(ClassLoader parent, String deniedClassName) {\n            super(parent);\n            this.deniedClassName = deniedClassName;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (deniedClassName.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n\n    private static final class NamedBean {\n        @NotNull\n        private final String name;\n\n        private NamedBean(String name) {\n            this.name = name;\n        }\n    }\n\n    private static final class GetterBean {\n        private final String name;\n\n        private GetterBean(String name) {\n            this.name = name;\n        }\n\n        @NotNull\n        public String validatedName() {\n            return name;\n        }\n    }\n\n    private static final class MeasuredValue {\n        @Min(value = 5, message = \"minimum is {value} and submitted value is ${validatedValue}\")\n        private final int value;\n\n        private MeasuredValue(int value) {\n            this.value = value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782316427391}]}
