violation.getMessage()).isEqualTo(\"name is required\");\n            });\n        }\n    }\n\n    private static final class ProgrammaticBean {\n        private final String name;\n\n        private ProgrammaticBean(String name) {\n            this.name = name;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
