{"type":"item.completed","item":{"id":"item_98","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,220p' tests/src/org.hibernate.validator/hibernate-validator/9.1.0.Final/src/test/java/com/example/hibernatevalidator/GetAnnotationAttributeTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com.example.hibernatevalidator;\n\nimport jakarta.validation.ConstraintViolation;\nimport jakarta.validation.Validation;\nimport jakarta.validation.Validator;\nimport jakarta.validation.ValidatorFactory;\nimport jakarta.validation.constraints.Pattern;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class GetAnnotationAttributeTest {\n    @Test\n    void validatesConstraintsDeclaredByMultiValueConstraintAnnotation() {\n        try (ValidatorFactory factory = Validation.buildDefaultValidatorFactory()) {\n            Validator validator = factory.getValidator();\n            Set<ConstraintViolation<CodeHolder>> violations = validator.validate(new CodeHolder(\"ab1\"));\n\n            assertThat(violations).hasSize(2);\n            assertThat(violations)\n                    .extracting(violation -> violation.getPropertyPath().toString())\n                    .containsOnly(\"code\");\n            assertThat(violations)\n                    .extracting(ConstraintViolation::getMessage)\n                    .containsExactlyInAnyOrder(\n                            \"code must contain only uppercase letters; actual value is ab1\",\n                            \"code must contain only digits; actual value is ab1\"\n                    );\n        }\n    }\n\n    private static final class CodeHolder {\n        @Pattern.List({\n                @Pattern(\n                        regexp = \"[A-Z]+\",\n                        message = \"code must contain only uppercase letters; actual value is ${validatedValue}\"\n                ),\n                @Pattern(\n                        regexp = \"\\\\d+\",\n                        message = \"code must contain only digits; actual value is ${validatedValue}\"\n                )\n        })\n        private final String code;\n\n        private CodeHolder(String code) {\n            this.code = code;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
