.ExpressionFactoryImpl\\\";\\n    private static final String EXPRESSION_FACTORY_IMPL_RESOURCE = \\\"com/sun/el/ExpressionFactoryImpl.class\\\";\\n    private static final String EXPRESSION_FACTORY_SERVICE = \\\"META-INF/services/jakarta.el.ExpressionFactory\\\";\\n\\n    @Test\\n    @Timeout(59)\\n    void initializesExpressionFactoryFromOsgiImplementationBundle() throws Exception {\\n        try {\\n            createInterpolatorWithOsgiBundleClassLoader();\\n        } catch (Error e) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(e)) {\\n                throw e;\\n            }\\n        }\\n    }\\n\\n    private static void createInterpolatorWithOsgiBundleClassLoader() throws Exception {\\n        URL hibernateValidatorJar = bundleUrl(HibernateValidator.class);\\n        URL elApiJar = bundleUrl(ELManager.class);\\n        URL elImplementationJar = bundleUrl(EXPRESSION_FACTORY_IMPL_RESOURCE);\\n        ClassLoader parentClassLoader = Thread.currentThread().getContextClassLoader();\\n        try (OsgiBundleClassLoader bundleClassLoader = new OsgiBundleClassLoader(\\n                new URL[] { hibernateValidatorJar, elApiJar }, parentClassLoader);\\n                URLClassLoader expressionFactoryClassLoader = new URLClassLoader(\\n                        new URL[] { elImplementationJar }, bundleClassLoader)) {\\n            Bundle bundle = bundle(bundleContext(expressionFactoryClassLoader), expressionFactoryClassLoader,\\n                    EXPRESSION_FACTORY_IMPL_CLASS_NAME);\\n            bundleClassLoader.setBundle(bundle);\\n\\n            Class<?> interpolatorType = bundleClassLoader.loadClass(INTERPOLATOR_CLASS_NAME);\\n            assertThat(interpolatorType.getClassLoader()).isSameAs(bundleClassLoader);\\n\\n            ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\\n            Thread.currentThread().setContextClassLoader(bundleClassLoader);\\n            try {\\n                Object interpolator = interpolatorType.getConstructor().newInstance();\\n                assertThat(interpolator).isInstanceOf(MessageInterpolator.class);\\n            } finally {\\n                Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n            }\\n        }\\n    }\\n\\n    private static BundleContext bundleContext(ClassLoader expressionFactoryClassLoader) {\\n        Bundle[] bundles = new Bundle[1];\\n        BundleContext context = proxy(BundleContext.class, (proxy, method, args) -> {\\n            if (\\\"getBundles\\\".equals(method.getName())) {\\n                return bundles.clone();\\n            }\\n            return defaultValue(method.getReturnType());\\n        });\\n        bundles[0] = bundle(context, expressionFactoryClassLoader, EXPRESSION_FACTORY_IMPL_CLASS_NAME);\\n        return context;\\n    }\\n\\n    private static Bundle bundle(BundleContext context, ClassLoader classLoader, String loadableClassName) {\\n        return proxy(Bundle.class, (proxy, method, args) -> {\\n            if (\\\"getBundleContext\\\".equals(method.getName())) {\\n                return context;\\n            }\\n            if (\\\"loadClass\\\".equals(method.getName()) && loadableClassName.equals(args[0])) {\\n                return classLoader.loadClass(loadableClassName);\\n            }\\n            return defaultValue(method.getReturnType());\\n        });\\n    }\\n\\n    private static Object defaultValue(Class<?> returnType) {\\n        if (!returnType.isPrimitive()) {\\n            return null;\\n        }\\n        if (returnType == boolean.class) {\\n            return false;\\n        }\\n        if (returnType == void.class) {\\n            return null;\\n        }\\n        return 0;\\n    }\\n\\n    private static <T> T proxy(Class<T> interfaceType, InvocationHandler invocationHandler) {\\n        Object proxy = Proxy.newProxyInstance(\\n                interfaceType.getClassLoader(),\\n                new Class<?>[] { interfaceType },\\n                invocationHandler\\n        );\\n        return interfaceType.cast(proxy);\\n    }\\n\\n    private static URL bundleUrl(Class<?> type) {\\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\\n        if (codeSource == null) {\\n            throw new IllegalStateException(\\\"No code source for \\\" + type.getName());\\n        }\\n        return codeSource.getLocation();\\n    }\\n\\n    private static URL bundleUrl(String resourceName) throws MalformedURLException {\\n        URL resource = Thread.currentThread().getContextClassLoader().getResource(resourceName);\\n        if (resource == null) {\\n            throw new IllegalStateException(\\\"Resource not found: \\\" + resourceName);\\n        }\\n        String resourceUrl = resource.toExternalForm();\\n        int separator = resourceUrl.indexOf(\\\"!/\\\");\\n        if (!resourceUrl.startsWith(\\\"jar:\\\") || separator < 0) {\\n            throw new IllegalStateException(\\\"Resource is not located in a jar: \\\" + resourceUrl);\\n        }\\n        return URI.create(resourceUrl.substring(\\\"jar:\\\".length(), separator)).toURL();\\n    }\\n\\n    private static final class OsgiBundleClassLoader extends URLClassLoader implements BundleReference {\\n        private Bundle bundle;\\n\\n        private OsgiBundleClassLoader(URL[] bundleUrls, ClassLoader parentClassLoader) {\\n            super(bundleUrls, parentClassLoader);\\n        }\\n\\n        private void setBundle(Bundle bundle) {\\n            this.bundle = bundle;\\n        }\\n\\n        @Override\\n        public Bundle getBundle() {\\n            return bundle;\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            synchronized (getClassLoadingLock(name)) {\\n                Class<?> loadedClass = findLoadedClass(name);\\n                if (loadedClass == null && name.startsWith(\\\"com.su