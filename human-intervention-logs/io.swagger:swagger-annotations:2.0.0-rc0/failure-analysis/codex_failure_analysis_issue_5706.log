ema = @Schema(type = \\\"integer\\\", format = \\\"int32\\\", minimum = \\\"1\\\", maximum = \\\"100\\\")) int limit,\\n                @RequestBody(\\n                        description = \\\"Overrides for default pet fields\\\",\\n                        content = @Content(\\n                                mediaType = \\\"application/json\\\",\\n                                schema = @Schema(implementation = Pet.class))) Pet defaults) {\\n            return Collections.singletonList(new Pet(\\\"pet-1\\\", type + '-' + limit, defaults.name));\\n        }\\n    }\\n\\n    private static final class AdministrativeResource {\\n        @Operation(summary = \\\"Purge cache\\\", deprecated = true)\\n        @Parameter(\\n                name = \\\"cacheName\\\",\\n                in = \\\"query\\\",\\n                description = \\\"Cache names to purge\\\",\\n                deprecated = true,\\n                allowEmptyValue = true,\\n                allowReserved = true,\\n                hidden = true)\\n        private void purgeCache(\\n                @Parameter(\\n                        name = \\\"cacheNames\\\",\\n                        in = \\\"query\\\",\\n                        description = \\\"Cache names to purge\\\",\\n                        array = @ArraySchema(\\n                                schema = @Schema(type = \\\"string\\\"),\\n                                uniqueItems = true),\\n                        hidden = true) List<String> cacheNames) {\\n        }\\n    }\\n\\n    private static final class AdministrativeRequest {\\n        @Schema(\\n                description = \\\"Internal audit note\\\",\\n                writeOnly = true,\\n                hidden = true)\\n        private final String auditNote = \\\"\\\";\\n    }\\n\\n    private static class BasePet {\\n    }\\n\\n    private static final class Dog extends Pet {\\n        private Dog() {\\n            super(\\\"dog-1\\\", \\\"dog\\\", \\\"Fido\\\");\\n        }\\n    }\\n\\n    private static final class Cat extends Pet {\\n        private Cat() {\\n            super(\\\"cat-1\\\", \\\"cat\\\", \\\"Garfield\\\");\\n        }\\n    }\\n\\n    @Schema(\\n            implementation = Pet.class,\\n            allOf = BasePet.class,\\n            oneOf = {Dog.class, Cat.class},\\n            name = \\\"Pet\\\",\\n            title = \\\"Pet\\\",\\n            requiredProperties = {\\\"id\\\", \\\"name\\\"},\\n            description = \\\"A pet visible through the API\\\",\\n            ref = \\\"#/components/schemas/Pet\\\",\\n            discriminatorProperty = \\\"kind\\\",\\n            discriminatorMapping = {\\n                    @DiscriminatorMapping(value = \\\"dog\\\", schema = Dog.class),\\n                    @DiscriminatorMapping(value = \\\"cat\\\", schema = Cat.class)\\n            },\\n            externalDocs = @ExternalDocumentation(\\n                    description = \\\"Pet schema guide\\\",\\n                    url = \\\"https://example.test/docs/pet-schema\\\"))\\n    private static class Pet extends BasePet {\\n        private final String identifier;\\n        private final String kind;\\n\\n        @Schema(\\n                name = \\\"name\\\",\\n                description = \\\"Display name\\\",\\n                type = \\\"string\\\",\\n                format = \\\"pet-name\\\",\\n                required = true,\\n                _enum = {\\\"Fido\\\", \\\"Garfield\\\"},\\n                examples = {\\\"Fido\\\", \\\"Garfield\\\"},\\n                example = \\\"Fido\\\",\\n                _default = \\\"Fido\\\",\\n                minLength = 1,\\n                maxLength = 64,\\n                pattern = \\\"[A-Za-z]+[A-Za-z -]*\\\")\\n        private final String name;\\n\\n        @ArraySchema(\\n                schema = @Schema(type = \\\"string\\\"),\\n                minItems = 1,\\n                maxItems = 5,\\n                uniqueItems = true)\\n        private final List<String> aliases = Collections.singletonList(\\\"good pet\\\");\\n\\n        private Pet(String identifier, String kind, String name) {\\n            this.identifier = identifier;\\n            this.kind = kind;\\n            this.name = name;\\n        }\\n\\n        private Pet(String identifier, String name) {\\n            this(identifier, \\\"pet\\\", name);\\n        }\\n\\n        @Schema(\\n                name = \\\"id\\\",\\n                description = \\\"Stable identifier\\\",\\n                readOnly = true)\\n        private String getIdentifier() {\\n            return identifier;\\n        }\\n    }\\n}\\n\"}\nhuman-intervention-logs/io.swagger:swagger-annotations:2.0.0-rc0/fix-javac-fail/pi-generation-2026-05-04T11-01-58-749439Z.log:3667:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0e4fa27c970806100169f87c16350081a29c7e6796c229694c\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp-Hwits3iKu9fHrj05GJSiZGJGOz5AtTdeCVy92vJyJGAvkyvCQYa4OICkrRvvmUjI-iilXTmNBDc_0-sK9SUgRsR-_hhc5a07g0mBeTOOZrfWrYcTNq5XoRfc1JpVr5tv91kUaBalzKVHkcmAahtayEf71LbzhAQbk5Z7GDKYAJs9RWNu3-tG8IHRpe_4GDaTNbOnF3P8wnjGSPt8cPfTotcwMl6feyUcgll5dAGX-wgK5WnCCn1CbK7-NOXlbxzdYZfc4XyHuLys_gzmw4rGJfuqixMLSH01MNr0CXCtXCM_16sx2TtnrrID2xxQVxn-FGTDZV40HPYScQImnel-PRg4AOxswr5gCQqtyCiJi_ahg6mPhO-xdJrSp2dnB-b474pSABLepsGRUlnxMxf3Rl6RJWxaOXPKoWoQGFxXvHcKhowCJLnfN4Wr2ksM-XD5Vk9XAYkcwV_dSGLRVzBfC8b6QxIP3YRH8biKui-hiHSGPjzIulWAOck6ojgG9iqqFq7kifdlyO-dP2XE_nhXSPL8Qrjde8pLOwXx-dRq9PUPcGHRdgp1X9znfCd9-WZSpbHrqNIX64NDVbsM6uKGQEkI9wMxPy_pH60UsnCwcYKmWXZjnh_KRT1aYgEkjpllrN30FFZaBw6u9zCOYipA6vkkDlessdNzVb5Hfd2pSs7_IRFgjTAmRVmEMMRVcHmJ3Afl3plyANJ-jAbh1CEdhxlR7dRJQ8X6OOvieD1d9Ny40nBIUjFI6lEqyxGrfz7K6rJDXq_GWOWtsNYfCyb4P1aQ_Fwq6qzQ-maWwgo6JyRNbyDp_kcy0tfOQsevYNBsK8OcCzwV9oGvMl02Q-0U5-uAKeQUZc7TrpOkZJ9SPkYlZuS3FIcbPhHHQE7ZoaHM9H9i2g93tbBJILzM4DbnE-HvAI0pms6-rP_7-BNxtIv1RlSc