ct.Method;\\nimport java.util.Collections;\\nimport java.util.List;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class Swagger_annotationsTest {\\n    @Test\\n    void topLevelInfoAndSecurityAnnotationsRetainDocumentationMetadata() {\\n        Info info = AnnotatedPetApi.class.getAnnotationsByType(Info.class)[0];\\n        assertThat(info.title()).isEqualTo(\\\"Pet API\\\");\\n        assertThat(info.version()).isEqualTo(\\\"1.0\\\");\\n        assertThat(info.description()).isEqualTo(\\\"Endpoints for looking up pets\\\");\\n        assertThat(info.termsOfService()).isEqualTo(\\\"https://example.test/terms\\\");\\n        assertThat(info.contact().name()).isEqualTo(\\\"API Support\\\");\\n        assertThat(info.contact().url()).isEqualTo(\\\"https://example.test/support\\\");\\n        assertThat(info.contact().email()).isEqualTo(\\\"support@example.test\\\");\\n        assertThat(info.license().name()).isEqualTo(\\\"Apache-2.0\\\");\\n        assertThat(info.license().url()).isEqualTo(\\\"https://www.apache.org/licenses/LICENSE-2.0\\\");\\n\\n        SecurityScheme securityScheme = AnnotatedPetApi.class.getAnnotationsByType(SecurityScheme.class)[0];\\n        assertThat(securityScheme.type()).isEqualTo(\\\"oauth2\\\");\\n        assertThat(securityScheme.name()).isEqualTo(\\\"oauth2\\\");\\n        assertThat(securityScheme.description()).isEqualTo(\\\"OAuth2 authorization code flow\\\");\\n        assertThat(securityScheme.flows().authorizationCode().authorizationUrl())\\n                .isEqualTo(\\\"https://auth.example.test/authorize\\\");\\n        assertThat(securityScheme.flows().authorizationCode().tokenUrl())\\n                .isEqualTo(\\\"https://auth.example.test/token\\\");\\n        assertThat(securityScheme.flows().authorizationCode().refreshUrl())\\n                .isEqualTo(\\\"https://auth.example.test/refresh\\\");\\n        assertThat(securityScheme.flows().authorizationCode().scopes().name()).isEqualTo(\\\"pets:read\\\");\\n        assertThat(securityScheme.flows().authorizationCode().scopes().description()).isEqualTo(\\\"Read pet records\\\");\\n\\n        SecurityRequirement requirement = AnnotatedPetApi.class.getAnnotationsByType(SecurityRequirement.class)[0];\\n        assertThat(requirement.name()).isEqualTo(\\\"oauth2\\\");\\n        assertThat(requirement.scopes()).containsExactly(\\\"pets:read\\\", \\\"pets:write\\\");\\n    }\\n\\n    @Test\\n    void operationAnnotationRetainsResponsesRequestBodyServersExtensionsAndParameters() throws NoSuchMethodException {\\n        Method findPets = PetResource.class.getDeclaredMethod(\\\"findPets\\\", String.class, int.class, Pet.class);\\n        Operation operation = findPets.getAnnotationsByType(Operation.class)[0];\\n\\n        assertThat(operation.method()).isEqualTo(\\\"GET\\\");\\n        assertThat(operation.tags()).containsExactly(\\\"pets\\\", \\\"search\\\");\\n        assertThat(operation.summary()).isEqualTo(\\\"Find pets\\\");\\n        assertThat(operation.description()).isEqualTo(\\\"Returns a bounded collection of pets matching the requested type\\\");\\n        assertThat(operation.operationId()).isEqualTo(\\\"findPetsByType\\\");\\n        assertThat(operation.deprecated()).isFalse();\\n        assertThat(operation.externalDocs().description()).isEqualTo(\\\"Pet guide\\\");\\n        assertThat(operation.externalDocs().url()).isEqualTo(\\\"https://example.test/docs/pets\\\");\\n\\n        Parameter filter = operation.parameters()[0];\\n        assertThat(filter.name()).isEqualTo(\\\"type\\\");\\n        assertThat(filter.in()).isEqualTo(\\\"query\\\");\\n        assertThat(filter.description()).isEqualTo(\\\"Pet type filter\\\");\\n        assertThat(filter.required()).isTrue();\\n        assertThat(filter.allowEmptyValue()).isFalse();\\n        assertThat(filter.style()).isEqualTo(\\\"form\\\");\\n        assertThat(filter.explode()).isEqualTo(Explode.FALSE);\\n        assertThat(filter.schema().type()).isEqualTo(\\\"string\\\");\\n        assertThat(filter.schema()._enum()).containsExactly(\\\"dog\\\", \\\"cat\\\", \\\"bird\\\");\\n        assertThat(filter.content()[0].mediaType()).isEqualTo(\\\"text/plain\\\");\\n        assertThat(filter.content()[0].examples()[0].value()).isEqualTo(\\\"cat\\\");\\n\\n        RequestBody body = operation.requestBody();\\n        assertThat(body.description()).isEqualTo(\\\"Pet to merge into search defaults\\\");\\n        assertThat(body.required()).isFalse();\\n        assertThat(body.content()[0].mediaType()).isEqualTo(\\\"application/json\\\");\\n        assertThat(body.content()[0].schema().implementation()).isEqualTo(Pet.class);\\n\\n        ApiResponse ok = operation.responses()[0];\\n        assertThat(ok.responseCode()).isEqualTo(\\\"200\\\");\\n        assertThat(ok.description()).isEqualTo(\\\"Pets were returned\\\");\\n        assertThat(ok.content().mediaType()).isEqualTo(\\\"application/json\\\");\\n        assertThat(ok.content().schema().implementation()).isEqualTo(Pet.class);\\n        assertThat(ok.content().examples()[0].name()).isEqualTo(\\\"pets\\\");\\n        assertThat(ok.content().examples()[0].value()).contains(\\\"Fido\\\");\\n        assertThat(ok.links()[0].name()).isEqualTo(\\\"self\\\");\\n        assertThat(ok.links()[0].operationId()).isEqualTo(\\\"findPetsByType\\\");\\n        assertThat(ok.links()[0].parameters().name()).isEqualTo(\\\"id\\\");\\n        assertThat(ok.links()[0].parameters().expression()).isEqualTo(\\\"$response.body#/0/id\\\");\\n\\n        ApiResponse notFound = operation.responses()[1];\\n        assertThat(notFound.responseCode()).isEqualTo(\\\"404\\\");\\n        assertThat(notFound.description()).isEqualTo(\\\"No pets matched\\\");\\n\\n        Server server = operation.servers()[0];\\n        assertThat(server.url()).isEqualTo(\\\"https://{environment}.example.test/v1\\\");\\n        assertThat(server.description()).isEqualTo(\\\"Pet API server\\\");\\n        assertThat(server.variables()[0].name()).isEqualTo(\\\"environment\\\");\\n        assertThat(server.variables()[0].allowableValues()).containsExactly(\\\"api\\\", \\\"staging\\\");\\n        assertThat(server.variables()[0].value()).isEqualTo(\\\"api\\\");\\n\\n        Extension extension = operation.extensions()[0];\\n        assertThat(extension.name()).isEqualTo(\\\"x-operation\\\");\\n        assertThat(extension.properties()[0].name()).isEqualTo(\\\"cached\\\");\\n        assertThat(extension.properties()[0].value()).isEqualTo(\\\"true\\\");\\n    }\\n\\n    @Test\\n    void schemaArrayAndParameterAnnotationsRetainModelDetails() throws NoSuchFieldException, NoSuchMethodException {\\n        Schema model = Pet.class.getAnnotationsByType(Schema.class)[0];\\n        assertThat(model.name()).isEqualTo(\\\"Pet\\\");\\n        assertThat(model.title()).isEqualTo(\\\"Pet\\\");\\n        assertThat(model.description()).isEqualTo(\\\"A pet visible through the API\\\");\\n        assertThat(model.implementation()).isEqualTo(Pet.class);\\n        assertThat(model.allOf()).containsExactly(BasePet.class);\\n        assertThat(model.oneOf()).containsExactly(Dog.class, Cat.class);\\n        assertThat(model.requiredProperties()).containsExactly(\\\"id\\\", \\\"name\\\");\\n        assertThat(model.discriminatorProperty()).isEqualTo(\\\"kind\\\");\\n        assertThat(model.discriminatorMapping()[0].value()).isEqualTo(\\\"dog\\\");\\n        assertThat(model.discriminatorMapping()[0].schema()).isEqualTo(Dog.class);\\n        assertThat(model.ref()).isEqualTo(\\\"#/components/schemas/Pet\\\");\\n        assertThat(model.externalDocs().url()).isEqualTo(\\\"https://example.test/docs/pet-schema\\\");\\n\\n        Field nameField = Pet.class.getDeclaredField(\\\"name\\\");\\n        Schema name = nameField.getAnnotationsByType(Schema.class)[0];\\n        assertThat(name.name()).isEqualTo(\\\"name\\\");\\n        assertThat(name.description()).isEqualTo(\\\"Display name\\\");\\n        assertThat(name.type()).isEqualTo(\\\"string\\\");\\n        assertThat(name.format()).isEqualTo(\\\"pet-name\\\");\\n        assertThat(name.required()).isTrue();\\n        assertThat(name._enum()).containsExactly(\\\"Fido\\\", \\\"Garfield\\\");\\n        assertThat(name.example()).isEqualTo(\\\"Fido\\\");\\n        assertThat(name.examples()).containsExactly(\\\"Fido\\\", \\\"Garfield\\\");\\n        assertThat(name._default()).isEqualTo(\\\"Fido\\\");\\n        assertThat(name.minLength()).isEqualTo(1);\\n        assertThat(name.maxLength()).isEqualTo(64);\\n        assertThat(name.pattern()).isEqualTo(\\\"[A-Za-z]+[A-Za-z -]*\\\");\\n        assertThat(name.nullable()).isFalse();\\n        assertThat(name.readOnly()).isFalse();\\n        assertThat(name.writeOnly()).isFalse();\\n\\n        Field aliasesField = Pet.class.getDeclaredField(\\\"aliases\\\");\\n        ArraySchema aliases = aliasesField.getAnnotationsByType(ArraySchema.class)[0];\\n        assertThat(aliases.minItems()).isEqualTo(1);\\n        assertThat(aliases.maxItems()).isEqualTo(5);\\n        assertThat(aliases.uniqueItems()).isTrue();\\n        assertThat(aliases.schema().type()).isEqualTo(\\\"string\\\");\\n\\n        Method getIdentifier = Pet.class.getDeclaredMethod(\\\"getIdentifier\\\");\\n        Schema identifier = getIdentifier.getAnnotationsByType(Schema.class)[0];\\n        assertThat(identifier.name()).isEqualTo(\\\"id\\\");\\n        assertThat(identifier.readOnly()).isTrue();\\n        assertThat(identifier.hidden()).isFalse();\\n\\n        Parameter limit = PetResource.class.getDeclaredMethod(\\\"findPets\\\", String.class, int.class, Pet.class)\\n                .getParameters()[1]\\n                .getAnnotationsByType(Parameter.class)[0];\\n        assertThat(limit.name()).isEqualTo(\\\"limit\\\");\\n        assertThat(limit.in()).isEqualTo(\\\"query\\\");\\n        assertThat(limit.description()).isEqualTo(\\\"Maximum result count\\\");\\n        assertThat(limit.required()).isTrue();\\n        assertThat(limit.schema().type()).isEqualTo(\\\"integer\\\");\\n        assertThat(limit.schema().format()).isEqualTo(\\\"int32\\\");\\n        assertThat(limit.schema().minimum()).isEqualTo(\\\"1\\\");\\n        assertThat(limit.schema().maximum()).isEqualTo(\\\"100\\\");\\n    }\\n\\n    @Test\\n    void visibilityAndParameterOptionAnnotationsRetainDocumentationControls()\\n            throws NoSuchFieldException, NoSuchMethodException {\\n        Method purgeCache = AdministrativeResource.class.getDeclaredMethod(\\\"purgeCache\\\", List.class);\\n        Operation operation = purgeCache.getAnnotationsByType(Operation.class)[0];\\n        assertThat(operation.summary()).isEqualTo(\\\"Purge cache\\\");\\n        assertThat(operation.deprecated()).isTrue();\\n\\n        Parameter implicitParam = purgeCache.getAnnotationsByType(Parameter.class)[0];\\n        assertThat(implicitParam.name()).isEqualTo(\\\"cacheName\\\");\\n        assertThat(implicitParam.description()).isEqualTo(\\\"Cache names to purge\\\");\\n        assertThat(implicitParam.allowEmptyValue()).isTrue();\\n        assertThat(implicitParam.allowReserved()).isTrue();\\n        assertThat(implicitParam.deprecated()).isTrue();\\n        assertThat(implicitParam.hidden()).isTrue();\\n\\n        Parameter parameter = purgeCache.getParameters()[0].getAnnotationsByType(Parameter.class)[0];\\n        assertThat(parameter.name()).isEqualTo(\\\"cacheNames\\\");\\n        assertThat(parameter.array().schema().type()).isEqualTo(\\\"string\\\");\\n        assertThat(parameter.array().uniqueItems()).isTrue();\\n        assertThat(parameter.hidden()).isTrue();\\n\\n        Field auditNoteField = AdministrativeRequest.class.getDeclaredField(\\\"auditNote\\\");\\n        Schema auditNote = auditNoteField.getAnnotationsByType(Schema.class)[0];\\n        assertThat(auditNote.description()).isEqualTo(\\\"Internal audit note\\\");\\n        assertThat(auditNote.writeOnly()).isTrue();\\n        assertThat(auditNote.hidden()).isTrue();\\n    }\\n\\n    @Test\\n    void enumHelpersPreserveDeclarationOrder() {\\n        assertThat(Explode.values()).containsExactly(Explode.DEFAULT, Explode.FALSE, Explode.TRUE);\\n    }\\n\\n    @Info(\\n            title = \\\"Pet API\\\",\\n            version = \\\"1.0\\\",\\n            description = \\\"Endpoints for looking up pets\\\",\\n            termsOfService = \\\"https://example.test/terms\\\",\\n            contact = @Contact(\\n                    name = \\\"API Support\\\",\\n                    url = \\\"https://example.test/support\\\",\\n                    email = \\\"support@example.test\\\"),\\n            license = @License(\\n                    name = \\\"Apache-2.0\\\",\\n                    url = \\\"https://www.apache.org/licenses/LICENSE-2.0\\\"))\\n    @SecurityScheme(\\n            type = \\\"oauth2\\\",\\n            name = \\\"oauth2\\\",\\n            description = \\\"OAuth2 authorization code flow\\\",\\n            flows = @io.swagger.oas.annotations.security.OAuthFlows(\\n                    authorizationCode = @OAuthFlow(\\n                            authorizationUrl = \\\"https://auth.example.test/authorize\\\",\\n                            tokenUrl = \\\"https://auth.example.test/token\\\",\\n                            refreshUrl = \\\"https://auth.example.test/refresh\\\",\\n                            scopes = @io.swagger.oas.annotations.security.Scopes(\\n                                    name = \\\"pets:read\\\",\\n                                    description = \\\"Read pet records\\\"))))\\n    @SecurityRequirement(name = \\\"oauth2\\\", scopes = {\\\"pets:read\\\", \\\"pets:write\\\"})\\n    private static final class AnnotatedPetApi {\\n    }\\n\\n    private static final class PetResource {\\n        @Operation(\\n                method = \\\"GET\\\",\\n                tags = {\\\"pets\\\", \\\"search\\\"},\\n                summary = \\\"Find pets\\\",\\n                descriptio