port io.swagger.oas.annotations.security.SecurityScheme;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Collections;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class Swagger_annotationsTest {\n    @Test\n    void typeAnnotationsRetainInfoSecuritySchemeAndSecurityRequirementMetadata() {\n        Info info = AnnotatedPetApi.class.getAnnotationsByType(Info.class)[0];\n        assertThat(info.title()).isEqualTo(\"Pet API\");\n        assertThat(info.version()).isEqualTo(\"1.0\");\n        assertThat(info.description()).isEqualTo(\"Endpoints for looking up pets\");\n        assertThat(info.termsOfService()).isEqualTo(\"https://example.test/terms\");\n        assertThat(info.contact().name()).isEqualTo(\"API Support\");\n        assertThat(info.contact().url()).isEqualTo(\"https://example.test/support\");\n        assertThat(info.contact().email()).isEqualTo(\"support@example.test\");\n        assertThat(info.license().name()).isEqualTo(\"Apache-2.0\");\n        assertThat(info.license().url()).isEqualTo(\"https://www.apache.org/licenses/LICENSE-2.0\");\n\n        SecurityScheme securityScheme = AnnotatedPetApi.class.getAnnotationsByType(SecurityScheme.class)[0];\n        assertThat(securityScheme.type()).isEqualTo(\"oauth2\");\n        assertThat(securityScheme.name()).isEqualTo(\"OAuth access code\");\n        assertThat(securityScheme.description()).isEqualTo(\"OAuth2 access code flow\");\n        assertThat(securityScheme.in()).isEqualTo(\"header\");\n        assertThat(securityScheme.scheme()).isEqualTo(\"bearer\");\n        assertThat(securityScheme.bearerFormat()).isEqualTo(\"JWT\");\n        assertThat(securityScheme.openIdConnectUrl()).isEqualTo(\"https://auth.example.test/.well-known/openid-configuration\");\n        assertThat(securityScheme.flows().authorizationCode().authorizationUrl())\n                .isEqualTo(\"https://auth.example.test/authorize\");\n        assertThat(securityScheme.flows().authorizationCode().tokenUrl()).isEqualTo(\"https://auth.example.test/token\");\n        assertThat(securityScheme.flows().authorizationCode().refreshUrl()).isEqualTo(\"https://auth.example.test/refresh\");\n        assertThat(securityScheme.flows().authorizationCode().scopes().name()).isEqualTo(\"pets:read\");\n        assertThat(securityScheme.flows().authorizationCode().scopes().description()).isEqualTo(\"Read pet records\");\n\n        SecurityRequirement requirement = AnnotatedPetApi.class.getAnnotationsByType(SecurityRequirement.class)[0];\n        assertThat(requirement.name()).isEqualTo(\"oauth2\");\n        assertThat(requirement.scopes()).containsExactly(\"pets:read\", \"pets:write\");\n    }\n\n    @Test\n    void operationAnnotationsRetainNestedParametersResponsesExamplesAndExtensions() throws NoSuchMethodException {\n        Method findPets = PetResource.class.getDeclaredMethod(\"findPets\", String.class, int.class);\n        Operation operation = findPets.getAnnotationsByType(Operation.class)[0];\n\n        assertThat(operation.method()).isEqualTo(\"GET\");\n        assertThat(operation.tags()).containsExactly(\"pets\", \"search\");\n        assertThat(operation.summary()).isEqualTo(\"Find pets\");\n        assertThat(operation.description()).isEqualTo(\"Returns a bounded collection of pets matching the requested type\");\n        assertThat(operation.operationId()).isEqualTo(\"findPetsByType\");\n        assertThat(operation.deprecated()).isFalse();\n        assertThat(operation.externalDocs().description()).isEqualTo(\"Pet guide\");\n        assertThat(operation.externalDocs().url()).isEqualTo(\"https://example.test/docs/pets\");\n        assertThat(operation.extensions()[0].name()).isEqualTo(\"operation\");\n        assertThat(operation.extensions()[0].properties()[0].name()).isEqualTo(\"cached\");\n        assertThat(operation.extensions()[0].properties()[0].value()).isEqualTo(\"true\");\n\n        Parameter typeFilter = operation.parameters()[0];\n        assertThat(typeFilter.name()).isEqualTo(\"type\");\n        assertThat(typeFilter.in()).isEqualTo(\"query\");\n        assertThat(typeFilter.description()).isEqualTo(\"Pet type filter\");\n        assertThat(typeFilter.required()).isTrue();\n        assertThat(typeFilter.allowEmptyValue()).isFalse();\n        assertThat(typeFilter.deprecated()).isFalse();\n        assertThat(typeFilter.style()).isEqualTo(\"form\");\n        assertThat(typeFilter.explode()).isEqualTo(Explode.FALSE);\n        assertThat(typeFilter.allowReserved()).isTrue();\n        assertThat(typeFilter.hidden()).isFalse();\n        assertThat(typeFilter.schema().type()).isEqualTo(\"string\");\n        assertThat(typeFilter.schema()._enum()).containsExactly(\"dog\", \"cat\", \"bird\");\n        assertThat(typeFilter.schema()._default()).isEqualTo(\"dog\");\n        assertThat(typeFilter.content()[0].mediaType()).isEqualTo(\"text/plain\");\n        assertThat(typeFilter.content()[0].examples()[0].name()).isEqualTo(\"cat-example\");\n        assertThat(typeFilter.content()[0].examples()[0].summary()).isEqualTo(\"Cat search\");\n        assertThat(typeFilter.content()[0].examples()[0].value()).isEqualTo(\"cat\");\n        assertThat(typeFilter.content()[0].examples()[0].externalValue()).isEqualTo(\"https://example.test/examples/cat.txt\");\n\n        Parameter resultFields = operation.parameters()[1];\n        assertThat(resultFields.name()).isEqualTo(\"fields\");\n        assertThat(resultFields.array().minItems()).isEqualTo(1);\n        assertThat(resultFields.array().maxItems()).isEqualTo(5);\n        assertThat(resultFields.array().uniqueItems()).isTrue();\n        assertThat(resultFields.array().schema().type()).isEqualTo(\"string\");\n\n        ApiResponse response = operation.responses()[0];\n        assertThat(response.responseCode()).isEqualTo(\"200\");\n        assertThat(response.description()).isEqualTo(\"Pets were returned\");\n        assertThat(response.content().mediaType()).isEqualTo(\"application/json\");\n        assertThat(response.content().schema().implementation()).isEqualTo(Pet.class);\n        assertThat(response.content().schema().type()).isEqualTo(\"array\");\n        assertThat(response.content().examples()[0].value()).contains(\"Fido\");\n\n        ApiResponse notFound = operation.responses()[1];\n        assertThat(notFound.responseCode()).isEqualTo(\"404\");\n        assertThat(notFound.description()).isEqualTo(\"No pets matched\");\n    }\n\n    @Test\n    void schemaAnnotationsRetainModelAndPropertyDetails() throws NoSuchFieldException, NoSuchMethodException {\n        Schema petSchema = Pet.class.getAnnotationsByType(Schema.class)[0];\n        assertThat(petSchema.name()).isEqualTo(\"Pet\");\n        assertThat(petSchema.title()).isEqualTo(\"Pet resource\");\n        assertThat(petSchema.description()).isEqualTo(\"A pet visible through the API\");\n        assertThat(petSchema.implementation()).isEqualTo(Pet.class);\n        assertThat(petSchema.allOf()).containsExactly(BasePet.class);\n        assertThat(petSchema.oneOf()).containsExactly(Dog.class, Cat.class);\n        assertThat(petSchema.requiredProperties()).containsExactly(\"identifier\", \"name\");\n        assertThat(petSchema.discriminatorProperty()).isEqualTo(\"kind\");\n        assertThat(petSchema.ref()).isEqualTo(\"#/components/schemas/Pet\");\n        assertThat(petSchema.externalDocs().description()).isEqualTo(\"Pet schema guide\");\n        assertThat(petSchema.externalDocs().url()).isEqualTo(\"https://example.test/docs/schemas/pet\");\n\n        Field nameField = Pet.class.getDeclaredField(\"name\");\n        Schema name = nameField.getAnnotationsByType(Schema.class)[0];\n        assertThat(name.name()).isEqualTo(\"name\");\n        assertThat(name.title()).isEqualTo(\"Display name\");\n        assertThat(name.description()).isEqualTo(\"Names are shown in search results\");\n        assertThat(name.type()).isEqualTo(\"string\");\n        assertThat(name.format()).isEqualTo(\"display-name\");\n        assertThat(name.required()).isTrue();\n        assertThat(name.minLength()).isEqualTo(1);\n        assertThat(name.maxLength()).isEqualTo(40);\n        assertThat(name.pattern()).isEqualTo(\"[A-Za-z ]+\");\n        assertThat(name._enum()).containsExactly(\"Fido\", \"Garfield\");\n        assertThat(name._default()).isEqualTo(\"Fido\");\n        assertThat(name.example()).isEqualTo(\"Fido\");\n        assertThat(name.examples()).containsExactly(\"Fido\", \"Garfield\");\n        assertThat(name.readOnly()).isFalse();\n        assertThat(name.writeOnly()).isFalse();\n        assertThat(name.nullable()).isFalse();\n        assertThat(name.hidden()).isFalse();\n\n        Method getIdentifier = Pet.class.getDeclaredMethod(\"getIdentifier\");\n        Schema identifier = getIdentifier.getAnnotationsByType(Schema.class)[0];\n        assertThat(identifier.name()).isEqualTo(\"id\");\n        assertThat(identifier.description()).isEqualTo(\"Stable identifier\");\n        assertThat(identifier.readOnly()).isTrue();\n        assertThat(identifier.hidden()).isFalse();\n    }\n\n    @Test\n    void methodParameterAndContainerAnnotationsRetainRequestParameterControls() throws NoSuchMethodException {\n        Method purgeCache = AdministrativeResource.class.getDeclaredMethod(\"purgeCache\", List.class);\n        Parameters parameters = purgeCache.getAnnotationsByType(Parameters.class)[0];\n        assertThat(parameters.parameters()).hasSize(1);\n        assertThat(parameters.parameters()[0].name()).isEqualTo(\"cacheName\");\n        assertThat(parameters.parameters()[0].allowEmptyValue()).isTrue();\n        assertThat(parameters.value()).hasSize(1);\n        assertThat(parameters.value()[0].name()).isEqualTo(\"audit\");\n        assertThat(parameters.value()[0].hidden()).isTrue();\n\n        Parameter methodParameter = purgeCache.getParameters()[0].getAnnotationsByType(Parameter.class)[0];\n        assertThat(methodParameter.name()).isEqualTo(\"cacheNames\");\n        assertThat(methodParameter.in()).isEqualTo(\"query\");\n        assertThat(methodParameter.description()).isEqualTo(\"Cache names to purge\");\n        assertThat(methodParameter.required()).isTrue();\n        assertThat(methodParameter.allowEmptyValue()).isTrue();\n        assertThat(methodParameter.deprecated()).isTrue();\n        assertThat(methodParameter.hidden()).isTrue();\n        assertThat(methodParameter.array().schema().type()).isEqualTo(\"string\");\n        assertThat(methodParameter.array().minItems()).isEqualTo(1);\n    }\n\n    @Test\n    void arraySchemaAndHiddenSchemaAnnotationsRetainFieldControls() throws NoSuchFieldException {\n        Field relatedPets = Pet.class.getDeclaredField(\"relatedPets\");\n        ArraySchema arraySchema = relatedPets.getAnnotationsByType(ArraySchema.class)[0];\n        assertThat(arraySchema.schema().implementation()).isEqualTo(Pet.class);\n        assertThat(arraySchema.maxItems()).isEqualTo(3);\n        assertThat(arraySchema.minItems()).isEqualTo(0);\n        assertThat(arraySchema.uniqueItems()).isTrue();\n\n        Field auditNoteField = AdministrativeRequest.class.getDeclaredField(\"auditNote\");\n        Schema auditNote = auditNoteField.getAnnotationsByType(Schema.class)[0];\n        assertThat(auditNote.name()).isEqualTo(\"auditNote\");\n        assertThat(auditNote.description()).isEqualTo(\"Internal audit note\");\n        assertThat(auditNote.hidden()).isTrue();\n        assertThat(auditNote.writeOnly()).isTrue();\n        assertThat(auditNote.nullable()).isTrue();\n    }\n\n    @Test\n    void enumHelpersPreserveDeclarationOrder() {\n        assertThat(Explode.values()).containsExactly(Explode.DEFAULT, Explode.FALSE, Explode.TRUE);\n    }\n\n    @Info(\n            title = \"Pet API\",\n            version = \"1.0\",\n            description = \"Endpoints for looking up pets\",\n            termsOfService = \"https://example.test/terms\",\n            contact = @Contact(\n                    name = \"API Support\",\n                    url = \"https://example.test/support\",\n                    email = \"support@example.test\"),\n            license = @License(\n                    name = \"Apache-2.0\",\n                    url = \"https://www.apache.org/licenses/LICENSE-2.0\"))\n    @SecurityScheme(\n            type = \"oauth2\",\n            name = \"OAuth access code\",\n            description = \"OAuth2 access code flow\",\n            in = \"header\",\n            scheme = \"bearer\",\n            bearerFormat = \"JWT\",\n            flows = @OAuthFlows(\n                    authorizationCode = @OAuthFlow(\n                            authorizationUrl = \"https://auth.example.test/authorize\",\n                            tokenUrl = \"https://auth.example.test/token\",\n                            refreshUrl = \"https://auth.example.test/refresh\",\n                            scopes = @Scopes(name = \"pets:read\", description = \"Read pet records\"))),\n            openIdConnectUrl = \"https://auth.example.test/.well-known/openid-configuration\")\n    @SecurityRequirement(name = \"oauth2\", scopes = {\"pets:read\", \"pets:write\"})\n    private static final class AnnotatedPetApi {\n    }\n\n    private static final class PetResource {\n        @Operation(\n                method = \"GET\",\n                tags = {\"pets\", \"search\"},\n                summary = \"Find pets\",\n                description = \"Returns a bounded collection of pets matching the requested type\",\n                externalDocs = @ExternalDocumentation(\n                        description = \"Pet guide\",\n                        url = \"https://example.test/docs/pets\"),\n                operationId = \"findPetsByType\",\n                parameters = {\n                        @Parameter(\n                                name = \"type\",\n                                in = \"query\",\n                                description = \"Pet type filter\",\n                                required = true,\n                                style = \"form\",\n                                explode = Explode.FALSE,\n                                allowReserved = true,\n                                schema = @Schema(type = \"string\", _enum = {\"dog\", \"cat\", \"bird\"}, _default = \"dog\"),\n                                content = @Content(\n                                        mediaType = \"text/plain\",\n                                        examples = @ExampleObject(\n                                                name = \"cat-example\",\n                                                summary = \"Cat search\",\n                                                value = \"cat\",\n                                                externalValue = \"https://example.test/examples/cat.txt\"))),\n                        @Parameter(\n                                name = \"fields\",\n                                in = \"query\",\n                                description = \"Fields to include\",\n                                array = @ArraySchema(\n                                        schema = @Schema(type = \"string\"),\n                                        minItems = 1,\n                                        maxItems = 5,\n                                        uniqueItems = true))\n                },\n                responses = {\n                        @ApiResponse(\n                                responseCode = \"200\",\n                                description = \"Pets were returned\",\n                                content = @Content(\n                                        mediaType = \"application/json\",\n                                        schema = @Schema(implementation = Pet.class, type = \"array\"),\n                                        examples = @ExampleObject(\n                                                name = \"pets\",\n                                                value = \"[{\\\"name\\\":\\\"Fido\\\"}]\"))),\n                        @ApiResponse(responseCode = \"404\", description = \"No pets matched\")\n                },\n                extensions = @Extension(\n                        name = \"operation\",\n                        properties = @ExtensionProperty(name = \"cached\", value = \"true\")))\n        private List<Pet> findPets(String type, int limit) {\n            return Collections.singletonList(new Pet(\"pet-1\", type + '-' + limit));\n        }\n    }\n\n    private static final class AdministrativeResource {\n        @Parameters(\n                parameters = @Parameter(\n                        name = \"cacheName\",\n                        in = \"query\",\n                        description = \"Cache names to purge\",\n                        allowEmptyValue = true),\n                value = @Parameter(\n                        name = \"audit\",\n                        in = \"header\",\n                        description = \"Audit flag\",\n                        hidden = true))\n        private void purgeCache(\n                @Parameter(\n                        name = \"cacheNames\",\n                        in = \"query\",\n                        description = \"Cache names to purge\",\n                        required = true,\n                        deprecated = true,\n                        allowEmptyValue = true,\n                        hidden = true,\n                        array = @ArraySchema(schema = @Schema(type = \"string\"), minItems = 1)) List<String> cacheNames) {\n        }\n    }\n\n    private static final class AdministrativeRequest {\n        @Schema(\n                name = \"auditNote\",\n                description = \"Internal audit note\",\n                nullable = true,\n                writeOnly = true,\n                hidden = true)\n        private final String auditNote = \"\";\n    }\n\n    private static class BasePet {\n    }\n\n    private static final class Dog extends Pet {\n        private Dog() {\n            super(\"dog-1\", \"Fido\");\n        }\n    }\n\n    private static final class Cat extends Pet {\n        private Cat() {\n            super(\"cat-1\", \"Garfield\");\n        }\n    }\n\n    @Schema(\n            implementation = Pet.class,\n            allOf = BasePet.class,\n            oneOf = {Dog.class, Cat.class},\n            name = \"Pet\",\n            title = \"Pet resource\",\n            requiredProperties = {\"identifier\", \"name\"},\n            description = \"A pet visible through the API\",\n            ref = \"#/components/schemas/Pet\",\n            discriminatorProperty = \"kind\",\n            externalDocs = @ExternalDocumentation(\n                    description = \"Pet schema guide\",\n                    url = \"https://example.test/docs/schemas/pet\"))\n    private static class Pet extends BasePet {\n        private final String identifier;\n\n        @Schema(\n                name = \"name\",\n                title = \"Display name\",\n                description = \"Names are shown in search results\",\n                type = \"string\",\n                format = \"display-name\",\n                minLength = 1,\n                maxLength = 40,\n                pattern = \"[A-Za-z ]+\",\n                required = true,\n                _enum = {\"Fido\", \"Garfield\"},\n                _default = \"Fido\",\n                examples = {\"Fido\", \"Garfield\"},\n                example = \"Fido\")\n        private final String name;\n\n        @ArraySchema(\n                schema = @Schema(implementation = Pet.class),\n                maxItems = 3,\n                minItems = 0,\n                uniqueItems = true)\n        private final List<Pet> relatedPets = Collections.emptyList();\n\n        private Pet(String identifier, String name) {\n            this.identifier = identifier;\n            this.name = name;\n        }\n\n        @Schema(\n                name = \"id\",\n                description = \"Stable identifier\",\n                readOnly = true)\n        private String getIdentifier() {\n            return identifier;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1451, "output": 5789, "cacheRead": 40960, "cacheWrite": 0, "totalTokens": 48200, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777890971006, "responseId": "resp_0eaf469516eab3af0169f8769b7554819f9934767450512024"}}
