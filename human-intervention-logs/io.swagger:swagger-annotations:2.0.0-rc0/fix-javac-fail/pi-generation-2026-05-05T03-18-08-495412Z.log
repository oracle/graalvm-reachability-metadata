ackage io_swagger.swagger_annotations;\n\nimport io.swagger.oas.annotations.ExternalDocumentation;\nimport io.swagger.oas.annotations.Operation;\nimport io.swagger.oas.annotations.Parameter;\nimport io.swagger.oas.annotations.callbacks.Callback;\nimport io.swagger.oas.annotations.enums.Explode;\nimport io.swagger.oas.annotations.extensions.Extension;\nimport io.swagger.oas.annotations.info.Contact;\nimport io.swagger.oas.annotations.info.Info;\nimport io.swagger.oas.annotations.info.License;\nimport io.swagger.oas.annotations.links.Link;\nimport io.swagger.oas.annotations.media.ArraySchema;\nimport io.swagger.oas.annotations.media.Content;\nimport io.swagger.oas.annotations.media.ExampleObject;\nimport io.swagger.oas.annotations.media.Schema;\nimport io.swagger.oas.annotations.parameters.RequestBody;\nimport io.swagger.oas.annotations.responses.ApiResponse;\nimport io.swagger.oas.annotations.security.OAuthFlow;\nimport io.swagger.oas.annotations.security.SecurityRequirement;\nimport io.swagger.oas.annotations.security.SecurityScheme;\nimport io.swagger.oas.annotations.servers.Server;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Collections;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class Swagger_annotationsTest {\n    @Test\n    void typeAnnotationsRetainDocumentationCallbacksAndSecurityMetadata() {\n        Info info = AnnotatedPetApi.class.getAnnotationsByType(Info.class)[0];\n        assertThat(info.title()).isEqualTo(\"Pet API\");\n        assertThat(info.version()).isEqualTo(\"1.0\");\n        assertThat(info.description()).isEqualTo(\"Endpoints for looking up pets\");\n        assertThat(info.termsOfService()).isEqualTo(\"https://example.test/terms\");\n        assertThat(info.contact().name()).isEqualTo(\"API Support\");\n        assertThat(info.contact().url()).isEqualTo(\"https://example.test/support\");\n        assertThat(info.contact().email()).isEqualTo(\"support@example.test\");\n        assertThat(info.license().name()).isEqualTo(\"Apache-2.0\");\n        assertThat(info.license().url()).isEqualTo(\"https://www.apache.org/licenses/LICENSE-2.0\");\n\n        SecurityScheme securityScheme = AnnotatedPetApi.class.getAnnotationsByType(SecurityScheme.class)[0];\n        assertThat(securityScheme.type()).isEqualTo(\"oauth2\");\n        assertThat(securityScheme.description()).isEqualTo(\"OAuth2 authorization code flow\");\n        assertThat(securityScheme.name()).isEqualTo(\"petstoreAuth\");\n        assertThat(securityScheme.in()).isEqualTo(\"header\");\n        assertThat(securityScheme.scheme()).isEqualTo(\"bearer\");\n        assertThat(securityScheme.bearerFormat()).isEqualTo(\"JWT\");\n        assertThat(securityScheme.openIdConnectUrl()).isEqualTo(\"https://auth.example.test/.well-known/openid-configuration\");\n        OAuthFlow authorizationCode = securityScheme.flows().authorizationCode();\n        assertThat(authorizationCode.authorizationUrl()).isEqualTo(\"https://auth.example.test/authorize\");\n        assertThat(authorizationCode.tokenUrl()).isEqualTo(\"https://auth.example.test/token\");\n        assertThat(authorizationCode.refreshUrl()).isEqualTo(\"https://auth.example.test/refresh\");\n        assertThat(authorizationCode.scopes().name()).isEqualTo(\"pets:read\");\n        assertThat(authorizationCode.scopes().description()).isEqualTo(\"Read pet records\");\n\n        Callback callback = AnnotatedPetApi.class.getAnnotationsByType(Callback.class)[0];\n        assertThat(callback.name()).isEqualTo(\"petCreated\");\n        assertThat(callback.callbackUrlExpression()).isEqualTo(\"{$request.body#/callbackUrl}\");\n        Operation callbackOperation = callback.operation()[0];\n        assertThat(callbackOperation.method()).isEqualTo(\"POST\");\n        assertThat(callbackOperation.summary()).isEqualTo(\"Notify when a pet is created\");\n        assertThat(callbackOperation.responses()[0].responseCode()).isEqualTo(\"202\");\n        assertThat(callbackOperation.responses()[0].description()).isEqualTo(\"Callback accepted\");\n    }\n\n    @Test\n    void operationAnnotationsRetainNestedParametersResponsesServersAndExtensions() throws NoSuchMethodException {\n        Method findPets = PetResource.class.getDeclaredMethod(\"findPets\", String.class, int.class, PetSearchRequest.class);\n\n        Operation operation = findPets.getAnnotationsByType(Operation.class)[0];\n        assertThat(operation.method()).isEqualTo(\"GET\");\n        assertThat(operation.tags()).containsExactly(\"pets\", \"search\");\n        assertThat(operation.summary()).isEqualTo(\"Find pets\");\n        assertThat(operation.description()).isEqualTo(\"Returns a bounded collection of pets matching the requested type\");\n        assertThat(operation.operationId()).isEqualTo(\"findPetsByType\");\n        assertThat(operation.deprecated()).isFalse();\n        assertThat(operation.externalDocs().description()).isEqualTo(\"Pet search guide\");\n        assertThat(operation.externalDocs().url()).isEqualTo(\"https://example.test/docs/pets/search\");\n\n        Parameter type = operation.parameters()[0];\n        assertThat(type.name()).isEqualTo(\"type\");\n        assertThat(type.in()).isEqualTo(\"query\");\n        assertThat(type.description()).isEqualTo(\"Pet type filter\");\n        assertThat(type.required()).isTrue();\n        assertThat(type.deprecated()).isFalse();\n        assertThat(type.allowEmptyValue()).isFalse();\n        assertThat(type.style()).isEqualTo(\"form\");\n        assertThat(type.explode()).isEqualTo(Explode.FALSE);\n        assertThat(type.allowReserved()).isTrue();\n        assertThat(type.schema().type()).isEqualTo(\"string\");\n        assertThat(type.schema()._enum()).containsExactly(\"dog\", \"cat\", \"bird\");\n        assertThat(type.schema()._default()).isEqualTo(\"dog\");\n        assertThat(type.content()[0].mediaType()).isEqualTo(\"text/plain\");\n        assertThat(type.content()[0].examples()[0].value()).isEqualTo(\"cat\");\n\n        RequestBody requestBody = operation.requestBody();\n        assertThat(requestBody.description()).isEqualTo(\"Search options\");\n        assertThat(requestBody.required()).isTrue();\n        assertThat(requestBody.content()[0].mediaType()).isEqualTo(\"application/json\");\n        assertThat(requestBody.content()[0].schema().implementation()).isEqualTo(PetSearchRequest.class);\n\n        ApiResponse ok = operation.responses()[0];\n        assertThat(ok.responseCode()).isEqualTo(\"200\");\n        assertThat(ok.description()).isEqualTo(\"Pets were returned\");\n        assertThat(ok.content().mediaType()).isEqualTo(\"application/json\");\n        assertThat(ok.content().schema().implementation()).isEqualTo(Pet.class);\n        assertThat(ok.content().examples()[0].name()).isEqualTo(\"sample-pets\");\n        assertThat(ok.content().examples()[0].summary()).isEqualTo(\"One returned pet\");\n        assertThat(ok.content().examples()[0].value()).contains(\"Fido\");\n        assertThat(ok.links()[0].name()).isEqualTo(\"petDetails\");\n        assertThat(ok.links()[0].operationId()).isEqualTo(\"getPetById\");\n        assertThat(ok.links()[0].operationRef()).isEqualTo(\"#/paths/~1pets~1{id}/get\");\n        assertThat(ok.links()[0].parameters().name()).isEqualTo(\"id\");\n        assertThat(ok.links()[0].parameters().expression()).isEqualTo(\"$response.body#/0/id\");\n        assertThat(ok.links()[0].description()).isEqualTo(\"Read the first returned pet\");\n        assertThat(operation.responses()[1].responseCode()).isEqualTo(\"404\");\n        assertThat(operation.responses()[1].description()).isEqualTo(\"No pets matched\");\n\n        Server server = operation.servers()[0];\n        assertThat(server.url()).isEqualTo(\"https://api.example.test/v1\");\n        assertThat(server.description()).isEqualTo(\"Production API\");\n        assertThat(server.variables()[0].name()).isEqualTo(\"region\");\n        assertThat(server.variables()[0]._default()).isEqualTo(\"us\");\n        assertThat(server.variables()[0].allowableValues()).containsExactly(\"us\", \"eu\");\n        assertThat(server.variables()[0].description()).isEqualTo(\"Deployment region\");\n\n        Extension extension = operation.extensions()[0];\n        assertThat(extension.name()).isEqualTo(\"x-operation\");\n        assertThat(extension.properties()[0].name()).isEqualTo(\"cached\");\n        assertThat(extension.properties()[0].value()).isEqualTo(\"true\");\n    }\n\n    @Test\n    void schemaAndParameterAnnotationsRetainModelAndRequestMetadata() throws NoSuchFieldException, NoSuchMethodException {\n        Schema model = Pet.class.getAnnotationsByType(Schema.class)[0];\n        assertThat(model.name()).isEqualTo(\"Pet\");\n        assertThat(model.title()).isEqualTo(\"Pet\");\n        assertThat(model.description()).isEqualTo(\"A pet visible through the API\");\n        assertThat(model.implementation()).isEqualTo(Pet.class);\n        assertThat(model.allOf()).containsExactly(BasePet.class);\n        assertThat(model.oneOf()).containsExactly(Dog.class, Cat.class);\n        assertThat(model.requiredProperties()).containsExactly(\"name\", \"identifier\");\n        assertThat(model.discriminatorProperty()).isEqualTo(\"kind\");\n        assertThat(model.externalDocs().description()).isEqualTo(\"Pet model documentation\");\n        assertThat(model.externalDocs().url()).isEqualTo(\"https://example.test/docs/models/pet\");\n\n        Field nameField = Pet.class.getDeclaredField(\"name\");\n        Schema name = nameField.getAnnotationsByType(Schema.class)[0];\n        assertThat(name.name()).isEqualTo(\"name\");\n        assertThat(name.description()).isEqualTo(\"Display name\");\n        assertThat(name.type()).isEqualTo(\"string\");\n        assertThat(name.format()).isEqualTo(\"pet-name\");\n        assertThat(name.required()).isTrue();\n        assertThat(name._enum()).containsExactly(\"Fido\", \"Garfield\");\n        assertThat(name.example()).isEqualTo(\"Fido\");\n        assertThat(name.examples()).containsExactly(\"Fido\", \"Garfield\");\n        assertThat(name._default()).isEqualTo(\"Fido\");\n        assertThat(name.minLength()).isEqualTo(1);\n        assertThat(name.maxLength()).isEqualTo(64);\n        assertThat(name.pattern()).isEqualTo(\"[A-Za-z]+( [A-Za-z]+)*\");\n        assertThat(name.nullable()).isFalse();\n        assertThat(name.readOnly()).isFalse();\n        assertThat(name.writeOnly()).isFalse();\n\n        Method getIdentifier = Pet.class.getDeclaredMethod(\"getIdentifier\");\n        Schema identifier = getIdentifier.getAnnotationsByType(Schema.class)[0];\n        assertThat(identifier.name()).isEqualTo(\"id\");\n        assertThat(identifier.description()).isEqualTo(\"Stable identifier\");\n        assertThat(identifier.readOnly()).isTrue();\n        assertThat(identifier.ref()).isEqualTo(\"#/components/schemas/Pet/properties/id\");\n        assertThat(identifier.hidden()).isFalse();\n\n        Field relatedPets = Pet.class.getDeclaredField(\"relatedPets\");\n        ArraySchema array = relatedPets.getAnnotationsByType(ArraySchema.class)[0];\n        assertThat(array.schema().implementation()).isEqualTo(Pet.class);\n        assertThat(array.minItems()).isEqualTo(0);\n        assertThat(array.maxItems()).isEqualTo(5);\n        assertThat(array.uniqueItems()).isTrue();\n\n        Method findPets = PetResource.class.getDeclaredMethod(\"findPets\", String.class, int.class, PetSearchRequest.class);\n        Parameter limit = findPets.getParameters()[1].getAnnotationsByType(Parameter.class)[0];\n        assertThat(limit.name()).isEqualTo(\"limit\");\n        assertThat(limit.in()).isEqualTo(\"query\");\n        assertThat(limit.description()).isEqualTo(\"Maximum result count\");\n        assertThat(limit.required()).isTrue();\n        assertThat(limit.schema().type()).isEqualTo(\"integer\");\n        assertThat(limit.schema().format()).isEqualTo(\"int32\");\n        assertThat(limit.schema().minimum()).isEqualTo(\"1\");\n        assertThat(limit.schema().maximum()).isEqualTo(\"100\");\n\n        RequestBody searchRequest = findPets.getParameters()[2].getAnnotationsByType(RequestBody.class)[0];\n        assertThat(searchRequest.description()).isEqualTo(\"Search request body\");\n        assertThat(searchRequest.required()).isFalse();\n        assertThat(searchRequest.content()[0].schema().implementation()).isEqualTo(PetSearchRequest.class);\n    }\n\n    @Test\n    void repeatableSecurityAndVisibilityAnnotationsRetainDocumentationControls()\n            throws NoSuchFieldException, NoSuchMethodException {\n        Method purgeCache = AdministrativeResource.class.getDeclaredMethod(\"purgeCache\", List.class);\n\n        SecurityRequirement securityRequirement = purgeCache.getAnnotationsByType(SecurityRequirement.class)[0];\n        assertThat(securityRequirement.name()).isEqualTo(\"adminAuth\");\n        assertThat(securityRequirement.scopes()).containsExactly(\"admin:cache\");\n\n        Parameter[] parameters = purgeCache.getAnnotationsByType(Parameter.class);\n        assertThat(parameters).hasSize(2);\n        assertThat(parameters[0].name()).isEqualTo(\"cacheName\");\n        assertThat(parameters[0].hidden()).isFalse();\n        assertThat(parameters[0].array().schema().type()).isEqualTo(\"string\");\n        assertThat(parameters[0].array().minItems()).isEqualTo(1);\n        assertThat(parameters[0].array().maxItems()).isEqualTo(10);\n        assertThat(parameters[0].array().uniqueItems()).isTrue();\n        assertThat(parameters[1].name()).isEqualTo(\"dryRun\");\n        assertThat(parameters[1].schema().type()).isEqualTo(\"boolean\");\n        assertThat(parameters[1].schema()._default()).isEqualTo(\"true\");\n\n        Parameter cacheNames = purgeCache.getParameters()[0].getAnnotationsByType(Parameter.class)[0];\n        assertThat(cacheNames.name()).isEqualTo(\"cacheNames\");\n        assertThat(cacheNames.hidden()).isTrue();\n        assertThat(cacheNames.allowEmptyValue()).isTrue();\n        assertThat(cacheNames.deprecated()).isTrue();\n\n        Field auditNoteField = AdministrativeRequest.class.getDeclaredField(\"auditNote\");\n        Schema auditNote = auditNoteField.getAnnotationsByType(Schema.class)[0];\n        assertThat(auditNote.description()).isEqualTo(\"Internal audit note\");\n        assertThat(auditNote.hidden()).isTrue();\n        assertThat(auditNote.nullable()).isTrue();\n        assertThat(auditNote.writeOnly()).isTrue();\n    }\n\n    @Test\n    void enumHelpersPreserveDeclarationOrder() {\n        assertThat(Explode.values()).containsExactly(Explode.DEFAULT, Explode.FALSE, Explode.TRUE);\n    }\n\n    @Info(\n            title = \"Pet API\",\n            version = \"1.0\",\n            description = \"Endpoints for looking up pets\",\n            termsOfService = \"https://example.test/terms\",\n            contact = @Contact(\n                    name = \"API Support\",\n                    url = \"https://example.test/support\",\n                    email = \"support@example.test\"),\n            license = @License(\n                    name = \"Apache-2.0\",\n                    url = \"https://www.apache.org/licenses/LICENSE-2.0\"))\n    @SecurityScheme(\n            type = \"oauth2\",\n            description = \"OAuth2 authorization code flow\",\n            name = \"petstoreAuth\",\n            in = \"header\",\n            scheme = \"bearer\",\n            bearerFormat = \"JWT\",\n            flows = @io.swagger.oas.annotations.security.OAuthFlows(\n                    authorizationCode = @OAuthFlow(\n                            authorizationUrl = \"https://auth.example.test/authorize\",\n                            tokenUrl = \"https://auth.example.test/token\",\n                            refreshUrl = \"https://auth.example.test/refresh\",\n                            scopes = @io.swagger.oas.annotations.security.Scopes(\n                                    name = \"pets:read\",\n                                    description = \"Read pet records\"))),\n            openIdConnectUrl = \"https://auth.example.test/.well-known/openid-configuration\")\n    @Callback(\n            name = \"petCreated\",\n            callbackUrlExpression = \"{$request.body#/callbackUrl}\",\n            operation = @Operation(\n                    method = \"POST\",\n                    summary = \"Notify when a pet is created\",\n                    responses = @ApiResponse(responseCode = \"202\", description = \"Callback accepted\")))\n    private static final class AnnotatedPetApi {\n    }\n\n    private static final class PetResource {\n        @Operation(\n                method = \"GET\",\n                tags = {\"pets\", \"search\"},\n                summary = \"Find pets\",\n                description = \"Returns a bounded collection of pets matching the requested type\",\n                externalDocs = @ExternalDocumentation(\n                        description = \"Pet search guide\",\n                        url = \"https://example.test/docs/pets/search\"),\n                operationId = \"findPetsByType\",\n                parameters = @Parameter(\n                        name = \"type\",\n                        in = \"query\",\n                        description = \"Pet type filter\",\n                        required = true,\n                        style = \"form\",\n                        explode = Explode.FALSE,\n                        allowReserved = true,\n                        schema = @Schema(\n                                type = \"string\",\n                                _enum = {\"dog\", \"cat\", \"bird\"},\n                                _default = \"dog\"),\n                        content = @Content(\n                                mediaType = \"text/plain\",\n                                examples = @ExampleObject(name = \"cat\", value = \"cat\"))),\n                requestBody = @RequestBody(\n                        description = \"Search options\",\n                        required = true,\n                        content = @Content(\n                                mediaType = \"application/json\",\n                                schema = @Schema(implementation = PetSearchRequest.class))),\n                responses = {\n                        @ApiResponse(\n                                responseCode = \"200\",\n                                description = \"Pets were returned\",\n                                links = @Link(\n                                        name = \"petDetails\",\n                                        operationRef = \"#/paths/~1pets~1{id}/get\",\n                                        operationId = \"getPetById\",\n                                        parameters = @io.swagger.oas.annotations.links.LinkParameters(\n                                                name = \"id\",\n                                                expression = \"$response.body#/0/id\"),\n                                        description = \"Read the first returned pet\"),\n                                content = @Content(\n                                        mediaType = \"application/json\",\n                                        schema = @Schema(implementation = Pet.class),\n                                        examples = @ExampleObject(\n                                                name = \"sample-pets\",\n                                                summary = \"One returned pet\",\n                                                value = \"[{\\\"id\\\":\\\"pet-1\\\",\\\"name\\\":\\\"Fido\\\"}]\"))),\n                        @ApiResponse(responseCode = \"404\", description = \"No pets matched\")\n                },\n                servers = @Server(\n                        url = \"https://api.example.test/v1\",\n                        description = \"Production API\",\n                        variables = @io.swagger.oas.annotations.servers.ServerVariable(\n                                name = \"region\",\n                                _default = \"us\",\n                                allowableValues = {\"us\", \"eu\"},\n                                description = \"Deployment region\")),\n                extensions = @Extension(\n                        name = \"x-operation\",\n                        properties = @io.swagger.oas.annotations.extensions.ExtensionProperty(name = \"cached\", value = \"true\")))\n        private List<Pet> findPets(\n                String type,\n                @Parameter(\n                        name = \"limit\",\n                        in = \"query\",\n                        description = \"Maximum result count\",\n                        required = true,\n                        schema = @Schema(type = \"integer\", format = \"int32\", minimum = \"1\", maximum = \"100\")) int limit,\n                @RequestBody(\n                        description = \"Search request body\",\n                        content = @Content(\n                                mediaType = \"application/json\",\n                                schema = @Schema(implementation = PetSearchRequest.class))) PetSearchRequest request) {\n            return Collections.singletonList(new Pet(\"pet-1\", type + '-' + limit, Collections.emptyList()));\n        }\n    }\n\n    private static final class AdministrativeResource {\n        @SecurityRequirement(name = \"adminAuth\", scopes = \"admin:cache\")\n        @Parameter(\n                name = \"cacheName\",\n                in = \"query\",\n                description = \"Cache names to purge\",\n                array = @ArraySchema(\n                        schema = @Schema(type = \"string\"),\n                        minItems = 1,\n                        maxItems = 10,\n                        uniqueItems = true))\n        @Parameter(\n                name = \"dryRun\",\n                in = \"query\",\n                description = \"Validate without deleting entries\",\n                schema = @Schema(type = \"boolean\", _default = \"true\"))\n        private void purgeCache(\n                @Parameter(\n                        name = \"cacheNames\",\n                        description = \"Cache names to purge\",\n                        deprecated = true,\n                        allowEmptyValue = true,\n                        hidden = true) List<String> cacheNames) {\n        }\n    }\n\n    private static final class AdministrativeRequest {\n        @Schema(\n                description = \"Internal audit note\",\n                nullable = true,\n                writeOnly = true,\n                hidden = true)\n        private final String auditNote = \"\";\n    }\n\n    private static class BasePet {\n    }\n\n    private static final class Dog extends Pet {\n        private Dog() {\n            super(\"dog-1\", \"Fido\", Collections.emptyList());\n        }\n    }\n\n    private static final class Cat extends Pet {\n        private Cat() {\n            super(\"cat-1\", \"Garfield\", Collections.emptyList());\n        }\n    }\n\n    @Schema(\n            implementation = Pet.class,\n            allOf = BasePet.class,\n            oneOf = {Dog.class, Cat.class},\n            name = \"Pet\",\n            title = \"Pet\",\n            description = \"A pet visible through the API\",\n            requiredProperties = {\"name\", \"identifier\"},\n            discriminatorProperty = \"kind\",\n            externalDocs = @ExternalDocumentation(\n                    description = \"Pet model documentation\",\n                    url = \"https://example.test/docs/models/pet\"))\n    private static class Pet extends BasePet {\n        private final String identifier;\n\n        @Schema(\n                name = \"name\",\n                description = \"Display name\",\n                type = \"string\",\n                format = \"pet-name\",\n                required = true,\n                _enum = {\"Fido\", \"Garfield\"},\n                example = \"Fido\",\n                examples = {\"Fido\", \"Garfield\"},\n                _default = \"Fido\",\n                minLength = 1,\n                maxLength = 64,\n                pattern = \"[A-Za-z]+( [A-Za-z]+)*\")\n        private final String name;\n\n        @ArraySchema(\n                schema = @Schema(implementation = Pet.class),\n                minItems = 0,\n                maxItems = 5,\n                uniqueItems = true)\n        private final List<Pet> relatedPets;\n\n        private Pet(String identifier, String name, List<Pet> relatedPets) {\n            this.identifier = identifier;\n            this.name = name;\n            this.relatedPets = relatedPets;\n        }\n\n        @Schema(\n                name = \"id\",\n                description = \"Stable identifier\",\n                ref = \"#/components/schemas/Pet/properties/id\",\n                readOnly = true)\n        private String getIdentifier() {\n            return identifier;\n        }\n    }\n\n    private static final class PetSearchRequest {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 364, "output": 6102, "cacheRead": 46592, "cacheWrite": 0, "totalTokens": 53058, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777950981148, "responseId": "resp_0b9d28f4b44c9e6e0169f96105b3988195a9a03f8fd28ecdc9"}}
[tool-exec] start id=call_YKnbx6eYfptUb6toJ2DzWMVn|fc_0b9d28f4b44c9e6e0169f9610f6ca88195889b23d0e81d27ae name=write args={"path": "tests/src/io.swagger/swagger-annotations/2.0.0-rc0/src/test/java/io_swagger/swagger_annotations/Swagger_annotationsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_swagger.swagger_annotations;\n\nimport io.swagger.oas.annotations.ExternalDocumentation;\nimport io.swagger.oas.annotations.Operation;\nimport io.swagger.oas.annotations.Parameter;\nimport io.swagger.oas.annotations.callbacks.Callback;\nimport io.swagger.oas.annotations.enums.Explode;\nimport io.swagger.oas.annotations.extensions.Extension;\nimport io.swagger.oas.annotations.info.Contact;\nimport io.swagger.oas.annotations.info.Info;\nimport io.swagger.oas.annotations.info.License;\nimport io.swagger.oas.annotations.links.Link;\nimport io.swagger.oas.annotations.media.ArraySchema;\nimport io.swagger.oas.annotations.media.Content;\nimport io.swagger.oas.annotations.media.ExampleObject;\nimport io.swagger.oas.annotations.media.Schema;\nimport io.swagger.oas.annotations.parameters.RequestBody;\nimport io.swagger.oas.annotations.responses.ApiResponse;\nimport io.swagger.oas.annotations.security.OAuthFlow;\nimport io.swagger.oas.annotations.security.SecurityRequirement;\nimport io.swagger.oas.annotations.security.SecurityScheme;\nimport io.swagger.oas.annotations.servers.Server;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Collections;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class Swagger_annotationsTest {\n    @Test\n    void typeAnnotationsRetainDocumentationCallbacksAndSecurityMetadata() {\n        Info info = AnnotatedPetApi.class.getAnnotationsByType(Info.class)[0];\n        assertThat(info.title()).isEqualTo(\"Pet API\");\n        assertThat(info.version()).isEqualTo(\"1.0\");\n        assertThat(info.description()).isEqualTo(\"Endpoints for looking up pets\");\n        assertThat(info.termsOfService()).isEqualTo(\"https://example.test/terms\");\n        assertThat(info.contact().name()).isEqualTo(\"API Support\");\n        assertThat(info.contact().url()).isEqualTo(\"https://example.test/support\");\n        assertThat(info.contact().email()).isEqualTo(\"support@example.test\");\n        assertThat(info.license().name()).isEqualTo(\"Apache-2.0\");\n        assertThat(info.license().url()).isEqualTo(\"https://www.apache.org/licenses/LICENSE-2.0\");\n\n        SecurityScheme securityScheme = AnnotatedPetApi.class.getAnnotationsByType(SecurityScheme.class)[0];\n        assertThat(securityScheme.type()).isEqualTo(\"oauth2\");\n        assertThat(securityScheme.description()).isEqualTo(\"OAuth2 authorization code flow\");\n        assertThat(securityScheme.name()).isEqualTo(\"petstoreAuth\");\n        assertThat(securityScheme.in()).isEqualTo(\"header\");\n        assertThat(securityScheme.scheme()).isEqualTo(\"bearer\");\n        assertThat(securityScheme.bearerFormat()).isEqualTo(\"JWT\");\n        assertThat(securityScheme.openIdConnectUrl()).isEqualTo(\"https://auth.example.test/.well-known/openid-configuration\");\n        OAuthFlow authorizationCode = securityScheme.flows().authorizationCode();\n        assertThat(authorizationCode.authorizationUrl()).isEqualTo(\"https://auth.example.test/authorize\");\n        assertThat(authorizationCode.tokenUrl()).isEqualTo(\"https://auth.example.test/token\");\n        assertThat(authorizationCode.refreshUrl()).isEqualTo(\"https://auth.example.test/refresh\");\n        assertThat(authorizationCode.scopes().name()).isEqualTo(\"pets:read\");\n        assertThat(authorizationCode.scopes().description()).isEqualTo(\"Read pet records\");\n\n        Callback callback = AnnotatedPetApi.class.getAnnotationsByType(Callback.class)[0];\n        assertThat(callback.name()).isEqualTo(\"petCreated\");\n        assertThat(callback.callbackUrlExpression()).isEqualTo(\"{$request.body#/callbackUrl}\");\n        Operation callbackOperation = callback.operation()[0];\n        assertThat(callbackOperation.method()).isEqualTo(\"POST\");\n        assertThat(callbackOperation.summary()).isEqualTo(\"Notify when a pet is created\");\n        assertThat(callbackOperation.responses()[0].responseCode()).isEqualTo(\"202\");\n        assertThat(callbackOperation.responses()[0].description()).isEqualTo(\"Callback accepted\");\n    }\n\n    @Test\n    void operationAnnotationsRetainNestedParametersResponsesServersAndExtensions() throws NoSuchMethodException {\n        Method findPets = PetResource.class.getDeclaredMethod(\"findPets\", String.class, int.class, PetSearchRequest.class);\n\n        Operation operation = findPets.getAnnotationsByType(Operation.class)[0];\n        assertThat(operation.method()).isEqualTo(\"GET\");\n        assertThat(operation.tags()).containsExactly(\"pets\", \"search\");\n        assertThat(operation.summary()).isEqualTo(\"Find pets\");\n        assertThat(operation.description()).isEqualTo(\"Returns a bounded collection of pets matching the requested type\");\n        assertThat(operation.operationId()).isEqualTo(\"findPetsByType\");\n        assertThat(operation.deprecated()).isFalse();\n        assertThat(operation.externalDocs().description()).isEqualTo(\"Pet search guide\");\n        assertThat(operation.externalDocs().url()).isEqualTo(\"https://example.test/docs/pets/search\");\n\n        Parameter type = operation.parameters()[0];\n        assertThat(type.name()).isEqualTo(\"type\");\n        assertThat(type.in()).isEqualTo(\"query\");\n        assertThat(type.description()).isEqualTo(\"Pet type filter\");\n        assertThat(type.required()).isTrue();\n        assertThat(type.deprecated()).isFalse();\n        assertThat(type.allowEmptyValue()).isFalse();\n        assertThat(type.style()).isEqualTo(\"form\");\n        assertThat(type.explode()).isEqualTo(Explode.FALSE);\n        assertThat(type.allowReserved()).isTrue();\n        assertThat(type.schema().type()).isEqualTo(\"string\");\n        assertThat(type.schema()._enum()).containsExactly(\"dog\", \"cat\", \"bird\");\n        assertThat(type.schema()._default()).isEqualTo(\"dog\");\n        assertThat(type.content()[0].mediaType()).isEqualTo(\"text/plain\");\n        assertThat(type.content()[0].examples()[0].value()).isEqualTo(\"cat\");\n\n        RequestBody requestBody = operation.requestBody();\n        assertThat(requestBody.description()).isEqualTo(\"Search options\");\n        assertThat(requestBody.required()).isTrue();\n        assertThat(requestBody.content()[0].mediaType()).isEqualTo(\"application/json\");\n        assertThat(requestBody.content()[0].schema().implementation()).isEqualTo(PetSearchRequest.class);\n\n        ApiResponse ok = operation.responses()[0];\n        assertThat(ok.responseCode()).isEqualTo(\"200\");\n        assertThat(ok.description()).isEqualTo(\"Pets were returned\");\n        assertThat(ok.content().mediaType()).isEqualTo(\"application/json\");\n        assertThat(ok.content().schema().implementation()).isEqualTo(Pet.class);\n        assertThat(ok.content().examples()[0].name()).isEqualTo(\"sample-pets\");\n        assertThat(ok.content().examples()[0].summary()).isEqualTo(\"One returned pet\");\n        assertThat(ok.content().examples()[0].value()).contains(\"Fido\");\n        assertThat(ok.links()[0].name()).isEqualTo(\"petDetails\");\n        assertThat(ok.links()[0].operationId()).isEqualTo(\"getPetById\");\n        assertThat(ok.links()[0].operationRef()).isEqualTo(\"#/paths/~1pets~1{id}/get\");\n        assertThat(ok.links()[0].parameters().name()).isEqualTo(\"id\");\n        assertThat(ok.links()[0].parameters().expression()).isEqualTo(\"$response.body#/0/id\");\n        assertThat(ok.links()[0].description()).isEqualTo(\"Read the first returned pet\");\n        assertThat(operation.responses()[1].responseCode()).isEqualTo(\"404\");\n        assertThat(operation.responses()[1].description()).isEqualTo(\"No pets matched\");\n\n        Server server = operation.servers()[0];\n        assertThat(server.url()).isEqualTo(\"https://api.example.test/v1\");\n        assertThat(server.description()).isEqualTo(\"Production API\");\n        assertThat(server.variables()[0].name()).isEqualTo(\"region\");\n        assertThat(server.variables()[0]._default()).isEqualTo(\"us\");\n        assertThat(server.variables()[0].allowableValues()).containsExactly(\"us\", \"eu\");\n        assertThat(server.variables()[0].description()).isEqualTo(\"Deployment region\");\n\n        Extension extension = operation.extensions()[0];\n        assertThat(extension.name()).isEqualTo(\"x-operation\");\n        assertThat(extension.properties()[0].name()).isEqualTo(\"cached\");\n        assertThat(extension.properties()[0].value()).isEqualTo(\"true\");\n    }\n\n    @Test\n    void schemaAndParameterAnnotationsRetainModelAndRequestMetadata() throws NoSuchFieldException, NoSuchMethodException {\n        Schema model = Pet.class.getAnnotationsByType(Schema.class)[0];\n        assertThat(model.name()).isEqualTo(\"Pet\");\n        assertThat(model.title()).isEqualTo(\"Pet\");\n        assertThat(model.description()).isEqualTo(\"A pet visible through the API\");\n        assertThat(model.implementation()).isEqualTo(Pet.class);\n        assertThat(model.allOf()).containsExactly(BasePet.class);\n        assertThat(model.oneOf()).containsExactly(Dog.class, Cat.class);\n        assertThat(model.requiredProperties()).containsExactly(\"name\", \"identifier\");\n        assertThat(model.discriminatorProperty()).isEqualTo(\"kind\");\n        assertThat(model.externalDocs().description()).isEqualTo(\"Pet model documentation\");\n        assertThat(model.externalDocs().url()).isEqualTo(\"https://example.test/docs/models/pet\");\n\n        Field nameField = Pet.class.getDeclaredField(\"name\");\n        Schema name = nameField.getAnnotationsByType(Schema.class)[0];\n        assertThat(name.name()).isEqualTo(\"name\");\n        assertThat(name.description()).isEqualTo(\"Display name\");\n        assertThat(name.type()).isEqualTo(\"string\");\n        assertThat(name.format()).isEqualTo(\"pet-name\");\n        assertThat(name.required()).isTrue();\n        assertThat(name._enum()).containsExactly(\"Fido\", \"Garfield\");\n        assertThat(name.example()).isEqualTo(\"Fido\");\n        assertThat(name.examples()).containsExactly(\"Fido\", \"Garfield\");\n        assertThat(name._default()).isEqualTo(\"Fido\");\n        assertThat(name.minLength()).isEqualTo(1);\n        assertThat(name.maxLength()).isEqualTo(64);\n        assertThat(name.pattern()).isEqualTo(\"[A-Za-z]+( [A-Za-z]+)*\");\n        assertThat(name.nullable()).isFalse();\n        assertThat(name.readOnly()).isFalse();\n        assertThat(name.writeOnly()).isFalse();\n\n        Method getIdentifier = Pet.class.getDeclaredMethod(\"getIdentifier\");\n        Schema identifier = getIdentifier.getAnnotationsByType(Schema.class)[0];\n        assertThat(identifier.name()).isEqualTo(\"id\");\n        assertThat(identifier.description()).isEqualTo(\"Stable identifier\");\n        assertThat(identifier.readOnly()).isTrue();\n        assertThat(identifier.ref()).isEqualTo(\"#/components/schemas/Pet/properties/id\");\n        assertThat(identifier.hidden()).isFalse();\n\n        Field relatedPets = Pet.class.getDeclaredField(\"relatedPets\");\n        ArraySchema array = relatedPets.getAnnotationsByType(ArraySchema.class)[0];\n        assertThat(array.schema().implementation()).isEqualTo(Pet.class);\n        assertThat(array.minItems()).isEqualTo(0);\n        assertThat(array.maxItems()).isEqualTo(5);\n        assertThat(array.uniqueItems()).isTrue();\n\n        Method findPets = PetResource.class.getDeclaredMethod(\"findPets\", String.class, int.class, PetSearchRequest.class);\n        Parameter limit = findPets.getParameters()[1].getAnnotationsByType(Parameter.class)[0];\n        assertThat(limit.name()).isEqualTo(\"limit\");\n        assertThat(limit.in()).isEqualTo(\"query\");\n        assertThat(limit.description()).isEqualTo(\"Maximum result count\");\n        assertThat(limit.required()).isTrue();\n        assertThat(limit.schema().type()).isEqualTo(\"integer\");\n        assertThat(limit.schema().format()).isEqualTo(\"int32\");\n        assertThat(limit.schema().minimum()).isEqualTo(\"1\");\n        assertThat(limit.schema().maximum()).isEqualTo(\"100\");\n\n        RequestBody searchRequest = findPets.getParameters()[2].getAnnotationsByType(RequestBody.class)[0];\n        assertThat(searchRequest.description()).isEqualTo(\"Search request body\");\n        assertThat(searchRequest.required()).isFalse();\n        assertThat(searchRequest.content()[0].schema().implementation()).isEqualTo(PetSearchRequest.class);\n    }\n\n    @Test\n    void repeatableSecurityAndVisibilityAnnotationsRetainDocumentationControls()\n            throws NoSuchFieldException, NoSuchMethodException {\n        Method purgeCache = AdministrativeResource.class.getDeclaredMethod(\"purgeCache\", List.class);\n\n        SecurityRequirement securityRequirement = purgeCache.getAnnotationsByType(SecurityRequirement.class)[0];\n        assertThat(securityRequirement.name()).isEqualTo(\"adminAuth\");\n        assertThat(securityRequirement.scopes()).containsExactly(\"admin:cache\");\n\n        Parameter[] parameters = purgeCache.getAnnotationsByType(Parameter.class);\n        assertThat(parameters).hasSize(2);\n        assertThat(parameters[0].name()).isEqualTo(\"cacheName\");\n        assertThat(parameters[0].hidden()).isFalse();\n        assertThat(parameters[0].array().schema().type()).isEqualTo(\"string\");\n        assertThat(parameters[0].array().minItems()).isEqualTo(1);\n        assertThat(parameters[0].array().maxItems()).isEqualTo(10);\n        assertThat(parameters[0].array().uniqueItems()).isTrue();\n        assertThat(parameters[1].name()).isEqualTo(\"dryRun\");\n        assertThat(parameters[1].schema().type()).isEqualTo(\"boolean\");\n        assertThat(parameters[1].schema()._default()).isEqualTo(\"true\");\n\n        Parameter cacheNames = purgeCache.getParameters()[0].getAnnotationsByType(Parameter.class)[0];\n        assertThat(cacheNames.name()).isEqualTo(\"cacheNames\");\n        assertThat(cacheNames.hidden()).isTrue();\n        assertThat(cacheNames.allowEmptyValue()).isTrue();\n        assertThat(cacheNames.deprecated()).isTrue();\n\n        Field auditNoteField = AdministrativeRequest.class.getDeclaredField(\"auditNote\");\n        Schema auditNote = auditNoteField.getAnnotationsByType(Schema.class)[0];\n        assertThat(auditNote.description()).isEqualTo(\"Internal audit note\");\n        assertThat(auditNote.hidden()).isTrue();\n        assertThat(auditNote.nullable()).isTrue();\n        assertThat(auditNote.writeOnly()).isTrue();\n    }\n\n    @Test\n    void enumHelpersPreserveDeclarationOrder() {\n        assertThat(Explode.values()).containsExactly(Explode.DEFAULT, Explode.FALSE, Explode.TRUE);\n    }\n\n    @Info(\n            title = \"Pet API\",\n            version = \"1.0\",\n            description = \"Endpoints for looking up pets\",\n            termsOfService = \"https://example.test/terms\",\n            contact = @Contact(\n                    name = \"API Support\",\n                    url = \"https://example.test/support\",\n                    email = \"support@example.test\"),\n            license = @License(\n                    name = \"Apache-2.0\",\n                    url = \"https://www.apache.org/licenses/LICENSE-2.0\"))\n    @SecurityScheme(\n            type = \"oauth2\",\n            description = \"OAuth2 authorization code flow\",\n            name = \"petstoreAuth\",\n            in = \"header\",\n            scheme = \"bearer\",\n            bearerFormat = \"JWT\",\n            flows = @io.swagger.oas.annotations.security.OAuthFlows(\n                    authorizationCode = @OAuthFlow(\n                            authorizationUrl = \"https://auth.example.test/authorize\",\n                            tokenUrl = \"https://auth.example.test/token\",\n                            refreshUrl = \"https://auth.example.test/refresh\",\n                            scopes = @io.swagger.oas.annotations.security.Scopes(\n                                    name = \"pets:read\",\n                                    description = \"Read pet records\"))),\n            openIdConnectUrl = \"https://auth.example.test/.well-known/openid-configuration\")\n    @Callback(\n            name = \"petCreated\",\n            callbackUrlExpression = \"{$request.body#/callbackUrl}\",\n            operation = @Operation(\n                    method = \"POST\",\n                    summary = \"Notify when a pet is created\",\n                    responses = @ApiResponse(responseCode = \"202\", description = \"Callback accepted\")))\n    private static final class AnnotatedPetApi {\n    }\n\n    private static final class PetResource {\n        @Operation(\n                method = \"GET\",\n                tags = {\"pets\", \"search\"},\n                summary = \"Find pets\",\n                description = \"Returns a bounded collection of pets matching the requested type\",\n                externalDocs = @ExternalDocumentation(\n                        description = \"Pet search guide\",\n                        url = \"https://example.test/docs/pets/search\"),\n                operationId = \"findPetsByType\",\n                parameters = @Parameter(\n                        name = \"type\",\n                        in = \"query\",\n                        description = \"Pet type filter\",\n                        required = true,\n                        style = \"form\",\n                        explode = Explode.FALSE,\n                        allowReserved = true,\n                        schema = @Schema(\n                                type = \"string\",\n                                _enum = {\"dog\", \"cat\", \"bird\"},\n                                _default = \"dog\"),\n                        content = @Content(\n                                mediaType = \"text/plain\",\n                                examples = @ExampleObject(name = \"cat\", value = \"cat\"))),\n                requestBody = @RequestBody(\n                        description = \"Search options\",\n                        required = true,\n                        content = @Content(\n                                mediaType = \"application/json\",\n                                schema = @Schema(implementation = PetSearchRequest.class))),\n                responses = {\n                        @ApiResponse(\n                                responseCode = \"200\",\n                                description = \"Pets were returned\",\n                                links = @Link(\n                                        name = \"petDetails\",\n                                        operationRef = \"#/paths/~1pets~1{id}/get\",\n                                        operationId = \"getPetById\",\n                                        parameters = @io.swagger.oas.annotations.links.LinkParameters(\n                                                name = \"id\",\n                                                expression = \"$response.body#/0/id\"),\n                                        description = \"Read the first returned pet\"),\n                                content = @Content(\n                                        mediaType = \"application/json\",\n                                        schema = @Schema(implementation = Pet.class),\n                                        examples = @ExampleObject(\n                                                name = \"sample-pets\",\n                                                summary = \"One returned pet\",\n                                                value = \"[{\\\"id\\\":\\\"pet-1\\\",\\\"name\\\":\\\"Fido\\\"}]\"))),\n                        @ApiResponse(responseCode = \"404\", description = \"No pets matched\")\n                },\n                servers = @Server(\n                        url = \"https://api.example.test/v1\",\n                        description = \"Production API\",\n                        variables = @io.swagger.oas.annotations.servers.ServerVariable(\n                                name = \"region\",\n                                _default = \"us\",\n                                allowableValues = {\"us\", \"eu\"},\n                                description = \"Deployment region\")),\n                extensions = @Extension(\n                        name = \"x-operation\",\n                        properties = @io.swagger.oas.annotations.extensions.ExtensionProperty(name = \"cached\", value = \"true\")))\n        private List<Pet> findPets(\n                String type,\n                @Parameter(\n                        name = \"limit\",\n                        in = \"query\",\n                        description = \"Maximum result count\",\n                        required = true,\n                        schema = @Schema(type = \"integer\", format = \"int32\", minimum = \"1\", maximum = \"100\")) int limit,\n                @RequestBody(\n                        description = \"Search request body\",\n                        content = @Content(\n                                mediaType = \"application/json\",\n                                schema = @Schema(implementation = PetSearchRequest.class))) PetSearchRequest request) {\n            return Collections.singletonList(new Pet(\"pet-1\", type + '-' + limit, Collections.emptyList()));\n        }\n    }\n\n    private static final class AdministrativeResource {\n        @SecurityRequirement(name = \"adminAuth\", scopes = \"admin:cache\")\n        @Parameter(\n                name = \"cacheName\",\n                in = \"query\",\n                description = \"Cache names to purge\",\n                array = @ArraySchema(\n                        schema = @Schema(type = \"string\"),\n                        minItems = 1,\n                        maxItems = 10,\n                        uniqueItems = true))\n        @Parameter(\n                name = \"dryRun\",\n                in = \"query\",\n                description = \"Validate without deleting entries\",\n                schema = @Schema(type = \"boolean\", _default = \"true\"))\n        private void purgeCache(\n                @Parameter(\n                        name = \"cacheNames\",\n                        description = \"Cache names to purge\",\n                        deprecated = true,\n                        allowEmptyValue = true,\n                        hidden = true) List<String> cacheNames) {\n        }\n    }\n\n    private static final class AdministrativeRequest {\n        @Schema(\n                description = \"Internal audit note\",\n                nullable = true,\n                writeOnly = true,\n                hidden = true)\n        private final String auditNote = \"\";\n    }\n\n    private static class BasePet {\n    }\n\n    private static final class Dog extends Pet {\n        private Dog() {\n            super(\"dog-1\", \"Fido\", Collections.emptyList());\n        }\n    }\n\n    private static final class Cat extends Pet {\n        private Cat() {\n            super(\"cat-1\", \"Garfield\", Collections.emptyList());\n        }\n    }\n\n    @Schema(\n            implementation = Pet.class,\n            allOf = BasePet.class,\n            oneOf = {Dog.class, Cat.class},\n            name = \"Pet\",\n            title = \"Pet\",\n            description = \"A pet visible through the API\",\n            requiredProperties = {\"name\", \"identifier\"},\n            discriminatorProperty = \"kind\",\n            externalDocs = @ExternalDocumentation(\n                    description = \"Pet model documentation\",\n                    url = \"https://example.test/docs/models/pet\"))\n    private static class Pet extends BasePet {\n        private final String identifier;\n\n        @Schema(\n                name = \"name\",\n                description = \"Display name\",\n                type = \"string\",\n                format = \"pet-name\",\n                required = true,\n                _enum = {\"Fido\", \"Garfield\"},\n                example = \"Fido\",\n                examples = {\"Fido\", \"Garfield\"},\n                _default = \"Fido\",\n                minLength = 1,\n                maxLength = 64,\n                pattern = \"[A-Za-z]+( [A-Za-z]+)*\")\n        private final String name;\n\n        @ArraySchema(\n                schema = @Schema(implementation = Pet.class),\n                minItems = 0,\n                maxItems = 5,\n                uniqueItems = true)\n        private final List<Pet> relatedPets;\n\n        private Pet(String identifier, String name, List<Pet> relatedPets) {\n            this.identifier = identifier;\n            this.name = name;\n            this.relatedPets = relatedPets;\n        }\n\n        @Schema(\n                name = \"id\",\n                description = \"Stable identifier\",\n                ref = \"#/components/schemas/Pet/properties/id\",\n                readOnly = true)\n        private String getIdentifier() {\n            return identifier;\n        }\n    }\n\n    private static final class PetSearchRequest {\n    }\n}\n"}
