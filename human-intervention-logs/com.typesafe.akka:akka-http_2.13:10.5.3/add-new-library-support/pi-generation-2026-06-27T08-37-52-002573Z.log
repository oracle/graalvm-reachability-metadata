[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-http_2.13/10.5.3/src/test/scala/com_typesafe_akka/akka_http_2_13/FileAndResourceDirectivesTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_http_2_13\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nimport akka.actor.ActorSystem\nimport akka.http.scaladsl.model.ContentTypes\nimport akka.http.scaladsl.model.HttpRequest\nimport akka.http.scaladsl.model.HttpResponse\nimport akka.http.scaladsl.server.Directives.getFromResource\nimport akka.http.scaladsl.server.Route\nimport akka.stream.Materializer\nimport akka.stream.SystemMaterializer\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass FileAndResourceDirectivesTest {\n  @Test\n  def servesClasspathResourceThroughGetFromResource(): Unit = {\n    implicit val system: ActorSystem = ActorSystem(\"file-and-resource-directives-test\")\n    implicit val materializer: Materializer = SystemMaterializer(system).materializer\n\n    try {\n      val route: Route = getFromResource(\n        \"file-and-resource-directives/content.txt\",\n        ContentTypes.`text/plain(UTF-8)`,\n        getClass.getClassLoader)\n      val handler: HttpRequest => scala.concurrent.Future[HttpResponse] = Route.toFunction(route)\n      val response: HttpResponse = Await.result(handler(HttpRequest(uri = \"/resource.txt\")), 10.seconds)\n      val body: String = Await.result(response.entity.toStrict(10.seconds), 10.seconds).data.utf8String\n\n      assertThat(response.status.intValue()).isEqualTo(200)\n      assertThat(body).isEqualTo(\"served from the test classpath\\n\")\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n"}
