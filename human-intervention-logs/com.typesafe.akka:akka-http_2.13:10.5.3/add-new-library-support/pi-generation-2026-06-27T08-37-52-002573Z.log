      exactCount must be >= 10
      exactCount must be < 20
  
      val measuredDistance: Double = 10.004
      measuredDistance mustBe 10.0 +- 0.01
      measuredDistance mustEqual 10.0 +- 0.01
  
      Array(1, 2, 3) must be (Array(1, 2, 3))
    }
  
    @Test
