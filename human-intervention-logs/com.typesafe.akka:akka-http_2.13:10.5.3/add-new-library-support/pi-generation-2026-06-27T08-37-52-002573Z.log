      assertThat(succeeded.recordedEvents.collect { case event: InfoProvided => event.message }.asJava)
        .containsExactly("diagnostic details")
      assertThat(suite.executionLog.asJava).containsExactly("succeeded", "pending", "failed")
    }
  
