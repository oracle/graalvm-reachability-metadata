      javaMap.put("retries", 3)
      javaMap.put("timeoutSeconds", 5)
  
      configured shouldBe defined
      configured should contain("enabled")
      absent shouldBe empty
      byteValues should contain theSameElementsInOrderAs Array[Byte](1, 2, 3)
