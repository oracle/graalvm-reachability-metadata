  89\t      val baseUri: String = s\"http://${binding.localAddress.getHostString}:${binding.localAddress.getPort}\"\n    90\t\n    91\t      val getResponse = Await.result(Http().singleRequest(HttpRequest(uri = s\"$baseUri/items/42?echo=hello\")), Timeout)\n    92\t      val getBody = strictBody(getResponse)\n    93\t      assertEquals(StatusCodes.OK, getResponse.status)\n    94\t      assertEquals(\"42\", headerValue(getResponse, \"x-item-id\"))\n    95\t      assertTrue(getBody.contains(\"\\\"id\\\":\\\"42\\\"\"))\n    96\t      assertTrue(getBody.contains(\"\\\"echo\\\":\\\"hello\\\"\"))\n    97\t\n    98\t      val postEntity: RequestEntity = HttpEntity(ContentTypes.`text/plain(UTF-8)`, \"payload\")\n    99\t      val postRequest = HttpRequest(\n   100\t        uri = s\"$baseUri/items/42\",\n   101\t        method = HttpMethods.POST,\n   102\t        entity = postEntity\n   103\t      )\n   104\t      val postResponse = Await.result(Http().singleRequest(postRequest), Timeout)\n   105\t      val postBody = strictBody(postResponse)\n   106\t      assertEquals(StatusCodes.Created, postResponse.status)\n   107\t      assertEquals(\"42:payload\", postBody)\n   108\t\n   109\t      val notFoundResponse = Await.result(Http().singleRequest(HttpRequest(uri = s\"$baseUri/missing\")), Timeout)\n   110\t      val notFoundBody = strictBody(notFoundResponse)\n   111\t      assertEquals(StatusCodes.NotFound, notFoundResponse.status)\n   112\t      assertThat(notFoundBody).contains(\"could not be found\")\n   113\t    } finally {\n   114\t      Await.result(binding.terminate(2.seconds), Timeout)\n   115\t    }\n   116\t  }\n   117\t\n   118\t  @Test\n   119\t  def uriModelParsesAuthoritiesPathsQueriesAndFragments(): Unit = {\n   120\t    val uri: Uri = Uri(\"https://example.org:8443/api/items/42?name=Akka%20HTTP&enabled=true#section\")\n   121\t\n   122\t    assertEquals(\"https\", uri.scheme)\n   123\t    assertEquals(\"example.org\", uri.authority.host.address)\n   124\t    assertEquals(8443, uri.authority.port)\n   125\t    assertEquals(\"/api/items/42\", uri.path.toString)\n   126\t    assertEquals(Some(\"Akka HTTP\"), uri.query().get(\"name\"))\n   127\t    assertEquals(Some(\"true\"), uri.query().get(\"enabled\"))\n   128\t    assertEquals(Some(\"section\"), uri.fragment)\n   129\t  }\n   130\t\n   131\t  @Test\n   132\t  def marshalAndUnmarshalMessageEntities(): Unit = {\n   133\t    val textEntity: MessageEntity = Await.result(Marshal(\"plain text\").to[MessageEntity], Timeout)\n   134\t    val decodedText: String = Await.result(Unmarshal(textEntity).to[String], Timeout)\n   135\t    assertEquals(\"plain text\", decodedText)\n   136\t\n   137\t    val jsonEntity: RequestEntity = HttpEntity(ContentTypes.`application/json`, \"\"\"{\"library\":\"akka-http\"}\"\"\")\n   138\t    val decodedJson: String = Await.result(Unmarshal(jsonEntity).to[String], Timeout)\n   139\t    assertEquals(\"\"\"{\"library\":\"akka-http\"}\"\"\", decodedJson)\n   140\t  }\n   141\t\n   142\t  @Test\n   143\t  def formDataProducesUrlEncodedRequestEntities(): Unit = {\n   144\t    val formData: FormData = FormData(\"name\" -> \"Akka HTTP\", \"symbols\" -> \"a+b=c\")\n   145\t    val strictEntity = Await.result(formData.toEntity.toStrict(Timeout), Timeout)\n   146\t\n   147\t    assertEquals(MediaTypes.`application/x-www-form-urlencoded`, strictEntity.contentType.mediaType)\n   148\t    val encodedForm: String = strictEntity.data.utf8String\n   149\t    assertTrue(encodedForm.contains(\"name=Akka+HTTP\"))\n   150\t    assertTrue(encodedForm.contains(\"symbols=a%2Bb%3Dc\"))\n   151\t  }\n   152\t\n   153\t  @Test\n   154\t  def chunkedEntitiesMaterializeIntoStrictEntities(): Unit = {\n   155\t    val data = Source(List(ByteString(\"first \"), ByteString(\"second\")))\n   156\t    val entity: HttpEntity.Chunked = HttpEntity.Chunked.fromData(ContentTypes.`text/plain(UTF-8)`, data)\n   157\t\n   158\t    assertThat(entity.isStrict).isFalse()\n   159\t    val strictEntity = Await.result(entity.toStrict(Timeout), Timeout)\n   160\t\n   161\t    assertEquals(ContentTypes.`text/plain(UTF-8)`, strictEntity.contentType)\n   162\t    assertEquals(\"first second\", strictEntity.data.utf8String)\n   163\t  }\n   164\t\n   165\t  @Test\n   166\t  def multipartFormDataEncodesAndDecodesStrictBodyParts(): Unit = {\n   167\t    val multipart: Multipart.FormData = Multipart.FormData(\n   168\t      Multipart.FormData.BodyPart.Strict(\n   169\t        \"description\",\n   170\t        HttpEntity(ContentTypes.`text/plain(UTF-8)`, \"sample upload\")\n   171\t      ),\n   172\t      Multipart.FormData.BodyPart.Strict(\n   173\t        \"payload\",\n   174\t        HttpEntity(ContentTypes.`application/octet-stream`, ByteString(\"abc123\")),\n   175\t        Map(\"filename\" -> \"payload.bin\")\n   176\t      )\n   177\t    )\n   178\t\n   179\t    val entity: RequestEntity = multipart.toEntity()\n   180\t    val strictEntity = Await.result(entity.toStrict(Timeout), Timeout)\n   181\t    assertTrue(strictEntity.contentType.mediaType.value.startsWith(\"multipart/form-data; boundary=\"))\n   182\t\n   183\t    val decoded: Multipart.FormData = Await.result(Unmarshal(strictEntity).to[Multipart.FormData], Timeout)\n   184\t    val strictParts: Seq[Multipart.FormData.BodyPart.Strict] = Await.result(\n   185\t      decoded.parts.mapAsync(1)(_.toStrict(Timeout)).runWith(Sink.seq),\n   186\t      Timeout\n   187\t    )\n   188\t\n   189\t    assertEquals(2, strictParts.size)\n   190\t    val descriptionPart: Multipart.FormData.BodyPart.Strict = strictParts.head\n","exit_code":0,"status":"completed"}}
