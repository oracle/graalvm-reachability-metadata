 sweep out expired cache entries.\\n        # Note that this interval has nothing to do with TTLs\\n        cache-cleanup-interval = 120s\\n      }\\n\\n      async-dns {\\n        provider-object = \\\"akka.io.dns.internal.AsyncDnsProvider\\\"\\n\\n        # Set upper bound for caching successfully resolved dns entries\\n        # if the DNS record has a smaller TTL value than the setting that\\n        # will be used. Default is to use the record TTL with no cap.\\n        # Possible values:\\n        # forever: always use the minimum TTL from the found records\\n        # never: never cache\\n        # n [time unit] = cap the caching to this value\\n        positive-ttl = forever\\n\\n        # Set how long the fact that a DNS record could not be found is\\n        # cached. If a new resolution is done while the fact is cached it will\\n        # be failed and not result in an actual DNS resolution. Default is\\n        # to never cache.\\n        # Possible values:\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nhuman-intervention-logs/com.typesafe.akka:akka-http_2.13:10.5.3/metadata-fix/codex.log:253:{\"type\":\"item.started\",\"item\":{\"id\":\"item_143\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'javap -classpath ~/.gradle/caches/modules-2/files-2.1/com.typesafe.akka/akka-actor_2.13/2.7.0/*/akka-actor_2.13-2.7.0.jar -p akka.io.InetAddressDnsProvider'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\nhuman-intervention-logs/com.typesafe.akka:akka-http_2.13:10.5.3/metadata-fix/codex.log:254:{\"type\":\"item.started\",\"item\":{\"id\":\"item_144\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'javap -classpath ~/.gradle/caches/modules-2/files-2.1/com.typesafe.akka/akka-actor_2.13/2.7.0/*/akka-actor_2.13-2.7.0.jar -p akka.routing.RoundRobinPool'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\nhuman-intervention-logs/com.typesafe.akka:akka-http_2.13:10.5.3/metadata-fix