g parseApplicationConfig(ConfigParseOptions parseOptions) {\n            return ConfigFactory.parseString(\"\"\"\n                    service {\n                      name = \"custom-loader-service\"\n                      enabled = true\n                    }\n                    \"\"\");\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
