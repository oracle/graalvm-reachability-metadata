{"type":"item.completed","item":{"id":"item_39","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.apache.hadoop/hadoop-common/2.2.0/src/test/java/org_apache_hadoop/hadoop_common/RunJarTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_common;\n\nimport java.io.InputStream;\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\nimport java.util.jar.Manifest;\n\nimport org.apache.hadoop.util.RunJar;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RunJarTest {\n    private static final String INVOKED_PROPERTY = RunJarTest.class.getName() + \".invoked\";\n    private static final String ARGUMENTS_PROPERTY = RunJarTest.class.getName() + \".arguments\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void loadsMainClassFromJarManifestAndInvokesMainMethod() throws Throwable {\n        resetTarget();\n        Path jar = createJarWithMainClassManifest(RunJarTest.class.getName());\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            RunJar.main(new String[] {jar.toString(), \"alpha\", \"beta\"});\n\n            assertThat(System.getProperty(INVOKED_PROPERTY)).isEqualTo(\"true\");\n            assertThat(System.getProperty(ARGUMENTS_PROPERTY)).isEqualTo(\"alpha,beta\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private Path createJarWithMainClassManifest(String mainClassName) throws Exception {\n        Path jar = temporaryDirectory.resolve(\"runjar-target.jar\");\n        Manifest manifest = new Manifest();\n        manifest.getMainAttributes().putValue(\"Manifest-Version\", \"1.0\");\n        manifest.getMainAttributes().putValue(\"Main-Class\", mainClassName);\n\n        try (OutputStream file = Files.newOutputStream(jar);\n                JarOutputStream jarOutput = new JarOutputStream(file, manifest)) {\n            addClassEntry(jarOutput, RunJarTest.class);\n            JarEntry entry = new JarEntry(\"payload.txt\");\n            jarOutput.putNextEntry(entry);\n            jarOutput.write(\"payload\".getBytes(StandardCharsets.UTF_8));\n            jarOutput.closeEntry();\n        }\n        return jar;\n    }\n\n    private static void addClassEntry(JarOutputStream jarOutput, Class<?> type) throws Exception {\n        String classResource = type.getName().replace('.', '/') + \".class\";\n        jarOutput.putNextEntry(new JarEntry(classResource));\n        try (InputStream input = type.getClassLoader().getResourceAsStream(classResource)) {\n            if (input == null) {\n                throw new IllegalStateException(\"Could not locate class resource \" + classResource);\n            }\n            input.transferTo(jarOutput);\n        }\n        jarOutput.closeEntry();\n    }\n\n    public static void main(String[] args) {\n        System.setProperty(INVOKED_PROPERTY, \"true\");\n        System.setProperty(ARGUMENTS_PROPERTY, String.join(\",\", args));\n    }\n\n    private static void resetTarget() {\n        System.clearProperty(INVOKED_PROPERTY);\n        System.clearProperty(ARGUMENTS_PROPERTY);\n    }\n}\n","exit_code":0,"status":"completed"}}
