rg.apache.hadoop.util.ReflectionUtils;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ReflectionUtilsTest {\\n    @Test\\n    void createsInstanceWithDefaultConstructorAndAppliesConfiguration() {\\n        Configuration configuration = new Configuration(false);\\n\\n        ConstructedConfigurable instance = ReflectionUtils.newInstance(ConstructedConfigurable.class, configuration);\\n\\n        assertThat(instance.isConstructed()).isTrue();\\n        assertThat(instance.getConf()).isSameAs(configuration);\\n    }\\n\\n    @Test\\n    void invokesLegacyJobConfigurableConfigureMethodWhenJobConfIsAvailable() {\\n        JobConf jobConf = new JobConf(false);\\n        JobConfigured target = new JobConfigured();\\n\\n        ReflectionUtils.setConf(target, jobConf);\\n\\n        assertThat(target.getConfiguredWith()).isSameAs(jobConf);\\n    }\\n\\n    @Test\\n    void returnsDeclaredFieldsFromClassHierarchy() {\\n        List<Field> fields = ReflectionUtils.getDeclaredFieldsIncludingInherited(ChildFieldHolder.class);\\n\\n        assertThat(fields).extracting(Field::getName)\\n                .contains(\\\"childField\\\", \\\"parentField\\\");\\n    }\\n\\n    @Test\\n    void returnsDeclaredMethodsFromClassHierarchy() {\\n        List<Method> methods = ReflectionUtils.getDeclaredMethodsIncludingInherited(ChildMethodHolder.class);\\n\\n        assertThat(methods).extracting(Method::getName)\\n                .contains(\\\"childMethod\\\", \\\"parentMethod\\\");\\n    }\\n\\n    public static class ConstructedConfigurable implements Configurable {\\n        private final boolean constructed;\\n        private Configuration configuration;\\n\\n        public ConstructedConfigurable() {\\n            constructed = true;\\n        }\\n\\n        @Override\\n        public void setConf(Configuration configuration) {\\n            this.configuration = configuration;\\n        }\\n\\n        @Override\\n        public Configuration getConf() {\\n            return configuration;\\n        }\\n\\n        boolean isConstructed() {\\n            return constructed;\\n        }\\n    }\\n\\n    public static class JobConfigured implements JobConfigurable {\\n        private JobConf configuredWith;\\n\\n        @Override\\n        public void configure(JobConf jobConf) {\\n            configuredWith = jobConf;\\n        }\\n\\n        JobConf getConfiguredWith() {\\n            return configuredWith;\\n        }\\n    }\\n\\n    private static class ParentFieldHolder {\\n        private String parentField;\\n    }\\n\\n    private static class ChildFieldHolder extends ParentFieldHolder {\\n        private String childField;\\n    }\\n\\n    private static class ParentMethodHolder {\\n        private void parentMethod() {\\n        }\\n    }\\n\\n    private static class ChildMethodHolder extends ParentMethodHolder {\\n        private void childMethod() {\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778027366086}, {\"role\": \"toolResult\", \"toolCallId\": \"call_MgYrsnNg6fHQmitkKiJK7Cfi|fc_0654736caa07ebe50169fa8b63616c819c9f55fa2c690ff851\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\nplugins {\\n    id \\\"org.graalvm.internal.tck\\\"\\n}\\n\\nString libraryVersion = tck.testedLibraryVersion.get()\\n\\ndependencies {\\n    testImplementation \\\"org.apache.hadoop:hadoop-common:$libraryVersion\\\"\\n    testImplementation \\\"org.apache.hadoop:hadoop-mapreduce-client-core:$libraryVersion\\\"\\n    testImplementation 'org.assertj:assertj-core:3.22.0'\\n}\\n\\ngraalvmNative {\\n    agent {\\n        defaultMode = \\\"conditional\\\"\\n        modes {\\n            conditional {\\n                userCodeFilterPath