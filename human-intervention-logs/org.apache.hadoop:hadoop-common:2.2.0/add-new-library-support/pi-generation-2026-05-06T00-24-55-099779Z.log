 java.io.DataInputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\n\nimport org.apache.hadoop.io.IntWritable;\nimport org.apache.hadoop.io.TwoDArrayWritable;\nimport org.apache.hadoop.io.Writable;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TwoDArrayWritableTest {\n    @Test\n    void readsWritableMatrixAndConvertsItToTypedTwoDimensionalArray() throws IOException {\n        Writable[][] matrix = new Writable[][] {\n                {new IntWritable(1), new IntWritable(2)},\n                {new IntWritable(3)}\n        };\n        TwoDArrayWritable original = new TwoDArrayWritable(IntWritable.class, matrix);\n\n        TwoDArrayWritable restored = new TwoDArrayWritable(IntWritable.class);\n        restored.readFields(new DataInputStream(new ByteArrayInputStream(write(original))));\n        Object typedArray = restored.toArray();\n\n        assertThat(restored.get()).hasDimensions(2, 2);\n        assertThat((IntWritable[][]) typedArray)\n                .extracting(row -> assertThat(row).extracting(IntWritable::get).toList())\n                .containsExactly(\n                        assertThat(new Integer[] {1, 2}).toList(),\n                        assertThat(new Integer[] {3}).toList());\n    }\n\n    private static byte[] write(TwoDArrayWritable writable) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (DataOutputStream out = new DataOutputStream(bytes)) {\n            writable.write(out);\n        }\n        return bytes.toByteArray();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1995, "output": 840, "cacheRead": 10752, "cacheWrite": 0, "totalTokens": 13587, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778027058735, "responseId": "resp_01f548b2ce477f6a0169fa8a3315ac81a191689560e753dc5e"}, 