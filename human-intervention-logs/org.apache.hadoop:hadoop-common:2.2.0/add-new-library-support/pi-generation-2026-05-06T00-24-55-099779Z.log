ed() {\n            return constructed;\n        }\n    }\n\n    public static class JobConfigured implements JobConfigurable {\n        private JobConf configuredWith;\n\n        @Override\n        public void configure(JobConf jobConf) {\n            configuredWith = jobConf;\n        }\n\n        JobConf getConfiguredWith() {\n            return configuredWith;\n        }\n    }\n\n    private static class ParentFieldHolder {\n        private String parentField;\n    }\n\n    private static class ChildFieldHolder extends ParentFieldHolder {\n        private String childField;\n    }\n\n    private static class ParentMethodHolder {\n        private void parentMethod() {\n        }\n    }\n\n    private static class ChildMethodHolder extends ParentMethodHolder {\n        private void childMethod() {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778027058727}, {"role": "toolResult", "toolCallId": "call_UNN5Pgz3zUdLukbO9AWYz9ob|fc_01f548b2ce477f6a0169fa8a32538c81a1bf08d6457a117486", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_common;\n\nimport java.io.InputStream;\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\nimport java.util.jar.Manifest;\n\nimport org.apache.hadoop.util.RunJar;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RunJarTest {\n    private static final String INVOKED_PROPERTY = RunJarTest.class.getName() + \".invoked\";\n    private static final String ARGUMENTS_PROPERTY = RunJarTest.class.getName() + \".arguments\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void loadsMainClassFromJarManifestAndInvokesMainMethod() throws Throwable {\n        resetTarget();\n        Path jar = createJarWithMainClassManifest(RunJarTest.class.getName());\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            RunJar.main(new String[] {jar.toString(), \"alpha\", \"beta\"});\n\n            assertThat(System.getProperty(INVOKED_PROPERTY)).isEqualTo(\"true\");\n            assertThat(System.getProperty(ARGUMENTS_PROPERTY)).isEqualTo(\"alpha,beta\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private Path createJarWithMainClassManifest(String mainClassName) throws Exception {\n        Path jar = temporaryDirectory.resolve(\"runjar-target.jar\");\n        Manifest manifest = new Manifest();\n        manifest.getMainAttributes().putValue(\"Manifest-Version\", \"1.0\");\n        manifest.getMainAttributes().putValue(\"Main-Class\", mainClassName);\n\n        try (OutputStream file = Files.newOutputStream(jar);\n                JarOutputStream jarOutput = new JarOutputStream(file, manifest)) {\n            addClassEntry(jarOutput, RunJarTest.class);\n            JarEntry entry = new JarEntry(\"payload.txt\");\n            jarOutput.putNextEntry(entry);\n            jarOutput.write(\"payload\".getBytes(StandardCharsets.UTF_8));\n            jarOutput.closeEntry();\n        }\n        return jar;\n    }\n\n    private static void addClassEntry(JarOutputStream jarOutput, Class<?> type) throws Exception {\n        String classResource = type.getName().replace('.', '/') + \".class\";\n        jarOutput.putNextEntry(new JarEntry(classResource));\n        try (InputStream input = type.getClassLoader().getResourceAsStream(classResource)) {\n            if (input == null) {\n                throw new IllegalStateException(\"Could not locate class resource \" + classResource);\n            }\n            input.transferTo(jarOutput);\n        }\n        jarOutput.closeEntry();\n    }\n\n    public static void main(String[] args) {\n        System.setProperty(INVOKED_PROPERTY, \"true\");\n        System.setProperty(ARGUMENTS_PROPERTY, String.join(\",\", args));\n    }\n\n    private static void resetTarget() {\n        System.clearProperty(INVOKED_PROPERTY);\n        System.clearProperty(ARGUMENTS_PROPERTY);\n    }\n}\n"}], "isError": false, "timestamp": 1778027058728}]}
