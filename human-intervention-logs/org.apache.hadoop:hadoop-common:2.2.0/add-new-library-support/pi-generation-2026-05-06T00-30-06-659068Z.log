      return ih instanceof RpcInvocationHandler;
    }
  
    @Override
    public void close() throws IOException {
      proxyProvider.close();
    }
  
    @Override //RpcInvocationHandler
    public ConnectionId getConnectionId() {
      return RPC.getConnectionIdForProxy(currentProxy);
    }
  
  }
