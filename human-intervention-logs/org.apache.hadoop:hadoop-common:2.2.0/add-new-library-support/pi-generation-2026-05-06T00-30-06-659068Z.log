[tool-call] delta {"path":"tests/src/org.apache.hadoop/hadoop-common/2.2.0/src/test/java/org_apache_hadoop/hadoop_common/RetryInvocationHandlerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_common;\n\nimport java.io.IOException;\n\nimport org.apache.hadoop.io.retry.AtMostOnce;\nimport org.apache.hadoop.io.retry.RetryPolicy;\nimport org.apache.hadoop.io.retry.RetryPolicy.RetryAction;\nimport org.apache.hadoop.io.retry.RetryProxy;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RetryInvocationHandlerTest {\n    @Test\n    void retriesFailedAtMostOnceMethodInvocation() throws IOException {\n        CapturingRetryPolicy retryPolicy = new CapturingRetryPolicy();\n        FailsOnceService implementation = new FailsOnceService();\n        UnstableService service = (UnstableService) RetryProxy.create(UnstableService.class, implementation, retryPolicy);\n\n        String result = service.readValue();\n\n        assertThat(result).isEqualTo(\"value-after-retry\");\n        assertThat(implementation.getInvocationCount()).isEqualTo(2);\n        assertThat(retryPolicy.getRetryAttempts()).isEqualTo(1);\n        assertThat(retryPolicy.wasLastInvocationIdempotentOrAtMostOnce()).isTrue();\n    }\n\n    public interface UnstableService {\n        @AtMostOnce\n        String readValue() throws IOException;\n    }\n\n    public static class FailsOnceService implements UnstableService {\n        private int invocationCount;\n\n        @Override\n        public String readValue() throws IOException {\n            invocationCount++;\n            if (invocationCount == 1) {\n                throw new IOException(\"first call fails\");\n            }\n            return \"value-after-retry\";\n        }\n\n        int getInvocationCount() {\n            return invocationCount;\n        }\n    }\n\n    private static class CapturingRetryPolicy implements RetryPolicy {\n        private int retryAttempts;\n        private boolean lastInvocationIdempotentOrAtMostOnce;\n\n        @Override\n        public RetryAction shouldRetry(Exception exception, int retries, int failovers,\n                boolean isIdempotentOrAtMostOnce) {\n            retryAttempts++;\n            lastInvocationIdempotentOrAtMostOnce = isIdempotentOrAtMostOnce;\n            return RetryAction.RETRY;\n        }\n\n        int getRetryAttempts() {\n            return retryAttempts;\n        }\n\n        boolean wasLastInvocationIdempotentOrAtMostOnce() {\n            return lastInvocationIdempotentOrAtMostOnce;\n        }\n    }\n}\n"}
