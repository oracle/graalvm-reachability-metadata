  package org_apache_hadoop.hadoop_common;
  
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.util.List;
  
  import org.apache.hadoop.conf.Configurable;
  import org.apache.hadoop.conf.Configuration;
  import org.apache.hadoop.mapred.JobConf;
  import org.apache.hadoop.mapred.JobConfigurable;
  import org.apache.hadoop.util.ReflectionUtils;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectionUtilsTest {
      @Test
      void createsInstanceWithDefaultConstructorAndAppliesConfiguration() {
          Configuration configuration = new Configuration(false);
  
          ConstructedConfigurable instance = ReflectionUtils.newInstance(ConstructedConfigurable.class, configuration);
  
          assertThat(instance.isConstructed()).isTrue();
          assertThat(instance.getConf()).isSameAs(configuration);
      }
  
      @Test
      void invokesLegacyJobConfigurableConfigureMethodWhenJobConfIsAvailable() {
          JobConf jobConf = new JobConf(false);
          JobConfigured target = new JobConfigured();
  
          ReflectionUtils.setConf(target, jobConf);
  
          assertThat(target.getConfiguredWith()).isSameAs(jobConf);
      }
  
      @Test
      void returnsDeclaredFieldsFromClassHierarchy() {
          List<Field> fields = ReflectionUtils.getDeclaredFieldsIncludingInherited(ChildFieldHolder.class);
  
          assertThat(fields).extracting(Field::getName)
                  .contains("childField", "parentField");
      }
  
      @Test
      void returnsDeclaredMethodsFromClassHierarchy() {
          List<Method> methods = ReflectionUtils.getDeclaredMethodsIncludingInherited(ChildMethodHolder.class);
  
          assertThat(methods).extracting(Method::getName)
                  .contains("childMethod", "parentMethod");
      }
  
      public static class ConstructedConfigurable implements Configurable {
          private final boolean constructed;
          private Configuration configuration;
  
          public ConstructedConfigurable() {
              constructed = true;
          }
  
          @Override
          public void setConf(Configuration configuration) {
              this.configuration = configuration;
          }
  
          @Override
          public Configuration getConf() {
              return configuration;
          }
  
          boolean isConstructed() {
              return constructed;
          }
      }
  
      public static class JobConfigured implements JobConfigurable {
          private JobConf configuredWith;
  
          @Override
          public void configure(JobConf jobConf) {
              configuredWith = jobConf;
          }
  
          JobConf getConfiguredWith() {
              return configuredWith;
          }
      }
  
      private static class ParentFieldHolder {
          private String parentField;
      }
  
      private static class ChildFieldHolder extends ParentFieldHolder {
          private String childField;
      }
  
      private static class ParentMethodHolder {
          private void parentMethod() {
          }
      }
  
      private static class ChildMethodHolder extends ParentMethodHolder {
          private void childMethod() {
          }
      }
  }
