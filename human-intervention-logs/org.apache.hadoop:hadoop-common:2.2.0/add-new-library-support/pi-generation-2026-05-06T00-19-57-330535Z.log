  package org_apache_hadoop.hadoop_common;
  
  import java.io.OutputStream;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Arrays;
  import java.util.List;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  import java.util.jar.Manifest;
  
  import org.apache.hadoop.util.RunJar;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RunJarTest {
      private static volatile boolean targetInvoked;
      private static volatile List<String> targetArguments = List.of();
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void loadsMainClassFromJarManifestAndInvokesMainMethod() throws Throwable {
          resetTarget();
          Path jar = createJarWithMainClassManifest(RunJarTest.class.getName());
          ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
  
          try {
              RunJar.main(new String[] {jar.toString(), "alpha", "beta"});
  
              assertThat(targetWasInvoked()).isTrue();
              assertThat(targetArguments()).containsExactly("alpha", "beta");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private Path createJarWithMainClassManifest(String mainClassName) throws Exception {
          Path jar = temporaryDirectory.resolve("runjar-target.jar");
          Manifest manifest = new Manifest();
          manifest.getMainAttributes().putValue("Manifest-Version", "1.0");
          manifest.getMainAttributes().putValue("Main-Class", mainClassName);
  
          try (OutputStream file = Files.newOutputStream(jar);
                  JarOutputStream jarOutput = new JarOutputStream(file, manifest)) {
              JarEntry entry = new JarEntry("payload.txt");
              jarOutput.putNextEntry(entry);
              jarOutput.write("payload".getBytes(StandardCharsets.UTF_8));
              jarOutput.closeEntry();
