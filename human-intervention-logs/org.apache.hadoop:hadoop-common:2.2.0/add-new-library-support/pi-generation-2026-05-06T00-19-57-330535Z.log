ghts waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_common;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataInput;\nimport java.io.DataInputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\n\nimport org.apache.hadoop.io.ObjectWritable;\nimport org.apache.hadoop.ipc.protobuf.IpcConnectionContextProtos.UserInformationProto;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ObjectWritableTest {\n    @Test\n    void readsObjectArraySerializedWithoutConfiguration() throws IOException {\n        String[] values = {\"alpha\", \"beta\", \"gamma\"};\n\n        Object restored = readWrittenObject(values, String[].class);\n\n        assertThat(restored).isInstanceOf(String[].class);\n        assertThat((String[]) restored).containsExactly(values);\n    }\n\n    @Test\n    void readsProtobufFromInputStreamBackedDataInput() throws IOException {\n        UserInformationProto message = testMessage(\"input-stream-backed\");\n        byte[] serialized = writeObject(message, UserInformationProto.class);\n\n        Object restored = ObjectWritable.readObject(\n                new DataInputStream(new ByteArrayInputStream(serialized)), null);\n\n        assertThat(restored).isEqualTo(message);\n    }\n\n    @Test\n    void readsProtobufFromDataInputThatIsNotAnInputStream() throws IOException {\n        UserInformationProto message = testMessage(\"data-input-only\");\n        byte[] serialized = writeObject(message, UserInformationProto.class);\n\n        Object restored = ObjectWritable.readObject(new DelegatingDataInput(serialized), null);\n\n        assertThat(restored).isEqualTo(message);\n    }\n\n    private static Object readWrittenObject(Object instance, Class<?> declaredClass) throws IOException {\n        return ObjectWritable.readObject(\n                new DataInputStream(new ByteArrayInputStream(writeObject(instance, declaredClass))), null);\n    }\n\n    private static byte[] writeObject(Object instance, Class<?> declaredClass) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (DataOutputStream out = new DataOutputStream(bytes)) {\n            ObjectWritable.writeObject(out, instance, declaredClass, null);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static UserInformationProto testMessage(String userName) {\n        return UserInformationProto.newBuilder()\n                .setEffectiveUser(userName)\n                .setRealUser(\"real-\" + userName)\n                .build();\n    }\n\n    private static final class DelegatingDataInput implements DataInput {\n        private final DataInputStream in;\n\n        private DelegatingDataInput(byte[] data) {\n            in = new DataInputStream(new ByteArrayInputStream(data));\n        }\n\n        @Override\n        public void readFully(byte[] bytes) throws IOException {\n            in.readFully(bytes);\n        }\n\n        @Override\n        public void readFully(byte[] bytes, int offset, int length) throws IOException {\n            in.readFully(bytes, offset, length);\n        }\n\n        @Override\n        public int skipBytes(int count) throws IOException {\n            return in.skipBytes(count);\n        }\n\n        @Override\n        public boolean readBoolean() throws IOException {\n            return in.readBoolean();\n        }\n\n        @Override\n        public byte readByte() throws IOException {\n            return in.readByte();\n        }\n\n        @Override\n        public int readUnsignedByte() throws IOException {\n            return in.readUnsignedByte();\n        }\n\n        @Override\n        public short readShort() throws IOException {\n            return in.readShort();\n        }\n\n        @Override\n        public int readUnsignedShort() throws IOException {\n            return in.readUnsignedShort();\n        }\n\n        @Override\n        public char readChar() throws IOException {\n            return in.readChar();\n        }\n\n        @Override\n        public int readInt() throws IOException {\n            return in.readInt();\n        }\n\n        @Override\n        public long readLong() throws IOException {\n            return in.readLong();\n        }\n\n        @Override\n        public float readFloat() throws IOException {\n            return in.readFloat();\n        }\n\n        @Override\n        public double readDouble() throws IOException {\n            return in.readDouble();\n        }\n\n        @Override\n        public String readLine() throws IOException {\n            return in.readLine();\n        }\n\n        @Override\n        public String readUTF() throws IOException {\n            return in.readUTF();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778026632963}, {"role": "toolResult", "toolCallId": "call_rF2MsvoElzxUNk9phQLNWthY|fc_05e0292de2a14f950169fa8888bca881a19ce7cd4a80d6cd16", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_common;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.List;\n\nimport org.apache.hadoop.conf.Configurable;\nimport org.apache.hadoop.conf.Configuration;\nimport org.apache.hadoop.mapred.JobConf;\nimport org.apache.hadoop.mapred.JobConfigurable;\nimport org.apache.hadoop.util.ReflectionUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionUtilsTest {\n    @Test\n    void createsInstanceWithDefaultConstructorAndAppliesConfiguration() {\n        Configuration configuration = new Configuration(false);\n\n        ConstructedConfigurable instance = ReflectionUtils.newInstance(ConstructedConfigurable.class, configuration);\n\n        assertThat(instance.isConstructed()).isTrue();\n        assertThat(instance.getConf()).isSameAs(configuration);\n    }\n\n    @Test\n    void invokesLegacyJobConfigurableConfigureMethodWhenJobConfIsAvailable() {\n        JobConf jobConf = new JobConf(false);\n        JobConfigured target = new JobConfigured();\n\n        ReflectionUtils.setConf(target, jobConf);\n\n        assertThat(target.getConfiguredWith()).isSameAs(jobConf);\n    }\n\n    @Test\n    void returnsDeclaredFieldsFromClassHierarchy() {\n        List<Field> fields = ReflectionUtils.getDeclaredFieldsIncludingInherited(ChildFieldHolder.class);\n\n        assertThat(fields).extracting(Field::getName)\n                .contains(\"childField\", \"parentField\");\n    }\n\n    @Test\n    void returnsDeclaredMethodsFromClassHierarchy() {\n        List<Method> methods = ReflectionUtils.getDeclaredMethodsIncludingInherited(ChildMethodHolder.class);\n\n        assertThat(methods).extracting(Method::getName)\n                .contains(\"childMethod\", \"parentMethod\");\n    }\n\n    public static class ConstructedConfigurable implements Configurable {\n        private final boolean constructed;\n        private Configuration configuration;\n\n        public ConstructedConfigurable() {\n            constructed = true;\n        }\n\n        @Override\n        public void setConf(Configuration configuration) {\n            this.configuration = configuration;\n        }\n\n        @Override\n        public Configuration getConf() {\n            return configuration;\n        }\n\n        boolean isConstructed() {\n            return constructed;\n        }\n    }\n\n    public static class JobConfigured implements JobConfigurable {\n        private JobConf configuredWith;\n\n        @Override\n        public void configure(JobConf jobConf) {\n            configuredWith = jobConf;\n        }\n\n        JobConf getConfiguredWith() {\n            return configuredWith;\n        }\n    }\n\n    private static class ParentFieldHolder {\n        private String parentField;\n    }\n\n    private static class ChildFieldHolder extends ParentFieldHolder {\n        private String childField;\n    }\n\n    private static class ParentMethodHolder {\n        private void parentMethod() {\n        }\n    }\n\n    private static class ChildMethodHolder extends ParentMethodHolder {\n        private void childMethod() {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778026632970}]}
