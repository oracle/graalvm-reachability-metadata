rgetArguments() {\n        return targetArguments;\n    }", "newText": "    private static void addClassEntry(JarOutputStream jarOutput, Class<?> type) throws Exception {\n        String classResource = type.getName().replace('.', '/') + \".class\";\n        jarOutput.putNextEntry(new JarEntry(classResource));\n        try (InputStream input = type.getClassLoader().getResourceAsStream(classResource)) {\n            if (input == null) {\n                throw new IllegalStateException(\"Could not locate class resource \" + classResource);\n            }\n            input.transferTo(jarOutput);\n        }\n        jarOutput.closeEntry();\n    }\n\n    public static void main(String[] args) {\n        System.setProperty(INVOKED_PROPERTY, \"true\");\n        System.setProperty(ARGUMENTS_PROPERTY, String.join(\",\", Arrays.asList(args.clone())));\n    }\n\n    private static void resetTarget() {\n        System.clearProperty(INVOKED_PROPERTY);\n        System.clearProperty(ARGUMENTS_PROPERTY);\n    }"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1009, "output": 2125, "cacheRead": 42496, "cacheWrite": 0, "totalTokens": 45630, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778026746124, "responseId": "resp_05e0292de2a14f950169fa88fab60081a1a0334b00fbe3719f"}}
