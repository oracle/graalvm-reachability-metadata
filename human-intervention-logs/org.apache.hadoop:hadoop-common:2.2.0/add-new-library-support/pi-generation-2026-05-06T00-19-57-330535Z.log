[tool-call] delta {"path":"tests/src/org.apache.hadoop/hadoop-common/2.2.0/src/test/java/org_apache_hadoop/hadoop_common/RunJarTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_common;\n\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Arrays;\nimport java.util.List;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarOutputStream;\nimport java.util.jar.Manifest;\n\nimport org.apache.hadoop.util.RunJar;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RunJarTest {\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void loadsMainClassFromJarManifestAndInvokesMainMethod() throws Throwable {\n        RunJarTarget.reset();\n        Path jar = createJarWithMainClassManifest(RunJarTarget.class.getName());\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            RunJar.main(new String[] {jar.toString(), \"alpha\", \"beta\"});\n\n            assertThat(RunJarTarget.wasInvoked()).isTrue();\n            assertThat(RunJarTarget.arguments()).containsExactly(\"alpha\", \"beta\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private Path createJarWithMainClassManifest(String mainClassName) throws Exception {\n        Path jar = temporaryDirectory.resolve(\"runjar-target.jar\");\n        Manifest manifest = new Manifest();\n        manifest.getMainAttributes().putValue(\"Manifest-Version\", \"1.0\");\n        manifest.getMainAttributes().putValue(\"Main-Class\", mainClassName);\n\n        try (OutputStream file = Files.newOutputStream(jar);\n                JarOutputStream jarOutput = new JarOutputStream(file, manifest)) {\n            JarEntry entry = new JarEntry(\"payload.txt\");\n            jarOutput.putNextEntry(entry);\n            jarOutput.write(\"payload\".getBytes(StandardCharsets.UTF_8));\n            jarOutput.closeEntry();\n        }\n        return jar;\n    }\n\n    public static final class RunJarTarget {\n        private static volatile boolean invoked;\n        private static volatile List<String> arguments = List.of();\n\n        public static void main(String[] args) {\n            invoked = true;\n            arguments = Arrays.asList(args.clone());\n        }\n\n        private static void reset() {\n            invoked = false;\n            arguments = List.of();\n        }\n\n        private static boolean wasInvoked() {\n            return invoked;\n        }\n\n        private static List<String> arguments() {\n            return arguments;\n        }\n    }\n}\n"}
