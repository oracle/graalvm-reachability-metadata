  package org_apache_hadoop.hadoop_common;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.DataInput;
  import java.io.DataInputStream;
  import java.io.DataOutputStream;
  import java.io.IOException;
  
  import org.apache.hadoop.io.ObjectWritable;
  import org.apache.hadoop.ipc.protobuf.IpcConnectionContextProtos.UserInformationProto;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ObjectWritableTest {
      @Test
      void readsObjectArraySerializedWithoutConfiguration() throws IOException {
          String[] values = {"alpha", "beta", "gamma"};
  
          Object restored = readWrittenObject(values, String[].class);
  
          assertThat(restored).isInstanceOf(String[].class);
          assertThat((String[]) restored).containsExactly(values);
      }
  
      @Test
      void readsProtobufFromInputStreamBackedDataInput() throws IOException {
          UserInformationProto message = testMessage("input-stream-backed");
          byte[] serialized = writeObject(message, UserInformationProto.class);
  
          Object restored = ObjectWritable.readObject(
                  new DataInputStream(new ByteArrayInputStream(serialized)), null);
  
          assertThat(restored).isEqualTo(message);
      }
  
      @Test
      void readsProtobufFromDataInputThatIsNotAnInputStream() throws IOException {
          UserInformationProto message = testMessage("data-input-only");
          byte[] serialized = writeObject(message, UserInformationProto.class);
  
          Object restored = ObjectWritable.readObject(new DelegatingDataInput(serialized), null);
  
          assertThat(restored).isEqualTo(message);
      }
  
      private static Object readWrittenObject(Object instance, Class<?> declaredClass) throws IOException {
          return ObjectWritable.readObject(
                  new DataInputStream(new ByteArrayInputStream(writeObject(instance, declaredClass))), null);
      }
  
      private static byte[] writeObject(Object instance, Class<?> declaredClass) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (DataOutputStream out = new DataOutputStream(bytes)) {
              ObjectWritable.writeObject(out, instance, declaredClass, null);
          }
          return bytes.toByteArray();
      }
  
      private static UserInformationProto testMessage(String userName) {
          return UserInformationProto.newBuilder()
                  .setEffectiveUser(userName)
                  .setRealUser("real-" + userName)
                  .build();
      }
  
      private static final class DelegatingDataInput implements DataInput {
          private final DataInputStream in;
  
          private DelegatingDataInput(byte[] data) {
              in = new DataInputStream(new ByteArrayInputStream(data));
          }
  
          @Override
          public void readFully(byte[] bytes) throws IOException {
              in.readFully(bytes);
          }
  
          @Override
          public void readFully(byte[] bytes, int offset, int length) throws IOException {
              in.readFully(bytes, offset, length);
          }
  
          @Override
          public int skipBytes(int count) throws IOException {
              return in.skipBytes(count);
          }
  
          @Override
          public boolean readBoolean() throws IOException {
              return in.readBoolean();
          }
  
          @Override
          public byte readByte() throws IOException {
              return in.readByte();
          }
  
          @Override
          public int readUnsignedByte() throws IOException {
              return in.readUnsignedByte();
          }
  
          @Override
          public short readShort() throws IOException {
              return in.readShort();
          }
  
          @Override
          public int readUnsignedShort() throws IOException {
              return in.readUnsignedShort();
          }
  
          @Override
          public char readChar() throws IOException {
              return in.readChar();
          }
  
          @Override
          public int readInt() throws IOException {
              return in.readInt();
          }
  
          @Override
          public long readLong() throws IOException {
              return in.readLong();
          }
  
          @Override
          public float readFloat() throws IOException {
              return in.readFloat();
          }
  
          @Override
          public double readDouble() throws IOException {
              return in.readDouble();
          }
  
          @Override
          public String readLine() throws IOException {
              return in.readLine();
          }
  
          @Override
          public String readUTF() throws IOException {
              return in.readUTF();
          }
      }
  }
