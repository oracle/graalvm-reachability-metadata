{"type":"item.completed","item":{"id":"item_40","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/ValidateIndexFilesTask.java | sed -n '188,320p'\"","aggregated_output":"   188\t     * Checks Maven Central URL templates against every tested-version alias in the entry.\n   189\t     * <p>\n   190\t     * This is intentionally a structural check instead of an HTTP probe so the global\n   191\t     * index validator remains deterministic. It catches templates such as\n   192\t     * {@code $version$+1} on entries that also contain aliases like {@code 13} or\n   193\t     * {@code 13-ea+1}, where rendering creates untracked Maven artifact versions.\n   194\t     */\n   195\t    static void checkLibraryIndexUrlTemplates(Object jsonNode, String filePath, List<String> failures) {\n   196\t        if (!(jsonNode instanceof JsonNode json) || !json.isArray()) {\n   197\t            return;\n   198\t        }\n   199\t\n   200\t        Matcher coordinateMatcher = METADATA_COORDINATE_PATTERN.matcher(filePath);\n   201\t        if (!coordinateMatcher.matches()) {\n   202\t            return;\n   203\t        }\n   204\t\n   205\t        String groupPath = coordinateMatcher.group(1).replace('.', '/');\n   206\t        String artifact = coordinateMatcher.group(2);\n   207\t\n   208\t        for (JsonNode entry : json) {\n   209\t            String metadataVersion = entry.path(\"metadata-version\").isTextual()\n   210\t                    ? entry.path(\"metadata-version\").asText()\n   211\t                    : \"<unknown>\";\n   212\t            List<String> testedVersions = testedVersions(entry);\n   213\t            if (testedVersions.size() <= 1) {\n   214\t                continue;\n   215\t            }\n   216\t\n   217\t            Set<String> testedVersionSet = new LinkedHashSet<>(testedVersions);\n   218\t            for (String fieldName : URL_TEMPLATE_FIELDS) {\n   219\t                JsonNode urlNode = entry.get(fieldName);\n   220\t                if (urlNode == null || !urlNode.isTextual()) {\n   221\t                    continue;\n   222\t                }\n   223\t\n   224\t                String template = urlNode.asText();\n   225\t                if (!template.contains(VERSION_TOKEN)) {\n   226\t                    continue;\n   227\t                }\n   228\t\n   229\t                for (String testedVersion : testedVersions) {\n   230\t                    String renderedUrl = template.replace(VERSION_TOKEN, testedVersion);\n   231\t                    String renderedMavenVersion = mavenCentralArtifactVersion(renderedUrl, groupPath, artifact);\n   232\t                    if (renderedMavenVersion == null || testedVersion.equals(renderedMavenVersion)) {\n   233\t                        continue;\n   234\t                    }\n   235\t                    if (!testedVersionSet.contains(renderedMavenVersion)) {\n   236\t                        failures.add(\"❌ \" + filePath + \": \" + fieldName\n   237\t                                + \" template under metadata-version \" + metadataVersion\n   238\t                                + \" renders tested-version \" + testedVersion\n   239\t                                + \" to Maven artifact version \" + renderedMavenVersion\n   240\t                                + \", which is not listed in tested-versions. Split the entry or use an alias-safe URL.\");\n   241\t                    }\n   242\t                }\n   243\t            }\n   244\t        }\n   245\t    }\n   246\t\n   247\t    private static List<String> testedVersions(Object entryNode) {\n   248\t        if (!(entryNode instanceof JsonNode entry)) {\n   249\t            return Collections.emptyList();\n   250\t        }\n   251\t        JsonNode testedVersionsNode = entry.get(\"tested-versions\");\n   252\t        if (testedVersionsNode == null || !testedVersionsNode.isArray()) {\n   253\t            return Collections.emptyList();\n   254\t        }\n   255\t\n   256\t        List<String> testedVersions = new ArrayList<>();\n   257\t        for (JsonNode testedVersionNode : testedVersionsNode) {\n   258\t            if (testedVersionNode != null && testedVersionNode.isTextual()) {\n   259\t                testedVersions.add(testedVersionNode.asText());\n   260\t            }\n   261\t        }\n   262\t        return testedVersions;\n   263\t    }\n   264\t\n   265\t    private static String mavenCentralArtifactVersion(String renderedUrl, String groupPath, String artifact) {\n   266\t        URI uri;\n   267\t        try {\n   268\t            uri = URI.create(renderedUrl);\n   269\t        } catch (IllegalArgumentException e) {\n   270\t            return null;\n   271\t        }\n   272\t\n   273\t        String host = uri.getHost();\n   274\t        if (host == null || !MAVEN_CENTRAL_HOSTS.contains(host.toLowerCase(Locale.ROOT))) {\n   275\t            return null;\n   276\t        }\n   277\t\n   278\t        String expectedPrefix = \"/maven2/\" + groupPath + \"/\" + artifact + \"/\";\n   279\t        String path = uri.getPath();\n   280\t        if (path == null || !path.startsWith(expectedPrefix)) {\n   281\t            return null;\n   282\t        }\n   283\t\n   284\t        String remainder = path.substring(expectedPrefix.length());\n   285\t        int separator = remainder.indexOf('/');\n   286\t        if (separator <= 0 || separator == remainder.length() - 1) {\n   287\t            return null;\n   288\t        }\n   289\t\n   290\t        String artifactVersion = remainder.substring(0, separator);\n   291\t        String fileName = remainder.substring(separator + 1);\n   292\t        if (!fileName.startsWith(artifact + \"-\" + artifactVersion + \"-\")) {\n   293\t            return null;\n   294\t        }\n   295\t        return artifactVersion;\n   296\t    }\n   297\t\n   298\t    /**\n   299\t     * Ensures \"tested-versions\" are mapped to the most appropri