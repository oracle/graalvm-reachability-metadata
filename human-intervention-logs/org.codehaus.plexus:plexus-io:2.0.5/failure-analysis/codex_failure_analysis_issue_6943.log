tility_scripts/metrics_writer.py:158:        covered = line_coverage.get(\"covered\")\n./forge/utility_scripts/metrics_writer.py:162:    if line_coverage != \"N/A\":\n./forge/utility_scripts/metrics_writer.py:165:    instruction_coverage = library_coverage.get(\"instruction\")\n./forge/utility_scripts/metrics_writer.py:166:    if instruction_coverage == \"N/A\":\n./forge/utility_scripts/metrics_writer.py:168:    if isinstance(instruction_coverage, dict):\n./forge/utility_scripts/metrics_writer.py:169:        ratio = instruction_coverage.get(\"ratio\")\n./forge/utility_scripts/metrics_writer.py:294:def collect_version_coverage_metrics(repo_path: str, package: str, artifact: str, library_version: str):\n./forge/utility_scripts/metrics_writer.py:295:    \"\"\"Return coverage metrics from exploded stats files for a library version.\"\"\"\n./forge/utility_scripts/metrics_writer.py:296:    stats_coverage = _stats_coverage_metrics(repo_path, package, artifact, library_version)\n./forge/utility_scripts/metrics_writer.py:297:    if stats_coverage is not None:\n./forge/utility_scripts/metrics_writer.py:298:        return stats_coverage\n./forge/utility_scripts/metrics_writer.py:321:      - coverage_percent (float)\n./forge/utility_scripts/metrics_writer.py:335:    coverage_percent, lines_covered = collect_version_coverage_metrics(repo_path, package, artifact, library_version)\n./forge/utility_scripts/metrics_writer.py:366:        f\"Iterations: {global_iterations}  Input Tokens: {input_tokens_used}{cached_tokens_suffix} Output Tokens: {output_tokens_used} Metadata Entries: {total_entries}{test_metadata_suffix} Coverage: {coverage_percent:.2f}% Generated LOC: {generated_loc} Cost: {total_cost_usd:.4f} Library lines covered: {lines_covered}\")\n./forge/utility_scripts/metrics_writer.py:369:        \"coverage_percent\": coverage_percent,\n./forge/utility_scripts/metrics_writer.py:391:        strategy_name: str,\n./forge/utility_scripts/metrics_writer.py:398:        coverage_perc