ies(Map<String, String> allProps, String name) {\\r\\n        Map<String, String> props = new HashMap<>();\\r\\n        String start = LOAD + name;\\r\\n        allProps.entrySet().stream().filter(entry -> entry.getKey().startsWith(start)).forEach(\\r\\n                entry -> props.put(entry.getKey().substring(start.length() + 1), entry.getValue()));\\r\\n        return props;\\r\\n    }\\r\\n\\r\\n}\\r\\n\"}], \"isError\": false, \"timestamp\": 1777723484973}}\n1315:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"toolCall\", \"id\": \"call_6fLM8MCAgelr8A76Ezq0Dlog|fc_0a83b75ce14898880169f5e85ca970819785a311c667443ec8\", \"name\": \"read\", \"arguments\": {\"path\": \"/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/org/javamoney/moneta/spi/DefaultMonetaryAmountsSingletonSpi.java\"}}, {\"type\": \"toolCall\", \"id\": \"call_nUhYvVFq7G2cBgE9mOtqSWkl|fc_0a83b75ce14898880169f5e85ca98881979e1323e5b5e4b23f\", \"name\": \"read\", \"arguments\": {\"path\": \"/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/javamoney.properties\"}}, {\"type\": \"toolCall\", \"id\": \"call_KPttyLZSrNlEYLpQAt44oljM|fc_0a83b75ce14898880169f5e85ca99c8197b290687f72e62e9e\", \"name\": \"read\", \"arguments\": {\"path\": \"/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/org/javamoney/moneta/spi/loader/DefaultLoaderService.java\"}}, {\"type\": \"toolCall\", \"id\": \"call_s10VUKtU4jDNkCRiKB2XqvPH|fc_0a83b75ce14898880169f5e85ca9a881979910b413d67e1f17\", \"name\": \"read\", \"arguments\": {\"path\": \"/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/m