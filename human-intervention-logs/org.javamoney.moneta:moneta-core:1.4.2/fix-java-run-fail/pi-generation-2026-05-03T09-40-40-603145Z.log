astMoney.class);\n            assertThat(amounts.getAmountTypes()).contains(FastMoney.class);\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(DEFAULT_AMOUNT_TYPE_PROPERTY);\n            } else {\n                System.setProperty(DEFAULT_AMOUNT_TYPE_PROPERTY, previousValue);\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777801218909}, {"role": "toolResult", "toolCallId": "call_2Q36YGBuGhz5HadnYRFW0bwc|fc_07341ac187fc6d130169f7180293b8819c839a6bb257a2467b", "toolName": "read", "content": [{"type": "text", "text": "load.loader-configurator-absolute.type=LAZY\nload.loader-configurator-absolute.resource=/javamoney.properties\n"}], "isError": false, "timestamp": 1777801218910}, {"role": "toolResult", "toolCallId": "call_RnxsmfroMV0lxWPwXTwEtgSY|fc_07341ac187fc6d130169f7180293c0819c9c6b0c39135b0ba4", "toolName": "bash", "content": [{"type": "text", "text": "/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/javamoney.properties\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/META-INF/services/javax.money.spi.MonetaryAmountsSingletonQuerySpi\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/META-INF/services/javax.money.spi.MonetaryAmountsSingletonSpi\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/org/javamoney/moneta/FastMoney.java\n/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/source_context/org.javamoney.moneta/moneta-core/1.4.2/main/extracted/org/javamoney/moneta/function/FastMoneyProducer.java\n/home/vjovanov/c/forge/forge1/graalvm-re