ource)\n   245\t                .bindOrCreate(\"spring.integration\", Bindable.of(IntegrationProperties.class));\n   246\t\n   247\t        assertThat(properties.getManagement().isDefaultLoggingEnabled()).isFalse();\n   248\t        assertThat(properties.getManagement().getObservationPatterns()).containsExactly(\"flow*\", \"handler.input\");\n   249\t        assertThat(properties.getRsocket().getClient().getHost()).isEqualTo(\"localhost\");\n   250\t        assertThat(properties.getRsocket().getClient().getPort()).isEqualTo(7000);\n   251\t        assertThat(properties.getRsocket().getClient().getUri()).isEqualTo(URI.create(\"ws://localhost:7001/rsocket\"));\n   252\t        assertThat(properties.getRsocket().getServer().isMessageMappingEnabled()).isTrue();\n   253\t    }\n   254\t\n   255\t    @Configuration(proxyBeanMethods = false)\n   256\t    public static class SimpleIntegrationFlowConfiguration {\n   257\t\n   258\t        @Bean\n   259\t        public IntegrationFlow uppercaseFlow() {\n   260\t            return IntegrationFlow.from(\"input\")\n   261\t                .transform(String.class, String::toUpperCase)\n   262\t                .channel(\"output\")\n   263\t                .get();\n   264\t        }\n   265\t\n   266\t        @Bean\n   267\t        public QueueChannel output() {\n   268\t            return new QueueChannel();\n   269\t        }\n   270\t\n   271\t    }\n   272\t\n   273\t    static final class TestIntegrationGraphServer extends IntegrationGraphServer {\n   274\t\n   275\t        private Graph graph = new Graph(Map.of(\"state\", \"initial\"), List.of(), List.of());\n   276\t\n   277\t        private int rebuildCount;\n   278\t\n   279\t        @Override\n   280\t        public Graph getGraph() {\n   281\t            return this.graph;\n   282\t        }\n   283\t\n   284\t        @Override\n   285\t        public Graph rebuild() {\n   286\t            this.rebuildCount++;\n   287\t            this.graph = new Graph(Map.of(\"state\",