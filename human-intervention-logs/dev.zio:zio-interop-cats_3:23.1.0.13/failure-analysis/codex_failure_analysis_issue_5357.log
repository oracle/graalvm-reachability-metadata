\"test-code-url\" : \"https://svn.apache.org/repos/asf/directory/shared/tags/$version$/util/src/test/java/org/apache/directory/api/util/\",\n./metadata/org.apache.directory.api/api-util/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/apache/directory/api/api-util/$version$/api-util-$version$-javadoc.jar\",\n./metadata/com.google.android/annotations/index.json:6:    \"source-code-url\": \"https://repo1.maven.org/maven2/com/google/android/annotations/$version$/annotations-$version$-sources.jar\",\n./metadata/com.google.android/annotations/index.json:8:    \"test-code-url\": \"N/A\",\n./metadata/com.google.android/annotations/index.json:9:    \"documentation-url\": \"https://repo1.maven.org/maven2/com/google/android/annotations/$version$/annotations-$version$-javadoc.jar\",\n./metadata/org.apache.directory.api/api-i18n/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/apache/directory/api/api-i18n/$version$/api-i18n-$version$-sources.jar\",\n./metadata/org.apache.directory.api/api-i18n/index.json:7:    \"test-code-url\" : \"https://github.com/apache/directory-ldap-api/blob/$version$/integ-osgi/src/test/java/org/apache/directory/api/osgi/ApiI18nOsgiTest.java\",\n./metadata/org.apache.directory.api/api-i18n/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/apache/directory/api/api-i18n/$version$/api-i18n-$version$-javadoc.jar\",\n./metadata/org.apache.directory.api/api-i18n/index.json:33:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/apache/directory/api/api-i18n/$version$/api-i18n-$version$-sources.jar\",\n./metadata/org.apache.directory.api/api-i18n/index.json:35:    \"test-code-url\" : \"N/A\",\n./metadata/org.apache.directory.api/api-i18n/index.json:36:    \"documentation-url\" : \"https://javadoc.io/doc/org.apache.directory.api/api-i18n/$version$/\",\n./metadata/io.netty/netty-transport/index.json:9:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-transport/$version$/netty-transport-$version$-sources.jar\",\n./metadata/io.netty/netty-transport/index.json:11:    \"test-code-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-transport/$version$/netty-transport-$version$-test-sources.jar\",\n./metadata/io.netty/netty-transport/index.json:12:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/io/netty/netty-transport/$version$/netty-transport-$version$-javadoc.jar\",\n\n=== human-intervention-logs/dev.zio:zio-interop-cats_3:23.1.0.13/populate-artifact-urls/populate_artifact_urls.log ===\n> Task :tck-build-logic:extractPluginRequests UP-TO-DATE\n> Task :tck-build-logic:generatePluginAdapters UP-TO-DATE\n> Task :tck-build-logic:compileJava UP-TO-DATE\n> Task :tck-build-logic:compileGroovy UP-TO-DATE\n> Task :tck-build-logic:compileGroovyPlugins UP-TO-DATE\n> Task :tck-build-logic:pluginDescriptors UP-TO-DATE\n> Task :tck-build-logic:processResources UP-TO-DATE\n> Task :tck-build-logic:classes UP-TO-DATE\n> Task :tck-build-logic:jar UP-TO-DATE\n\n> Configure project :\nGraalVM Reachability Metadata TCK\n---------------------------------\n\n> Task :populateArtifactURLs\nSkipping dev.zio:zio-interop-cats_3:23.1.0.13 because all requested metadata fields are already present.\nCompleted populateArtifactURLs: invoked=0, prompted=0, skipped=1, overwriteExisting=false, verifyArtifactSources=false, limit=null\n\n[Incubating] Problems report is available at: file:///home/jovan/Work/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/5357-4fe91de6/build/reports/problems/problems-report.html\n\nDeprecated Gradle features were used in this build, making it incompatible with Gradle 10.\n\nYou can use '--warning-mode all' to show the individual deprecation warnings and determine if they come from your own scripts or plugins.\n\nFor more on this, please refer to https://docs.gradle.org/9.1.0/userguide/command_line_interface.html#sec:command_line_warnings in the Gradle documentat