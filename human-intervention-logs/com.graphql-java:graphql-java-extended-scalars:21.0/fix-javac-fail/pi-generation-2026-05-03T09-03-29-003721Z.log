                      if (!url.isPresent()) {
                          throw new CoercingParseValueException(
                                  "Expected a 'URL' like object but was '" + typeName(input) + "'."
                          );
                      }
                      return url.get();
                  }
                  return parseURL(urlStr, CoercingParseValueException::new);
