379\t      \"module\": \"java.base\",\n   380\t      \"glob\": \"java/lang/String.SCL.lombok\"\n\n---\n     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage org_projectlombok.lombok;\n     8\t\n     9\timport org.junit.jupiter.api.Test;\n    10\timport org.opentest4j.TestAbortedException;\n    11\t\n    12\timport java.lang.instrument.ClassFileTransformer;\n    13\timport java.lang.instrument.Instrumentation;\n    14\timport java.lang.reflect.InvocationTargetException;\n    15\timport java.lang.reflect.Method;\n    16\timport java.lang.reflect.Proxy;\n    17\timport java.util.ArrayList;\n    18\timport java.util.List;\n    19\t\n    20\timport static org.assertj.core.api.Assertions.assertThat;\n    21\t\n    22\tpublic class AgentTest {\n    23\t\n    24\t    @Test\n    25\t    void delegatesPremainToTheShadowLoadedAgentLauncher() throws Exception {\n    26\t        List<String> invokedMethods = new ArrayList<>();\n    27\t        Instrumentation instrumentation = (Instrumentation) Proxy.newProxyInstance(\n    28\t                AgentTest.class.getClassLoader(),\n    29\t                new Class<?>[]{Instrumentation.class},\n    30\t                (proxy, method, args) -> {\n    31\t                    invokedMethods.add(method.getName());\n    32\t                    if (method.getName().equals(\"addTransformer\") && args != null && args.length > 0) {\n    33\t                        assertThat(args[0]).isInstanceOf(ClassFileTransformer.class);\n    34\t                    }\n    35\t                    return defaultValue(method.getReturnType());\n    36\t                }\n    37\t        );\n    38\t\n    39\t        Class<?> agentClass = Class.forName(\"lombok.launch.Agent\");\n    40\t        Method premain = agentClass.getDeclaredMethod(\"premain\", String.class, Instrumentation.class);\n    41\t        premain.setAccessible(true);\n    42\t        try {\n    43\t            premain.invoke(null, \"\", instrumentation);\n    44\t        } catch (InvocationTargetException invocationTargetException) {\n    45\t            Throwable cause = invocationTargetException.getCause();\n    46\t            if (isUnsupportedNativeImageClassRoot(cause)) {\n    47\t                throw new TestAbortedException(\"Native image exposes embedded class resources with the resource: protocol\", cause);\n    48\t            }\n    49\t            throw invocationTargetException;\n    50\t        }\n    51\t\n    52\t        assertThat(invokedMethods).contains(\"addTransformer\");\n    53\t    }\n    54\t\n    55\t    private static boolean isUnsupportedNativeImageClassRoot(Throwable throwable) {\n    56\t        return isNativeImageRuntime()\n    57\t                && (throwable instanceof IllegalArgumentException)\n    58\t                && throwable.getMessage() != null\n    59\t                && throwable.getMessage().startsWith(\"Unknown protocol: resource:\");\n    60\t    }\n    61\t\n    62\t    private static boolean isNativeImageRuntime() {\n    63\t        return \"runtime\".equals(System.getProperty(\"org.graalvm.nativeimage.imagecode\"));\n    64\t    }\n    65\t\n    66\t    private static Object defaultValue(Class<?> returnType) {\n    67\t        if (!returnType.isPrimitive()) {\n    68\t            return null;\n    69\t        }\n    70\t        if (returnType == boolean.class) {\n    71\t            return false;\n    72\t        }\n    73\t        if (returnType == byte.class) {\n    74\t            return (byte) 0;\n    75\t        }\n    76\t        if (returnType == short.class) {\n    77\t            return (short) 0;\n    78\t        }\n    79\t        if (returnType == int.class) {\n    80\t            return 0;\n    81\t        }\n    82\t        if (returnType == long.class) {\n    83\t            return 0L;\n    84\t        }\n    85\t        if (returnType == float.class) {\n    86\t            return 0F;\n    87\t        }\n    88\t        if (returnType == double.class) {\n    89\t            return 0D;\n    90\t        }\n    91\t        if (returnType == char.class) {\n    92\t            return '\\0';\n    93\t        }\n    94\t        return null;\n    95\t    }\n    96\t}\n\n---\n     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage org_projectlombok.lombok;\n     8\t\n     9\timport org.junit.jupiter.api.Test;\n    10\timport org.opentest4j.TestAbortedException;\n    11\t\n    12\timport java.lang.reflect.Constructor;\n    13\timport java.lang.reflect.Method;\n    14\timport java.net.URL;\n    15\timport java.nio.file.Files;\n    16\timport java.nio.file.Path;\n    17\timport java.util.Collections;\n    18\timport java.util.List;\n    19\t\n    20\timport static org.assertj.core.api.Assertions.assertThat;\n    21\t\n    22\tpublic class ShadowClassLoaderTest {\n    23\t\n    24\t    @Test\n    25\t    void loadsResourcesAndClassesThroughTheShadowLoader() throws Exception {\n    26\t        ClassLoader shadowLoader = newShadowClassLoader();\n    27\t\n    28\t        assertThat(shadowLoader.getResource(\"java/lang/String.class\")).isNotNull();\n    29\t        List<URL> mainResources = Collections.list(shadowLoader.getResources(\"lombok/core/Main.class\"));\n    30\t        if (mainResources.isEmpty() && isNativeImageRuntime()) {\n    31\t            throw new TestAbortedException(\"Native image does not expose shadow-loader resources as enumerable jar/file URLs\");\n    32\t        }\n    33\t        assertThat(mainResources).isNotEmpty();\n    34\t        assertThat(shadowLoader.loadClass(\"java.lang.String\")).isSameAs(String.class);\n    35\t\n    36\t        Method addOverrideClasspathEntry = declaredMethod(shadowLoader.getClass(), \"addOverrideClasspathEntry\", String.class);\n    37\t        Path overrideDirectory = Files.createTempDirectory(\"lombok-shadow-override\");\n    38\t        addOverrideClasspathEntry.invoke(shadowLoader, overrideDirectory.toString());\n    39\t\n    40\t        assertThat(shadowLoader.getResource(\"lombok/core/Main.SCL.lombok\")).isNull();\n    41\t    }\n    42\t\n    43\t    @Test\n    44\t    void loadsClassesFromPrependedParentsBeforeFallingBackToTheRegularParent() throws Exception {\n    45\t        ClassLoader shadowLoader = newShadowClassLoader();\n    46\t        Method prependParent = declaredMethod(shadowLoader.getClass(), \"prependParent\", ClassLoader.class);\n    47\t        prependParent.invoke(shadowLoader, ClassLoader.getPlatformClassLoader());\n    48\t\n    49\t        assertThat(shadowLoader.loadClass(\"java.lang.Integer\")).isSameAs(Integer.class);\n    50\t    }\n    51\t\n    52\t    @Test\n    53\t    void fallsBackToTheAlreadyDefinedClassWhenTheSameBytesAreDefinedTwice() throws Exception {\n    54\t        ClassLoader shadowLoader = newShadowClassLoader();\n    55\t        Method urlToDefineClass = declaredMethod(shadowLoader.getClass(), \"urlToDefineClass\", String.class, URL.class, boolean.class);\n    56\t        URL shadowClass = shadowLoader.getResource(\"lombok/core/TypeLibrary.SCL.lombok\");\n    57\t        assertThat(shadowClass).isNotNull();\n    58\t\n    59\t        Class<?> firstDefinition = (Class<?>) urlToDefineClass.invoke(shadowLoader, \"lombok.core.TypeLibrary\", shadowClass, false);\n    60\t        Class<?> duplicateDefinition = (Class<?>) urlToDefineClass.invoke(shadowLoader, \"lombok.core.TypeLibrary\", shadowClass, false);\n    61\t\n    62\t        assertThat(duplicateDefinition).isSameAs(firstDefinition);\n    63\t    }\n    64\t\n    65\t    private static ClassLoader newShadowClassLoader() throws Exception {\n    66\t        Class<?> shadowClassLoaderClass = Class.forName(\"lombok.launch.ShadowClassLoader\");\n    67\t        Constructor<?> constructor = shadowClassLoaderClass.getDeclaredConstructor(\n    68\t                ClassLoader.class,\n    69\t                String.class,\n    70\t                String.class,\n    71\t                List.class,\n    72\t                List.class\n    73\t        );\n    74\t        constructor.setAccessible(true);\n    75\t        return (ClassLoader) constructor.newInstance(\n    76\t                ShadowClassLoaderTest.class.getClassLoader(),\n    77\t                \"lombok\",\n    78\t                null,\n    79\t                List.of(),\n    80\t                List.of(\"lombok.patcher.Symbols\")\n    81\t        );\n    82\t    }\n    83\t\n    84\t    private static Method declaredMethod(Class<?> type, String name, Class<?>... parameterTypes) throws Exception {\n    85\t        Method method = type.getDeclaredMethod(name, parameterTypes);\n    86\t        method.setAccessible(true);\n    87\t        return method;\n    88\t    }\n    89\t\n    90\t    private static boolean isNativeImageRuntime() {\n    91\t        return \"runtime\".equals(System.getProperty(\"org.graalvm.nativeimage.imagecode\"));\n    92\t    }\n    93\t}\n","exit_code":0,"status":"completed"}}
