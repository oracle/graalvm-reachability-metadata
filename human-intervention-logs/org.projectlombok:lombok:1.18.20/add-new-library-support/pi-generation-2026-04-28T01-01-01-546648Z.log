  		} catch (Exception e) {
  			return null;
  		}
  	}
  	
  	/**
  	 * Kotlin incremental processing
  	 */
  	private static Object tryGetProcessingEnvField(Class<?> delegateClass, Object instance) {
  		try {
  			return Permit.getField(delegateClass, "processingEnv").get(instance);
  		} catch (Exception e) {
  			return null;
  		}
  	}
  	
  	/**
