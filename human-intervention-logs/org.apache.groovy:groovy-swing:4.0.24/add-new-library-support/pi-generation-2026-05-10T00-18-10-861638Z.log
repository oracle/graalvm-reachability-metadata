[tool-call] delta {"path":"tests/src/org.apache.groovy/groovy-swing/4.0.24/src/test/groovy/org_apache_groovy/groovy_swing/LookAndFeelHelperTest.groovy","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_groovy.groovy_swing\n\nimport groovy.swing.LookAndFeelHelper\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\nimport static org.assertj.core.api.Assertions.assertThatCode\n\npublic class LookAndFeelHelperTest {\n    @Test\n    void probesOptionalLookAndFeelImplementations() {\n        List<String> lookAndFeelClassNames = [\n            LookAndFeelHelper.getNimbusLAFName(),\n            LookAndFeelHelper.getAquaLAFName(),\n            LookAndFeelHelper.getSubstanceLAFName(),\n        ]\n\n        assertThat(lookAndFeelClassNames).hasSize(3)\n        assertThat(lookAndFeelClassNames.findAll { String className -> className != null })\n            .allSatisfy { String className -> assertThat(className).isNotBlank() }\n    }\n\n    @Test\n    void createsHelperWithLookAndFeelAliasesInitialized() {\n        assertThatCode { LookAndFeelHelper.getInstance() }.doesNotThrowAnyException()\n    }\n}\n"}
