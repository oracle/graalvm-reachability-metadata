  package org_apache_groovy.groovy_swing
  
  import org.apache.groovy.swing.binding.ClosureTriggerBinding
  import org.apache.groovy.swing.binding.FullBinding
  import org.apache.groovy.swing.binding.TargetBinding
  import org.junit.jupiter.api.Test
  
  import java.beans.PropertyChangeListener
  import java.beans.PropertyChangeSupport
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class ClosureTriggerBindingAnonymous1Test {
      @Test
      void createsBindingFromClosureCapturingNestedPropertyPath() {
          PersonModel person = new PersonModel(new AddressModel('Paris'))
          ClosureTriggerBinding triggerBinding = new ClosureTriggerBinding(Collections.emptyMap())
          triggerBinding.setClosure({ person.address.city })
          RecordingTargetBinding targetBinding = new RecordingTargetBinding()
  
          FullBinding fullBinding = triggerBinding.createBinding(triggerBinding, targetBinding)
  
          try {
              fullBinding.bind()
              fullBinding.update()
  
              assertThat(targetBinding.values).containsExactly('Paris')
  
              person.getAddress().setCity('Prague')
              fullBinding.update()
  
              assertThat(targetBinding.values.first()).isEqualTo('Paris')
              assertThat(targetBinding.values.last()).isEqualTo('Prague')
          } finally {
              fullBinding.unbind()
          }
      }
  
      private static final class RecordingTargetBinding implements TargetBinding {
          private final List<Object> values = new ArrayList<>()
  
          @Override
          void updateTargetValue(Object value) {
              values.add(value)
          }
  
          List<Object> getValues() {
              return values
          }
      }
  
      private static final class PersonModel {
          private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this)
          private AddressModel address
  
          private PersonModel(AddressModel address) {
              this.address = address
          }
  
          AddressModel getAddress() {
              return address
          }
  
          void setAddress(AddressModel address) {
              AddressModel oldAddress = this.address
              this.address = address
              propertyChangeSupport.firePropertyChange('address', oldAddress, address)
          }
  
          void addPropertyChangeListener(String propertyName, PropertyChangeListener listener) {
              propertyChangeSupport.addPropertyChangeListener(propertyName, listener)
          }
  
          void removePropertyChangeListener(String propertyName, PropertyChangeListener listener) {
              propertyChangeSupport.removePropertyChangeListener(propertyName, listener)
          }
      }
  
      private static final class AddressModel {
          private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this)
          private String city
  
          private AddressModel(String city) {
              this.city = city
          }
  
          String getCity() {
              return city
          }
  
          void setCity(String city) {
              String oldCity = this.city
              this.city = city
              propertyChangeSupport.firePropertyChange('city', oldCity, city)
          }
  
          void addPropertyChangeListener(String propertyName, PropertyChangeListener listener) {
              propertyChangeSupport.addPropertyChangeListener(propertyName, listener)
          }
  
          void removePropertyChangeListener(String propertyName, PropertyChangeListener listener) {
              propertyChangeSupport.removePropertyChangeListener(propertyName, listener)
          }
      }
  }
