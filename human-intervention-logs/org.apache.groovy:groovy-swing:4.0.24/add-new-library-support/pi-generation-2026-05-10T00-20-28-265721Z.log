ing.values.last()).isEqualTo('Prague')\n        } finally {\n            fullBinding.unbind()\n        }\n    }\n\n    private static final class RecordingTargetBinding implements TargetBinding {\n        private final List<Object> values = new ArrayList<>()\n\n        @Override\n        void updateTargetValue(Object value) {\n            values.add(value)\n        }\n\n        List<Object> getValues() {\n            return values\n        }\n    }\n\n    private static final class PersonModel {\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this)\n        private AddressModel address\n\n        private PersonModel(AddressModel address) {\n            this.address = address\n        }\n\n        AddressModel getAddress() {\n            return address\n        }\n\n        void setAddress(AddressModel address) {\n            AddressModel oldAddress = this.address\n            this.address = address\n            propertyChangeSupport.firePropertyChange('address', oldAddress, address)\n        }\n\n        void addPropertyChangeListener(String propertyName, PropertyChangeListener listener) {\n            propertyChangeSupport.addPropertyChangeListener(propertyName, listener)\n        }\n\n        void removePropertyChangeListener(String propertyName, PropertyChangeListener listener) {\n            propertyChangeSupport.removePropertyChangeListener(propertyName, listener)\n        }\n    }\n\n    private static final class AddressModel {\n        private final PropertyChangeSupport propertyChangeSupport = new PropertyChangeSupport(this)\n        private String city\n\n        private AddressModel(String city) {\n            this.city = city\n        }\n\n        String getCity() {\n            return city\n        }\n\n        void setCity(String city) {\n            String oldCity = this.city\n            this.city = city\n            propertyChangeSupport.firePropertyChange('city', oldCity, city)\n        }\n\n        void addPropertyChangeListener(String propertyName, PropertyChangeListener listener) {\n            propertyChangeSupport.addPropertyChangeListener(propertyName, listener)\n        }\n\n        void removePropertyChangeListener(String propertyName, PropertyChangeListener listener) {\n            propertyChangeSupport.removePropertyChangeListener(propertyName, listener)\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778372400818}, {"role": "toolResult", "toolCallId": "call_C2xpetnAF61qLfpaTwMajO5f|fc_0ac9a0cf1660ca530169ffcf309e6081a2b7bb929f3d389d3d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_groovy.groovy_swing\n\nimport groovy.beans.PropertyAccessor\nimport org.apache.groovy.swing.binding.PropertyBinding\nimport org.junit.jupiter.api.Test\n\nimport static org.assertj.core.api.Assertions.assertThat\n\npublic class PropertyBindingTest {\n    @Test\n    void discoversServiceConfiguredPropertyAccessorAndUsesItForReadAndWrite() {\n        PropertyBindingTestBean bean = new PropertyBindingTestBean(storedValue: 'initial')\n        PropertyBinding binding = new PropertyBinding(bean, 'customProperty')\n\n        assertThat(binding.sourceValue).isEqualTo('initial')\n\n        binding.updateTargetValue('updated')\n\n        assertThat(bean.storedValue).isEqualTo('accessor:customProperty:updated')\n    }\n}\n\npublic class PropertyBindingTestBean {\n    String storedValue\n}\n\npublic class PropertyBindingTestAccessor implements PropertyAccessor {\n    @Override\n    Object read(Object bean, String propertyName) {\n        return ((PropertyBindingTestBean) bean).storedValue\n    }\n\n    @Override\n    void write(Object bean, String propertyName, Object newValue) {\n        ((PropertyBindingTestBean) bean).storedValue = \"acce