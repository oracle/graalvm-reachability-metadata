  package org_apache_groovy.groovy_swing
  
  import groovy.beans.PropertyAccessor
  import org.apache.groovy.swing.binding.PropertyBinding
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class PropertyBindingTest {
      @Test
      void discoversServiceConfiguredPropertyAccessorAndUsesItForReadAndWrite() {
          PropertyBindingTestBean bean = new PropertyBindingTestBean(storedValue: 'initial')
          PropertyBinding binding = new PropertyBinding(bean, 'customProperty')
  
          assertThat(binding.sourceValue).isEqualTo('initial')
  
          binding.updateTargetValue('updated')
  
          assertThat(bean.storedValue).isEqualTo('accessor:customProperty:updated')
      }
  }
  
  public class PropertyBindingTestBean {
      String storedValue
  }
  
  public class PropertyBindingTestAccessor implements PropertyAccessor {
      @Override
      Object read(Object bean, String propertyName) {
          return ((PropertyBindingTestBean) bean).storedValue
      }
  
      @Override
      void write(Object bean, String propertyName, Object newValue) {
          ((PropertyBindingTestBean) bean).storedValue = "accessor:${propertyName}:${newValue}"
      }
  }
