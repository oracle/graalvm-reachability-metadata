  package org_apache_groovy.groovy_swing
  
  import groovy.swing.LookAndFeelHelper
  import org.junit.jupiter.api.Test
  
  import static org.assertj.core.api.Assertions.assertThat
  
  public class LookAndFeelHelperTest {
      @Test
      void probesOptionalLookAndFeelImplementations() {
          List<String> lookAndFeelClassNames = [
              LookAndFeelHelper.getNimbusLAFName(),
              LookAndFeelHelper.getAquaLAFName(),
              LookAndFeelHelper.getSubstanceLAFName(),
          ]
  
          List<String> discoveredClassNames = lookAndFeelClassNames.findAll { String className -> className != null }
  
          assertThat(lookAndFeelClassNames).hasSize(3)
          assertThat(discoveredClassNames.every { String className -> !className.isBlank() }).isTrue()
      }
  }
