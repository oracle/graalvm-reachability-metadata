t {\\n    @Test\\n    void loadsMetalThemeFromClassNameAttribute() {\\n        LookAndFeel originalLookAndFeel = UIManager.getLookAndFeel()\\n        MetalTheme originalMetalTheme = MetalLookAndFeel.getCurrentTheme()\\n\\n        try {\\n            LookAndFeel lookAndFeel = LookAndFeelHelper.instance.lookAndFeel(\\n                'metal',\\n                [theme: DefaultMetalTheme.name],\\n                null\\n            )\\n\\n            assertThat(lookAndFeel).isInstanceOf(MetalLookAndFeel)\\n            assertThat(MetalLookAndFeel.getCurrentTheme()).isExactlyInstanceOf(DefaultMetalTheme)\\n        } finally {\\n            MetalLookAndFeel.setCurrentTheme(originalMetalTheme)\\n            if (originalLookAndFeel != null) {\\n                UIManager.setLookAndFeel(originalLookAndFeel)\\n            }\\n        }\\n    }\\n}\\n\"}\n1237:[tool-call] end id=call_Re0jLIkBi9UlniffnIJ2Seuo|fc_0ac9a0cf1660ca530169ffcf3886c081a29adf86fdff12872a name=write args={\"path\": \"tests/src/org.apache.groovy/groovy-swing/4.0.24/src/test/groovy/org_apache_groovy/groovy_swing/LookAndFeelHelperInnerClosure1Test.groovy\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_groovy.groovy_swing\\n\\nimport groovy.swing.LookAndFeelHelper\\nimport org.junit.jupiter.api.Test\\n\\nimport javax.swing.LookAndFeel\\nimport javax.swing.UIManager\\nimport javax.swing.plaf.metal.DefaultMetalTheme\\nimport javax.swing.plaf.metal.MetalLookAndFeel\\nimport javax.swing.plaf.metal.MetalTheme\\n\\nimport static org.assertj.core.api.Assertions.assertThat\\n\\npublic class LookAndFeelHelperInnerClosure1Test {\\n    @Test\\n    void loadsMetalThemeFromClassNameAttribute() {\\n        LookAndFeel originalLookAndFeel = UIManager.getLookAndFeel()\\n        MetalTheme originalMetalTheme = MetalLookAndFeel.