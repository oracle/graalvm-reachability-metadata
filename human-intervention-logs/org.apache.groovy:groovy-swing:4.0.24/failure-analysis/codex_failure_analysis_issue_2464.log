alTheme.name],\\n                null\\n            )\\n\\n            assertThat(lookAndFeel).isInstanceOf(MetalLookAndFeel)\\n            assertThat(MetalLookAndFeel.getCurrentTheme()).isExactlyInstanceOf(DefaultMetalTheme)\\n        } finally {\\n            MetalLookAndFeel.setCurrentTheme(originalMetalTheme)\\n            if (originalLookAndFeel != null) {\\n                UIManager.setLookAndFeel(originalLookAndFeel)\\n            }\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1636, \"output\": 934, \"cacheRead\": 17408, \"cacheWrite\": 0, \"totalTokens\": 19978, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778372400822, \"responseId\": \"resp_0ac9a0cf1660ca530169ffcf31467c81a29af911e0054f87c8\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_Re0jLIkBi9UlniffnIJ2Seuo|fc_0ac9a0cf1660ca530169ffcf3886c081a29adf86fdff12872a\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 1420 bytes to tests/src/org.apache.groovy/groovy-swing/4.0.24/src/test/groovy/org_apache_groovy/groovy_swing/LookAndFeelHelperInnerClosure1Test.groovy\"}], \"isError\": false, \"timestamp\": 1778372410733}]}\n1261:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_MZOB5EJj9xSGZkTcj0J05uYk|fc_0ac9a0cf1660ca530169ffcf3da3ec81a290c3c4a82c2d958e\", \"toolName\": \"bash\", \"content\": [{\"type\": \"text\", \"text\": \"(no output)\"}], \"isError\": false, \"timestamp\": 1778372414093}}\n1262:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_MZOB5EJj9xSGZkTcj0J05uYk|fc_0ac9a0cf1660ca530169ffcf3da3ec81a290c3c4a82c2d958e\", \"toolName\": \"bash\", \"content\": [{\"type\": \"text\", \"text\": \"(no output)\"}], \"isError\": false, \"timestamp\": 1778372414093}}\n12