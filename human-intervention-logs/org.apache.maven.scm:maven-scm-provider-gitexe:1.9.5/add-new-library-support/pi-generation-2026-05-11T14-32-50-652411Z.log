e static final String BRANCH_INDICATOR = \"refs/heads/\";\n    \n    private String branch;\n    \n    /**\n     * Default constructor.\n     */\n    public GitCurrentBranchConsumer( ScmLogger logger )\n    {\n        super( logger );\n    }\n\n    public String getBranchName()\n    {\n        return branch;\n    }\n\n    // ----------------------------------------------------------------------\n    // StreamConsumer Implementation\n    // ----------------------------------------------------------------------\n\n    /** {@inheritDoc} */\n    public void consumeLine( String line )\n    {\n        line = line.trim();\n        \n        if ( line.startsWith( BRANCH_INDICATOR ) )\n        {\n            branch = line.substring( BRANCH_INDICATOR.length() );\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1778509582991}]}
