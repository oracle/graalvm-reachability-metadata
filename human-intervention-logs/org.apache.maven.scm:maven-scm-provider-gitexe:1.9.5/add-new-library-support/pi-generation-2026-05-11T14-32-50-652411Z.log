  import java.io.File;
  
  import org.apache.maven.scm.ScmException;
  import org.apache.maven.scm.ScmFileSet;
  import org.apache.maven.scm.command.info.InfoScmResult;
  import org.apache.maven.scm.provider.git.AbstractGitScmProvider;
