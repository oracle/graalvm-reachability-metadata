      /**
       * Date formatter for git timestamp
       * we use iso format cli git log --date=iso sample : 2008-08-06 01:37:18 +0200
       */
      private static final String GIT_TIMESTAMP_PATTERN = "yyyy-MM-dd HH:mm:ss Z";
  
