ters )\n        throws ScmException\n    {\n        if ( parameters == null )\n        {\n            return NO_REVISION_LENGTH;\n        }\n        else\n        {\n            return parameters.getInt( CommandParameter.SCM_SHORT_REVISION_LENGTH, NO_REVISION_LENGTH );\n\n[6 more lines in file. Use offset=101 to continue.]"}], "isError": false, "timestamp": 1778509597328}}
