          }
  
          @Override
          public boolean isErrorEnabled() {
              return false;
          }
  
          @Override
          public void error(String content) {
          }
  
          @Override
          public void error(String content, Throwable error) {
          }
  
          @Override
          public void error(Throwable error) {
          }
      }
