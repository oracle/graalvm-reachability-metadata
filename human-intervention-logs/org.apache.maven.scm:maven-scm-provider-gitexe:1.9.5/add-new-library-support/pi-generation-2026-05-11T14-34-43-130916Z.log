          }
  
          @Override
          public void info(Throwable error) {
          }
  
          @Override
          public boolean isWarnEnabled() {
              return false;
          }
  
          @Override
          public void warn(String content) {
          }
  
          @Override
          public void warn(String content, Throwable error) {
          }
  
          @Override
