 Field CoordinatedShutdownRunByActorSystemTerminate:Z\n       953: aload_0\n       954: invokevirtual #468                // Method CoordinatedShutdownRunByActorSystemTerminate:()Z\n       957: ifeq          978\n       960: aload_0\n       961: invokevirtual #470                // Method CoordinatedShutdownTerminateActorSystem:()Z\n       964: ifne          978\n       967: new           #472                // class akka/ConfigurationException\n       970: dup\n       971: ldc_w         #474                // String akka.coordinated-shutdown.run-by-actor-system-terminate=on and akka.coordinated-shutdown.terminate-actor-system=off is not a supported configuration combination.\n       974: invokespecial #477                // Method akka/ConfigurationException.\"<init>\":(Ljava/lang/String;)V\n       977: athrow\n       978: aload_0\n       979: aload_0\n       980: invokevirtual #129                // Method config:()Lcom/typesafe/config/Config;\n       983: ldc_w         #479                // String akka.actor.deployment.default.virtual-nodes-factor\n       986: invokeinterface #370,  2          // InterfaceMethod com/typesafe/config/Config.getInt:(Ljava/lang/String;)I\n       991: putfield      #481                // Field DefaultVirtualNodesFactor:I\n       994: aload_0\n       995: invokevirtual #483                // Method ConfigVersion:()Ljava/lang/String;\n       998: getstatic     #488                // Field akka/actor/ActorSystem$.MODULE$:Lakka/actor/ActorSystem$;\n      1001: invokevirtual #491                // Method akka/actor/ActorSystem$.Version:()Ljava/lang/String;\n      1004: astore        11\n      1006: dup\n      1007: ifnonnull     1019\n      1010: pop\n      1011: aload         11\n      1013: ifnull        1082\n      1016: goto          1027\n      1019: aload         11\n      1021: invokevirtual #359                // Method java/lang/Object.equals:(Ljava/lang/Object;)Z\n      1024: ifne          1082\n      1027: new           #472   