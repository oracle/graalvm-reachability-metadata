      @Test
      void exposesHtmlStringTransferFlavor() {
          text_html handler = new text_html();
  
          DataFlavor[] flavors = handler.getTransferDataFlavors();
  
          assertThat(flavors).hasSize(1);
          assertThat(flavors[0].getRepresentationClass()).isEqualTo(String.class);
          assertThat(flavors[0].getPrimaryType()).isEqualTo("text");
          assertThat(flavors[0].getSubType()).isEqualTo("html");
          assertThat(flavors[0].getHumanPresentableName()).isEqualTo("HTML String");
      }
  
      @Test
      void readsHtmlContentFromDataSource() throws IOException {
          text_html handler = new text_html();
          DataFlavor flavor = handler.getTransferDataFlavors()[0];
          DataSource dataSource = new HtmlDataSource(HTML_DOCUMENT, MIME_TYPE + "; charset=UTF-8");
  
          Object transferData = handler.getTransferData(flavor, dataSource);
  
          assertThat(transferData).isEqualTo(HTML_DOCUMENT);
      }
  
      @Test
      void writesHtmlStringToOutputStream() throws IOException {
          text_html handler = new text_html();
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
  
          handler.writeTo(HTML_DOCUMENT, MIME_TYPE + "; charset=UTF-8", outputStream);
  
          assertThat(outputStream.toString(StandardCharsets.UTF_8.name())).isEqualTo(HTML_DOCUMENT);
      }
  
      @Test
      void initializesIsolatedHtmlHandlerThroughActivationCommandMap() {
          IsolatedTextHtmlClassLoader classLoader = new IsolatedTextHtmlClassLoader(parentClassLoader());
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
          currentThread.setContextClassLoader(classLoader);
          try {
              DataHandler dataHandler = newDataHandler(new HtmlDataSource(HTML_DOCUMENT, MIME_TYPE + "; charset=UTF-8"));
  
              assertHtmlStringFlavor(dataHandler.getTransferDataFlavors());
              assertThat(classLoader.isHandlerClassDefined()).isTrue();
          } catch (Error error) {
              rethrowUnlessUnsupportedDynamicClassLoading(error);
          } finally {
              currentThread.setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private static DataHandler newDataHandler(DataSource dataSource) {
          MailcapCommandMap commandMap = new MailcapCommandMap();
          commandMap.addMailcap(MIME_TYPE + ";; x-java-content-handler=" + TEXT_HTML_HANDLER_CLASS_NAME);
          DataHandler dataHandler = new DataHandler(dataSource);
          dataHandler.setCommandMap(commandMap);
          return dataHandler;
      }
  
      private static void assertHtmlStringFlavor(DataFlavor[] flavors) {
          assertThat(flavors).hasSize(1);
          assertThat(flavors[0].getRepresentationClass()).isEqualTo(String.class);
          assertThat(flavors[0].getPrimaryType()).isEqualTo("text");
          assertThat(flavors[0].getSubType()).isEqualTo("html");
          assertThat(flavors[0].getHumanPresentableName()).isEqualTo("HTML String");
      }
  
      private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static ClassLoader parentClassLoader() {
          ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();
          if (contextClassLoader != null) {
              return contextClassLoader;
          }
          return TextHtmlTest.class.getClassLoader();
      }
  
      private static final class IsolatedTextHtmlClassLoader extends ClassLoader {
          private Class<?> handlerClass;
  
          private IsolatedTextHtmlClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!TEXT_HTML_HANDLER_CLASS_NAME.equals(name)) {
                  return super.loadClass(name, resolve);
              }
              Class<?> loadedClass = handlerClass;
              if (loadedClass == null) {
                  byte[] bytes = Base64.getMimeDecoder().decode(TEXT_HTML_HANDLER_BYTES);
                  loadedClass = defineClass(name, bytes, 0, bytes.length, DataHandler.class.getProtectionDomain());
                  handlerClass = loadedClass;
              }
              if (resolve) {
                  resolveClass(loadedClass);
              }
              return loadedClass;
          }
  
          private boolean isHandlerClassDefined() {
              return handlerClass != null;
          }
      }
  
      private static final class HtmlDataSource implements DataSource {
          private final byte[] content;
          private final String contentType;
  
          private HtmlDataSource(String content, String contentType) {
              this.content = content.getBytes(StandardCharsets.UTF_8);
              this.contentType = contentType;
          }
  
          @Override
          public InputStream getInputStream() {
              return new ByteArrayInputStream(content);
          }
  
          @Override
          public OutputStream getOutputStream() throws IOException {
              throw new IOException("Output is not supported");
          }
  
          @Override
          public String getContentType() {
              return contentType;
          }
  
          @Override
          public String getName() {
              return "html-message";
          }
      }
  }
