  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import com.sun.mail.handlers.message_rfc822;
  import java.awt.datatransfer.DataFlavor;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  import java.security.CodeSource;
  import java.util.Properties;
  import javax.activation.DataHandler;
  import javax.activation.DataSource;
  import javax.activation.MailcapCommandMap;
  import javax.mail.Message;
  import javax.mail.Session;
  import javax.mail.internet.MimeMessage;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class MessageRfc822Test {
      private static final String MIME_TYPE = "message/rfc822";
      private static final String MESSAGE_TEXT = ""
              + "From: sender@example.com\r\n"
              + "To: recipient@example.com\r\n"
              + "Subject: handler message\r\n"
              + "\r\n"
              + "Message body from the data source.\r\n";
      private static final String MESSAGE_RFC822_HANDLER_CLASS_NAME = "com.sun.mail.handlers.message_rfc822";
  
      @Test
      void exposesMessageTransferFlavorDirectlyFromHandler() {
          message_rfc822 handler = new message_rfc822();
  
          DataFlavor[] flavors = handler.getTransferDataFlavors();
  
          assertMessageFlavor(flavors);
      }
  
      @Test
      void exposesMessageTransferFlavorThroughActivationCommandMap() {
          DataFlavor[] flavors = getTransferDataFlavors(new MessageDataSource(MESSAGE_TEXT), new MailcapCommandMap());
  
          assertMessageFlavor(flavors);
      }
  
      @Test
      void readsMessageContentThroughActivationCommandMap() throws Exception {
          DataHandler dataHandler = newDataHandler(new MessageDataSource(MESSAGE_TEXT), new MailcapCommandMap());
  
          Object content = dataHandler.getContent();
  
          assertThat(content).isInstanceOf(MimeMessage.class);
          MimeMessage message = (MimeMessage) content;
          assertThat(message.getSubject()).isEqualTo("handler message");
      }
  
      @Test
      void initializesMessageHandlerLoadedFromArtifactThroughActivationCommandMap() throws Exception {
          CodeSource codeSource = message_rfc822.class.getProtectionDomain().getCodeSource();
          MessageHandlerClassLoader classLoader = new MessageHandlerClassLoader(
                  new URL[] {codeSource.getLocation()}, parentClassLoader());
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
          currentThread.setContextClassLoader(classLoader);
          try {
              DataFlavor[] flavors = getTransferDataFlavors(new MessageDataSource(MESSAGE_TEXT), new MailcapCommandMap());
  
              assertMessageFlavor(flavors);
              assertThat(classLoader.isHandlerClassLoaded()).isTrue();
          } catch (Error error) {
              rethrowUnlessUnsupportedDynamicClassLoading(error);
          } finally {
              currentThread.setContextClassLoader(originalContextClassLoader);
              classLoader.close();
          }
      }
  
      @Test
      void readsTransferDataAsMimeMessage() throws Exception {
          message_rfc822 handler = new message_rfc822();
          DataFlavor flavor = handler.getTransferDataFlavors()[0];
  
          Object transferData = handler.getTransferData(flavor, new MessageDataSource(MESSAGE_TEXT));
  
          assertThat(transferData).isInstanceOf(MimeMessage.class);
          MimeMessage message = (MimeMessage) transferData;
          assertThat(message.getSubject()).isEqualTo("handler message");
      }
  
      @Test
      void returnsNullForUnsupportedTransferFlavor() throws IOException {
          message_rfc822 handler = new message_rfc822();
          DataFlavor unsupportedFlavor = new DataFlavor(String.class, "Plain String");
  
          Object transferData = handler.getTransferData(unsupportedFlavor, new MessageDataSource(MESSAGE_TEXT));
  
          assertThat(transferData).isNull();
      }
  
      @Test
      void writesMimeMessageToOutputStream() throws Exception {
          message_rfc822 handler = new message_rfc822();
          MimeMessage message = new MimeMessage(Session.getInstance(new Properties()));
          message.setSubject("written by handler");
          message.setText("Written message body");
          message.saveChanges();
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
  
          handler.writeTo(message, MIME_TYPE, outputStream);
  
          String serializedMessage = outputStream.toString(StandardCharsets.UTF_8.name());
          assertThat(serializedMessage).contains("Subject: written by handler");
          assertThat(serializedMessage).contains("Written message body");
      }
  
      @Test
      void rejectsUnsupportedObjectWhenWriting() {
          message_rfc822 handler = new message_rfc822();
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
  
          assertThatThrownBy(() -> handler.writeTo("not a message", MIME_TYPE, outputStream))
                  .isInstanceOf(IOException.class)
                  .hasMessage("unsupported object");
      }
  
      private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {
          return newDataHandler(dataSource, commandMap).getTransferDataFlavors();
      }
  
      private static DataHandler newDataHandler(DataSource dataSource, MailcapCommandMap commandMap) {
          commandMap.addMailcap(MIME_TYPE + ";; x-java-content-handler=" + MESSAGE_RFC822_HANDLER_CLASS_NAME);
          DataHandler dataHandler = new DataHandler(dataSource);
          dataHandler.setCommandMap(commandMap);
          return dataHandler;
      }
  
      private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static ClassLoader parentClassLoader() {
          ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();
          if (contextClassLoader != null) {
              return contextClassLoader;
          }
          return MessageRfc822Test.class.getClassLoader();
      }
  
      private static void assertMessageFlavor(DataFlavor[] flavors) {
          assertThat(flavors).hasSize(1);
          assertThat(flavors[0].getRepresentationClass()).isEqualTo(Message.class);
          assertThat(flavors[0].getPrimaryType()).isEqualTo("message");
          assertThat(flavors[0].getSubType()).isEqualTo("rfc822");
          assertThat(flavors[0].getHumanPresentableName()).isEqualTo("Message");
      }
  
      private static final class MessageHandlerClassLoader extends URLClassLoader {
          private boolean handlerClassLoaded;
  
          private MessageHandlerClassLoader(URL[] urls, ClassLoader parent) {
              super(urls, parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!MESSAGE_RFC822_HANDLER_CLASS_NAME.equals(name)) {
                  return super.loadClass(name, resolve);
              }
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      loadedClass = findClass(name);
                      handlerClassLoaded = true;
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private boolean isHandlerClassLoaded() {
              return handlerClassLoaded;
          }
      }
  
      private static final class MessageDataSource implements DataSource {
          private final byte[] content;
  
          private MessageDataSource(String content) {
              this.content = content.getBytes(StandardCharsets.UTF_8);
          }
  
          @Override
          public InputStream getInputStream() {
              return new ByteArrayInputStream(content);
          }
  
          @Override
          public OutputStream getOutputStream() throws IOException {
              throw new IOException("Output is not supported");
          }
  
          @Override
          public String getContentType() {
              return MIME_TYPE;
          }
  
          @Override
          public String getName() {
              return "rfc822-message";
          }
      }
  }
