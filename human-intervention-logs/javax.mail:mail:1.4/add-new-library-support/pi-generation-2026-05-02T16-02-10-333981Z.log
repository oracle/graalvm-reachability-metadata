  	public static final Type STORE     = new Type("STORE");
  	public static final Type TRANSPORT = new Type("TRANSPORT");
  
  	private String type;
  
  	private Type(String type) {
  	    this.type = type;
  	}
  
  	public String toString() {
  	    return type;
  	}
      }
  
      private Type type;
      private String protocol, className, vendor, version;
  
      /**
