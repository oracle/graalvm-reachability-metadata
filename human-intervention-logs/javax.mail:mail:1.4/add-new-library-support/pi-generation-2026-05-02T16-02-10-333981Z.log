sport = getTransportWithContextClassLoader(contextClassLoader, \"smtp-class-for-name\");\n\n        assertTransportWasCreatedForProtocol(transport, \"smtp-class-for-name\");\n    }\n\n    private static Transport getTransportWithContextClassLoader(ClassLoader contextClassLoader, String protocol)\n            throws Exception {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(contextClassLoader);\n            Session session = Session.getInstance(new Properties());\n            return session.getTransport(provider(protocol));\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static Provider provider(String protocol) {\n        return new Provider(Provider.Type.TRANSPORT, protocol, PROVIDER_CLASS_NAME, \"test\", null);\n    }\n\n    private static void assertTransportWasCreatedForProtocol(Transport transport, String protocol) throws Exception {\n        try {\n            assertThat(transport).isInstanceOf(SMTPTransport.class);\n            URLName urlName = transport.getURLName();\n            assertThat(urlName.getProtocol()).isEqualTo(protocol);\n            assertThat(urlName.getHost()).isNull();\n            assertThat(urlName.getPort()).isEqualTo(-1);\n        } finally {\n            transport.close();\n        }\n    }\n\n    private static ClassLoader currentClassLoader() {\n        return SessionTest.class.getClassLoader();\n    }\n\n    private static class RejectingProviderClassLoader extends ClassLoader {\n        RejectingProviderClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (PROVIDER_CLASS_NAME.equals(name)) {\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    private static class FailingProviderClassLoader extends ClassLoader {\n        FailingProviderClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (PROVIDER_CLASS_NAME.equals(name)) {\n                throw new IllegalStateException(\"Provider lookup failure for \" + name);\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    public static class SendOnlyTransport extends Transport {\n        public SendOnlyTransport(Session session, URLName urlName) {\n            super(session, urlName);\n        }\n\n        @Override\n        public void sendMessage(Message message, Address[] addresses) throws MessagingException {\n            assertThat(message).isNotNull();\n            assertThat(addresses).isNotNull();\n        }\n    }\n}\n"}
