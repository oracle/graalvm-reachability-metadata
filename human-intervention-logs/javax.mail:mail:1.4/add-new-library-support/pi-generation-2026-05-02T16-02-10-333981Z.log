  package javax_mail.mail;
  
  import com.sun.mail.smtp.SMTPTransport;
  import java.util.Properties;
  import javax.mail.Provider;
  import javax.mail.Session;
  import javax.mail.Transport;
  import javax.mail.URLName;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SessionTest {
      private static final String PROVIDER_CLASS_NAME = SMTPTransport.class.getName();
  
      @Test
      void getTransportLoadsProviderWithContextClassLoader() throws Exception {
          ClassLoader contextClassLoader = new ClassLoader(currentClassLoader()) {
          };
  
          Transport transport = getTransportWithContextClassLoader(contextClassLoader, "smtp-context");
  
          assertTransportWasCreatedForProtocol(transport, "smtp-context");
      }
  
      @Test
      void getTransportFallsBackToSessionClassLoaderWhenContextClassLoaderCannotFindProvider() throws Exception {
          ClassLoader contextClassLoader = new RejectingProviderClassLoader(currentClassLoader());
  
          Transport transport = getTransportWithContextClassLoader(contextClassLoader, "smtp-session-loader");
  
          assertTransportWasCreatedForProtocol(transport, "smtp-session-loader");
      }
  
      @Test
      void getTransportFallsBackToClassForNameWhenContextClassLoaderFailsUnexpectedly() throws Exception {
          ClassLoader contextClassLoader = new FailingProviderClassLoader(currentClassLoader());
  
          Transport transport = getTransportWithContextClassLoader(contextClassLoader, "smtp-class-for-name");
  
          assertTransportWasCreatedForProtocol(transport, "smtp-class-for-name");
      }
  
      private static Transport getTransportWithContextClassLoader(ClassLoader contextClassLoader, String protocol)
              throws Exception {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(contextClassLoader);
              Session session = Session.getInstance(new Properties());
              return session.getTransport(provider(protocol));
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      private static Provider provider(String protocol) {
          return new Provider(Provider.Type.TRANSPORT, protocol, PROVIDER_CLASS_NAME, "test", null);
      }
  
      private static void assertTransportWasCreatedForProtocol(Transport transport, String protocol) throws Exception {
          try {
              assertThat(transport).isInstanceOf(SMTPTransport.class);
              URLName urlName = transport.getURLName();
              assertThat(urlName.getProtocol()).isEqualTo(protocol);
