\n            AB6/uwATWbsAFFm3ABUqtgAJtgAYtgAXEh+2ABe2AB23AB6/AAAAAgAyAAAADgADAAAAZwAHAGgAPABsADMAAAAq\n            AAQAAABdADQANQAAAAAAXQBQAFEAAQAAAF0AUgBTAAIAAABdAFQAVQADAEAAAAAEAAEAEwAIAFYAVwACADEAAABO\n            AAIAAgAAABIquAABsEy7AANZtwAEK7YABb8AAQAAAAQABQACAAIAMgAAAAYAAQAAACkAMwAAABYAAgAGAAwAWABZ\n            AAEAAAASAFoAUwAAAC4AAAAAAAgAWwAwAAEAMQAAADwABQAAAAAAJLsAIFmyACHHAA8SIrgAI1mzACGnAAayACES\n            JBIltwAmswAHsQAAAAEAMgAAAAYAAQAAACgAAQBcAAAAAgBd\n            \"\"\";\n\n    @Test\n    void exposesGifImageTransferFlavorThroughActivationCommandMap() {\n        try {\n            DataFlavor[] flavors = getTransferDataFlavors(new GifDataSource(), new MailcapCommandMap());\n\n            assertGifImageFlavor(flavors);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        }\n    }\n\n    @Test\n    void initializesIsolatedGifHandlerThroughActivationCommandMap() {\n        IsolatedImageGifClassLoader classLoader = new IsolatedImageGifClassLoader(parentClassLoader());\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            DataFlavor[] flavors = getTransferDataFlavors(new GifDataSource(), new MailcapCommandMap());\n\n            assertGifImageFlavor(flavors);\n            assertThat(classLoader.isHandlerClassDefined()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + IMAGE_GIF_HANDLER_CLASS_NAME);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler.getTransferDataFlavors();\n    }\n\n    private static void assertGifImageFlavor(DataFlavor[] flavors) {\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(Image.class);\n        assertThat(flavors[0].getPrimaryType()).isEqualTo(\"image\");\n        assertThat(flavors[0].getSubType()).isEqualTo(\"gif\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"GIF Image\");\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return ImageGifTest.class.getClassLoader();\n    }\n\n    private static final class GifDataSource implements DataSource {\n        @Override\n        public InputStream getInputStream() {\n            return new ByteArrayInputStream(new byte[0]);\n        }\n\n        @Override\n        public OutputStream getOutputStream() throws IOException {\n            throw new IOException(\"Output is not supported\");\n        }\n\n        @Override\n        public String getContentType() {\n            return MIME_TYPE;\n        }\n\n        @Override\n        public String getName() {\n            return \"gif-data\";\n        }\n    }\n\n[31 more lines in file. Use offset=161 to continue.]"}], "isError": false, "timestamp": 1777667388199}}
