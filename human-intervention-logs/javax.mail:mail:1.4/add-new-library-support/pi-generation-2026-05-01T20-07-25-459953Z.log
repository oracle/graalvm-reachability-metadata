[tool-call] delta {"path":"tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/ImageGifTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.mail.handlers.image_gif;\nimport java.awt.Image;\nimport java.awt.datatransfer.DataFlavor;\nimport javax.activation.ActivationDataFlavor;\nimport org.junit.jupiter.api.Test;\n\npublic class ImageGifTest {\n    @Test\n    void exposesGifImageTransferFlavor() {\n        image_gif handler = new image_gif();\n\n        DataFlavor[] flavors = handler.getTransferDataFlavors();\n\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0]).isInstanceOf(ActivationDataFlavor.class);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(Image.class);\n        assertThat(((ActivationDataFlavor) flavors[0]).getMimeType()).isEqualTo(\"image/gif\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"GIF Image\");\n    }\n}\n"}
