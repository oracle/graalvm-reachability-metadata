  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.awt.Image;
  import java.awt.datatransfer.DataFlavor;
  import java.io.ByteArrayInputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import javax.activation.DataHandler;
  import javax.activation.DataSource;
  import javax.activation.MailcapCommandMap;
  import org.junit.jupiter.api.Test;
  
  public class ImageGifTest {
      private static final String MIME_TYPE = "image/gif";
      private static final String IMAGE_GIF_HANDLER_CLASS_NAME = "com.sun.mail.handlers.image_gif";
  
      @Test
      void exposesGifImageTransferFlavorThroughActivationCommandMap() {
          MailcapCommandMap commandMap = new MailcapCommandMap();
          commandMap.addMailcap(MIME_TYPE + ";; x-java-content-handler=" + IMAGE_GIF_HANDLER_CLASS_NAME);
          DataHandler dataHandler = new DataHandler(new GifDataSource());
          dataHandler.setCommandMap(commandMap);
  
          DataFlavor[] flavors = dataHandler.getTransferDataFlavors();
          assertThat(flavors).hasSize(1);
          assertThat(flavors[0].getRepresentationClass()).isEqualTo(Image.class);
          assertThat(flavors[0].getPrimaryType()).isEqualTo("image");
          assertThat(flavors[0].getSubType()).isEqualTo("gif");
          assertThat(flavors[0].getHumanPresentableName()).isEqualTo("GIF Image");
      }
  
      private static final class GifDataSource implements DataSource {
          @Override
          public InputStream getInputStream() {
              return new ByteArrayInputStream(new byte[0]);
          }
  
          @Override
          public OutputStream getOutputStream() throws IOException {
              throw new IOException("Output is not supported");
          }
  
          @Override
          public String getContentType() {
              return MIME_TYPE;
          }
  
          @Override
          public String getName() {
              return "gif-data";
          }
      }
  }
