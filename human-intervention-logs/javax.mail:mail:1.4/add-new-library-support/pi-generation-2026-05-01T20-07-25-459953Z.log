.mail.Transport;\nimport org.junit.jupiter.api.Test;\n\npublic class SessionTest {\n    private static final String SMTP_PROTOCOL = \"smtp\";\n    private static final String SMTP_TRANSPORT_CLASS_NAME = SMTPTransport.class.getName();\n\n    @Test\n    void loadsTransportProviderWithContextClassLoader() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        RecordingClassLoader contextClassLoader = new RecordingClassLoader(parentClassLoader());\n\n        Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);\n\n        assertThat(transport).isInstanceOf(SMTPTransport.class);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);\n        assertThat(contextClassLoader.getLoadedClassNames()).contains(SMTP_TRANSPORT_CLASS_NAME);\n    }\n\n    @Test\n    void fallsBackToSessionClassLoaderWhenContextLoaderCannotFindProvider() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n                parentClassLoader(), SMTP_TRANSPORT_CLASS_NAME, new ClassNotFoundException(SMTP_TRANSPORT_CLASS_NAME));\n\n        Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);\n\n        assertThat(transport).isInstanceOf(SMTPTransport.class);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);\n        assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SMTP_TRANSPORT_CLASS_NAME);\n    }\n\n    @Test\n    void fallsBackToClassForNameWhenContextClassLoaderFails() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n                parentClassLoader(), SMTP_TRANSPORT_CLASS_NAME, new IllegalStateException(\"context loader failed\"));\n\n        Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);\n\n        assertThat(transport).isInstanceOf(SMTPTransport.class);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);\n        assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SMTP_TRANSPORT_CLASS_NAME);\n    }\n\n    private static Transport getTransportWithContextClassLoader(Session session, ClassLoader contextClassLoader)\n            throws NoSuchProviderException {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(contextClassLoader);\n        try {\n            return session.getTransport(smtpProvider());\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static Provider smtpProvider() {\n        return new Provider(Provider.Type.TRANSPORT, SMTP_PROTOCOL, SMTP_TRANSPORT_CLASS_NAME, \"JavaMail\", null);\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return SessionTest.class.getClassLoader();\n    }\n\n    private static class RecordingClassLoader extends ClassLoader {\n        private final List<String> loadedClassNames = new ArrayList<>();\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            loadedClassNames.add(name);\n            return super.loadClass(name);\n        }\n\n        private List<String> getLoadedClassNames() {\n            return loadedClassNames;\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        private final String rejectedClassName;\n        private final Exception failure;\n        private final List<String> rejectedClassNames = new ArrayList<>();\n\n        private RejectingClassLoader(ClassLoader parent, String rejectedClassName, Exception failure) {\n            super(parent);\n            this.rejectedClassName = rejectedClassName;\n            this.failure = failure;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedClassName.equals(name)) {\n                rejectedClassNames.add(name);\n                if (failure instanceof ClassNotFoundException) {\n                    throw (ClassNotFoundException) failure;\n                }\n                throw new IllegalStateException(failure.getMessage(), failure);\n            }\n            return super.loadClass(name);\n        }\n\n        private List<String> getRejectedClassNames() {\n            return rejectedClassNames;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777666017665}, {"role": "toolResult", "toolCallId": "call_dCIsIwbEPiba1qZ2fQHDRlvo|fc_01a34223c841f9670169f507e155308192a389ce4a66d8a49d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.mail.pop3.POP3Message;\nimport com.sun.mail.pop3.POP3Store;\nimport java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Properties;\nimport javax.mail.Session;\nimport javax.mail.URLName;\nimport org.junit.jupiter.api.Test;\n\npublic class POP3StoreTest {\n    private static final String PROTOCOL = \"pop3\";\n    private static final String MESSAGE_CLASS_PROPERTY = \"mail.\" + PROTOCOL + \".message.class\";\n\n    @Test\n    void configuresCustomMessageClassConstructor() {\n        Properties properties = new Properties();\n        properties.setProperty(MESSAGE_CLASS_PROPERTY, POP3Message.class.getName());\n        Session session = Session.getInstance(properties);\n\n        POP3Store store = new POP3Store(session, pop3Url());\n\n        assertThat(store.isConnected()).isFalse();\n        assertThat(store.getURLName().getProtocol()).isEqualTo(PROTOCOL);\n    }\n\n    @Test\n    void fallsBackToClassForNameForMessageClassLookup() {\n        Properties properties = new Properties();\n        String invalidArrayMessageClassName = \"[I\";\n        properties.setProperty(MESSAGE_CLASS_PROPERTY, invalidArrayMessageClassName);\n        Session session = Session.getInstance(properties);\n        ByteArrayOutputStream debugOutput = new ByteArrayOutputStream();\n        session.setDebugOut(new PrintStream(debugOutput));\n        session.setDebug(true);\n\n        POP3Store store = new POP3Store(session, pop3Url());\n\n        assertThat(store.isConnected()).isFalse();\n        String debugText = new String(debugOutput.toByteArray(), StandardCharsets.UTF_8);\n        assertThat(debugText).contains(\n                \"DEBUG: POP3 message class: \" + invalidArrayMessageClassName,\n                \"DEBUG: failed to load POP3 message class:\");\n    }\n\n    private static URLName pop3Url() {\n        return new URLName(PROTOCOL, \"localhost\", -1, null, \"user\", \"password\");\n    }\n}\n"}], "isError": false, "timestamp": 1777666017665}, {"role": "toolResult", "toolCallId": "call_0Bi5tNwMth5UEizUpatAlkfP|fc_01a34223c841f9670169f507e1553881928ef981e7d65c5ef8", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport com.sun.mail.util.SocketFetcher;\nimport java.io.IOException;\nimport java.net.InetAddress;\nimport java.net.Socket;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Properties;\nimport javax.net.SocketFactory;\nimport org.junit.jupiter.api.Test;\n\npublic class SocketFetcherTest {\n    private static final String PREFIX = \"mail.socketfetcher\";\n    private static final String SOCKET_FACTORY_CLASS_NAME = SocketFactory.class.getName();\n\n    @Test\n    void loadsConfiguredSocketFactoryWithContextClassLoader() {\n        Properties properties = socketFactoryProperties();\n        RecordingClassLoader contextClassLoader = new RecordingClassLoader(parentClassLoader());\n\n        assertThatThrownBy(() -> getSocketWithContextClassLoader(\n                        InetAddress.getLoopbackAddress().getHostAddress(), 0, properties, contextClassLoader))\n                .isInstanceOf(IOException.class);\n        assertThat(contextClassLoader.getLoadedClassNames()).contains(SOCKET_FACTORY_CLASS_NAME);\n    }\n\n    @Test\n    void loadsConfiguredSocketFactoryWithClassForNameFallback() {\n        Properties properties = socketFactoryProperties();\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n                parentClassLoader(), SOCKET_FACTORY_CLASS_NAME);\n\n        assertThatThrownBy(() -> getSocketWithContextClassLoader(\n                        InetAddress.getLoopbackAddress().getHostAddress(), 0, properties, contextClassLoader))\n                .isInstanceOf(IOException.class);\n        assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SOCKET_FACTORY_CLASS_NAME);\n    }\n\n    private static Properties socketFactoryProperties() {\n        Properties properties = new Properties();\n        properties.setProperty(PREFIX + \".socketFactory.class\", SOCKET_FACTORY_CLASS_NAME);\n        properties.setProperty(PREFIX + \".socketFactory.fallback\", \"false\");\n        return properties;\n    }\n\n    private static Socket getSocketWithContextClassLoader(\n            String host, int port, Properties properties, ClassLoader contextClassLoader) throws IOException {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(contextClassLoader);\n        try {\n            return SocketFetcher.getSocket(host, port, properties, PREFIX, false);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return SocketFetcherTest.class.getClassLoader();\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private final List<String> loadedClassNames = new ArrayList<>();\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            loadedClassNames.add(name);\n            return super.loadClass(name);\n        }\n\n        private List<String> getLoadedClassNames() {\n            return loadedClassNames;\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        private final String rejectedClassName;\n        private final List<String> rejectedClassNames = new ArrayList<>();\n\n        private RejectingClassLoader(ClassLoader parent, String rejectedClassName) {\n            super(parent);\n            this.rejectedClassName = rejectedClassName;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedClassName.equals(name)) {\n                rejectedClassNames.add(name);\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private List<String> getRejectedClassNames() {\n            return rejectedClassNames;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777666017665}]}
