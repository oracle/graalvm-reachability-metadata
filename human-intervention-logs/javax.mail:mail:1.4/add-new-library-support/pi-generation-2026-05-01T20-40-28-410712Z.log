p commandMap) {\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + MULTIPART_MIXED_HANDLER_CLASS_NAME);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler.getTransferDataFlavors();\n    }\n", "newText": "    private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {\n        return newDataHandler(dataSource, commandMap).getTransferDataFlavors();\n    }\n\n    private static DataHandler newDataHandler(DataSource dataSource, MailcapCommandMap commandMap) {\n        registerMultipartMixedHandler(commandMap);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler;\n    }\n\n    private static DataHandler newDataHandler(MimeMultipart multipart, MailcapCommandMap commandMap) {\n        registerMultipartMixedHandler(commandMap);\n        DataHandler dataHandler = new DataHandler(multipart, MIME_TYPE);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler;\n    }\n\n    private static void registerMultipartMixedHandler(MailcapCommandMap commandMap) {\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + MULTIPART_MIXED_HANDLER_CLASS_NAME);\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 715, "output": 1910, "cacheRead": 72192, "cacheWrite": 0, "totalTokens": 74817, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777668417965, "responseId": "resp_0f7231e1bdc6aadf0169f51142a0548191bcea7d2c4987ae14"}}
