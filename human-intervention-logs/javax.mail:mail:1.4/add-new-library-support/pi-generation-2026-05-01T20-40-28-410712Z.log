                  dynamicAccessDir.resolve("demo").resolve("reflection-calls.json"),
                  """
                  {
                    "java.lang.Class#forName(java.lang.String)": [
                      "com.example.Foo.load(Foo.java:10)"
                    ]
                  }
                  """,
