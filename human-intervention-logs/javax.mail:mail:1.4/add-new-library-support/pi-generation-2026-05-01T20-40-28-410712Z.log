  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.mail.handlers.multipart_mixed;
  import java.awt.datatransfer.DataFlavor;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  import java.security.CodeSource;
  import javax.activation.DataHandler;
  import javax.activation.DataSource;
  import javax.activation.MailcapCommandMap;
  import javax.mail.internet.MimeBodyPart;
  import javax.mail.internet.MimeMultipart;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class MultipartMixedTest {
      private static final String MIME_TYPE = "multipart/mixed";
      private static final String MULTIPART_MIXED_HANDLER_CLASS_NAME = "com.sun.mail.handlers.multipart_mixed";
      private static final String BOUNDARY = "test-boundary";
      private static final String CONTENT_TYPE = MIME_TYPE + "; boundary=\"" + BOUNDARY + "\"";
      private static final String MULTIPART_CONTENT = ""
              + "--" + BOUNDARY + "\r\n"
              + "Content-Type: text/plain; charset=UTF-8\r\n"
              + "\r\n"
              + "first part\r\n"
              + "--" + BOUNDARY + "\r\n"
              + "Content-Type: text/plain; charset=UTF-8\r\n"
              + "\r\n"
              + "second part\r\n"
              + "--" + BOUNDARY + "--\r\n";
  
      @Test
      void exposesMimeMultipartTransferFlavor() {
          multipart_mixed handler = new multipart_mixed();
  
          DataFlavor[] flavors = handler.getTransferDataFlavors();
  
          assertMultipartFlavor(flavors);
      }
  
      @Test
      void initializesMultipartMixedHandlerLoadedFromArtifactThroughActivationCommandMap() throws Exception {
          CodeSource codeSource = multipart_mixed.class.getProtectionDomain().getCodeSource();
          MultipartMixedHandlerClassLoader classLoader = new MultipartMixedHandlerClassLoader(
                  new URL[] {codeSource.getLocation()}, parentClassLoader());
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
          currentThread.setContextClassLoader(classLoader);
          try {
              DataFlavor[] flavors = getTransferDataFlavors(new MultipartDataSource(), new MailcapCommandMap());
  
              assertMultipartFlavor(flavors);
              assertThat(classLoader.isHandlerClassLoaded()).isTrue();
          } catch (Error error) {
              rethrowUnlessUnsupportedDynamicClassLoading(error);
          } finally {
              currentThread.setContextClassLoader(originalContextClassLoader);
              classLoader.close();
          }
      }
  
      @Test
      void readsMimeMultipartContentFromDataSource() throws Exception {
          multipart_mixed handler = new multipart_mixed();
  
          Object content = handler.getContent(new MultipartDataSource());
  
          assertThat(content).isInstanceOf(MimeMultipart.class);
          MimeMultipart multipart = (MimeMultipart) content;
          assertThat(multipart.getCount()).isEqualTo(2);
          assertThat(readBodyPartText(multipart, 0)).contains("first part");
          assertThat(readBodyPartText(multipart, 1)).contains("second part");
      }
  
      @Test
      void readsTransferDataForMultipartFlavor() throws Exception {
          multipart_mixed handler = new multipart_mixed();
          DataFlavor flavor = handler.getTransferDataFlavors()[0];
  
          Object transferData = handler.getTransferData(flavor, new MultipartDataSource());
  
          assertThat(transferData).isInstanceOf(MimeMultipart.class);
          MimeMultipart multipart = (MimeMultipart) transferData;
          assertThat(multipart.getCount()).isEqualTo(2);
      }
  
      @Test
      void returnsNullForUnsupportedTransferFlavor() {
          multipart_mixed handler = new multipart_mixed();
          DataFlavor unsupportedFlavor = new DataFlavor(String.class, "Plain String");
  
          Object transferData = handler.getTransferData(unsupportedFlavor, new MultipartDataSource());
  
          assertThat(transferData).isNull();
      }
  
      @Test
      void writesMimeMultipartToOutputStream() throws Exception {
          multipart_mixed handler = new multipart_mixed();
          MimeBodyPart bodyPart = new MimeBodyPart();
          bodyPart.setText("body written by handler", StandardCharsets.UTF_8.name());
          MimeMultipart multipart = new MimeMultipart();
          multipart.addBodyPart(bodyPart);
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
  
          handler.writeTo(multipart, MIME_TYPE, outputStream);
  
          String serializedMultipart = outputStream.toString(StandardCharsets.UTF_8.name());
          assertThat(serializedMultipart).contains("body written by handler");
          assertThat(serializedMultipart).contains("--");
      }
  
      private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {
          commandMap.addMailcap(MIME_TYPE + ";; x-java-content-handler=" + MULTIPART_MIXED_HANDLER_CLASS_NAME);
          DataHandler dataHandler = new DataHandler(dataSource);
          dataHandler.setCommandMap(commandMap);
          return dataHandler.getTransferDataFlavors();
      }
  
      private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static ClassLoader parentClassLoader() {
          ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();
          if (contextClassLoader != null) {
              return contextClassLoader;
          }
          return MultipartMixedTest.class.getClassLoader();
      }
  
      private static String readBodyPartText(MimeMultipart multipart, int index) throws Exception {
          try (InputStream inputStream = multipart.getBodyPart(index).getInputStream()) {
              return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);
          }
      }
  
      private static void assertMultipartFlavor(DataFlavor[] flavors) {
          assertThat(flavors).hasSize(1);
          assertThat(flavors[0].getRepresentationClass()).isEqualTo(MimeMultipart.class);
          assertThat(flavors[0].getPrimaryType()).isEqualTo("multipart");
          assertThat(flavors[0].getSubType()).isEqualTo("mixed");
          assertThat(flavors[0].getHumanPresentableName()).isEqualTo("Multipart");
      }
  
      private static final class MultipartMixedHandlerClassLoader extends URLClassLoader {
          private boolean handlerClassLoaded;
  
          private MultipartMixedHandlerClassLoader(URL[] urls, ClassLoader parent) {
              super(urls, parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!MULTIPART_MIXED_HANDLER_CLASS_NAME.equals(name)) {
                  return super.loadClass(name, resolve);
              }
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      loadedClass = findClass(name);
                      handlerClassLoaded = true;
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private boolean isHandlerClassLoaded() {
              return handlerClassLoaded;
          }
      }
  
      private static final class MultipartDataSource implements DataSource {
          private final byte[] content = MULTIPART_CONTENT.getBytes(StandardCharsets.UTF_8);
  
          @Override
          public InputStream getInputStream() {
              return new ByteArrayInputStream(content);
          }
  
          @Override
          public OutputStream getOutputStream() throws IOException {
              throw new IOException("Output is not supported");
          }
  
          @Override
          public String getContentType() {
              return CONTENT_TYPE;
          }
  
          @Override
          public String getName() {
              return "mixed-multipart";
          }
