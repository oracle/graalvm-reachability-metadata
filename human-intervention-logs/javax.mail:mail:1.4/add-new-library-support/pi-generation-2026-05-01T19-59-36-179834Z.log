ay(), StandardCharsets.UTF_8))\n                        .contains(\"IMAP DEBUG: AUTH: PLAIN\", \"IMAP SASL DEBUG: Mechanisms:\");\n            } finally {\n                protocol.disconnect();\n            }\n        }\n    }\n\n    @Test\n    void fetchUidReadsUidFetchResponse() throws Exception {\n        Properties properties = new Properties();\n\n        try (LocalImapServer server = LocalImapServer.start((reader, writer) -> {\n            String command = reader.readLine();\n            if (command == null || !command.endsWith(\" FETCH 1 (UID)\")) {\n                throw new IOException(\"Expected FETCH UID command but received: \" + command);\n            }\n            String tag = command.substring(0, command.indexOf(' '));\n            writer.write(\"* 1 FETCH (UID 123)\\r\\n\");\n            writer.write(tag + \" OK FETCH completed\\r\\n\");\n            writer.flush();\n        })) {\n            IMAPProtocol protocol = new IMAPProtocol(\n                    PROTOCOL_NAME, LOCALHOST, server.port(), false, System.out, properties, false);\n            try {\n                UID uid = protocol.fetchUID(1);\n\n                assertThat(uid).isNotNull();\n                assertThat(uid.msgno).isEqualTo(1);\n                assertThat(uid.uid).isEqualTo(123L);\n            } finally {\n                protocol.disconnect();\n            }\n        }\n    }\n"}, {"oldText": "        private static LocalImapServer start() throws IOException {\n            ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getByName(LOCALHOST));\n            ExecutorService executor = Executors.newSingleThreadExecutor();\n            Future<?> serverTask = executor.submit(() -> {\n                serveCapabilityRequest(serverSocket);\n                return null;\n            });\n            return new LocalImapServer(serverSocket, executor, serverTask);\n        }\n", "newText": "        private static LocalImapServer start(ImapSession session) throws IOException {\n            ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getByName(LOCALHOST));\n            ExecutorService executor = Executors.newSingleThreadExecutor();\n            Future<?> serverTask = executor.submit(() -> {\n                serveSession(serverSocket, session);\n                return null;\n            });\n            return new LocalImapServer(serverSocket, executor, serverTask);\n        }\n"}, {"oldText": "        private static void serveCapabilityRequest(ServerSocket serverSocket) throws IOException {\n            try (Socket socket = serverSocket.accept();\n                    BufferedReader reader = new BufferedReader(\n                            new InputStreamReader(socket.getInputStream(), StandardCharsets.US_ASCII));\n                    BufferedWriter writer = new BufferedWriter(\n                            new OutputStreamWriter(socket.getOutputStream(), StandardCharsets.US_ASCII))) {\n                writer.write(\"* OK IMAP test server ready\\r\\n\");\n                writer.flush();\n\n                String command = reader.readLine();\n                if (command == null || !command.endsWith(\" CAPABILITY\")) {\n                    throw new IOException(\"Expected CAPABILITY command but received: \" + command);\n                }\n                String tag = command.substring(0, command.indexOf(' '));\n                writer.write(\"* CAPABILITY IMAP4rev1 AUTH=PLAIN\\r\\n\");\n                writer.write(tag + \" OK CAPABILITY completed\\r\\n\");\n                writer.flush();\n            }\n        }\n", "newText": "        private static void serveSession(ServerSocket serverSocket, ImapSession session) throws IOException {\n            try (Socket socket = serverSocket.accept();\n                    BufferedReader reader = new BufferedReader(\n                            new InputStreamReader(socket.getInputStream(), StandardCharsets.US_ASCII));\n                    BufferedWriter writer = new BufferedWriter(\n                            new OutputStreamWriter(socket.getOutputStream(), StandardCharsets.US_ASCII))) {\n                writer.write(\"* OK IMAP test server ready\\r\\n\");\n                writer.flush();\n\n                String command = reader.readLine();\n                if (command == null || !command.endsWith(\" CAPABILITY\")) {\n                    throw new IOException(\"Expected CAPABILITY command but received: \" + command);\n                }\n                String tag = command.substring(0, command.indexOf(' '));\n                writer.write(\"* CAPABILITY IMAP4rev1 AUTH=PLAIN\\r\\n\");\n                writer.write(tag + \" OK CAPABILITY completed\\r\\n\");\n                writer.flush();\n\n                session.handle(reader, writer);\n            }\n        }\n    }\n\n    private interface ImapSession {\n        void handle(BufferedReader reader, BufferedWriter writer) throws IOException;\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 896, "output": 1660, "cacheRead": 37376, "cacheWrite": 0, "totalTokens": 39932, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777665725817, "responseId": "resp_04c731dbfe3889e20169f506be66848192807866ab71461062"}}
