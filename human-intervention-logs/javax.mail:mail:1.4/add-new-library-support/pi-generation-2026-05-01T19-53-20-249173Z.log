  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.mail.pop3.POP3Message;
  import com.sun.mail.pop3.POP3Store;
  import java.io.ByteArrayOutputStream;
  import java.io.PrintStream;
  import java.nio.charset.StandardCharsets;
  import java.util.Properties;
  import javax.mail.Session;
  import javax.mail.URLName;
  import org.junit.jupiter.api.Test;
  
  public class POP3StoreTest {
      private static final String PROTOCOL = "pop3";
      private static final String MESSAGE_CLASS_PROPERTY = "mail." + PROTOCOL + ".message.class";
  
      @Test
      void configuresCustomMessageClassConstructor() {
          Properties properties = new Properties();
          properties.setProperty(MESSAGE_CLASS_PROPERTY, POP3Message.class.getName());
          Session session = Session.getInstance(properties);
  
          POP3Store store = new POP3Store(session, pop3Url());
  
          assertThat(store.isConnected()).isFalse();
          assertThat(store.getURLName().getProtocol()).isEqualTo(PROTOCOL);
      }
  
      @Test
      void fallsBackToClassForNameForMessageClassLookup() {
          Properties properties = new Properties();
          String invalidArrayMessageClassName = "[I";
          properties.setProperty(MESSAGE_CLASS_PROPERTY, invalidArrayMessageClassName);
          Session session = Session.getInstance(properties);
          ByteArrayOutputStream debugOutput = new ByteArrayOutputStream();
          session.setDebugOut(new PrintStream(debugOutput));
          session.setDebug(true);
  
          POP3Store store = new POP3Store(session, pop3Url());
  
          assertThat(store.isConnected()).isFalse();
          String debugText = new String(debugOutput.toByteArray(), StandardCharsets.UTF_8);
          assertThat(debugText).contains(
                  "DEBUG: POP3 message class: " + invalidArrayMessageClassName,
                  "DEBUG: failed to load POP3 message class:");
      }
  
      private static URLName pop3Url() {
          return new URLName(PROTOCOL, "localhost", -1, null, "user", "password");
