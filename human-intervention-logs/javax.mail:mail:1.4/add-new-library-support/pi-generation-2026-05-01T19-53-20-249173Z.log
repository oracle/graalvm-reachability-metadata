til.List;\nimport java.util.Properties;\nimport java.util.concurrent.FutureTask;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport javax.net.SocketFactory;\nimport org.junit.jupiter.api.Test;\n\npublic class SocketFetcherTest {\n    private static final String PREFIX = \"mail.socketfetcher\";\n    private static final String SOCKET_FACTORY_CLASS_NAME = RecordingSocketFactory.class.getName();\n\n    @Test\n    void loadsConfiguredSocketFactoryWithClassForNameFallback() throws Exception {\n        RecordingSocketFactory.reset();\n        Properties properties = new Properties();\n        properties.setProperty(PREFIX + \".socketFactory.class\", SOCKET_FACTORY_CLASS_NAME);\n        properties.setProperty(PREFIX + \".socketFactory.fallback\", \"false\");\n\n        try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\n            FutureTask<Socket> acceptedConnection = new FutureTask<>(serverSocket::accept);\n            Thread acceptThread = new Thread(acceptedConnection, \"socket-fetcher-test-server\");\n            acceptThread.setDaemon(true);\n            acceptThread.start();\n\n            RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n                    parentClassLoader(), SOCKET_FACTORY_CLASS_NAME);\n            try (Socket clientSocket = getSocketWithContextClassLoader(\n                            serverSocket.getInetAddress().getHostAddress(),\n                            serverSocket.getLocalPort(),\n                            properties,\n                            contextClassLoader);\n                    Socket serverConnection = acceptedConnection.get(5, TimeUnit.SECONDS)) {\n                assertThat(clientSocket.isConnected()).isTrue();\n                assertThat(serverConnection.isConnected()).isTrue();\n            }\n\n            assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SOCKET_FACTORY_CLASS_NAME);\n            assertThat(RecordingSocketFactory.defaultCallCount()).isEqualTo(1);\n            assertThat(RecordingSocketFactory.unconnectedSocketCallCount()).isEqualTo(1);\n        }\n    }\n\n    private static Socket getSocketWithContextClassLoader(\n            String host, int port, Properties properties, ClassLoader contextClassLoader) throws IOException {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(contextClassLoader);\n        try {\n            return SocketFetcher.getSocket(host, port, properties, PREFIX, false);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return SocketFetcherTest.class.getClassLoader();\n    }\n\n    public static final class RecordingSocketFactory extends SocketFactory {\n        private static final AtomicInteger DEFAULT_CALL_COUNT = new AtomicInteger();\n        private static final AtomicInteger UNCONNECTED_SOCKET_CALL_COUNT = new AtomicInteger();\n\n        public static SocketFactory getDefault() {\n            DEFAULT_CALL_COUNT.incrementAndGet();\n            return new RecordingSocketFactory();\n        }\n\n        @Override\n        public Socket createSocket() throws IOException {\n            UNCONNECTED_SOCKET_CALL_COUNT.incrementAndGet();\n            return new Socket();\n        }\n\n        @Override\n        public Socket createSocket(String host, int port) throws IOException {\n            return new Socket(host, port);\n        }\n\n        @Override\n        public Socket createSocket(String host, int port, InetAddress localAddress, int localPort) throws IOException {\n            Socket socket = new Socket();\n            socket.bind(new java.net.InetSocketAddress(localAddress, localPort));\n            socket.connect(new java.net.InetSocketAddress(host, port));\n            return socket;\n        }\n\n        @Override\n        public Socket createSocket(InetAddress host, int port) throws IOException {\n            return new Socket(host, port);\n        }\n\n        @Override\n        public Socket createSocket(InetAddress address, int port, InetAddress localAddress, int localPort)\n                throws IOException {\n            Socket socket = new Socket();\n            socket.bind(new java.net.InetSocketAddress(localAddress, localPort));\n            socket.connect(new java.net.InetSocketAddress(address, port));\n            return socket;\n        }\n\n        private static void reset() {\n            DEFAULT_CALL_COUNT.set(0);\n            UNCONNECTED_SOCKET_CALL_COUNT.set(0);\n        }\n\n        private static int defaultCallCount() {\n            return DEFAULT_CALL_COUNT.get();\n        }\n\n        private static int unconnectedSocketCallCount() {\n            return UNCONNECTED_SOCKET_CALL_COUNT.get();\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        private final String rejectedClassName;\n        private final List<String> rejectedClassNames = new ArrayList<>();\n\n        private RejectingClassLoader(ClassLoader parent, String rejectedClassName) {\n            super(parent);\n            this.rejectedClassName = rejectedClassName;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedClassName.equals(name)) {\n                rejectedClassNames.add(name);\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private List<String> getRejectedClassNames() {\n            return rejectedClassNames;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777665084466}]}
