  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.mail.smtp.SMTPTransport;
  import java.util.ArrayList;
  import java.util.List;
  import java.util.Properties;
  import javax.mail.NoSuchProviderException;
  import javax.mail.Provider;
  import javax.mail.Session;
  import javax.mail.Transport;
  import org.junit.jupiter.api.Test;
  
  public class SessionTest {
      private static final String SMTP_PROTOCOL = "smtp";
      private static final String SMTP_TRANSPORT_CLASS_NAME = SMTPTransport.class.getName();
  
      @Test
      void loadsTransportProviderWithContextClassLoader() throws Exception {
          Session session = Session.getInstance(new Properties());
          RecordingClassLoader contextClassLoader = new RecordingClassLoader(parentClassLoader());
  
          Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);
  
          assertThat(transport).isInstanceOf(SMTPTransport.class);
          assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);
          assertThat(contextClassLoader.getLoadedClassNames()).contains(SMTP_TRANSPORT_CLASS_NAME);
      }
  
      @Test
      void fallsBackToSessionClassLoaderWhenContextLoaderCannotFindProvider() throws Exception {
          Session session = Session.getInstance(new Properties());
          RejectingClassLoader contextClassLoader = new RejectingClassLoader(
                  parentClassLoader(), SMTP_TRANSPORT_CLASS_NAME, new ClassNotFoundException(SMTP_TRANSPORT_CLASS_NAME));
  
          Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);
  
          assertThat(transport).isInstanceOf(SMTPTransport.class);
          assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);
          assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SMTP_TRANSPORT_CLASS_NAME);
      }
  
      @Test
      void fallsBackToClassForNameWhenContextClassLoaderFails() throws Exception {
          Session session = Session.getInstance(new Properties());
          RejectingClassLoader contextClassLoader = new RejectingClassLoader(
                  parentClassLoader(), SMTP_TRANSPORT_CLASS_NAME, new IllegalStateException("context loader failed"));
  
          Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);
  
          assertThat(transport).isInstanceOf(SMTPTransport.class);
          assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);
          assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SMTP_TRANSPORT_CLASS_NAME);
      }
  
      private static Transport getTransportWithContextClassLoader(Session session, ClassLoader contextClassLoader)
              throws NoSuchProviderException {
          Thread currentThread = Thread.currentThread();
          ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();
          currentThread.setContextClassLoader(contextClassLoader);
          try {
              return session.getTransport(smtpProvider());
          } finally {
              currentThread.setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private static Provider smtpProvider() {
          return new Provider(Provider.Type.TRANSPORT, SMTP_PROTOCOL, SMTP_TRANSPORT_CLASS_NAME, "JavaMail", null);
      }
  
      private static ClassLoader parentClassLoader() {
