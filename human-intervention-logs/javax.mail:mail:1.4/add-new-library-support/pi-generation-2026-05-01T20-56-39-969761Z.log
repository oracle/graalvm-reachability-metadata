      public Object getContent(DataSource ds) throws IOException {
  	String enc = null;
  	InputStreamReader is = null;
  	
  	try {
  	    enc = getCharset(ds.getContentType());
  	    is = new InputStreamReader(ds.getInputStream(), enc);
  	} catch (IllegalArgumentException iex) {
  	    /*
