+ \"--\" + BOUNDARY + \"--\\r\\n\";\n\n    @Test\n    void exposesMimeMultipartTransferFlavorThroughActivationCommandMap() {\n        DataFlavor[] flavors = getTransferDataFlavors(new MultipartDataSource(), new MailcapCommandMap());\n\n        assertMultipartFlavor(flavors);\n    }\n\n    @Test\n    void createsMultipartMixedHandlerThroughMailcapCommandMap() {\n        MailcapCommandMap commandMap = new MailcapCommandMap();\n        registerMultipartMixedHandler(commandMap);\n\n        DataContentHandler handler = commandMap.createDataContentHandler(MIME_TYPE);\n\n        assertThat(handler).isNotNull();\n        assertMultipartFlavor(handler.getTransferDataFlavors());\n    }\n\n    @Test\n    void initializesMultipartMixedHandlerLoadedFromArtifactThroughActivationCommandMap() throws Exception {\n        CodeSource codeSource = MimeMultipart.class.getProtectionDomain().getCodeSource();\n        MultipartMixedHandlerClassLoader classLoader = new MultipartMixedHandlerClassLoader(\n                new URL[] {codeSource.getLocation()}, parentClassLoader());\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            DataFlavor[] flavors = getTransferDataFlavors(new MultipartDataSource(), new MailcapCommandMap());\n\n            assertMultipartFlavor(flavors);\n            assertThat(classLoader.isHandlerClassLoaded()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n            classLoader.close();\n        }\n    }\n\n    @Test\n    void readsMimeMultipartContentThroughActivationCommandMap() throws Exception {\n        DataHandler dataHandler = newDataHandler(new MultipartDataSource(), new MailcapCommandMap());\n\n        Object content = dataHandler.getContent();\n\n        assertThat(content).isInstanceOf(MimeMultipart.class);\n        MimeMultipart multipart = (MimeMultipart) content;\n        assertThat(multipart.getCount()).isEqualTo(2);\n        assertThat(readBodyPartText(multipart, 0)).contains(\"first part\");\n        assertThat(readBodyPartText(multipart, 1)).contains(\"second part\");\n    }\n\n    @Test\n    void readsTransferDataForMultipartFlavorThroughActivationCommandMap() throws Exception {\n        DataHandler dataHandler = newDataHandler(new MultipartDataSource(), new MailcapCommandMap());\n        DataFlavor flavor = dataHandler.getTransferDataFlavors()[0];\n\n        Object transferData = dataHandler.getTransferData(flavor);\n\n        assertThat(transferData).isInstanceOf(MimeMultipart.class);\n        MimeMultipart multipart = (MimeMultipart) transferData;\n        assertThat(multipart.getCount()).isEqualTo(2);\n    }\n\n    @Test\n    void returnsNullForUnsupportedTransferFlavor() throws Exception {\n        DataHandler dataHandler = newDataHandler(new MultipartDataSource(), new MailcapCommandMap());\n        DataFlavor unsupportedFlavor = new DataFlavor(String.class, \"Plain String\");\n\n        Object transferData = dataHandler.getTransferData(unsupportedFlavor);\n\n        assertThat(transferData).isNull();\n    }\n\n    @Test\n    void writesMimeMultipartToOutputStream() throws Exception {\n        MimeBodyPart bodyPart = new MimeBodyPart();\n        bodyPart.setText(\"body written by handler\", StandardCharsets.UTF_8.name());\n        MimeMultipart multipart = new MimeMultipart();\n        multipart.addBodyPart(bodyPart);\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        DataHandler dataHandler = newDataHandler(multipart, new MailcapCommandMap());\n        dataHandler.writeTo(outputStream);\n\n        String serializedMultipart = outputStream.toString(StandardCharsets.UTF_8.name());\n        assertThat(serializedMultipart).contains(\"body written by handler\");\n        assertThat(serializedMultipart).contains(\"--\");\n    }\n\n    private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {\n        return newDataHandler(dataSource, commandMap).getTransferDataFlavors();\n    }\n\n    private static DataHandler newDataHandler(DataSource dataSource, MailcapCommandMap commandMap) {\n        registerMultipartMixedHandler(commandMap);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler;\n    }\n\n    private static DataHandler newDataHandler(MimeMultipart multipart, MailcapCommandMap commandMap) {\n        registerMultipartMixedHandler(commandMap);\n        DataHandler dataHandler = new DataHandler(multipart, MIME_TYPE);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler;\n    }\n\n    private static void registerMultipartMixedHandler(MailcapCommandMap commandMap) {\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + MULTIPART_MIXED_HANDLER_CLASS_NAME);\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return MultipartMixedTest.class.getClassLoader();\n    }\n\n    private static String readBodyPartText(MimeMultipart multipart, int index) throws Exception {\n        try (InputStream inputStream = multipart.getBodyPart(index).getInputStream()) {\n            return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\n        }\n    }\n\n    private static void assertMultipartFlavor(DataFlavor[] flavors) {\n        as