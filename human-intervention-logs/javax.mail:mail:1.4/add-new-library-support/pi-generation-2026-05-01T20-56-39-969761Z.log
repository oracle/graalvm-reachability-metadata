[tool-call] delta {"path":"tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/TextPlainTest.java","edits":[{"oldText":"import java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport javax.activation.DataSource;\nimport org.junit.jupiter.api.Test;\n","newText":"import java.io.OutputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.security.CodeSource;\nimport javax.activation.DataHandler;\nimport javax.activation.DataSource;\nimport javax.activation.MailcapCommandMap;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"public class TextPlainTest {\n    private static final String MIME_TYPE = \"text/plain\";\n    private static final String PLAIN_TEXT = \"Mail handler plain text \\u2603\";\n","newText":"public class TextPlainTest {\n    private static final String MIME_TYPE = \"text/plain\";\n    private static final String TEXT_PLAIN_HANDLER_CLASS_NAME = \"com.sun.mail.handlers.text_plain\";\n    private static final String PLAIN_TEXT = \"Mail handler plain text \\u2603\";\n"},{"oldText":"    @Test\n    void writesPlainTextStringToOutputStream() throws IOException {\n        text_plain handler = new text_plain();\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        handler.writeTo(PLAIN_TEXT, MIME_TYPE + \"; charset=UTF-8\", outputStream);\n\n        assertThat(outputStream.toString(StandardCharsets.UTF_8.name())).isEqualTo(PLAIN_TEXT);\n    }\n\n    @Test\n    void rejectsNonStringObjectsWhenWriting() {\n","newText":"    @Test\n    void writesPlainTextStringToOutputStream() throws IOException {\n        text_plain handler = new text_plain();\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        handler.writeTo(PLAIN_TEXT, MIME_TYPE + \"; charset=UTF-8\", outputStream);\n\n        assertThat(outputStream.toString(StandardCharsets.UTF_8.name())).isEqualTo(PLAIN_TEXT);\n    }\n\n    @Test\n    void initializesArtifactPlainTextHandlerThroughActivationCommandMap() throws Exception {\n        CodeSource codeSource = text_plain.class.getProtectionDomain().getCodeSource();\n        TextPlainHandlerClassLoader classLoader = new TextPlainHandlerClassLoader(\n                new URL[] {codeSource.getLocation()}, parentClassLoader());\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            DataHandler dataHandler = newDataHandler(new PlainTextDataSource(PLAIN_TEXT, MIME_TYPE + \"; charset=UTF-8\"));\n\n            assertPlainStringFlavor(dataHandler.getTransferDataFlavors());\n            assertThat(dataHandler.getContent()).isEqualTo(PLAIN_TEXT);\n            assertThat(classLoader.isHandlerClassLoaded()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n            classLoader.close();\n        }\n    }\n\n    @Test\n    void rejectsNonStringObjectsWhenWriting() {\n"},{"oldText":"    private static void assertPlainStringFlavor(DataFlavor[] flavors) {\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(String.class);\n        assertThat(flavors[0].getPrimaryType()).isEqualTo(\"text\");\n        assertThat(flavors[0].getSubType()).isEqualTo(\"plain\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"Text String\");\n    }\n\n    private static final class PlainTextDataSource implements DataSource {\n","newText":"    private static DataHandler newDataHandler(DataSource dataSource) {\n        MailcapCommandMap commandMap = new MailcapCommandMap();\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + TEXT_PLAIN_HANDLER_CLASS_NAME);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler;\n    }\n\n    private static void assertPlainStringFlavor(DataFlavor[] flavors) {\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(String.class);\n        assertThat(flavors[0].getPrimaryType()).isEqualTo(\"text\");\n        assertThat(flavors[0].getSubType()).isEqualTo(\"plain\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"Text String\");\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return TextPlainTest.class.getClassLoader();\n    }\n\n    private static final class TextPlainHandlerClassLoader extends URLClassLoader {\n        private boolean handlerClassLoaded;\n\n        private TextPlainHandlerClassLoader(URL[] urls, ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!TEXT_PLAIN_HANDLER_CLASS_NAME.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = findClass(name);\n                    handlerClassLoaded = true;\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private boolean isHandlerClassLoaded() {\n            return handlerClassLoaded;\n        }\n    }\n\n    private static final class PlainTextDataSource implements DataSource {\n"}]}
