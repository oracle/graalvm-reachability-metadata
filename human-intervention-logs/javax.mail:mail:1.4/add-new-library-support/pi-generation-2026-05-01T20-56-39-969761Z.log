[tool-call] delta {"path":"tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/TextPlainTest.java","edits":[{"oldText":"import org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class TextPlainTest {\n","newText":"import org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.MethodOrderer;\nimport org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\n\n@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\npublic class TextPlainTest {\n"},{"oldText":"    @Test\n    void exposesPlainStringTransferFlavor() {\n        text_plain handler = new text_plain();\n\n        DataFlavor[] flavors = handler.getTransferDataFlavors();\n\n        assertPlainStringFlavor(flavors);\n    }\n","newText":"    @Test\n    @Order(1)\n    void readsPlainTextThroughDefaultMailcapCommandMap() throws Exception {\n        try {\n            DataHandler dataHandler = new DataHandler(\n                    new PlainTextDataSource(PLAIN_TEXT, MIME_TYPE + \"; charset=UTF-8\"));\n\n            assertPlainStringFlavor(dataHandler.getTransferDataFlavors());\n            assertThat(dataHandler.getContent()).isEqualTo(PLAIN_TEXT);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        }\n    }\n\n    @Test\n    void exposesPlainStringTransferFlavor() {\n        text_plain handler = new text_plain();\n\n        DataFlavor[] flavors = handler.getTransferDataFlavors();\n\n        assertPlainStringFlavor(flavors);\n    }\n"}]}
