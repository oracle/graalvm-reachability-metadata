ttp://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport com.sun.mail.handlers.text_xml;\nimport java.awt.datatransfer.DataFlavor;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport javax.activation.DataSource;\nimport org.junit.jupiter.api.Test;\n\npublic class TextXmlTest {\n    private static final String MIME_TYPE = \"text/xml\";\n    private static final String XML_DOCUMENT = \"<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?><message>Mail handler</message>\";\n\n    @Test\n    void exposesXmlStringTransferFlavor() {\n        text_xml handler = new text_xml();\n\n        DataFlavor[] flavors = handler.getTransferDataFlavors();\n\n        assertXmlStringFlavor(flavors);\n    }\n\n    @Test\n    void readsXmlContentFromDataSource() throws IOException {\n        text_xml handler = new text_xml();\n        DataFlavor flavor = handler.getTransferDataFlavors()[0];\n        DataSource dataSource = new XmlDataSource(XML_DOCUMENT, MIME_TYPE + \"; charset=UTF-8\");\n\n        Object transferData = handler.getTransferData(flavor, dataSource);\n\n        assertThat(transferData).isEqualTo(XML_DOCUMENT);\n    }\n\n    @Test\n    void returnsNullForUnsupportedTransferFlavor() throws IOException {\n        text_xml handler = new text_xml();\n        DataFlavor unsupportedFlavor = new DataFlavor(InputStream.class, \"Input Stream\");\n        DataSource dataSource = new XmlDataSource(XML_DOCUMENT, MIME_TYPE + \"; charset=UTF-8\");\n\n        Object transferData = handler.getTransferData(unsupportedFlavor, dataSource);\n\n        assertThat(transferData).isNull();\n    }\n\n    @Test\n    void writesXmlStringToOutputStream() throws IOException {\n        text_xml handler = new text_xml();\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        handler.writeTo(XML_DOCUMENT, MIME_TYPE + \"; charset=UTF-8\", outputStream);\n\n        assertThat(outputStream.toString(StandardCharsets.UTF_8.name())).isEqualTo(XML_DOCUMENT);\n    }\n\n    @Test\n    void rejectsNonStringObjectsWhenWriting() {\n        text_xml handler = new text_xml();\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n\n        assertThatThrownBy(() -> handler.writeTo(new byte[] {1, 2, 3}, MIME_TYPE, outputStream))\n                .isInstanceOf(IOException.class)\n                .hasMessageContaining(\"DataContentHandler requires String object\");\n    }\n\n    private static void assertXmlStringFlavor(DataFlavor[] flavors) {\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(String.class);\n        assertThat(flavors[0].getPrimaryType()).isEqualTo(\"text\");\n        assertThat(flavors[0].getSubType()).isEqualTo(\"xml\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"XML String\");\n    }\n\n    private static final class XmlDataSource implements DataSource {\n        private final byte[] content;\n        private final String contentType;\n\n        private XmlDataSource(String content, String contentType) {\n            this.content = content.getBytes(StandardCharsets.UTF_8);\n            this.contentType = contentType;\n        }\n\n        @Override\n        public InputStream getInputStream() {\n            return new ByteArrayInputStream(content);\n        }\n\n        @Override\n        public OutputStream getOutputStream() throws IOException {\n            throw new IOException(\"Output is not supported\");\n        }\n\n        @Override\n        public String getContentType() {\n            return contentType;\n        }\n\n        @Override\n        public String getName() {\n            return \"xml-message\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2037, "output": 1109, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 25674, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777669397665, "responseId": "resp_01a057c17f3cee640169f515161fac81a392d14e5076da38b3"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_lpRc9NNqovGOD3GIK3C5QuNW|fc_01a057c17f3cee640169f51519b46c81a3a90d1c1db1ca1b90", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4031 bytes to tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/TextXmlTest.java"}], "isError": false, "timestamp": 1777669404970}]}
