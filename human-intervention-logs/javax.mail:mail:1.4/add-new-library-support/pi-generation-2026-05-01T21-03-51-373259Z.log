  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.mail.handlers.text_html;
  import java.awt.datatransfer.DataFlavor;
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  import java.security.CodeSource;
  import javax.activation.DataHandler;
  import javax.activation.DataSource;
  import javax.activation.MailcapCommandMap;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class TextHtmlTest {
      private static final String MIME_TYPE = "text/html";
      private static final String HTML_DOCUMENT = "<html><body><h1>Mail handler</h1></body></html>";
      private static final String TEXT_HTML_HANDLER_CLASS_NAME = "com.sun.mail.handlers.text_html";
  
      @Test
      void exposesHtmlStringTransferFlavor() {
          text_html handler = new text_html();
  
          DataFlavor[] flavors = handler.getTransferDataFlavors();
  
          assertThat(flavors).hasSize(1);
          assertThat(flavors[0].getRepresentationClass()).isEqualTo(String.class);
          assertThat(flavors[0].getPrimaryType()).isEqualTo("text");
          assertThat(flavors[0].getSubType()).isEqualTo("html");
          assertThat(flavors[0].getHumanPresentableName()).isEqualTo("HTML String");
      }
  
      @Test
      void readsHtmlContentFromDataSource() throws IOException {
          text_html handler = new text_html();
          DataFlavor flavor = handler.getTransferDataFlavors()[0];
          DataSource dataSource = new HtmlDataSource(HTML_DOCUMENT, MIME_TYPE + "; charset=UTF-8");
  
          Object transferData = handler.getTransferData(flavor, dataSource);
  
          assertThat(transferData).isEqualTo(HTML_DOCUMENT);
      }
  
      @Test
      void writesHtmlStringToOutputStream() throws IOException {
          text_html handler = new text_html();
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
  
          handler.writeTo(HTML_DOCUMENT, MIME_TYPE + "; charset=UTF-8", outputStream);
  
          assertThat(outputStream.toString(StandardCharsets.UTF_8.name())).isEqualTo(HTML_DOCUMENT);
      }
  
      @Test
      void initializesArtifactHtmlHandlerThroughActivationCommandMap() throws Exception {
          CodeSource codeSource = text_html.class.getProtectionDomain().getCodeSource();
          TextHtmlHandlerClassLoader classLoader = new TextHtmlHandlerClassLoader(
