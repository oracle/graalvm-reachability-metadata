[tool-call] delta {"path":"tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/SessionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.mail.smtp.SMTPTransport;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Properties;\nimport javax.mail.NoSuchProviderException;\nimport javax.mail.Provider;\nimport javax.mail.Session;\nimport javax.mail.Transport;\nimport org.junit.jupiter.api.Test;\n\npublic class SessionTest {\n    private static final String SMTP_PROTOCOL = \"smtp\";\n    private static final String SMTP_TRANSPORT_CLASS_NAME = SMTPTransport.class.getName();\n\n    @Test\n    void loadsTransportProviderWithContextClassLoader() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        RecordingClassLoader contextClassLoader = new RecordingClassLoader(parentClassLoader());\n\n        Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);\n\n        assertThat(transport).isInstanceOf(SMTPTransport.class);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);\n        assertThat(contextClassLoader.getLoadedClassNames()).contains(SMTP_TRANSPORT_CLASS_NAME);\n    }\n\n    @Test\n    void fallsBackToSessionClassLoaderWhenContextLoaderCannotFindProvider() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n                parentClassLoader(), SMTP_TRANSPORT_CLASS_NAME, new ClassNotFoundException(SMTP_TRANSPORT_CLASS_NAME));\n\n        Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);\n\n        assertThat(transport).isInstanceOf(SMTPTransport.class);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);\n        assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SMTP_TRANSPORT_CLASS_NAME);\n    }\n\n    @Test\n    void fallsBackToClassForNameWhenContextClassLoaderFails() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        RejectingClassLoader contextClassLoader = new RejectingClassLoader(\n                parentClassLoader(), SMTP_TRANSPORT_CLASS_NAME, new IllegalStateException(\"context loader failed\"));\n\n        Transport transport = getTransportWithContextClassLoader(session, contextClassLoader);\n\n        assertThat(transport).isInstanceOf(SMTPTransport.class);\n        assertThat(transport.getURLName().getProtocol()).isEqualTo(SMTP_PROTOCOL);\n        assertThat(contextClassLoader.getRejectedClassNames()).containsExactly(SMTP_TRANSPORT_CLASS_NAME);\n    }\n\n    private static Transport getTransportWithContextClassLoader(Session session, ClassLoader contextClassLoader)\n            throws NoSuchProviderException {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(contextClassLoader);\n        try {\n            return session.getTransport(smtpProvider());\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static Provider smtpProvider() {\n        return new Provider(Provider.Type.TRANSPORT, SMTP_PROTOCOL, SMTP_TRANSPORT_CLASS_NAME, \"JavaMail\", null);\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return SessionTest.class.getClassLoader();\n    }\n\n    private static class RecordingClassLoader extends ClassLoader {\n        private final List<String> loadedClassNames = new ArrayList<>();\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            loadedClassNames.add(name);\n            return super.loadClass(name);\n        }\n\n        private List<String> getLoadedClassNames() {\n            return loadedClassNames;\n        }\n    }\n\n    private static final class RejectingClassLoader extends ClassLoader {\n        private final String rejectedClassName;\n        private final Exception failure;\n        private final List<String> rejectedClassNames = new ArrayList<>();\n\n        private RejectingClassLoader(ClassLoader parent, String rejectedClassName, Exception failure) {\n            super(parent);\n            this.rejectedClassName = rejectedClassName;\n            this.failure = failure;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedClassName.equals(name)) {\n                rejectedClassNames.add(name);\n                if (failure instanceof ClassNotFoundException) {\n                    throw (ClassNotFoundException) failure;\n                }\n                throw new IllegalStateException(failure.getMessage(), failure);\n            }\n            return super.loadClass(name);\n        }\n\n        private List<String> getRejectedClassNames() {\n            return rejectedClassNames;\n        }\n    }\n}\n"}
