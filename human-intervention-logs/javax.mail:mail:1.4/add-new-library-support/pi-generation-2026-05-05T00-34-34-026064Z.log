  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Properties;
  
  import javax.activation.DataContentHandler;
  import javax.activation.MailcapCommandMap;
  import javax.mail.Session;
  import javax.mail.Transport;
  import javax.mail.internet.InternetAddress;
  import javax.mail.internet.MimeUtility;
  
  import org.junit.jupiter.api.Test;
  
  public class JavaxMailTest {
  
      @Test
      void getTransportLoadsBuiltInDefaultProviderAndAddressMap() throws Exception {
          Session session = Session.getInstance(new Properties());
  
          Transport transport = session.getTransport(new InternetAddress("native-image@example.test"));
  
          assertThat(session.getProvider("smtp").getClassName()).isEqualTo("com.sun.mail.smtp.SMTPTransport");
          assertThat(transport.getClass().getName()).isEqualTo("com.sun.mail.smtp.SMTPTransport");
      }
  
      @Test
      void mailcapCommandMapLoadsBuiltInMailHandlers() {
          MailcapCommandMap commandMap = new MailcapCommandMap();
  
          assertHandlerType(commandMap, "message/rfc822", "com.sun.mail.handlers.message_rfc822");
          assertHandlerType(commandMap, "multipart/mixed", "com.sun.mail.handlers.multipart_mixed");
          assertHandlerType(commandMap, "text/html", "com.sun.mail.handlers.text_html");
          assertHandlerType(commandMap, "text/plain", "com.sun.mail.handlers.text_plain");
          assertHandlerType(commandMap, "text/xml", "com.sun.mail.handlers.text_xml");
      }
  
      @Test
      void mimeUtilityLoadsCharsetMappings() {
          assertThat(MimeUtility.javaCharset("iso-2022-jp")).isEqualTo("iso-2022-jp");
          assertThat(MimeUtility.mimeCharset("EUC_JP")).isEqualTo("euc-jp");
      }
  
      private static void assertHandlerType(MailcapCommandMap commandMap, String mimeType, String expectedClassName) {
          DataContentHandler handler = commandMap.createDataContentHandler(mimeType);
  
          assertThat(handler).isNotNull();
          assertThat(handler.getClass().getName()).isEqualTo(expectedClassName);
      }
  }
