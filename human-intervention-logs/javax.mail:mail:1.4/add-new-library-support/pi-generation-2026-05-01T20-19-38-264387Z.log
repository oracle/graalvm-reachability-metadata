0/>.\n */\npackage javax_mail.mail;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.awt.Image;\nimport java.awt.datatransfer.DataFlavor;\nimport java.io.ByteArrayInputStream;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.io.OutputStream;\nimport javax.activation.DataHandler;\nimport javax.activation.DataSource;\nimport javax.activation.MailcapCommandMap;\nimport org.junit.jupiter.api.Test;\n\npublic class ImageJpegTest {\n    private static final String MIME_TYPE = \"image/jpeg\";\n    private static final String IMAGE_JPEG_HANDLER_CLASS_NAME = \"com.sun.mail.handlers.image_jpeg\";\n\n    @Test\n    void exposesJpegImageTransferFlavorThroughActivationCommandMap() {\n        DataFlavor[] flavors = getTransferDataFlavors(new JpegDataSource(), new MailcapCommandMap());\n\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(Image.class);\n        assertThat(flavors[0].getPrimaryType()).isEqualTo(\"image\");\n        assertThat(flavors[0].getSubType()).isEqualTo(\"jpeg\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"JPEG Image\");\n    }\n\n    private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + IMAGE_JPEG_HANDLER_CLASS_NAME);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler.getTransferDataFlavors();\n    }\n\n    private static final class JpegDataSource implements DataSource {\n        @Override\n        public InputStream getInputStream() {\n            return new ByteArrayInputStream(new byte[0]);\n        }\n\n        @Override\n        public OutputStream getOutputStream() throws IOException {\n            throw new IOException(\"Output is not supported\");\n        }\n\n        @Override\n        public String getContentType() {\n            return MIME_TYPE;\n        }\n\n        @Override\n        public String getName() {\n            return \"jpeg-data\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 505, "output": 1503, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 24536, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777666746830, "responseId": "resp_06604bab9cf6de020169f50abb44fc81928ac79083c72b874b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_VnFnfIoFbYGIGp9x9JiyimqS|fc_06604bab9cf6de020169f50acab6048192a8cfcabf6d1cc005", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2286 bytes to tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/ImageJpegTest.java"}], "isError": false, "timestamp": 1777666766237}]}
