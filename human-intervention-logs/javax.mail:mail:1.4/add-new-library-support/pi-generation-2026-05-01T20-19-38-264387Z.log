 image_jpeg handler = new image_jpeg();\n        DataFlavor flavor = handler.getTransferDataFlavors()[0];\n\n        Object transferData = handler.getTransferData(flavor, new JpegDataSource(TINY_JPEG));\n\n        assertThat(transferData).isInstanceOf(Image.class);\n    }\n\n    @Test\n    void rejectsJpegEncoding() {\n        image_jpeg handler = new image_jpeg();\n        BufferedImage image = new BufferedImage(1, 1, BufferedImage.TYPE_INT_RGB);\n\n        assertThatThrownBy(() -> handler.writeTo(image, MIME_TYPE, OutputStream.nullOutputStream()))\n                .isInstanceOf(IOException.class)\n                .hasMessage(\"image/jpeg encoding not supported\");\n    }\n\n    @Test\n    void initializesIsolatedJpegHandlerThroughActivationCommandMap() {\n        IsolatedImageJpegClassLoader classLoader = new IsolatedImageJpegClassLoader(parentClassLoader());\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            DataFlavor[] flavors = getTransferDataFlavors(new JpegDataSource(), new MailcapCommandMap());\n\n            assertJpegImageFlavor(flavors);\n            assertThat(classLoader.isHandlerClassDefined()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + IMAGE_JPEG_HANDLER_CLASS_NAME);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler.getTransferDataFlavors();\n    }\n\n    private static void assertJpegImageFlavor(DataFlavor[] flavors) {\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(Image.class);\n        assertThat(flavors[0].getPrimaryType()).isEqualTo(\"image\");\n        assertThat(flavors[0].getSubType()).isEqualTo(\"jpeg\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"JPEG Image\");\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return ImageJpegTest.class.getClassLoader();\n    }\n\n    private static final class JpegDataSource implements DataSource {\n        private final byte[] data;\n\n        private JpegDataSource() {\n            this(new byte[0]);\n        }\n\n        private JpegDataSource(byte[] data) {\n            this.data = data;\n        }\n\n        @Override\n        public InputStream getInputStream() {\n            return new ByteArrayInputStream(data);\n        }\n\n        @Override\n        public OutputStream getOutputStream() throws IOException {\n            throw new IOException(\"Output is not supported\");\n        }\n\n        @Override\n        public String getContentType() {\n            return MIME_TYPE;\n        }\n\n        @Override\n        public String getName() {\n            return \"jpeg-data\";\n        }\n    }\n\n    private static final class IsolatedImageJpegClassLoader extends ClassLoader {\n        private Class<?> handlerClass;\n\n        private IsolatedImageJpegClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!IMAGE_JPEG_HANDLER_CLASS_NAME.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n            Class<?> loadedClass = handlerClass;\n            if (loadedClass == null) {\n                byte[] bytes = Base64.getMimeDecoder().decode(IMAGE_JPEG_HANDLER_BYTES);\n                loadedClass = defineClass(name, bytes, 0, bytes.length, DataHandler.class.getProtectionDomain());\n                handlerClass = loadedClass;\n            }\n            if (resolve) {\n                resolveClass(loadedClass);\n            }\n            return loadedClass;\n        }\n\n        private boolean isHandlerClassDefined() {\n            return handlerClass != null;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777667262431}}
