;\n\n    @Test\n    void exposesGifImageTransferFlavorThroughActivationCommandMap() {\n        try {\n            DataFlavor[] flavors = getTransferDataFlavors(new GifDataSource(), new MailcapCommandMap());\n\n            assertGifImageFlavor(flavors);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        }\n    }\n\n    @Test\n    void initializesIsolatedGifHandlerThroughActivationCommandMap() {\n        IsolatedImageGifClassLoader classLoader = new IsolatedImageGifClassLoader(parentClassLoader());\n        Thread currentThread = Thread.currentThread();\n        ClassLoader originalContextClassLoader = currentThread.getContextClassLoader();\n        currentThread.setContextClassLoader(classLoader);\n        try {\n            DataFlavor[] flavors = getTransferDataFlavors(new GifDataSource(), new MailcapCommandMap());\n\n            assertGifImageFlavor(flavors);\n            assertThat(classLoader.isHandlerClassDefined()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedDynamicClassLoading(error);\n        } finally {\n            currentThread.setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static DataFlavor[] getTransferDataFlavors(DataSource dataSource, MailcapCommandMap commandMap) {\n        commandMap.addMailcap(MIME_TYPE + \";; x-java-content-handler=\" + IMAGE_GIF_HANDLER_CLASS_NAME);\n        DataHandler dataHandler = new DataHandler(dataSource);\n        dataHandler.setCommandMap(commandMap);\n        return dataHandler.getTransferDataFlavors();\n    }\n\n    private static void assertGifImageFlavor(DataFlavor[] flavors) {\n        assertThat(flavors).hasSize(1);\n        assertThat(flavors[0].getRepresentationClass()).isEqualTo(Image.class);\n        assertThat(flavors[0].getPrimaryType()).isEqualTo(\"image\");\n        assertThat(flavors[0].getSubType()).isEqualTo(\"gif\");\n        assertThat(flavors[0].getHumanPresentableName()).isEqualTo(\"GIF Image\");\n    }\n\n    private static ClassLoader parentClassLoader() {\n        ClassLoader contextClassLoader = Thread.currentThread().getContextClassLoader();\n        if (contextClassLoader != null) {\n            return contextClassLoader;\n        }\n        return ImageGifTest.class.getClassLoader();\n    }\n\n    private static final class GifDataSource implements DataSource {\n        @Override\n        public InputStream getInputStream() {\n            return new ByteArrayInputStream(new byte[0]);\n        }\n\n        @Override\n        public OutputStream getOutputStream() throws IOException {\n            throw new IOException(\"Output is not supported\");\n        }\n\n        @Override\n        public String getContentType() {\n            return MIME_TYPE;\n        }\n\n        @Override\n        public String getName() {\n            return \"gif-data\";\n        }\n    }\n\n    private static final class IsolatedImageGifClassLoader extends ClassLoader {\n        private Class<?> handlerClass;\n\n        private IsolatedImageGifClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (!IMAGE_GIF_HANDLER_CLASS_NAME.equals(name)) {\n                return super.loadClass(name, resolve);\n            }\n            Class<?> loadedClass = handlerClass;\n            if (loadedClass == null) {\n                byte[] bytes = Base64.getMimeDecoder().decode(IMAGE_GIF_HANDLER_BYTES);\n                loadedClass = defineClass(name, bytes, 0, bytes.length, DataHandler.class.getProtectionDomain());\n                handlerClass = loadedClass;\n            }\n            if (resolve) {\n                resolveClass(loadedClass);\n            }\n            return loadedClass;\n        }\n\n        private boolean isHandlerClassDefined() {\n            return handlerClass != null;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777666723480}, {"role": "toolResult", "toolCallId": "call_AXQ0ARdlqqoZbZtTWBGjJZwp|fc_06604bab9cf6de020169f50aa3449481929f8389013586c8a2", "toolName": "read", "content": [{"type": "text", "text": "/*\n * The contents of this file are subject to the terms \n * of the Common Development and Distribution License \n * (the \"License\").  You may not use this file except \n * in compliance with the License.\n * \n * You can obtain a copy of the license at \n * glassfish/bootstrap/legal/CDDLv1.0.txt or \n * https://glassfish.dev.java.net/public/CDDLv1.0.html. \n * See the License for the specific language governing \n * permissions and limitations under the License.\n * \n * When distributing Covered Code, include this CDDL \n * HEADER in each file and include the License file at \n * glassfish/bootstrap/legal/CDDLv1.0.txt.  If applicable, \n * add the following below this CDDL HEADER, with the \n * fields enclosed by brackets \"[]\" replaced with your \n * own identifying information: Portions Copyright [yyyy] \n * [name of copyright owner]\n */\n\n/*\n * @(#)image_jpeg.java\t1.2 05/08/29\n *\n * Copyright 1997-2005 Sun Microsystems, Inc. All Rights Reserved.\n */\n\npackage com.sun.mail.handlers;\n\nimport java.awt.datatransfer.DataFlavor;\nimport javax.activation.*;\n\n/**\n * DataContentHandler for image/jpeg.\n */\npublic class image_jpeg extends image_gif {\n    private static ActivationDataFlavor myDF = new ActivationDataFlavor(\n\tjava.awt.Image.class,\n\t\"image/jpeg\",\n\t\"JPEG Image\");\n\n    protected ActivationDataFlavor getDF() {\n\treturn myDF;\n    }\n}\n"}], "isError": false, "timestamp": 1777666723480}, {"role": "toolResult", "toolCallId": "call_bkVPnsRFWeUKVwtnVEKslSOv|fc_06604bab9cf6de020169f50aa344a0819295a8cc80c3fe5321", "toolName": "read", "content": [{"type": "text", "text": "/*\n * The contents of this file are subject to the terms \n * of the Common Development and Distribution License \n * (the \"License\").  You may not use this file except \n * in compliance with the License.\n * \n * You can obtain a copy of the license at \n * glassfish/bootstrap/legal/CDDLv1.0.txt or \n * https://glassfish.dev.java.net/public/CDDLv1.0.html. \n * See the License for the specific language governing \n * permissions and limitations under the License.\n * \n * When distributing Covered Code, include this CDDL \n * HEADER in each file and include the License file at \n * glassfish/bootstrap/legal/CDDLv1.0.txt.  If applicable, \n * add the following below this CDDL HEADER, with the \n * fields enclosed by brackets \"[]\" replaced with your \n * own identifying information: Portions Copyright [yyyy] \n * [name of copyright owner]\n */\n\n/*\n * @(#)image_gif.java\t1.2 05/08/29\n *\n * Copyright 1997-2005 Sun Microsystems, Inc. All Rights Reserved.\n */\n\npackage com.sun.mail.handlers;\n\nimport java.io.*;\nimport java.awt.*;\nimport java.awt.datatransfer.DataFlavor;\nimport javax.activation.*;\nimport javax.mail.internet.*;\n\n/**\n * DataContentHandler for image/gif.\n */\npublic class image_gif implements DataContentHandler {\n    private static ActivationDataFlavor myDF = new ActivationDataFlavor(\n\tjava.awt.Image.class,\n\t\"image/gif\",\n\t\"GIF Image\");\n\n    protected ActivationDataFlavor getDF() {\n\treturn myDF;\n    }\n\n    /**\n     * Return the DataFlavors for this <code>DataContentHandler</code>.\n     *\n     * @return The DataFlavors\n     */\n    public DataFlavor[] getTransferDataFlavors() { // throws Exception;\n\treturn new DataFlavor[] { getDF() };\n    }\n\n    /**\n     * Return the Transfer Data of type DataFlavor from InputStream.\n     *\n     * @param df The DataFlavor\n     * @param ins The InputStream corresponding to the data\n     * @return String object\n     */\n    public Object getTransferData(DataFlavor df, DataSource ds)\n\t\t\tthrows IOException {\n\t// use myDF.equals to be sure to get ActivationDataFlavor.equals,\n\t// which properly ignores Content-Type parameters in comparison\n\tif (getDF().equals(df))\n\t    return getContent(ds);\n\telse\n\t    return null;\n    }\n\n    public Object getContent(DataSource ds) throws IOException {\n\tInputStream is = ds.getInputStream();\n\tint pos = 0;\n\tint count;\n\tbyte buf[] = new byte[1024];\n\n\twhile ((count = is.read(buf, pos, buf.length - pos)) != -1) {\n\t    pos += count;\n\t    if (pos >= buf.length) {\n\t\tint size = buf.length;\n\t\tif (size < 256*1024)\n\t\t    size += size;\n\t\telse\n\t\t    size += 256*1024;\n\t\tbyte tbuf[] = new byte[size];\n\t\tSystem.arraycopy(buf, 0, tbuf, 0, pos);\n\t\tbuf = tbuf;\n\t    }\n\t}\n\tToolkit tk = Toolkit.getDefaultToolkit();\n\treturn tk.createImage(buf, 0, pos);\n    }\n\n    /**\n     * Write the object to the output stream, using the specified MIME type.\n     */\n    public void writeTo(Object obj, String type, OutputStream os)\n\t\t\tthrows IOException {\n\tif (!(obj instanceof Image))\n\t    throw new IOException(\"\\\"\" + getDF().getMimeType() +\n\t\t\"\\\" DataContentHandler requires Image object, \" +\n\t\t\"was given object of type \" + obj.getClass().toString());\n\n\tthrow new IOException(getDF().getMimeType() + \" encoding not supported\");\n    }\n}\n"}], "isError": false, "timestamp": 1777666723480}, {"role": "toolResult", "toolCallId": "call_eTUPA7gi8Az8Z2yemdrLYGxg|fc_06604bab9cf6de020169f50aa344ac8192a65f5740b541fe79", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"javax.mail:mail:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777666723480}]}
