  		urls = getResources(cld, name);
  	    else
  		urls = getSystemResources(name);
  	    if (urls != null) {
  		for (int i = 0; i < urls.length; i++) {
  		    URL url = urls[i];
  		    InputStream clis = null;
  		    if (debug)
