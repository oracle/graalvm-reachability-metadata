  package javax_mail.mail;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Properties;
  import javax.mail.Address;
  import javax.mail.Message;
  import javax.mail.MessagingException;
  import javax.mail.Provider;
  import javax.mail.Session;
  import javax.mail.Transport;
  import javax.mail.URLName;
  import org.junit.jupiter.api.Test;
  
  public class SessionTest {
      private static final String VENDOR = "coverage";
      private static final String VERSION = "test";
  
      @Test
      void getTransportInstantiatesProviderLoadedByContextClassLoader() throws Exception {
          Session session = Session.getInstance(new Properties());
          Provider provider = provider("context-loader");
          Thread currentThread = Thread.currentThread();
          ClassLoader originalClassLoader = currentThread.getContextClassLoader();
          ClassLoader contextClassLoader = new DelegatingProviderClassLoader(
                  originalClassLoader, RecordingTransport.class.getName());
  
          currentThread.setContextClassLoader(contextClassLoader);
          try {
              Transport transport = session.getTransport(provider);
  
              assertThat(transport).isInstanceOf(RecordingTransport.class);
              assertThat(transport.getURLName().getProtocol()).isEqualTo(provider.getProtocol());
          } finally {
              currentThread.setContextClassLoader(originalClassLoader);
          }
      }
  
      @Test
      void getTransportFallsBackToSessionClassLoaderWhenContextClassLoaderCannotLoadProvider() throws Exception {
          Session session = Session.getInstance(new Properties());
          Provider provider = provider("session-loader");
          Thread currentThread = Thread.currentThread();
          ClassLoader originalClassLoader = currentThread.getContextClassLoader();
          ClassLoader contextClassLoader = new MissingProviderClassLoader(
                  originalClassLoader, RecordingTransport.class.getName());
  
          currentThread.setContextClassLoader(contextClassLoader);
          try {
              Transport transport = session.getTransport(provider);
  
              assertThat(transport).isInstanceOf(RecordingTransport.class);
              assertThat(transport.getURLName().getProtocol()).isEqualTo(provider.getProtocol());
          } finally {
              currentThread.setContextClassLoader(originalClassLoader);
          }
      }
  
      @Test
