er folder = null;\n            try {\n                store.connect(LOCALHOST, server.port(), \"user\", \"password\");\n                folder = store.getFolder(\"INBOX\");\n                folder.open(Folder.READ_ONLY);\n\n                AtomicInteger changedMessages = new AtomicInteger();\n                AtomicReference<Message> changedMessage = new AtomicReference<>();\n                folder.addMessageChangedListener(event -> {\n                    if (event.getMessageChangeType() == MessageChangedEvent.FLAGS_CHANGED) {\n                        changedMessages.incrementAndGet();\n                        changedMessage.set(event.getMessage());\n                    }\n                });\n\n                Thread.sleep(1200L);\n\n                assertThat(folder.getMessageCount()).isEqualTo(1);\n\n                Message message = folder.getMessage(1);\n                assertThat(changedMessages).hasValue(1);\n                assertThat(changedMessage).hasValue(message);\n                assertThat(message.isSet(Flags.Flag.SEEN)).isTrue();\n            } finally {\n                if (folder != null && folder.isOpen()) {\n                    folder.close(false);\n                }\n                if (store.isConnected()) {\n                    store.close();\n                }\n            }\n        }\n    }\n\n    private static final class LocalImapServer implements AutoCloseable {\n        private final ServerSocket serverSocket;\n        private final ExecutorService executor;\n        private final Future<?> serverTask;\n\n        private LocalImapServer(ServerSocket serverSocket, ExecutorService executor, Future<?> serverTask) {\n            this.serverSocket = serverSocket;\n            this.executor = executor;\n            this.serverTask = serverTask;\n        }\n\n        private static LocalImapServer start() throws IOException {\n            ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getByName(LOCALHOST));\n            ExecutorService executor = Executors.newSingleThreadExecutor();\n            Future<?> serverTask = executor.submit(() -> {\n                serveSession(serverSocket);\n                return null;\n            });\n            return new LocalImapServer(serverSocket, executor, serverTask);\n        }\n\n        private int port() {\n            return serverSocket.getLocalPort();\n        }\n\n        @Override\n        public void close() throws Exception {\n            serverSocket.close();\n            executor.shutdownNow();\n            try {\n                serverTask.get(5, TimeUnit.SECONDS);\n            } catch (ExecutionException e) {\n                Throwable cause = e.getCause();\n                if (!(cause instanceof SocketException && serverSocket.isClosed())) {\n                    throw e;\n                }\n            } catch (TimeoutException e) {\n                throw new AssertionError(\"Timed out waiting for IMAP test server to stop\", e);\n            }\n        }\n\n        private static void serveSession(ServerSocket serverSocket) throws IOException {\n            try (Socket socket = serverSocket.accept();\n                    BufferedReader reader = new BufferedReader(\n                            new InputStreamReader(socket.getInputStream(), StandardCharsets.US_ASCII));\n                    BufferedWriter writer = new BufferedWriter(\n                            new OutputStreamWriter(socket.getOutputStream(), StandardCharsets.US_ASCII))) {\n                writer.write(\"* OK IMAP test server ready\\r\\n\");\n                writer.flush();\n\n                boolean sentUnsolicitedFetch = false;\n                String command;\n                while ((command = reader.readLine()) != null) {\n                    String tag = command.substring(0, command.indexOf(' '));\n                    String upperCommand = command.toUpperCase();\n\n                    if (upperCommand.contains(\" CAPABILITY\")) {\n                        writer.write(\"* CAPABILITY IMAP4rev1\\r\\n\");\n                        writer.write(tag + \" OK CAPABILITY completed\\r\\n\");\n                    } else if (upperCommand.contains(\" LOGIN \")) {\n                        writer.write(tag + \" OK LOGIN completed\\r\\n\");\n                    } else if (upperCommand.contains(\" EXAMINE \") || upperCommand.contains(\" SELECT \")) {\n                        writer.write(\"* FLAGS (\\\\Answered \\\\Flagged \\\\Deleted \\\\Seen \\\\Draft)\\r\\n\");\n                        writer.write(\"* 1 EXISTS\\r\\n\");\n                        writer.write(\"* 0 RECENT\\r\\n\");\n                        writer.write(\"* OK [UIDVALIDITY 1] UIDs valid\\r\\n\");\n                        writer.write(\"* OK [UIDNEXT 2] Predicted next UID\\r\\n\");\n                        writer.write(\"* OK [PERMANENTFLAGS (\\\\Answered \\\\Flagged \\\\Deleted \\\\Seen \\\\Draft)] Flags permitted\\r\\n\");\n                        writer.write(tag + \" OK [READ-ONLY] EXAMINE completed\\r\\n\");\n                    } else if (upperCommand.contains(\" NOOP\")) {\n                        if (!sentUnsolicitedFetch) {\n                            writer.write(\"* 1 FETCH (FLAGS (\\\\Seen))\\r\\n\");\n                            sentUnsolicitedFetch = true;\n                        }\n                        writer.write(tag + \" OK NOOP completed\\r\\n\");\n                    } else if (upperCommand.contains(\" CLOSE\")) {\n                        writer.write(tag + \" OK CLOSE completed\\r\\n\");\n                    } else if (upperCommand.contains(\" LOGOUT\")) {\n                        writer.write(\"* BYE IMAP test server logging out\\r\\n\");\n                        writer.write(tag + \" OK LOGOUT completed\\r\\n\");\n                        writer.flush();\n                        return;\n                    } else {\n                        throw new IOException(\"Unexpected IMAP command: \" + command);\n                    }\n                    writer.flush();\n                }\n            }\n        }\n    }\n}\n"}
