mmandMap, \\\"multipart/mixed\\\", \\\"com.sun.mail.handlers.multipart_mixed\\\");\\n        assertHandlerType(commandMap, \\\"text/html\\\", \\\"com.sun.mail.handlers.text_html\\\");\\n        assertHandlerType(commandMap, \\\"text/plain\\\", \\\"com.sun.mail.handlers.text_plain\\\");\\n        assertHandlerType(commandMap, \\\"text/xml\\\", \\\"com.sun.mail.handlers.text_xml\\\");\\n    }\\n\\n    @Test\\n    void mimeUtilityLoadsCharsetMappings() {\\n        assertThat(MimeUtility.javaCharset(\\\"iso-2022-jp\\\")).isEqualTo(\\\"iso-2022-jp\\\");\\n        assertThat(MimeUtility.mimeCharset(\\\"EUC_JP\\\")).isEqualTo(\\\"euc-jp\\\");\\n    }\\n\\n    private static void assertHandlerType(MailcapCommandMap commandMap, String mimeType, String expectedClassName) {\\n        DataContentHandler handler = commandMap.createDataContentHandler(mimeType);\\n\\n        assertThat(handler).isNotNull();\\n        assertThat(handler.getClass().getName()).isEqualTo(expectedClassName);\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777941205179}, {\"role\": \"toolResult\", \"toolCallId\": \"call_m2Sl7FeTykJkzfRTvmpSU0U5|fc_0123bbe42a063d0e0169f93ad4f248819598dd2e02b2ddacb0\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage javax_mail.mail;\\n\\nimport org.junit.jupiter.api.Test;\\n\\npublic class MailTest {\\n    @Test\\n    void test() throws Exception {\\n        System.out.println(\\\"This is just a placeholder, implement your test\\\");\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777941205179}, {\"role\": \"toolResult\", \"toolCallId\": \"call_RNpJ4HeR37lvsdP13U66zk8N|fc_0123bbe42a063d0e0169f93ad4f2508195a72f46938987eca3\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage javax_mail.mail;\\n\\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\\n\\nimport java.util.Properties;\\nimport javax.mail.Address;\\nimport javax.mail.Message;\\nimport javax.mail.MessagingException;\\nimport javax.mail.Provider;\\nimport javax.mail.Session;\\nimport javax.mail.Transport;\\nimport javax.mail.URLName;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class SessionTest {\\n    @Test\\n    void getTransportLoadsProviderWithSessionClassLoaderWhenContextClassLoaderCannotFindIt() throws Exception {\\n        Session session = Session.getInstance(new Properties());\\n        Provider provider = provider(\\\"session-loader\\\");\\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\\n        Thread.currentThread().setContextClassLoader(new MissingProviderClassLoader());\\n        try {\\n            Transport transport = session.getTransport(provider);\\n\\n            assertInstanceOf(TestTransport.class, transport);\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void getTransportFallsBackToClassForNameWhenContextClassLoaderFailsUnexpectedly() throws Exception {\\n        Session session = Session.getInstance(new Properties());\\n        Provider provider = provider(\\\"class-for-name\\\");\\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\\n        Thread.currentThread().setContextClassLoader(new FailingProviderClassLoader(originalContextClassLoader));\\n        try {\\n            Transport transport = session.getTransport(provider);\\n\\n            assertInstanceOf(TestTransport.class, transport);\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n        }\\n    }\\n\\n    private static Provider provider(String protocol) {\\n        return new Provider(Provider.Type.TRANSPORT, protocol, TestTransport.class.getName(), \\\"test\\\", null);\\n    }\\n\\n    public static class TestTransport extends Transport {\\n        public TestTransport(Session session, URLName urlName) {\\n            super(session, urlName);\\n        }\\n\\n        @Override\\n        public void sendMessage(Message message, Address[] addresses) throws MessagingException {\\n            if (!isConnected()) {\\n                throw new MessagingException(\\\"Transport is not connected\\\");\\n            }\\n        }\\n    }\\n\\n    private static final class MissingProviderClassLoader extends ClassLoader {\\n        MissingProviderClassLoader() {\\n            super(null);\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\\n            throw new ClassNotFoundException(name);\\n        }\\n    }\\n\\n    private static final class FailingProviderClassLoader extends ClassLoader {\\n        FailingProviderClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\\n            if (TestTransport.class.getName().equals(name)) {\\n                throw new IllegalStateException(\\\"Deliberate provider loading failure\\\");\\n            }\\n            return super.loadClass(name);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777941205180}, {\"role\": \"toolResult\", \"toolCallId\": \"call_NCbz2AHx9SAos25v9EvVxqzg|fc_0123bbe42a063d0e0169f93ad4f25481959088b7c302548d35\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this