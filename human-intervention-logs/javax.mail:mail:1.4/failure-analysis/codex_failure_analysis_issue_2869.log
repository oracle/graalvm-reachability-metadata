ader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\\n        Thread.currentThread().setContextClassLoader(new MissingProviderClassLoader());\\n        try {\\n            Transport transport = session.getTransport(provider);\\n\\n            assertInstanceOf(TestTransport.class, transport);\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void getTransportFallsBackToClassForNameWhenContextClassLoaderFailsUnexpectedly() throws Exception {\\n        Session session = Session.getInstance(new Properties());\\n        Provider provider = provider(\\\"class-for-name\\\");\\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\\n        Thread.currentThread().setContextClassLoader(new FailingProviderClassLoader(originalContextClassLoader));\\n        try {\\n            Transport transport = session.getTransport(provider);\\n\\n            assertInstanceOf(TestTransport.class, transport);\\n        } finally {\\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\\n        }\\n    }\\n\\n    private static Provider provider(String protocol) {\\n        return new Provider(Provider.Type.TRANSPORT, protocol, TestTransport.class.getName(), \\\"test\\\", null);\\n    }\\n\\n    public static class TestTransport extends Transport {\\n        public TestTransport(Session session, URLName urlName) {\\n            super(session, urlName);\\n        }\\n\\n        @Override\\n        public void sendMessage(Message message, Address[] addresses) throws MessagingException {\\n            if (!isConnected()) {\\n                throw new MessagingException(\\\"Transport is not connected\\\");\\n            }\\n        }\\n    }\\n\\n    private static final class MissingProviderClassLoader extends ClassLoader {\\n        MissingProviderClassLoader() {\\n            super(null);