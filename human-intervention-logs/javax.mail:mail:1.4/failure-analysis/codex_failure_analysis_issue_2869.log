il.internet.MimeUtility;\\n\\nimport org.junit.jupiter.api.Test;\\n\\npublic class JavaxMailTest {\\n\\n    @Test\\n    void getTransportLoadsBuiltInDefaultProviderAndAddressMap() throws Exception {\\n        Session session = Session.getInstance(new Properties());\\n\\n        Transport transport = session.getTransport(new InternetAddress(\\\"native-image@example.test\\\"));\\n\\n        assertThat(session.getProvider(\\\"smtp\\\").getClassName()).isEqualTo(\\\"com.sun.mail.smtp.SMTPTransport\\\");\\n        assertThat(transport.getClass().getName()).isEqualTo(\\\"com.sun.mail.smtp.SMTPTransport\\\");\\n    }\\n\\n    @Test\\n    void mailcapCommandMapLoadsBuiltInMailHandlers() {\\n        MailcapCommandMap commandMap = new MailcapCommandMap();\\n\\n        assertHandlerType(commandMap, \\\"message/rfc822\\\", \\\"com.sun.mail.handlers.message_rfc822\\\");\\n        assertHandlerType(commandMap, \\\"multipart/mixed\\\", \\\"com.sun.mail.handlers.multipart_mixed\\\");\\n        assertHandlerType(commandMap, \\\"text/html\\\", \\\"com.sun.mail.handlers.text_html\\\");\\n        assertHandlerType(commandMap, \\\"text/plain\\\", \\\"com.sun.mail.handlers.text_plain\\\");\\n        assertHandlerType(commandMap, \\\"text/xml\\\", \\\"com.sun.mail.handlers.text_xml\\\");\\n    }\\n\\n    @Test\\n    void mimeUtilityLoadsCharsetMappings() {\\n        assertThat(MimeUtility.javaCharset(\\\"iso-2022-jp\\\")).isEqualTo(\\\"iso-2022-jp\\\");\\n        assertThat(MimeUtility.mimeCharset(\\\"EUC_JP\\\")).isEqualTo(\\\"euc-jp\\\");\\n    }\\n\\n    private static void assertHandlerType(MailcapCommandMap commandMap, String mimeType, String expectedClassName) {\\n        DataContentHandler handler = commandMap.createDataContentHandler(mimeType);\\n\\n        assertThat(handler).isNotNull();\\n        assertThat(handler.getClass().getName()).isEqualTo(expectedClassName);\\n    }\\n}\\n\\n---\\n/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a c