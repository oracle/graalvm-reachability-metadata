);\\n\\n            assertThat(transport).isInstanceOf(SMTPTransport.class);\\n            assertThat(transport.getURLName().getProtocol()).isEqualTo(provider.getProtocol());\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void getTransportFallsBackToSessionClassLoaderWhenContextClassLoaderCannotLoadProvider() throws Exception {\\n        Session session = Session.getInstance(new Properties());\\n        Provider provider = provider(\\\"session-loader\\\");\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        ClassLoader contextClassLoader = new MissingProviderClassLoader(\\n                originalClassLoader, SMTPTransport.class.getName());\\n\\n        currentThread.setContextClassLoader(contextClassLoader);\\n        try {\\n            Transport transport = session.getTransport(provider);\\n\\n            assertThat(transport).isInstanceOf(SMTPTransport.class);\\n            assertThat(transport.getURLName().getProtocol()).isEqualTo(provider.getProtocol());\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    @Test\\n    void getTransportFallsBackToClassForNameWhenContextClassLoaderFails() throws Exception {\\n        Session session = Session.getInstance(new Properties());\\n        Provider provider = provider(\\\"system-loader\\\");\\n        Thread currentThread = Thread.currentThread();\\n        ClassLoader originalClassLoader = currentThread.getContextClassLoader();\\n        ClassLoader contextClassLoader = new FailingProviderClassLoader(\\n                originalClassLoader, SMTPTransport.class.getName());\\n\\n        currentThread.setContextClassLoader(contextClassLoader);\\n        try {\\n            Transport transport = session.getTransport(provider);\\n\\n            assertThat(transport).isInstanceOf(SMTPTransport.class);\\n            assertThat(transport.getURLName().getProtocol()).isEqualTo(provider.getProtocol());\\n        } finally {\\n            currentThread.setContextClassLoader(originalClassLoader);\\n        }\\n    }\\n\\n    private static Provider provider(String protocol) {\\n        return new Provider(Provider.Type.TRANSPORT, protocol, SMTPTransport.class.getName(), VENDOR, VERSION);\\n    }\\n\\n    private static final class DelegatingProviderClassLoader extends ClassLoader {\\n        private DelegatingProviderClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n    }\\n\\n    private static final class MissingProviderClassLoader extends ClassLoader {\\n        private final String providerClassName;\\n\\n        private MissingProviderClassLoader(ClassLoader parent, String providerClassName) {\\n            super(parent);\\n            this.providerClassName = providerClassName;\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\\n            if (providerClassName.equals(name)) {\\n                throw new ClassNotFoundException(name);\\n            }\\n            return super.loadClass(name);\\n        }\\n    }\\n\\n    private static final class FailingProviderClassLoader extends ClassLoader {\\n        private final String providerClassName;\\n\\n        private FailingProviderClassLoader(ClassLoader parent, String providerClassName) {\\n            super(parent);\\n            this.providerClassName = providerClassName;\\n        }\\n\\n        @Override\\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\\n            if (providerClassName.equals(name)) {\\n                throw new SecurityException(\\\"provider class is hidden from the context class loader\\\");\\n            }\\n            return super.loadClass(name);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777828914146}}\n3171