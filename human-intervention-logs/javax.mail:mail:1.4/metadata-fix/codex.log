{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/JavaxMailTest.java; printf '\\\\n---\\\\n'; sed -n '1,220p' tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/SessionTest.java; printf '\\\\n---\\\\n'; sed -n '1,220p' tests/src/javax.mail/mail/1.4/src/test/java/javax_mail/mail/MailTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Properties;\n\nimport javax.activation.DataContentHandler;\nimport javax.activation.MailcapCommandMap;\nimport javax.mail.Session;\nimport javax.mail.Transport;\nimport javax.mail.internet.InternetAddress;\nimport javax.mail.internet.MimeUtility;\n\nimport org.junit.jupiter.api.Test;\n\npublic class JavaxMailTest {\n\n    @Test\n    void getTransportLoadsBuiltInDefaultProviderAndAddressMap() throws Exception {\n        Session session = Session.getInstance(new Properties());\n\n        Transport transport = session.getTransport(new InternetAddress(\"native-image@example.test\"));\n\n        assertThat(session.getProvider(\"smtp\").getClassName()).isEqualTo(\"com.sun.mail.smtp.SMTPTransport\");\n        assertThat(transport.getClass().getName()).isEqualTo(\"com.sun.mail.smtp.SMTPTransport\");\n    }\n\n    @Test\n    void mailcapCommandMapLoadsBuiltInMailHandlers() {\n        MailcapCommandMap commandMap = new MailcapCommandMap();\n\n        assertHandlerType(commandMap, \"message/rfc822\", \"com.sun.mail.handlers.message_rfc822\");\n        assertHandlerType(commandMap, \"multipart/mixed\", \"com.sun.mail.handlers.multipart_mixed\");\n        assertHandlerType(commandMap, \"text/html\", \"com.sun.mail.handlers.text_html\");\n        assertHandlerType(commandMap, \"text/plain\", \"com.sun.mail.handlers.text_plain\");\n        assertHandlerType(commandMap, \"text/xml\", \"com.sun.mail.handlers.text_xml\");\n    }\n\n    @Test\n    void mimeUtilityLoadsCharsetMappings() {\n        assertThat(MimeUtility.javaCharset(\"iso-2022-jp\")).isEqualTo(\"iso-2022-jp\");\n        assertThat(MimeUtility.mimeCharset(\"EUC_JP\")).isEqualTo(\"euc-jp\");\n    }\n\n    private static void assertHandlerType(MailcapCommandMap commandMap, String mimeType, String expectedClassName) {\n        DataContentHandler handler = commandMap.createDataContentHandler(mimeType);\n\n        assertThat(handler).isNotNull();\n        assertThat(handler.getClass().getName()).isEqualTo(expectedClassName);\n    }\n}\n\n---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\n\nimport java.util.Properties;\nimport javax.mail.Address;\nimport javax.mail.Message;\nimport javax.mail.MessagingException;\nimport javax.mail.Provider;\nimport javax.mail.Session;\nimport javax.mail.Transport;\nimport javax.mail.URLName;\nimport org.junit.jupiter.api.Test;\n\npublic class SessionTest {\n    @Test\n    void getTransportLoadsProviderWithSessionClassLoaderWhenContextClassLoaderCannotFindIt() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        Provider provider = provider(\"session-loader\");\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(new MissingProviderClassLoader());\n        try {\n            Transport transport = session.getTransport(provider);\n\n            assertInstanceOf(TestTransport.class, transport);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void getTransportFallsBackToClassForNameWhenContextClassLoaderFailsUnexpectedly() throws Exception {\n        Session session = Session.getInstance(new Properties());\n        Provider provider = provider(\"class-for-name\");\n        ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(new FailingProviderClassLoader(originalContextClassLoader));\n        try {\n            Transport transport = session.getTransport(provider);\n\n            assertInstanceOf(TestTransport.class, transport);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static Provider provider(String protocol) {\n        return new Provider(Provider.Type.TRANSPORT, protocol, TestTransport.class.getName(), \"test\", null);\n    }\n\n    public static class TestTransport extends Transport {\n        public TestTransport(Session session, URLName urlName) {\n            super(session, urlName);\n        }\n\n        @Override\n        public void sendMessage(Message message, Address[] addresses) throws MessagingException {\n            if (!isConnected()) {\n                throw new MessagingException(\"Transport is not connected\");\n            }\n        }\n    }\n\n    private static final class MissingProviderClassLoader extends ClassLoader {\n        MissingProviderClassLoader() {\n            super(null);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            throw new ClassNotFoundException(name);\n        }\n    }\n\n    private static final class FailingProviderClassLoader extends ClassLoader {\n        FailingProviderClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (TestTransport.class.getName().equals(name)) {\n                throw new IllegalStateException(\"Deliberate provider loading failure\");\n            }\n            return super.loadClass(name);\n        }\n    }\n}\n\n---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage javax_mail.mail;\n\nimport org.junit.jupiter.api.Test;\n\npublic class MailTest {\n    @Test\n    void test() throws Exception {\n        System.out.println(\"This is just a placeholder, implement your test\");\n    }\n}\n","exit_code":0,"status":"completed"}}
