th).isGreaterThan(0)\\n      assertThat(copy).isEqualTo(payload)\\n    }\\n  }\\n\\n  private def withActorSystem(name: String, config: Config)(test: ActorSystem => Unit): Unit = {\\n    val system: ActorSystem = ActorSystem(name, config)\\n    try {\\n      test(system)\\n    } finally {\\n      Await.result(system.terminate(), 10.seconds)\\n    }\\n  }\\n}\\n\\nfinal case class ManifestlessPayload(name: String, revision: Int, tags: Vector[String], description: String)\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_9\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,240p' metadata/com.typesafe.akka/akka-serialization-jackson_2.13/2.6.21/reachability-metadata.json\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_9\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,240p' metadata/com.typesafe.akka/akka-serialization-jackson_2.13/2.6.21/reachability-metadata.json\\\"\",\"aggregated_output\":\"{}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_10\",\"type\":\"agent_message\",\"text\":\"The current library metadata file is empty, so this is likely a straight reachability gap rather than a bad existing entry. I’m waiting for the native test to emit the first concrete missing registration and then I’ll patch that JSON with the narrowest condition that matches the Akka stack.\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_3\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc './gradlew test -Pcoordinates=com.typesafe.akka:akka-serialization-jackson_2.13:2.6.21 --stacktrace'\",\"aggregated_output\":\"> Task :tck-build-logic:extractPluginRequests UP-TO-DATE\\n> Task :tck-build-logic:generatePluginAdapters UP-TO-DATE\\n> Task :tck-build-logic:compileJava UP-TO-DATE\\n> Task :tck-build-logic:compileGroovy UP