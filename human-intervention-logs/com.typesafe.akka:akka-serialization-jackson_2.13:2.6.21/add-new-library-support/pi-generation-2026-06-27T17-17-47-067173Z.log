lizer.isInstanceOf[JacksonJsonSerializer])\n\n      val bytes: Array[Byte] = serialization.serialize(command).get\n      val manifest: String = Serializers.manifestFor(serializer, command)\n      val decoded: StartCommand =\n        serialization.deserialize(bytes, serializer.identifier, manifest).get.asInstanceOf[StartCommand]\n      assertEquals(\"indexing\", decoded.name)\n      assertEquals(3, decoded.priority)\n    }\n  }\n\n  @Test\n  def objectMapperProviderCreatesCachedMappersForConfiguredBindings(): Unit = {\n    withActorSystem(\"AkkaJacksonObjectMapperProviderTest\") { system =>\n      val provider: JacksonObjectMapperProvider = JacksonObjectMapperProvider(system)\n      val firstMapper: ObjectMapper = provider.getOrCreate(\"jackson-json\", None)\n      val secondMapper: ObjectMapper = provider.getOrCreate(\"jackson-json\", None)\n      val message: JsonMessage = new JsonMessage(\"mapper-message\", 7)\n\n      assertSame(firstMapper, secondMapper)\n\n      val json: String = firstMapper.writeValueAsString(message)\n      assertTrue(json.contains(\"mapper-message\"))\n\n      val decoded: JsonMessage = firstMapper.readValue(json, classOf[JsonMessage])\n      assertEquals(message.id, decoded.id)\n      assertEquals(message.count, decoded.count)\n    }\n  }\n\n  private def withActorSystem(name: String)(testBody: ActorSystem => Unit): Unit = {\n    val system: ActorSystem = ActorSystem(name, serializationConfig)\n    try {\n      testBody(system)\n    } finally {\n      Await.result(system.terminate(), TestTimeout)\n    }\n  }\n}\n\nobject Akka_serialization_jackson_2_13Test {\n  private val TestTimeout = 10.seconds\n\n  private val serializationConfig: Config = ConfigFactory.parseString(\n    s\"\"\"\n       |akka {\n       |  loglevel = \"WARNING\"\n       |  stdout-loglevel = \"OFF\"\n       |  actor {\n       |    default-dispatcher.shutdown-timeout = 10s\n       |    serializers {\n       |      jackson-json = \"akka.serialization.jackson.JacksonJsonSerializer\"\n       |      jackson-cbor = \"akka.serialization.jackson.JacksonCborSerializer\"\n       |    }\n       |    serialization-bindings {\n       |      \"${classOf[JsonMessage].getName}\" = jackson-json\n       |      \"${classOf[CborMessage].getName}\" = jackson-cbor\n       |      \"${classOf[Command].getName}\" = jackson-json\n       |    }\n       |  }\n       |}\n       |\"\"\".stripMargin\n  )\n}\n\nfinal class JsonMessage() {\n  @BeanProperty var id: String = _\n  @BeanProperty var count: Int = 0\n\n  def this(id: String, count: Int) = {\n    this()\n    this.id = id\n    this.count = count\n  }\n}\n\nfinal class CborMessage() {\n  @BeanProperty var name: String = _\n  @BeanProperty var enabled: Boolean = false\n\n  def this(name: String, enabled: Boolean) = {\n    this()\n    this.name = name\n    this.enabled = enabled\n  }\n}\n\ntrait Command\n\nfinal class StartCommand() extends Command {\n  @BeanProperty var name: String = _\n  @BeanProperty var priority: Int = 0\n\n  @JsonCreator\n  def this(\n    @JsonProperty(\"name\") name: String,\n    @JsonProperty(\"priority\") priority: Int\n  ) = {\n    this()\n    this.name = name\n    this.priority = priority\n  }\n}\n"}
[recv] {"type": "message_end", "message": {"role": "assistant", "content": [{"type": "thinking", "thinking": "**Resolving Scala Class Issues**\n\nI’m thinking about Scala and how it resolves classes using `classOf` for classes in the same file package. But what happens if an object gets initialized before the classes? It seems `classOf` as a static constant should be fine. However, there could be a potential issue with the HOCON path if class names are used as keys in a string, especially if they need to be quoted. I need to consider this carefully!", "thinkingSignature": "{\"id\":\"rs_01590e008a41ab7b016a40056cb164819095565c9e60032af9\",\"type\":\"reasoning\",\"content\":[],\"encrypted_content\":\"gAAAAABqQAWQotTyo5jzhvn6fmc3GJ1y-MadlV1JjGmSL472X1B47G3OJ9Rh83AO0ALM6fAv5SNuiFPKsigvNCvHmd0ssP9j6fyuNGLIFX_Ldbch6-xft2nLK2ggds7GD-yKZQriNB46hbIkzgqU3e06KVk5GD9XhNtIrR7jMOzu_UXYkERBKrcj0AHP69Gz1TQg8zgAQtEWXUo3bvZWAl20Y_k8Yt6KihmMjJA7exxjfRH76-Noml8fqi3befu4MYsbiqv9XXAJA5RuMNfr_YX-VSfGvdJVH1JPN_cTIN0yNUopSGLgB3JecSZl86PFveyF96YtYivNU1k3KM2bg7oTb-HpAttDG5Dv0GLHCFcXKEY2BxNrGs4aKxxe4SHY6xYGXhAKl4VVReffG2Snt5H_eSJ4yBaQGd1okEMHi4Zs8jGld3aRwv2mvQjRS8zUHzmoPpmO7Msiyy4yLqvrgG8OKTDdQ5K4_fM5qb_62RFE4UpVHlaI1PNjTla0NaXNYZHVNxwoUO9_NcAJmsJkWrpvnZOyS5Z5CGU_Mu7sdbWCYOMdWFY2QIO4wNVbqIEu_fwei9obhOzhBG0UJ0s127qOqlKD-EtCsLGeWzH6uz75NpS382QxujaVbCMfBuBRVvryE8uuj_rKlcG54HDNFkFPzWkHP7KvPNc1HxfhWxwyQA-_JlzVyiSYx_LLq2lX4ubd-nniw1sunbXbYApmdJDp_5BMnGtzdAZC3GqilBJD4aGiCIEgZrbOqMEjLwpOfzRqkNaiNzI6i6Q3g1MJ9z_nxa1R6O1xhhnaqBaAKgZhckpw0UEcAczemZSzGsPy-Ldt3xSiWAZYVaP2a4BNkqfXZVWZDIEMtU33oP1bZDYuPyl48x8LjktLeqKOQLJbhYG-rJwwZmkvjABJj6wT3il9Y8qWFWkT8ZWiewRBcFgXWvREd7zwDvk7Z7NaQoBE7FOcdNUsPcr7QPPERBdMSIg6DZiGQGsJMuBSxmvRxj2f5lP-e6woYX8cJnnIpP_suKroem8VCWhNSdb4Kux1OrueHrUgtO4DWa7Pdu-HTTlil8Omf2CTE5wrFEQpLIc6R6_jYUuW39wHIHjeitze8skP8-Ly-qzaSFSo6ZRz37lxOTWEb66DZakdJZQ5S5FgYBRjBAtQNfIzOFFMpD5YIzEEo3jAa1qzUwrINSkdlawVmNUg16kyyHoJHPNWrpyEVShgg8xgDM0eyDYIDbXuBzUbAkUa-M7Il_jpaSSL_3G7FqEe1UBeN2_ZqYBfcSIXxnuz13xwbICZ