d]).get).isEqualTo(payload)\n    }\n  }\n\n  @Test\n  def actorRefModuleSerializesResolvableClassicActorReferences(): Unit = {\n    val config: Config = configWithBindings(Map(classOf[ActorRefPayload] -> \"jackson-json\"))\n\n    withActorSystem(\"JacksonActorRefRoundTrip\", config) { system =>\n      val payload: ActorRefPayload = ActorRefPayload(\"deadLetters\", system.deadLetters)\n      val serialization = SerializationExtension(system)\n      val serializer = serialization.serializerFor(classOf[ActorRefPayload]).asInstanceOf[JacksonSerializer]\n      val bytes: Array[Byte] = serializer.toBinary(payload)\n      val json: String = new String(bytes, StandardCharsets.UTF_8)\n      val copy = serializer.fromBinary(bytes, serializer.manifest(payload)).asInstanceOf[ActorRefPayload]\n\n      assertThat(json).contains(\"akka://JacksonActorRefRoundTrip/deadLetters\")\n      assertThat(copy.name).isEqualTo(payload.name)\n      assertThat(copy.ref).isEqualTo(system.deadLetters)\n    }\n  }\n\n  @Test\n  def objectMapperProviderAppliesConfiguredModulesAndFeatures(): Unit = {\n    val config: Config = configWithBindings(\n      Map.empty,\n      \"\"\"\n        akka.serialization.jackson.jackson-json.serialization-features {\n          INDENT_OUTPUT = on\n        }\n        \"\"\"\n    )\n\n    withActorSystem(\"JacksonObjectMapperProvider\", config) { system =>\n      val provider = JacksonObjectMapperProvider.get(system)\n      val mapper = provider.getOrCreate(\"jackson-json\", Optional.empty())\n      val sameMapper = provider.getOrCreate(\"jackson-json\", Optional.empty())\n      val payload: MapperPayload = MapperPayload(\n        id = \"mapper-1\",\n        created = Instant.parse(\"2023-01-02T03:04:05Z\"),\n        timeout = 2.seconds,\n        address = Address(\"akka\", system.name, \"127.0.0.1\", 2554),\n        maybe = Some(\"configured\")\n      )\n\n      val json: String = mapper.writeValueAsString(payload)\n      val copy: MapperPayload = mapper.readValue(json, classOf[MapperPayload])\n\n      assertThat(sameMapper).isSameAs(mapper)\n      assertThat(json).contains(System.lineSeparator())\n      assertThat(json).contains(\"2023-01-02T03:04:05Z\")\n      assertThat(copy).isEqualTo(payload)\n    }\n  }\n\n  @Test\n  def migrationTransformsLegacyJsonAndClassName(): Unit = {\n    val legacyClassName: String = \"com.example.LegacyPayload\"\n    val config: Config = configWithBindings(\n      Map(classOf[RenamedPayload] -> \"jackson-json\"),\n      s\"\"\"\n        akka.serialization.jackson.allowed-class-prefix += \"com.example.\"\n        akka.serialization.jackson.migrations {\n          \"$legacyClassName\" = \"${classOf[LegacyPayloadMigration].getName}\"\n        }\n        \"\"\"\n    )\n\n    withActorSystem(\"JacksonMigration\", config) { system =>\n      val serialization = SerializationExtension(system)\n      val serializer = serialization.serializerFor(classOf[RenamedPayload]).asInstanceOf[JacksonSerializer]\n      val legacyJson: Array[Byte] = \"\"\"{\"name\":\"legacy-name\",\"revision\":7}\"\"\".getBytes(StandardCharsets.UTF_8)\n      val migrated = serializer.fromBinary(legacyJson, s\"$legacyClassName#1\").asInstanceOf[RenamedPayload]\n\n      assertThat(migrated).isEqualTo(RenamedPayload(\"legacy-name\", 7))\n      assertThat(serializer.manifest(RenamedPayload(\"current\", 8))).isEqualTo(classOf[RenamedPayload].getName)\n    }\n  }\n\n  private def configWithBindings(bindings: Map[Class[_], String], extraConfig: String = \"\"): Config = {\n    val bindingConfig: String = bindings\n      .map { case (clazz, serializerName) => s\"\\\"${clazz.getName}\\\" = $serializerName\" }\n      .mkString(System.lineSeparator())\n\n    ConfigFactory.parseString(\n      s\"\"\"\n        akka.loglevel = \"WARNING\"\n        akka.actor.allow-java-serialization = off\n        akka.actor.serializers {\n          jackson-json = \"akka.serialization.jackson.JacksonJsonSerializer\"\n          jackson-cbor = \"akka.serialization.jackson.JacksonCborSerializer\"\n        }\n        akka.actor.serialization-bindings {\n          $bindingConfig\n        }\n        $extraConfig\n        \"\"\"\n    ).withFallback(ConfigFactory.load())\n  }\n\n  private def withActorSystem(name: String, config: Config)(test: ActorSystem => Unit): Unit = {\n    val system: ActorSystem = ActorSystem(name, config)\n    try {\n      test(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n\nfinal case class JsonPayload(\n    id: String,\n    count: Int,\n    created: Instant,\n    maybe: Option[String],\n    javaMaybe: Optional[Integer],\n    timeout: FiniteDuration,\n    address: Address,\n    description: String)\n\nfinal case class CborPayload(id: String, values: Vector[Int], address: Address, nested: NestedPayload)\n\nfinal case class NestedPayload(label: String, enabled: Boolean)\n\nfinal case class ActorRefPayload(name: String, ref: ActorRef)\n\nfinal case class MapperPayload(\n    id: String,\n    created: Instant,\n    timeout: FiniteDuration,\n    address: Address,\n    maybe: Option[String])\n\nfinal case class RenamedPayload(text: String, revision: Int)\n\nfinal class LegacyPayloadMigration extends JacksonMigration {\n  override def currentVersion(): Int = 2\n\n  override def transformClassName(fromVersion: Int, className: String): String = classOf[RenamedPayload].getName\n\n  override def transform(fromVersion: Int, json: JsonNode): JsonNode = {\n    val objectNode: ObjectNode = json.asInstanceOf[ObjectNode]\n    objectNode.set[JsonNode](\"text\", objectNode.get(\"name\"))\n    objectNode.remove(\"name\")\n    objectNode\n  }\n}\n"}], "isError": false, "timestamp": 1778061080080}}
