n findResources(name: String): Enumeration<URL> {\\n            val urls: List<URL> = resourceUrl(name)?.let { listOf(it) } ?: emptyList()\\n            return Collections.enumeration(urls)\\n        }\\n\\n        private fun resourceUrl(name: String): URL? {\\n            if (name.isEmpty()) {\\n                return root.toUri().toURL()\\n            }\\n\\n            val candidate: NioPath = root.resolve(name)\\n            return if (Files.exists(candidate)) candidate.toUri().toURL() else null\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_78\",\"type\":\"agent_message\",\"text\":\"The checked-in `3.0.0` metadata only covers `ByteString` serialization, while the `3.6.0` tests add `ResourceFileSystem` behavior. I’m running the `3.6.0` project’s native path directly now, outside the root `generateMetadata` wrapper, to capture the actual missing entry.\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_79\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'export JAVA_HOME=/home/vjovanov/Downloads/graalvm-jdk-21.0.10+8.1\\nexport GRAALVM_HOME=/home/vjovanov/Downloads/graalvm-jdk-21.0.10+8.1\\nexport PATH=\\\"$JAVA_HOME/bin:$PATH\\\"\\nexport LD_LIBRARY_PATH=\\\"$JAVA_HOME/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}\\\"\\ncd tests/src/com.squareup.okio/okio-jvm/3.6.0\\n../../../../gradlew --no-daemon nativeTest --stacktrace'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_79\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'export JAVA_HOME=/home/vjovanov/Downloads/graalvm-jdk-21.0.10+8.1\\nexport GRAALVM_HOME=/home/vjovanov/Downloads/graalvm-jdk-21.0.10+8.1\\nexport PATH=\\\"$JAVA_HOME/bin:$PATH\\\"\\nexport LD_LIBRARY_PATH=\\\"$JAVA_HOME/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}\\\"\\ncd tests/src/com.squareup.okio/okio-jvm/3.6.0\\n../../../../gradlew --no-daemon nativeTe