{"type":"item.started","item":{"id":"item_57","type":"command_execution","command":"/usr/bin/bash -lc \"python - <<'PY'\nimport json\nfrom pathlib import Path\nfrom collections import defaultdict\ncur = json.load(open('metadata/org.springframework.boot/spring-boot-test-autoconfigure/2.7.18/reachability-metadata.json'))['reflection']\nruns = list(Path('tests/src/org.springframework.boot/spring-boot-test-autoconfigure/2.7.18/build/natively-collected/runs').glob('cycle-*/reachability-metadata.json'))\n\ndef norm_type(t):\n    if isinstance(t, str):\n        return ('type', t)\n    if isinstance(t, dict) and 'proxy' in t:\n        return ('proxy', tuple(t['proxy']))\n    return ('other', json.dumps(t, sort_keys=True))\n\ndef methods_set(ent):\n    return {(m['name'], tuple(m.get('parameterTypes', []))) for m in ent.get('methods', [])}\n\ncur_map = defaultdict(set)\nfor ent in cur:\n    key=(norm_type(ent['type']))\n    cur_map[key] |= methods_set(ent)\n\nmissing=[]\nseen=set()\nfor f in sorted(runs):\n    d=json.load(open(f))\n    for ent in d.get('reflection', []):\n        key=norm_type(ent['type'])\n        ms=methods_set(ent)\n        if key not in cur_map or (ms and not ms.issubset(cur_map[key])):\n            ident=(key, tuple(sorted(ms)))\n            if ident in seen: continue\n            seen.add(ident)\n            missing.append((str(f), ent))\nprint('type_coverage_missing_count', len(missing))\nif missing:\n    for src, ent in missing[:20]:\n        print(src)\n        print(json.dumps(ent, indent=2, sort_keys=True))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
