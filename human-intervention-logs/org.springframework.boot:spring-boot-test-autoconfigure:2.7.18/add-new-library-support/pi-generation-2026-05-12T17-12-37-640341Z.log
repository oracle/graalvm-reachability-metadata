  		}
  
  	}
  
  	@Configuration(proxyBeanMethods = false)
  	@ConditionalOnClass(Gson.class)
  	static class GsonJsonTestersConfiguration {
  
  		@Bean
  		@Scope("prototype")
  		@ConditionalOnBean(Gson.class)
  		FactoryBean<GsonTester<?>> gsonTesterFactoryBean(Gson gson) {
