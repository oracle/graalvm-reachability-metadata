                          // %x
                          // Log4j 1: "foo bar baz"
                          // Log4j 2: "[foo, bar, baz]"
                          // Use %ndc to get the Log4j 1 format
                          .replaceAll("%([-\\.\\d]*)x(?!\\w)", "%$1ndc")
  
