                          // %X
                          // Log4j 1: "{{foo,bar}{hoo,boo}}"
                          // Log4j 2: "{foo=bar,hoo=boo}"
                          // Use %properties to get the Log4j 1 format
                          .replaceAll("%([-\\.\\d]*)X(?!\\w)", "%$1properties"))
                  .withConfiguration(config)
                  .build());
      }
  }
