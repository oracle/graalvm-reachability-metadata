      protected void append(final LoggingEvent event) {
          // noop
      }
  
      @Override
      public void close() {
          // noop
      }
  
      /**
       * Does not do anything.
       */
      @Override
      public void doAppend(final LoggingEvent event) {
          // noop
      }
  
