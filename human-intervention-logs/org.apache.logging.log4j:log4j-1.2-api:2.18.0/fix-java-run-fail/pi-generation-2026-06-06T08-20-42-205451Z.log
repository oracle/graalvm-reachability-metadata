new Attribute(\"threshold\", \"WARN\"));\n\n        assertThat(appender.getTarget()).isEqualTo(ConsoleAppender.SYSTEM_ERR);\n        assertThat(appender.getFollow()).isTrue();\n        assertThat(appender.getThreshold()).isEqualTo(Level.WARN);\n        assertThat(mbean.getAttribute(\"target\")).isEqualTo(ConsoleAppender.SYSTEM_ERR);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2623, "output": 1212, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 22779, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780733997101, "responseId": "resp_0dee4eada56450c5016a23d83613dc819385605d851a412046"}}
