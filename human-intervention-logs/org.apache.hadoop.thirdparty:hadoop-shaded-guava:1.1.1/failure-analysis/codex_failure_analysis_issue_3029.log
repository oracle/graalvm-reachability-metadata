\\nimport java.io.ObjectOutputStream;\\n\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashBiMap;\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashMultimap;\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashMultiset;\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.ImmutableListMultimap;\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.Multiset;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class SerializationTest {\\n    @Test\\n    void hashBiMapRoundTripUsesSerializationMapHelpers() throws Exception {\\n        HashBiMap<String, Integer> original = HashBiMap.create();\\n        original.put(\\\"alpha\\\", 1);\\n        original.put(\\\"beta\\\", 2);\\n\\n        Object restored = roundTrip(original);\\n\\n        assertThat(restored).isEqualTo(original);\\n    }\\n\\n    @Test\\n    void hashMultisetRoundTripUsesSerializationMultisetHelpers() throws Exception {\\n        HashMultiset<String> original = HashMultiset.create();\\n        original.add(\\\"apple\\\", 3);\\n        original.add(\\\"orange\\\", 2);\\n\\n        @SuppressWarnings(\\\"unchecked\\\")\\n        Multiset<String> restored = (Multiset<String>) roundTrip(original);\\n\\n        assertThat(restored.count(\\\"apple\\\")).isEqualTo(3);\\n        assertThat(restored.count(\\\"orange\\\")).isEqualTo(2);\\n        assertThat(restored).isEqualTo(original);\\n    }\\n\\n    @Test\\n    void hashMultimapRoundTripUsesSerializationMultimapHelpers() throws Exception {\\n        HashMultimap<String, String> original = HashMultimap.create();\\n        original.put(\\\"letters\\\", \\\"a\\\");\\n        original.put(\\\"letters\\\", \\\"b\\\");\\n        original.put(\\\"numbers\\\", \\\"one\\\");\\n\\n        Object restored = roundTrip(original);\\n\\n        assertThat(restored).isEqualTo(original);\\n    }\\n\\n    @Test\\n    void immutableListMultimapRoundTripUsesSerializationFieldSetters() throws Exception {\\n        ImmutableListMultimap<String, String> original = ImmutableListMultimap.<String, String>builder()\\n                .put(\\\"letters\\\", \\\"a\\\")\\n                .put(\\\"letters\\\", \\\"b\\\")\\n                .put(\\\"numbers\\\", \\\"one\\\")\\n                .build();\\n\\n        Object restored = roundTrip(original);\\n\\n        assertThat(restored).isEqualTo(original);\\n    }\\n\\n    private static Object roundTrip(Object original) throws IOException, ClassNotFoundException {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\n            output.writeObject(original);\\n        }\\n\\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\\n            return input.readObject();\\n        }\\n    }\\n}\\n\"}\n[tool-call] end id=call_WdANUlIQjWOoF7ctTcEigPXA|fc_0121429b4e06cbf10169f6dbc2a03c819f95122c557ae14bbb name=write args={\"path\": \"tests/src/org.apache.hadoop.thirdparty/hadoop-shaded-guava/1.1.1/src/test/java/org_apache_hadoop_thirdparty/hadoop_shaded_guava/SerializationTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_hadoop_thirdparty.hadoop_shaded_guava;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.IOException;\\nimport java.io.ObjectInputStream;\\nimport java.io.ObjectOutputStream;\\n\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashBiMap;\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashMultimap;\\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashMultiset;\\nimport org.apache.hadoop.thirdparty.com.google.commo