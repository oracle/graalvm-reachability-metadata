ultimapRoundTripUsesSerializationMultimapHelpers() throws Exception {\\n        HashMultimap<String, String> original = HashMultimap.create();\\n        original.put(\\\"letters\\\", \\\"a\\\");\\n        original.put(\\\"letters\\\", \\\"b\\\");\\n        original.put(\\\"numbers\\\", \\\"one\\\");\\n\\n        Object restored = roundTrip(original);\\n\\n        assertThat(restored).isEqualTo(original);\\n    }\\n\\n    @Test\\n    void immutableListMultimapRoundTripUsesSerializationFieldSetters() throws Exception {\\n        ImmutableListMultimap<String, String> original = ImmutableListMultimap.<String, String>builder()\\n                .put(\\\"letters\\\", \\\"a\\\")\\n                .put(\\\"letters\\\", \\\"b\\\")\\n                .put(\\\"numbers\\\", \\\"one\\\")\\n                .build();\\n\\n        Object restored = roundTrip(original);\\n\\n        assertThat(restored).isEqualTo(original);\\n    }\\n\\n    private static Object roundTrip(Object original) throws IOException, ClassNotFoundException {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\n            output.writeObject(original);\\n        }\\n\\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\\n            return input.readObject();\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 698, \"output\": 1193, \"cacheRead\": 22016, \"cacheWrite\": 0, \"totalTokens\": 23907, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777785786547, \"responseId\": \"resp_0121429b4e06cbf10169f6dbbafd84819f8b2a3521a0f80956\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_WdANUlIQjWOoF7ctTcEigPXA|fc_0121429b4e06cbf10169f6dbc2a03c819f95122c557ae14bbb\", \"toolNam