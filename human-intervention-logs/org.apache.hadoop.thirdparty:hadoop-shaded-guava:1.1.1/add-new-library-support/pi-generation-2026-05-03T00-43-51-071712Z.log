  package org_apache_hadoop_thirdparty.hadoop_shaded_guava;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  
  import org.apache.hadoop.thirdparty.com.google.common.collect.ArrayListMultimap;
  import org.apache.hadoop.thirdparty.com.google.common.collect.ConcurrentHashMultiset;
  import org.apache.hadoop.thirdparty.com.google.common.collect.HashBiMap;
  import org.apache.hadoop.thirdparty.com.google.common.collect.HashMultiset;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SerializationTest {
      @Test
      void hashBiMapRoundTripUsesMapSerializationHelpers() throws Exception {
          HashBiMap<String, Integer> original = HashBiMap.create();
          original.put("alpha", 1);
          original.put("beta", 2);
  
          HashBiMap<String, Integer> copy = roundTrip(original);
  
          assertThat(copy).containsEntry("alpha", 1).containsEntry("beta", 2);
          assertThat(copy.inverse()).containsEntry(1, "alpha").containsEntry(2, "beta");
      }
  
      @Test
      void arrayListMultimapRoundTripUsesMultimapSerializationHelpers() throws Exception {
          ArrayListMultimap<String, String> original = ArrayListMultimap.create();
          original.put("colors", "red");
          original.put("colors", "blue");
          original.put("shapes", "circle");
  
          ArrayListMultimap<String, String> copy = roundTrip(original);
  
          assertThat(copy.get("colors")).containsExactly("red", "blue");
          assertThat(copy.get("shapes")).containsExactly("circle");
          assertThat(copy.asMap()).containsOnlyKeys("colors", "shapes");
      }
  
      @Test
      void hashMultisetRoundTripUsesMultisetSerializationHelpers() throws Exception {
          HashMultiset<String> original = HashMultiset.create();
          original.add("alpha", 3);
          original.add("beta", 2);
  
          HashMultiset<String> copy = roundTrip(original);
  
          assertThat(copy.count("alpha")).isEqualTo(3);
          assertThat(copy.count("beta")).isEqualTo(2);
          assertThat(copy.elementSet()).containsExactlyInAnyOrder("alpha", "beta");
      }
  
      @Test
      void concurrentHashMultisetRoundTripUsesFieldSetterForBackingMap() throws Exception {
          ConcurrentHashMultiset<String> original = ConcurrentHashMultiset.create();
          original.add("alpha", 3);
          original.add("beta", 2);
  
          ConcurrentHashMultiset<String> copy = roundTrip(original);
  
          assertThat(copy.count("alpha")).isEqualTo(3);
          assertThat(copy.count("beta")).isEqualTo(2);
          assertThat(copy.elementSet()).containsExactlyInAnyOrder("alpha", "beta");
      }
  
      private static <T extends Serializable> T roundTrip(T original) throws IOException, ClassNotFoundException {
          byte[] serialized = serialize(original);
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              @SuppressWarnings("unchecked")
              T copy = (T) input.readObject();
              return copy;
          }
      }
  
      private static byte[] serialize(Serializable value) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  }
