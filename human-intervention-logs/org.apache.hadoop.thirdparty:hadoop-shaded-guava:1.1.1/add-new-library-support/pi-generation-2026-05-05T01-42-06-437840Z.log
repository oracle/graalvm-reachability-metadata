[tool-call] delta {"path":"tests/src/org.apache.hadoop.thirdparty/hadoop-shaded-guava/1.1.1/src/test/java/org_apache_hadoop_thirdparty/hadoop_shaded_guava/SerializationTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop_thirdparty.hadoop_shaded_guava;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.List;\n\nimport org.apache.hadoop.thirdparty.com.google.common.collect.ArrayListMultimap;\nimport org.apache.hadoop.thirdparty.com.google.common.collect.BiMap;\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashBiMap;\nimport org.apache.hadoop.thirdparty.com.google.common.collect.HashMultiset;\nimport org.apache.hadoop.thirdparty.com.google.common.collect.ImmutableListMultimap;\nimport org.apache.hadoop.thirdparty.com.google.common.collect.Multiset;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\npublic class SerializationTest {\n    @Test\n    void serializesAndRestoresMapEntries() throws Exception {\n        HashBiMap<String, String> map = HashBiMap.create();\n        map.put(\"primary\", \"alpha\");\n        map.put(\"secondary\", \"beta\");\n\n        BiMap<String, String> copy = roundTrip(map);\n\n        assertEquals(map, copy);\n        assertEquals(\"primary\", copy.inverse().get(\"alpha\"));\n        assertEquals(\"secondary\", copy.inverse().get(\"beta\"));\n    }\n\n    @Test\n    void serializesAndRestoresMultisetElementCounts() throws Exception {\n        Multiset<String> multiset = HashMultiset.create();\n        multiset.add(\"apple\", 3);\n        multiset.add(\"orange\", 2);\n\n        Multiset<String> copy = roundTrip(multiset);\n\n        assertEquals(multiset, copy);\n        assertEquals(3, copy.count(\"apple\"));\n        assertEquals(2, copy.count(\"orange\"));\n    }\n\n    @Test\n    void serializesAndRestoresMultimapKeysAndValues() throws Exception {\n        ArrayListMultimap<String, String> multimap = ArrayListMultimap.create();\n        multimap.put(\"letters\", \"a\");\n        multimap.put(\"letters\", \"b\");\n        multimap.put(\"digits\", \"1\");\n\n        ArrayListMultimap<String, String> copy = roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertEquals(List.of(\"a\", \"b\"), copy.get(\"letters\"));\n        assertEquals(List.of(\"1\"), copy.get(\"digits\"));\n    }\n\n    @Test\n    void deserializesImmutableMultimapUsingSerializedFieldSetters() throws Exception {\n        ImmutableListMultimap<String, Integer> multimap = ImmutableListMultimap.<String, Integer>builder()\n                .put(\"odd\", 1)\n                .put(\"odd\", 3)\n                .put(\"even\", 2)\n                .build();\n\n        ImmutableListMultimap<String, Integer> copy = roundTrip(multimap);\n\n        assertEquals(multimap, copy);\n        assertEquals(List.of(1, 3), copy.get(\"odd\"));\n        assertEquals(3, copy.size());\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T object) throws IOException, ClassNotFoundException {\n        byte[] serialized = serialize(object);\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (T) inputStream.readObject();\n        }\n    }\n\n    private static byte[] serialize(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n}\n"}
