  import org.apache.hadoop.thirdparty.com.google.common.collect.LinkedHashMultimap;
  import org.apache.hadoop.thirdparty.com.google.common.collect.Multimap;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class LinkedHashMultimapTest {
      @Test
      void serializesAndRestoresInsertionOrderedKeysAndEntries() throws Exception {
          LinkedHashMultimap<String, Integer> multimap = LinkedHashMultimap.create();
          multimap.put("letters", 1);
          multimap.put("digits", 2);
          multimap.put("letters", 3);
  
          LinkedHashMultimap<String, Integer> copy = roundTrip(multimap);
  
          assertEquals(multimap, copy);
          assertEquals(List.of("letters", "digits"), List.copyOf(copy.keySet()));
          assertEquals(List.of(1, 3), List.copyOf(copy.get("letters")));
          assertEquals(List.of(
                  Map.entry("letters", 1),
                  Map.entry("digits", 2),
                  Map.entry("letters", 3)), List.copyOf(copy.entries()));
      }
  
      @SuppressWarnings("unchecked")
      private static <K, V> LinkedHashMultimap<K, V> roundTrip(Multimap<K, V> multimap)
              throws IOException, ClassNotFoundException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(multimap);
          }
  
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {
              return (LinkedHashMultimap<K, V>) inputStream.readObject();
          }
      }
  }
