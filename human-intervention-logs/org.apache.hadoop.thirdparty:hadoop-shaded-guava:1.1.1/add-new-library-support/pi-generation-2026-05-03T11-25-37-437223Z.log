  package org_apache_hadoop_thirdparty.hadoop_shaded_guava;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.apache.hadoop.thirdparty.com.google.common.collect.ArrayListMultimap;
  import org.apache.hadoop.thirdparty.com.google.common.collect.HashBiMap;
  import org.apache.hadoop.thirdparty.com.google.common.collect.HashMultiset;
  import org.apache.hadoop.thirdparty.com.google.common.collect.TreeMultiset;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SerializationTest {
      @Test
      void serializesHashBiMapEntries() throws Exception {
          HashBiMap<String, String> map = HashBiMap.create();
          map.put("first", "one");
          map.put("second", "two");
  
          HashBiMap<String, String> copy = reserialize(map);
  
          assertThat(copy).containsExactlyInAnyOrderEntriesOf(map);
          assertThat(copy.inverse()).containsEntry("one", "first");
      }
  
      @Test
      void serializesArrayListMultimapKeysAndValues() throws Exception {
          ArrayListMultimap<String, String> multimap = ArrayListMultimap.create();
          multimap.put("letters", "a");
          multimap.put("letters", "b");
          multimap.put("numbers", "one");
  
          ArrayListMultimap<String, String> copy = reserialize(multimap);
  
          assertThat(copy.asMap()).isEqualTo(multimap.asMap());
          assertThat(copy.get("letters")).containsExactly("a", "b");
      }
  
      @Test
      void serializesHashMultisetElementsAndCounts() throws Exception {
          HashMultiset<String> multiset = HashMultiset.create();
          multiset.add("red", 3);
          multiset.add("blue", 1);
  
          HashMultiset<String> copy = reserialize(multiset);
  
          assertThat(copy.count("red")).isEqualTo(3);
          assertThat(copy.count("blue")).isEqualTo(1);
          assertThat(copy.elementSet()).containsExactlyInAnyOrderElementsOf(multiset.elementSet());
      }
  
      @Test
      void serializesTreeMultisetRestoringInternalFields() throws Exception {
          TreeMultiset<String> multiset = TreeMultiset.create();
          multiset.add("alpha", 2);
          multiset.add("beta", 4);
  
          TreeMultiset<String> copy = reserialize(multiset);
  
          assertThat(copy).containsExactly("alpha", "alpha", "beta", "beta", "beta", "beta");
          assertThat(copy.comparator().compare("alpha", "beta")).isLessThan(0);
      }
  
      @SuppressWarnings("unchecked")
      private static <T> T reserialize(T value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (T) input.readObject();
          }
      }
  }
