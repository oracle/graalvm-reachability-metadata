asMap());\n        assertThat(copy.get(\"letters\")).containsExactly(\"a\", \"b\");\n    }\n\n    @Test\n    void serializesHashMultisetElementsAndCounts() throws Exception {\n        HashMultiset<String> multiset = HashMultiset.create();\n        multiset.add(\"red\", 3);\n        multiset.add(\"blue\", 1);\n\n        HashMultiset<String> copy = reserialize(multiset);\n\n        assertThat(copy.count(\"red\")).isEqualTo(3);\n        assertThat(copy.count(\"blue\")).isEqualTo(1);\n        assertThat(copy.elementSet()).containsExactlyInAnyOrderElementsOf(multiset.elementSet());\n    }\n\n    @Test\n    void serializesTreeMultisetRestoringInternalFields() throws Exception {\n        TreeMultiset<String> multiset = TreeMultiset.create();\n        multiset.add(\"alpha\", 2);\n        multiset.add(\"beta\", 4);\n\n        TreeMultiset<String> copy = reserialize(multiset);\n\n        assertThat(copy).containsExactly(\"alpha\", \"alpha\", \"beta\", \"beta\", \"beta\", \"beta\");\n        assertThat(copy.comparator().compare(\"alpha\", \"beta\")).isLessThan(0);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T reserialize(T value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (T) input.readObject();\n        }\n    }\n}\n"}
