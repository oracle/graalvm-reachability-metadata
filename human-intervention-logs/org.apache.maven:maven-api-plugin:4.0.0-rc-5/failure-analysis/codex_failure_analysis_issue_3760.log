er) {\\n   158\\t    List<String> matchingCoordinates\\n   159\\t    if (CoordinateUtils.isFractionalBatch(coordinateFilter)) {\\n   160\\t        int[] fraction = CoordinateUtils.parseFraction(coordinateFilter)\\n   161\\t        List<String> allCoordinates = tck.getMatchingCoordinatesStrict(\\\"all\\\")\\n   162\\t        matchingCoordinates = CoordinateUtils.computeBatchedCoordinates(allCoordinates, fraction[0], fraction[1])\\n   163\\t    } else {\\n   164\\t        matchingCoordinates = tck.getMatchingCoordinates(coordinateFilter)\\n   165\\t    }\\n   166\\t    return matchingCoordinates.findAll { !it.startsWith(\\\"samples:\\\") }\\n   167\\t}\\n   168\\t\\n   169\\tString resolveSelectedNativeImageMode() {\\n   170\\t    return NativeImageConfigUtils.resolveSelectedMode(\\n   171\\t            System.getenv(\\\"GVM_TCK_NATIVE_IMAGE_MODE\\\"),\\n   172\\t            project.findProperty(\\\"tck.nativeImageMode\\\")?.toString()\\n   173\\t    )\\n   174\\t}\\n   175\\t\\n   176\\tvoid printTestInfraReproducer(String gradleCmd, String coordinate, int parallelism) {\\n   177\\t    String nativeImageMode = resolveSelectedNativeImageMode()\\n   178\\t    TestInfraLoggingUtils.batchReproducerLines(\\n   179\\t            \\\"testInfra\\\",\\n   180\\t            gradleCmd,\\n   181\\t            nativeImageMode,\\n   182\\t            coordinate,\\n   183\\t            parallelism\\n   184\\t    ).each { println(it) }\\n   185\\t}\\n   186\\t\\n   187\\ttasks.register('testInfra') { t ->\\n   188\\t    t.group = \\\"verification\\\"\\n   189\\t    t.setDescription(\\\"\\\"\\\"Runs clean and pullAllowedDockerImages, then runs (${testInfraCommands('', '').collect { it.name }.join(', ')}) concurrently with isolated logs for a single coordinate.\\n   190\\t                        Options: -Pcoordinate or -Pcoordinates to specify the target; -Pparallelism to control the number of concurrent tasks.\\\"\\\"\\\")\\n   191\\t\\n   192\\t    doLast {\\n   193\\t        def coordinateProp = ((project.findProperty('coordinate') ?: project.findProperty('coordinates')) ?: '').toString().trim()\\n   194\\t        if (coordinateProp.isEmpty()) {\\n   195\\t            throw new GradleException(\\\"Missing -Pcoordinate=<group:artifact:version|k/n|all> (or -Pcoordinates).\\\")\\n   196\\t        }\\n   197\\t\\n   198\\t        def gradleCmd = System.getProperty(\\\"os.name\\\").toLowerCase().contains(\\\"windows\\\") ? \\\"gradlew.bat\\\" : \\\"./gradlew\\\"\\n   199\\t        int parallelism = parsePositiveIntProp('parallelism', 4)\\n   200\\t        println(\\\"Using parallelism=${parallelism} for testInfra.\\\")\\n   201\\t\\n   202\\t        List<String> concreteCoordinates = resolveConcreteCoordinates(coordinateProp)\\n   203\\t        if (concreteCoordinates.isEmpty()) {\\n   204\\t            throw new GradleException(\\\"No matching coordinates found for '${coordinateProp}'.\\\")\\n   205\\t        }\\n   206\\t        concreteCoordinates.each { coordinate ->\\n   207\\t            printTestInfraReproducer(gradleCmd, coordinate, parallelism)\\n   208\\t        }\\n   209\\t\\n   210\\t        def logsDir = layout.buildDirectory.dir(\\\"command-logs\\\").get().asFile\\n   211\\t        logsDir.mkdirs()\\n   212\\t\\n   213\\t        // Helper to run pull + command set for a given target (artifact or coordinates)\\n   214\\t        def runPhaseForCoordinate = { String coordinate ->\\n   215\\t            // Clean project before pulling Docker images for this coordinate\\n   216\\t            // Note: 'clean' deletes the build/ directory, so log to a temporary location outside build/,\\n   217\\t            // then move/copy the log into build/ afterwards.\\n   218\\t            def tmpCleanLogsDir = new File(project.rootDir, \\\".tmp-command-logs-clean\\\")\\n   219\\t            tmpCleanLogsDir.mkdirs()\\n   220\\t            def fileSuffix = sanitizeFileName(coordinate)\\n   221\\t            def tmpCleanLogFile = new File(tmpCleanLog