ME = \"NamedSPITest\";\n\n    @Test\n    public void reloadInstantiatesProviderDeclaredInSpiResource() {\n        ClassLoader classLoader = NamedSPILoaderTest.class.getClassLoader();\n        assertThat(classLoader).isNotNull();\n\n        NamedSPILoader<NamedSPILoaderTest> loader = new NamedSPILoader<>(NamedSPILoaderTest.class, classLoader);\n        loader.reload(classLoader);\n\n        NamedSPILoaderTest service = loader.lookup(SERVICE_NAME);\n\n        assertThat(service).isNotSameAs(this);\n        assertThat(service.getName()).isEqualTo(SERVICE_NAME);\n        assertThat(loader.availableServices()).containsExactly(SERVICE_NAME);\n        assertThat(discoveredServiceNames(loader)).containsExactly(SERVICE_NAME);\n    }\n\n    @Override\n    public String getName() {\n        return SERVICE_NAME;\n    }\n\n    private static List<String> discoveredServiceNames(NamedSPILoader<NamedSPILoaderTest> loader) {\n        List<String> names = new ArrayList<>();\n        for (NamedSPILoaderTest service : loader) {\n            names.add(service.getName());\n        }\n        return names;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 631, "output": 1544, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 19583, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777611788772, "responseId": "resp_02949d109de2ce660169f4340d1cbc81a3a93b3336f1b6b8b6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tYL3sLIwh73yzceoizhy0k61|fc_02949d109de2ce660169f4341bd19881a381fa3121771f5859", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1625 bytes to tests/src/org.apache.lucene/lucene-core/4.10.4/src/test/java/org_apache_lucene/lucene_core/NamedSPILoaderTest.java"}], "isError": false, "timestamp": 1777611805283}]}
