      final MethodHandle constr = findAttributeImplCtor(clazz);
      return new StaticImplementationAttributeFactory<A>(delegate, clazz) {
        @Override
        protected A createInstance() {
          try {
            return (A) constr.invokeExact();
          } catch (Throwable t) {
