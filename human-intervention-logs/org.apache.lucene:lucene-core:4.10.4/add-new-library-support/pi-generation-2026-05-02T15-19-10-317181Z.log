  package org_apache_lucene.lucene_core;
  
  import org.apache.lucene.util.Accountable;
  import org.apache.lucene.util.RamUsageEstimator;
  import org.apache.lucene.util.RamUsageEstimator.JvmFeature;
  import org.junit.jupiter.api.Test;
  
  import java.util.EnumSet;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RamUsageEstimatorTest {
      @Test
      void detectsAvailableJvmSizingFeaturesDuringClassInitialization() {
          EnumSet<JvmFeature> supportedFeatures = RamUsageEstimator.getSupportedFeatures();
          EnumSet<JvmFeature> unsupportedFeatures = RamUsageEstimator.getUnsupportedFeatures();
          EnumSet<JvmFeature> featurePartition = EnumSet.copyOf(supportedFeatures);
          featurePartition.addAll(unsupportedFeatures);
  
          EnumSet<JvmFeature> overlap = EnumSet.copyOf(supportedFeatures);
          overlap.retainAll(unsupportedFeatures);
  
          assertThat(featurePartition).containsExactlyInAnyOrder(JvmFeature.values());
          assertThat(overlap).isEmpty();
          assertThat(RamUsageEstimator.NUM_BYTES_OBJECT_REF).isPositive();
          assertThat(RamUsageEstimator.NUM_BYTES_OBJECT_ALIGNMENT).isPositive();
          assertThat(RamUsageEstimator.JVM_INFO_STRING).startsWith("[JVM: ");
      }
  
      @Test
      void estimatesShallowSizeByWalkingDeclaredFieldsInClassHierarchy() {
          long parentSize = RamUsageEstimator.shallowSizeOfInstance(ParentValue.class);
          long childSize = RamUsageEstimator.shallowSizeOfInstance(ChildValue.class);
          long objectSize = RamUsageEstimator.shallowSizeOf(new ChildValue());
  
          assertThat(parentSize).isPositive();
          assertThat(childSize).isGreaterThanOrEqualTo(parentSize);
          assertThat(objectSize).isEqualTo(childSize);
          assertThat(childSize % RamUsageEstimator.NUM_BYTES_OBJECT_ALIGNMENT).isZero();
      }
  
      @Test
      void reportsPrimitiveArrayAndAccountableArraySizes() {
          AccountableValue first = new AccountableValue(11L);
          AccountableValue second = new AccountableValue(17L);
  
          long shallowArraySize = RamUsageEstimator.shallowSizeOf(new Object[] {first, second});
          long accountableArraySize = RamUsageEstimator.sizeOf(new AccountableValue[] {first, second});
  
          assertThat(RamUsageEstimator.sizeOf(new long[] {1L, 2L, 3L})).isGreaterThan(3L * Long.BYTES);
          assertThat(accountableArraySize).isEqualTo(shallowArraySize + first.ramBytesUsed() + second.ramBytesUsed());
      }
  
      private static class ParentValue {
          private long identifier = 7L;
          private Object payload = "lucene";
      }
  
      private static final class ChildValue extends ParentValue {
          private int count = 3;
          private boolean deleted;
          private double score = 1.5D;
      }
  
      private static final class AccountableValue implements Accountable {
          private final long ramBytesUsed;
  
          private AccountableValue(long ramBytesUsed) {
              this.ramBytesUsed = ramBytesUsed;
          }
  
          @Override
          public long ramBytesUsed() {
              return ramBytesUsed;
          }
      }
  }
