te static final class AlwaysUnmappingMMapDirectory extends MMapDirectory {\n        private AlwaysUnmappingMMapDirectory(File path, int maxChunkSize) throws IOException {\n            super(path, null, maxChunkSize);\n        }\n\n        @Override\n        public boolean getUseUnmap() {\n            return true;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777610765575}}
