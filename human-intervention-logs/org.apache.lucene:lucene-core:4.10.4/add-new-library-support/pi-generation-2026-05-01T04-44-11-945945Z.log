sets.UTF_8);\n        Files.write(indexFile, expectedBytes);\n\n        File directoryPath = temporaryDirectory.toFile();\n        MMapDirectory directory = new MMapDirectory(directoryPath, null, 8);\n        directory.setUseUnmap(MMapDirectory.UNMAP_SUPPORTED);\n\n        assertThat(directory.getUseUnmap()).isEqualTo(MMapDirectory.UNMAP_SUPPORTED);\n\n        IndexInput input = directory.openInput(indexFile.getFileName().toString(), IOContext.READONCE);\n        byte[] actualBytes = new byte[expectedBytes.length];\n        input.readBytes(actualBytes, 0, actualBytes.length);\n\n        assertThat(actualBytes).containsExactly(expectedBytes);\n        assertThat(input.getFilePointer()).isEqualTo(expectedBytes.length);\n\n        input.close();\n        directory.close();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 585, "output": 691, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 23804, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777610574920, "responseId": "resp_0912e6984bf2968e0169f42f4f63d4819fb1dea7d5b4efa1e4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_SsZ3ENdsAsAGabBVsiyRiE2M|fc_0912e6984bf2968e0169f42f548cd0819f8bd35e28531315ac", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1790 bytes to tests/src/org.apache.lucene/lucene-core/4.10.4/src/test/java/org_apache_lucene/lucene_core/MMapDirectoryAnonymous1Anonymous1Test.java"}], "isError": false, "timestamp": 1777610583293}]}
