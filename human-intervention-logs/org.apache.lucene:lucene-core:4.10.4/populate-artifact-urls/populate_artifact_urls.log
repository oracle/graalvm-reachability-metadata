                <exclude>org/apache/lucene/util/PrintStreamInfoStream.class</exclude>
              </excludes>
            </configuration>
            <goals>
              <goal>check</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
