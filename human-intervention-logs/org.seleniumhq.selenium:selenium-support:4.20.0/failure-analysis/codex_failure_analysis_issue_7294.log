tadata is necessary for the test-local builder, which could lead to a missing reflection issue if not registered correctly.\\\"}]}\"}, {\"type\": \"toolCall\", \"id\": \"call_xnfOCMi2S4WFf5pzbbQSYXWW|fc_0e887a5a86dbbe14016a258036ab0c81969f34aee78e9204d2\", \"name\": \"read\", \"arguments\": {\"path\": \"tests/src/org.seleniumhq.selenium/selenium-support/4.20.0/build.gradle\"}, \"partialJson\": \"{\\\"path\\\":\\\"tests/src/org.seleniumhq.selenium/selenium-support/4.20.0/build.gradle\\\"}\"}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1354, \"output\": 1432, \"cacheRead\": 47104, \"cacheWrite\": 0, \"totalTokens\": 49890, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1780842514165, \"responseId\": \"resp_0e887a5a86dbbe14016a258013bef88196b941572a55a583b6\"}}\n2582:[tool-exec] start id=call_xnfOCMi2S4WFf5pzbbQSYXWW|fc_0e887a5a86dbbe14016a258036ab0c81969f34aee78e9204d2 name=read args={\"path\": \"tests/src/org.seleniumhq.selenium/selenium-support/4.20.0/build.gradle\"}\n2611:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_xnfOCMi2S4WFf5pzbbQSYXWW|fc_0e887a5a86dbbe14016a258036ab0c81969f34aee78e9204d2\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\nplugins {\\n    id \\\"org.graalvm.internal.tck\\\"\\n}\\n\\nString libraryVersion = tck.testedLibraryVersion.get()\\n\\ndependencies {\\n    testImplementation \\\"org.seleniumhq.selenium:selenium-support:$libraryVersion\\\"\\n    testImplementation 'org.assertj:assertj-core:3.22.0'\\n}\\n\\ngraalvmNative {\\n    agent {\\n        defaultMode = \\\"conditional\\\"\\n        modes {\\n       