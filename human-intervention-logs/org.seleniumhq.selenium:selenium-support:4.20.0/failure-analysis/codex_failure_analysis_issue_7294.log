     .near(new JsonSerializableBy(\\\"css selector\\\", \\\".primary\\\"), 10);\\n\\n        List<WebElement> elements = relativeLocator.findElements(context);\\n\\n        assertThat(elements).isEmpty();\\n        assertThat(context.script)\\n                .startsWith(\\\"/* findElements */return (function\\\")\\n                .contains(\\\"getBoundingClientRect\\\")\\n                .endsWith(\\\").apply(null, arguments);\\\");\\n        assertThat(context.arguments).singleElement()\\n                .isInstanceOf(Map.class)\\n                .asInstanceOf(MAP)\\n                .containsEntry(\\\"root\\\", Map.of(\\\"tag name\\\", \\\"button\\\"));\\n    }\\n\\n    @Test\\n    void relativeLocatorChainedFiltersAreSerializedForRemoteExecution() {\\n        RelativeLocator.RelativeBy relativeLocator = RelativeLocator.with(new JsonSerializableBy(\\\"tag name\\\", \\\"button\\\"))\\n                .near(new JsonSerializableBy(\\\"css selector\\\", \\\".primary\\\"), 10)\\n                .above(new JsonSerializableBy(\\\"id\\\", \\\"message\\\"));\\n\\n        By.Remotable.Parameters parameters = relativeLocator.getRemoteParameters();\\n\\n        assertThat(parameters.using()).isEqualTo(\\\"relative\\\");\\n        assertThat(parameters.value())\\n                .isInstanceOf(Map.class)\\n                .asInstanceOf(MAP)\\n                .containsEntry(\\\"root\\\", Map.of(\\\"tag name\\\", \\\"button\\\"))\\n                .extractingByKey(\\\"filters\\\")\\n                .asInstanceOf(LIST)\\n                .containsExactly(\\n                        Map.of(\\\"kind\\\", \\\"near\\\", \\\"args\\\", List.of(Map.of(\\\"css selector\\\", \\\".primary\\\"), 10)),\\n                        Map.of(\\\"kind\\\", \\\"above\\\", \\\"args\\\", List.of(Map.of(\\\"id\\\", \\\"message\\\"))));\\n    }\\n\\n    public static final class RecordingSearchContext implements SearchContext, JavascriptExecutor {\\n        private String script;\\n        private Object[] arguments;\\n\\n        @Override\\n        public List<WebElement> findElements(By by) {\\n            return List.of();\\n        }\\n\\n        @Override\\n        public WebElement findElement(By by) {\\n            throw new UnsupportedOperationException(\\\"This test only exercises relative locator script execution\\\");\\n        }\\n\\n        @Override\\n        public Object executeScript(String script, Object... args) {\\n            this.script = script;\\n            this.arguments = args;\\n            return List.of();\\n        }\\n\\n        @Override\\n        public Object executeAsyncScript(String script, Object... args) {\\n            throw new UnsupportedOperationException(\\\"This test only exercises synchronous script execution\\\");\\n        }\\n    }\\n\\n    public static final class JsonSerializableBy extends By {\\n        private final String using;\\n        private final String value;\\n\\n        public JsonSerializableBy(String using, String value) {\\n            this.using = using;\\n            this.value = value;\\n        }\\n\\n        @Override\\n        public List<WebElement> findElements(SearchContext context) {\\n            return List.of();\\n        }\\n\\n        public Map<String, Object> toJson() {\\n            return Map.of(\\\"using\\\", using, \\\"value\\\", value);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1780843157613}}\n2064:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_IG8WC2S7Xm7xtwikJhMurx8j|fc_04279d04ba865cdd016a2582952cbc81909b1f33196d922863\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_seleniumhq_selenium.selenium_support;\\n\\nimport java.util.List;\\nimport java.util.Map