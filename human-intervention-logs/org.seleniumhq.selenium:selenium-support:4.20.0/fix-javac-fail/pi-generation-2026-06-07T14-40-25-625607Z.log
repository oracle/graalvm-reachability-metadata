  package org_seleniumhq_selenium.selenium_support;
  
  import java.util.List;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.openqa.selenium.By;
  import org.openqa.selenium.JavascriptExecutor;
  import org.openqa.selenium.SearchContext;
  import org.openqa.selenium.WebElement;
  import org.openqa.selenium.support.locators.RelativeLocator;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.InstanceOfAssertFactories.LIST;
  import static org.assertj.core.api.InstanceOfAssertFactories.MAP;
  
  public class RelativeLocatorScriptTest {
      @Test
      void relativeLocatorFindElementsExecutesBundledJavascriptAtom() {
          RecordingSearchContext context = new RecordingSearchContext();
          RelativeLocator.RelativeBy relativeLocator = RelativeLocator.with(new JsonSerializableBy("tag name", "button"))
                  .near(new JsonSerializableBy("css selector", ".primary"), 10);
  
          List<WebElement> elements = relativeLocator.findElements(context);
  
          assertThat(elements).isEmpty();
          assertThat(context.script)
                  .startsWith("/* findElements */return (")
                  .contains("function")
                  .endsWith(").apply(null, arguments);");
          assertThat(context.arguments).singleElement()
                  .isInstanceOf(Map.class)
                  .asInstanceOf(MAP)
                  .extractingByKey("relative")
                  .asInstanceOf(MAP)
                  .containsEntry("root", Map.of("tag name", "button"))
                  .extractingByKey("filters")
                  .asInstanceOf(LIST)
                  .containsExactly(Map.of("kind", "near", "args", List.of(Map.of("css selector", ".primary"), 10)));
      }
  
      @Test
      void relativeLocatorChainedFiltersAreSerializedForRemoteExecution() {
          RelativeLocator.RelativeBy relativeLocator = RelativeLocator.with(new JsonSerializableBy("tag name", "button"))
                  .near(new JsonSerializableBy("css selector", ".primary"), 10)
                  .above(new JsonSerializableBy("id", "message"));
  
          By.Remotable.Parameters parameters = relativeLocator.getRemoteParameters();
  
          assertThat(parameters.using()).isEqualTo("relative");
          assertThat(parameters.value())
                  .isInstanceOf(Map.class)
                  .asInstanceOf(MAP)
                  .containsEntry("root", Map.of("tag name", "button"))
                  .extractingByKey("filters")
                  .asInstanceOf(LIST)
                  .containsExactly(
                          Map.of("kind", "near", "args", List.of(Map.of("css selector", ".primary"), 10)),
                          Map.of("kind", "above", "args", List.of(Map.of("id", "message"))));
      }
  
      public static final class RecordingSearchContext implements SearchContext, JavascriptExecutor {
          private String script;
          private Object[] arguments;
  
          @Override
          public List<WebElement> findElements(By by) {
              return List.of();
          }
  
          @Override
          public WebElement findElement(By by) {
              throw new UnsupportedOperationException("This test only exercises relative locator script execution");
          }
  
          @Override
          public Object executeScript(String script, Object... args) {
              this.script = script;
              this.arguments = args;
              return List.of();
          }
  
          @Override
          public Object executeAsyncScript(String script, Object... args) {
              throw new UnsupportedOperationException("This test only exercises synchronous script execution");
          }
      }
  
      public static final class JsonSerializableBy extends By {
          private final String using;
          private final String value;
  
          public JsonSerializableBy(String using, String value) {
              this.using = using;
              this.value = value;
          }
  
          @Override
          public List<WebElement> findElements(SearchContext context) {
              return List.of();
          }
  
          public Map<String, Object> toJson() {
              return Map.of("using", using, "value", value);
          }
      }
  }
