  public static final class JsonSerializableBy extends By {\n","newText":"    public static final class RecordingSearchContext implements SearchContext, JavascriptExecutor {\n        private String script;\n        private Object[] arguments;\n\n        @Override\n        public List<WebElement> findElements(By by) {\n            return List.of();\n        }\n\n        @Override\n        public WebElement findElement(By by) {\n            throw new UnsupportedOperationException(\"This test only exercises relative locator script execution\");\n        }\n\n        @Override\n        public Object executeScript(String script, Object... args) {\n            this.script = script;\n            this.arguments = args;\n            return List.of();\n        }\n\n        @Override\n        public Object executeAsyncScript(String script, Object... args) {\n            throw new UnsupportedOperationException(\"This test only exercises synchronous script execution\");\n        }\n    }\n\n    public static final class JsonSerializableBy extends By {\n"}]}
