          assertThat(foundElement).isNotSameAs(element);
          assertThat(driver.calls()).containsExactly("findElement");
          assertThat(element.calls()).containsExactly("getText", "click");
          assertThat(listener.events()).containsExactly(
                  "beforeFindElement",
                  "afterFindElement",
                  "beforeGetText",
                  "afterGetText:Save",
                  "beforeClick",
                  "afterClick");
