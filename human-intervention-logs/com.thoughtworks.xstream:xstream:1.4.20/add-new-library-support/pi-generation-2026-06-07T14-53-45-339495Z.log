write", "arguments": {"path": "tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/BeanProviderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.thoughtworks.xstream.converters.javabean.BeanProvider;\nimport com.thoughtworks.xstream.converters.javabean.JavaBeanProvider;\nimport java.lang.reflect.Constructor;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\npublic class BeanProviderTest {\n    @Test\n    void createsBeanWithDefaultConstructor() {\n        ExposedBeanProvider provider = new ExposedBeanProvider();\n\n        Object instance = provider.newInstance(MutableBean.class);\n        Constructor<?> constructor = provider.defaultConstructorOf(MutableBean.class);\n\n        assertThat(instance).isInstanceOf(MutableBean.class);\n        assertThat(constructor).isNotNull();\n        assertThat(constructor.getDeclaringClass()).isEqualTo(MutableBean.class);\n        assertThat(constructor.getParameterCount()).isZero();\n    }\n\n    @Test\n    void writesAndVisitsSerializableBeanProperties() {\n        BeanProvider provider = new BeanProvider();\n        MutableBean bean = new MutableBean();\n\n        provider.writeProperty(bean, \"name\", \"metadata\");\n        provider.writeProperty(bean, \"count\", Integer.valueOf(42));\n\n        RecordingVisitor visitor = new RecordingVisitor();\n        provider.visitSerializableProperties(bean, visitor);\n\n        assertThat(bean.getName()).isEqualTo(\"metadata\");\n        assertThat(bean.getCount()).isEqualTo(42);\n        assertThat(visitor.valuesByName).containsEntry(\"name\", \"metadata\").containsEntry(\"count\", Integer.valueOf(42));\n        assertThat(visitor.typesByName).containsEntry(\"name\", String.class).containsEntry(\"count\", int.class);\n        assertThat(visitor.definedInByName).containsEntry(\"name\", MutableBean.class).containsEntry(\"count\", MutableBean.class);\n    }\n\n    public static class MutableBean {\n        private String name;\n        private int count;\n\n        public MutableBean() {}\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n    }\n\n    private static final class ExposedBeanProvider extends BeanProvider {\n        Constructor<?> defaultConstructorOf(Class<?> type) {\n            return getDefaultConstrutor(type);\n        }\n    }\n\n    private static final class RecordingVisitor implements JavaBeanProvider.Visitor {\n        private final Map<String, Object> valuesByName = new LinkedHashMap<>();\n        private final Map<String, Class<?>> typesByName = new LinkedHashMap<>();\n        private final Map<String, Class<?>> definedInByName = new LinkedHashMap<>();\n\n        @Override\n        public boolean shouldVisit(String name, Class definedIn) {\n            return true;\n        }\n\n        @Override\n        public void visit(String name, Class type, Class definedIn, Object value) {\n            valuesByName.put(name, value);\n            typesByName.put(name, type);\n            definedInByName.put(name, definedIn);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 298, "output": 1999, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 21753, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780843955419, "responseId": "resp_0214137752f188a