m/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/PureJavaReflectionProviderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.thoughtworks.xstream.converters.reflection.PureJavaReflectionProvider;\nimport com.thoughtworks.xstream.io.xml.xppdom.XppDom;\nimport org.junit.jupiter.api.Test;\n\npublic class PureJavaReflectionProviderTest {\n    @Test\n    void createsTypeWithDefaultConstructor() {\n        PureJavaReflectionProvider provider = new PureJavaReflectionProvider();\n\n        Object instance = provider.newInstance(PureJavaReflectionProvider.class);\n\n        assertThat(instance).isInstanceOf(PureJavaReflectionProvider.class);\n        assertThat(instance).isNotSameAs(provider);\n    }\n\n    @Test\n    void createsSerializableTypeWithoutDefaultConstructor() {\n        PureJavaReflectionProvider provider = new PureJavaReflectionProvider();\n\n        Object instance = provider.newInstance(XppDom.class);\n\n        assertThat(instance).isInstanceOf(XppDom.class);\n        XppDom dom = (XppDom) instance;\n        assertThat(dom.getName()).isNull();\n        assertThat(dom.getChildCount()).isZero();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 19156, "output": 2370, "cacheRead": 61440, "cacheWrite": 0, "totalTokens": 82966, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780843391225, "responseId": "resp_045a421a425e7438016a258380bdb481968427c98f2cedf6e5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_0Dycm7vGqOqqw82ycVvbRc59|fc_045a421a425e7438016a2583c19e148196ba8501e2b642b9ae", "toolName": "write", "content": [{"ty