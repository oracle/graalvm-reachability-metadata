rovider = new PureJavaReflectionProvider();\n\n        Object instance = provider.newInstance(PureJavaReflectionProvider.class);\n\n        assertThat(instance).isInstanceOf(PureJavaReflectionProvider.class);\n        assertThat(instance).isNotSameAs(provider);\n    }\n\n    @Test\n    void createsSerializableTypeWithoutDefaultConstructor() {\n        PureJavaReflectionProvider provider = new PureJavaReflectionProvider();\n\n        Object instance = provider.newInstance(XppDom.class);\n\n        assertThat(instance).isInstanceOf(XppDom.class);\n        XppDom dom = (XppDom) instance;\n        assertThat(dom.getName()).isNull();\n        assertThat(dom.getChildCount()).isZero();\n    }\n\n    @Test\n    void createsSerializableTypeWithObjectInputStreamFallback() throws Exception {\n        try (ChildFirstXStreamClassLoader classLoader = new ChildFirstXStreamClassLoader(classPathUrls())) {\n            Runnable fallbackRunner = classLoader.loadClass(SerializationFallbackRunner.class.getName())\n                    .asSubclass(Runnable.class)\n                    .getConstructor()\n                    .newInstance();\n            runWithoutSuppressAccessChecks(fallbackRunner);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static URL[] classPathUrls() {\n        String classPath = System.getProperty(\"java.class.path\");\n        return Arrays.stream(classPath.split(File.pathSeparator))\n                .map(Path::of)\n                .map(Path::toUri)\n                .map(uri -> {\n                    try {\n                        return uri.toURL();\n                    } catch (Exception exception) {\n                        throw new IllegalArgumentException(\"Cannot convert class path entry to URL\", exception);\n                    }\n                })\n                .toArray(URL[]::new);\n    }\n\n    @SuppressWarnings({\"deprecation\", \"removal\"})\n    private static void runWithoutSuppressAccessChecks(Runnable runner) {\n        SecurityManager original = System.getSecurityManager();\n        System.setSecurityManager(new DenySuppressAccessChecksSecurityManager());\n        try {\n            runner.run();\n        } finally {\n            System.setSecurityManager(original);\n        }\n    }\n\n    public static class SerializationFallbackRunner implements Runnable {\n        @Override\n        public void run() {\n            PureJavaReflectionProvider provider = new PureJavaReflectionProvider();\n\n            Object instance = provider.newInstance(SerializableWithoutDefaultConstructor.class);\n\n            if (!(instance instanceof SerializableWithoutDefaultConstructor)) {\n                throw new AssertionError(\"Expected serializable helper instance, got \" + instance);\n            }\n        }\n\n        private static final class SerializableWithoutDefaultConstructor implements Serializable {\n            private static final long serialVersionUID = 1L;\n\n            private SerializableWithoutDefaultConstructor(String value) {\n            }\n        }\n    }\n\n    private static class ChildFirstXStreamClassLoader extends URLClassLoader {\n        ChildFirstXStreamClassLoader(URL[] urls) {\n            super(urls, PureJavaReflectionProviderTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && isChildFirst(name)) {\n                    try {\n                        loadedClass = findClass(name);\n                    } catch (ClassNotFoundException ignored) {\n                        // Fall back to the parent for JDK and test infrastructure classes.\n                    }\n                }\n                if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean isChildFirst(String name) {\n            return name.startsWith(\"com.thoughtworks.xstream.\")\n                    || name.startsWith(SerializationFallbackRunner.class.getName());\n        }\n    }\n\n    @SuppressWarnings({\"deprecation\", \"removal\"})\n    private static class DenySuppressAccessChecksSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            if (permission instanceof ReflectPermission\n                    && \"suppressAccessChecks\".equals(permission.getName())) {\n                throw new SecurityException(\"suppressAccessChecks intentionally disabled\");\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780843353204}]}
