  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package com_thoughtworks_xstream.xstream;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import com.thoughtworks.xstream.converters.reflection.PureJavaReflectionProvider;
  +import com.thoughtworks.xstream.io.xml.xppdom.XppDom;
  +import org.junit.jupiter.api.Test;
  +
  +public class PureJavaReflectionProviderTest {
  +    @Test
  +    void createsTypeWithDefaultConstructor() {
  +        PureJavaReflectionProvider provider = new PureJavaReflectionProvider();
  +
  +        Object instance = provider.newInstance(PureJavaReflectionProvider.class);
  +
  +        assertThat(instance).isInstanceOf(PureJavaReflectionProvider.class);
  +        assertThat(instance).isNotSameAs(provider);
  +    }
  +
  +    @Test
  +    void createsSerializableTypeWithoutDefaultConstructor() {
  +        PureJavaReflectionProvider provider = new PureJavaReflectionProvider();
  +
  +        Object instance = provider.newInstance(XppDom.class);
  +
  +        assertThat(instance).isInstanceOf(XppDom.class);
  +        XppDom dom = (XppDom) instance;
  +        assertThat(dom.getName()).isNull();
  +        assertThat(dom.getChildCount()).isZero();
  +    }
  +}
