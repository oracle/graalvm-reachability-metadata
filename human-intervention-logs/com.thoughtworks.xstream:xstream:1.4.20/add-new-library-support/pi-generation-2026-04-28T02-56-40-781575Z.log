      }
  
      public Class getItemTypeForItemFieldName(Class definedIn, String itemFieldName) {
          return null;
      }
  
      public ImplicitCollectionMapping getImplicitCollectionDefForFieldName(Class itemType, String fieldName) {
          return null;
  
