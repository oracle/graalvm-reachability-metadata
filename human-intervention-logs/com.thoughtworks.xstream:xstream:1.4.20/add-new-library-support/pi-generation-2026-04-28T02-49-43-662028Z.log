er.createWriter(xml);\n+        writer.startNode(\"order\");\n+        writer.addAttribute(\"status\", \"created\");\n+        writer.startNode(\"id\");\n+        writer.setValue(\"42\");\n+        writer.endNode();\n+        writer.endNode();\n+        writer.close();\n+\n+        HierarchicalStreamReader reader = driver.createReader(new StringReader(xml.toString()));\n+        try {\n+            assertThat(reader.getNodeName()).isEqualTo(\"order\");\n+            assertThat(reader.getAttribute(\"status\")).isEqualTo(\"created\");\n+            assertThat(reader.hasMoreChildren()).isTrue();\n+\n+            reader.moveDown();\n+            assertThat(reader.getNodeName()).isEqualTo(\"id\");\n+            assertThat(reader.getValue()).isEqualTo(\"42\");\n+            reader.moveUp();\n+\n+            assertThat(reader.hasMoreChildren()).isFalse();\n+        } finally {\n+            reader.close();\n+        }\n+    }\n+}\n\n--- metadata ---\ndiff --git 1/metadata/com.thoughtworks.xstream/xstream/1.4.20/reachability-metadata.json 2/metadata/com.thoughtworks.xstream/xstream/1.4.20/reachability-metadata.json\nnew file mode 100644\nindex 0000000000..1caab57e01\n--- /dev/null\n+++ 2/metadata/com.thoughtworks.xstream/xstream/1.4.20/reachability-metadata.json\n@@ -0,0 +1,28 @@\n+{\n+  \"reflection\": [\n+    {\n+      \"condition\": {\n+        \"typeReached\": \"com.thoughtworks.xstream.io.xml.SjsxpDriver\"\n+      },\n+      \"type\": \"com.sun.xml.internal.stream.XMLInputFactoryImpl\",\n+      \"methods\": [\n+        {\n+          \"name\": \"<init>\",\n+          \"parameterTypes\": []\n+        }\n+      ]\n+    },\n+    {\n+      \"condition\": {\n+        \"typeReached\": \"com.thoughtworks.xstream.io.xml.SjsxpDriver\"\n+      },\n+      \"type\": \"com.sun.xml.internal.stream.XMLOutputFactoryImpl\",\n+      \"methods\": [\n+        {\n+          \"name\": \"<init>\",\n+          \"parameterTypes\": []\n+        }\n+      ]\n+    }\n+  ]\n+}\n"}], "isError": fals