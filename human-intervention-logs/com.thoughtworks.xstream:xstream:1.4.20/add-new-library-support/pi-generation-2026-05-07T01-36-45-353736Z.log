  +    private static final class IsolatedPureJavaReflectionProviderLoader extends ClassLoader {
  +        private static final String ORIGINAL_METHOD_NAME = "newInstance";
  +        private static final String UNAVAILABLE_METHOD_NAME = "newInstancE";
  +
  +        private final Map<String, Class<?>> definedClasses = new ConcurrentHashMap<>();
  +
  +        private IsolatedPureJavaReflectionProviderLoader(ClassLoader parent) {
  +            super(parent);
  +        }
  +
  +        private ReflectionProvider newProvider() throws ReflectiveOperationException {
  +            return (ReflectionProvider)loadClass(PROVIDER_CLASS).getConstructor().newInstance();
  +        }
  +
