  package com_thoughtworks_xstream.xstream;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import com.thoughtworks.xstream.XStream;
  import com.thoughtworks.xstream.XStreamer;
  
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class XStreamerTest {
      @Test
      void roundTripsPayloadWithSelfContainedXStreamConfiguration() throws Exception {
          XStreamer streamer = new XStreamer();
          XStream xstream = new XStream();
          List<String> expected = new ArrayList<>();
          expected.add("created");
          expected.add("serialized");
          expected.add("restored");
  
          String xml = streamer.toXML(xstream, expected);
          Object restored = streamer.fromXML(xml);
  
          assertThat(xml).contains("created", "serialized", "restored");
          assertThat(restored).isInstanceOf(List.class);
          assertThat(restored).isEqualTo(expected);
      }
  }
