[tool-call] delta {"path":"tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/XStreamerTest.java","edits":[{"oldText":"import java.util.ArrayList;\nimport java.util.List;\n\nimport com.thoughtworks.xstream.XStream;\nimport com.thoughtworks.xstream.XStreamer;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class XStreamerTest {\n    @Test\n    void roundTripsPayloadWithSelfContainedXStreamConfiguration() throws Exception {\n        XStreamer streamer = new XStreamer();\n        XStream xstream = new XStream();\n        List<String> expected = new ArrayList<>();\n        expected.add(\"created\");\n        expected.add(\"serialized\");\n        expected.add(\"restored\");\n\n        String xml = streamer.toXML(xstream, expected);\n        Object restored = streamer.fromXML(xml);\n\n        assertThat(xml).contains(\"created\", \"serialized\", \"restored\");\n        assertThat(restored).isInstanceOf(List.class);\n        assertThat(restored).isEqualTo(expected);\n    }\n}\n","newText":"import com.thoughtworks.xstream.XStream;\nimport com.thoughtworks.xstream.XStreamer;\nimport com.thoughtworks.xstream.converters.ConversionException;\nimport com.thoughtworks.xstream.converters.Converter;\nimport com.thoughtworks.xstream.converters.ConverterLookup;\nimport com.thoughtworks.xstream.converters.ConverterRegistry;\nimport com.thoughtworks.xstream.converters.MarshallingContext;\nimport com.thoughtworks.xstream.converters.UnmarshallingContext;\nimport com.thoughtworks.xstream.core.ClassLoaderReference;\nimport com.thoughtworks.xstream.io.HierarchicalStreamReader;\nimport com.thoughtworks.xstream.io.HierarchicalStreamWriter;\nimport com.thoughtworks.xstream.io.xml.XppDriver;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class XStreamerTest {\n    @Test\n    void roundTripsPayloadWithSelfContainedXStreamConfiguration() throws Exception {\n        XStreamer streamer = new XStreamer();\n        XStream xstream = newStringOnlyXStream();\n        String expected = \"created serialized restored\";\n\n        String xml = streamer.toXML(xstream, expected);\n        Object restored = streamer.fromXML(xml);\n\n        assertThat(xml).contains(expected);\n        assertThat(restored).isEqualTo(expected);\n    }\n\n    private static XStream newStringOnlyXStream() {\n        return new XStream(\n            null,\n            new XppDriver(),\n            new ClassLoaderReference(XStreamerTest.class.getClassLoader()),\n            null,\n            new StringOnlyConverterLookup(),\n            new IgnoringConverterRegistry());\n    }\n\n    public static final class StringOnlyConverterLookup implements ConverterLookup {\n        @Override\n        public Converter lookupConverterForType(Class type) {\n            if (type == String.class) {\n                return new StringOnlyConverter();\n            }\n            throw new ConversionException(\"Unsupported type: \" + type);\n        }\n    }\n\n    public static final class IgnoringConverterRegistry implements ConverterRegistry {\n        @Override\n        public void registerConverter(Converter converter, int priority) {\n        }\n    }\n\n    public static final class StringOnlyConverter implements Converter {\n        @Override\n        public boolean canConvert(Class type) {\n            return type == String.class;\n        }\n\n        @Override\n        public void marshal(Object source, HierarchicalStreamWriter writer, MarshallingContext context) {\n            writer.setValue((String)source);\n        }\n\n        @Override\n        public Object unmarshal(HierarchicalStreamReader reader, UnmarshallingContext context) {\n            return reader.getValue();\n        }\n    }\n}\n"}]}
