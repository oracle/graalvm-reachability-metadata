hat;\n\npublic class XStreamerTest {\n    @Test\n    void roundTripsPayloadWithSelfContainedXStreamConfiguration() throws Exception {\n        XStreamer streamer = new XStreamer();\n        XStream xstream = newStringOnlyXStream();\n        String expected = \"created serialized restored\";\n\n        String xml = streamer.toXML(xstream, expected);\n        Object restored = streamer.fromXML(xml);\n\n        assertThat(xml).contains(expected);\n        assertThat(restored).isEqualTo(expected);\n    }\n\n    private static XStream newStringOnlyXStream() {\n        return new XStream(\n            null,\n            new XppDriver(),\n            new ClassLoaderReference(XStreamerTest.class.getClassLoader()),\n            null,\n            new StringOnlyConverterLookup(),\n            new IgnoringConverterRegistry());\n    }\n\n    public static final class StringOnlyConverterLookup implements ConverterLookup {\n        @Override\n        public Converter lookupConverterForType(Class type) {\n            if (type == String.class) {\n                return new StringOnlyConverter();\n            }\n            throw new ConversionException(\"Unsupported type: \" + type);\n        }\n    }\n\n    public static final class IgnoringConverterRegistry implements ConverterRegistry {\n        @Override\n        public void registerConverter(Converter converter, int priority) {\n        }\n    }\n\n    public static final class StringOnlyConverter implements Converter {\n        @Override\n        public boolean canConvert(Class type) {\n            return type == String.class;\n        }\n\n        @Override\n        public void marshal(Object source, HierarchicalStreamWriter writer, MarshallingContext context) {\n            writer.setValue((String)source);\n        }\n\n        @Override\n        public Object unmarshal(HierarchicalStreamReader reader, UnmarshallingContext context) {\n            return reader.getValue();\n        }\n    }\n}\n"}]}
