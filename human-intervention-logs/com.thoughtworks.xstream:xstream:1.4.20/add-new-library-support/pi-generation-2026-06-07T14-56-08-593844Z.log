[tool-call] delta {"path":"tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/XStreamerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.thoughtworks.xstream.XStream;\nimport com.thoughtworks.xstream.XStreamer;\nimport java.util.ArrayList;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class XStreamerTest {\n    @Test\n    void roundTripsObjectWithEmbeddedXStreamConfiguration() throws Exception {\n        XStream configured = new XStream();\n        configured.alias(\"values\", ArrayList.class);\n        XStreamer streamer = new XStreamer();\n        List<Object> values = new ArrayList<>();\n        values.add(\"xstreamer\");\n        values.add(Integer.valueOf(20));\n\n        String xml = streamer.toXML(configured, values);\n        Object restored = streamer.fromXML(xml);\n\n        assertThat(xml).contains(\"<values>\");\n        assertThat(restored).isEqualTo(values);\n    }\n}\n"}
