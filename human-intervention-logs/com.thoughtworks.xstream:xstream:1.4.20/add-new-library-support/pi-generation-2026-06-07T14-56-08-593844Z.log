  package com_thoughtworks_xstream.xstream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.thoughtworks.xstream.XStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamField;
  import java.io.Serializable;
  import org.junit.jupiter.api.BeforeEach;
  import org.junit.jupiter.api.Test;
  
  public class SerializationMembersTest {
      @BeforeEach
      void resetInvocationCounters() {
          CustomSerializedValue.writeObjectInvocations = 0;
          CustomSerializedValue.readObjectInvocations = 0;
      }
  
      @Test
      void appliesWriteReplaceAndReadResolveDuringXmlRoundTrip() {
          XStream xstream = configuredXStream(
                  WriteReplaceValue.class,
                  ReplacementValue.class,
                  ResolvedValue.class);
          xstream.alias("write-replace-value", WriteReplaceValue.class);
          xstream.alias("replacement-value", ReplacementValue.class);
          xstream.alias("resolved-value", ResolvedValue.class);
  
          String xml = xstream.toXML(new WriteReplaceValue("payload"));
          Object restored = xstream.fromXML(xml);
  
          assertThat(xml).contains("replacement-value");
          assertThat(restored)
                  .isInstanceOfSatisfying(ResolvedValue.class, value ->
                          assertThat(value.value).isEqualTo("payload replaced resolved"));
      }
  
      @Test
      void invokesCustomSerializableHooksAndReadsPersistentFields() {
          XStream xstream = configuredXStream(CustomSerializedValue.class);
          xstream.alias("custom-serialized-value", CustomSerializedValue.class);
  
          String xml = xstream.toXML(new CustomSerializedValue("payload"));
          Object restored = xstream.fromXML(xml);
  
          assertThat(CustomSerializedValue.writeObjectInvocations).isEqualTo(1);
          assertThat(CustomSerializedValue.readObjectInvocations).isEqualTo(1);
          assertThat(xml).contains("serialization=\"custom\"");
          assertThat(restored)
                  .isInstanceOfSatisfying(CustomSerializedValue.class, value ->
                          assertThat(value.value).isEqualTo("restored by readObject"));
      }
  
      private static XStream configuredXStream(Class<?>... allowedTypes) {
          XStream xstream = new XStream();
          xstream.allowTypes(allowedTypes);
          return xstream;
      }
  
      private static final class WriteReplaceValue {
          private final String value;
  
          private WriteReplaceValue(String value) {
              this.value = value;
          }
  
          private Object writeReplace() {
              return new ReplacementValue(value + " replaced");
          }
      }
  
      private static final class ReplacementValue {
          private String value;
  
          private ReplacementValue(String value) {
              this.value = value;
          }
  
          private Object readResolve() {
              return new ResolvedValue(value + " resolved");
          }
      }
  
      private static final class ResolvedValue {
          private final String value;
  
          private ResolvedValue(String value) {
              this.value = value;
          }
      }
  
      private static final class CustomSerializedValue implements Serializable {
          private static final long serialVersionUID = 1L;
          private static final ObjectStreamField[] serialPersistentFields = {
              new ObjectStreamField("value", String.class)
          };
          private static int writeObjectInvocations;
          private static int readObjectInvocations;
  
          private String value;
  
          private CustomSerializedValue(String value) {
              this.value = value;
          }
  
          private void writeObject(ObjectOutputStream stream) throws IOException {
              writeObjectInvocations++;
              stream.defaultWriteObject();
          }
  
          private void readObject(ObjectInputStream stream)
                  throws IOException, ClassNotFoundException {
              readObjectInvocations++;
              stream.defaultReadObject();
              value = "restored by readObject";
          }
      }
  }
[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_aflUQwy7F7vLIb3sapbQX5Ix|fc_034cbbecb2ce62c8016a2586bb604481959b1c437fea1f808e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.thoughtworks.xstream.XStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamField;\nimport java.io.Serializable;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class SerializationMembersTest {\n    @BeforeEach\n    void resetInvocationCounters() {\n        CustomSerializedValue.writeObjectInvocations = 0;\n        CustomSerializedValue.readObjectInvocations = 0;\n    }\n\n    @Test\n    void appliesWriteReplaceAndReadResolveDuringXmlRoundTrip() {\n        XStream xstream = configuredXStream(\n                WriteReplaceValue.class,\n                ReplacementValue.class,\n                ResolvedValue.class);\n        xstream.alias(\"write-replace-value\", WriteReplaceValue.class);\n        xstream.alias(\"replacement-value\", ReplacementValue.class);\n        xstream.alias(\"resolved-value\", ResolvedValue.class);\n\n        String xml = xstream.toXML(new WriteReplaceValue(\"payload\"));\n        Object restored = xstream.fromXML(xml);\n\n        assertThat(xml).contains(\"replacement-value\");\n        assertThat(restored)\n                .isInstanceOfSatisfying(ResolvedValue.class, value ->\n                        assertThat(value.value).isEqualTo(\"payload replaced resolved\"));\n    }\n\n    @Test\n    void invokesCustomSerializableHooksAndReadsPersistentFields() {\n        XStream xstream = configuredXStream(CustomSerializedValue.class);\n        xstream.alias(\"custom-serialized-value\", CustomSerializedValue.class);\n\n        String xml = xstream.toXML(new CustomSerializedValue(\"payload\"));\n        Object restored = xstream.fromXML(xml);\n\n        assertThat(CustomSerializedValue.writeObjectInvocations).isEqualTo(1);\n        assertThat(CustomSerializedValue.readObjectInvocations).isEqualTo(1);\n        assertThat(xml).contains(\"serialization=\\\"custom\\\"\");\n        assertThat(restored)\n                .isInstanceOfSatisfying(CustomSerializedValue.class, value ->\n                        assertThat(value.value).isEqualTo(\"restored by readObject\"));\n    }\n\n    private static XStream configuredXStream(Class<?>... allowedTypes) {\n        XStream xstream = new XStream();\n        xstream.allowTypes(allowedTypes);\n        return xstream;\n    }\n\n    private static final class WriteReplaceValue {\n        private final String value;\n\n        private WriteReplaceValue(String value) {\n            this.value = value;\n        }\n\n        private Object writeReplace() {\n            return new ReplacementValue(value + \" replaced\");\n        }\n    }\n\n    private static final class ReplacementValue {\n        private String value;\n\n        private ReplacementValue(String value) {\n            this.value = value;\n        }\n\n        private Object readResolve() {\n            return new ResolvedValue(value + \" resolved\");\n        }\n    }\n\n    private static final class ResolvedValue {\n        private final String value;\n\n        private ResolvedValue(String value) {\n            this.value = value;\n        }\n    }\n\n    private static final class CustomSerializedValue implements Serializable {\n        private static final long serialVersionUID = 1L;\n        private static final ObjectStreamField[] serialPersistentFields = {\n            new ObjectStreamField(\"value\", String.class)\n        };\n        private static int writeObjectInvocations;\n        private static int readObjectInvocations;\n\n        private String value;\n\n        private CustomSerializedValue(String value) {\n            this.value = value;\n        }\n\n        private void writeObject(ObjectOutputStream stream) throws IOException {\n            writeObjectInvocations++;\n            stream.defaultWriteObject();\n        }\n\n        private void readObject(ObjectInputStream stream)\n                throws IOException, ClassNotFoundException {\n            readObjectInvocations++;\n            stream.defaultReadObject();\n            value = \"restored by readObject\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780844219758}}
[recv] {"type": "message_end", "message": {"role": "toolResult", "toolCallId": "call_aflUQwy7F7vLIb3sapbQX5Ix|fc_034cbbecb2ce62c8016a2586bb604481959b1c437fea1f808e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.thoughtworks.xstream.XStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamField;\nimport java.io.Serializable;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class SerializationMembersTest {\n    @BeforeEach\n    void resetInvocationCounters() {\n        CustomSerializedValue.writeObjectInvocations = 0;\n        CustomSerializedValue.readObjectInvocations = 0;\n    }\n\n    @Test\n    void appliesWriteReplaceAndReadResolveDuringXmlRoundTrip() {\n        XStream xstream = configuredXStream(\n                WriteReplaceValue.class,\n                ReplacementValue.class,\n                ResolvedValue.class);\n        xstream.alias(\"write-replace-value\", WriteReplaceValue.class);\n        xstream.alias(\"replacement-value\", ReplacementValue.class);\n        xstream.alias(\"resolved-value\", ResolvedValue.class);\n\n        String xml = xstream.toXML(new WriteReplaceValue(\"payload\"));\n        Object restored = xstream.fromXML(xml);\n\n        assertThat(xml).contains(\"replacement-value\");\n        assertThat(restored)\n                .isInstanceOfSatisfying(ResolvedValue.class, value ->\n                        assertThat(value.value).isEqualTo(\"payload replaced resolved\"));\n    }\n\n    @Test\n    void invokesCustomSerializableHooksAndReadsPersistentFields() {\n        XStream xstream = configuredXStream(CustomSerializedValue.class);\n        xstream.alias(\"custom-serialized-value\", CustomSerializedValue.class);\n\n        String xml = xstream.toXML(new CustomSerializedValue(\"payload\"));\n        Object restored = xstream.fromXML(xml);\n\n        assertThat(CustomSerializedValue.writeObjectInvocations).isEqualTo(1);\n        assertThat(CustomSerializedValue.readObjectInvocations).isEqualTo(1);\n        assertThat(xml).contains(\"serialization=\\\"custom\\\"\");\n        assertThat(restored)\n                .isInstanceOfSatisfying(CustomSerializedValue.class, value ->\n                        assertThat(value.value).isEqualTo(\"restored by readObject\"));\n    }\n\n    private static XStream configuredXStream(Class<?>... allowedTypes) {\n        XStream xstream = new XStream();\n        xstream.allowTypes(allowedTypes);\n        return xstream;\n    }\n\n    private static final class WriteReplaceValue {\n        private final String value;\n\n        private WriteReplaceValue(String value) {\n            this.value = value;\n        }\n\n        private Object writeReplace() {\n            return new ReplacementValue(value + \" replaced\");\n        }\n    }\n\n    private static final class ReplacementValue {\n        private String value;\n\n        private ReplacementValue(String value) {\n            this.value = value;\n        }\n\n        private Object readResolve() {\n            return new ResolvedValue(value + \" resolved\");\n        }\n    }\n\n    private static final class ResolvedValue {\n        private final String value;\n\n        private ResolvedValue(String value) {\n            this.value = value;\n        }\n    }\n\n    private static final class CustomSerializedValue implements Serializable {\n        private static final long serialVersionUID = 1L;\n        private static final ObjectStreamField[] serialPersistentFields = {\n            new ObjectStreamField(\"value\", String.class)\n        };\n        private static int writeObjectInvocations;\n        private static int readObjectInvocations;\n\n        private String value;\n\n        private CustomSerializedValue(String value) {\n            this.value = value;\n        }\n\n        private void writeObject(ObjectOutputStream stream) throws IOException {\n            writeObjectInvocations++;\n            stream.defaultWriteObject();\n        }\n\n        private void readObject(ObjectInputStream stream)\n                throws IOException, ClassNotFoundException {\n            readObjectInvocations++;\n            stream.defaultReadObject();\n            value = \"restored by readObject\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780844219758}}
