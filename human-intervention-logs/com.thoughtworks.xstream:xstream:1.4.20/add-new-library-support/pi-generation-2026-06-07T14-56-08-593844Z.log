;\n        assertThat(restored).isEqualTo(values);\n    }\n}\n", "newText": "import com.thoughtworks.xstream.XStream;\nimport com.thoughtworks.xstream.XStreamer;\nimport com.thoughtworks.xstream.converters.ConversionException;\nimport com.thoughtworks.xstream.converters.Converter;\nimport com.thoughtworks.xstream.converters.ConverterLookup;\nimport com.thoughtworks.xstream.converters.basic.NullConverter;\nimport com.thoughtworks.xstream.converters.basic.StringConverter;\nimport com.thoughtworks.xstream.io.xml.XppDriver;\nimport org.junit.jupiter.api.Test;\n\npublic class XStreamerTest {\n    @Test\n    void roundTripsObjectWithEmbeddedXStreamConfiguration() throws Exception {\n        XStream configured = new XStream(\n                null,\n                new XppDriver(),\n                XStreamerTest.class.getClassLoader(),\n                null,\n                new StringOnlyConverterLookup(),\n                null);\n        configured.alias(\"payload\", String.class);\n        XStreamer streamer = new XStreamer();\n\n        String xml = streamer.toXML(configured, \"xstreamer\");\n        Object restored = streamer.fromXML(xml);\n\n        assertThat(xml).contains(\"<payload>xstreamer</payload>\");\n        assertThat(restored).isEqualTo(\"xstreamer\");\n    }\n}\n\nfinal class StringOnlyConverterLookup implements ConverterLookup {\n    private final Converter nullConverter = new NullConverter();\n    private final Converter stringConverter = new StringConverter(null);\n\n    @Override\n    public Converter lookupConverterForType(Class type) {\n        if (type == null) {\n            return nullConverter;\n        }\n        if (String.class.equals(type)) {\n            return stringConverter;\n        }\n        throw new ConversionException(\"Unsupported type: \" + type.getName());\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 525, "output": 1400, "cacheRead": 57856, "cacheWrite": 0, "totalToke