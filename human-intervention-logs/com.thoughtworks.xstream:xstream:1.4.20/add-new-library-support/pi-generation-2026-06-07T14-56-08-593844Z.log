  package com_thoughtworks_xstream.xstream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.thoughtworks.xstream.XStream;
  import java.time.LocalDate;
  import java.util.ArrayList;
  import java.util.List;
  import java.util.Optional;
  import org.junit.jupiter.api.Test;
  
  public class XStreamTest {
      @Test
      void constructsDefaultInstanceAndRoundTripsJdkTypes() {
          XStream xstream = new XStream();
          List<Object> values = new ArrayList<>();
          values.add("xstream");
          values.add(Integer.valueOf(42));
          values.add(LocalDate.of(2020, 2, 29));
          values.add(Optional.of("metadata"));
  
          String xml = xstream.toXML(values);
          Object restored = xstream.fromXML(xml);
  
          assertThat(xstream.getMapper()).isNotNull();
          assertThat(restored).isEqualTo(values);
      }
  }
