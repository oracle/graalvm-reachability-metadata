          "--add-opens=java.base/java.util=ALL-UNNAMED",
          "--add-opens=java.xml/com.sun.xml.internal.stream=ALL-UNNAMED"
      ]
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          all {
