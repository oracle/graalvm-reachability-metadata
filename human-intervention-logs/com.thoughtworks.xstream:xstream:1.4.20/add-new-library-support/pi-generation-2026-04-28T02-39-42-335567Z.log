   assertThat(property.isReadable()).isTrue();\n        assertThat(property.isWritable()).isTrue();\n    }\n\n    public static final class ReadableWritableBean {\n        private String name;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 731, "output": 947, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26254, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777343940621, "responseId": "resp_095e8f2e52c8302a0169f01dc51f488194819cbb18cbd0127b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Nt8nK4r6P6MzvLblpxUS15nb|fc_095e8f2e52c8302a0169f01dce4cb48194868fa3cdac945e98", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1818 bytes to tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/BeanPropertyDynamicAccessTest.java"}], "isError": false, "timestamp": 1777343952112}]}
