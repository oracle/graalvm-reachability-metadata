ttp://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamField;\nimport java.util.Map;\n\nimport com.thoughtworks.xstream.core.util.SerializationMembers;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SerializationMembersTest {\n    @Test\n    void invokesReadResolveMethod() {\n        SerializationMembers members = new SerializationMembers();\n        ReadResolvePayload payload = new ReadResolvePayload(\"original\");\n\n        Object resolved = members.callReadResolve(payload);\n\n        assertThat(resolved).isEqualTo(new ResolvedPayload(\"original-resolved\"));\n    }\n\n    @Test\n    void invokesWriteReplaceMethod() {\n        SerializationMembers members = new SerializationMembers();\n        WriteReplacePayload payload = new WriteReplacePayload(\"original\");\n\n        Object replaced = members.callWriteReplace(payload);\n\n        assertThat(replaced).isEqualTo(new ReplacementPayload(\"original-replaced\"));\n    }\n\n    @Test\n    void invokesReadObjectMethod() throws Exception {\n        SerializationMembers members = new SerializationMembers();\n        ReadObjectPayload payload = new ReadObjectPayload();\n\n        assertThat(members.supportsReadObject(ReadObjectPayload.class, false)).isTrue();\n        members.callReadObject(ReadObjectPayload.class, payload, objectInputStreamWithUtf(\"stream-value\"));\n\n        assertThat(payload.getValue()).isEqualTo(\"stream-value\");\n    }\n\n    @Test\n    void invokesWriteObjectMethod() throws Exception {\n        SerializationMembers members = new SerializationMembers();\n        WriteObjectPayload payload = new WriteObjectPayload(\"stream-value\");\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n\n        assertThat(members.supportsWriteObject(WriteObjectPayload.class, false)).isTrue();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            members.callWriteObject(WriteObjectPayload.class, payload, stream);\n        }\n\n        assertThat(payload.wasWritten()).isTrue();\n        try (ObjectInputStream stream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            assertThat(stream.readUTF()).isEqualTo(\"stream-value\");\n        }\n    }\n\n    @Test\n    void readsSerializablePersistentFields() {\n        SerializationMembers members = new SerializationMembers();\n\n        Map fields = members.getSerializablePersistentFields(PersistentFieldsPayload.class);\n\n        assertThat(fields).containsOnlyKeys(\"name\", \"count\");\n        assertThat((ObjectStreamField)fields.get(\"name\"))\n            .extracting(ObjectStreamField::getType)\n            .isEqualTo(String.class);\n        assertThat((ObjectStreamField)fields.get(\"count\"))\n            .extracting(ObjectStreamField::getType)\n            .isEqualTo(Integer.TYPE);\n    }\n\n    private static ObjectInputStream objectInputStreamWithUtf(String value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            stream.writeUTF(value);\n        }\n        return new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()));\n    }\n\n    private static final class ReadResolvePayload {\n        private final String value;\n\n        private ReadResolvePayload(String value) {\n            this.value = value;\n        }\n\n        private Object readResolve() {\n            return new ResolvedPayload(value + \"-resolved\");\n        }\n    }\n\n    private static final class ResolvedPayload {\n        private final String value;\n\n        private ResolvedPayload(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof ResolvedPayload)) {\n                return false;\n            }\n            ResolvedPayload that = (ResolvedPayload)other;\n            return value.equals(that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n\n    private static final class WriteReplacePayload {\n        private final String value;\n\n        private WriteReplacePayload(String value) {\n            this.value = value;\n        }\n\n        private Object writeReplace() {\n            return new ReplacementPayload(value + \"-replaced\");\n        }\n    }\n\n    private static final class ReplacementPayload {\n        private final String value;\n\n        private ReplacementPayload(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof ReplacementPayload)) {\n                return false;\n            }\n            ReplacementPayload that = (ReplacementPayload)other;\n            return value.equals(that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n\n    private static final class ReadObjectPayload {\n        private String value;\n\n        private void readObject(ObjectInputStream stream) throws IOException {\n            value = stream.readUTF();\n        }\n\n        private String getValue() {\n            return value;\n        }\n    }\n\n    private static final class WriteObjectPayload {\n        private final String value;\n        private boolean written;\n\n        private WriteObjectPayload(String value) {\n            this.value = value;\n        }\n\n        private void writeObject(ObjectOutputStream stream) throws IOException {\n            written = true;\n            stream.writeUTF(value);\n        }\n\n        private boolean wasWritten() {\n            return written;\n        }\n    }\n\n    private static final class PersistentFieldsPayload {\n        private static final ObjectStreamField[] serialPersistentFields = {\n            new ObjectStreamField(\"name\", String.class),\n            new ObjectStreamField(\"count\", Integer.TYPE)\n        };\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2402, "output": 2482, "cacheRead": 9728, "cacheWrite": 0, "totalTokens": 14612, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778118222437, "responseId": "resp_007f368fcd9259990169fbee4effe0819c802a05d6b7c2c502"}}
