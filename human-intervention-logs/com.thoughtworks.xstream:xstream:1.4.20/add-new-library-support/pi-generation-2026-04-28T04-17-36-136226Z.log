       7	package com.thoughtworks.xstream.security;
       8	
       9	import net.sf.cglib.proxy.Proxy;
      10	
      11	
      12	/**
      13	 * Permission for any array type.
      14	 * 
      15	 * @author J&ouml;rg Schaible
      16	 * @since 1.4.7
      17	 */
      18	public class CGLIBProxyTypePermission implements TypePermission {
      19	    /**
      20	     * @since 1.4.7
      21	     */
      22	    public static final TypePermission PROXIES = new CGLIBProxyTypePermission();
      23	
      24	    public boolean allows(final Class type) {
      25	        return type != null && type != Object.class && !type.isInterface()
      26	            && (Proxy.isProxyClass(type) || type.getName().startsWith(Proxy.class.getPackage().getName() + "."));
      27	    }
      28	
      29	    public int hashCode() {
      30	        return 19;
      31	    }
      32	
      33	    public boolean equals(final Object obj) {
      34	        return obj != null && obj.getClass() == CGLIBProxyTypePermission.class;
      35	    }
      36	}
