entFields() {\n        XStream xstream = configuredXStream(CustomSerializedValue.class);\n        xstream.alias(\"custom-serialized-value\", CustomSerializedValue.class);\n\n        String xml = xstream.toXML(new CustomSerializedValue(\"payload\"));\n        Object restored = xstream.fromXML(xml);\n\n        assertThat(CustomSerializedValue.writeObjectInvocations).isEqualTo(1);\n        assertThat(CustomSerializedValue.readObjectInvocations).isEqualTo(1);\n        assertThat(xml).contains(\"serialization=\\\"custom\\\"\");\n        assertThat(restored)\n                .isInstanceOfSatisfying(CustomSerializedValue.class, value ->\n                        assertThat(value.value).isEqualTo(\"restored by readObject\"));\n    }\n\n    private static XStream configuredXStream(Class<?>... allowedTypes) {\n        XStream xstream = new XStream();\n        xstream.allowTypes(allowedTypes);\n        return xstream;\n    }\n\n    private static final class WriteReplaceValue {\n        private final String value;\n\n        private WriteReplaceValue(String value) {\n            this.value = value;\n        }\n\n        private Object writeReplace() {\n            return new ReplacementValue(value + \" replaced\");\n        }\n    }\n\n    private static final class ReplacementValue {\n        private String value;\n\n        private ReplacementValue(String value) {\n            this.value = value;\n        }\n\n        private Object readResolve() {\n            return new ResolvedValue(value + \" resolved\");\n        }\n    }\n\n    private static final class ResolvedValue {\n        private final String value;\n\n        private ResolvedValue(String value) {\n            this.value = value;\n        }\n    }\n\n    private static final class CustomSerializedValue implements Serializable {\n        private static final long serialVersionUID = 1L;\n        private static final ObjectStreamField[] serialPersistentFields = {\n            new ObjectStreamField(\"value\", String.class)\n        };\n        private static int writeObjectInvocations;\n        private static int readObjectInvocations;\n\n        private String value;\n\n        private CustomSerializedValue(String value) {\n            this.value = value;\n        }\n\n        private void writeObject(ObjectOutputStream stream) throws IOException {\n            writeObjectInvocations++;\n            stream.defaultWriteObject();\n        }\n\n        private void readObject(ObjectInputStream stream) throws IOException, ClassNotFoundException {\n            readObjectInvocations++;\n            stream.defaultReadObject();\n            value = \"restored by readObject\";\n        }\n    }\n}\n"}
