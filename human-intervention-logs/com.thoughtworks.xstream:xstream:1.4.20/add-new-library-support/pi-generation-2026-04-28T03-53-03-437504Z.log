      private void writeText(String text) {
          int length = text.length();
          for (int i = 0; i < length; i++ ) {
              char c = text.charAt(i);
              switch (c) {
              case '"':
                  this.writer.write("\\\"");
                  break;
              case '\\':
                  this.writer.write("\\\\");
                  break;
              // turn this off - it is no CTRL char anyway
              // case '/':
              // this.writer.write("\\/");
              // break;
              case '\b':
                  this.writer.write("\\b");
