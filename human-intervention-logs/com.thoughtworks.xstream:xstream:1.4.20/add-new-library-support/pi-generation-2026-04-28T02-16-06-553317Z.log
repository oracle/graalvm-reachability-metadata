      public int skipBytes(int len) {
          throw new UnsupportedOperationException();
      }
  
      public long skip(long n) {
          throw new UnsupportedOperationException();
      }
  
      public void mark(int readlimit) {
          throw new UnsupportedOperationException();
      }
  
      public void reset() {
          throw new UnsupportedOperationException();
      }
  
      public boolean markSupported() {
          return false;
      }
  
  }
