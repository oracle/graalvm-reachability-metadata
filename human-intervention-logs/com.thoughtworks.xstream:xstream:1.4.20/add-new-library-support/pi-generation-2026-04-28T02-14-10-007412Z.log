          throw new UnsupportedOperationException();
      }
  
      public void useProtocolVersion(int version) {
          throw new UnsupportedOperationException();
      }
  
      public void writeBytes(String str) {
          throw new UnsupportedOperationException();
      }
  
      public void writeUnshared(Object obj) {
          throw new UnsupportedOperationException();
      }
  
