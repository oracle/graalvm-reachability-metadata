  package com_thoughtworks_xstream.xstream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.thoughtworks.xstream.XStream;
  import com.thoughtworks.xstream.XStreamer;
  import com.thoughtworks.xstream.converters.ConversionException;
  import com.thoughtworks.xstream.converters.Converter;
  import com.thoughtworks.xstream.converters.ConverterLookup;
  import com.thoughtworks.xstream.converters.SingleValueConverterWrapper;
  import com.thoughtworks.xstream.converters.basic.NullConverter;
  import com.thoughtworks.xstream.converters.basic.StringConverter;
  import com.thoughtworks.xstream.io.xml.XppDriver;
  import org.junit.jupiter.api.Test;
  
  public class XStreamerTest {
      @Test
      void roundTripsObjectWithEmbeddedXStreamConfiguration() throws Exception {
          XStream configured = new XStream(
                  null,
                  new XppDriver(),
                  XStreamerTest.class.getClassLoader(),
                  null,
                  new StringOnlyConverterLookup(),
                  null);
          configured.alias("payload", String.class);
          XStreamer streamer = new XStreamer();
  
          String xml = streamer.toXML(configured, "xstreamer");
          Object restored = streamer.fromXML(xml);
  
          assertThat(xml).contains("<payload>xstreamer</payload>");
          assertThat(restored).isEqualTo("xstreamer");
      }
  }
  
  final class StringOnlyConverterLookup implements ConverterLookup {
      private final Converter nullConverter = new NullConverter();
      private final Converter stringConverter = new SingleValueConverterWrapper(new StringConverter(null));
  
      @Override
      public Converter lookupConverterForType(Class type) {
          if (type == null) {
              return nullConverter;
          }
          if (String.class.equals(type)) {
              return stringConverter;
          }
          throw new ConversionException("Unsupported type: " + type.getName());
      }
  }
