  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.thoughtworks.xstream.converters.javabean.BeanProvider;
  import com.thoughtworks.xstream.converters.javabean.JavaBeanProvider;
  import java.lang.reflect.Constructor;
  import java.util.LinkedHashMap;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  public class BeanProviderTest {
      @Test
      void createsBeanWithDefaultConstructor() {
          ExposedBeanProvider provider = new ExposedBeanProvider();
  
          Object instance = provider.newInstance(MutableBean.class);
          Constructor<?> constructor = provider.defaultConstructorOf(MutableBean.class);
  
          assertThat(instance).isInstanceOf(MutableBean.class);
          assertThat(constructor).isNotNull();
          assertThat(constructor.getDeclaringClass()).isEqualTo(MutableBean.class);
          assertThat(constructor.getParameterCount()).isZero();
      }
  
      @Test
      void writesAndVisitsSerializableBeanProperties() {
          BeanProvider provider = new BeanProvider();
          MutableBean bean = new MutableBean();
  
          provider.writeProperty(bean, "name", "metadata");
          provider.writeProperty(bean, "count", Integer.valueOf(42));
  
          RecordingVisitor visitor = new RecordingVisitor();
          provider.visitSerializableProperties(bean, visitor);
  
          assertThat(bean.getName()).isEqualTo("metadata");
          assertThat(bean.getCount()).isEqualTo(42);
          assertThat(visitor.valuesByName).containsEntry("name", "metadata").containsEntry("count", Integer.valueOf(42));
          assertThat(visitor.typesByName).containsEntry("name", String.class).containsEntry("count", int.class);
          assertThat(visitor.definedInByName)
                  .containsEntry("name", MutableBean.class)
                  .containsEntry("count", MutableBean.class);
      }
  
      public static class MutableBean {
          private String name;
          private int count;
  
          public MutableBean() {}
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getCount() {
              return count;
          }
  
          public void setCount(int count) {
              this.count = count;
          }
      }
  
      private static final class ExposedBeanProvider extends BeanProvider {
          Constructor<?> defaultConstructorOf(Class<?> type) {
              return getDefaultConstrutor(type);
          }
      }
  
      private static final class RecordingVisitor implements JavaBeanProvider.Visitor {
          private final Map<String, Object> valuesByName = new LinkedHashMap<>();
          private final Map<String, Class<?>> typesByName = new LinkedHashMap<>();
          private final Map<String, Class<?>> definedInByName = new LinkedHashMap<>();
  
          @Override
          public boolean shouldVisit(String name, Class definedIn) {
              return true;
          }
  
          @Override
          public void visit(String name, Class type, Class definedIn, Object value) {
              valuesByName.put(name, value);
              typesByName.put(name, type);
              definedInByName.put(name, definedIn);
          }
      }
  }
