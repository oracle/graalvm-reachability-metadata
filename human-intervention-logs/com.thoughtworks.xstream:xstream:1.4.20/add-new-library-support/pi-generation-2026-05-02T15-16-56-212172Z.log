  package com_thoughtworks_xstream.xstream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Path;
  import java.nio.file.Paths;
  import java.time.Duration;
  import java.time.LocalDate;
  import java.time.MonthDay;
  import java.time.YearMonth;
  import java.util.LinkedHashMap;
  import java.util.Map;
  import java.util.Optional;
  import java.util.UUID;
  
  import org.junit.jupiter.api.Test;
  
  import com.thoughtworks.xstream.XStream;
  import com.thoughtworks.xstream.annotations.XStreamAlias;
  
  public class XStreamTest {
  
      @Test
      public void constructsDefaultInstanceWithDynamicMappersConvertersAndImmutableTypes() {
          XStream xstream = new XStream();
  
          Map<String, Object> values = new LinkedHashMap<>();
          values.put("uuid", UUID.nameUUIDFromBytes("xstream-dynamic-access".getBytes(StandardCharsets.UTF_8)));
          values.put("path", Paths.get("build", "xstream", "sample.xml"));
          values.put("duration", Duration.ofMinutes(42));
          values.put("localDate", LocalDate.of(2024, 2, 29));
          values.put("monthDay", MonthDay.of(12, 25));
          values.put("yearMonth", YearMonth.of(2024, 2));
          values.put("optional", Optional.of("present"));
  
          String xml = xstream.toXML(values);
          @SuppressWarnings("unchecked")
          Map<String, Object> roundTripped = (Map<String, Object>)xstream.fromXML(xml);
  
          assertThat(roundTripped)
              .containsEntry("uuid", values.get("uuid"))
              .containsEntry("duration", values.get("duration"))
              .containsEntry("localDate", values.get("localDate"))
              .containsEntry("monthDay", values.get("monthDay"))
              .containsEntry("yearMonth", values.get("yearMonth"))
              .containsEntry("optional", values.get("optional"));
          assertThat(roundTripped.get("path").toString()).isEqualTo(((Path)values.get("path")).toString());
      }
  
      @Test
      public void annotationMapperCreatedDuringConstructionProcessesAliases() {
          XStream xstream = new XStream();
          xstream.processAnnotations(AliasedMessage.class);
          xstream.allowTypes(new Class<?>[]{AliasedMessage.class});
  
          AliasedMessage message = new AliasedMessage("hello");
          String xml = xstream.toXML(message);
          Object roundTripped = xstream.fromXML(xml);
  
          assertThat(xml).contains("<aliased-message>");
          assertThat(roundTripped).isEqualTo(message);
      }
  
      @XStreamAlias("aliased-message")
      public static class AliasedMessage {
          private String text;
  
          public AliasedMessage() {
          }
  
          AliasedMessage(String text) {
              this.text = text;
          }
  
          @Override
          public boolean equals(Object other) {
              if (this == other) {
                  return true;
              }
              if (!(other instanceof AliasedMessage)) {
                  return false;
              }
              AliasedMessage that = (AliasedMessage)other;
              return text.equals(that.text);
          }
  
          @Override
          public int hashCode() {
              return text.hashCode();
          }
      }
  }
