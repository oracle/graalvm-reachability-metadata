alDate\"))\n            .containsEntry(\"monthDay\", values.get(\"monthDay\"))\n            .containsEntry(\"yearMonth\", values.get(\"yearMonth\"))\n            .containsEntry(\"optional\", values.get(\"optional\"));\n        assertThat(roundTripped.get(\"path\").toString()).isEqualTo(((Path)values.get(\"path\")).toString());\n    }\n\n    @Test\n    public void annotationMapperCreatedDuringConstructionProcessesAliases() {\n        XStream xstream = new XStream();\n        xstream.processAnnotations(AliasedMessage.class);\n        xstream.allowTypes(new Class<?>[]{AliasedMessage.class});\n\n        AliasedMessage message = new AliasedMessage(\"hello\");\n        String xml = xstream.toXML(message);\n        Object roundTripped = xstream.fromXML(xml);\n\n        assertThat(xml).contains(\"<aliased-message>\");\n        assertThat(roundTripped).isEqualTo(message);\n    }\n\n    @XStreamAlias(\"aliased-message\")\n    public static class AliasedMessage {\n        private String text;\n\n        public AliasedMessage() {\n        }\n\n        AliasedMessage(String text) {\n            this.text = text;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof AliasedMessage)) {\n                return false;\n            }\n            AliasedMessage that = (AliasedMessage)other;\n            return text.equals(that.text);\n        }\n\n        @Override\n        public int hashCode() {\n            return text.hashCode();\n        }\n    }\n}\n"}
