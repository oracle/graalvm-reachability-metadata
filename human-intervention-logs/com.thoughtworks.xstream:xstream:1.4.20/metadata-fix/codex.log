  public static final class AttributedMessage {\n        public String kind;\n        public String text;\n\n        public AttributedMessage() {\n        }\n\n        public AttributedMessage(String kind, String text) {\n            this.kind = kind;\n            this.text = text;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
