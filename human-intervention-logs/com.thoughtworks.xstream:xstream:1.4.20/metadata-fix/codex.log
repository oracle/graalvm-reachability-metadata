{"type":"item.started","item":{"id":"item_7","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/AnnotationReflectionConverterTest.java\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/AnnotationReflectionConverterTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.thoughtworks.xstream.XStream;\nimport com.thoughtworks.xstream.annotations.AnnotationProvider;\nimport com.thoughtworks.xstream.annotations.AnnotationReflectionConverter;\nimport com.thoughtworks.xstream.annotations.XStreamConverter;\nimport com.thoughtworks.xstream.converters.Converter;\nimport com.thoughtworks.xstream.converters.MarshallingContext;\nimport com.thoughtworks.xstream.converters.SingleValueConverter;\nimport com.thoughtworks.xstream.converters.UnmarshallingContext;\nimport com.thoughtworks.xstream.io.HierarchicalStreamReader;\nimport com.thoughtworks.xstream.io.HierarchicalStreamWriter;\nimport java.util.Locale;\nimport org.junit.jupiter.api.Test;\n\npublic class AnnotationReflectionConverterTest {\n    @Test\n    void roundTripsFieldsWithLegacyAnnotationReflectionConverter() {\n        UppercaseStringConverter.constructorInvocations = 0;\n        UppercaseRegularValueConverter.constructorInvocations = 0;\n        XStream xstream = configuredXStream();\n        AnnotatedPayload payload = new AnnotatedPayload(\"alpha\", new RegularValue(\"beta\"));\n\n        String xml = xstream.toXML(payload);\n        Object restored = xstream.fromXML(xml);\n\n        assertThat(xml).contains(\"<label>ALPHA</label>\");\n        assertThat(xml).contains(\"<regularValue>BETA</regularValue>\");\n        assertThat(UppercaseStringConverter.constructorInvocations).isEqualTo(1);\n        assertThat(UppercaseRegularValueConverter.constructorInvocations).isEqualTo(1);\n        assertThat(restored)\n                .isInstanceOfSatisfying(AnnotatedPayload.class, value -> {\n                    assertThat(value.label).isEqualTo(\"alpha\");\n                    assertThat(value.regularValue.text).isEqualTo(\"beta\");\n                });\n    }\n\n    @SuppressWarnings(\"deprecation\")\n    private static XStream configuredXStream() {\n        XStream xstream = new XStream();\n        xstream.alias(\"annotated-payload\", AnnotatedPayload.class);\n        xstream.allowTypes(new Class<?>[] {AnnotatedPayload.class, RegularValue.class});\n        AnnotationReflectionConverter converter = new AnnotationReflectionConverter(\n                xstream.getMapper(), xstream.getReflectionProvider(), new AnnotationProvider());\n        xstream.registerConverter(converter, XStream.PRIORITY_VERY_LOW);\n        return xstream;\n    }\n\n    private static final class AnnotatedPayload {\n        @XStreamConverter(UppercaseStringConverter.class)\n        private String label;\n\n        @XStreamConverter(UppercaseRegularValueConverter.class)\n        private RegularValue regularValue;\n\n        private AnnotatedPayload(String label, RegularValue regularValue) {\n            this.label = label;\n            this.regularValue = regularValue;\n        }\n    }\n\n    private static final class RegularValue {\n        private final String text;\n\n        private RegularValue(String text) {\n            this.text = text;\n        }\n    }\n\n    public static class UppercaseStringConverter implements SingleValueConverter {\n        private static int constructorInvocations;\n\n        public UppercaseStringConverter() {\n            constructorInvocations++;\n        }\n\n        @Override\n        public boolean canConvert(Class type) {\n            return String.class.equals(type);\n        }\n\n        @Override\n        public String toString(Object value) {\n            return value.toString().toUpperCase(Locale.ROOT);\n        }\n\n        @Override\n        public Object fromString(String value) {\n            return value.toLowerCase(Locale.ROOT);\n        }\n    }\n\n    public static class UppercaseRegularValueConverter implements Converter {\n        private static int constructorInvocations;\n\n        public UppercaseRegularValueConverter() {\n            constructorInvocations++;\n        }\n\n        @Override\n        public boolean canConvert(Class type) {\n            return RegularValue.class.equals(type);\n        }\n\n        @Override\n        public void marshal(Object source, HierarchicalStreamWriter writer, MarshallingContext context) {\n            RegularValue value = (RegularValue) source;\n            writer.setValue(value.text.toUpperCase(Locale.ROOT));\n        }\n\n        @Override\n        public Object unmarshal(HierarchicalStreamReader reader, UnmarshallingContext context) {\n            return new RegularValue(reader.getValue().toLowerCase(Locale.ROOT));\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
