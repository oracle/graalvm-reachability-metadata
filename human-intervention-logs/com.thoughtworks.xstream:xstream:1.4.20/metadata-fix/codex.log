{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/BeanProviderTest.java && printf '\\\\n=====\\\\n' && sed -n '1,220p' tests/src/com.thoughtworks.xstream/xstream/1.4.20/src/test/java/com_thoughtworks_xstream/xstream/SerializationMembersTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.lang.reflect.Constructor;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\n\nimport com.thoughtworks.xstream.converters.ConversionException;\nimport com.thoughtworks.xstream.converters.javabean.BeanProvider;\nimport com.thoughtworks.xstream.converters.javabean.JavaBeanProvider;\nimport com.thoughtworks.xstream.io.xml.TraxSource;\n\nimport org.junit.jupiter.api.Test;\nimport org.xml.sax.XMLReader;\nimport org.xml.sax.helpers.XMLFilterImpl;\n\npublic class BeanProviderTest {\n    @Test\n    void createsBeanWithPublicNoArgsConstructor() {\n        BeanProvider provider = new BeanProvider();\n\n        Object instance = provider.newInstance(TraxSource.class);\n\n        assertThat(instance).isInstanceOf(TraxSource.class);\n    }\n\n    @Test\n    void findsPublicNoArgsConstructor() {\n        ExposedBeanProvider provider = new ExposedBeanProvider();\n\n        Constructor<?> constructor = provider.defaultConstructorFor(TraxSource.class);\n\n        assertThat(constructor).isNotNull();\n        assertThat(constructor.getParameterTypes()).isEmpty();\n    }\n\n    @Test\n    void rejectsVoidType() {\n        BeanProvider provider = new BeanProvider();\n\n        assertThatThrownBy(() -> provider.newInstance(Void.class))\n            .isInstanceOf(ConversionException.class)\n            .hasMessageContaining(\"Security alert\");\n    }\n\n    @Test\n    void visitsReadableAndWritableBeanProperties() {\n        BeanProvider provider = new BeanProvider();\n        TraxSource source = new TraxSource();\n        Map<String, Object> visitedValues = new LinkedHashMap<>();\n\n        provider.visitSerializableProperties(source, new JavaBeanProvider.Visitor() {\n            @Override\n            public boolean shouldVisit(String name, Class definedIn) {\n                return true;\n            }\n\n            @Override\n            public void visit(String name, Class type, Class definedIn, Object value) {\n                visitedValues.put(name, value);\n            }\n        });\n\n        assertThat(visitedValues).containsKey(\"XMLReader\");\n        assertThat(visitedValues.get(\"XMLReader\")).isInstanceOf(XMLReader.class);\n    }\n\n    @Test\n    void writesBeanProperty() {\n        BeanProvider provider = new BeanProvider();\n        TraxSource source = new TraxSource();\n        XMLFilterImpl reader = new XMLFilterImpl();\n\n        provider.writeProperty(source, \"XMLReader\", reader);\n\n        assertThat(source.getXMLReader()).isSameAs(reader);\n    }\n\n    private static final class ExposedBeanProvider extends BeanProvider {\n        @SuppressWarnings(\"deprecation\")\n        private Constructor<?> defaultConstructorFor(Class<?> type) {\n            return getDefaultConstrutor(type);\n        }\n    }\n}\n\n=====\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_thoughtworks_xstream.xstream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamField;\nimport java.util.Map;\n\nimport com.thoughtworks.xstream.core.util.SerializationMembers;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SerializationMembersTest {\n    @Test\n    void invokesReadResolveMethod() {\n        SerializationMembers members = new SerializationMembers();\n        ReadResolvePayload payload = new ReadResolvePayload(\"original\");\n\n        Object resolved = members.callReadResolve(payload);\n\n        assertThat(resolved).isEqualTo(new ResolvedPayload(\"original-resolved\"));\n    }\n\n    @Test\n    void invokesWriteReplaceMethod() {\n        SerializationMembers members = new SerializationMembers();\n        WriteReplacePayload payload = new WriteReplacePayload(\"original\");\n\n        Object replaced = members.callWriteReplace(payload);\n\n        assertThat(replaced).isEqualTo(new ReplacementPayload(\"original-replaced\"));\n    }\n\n    @Test\n    void invokesReadObjectMethod() throws Exception {\n        SerializationMembers members = new SerializationMembers();\n        ReadObjectPayload payload = new ReadObjectPayload();\n\n        assertThat(members.supportsReadObject(ReadObjectPayload.class, false)).isTrue();\n        try (ObjectInputStream stream = objectInputStreamWithUtf(\"stream-value\")) {\n            members.callReadObject(ReadObjectPayload.class, payload, stream);\n        }\n\n        assertThat(payload.getValue()).isEqualTo(\"stream-value\");\n    }\n\n    @Test\n    void invokesWriteObjectMethod() throws Exception {\n        SerializationMembers members = new SerializationMembers();\n        WriteObjectPayload payload = new WriteObjectPayload(\"stream-value\");\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n\n        assertThat(members.supportsWriteObject(WriteObjectPayload.class, false)).isTrue();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            members.callWriteObject(WriteObjectPayload.class, payload, stream);\n        }\n\n        assertThat(payload.wasWritten()).isTrue();\n        try (ObjectInputStream stream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            assertThat(stream.readUTF()).isEqualTo(\"stream-value\");\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"unchecked\")\n    void readsSerializablePersistentFields() {\n        SerializationMembers members = new SerializationMembers();\n\n        Map<String, ObjectStreamField> fields = members.getSerializablePersistentFields(PersistentFieldsPayload.class);\n\n        assertThat(fields).containsOnlyKeys(\"name\", \"count\");\n        assertThat(fields.get(\"name\"))\n            .extracting(ObjectStreamField::getType)\n            .isEqualTo(String.class);\n        assertThat(fields.get(\"count\"))\n            .extracting(ObjectStreamField::getType)\n            .isEqualTo(Integer.TYPE);\n    }\n\n    private static ObjectInputStream objectInputStreamWithUtf(String value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            stream.writeUTF(value);\n        }\n        return new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()));\n    }\n\n    private static final class ReadResolvePayload {\n        private final String value;\n\n        private ReadResolvePayload(String value) {\n            this.value = value;\n        }\n\n        private Object readResolve() {\n            return new ResolvedPayload(value + \"-resolved\");\n        }\n    }\n\n    private static final class ResolvedPayload {\n        private final String value;\n\n        private ResolvedPayload(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof ResolvedPayload)) {\n                return false;\n            }\n            ResolvedPayload that = (ResolvedPayload)other;\n            return value.equals(that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n\n    private static final class WriteReplacePayload {\n        private final String value;\n\n        private WriteReplacePayload(String value) {\n            this.value = value;\n        }\n\n        private Object writeReplace() {\n            return new ReplacementPayload(value + \"-replaced\");\n        }\n    }\n\n    private static final class ReplacementPayload {\n        private final String value;\n\n        private ReplacementPayload(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof ReplacementPayload)) {\n                return false;\n            }\n            ReplacementPayload that = (ReplacementPayload)other;\n            return value.equals(that.value);\n        }\n\n        @Override\n        public int hashCode() {\n            return value.hashCode();\n        }\n    }\n\n    private static final class ReadObjectPayload {\n        private String value;\n\n        private void readObject(ObjectInputStream stream) throws IOException {\n            value = stream.readUTF();\n        }\n\n        private String getValue() {\n            return value;\n        }\n    }\n\n    private static final class WriteObjectPayload {\n        private final String value;\n        private boolean written;\n\n        private WriteObjectPayload(String value) {\n            this.value = value;\n        }\n\n        private void writeObject(ObjectOutputStream stream) throws IOException {\n            written = true;\n            stream.writeUTF(value);\n        }\n\n        private boolean wasWritten() {\n            return written;\n        }\n    }\n\n    private static final class PersistentFieldsPayload {\n        private static final ObjectStreamField[] serialPersistentFields = {\n            new ObjectStreamField(\"name\", String.class),\n            new ObjectStreamField(\"count\", Integer.TYPE)\n        };\n    }\n}\n","exit_code":0,"status":"completed"}}
