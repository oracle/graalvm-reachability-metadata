IgnoringBase|LocationAwareLogger'"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1298, "output": 745, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 33787, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778215347850, "responseId": "resp_07dd2814e5da01200169fd69b466ec81929700bbaa49395935"}}
