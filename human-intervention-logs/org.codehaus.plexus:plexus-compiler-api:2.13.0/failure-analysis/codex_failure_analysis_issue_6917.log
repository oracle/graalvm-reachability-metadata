en.apache.org/maven2/org/codehaus/plexus/plexus-io/$version$/plexus-io-$version$-javadoc.jar\",\nmetadata/org.codehaus.plexus/plexus-io/index.json:9:    \"description\" : \"Plexus IO provides reusable I/O resource abstractions, file selectors, file mappers, and archive or compressed-resource collection utilities for Plexus-based Java applications. It helps tools enumerate, filter, transform, and read file, URL, ZIP, and compressed resources while preserving resource attributes.\",\nmetadata/com.google.truth/truth/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/google/truth/truth/$version$/truth-$version$-sources.jar\",\nmetadata/com.google.truth/truth/index.json:7:    \"test-code-url\" : \"https://github.com/google/truth/tree/release_1_1_3/core/src/test/java?version=$version$\",\nmetadata/com.google.truth/truth/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/google/truth/truth/$version$/truth-$version$-javadoc.jar\",\nmetadata/com.google.truth/truth/index.json:9:    \"description\" : \"Truth is a Java assertion framework that provides fluent assertions and readable failure messages for tests. It includes built-in subjects for common JDK and Guava types and extension points for defining custom assertions.\",\nmetadata/org.codehaus.plexus/plexus-cipher/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-cipher/$version$/plexus-cipher-$version$-sources.jar\",\nmetadata/org.codehaus.plexus/plexus-cipher/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-cipher/$version$/plexus-cipher-$version$-source-release.zip\",\nmetadata/org.codehaus.plexus/plexus-cipher/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-cipher/$version$/plexus-cipher-$version$-javadoc.jar\",\nmetadata/org.codehaus.plexus/plexus-cipher/index.json:9:    \"description\" : \"Plexus Cipher is a Java component for encrypting and decrypting strings with passphrases and Base64-encoded output. It also supports Maven/Plexus-style decorated encrypted values wrapped in braces so callers can detect, decorate, and undecorate stored secrets.\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-graal-ffi-jvm/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/github/ajalt/mordant/mordant-jvm-graal-ffi-jvm/$version$/mordant-jvm-graal-ffi-jvm-$version$-sources.jar\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-graal-ffi-jvm/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-graal-ffi-jvm/index.json:8:    \"documentation-url\" : \"https://github.com/ajalt/mordant/blob/$version$/mordant-jvm-graal-ffi/README.md\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-graal-ffi-jvm/index.json:9:    \"description\" : \"Mordant is a Kotlin multiplatform library for rendering styled terminal output, including colors, tables, widgets, Markdown, input, and animations. The mordant-jvm-graal-ffi-jvm artifact provides Mordant's JVM terminal interface for GraalVM Native Image by binding native terminal functionality through GraalVM foreign function interfaces.\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-graal-ffi-jvm/index.json:10:    \"language\" : {\nmetadata/org.codehaus.plexus/plexus-resources/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-resources/$version$/plexus-resources-$version$-sources.jar\",\nmetadata/org.codehaus.plexus/plexus-resources/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-resources/$version$/plexus-resources-$version$-source-release.zip\",\nmetadata/org.codehaus.plexus/plexus-resources/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-resources/$version$/plexus-resources-$version$-javadoc.jar\",\nmetadata/org.codehaus.plexus/plexus-resources/index.json:9:    \"description\" : \"Plexus Resources provides a component API for locating and loading resources from the filesystem, classpath, JAR files, and URLs. It is used by Plexus-based Java applications and Maven-related tooling to access resources through a common resource manager abstraction.\",\nmetadata/io.prometheus/simpleclient_caffeine/index.json:5:    \"source-code-url\": \"https://repo.maven.apache.org/maven2/io/prometheus/simpleclient_caffeine/$version$/simpleclient_caffeine-$version$-sources.jar\",\nmetadata/io.prometheus/simpleclient_caffeine/index.json:7:    \"test-code-url\": \"https://github.com/prometheus/client_java/tree/parent-$version$/simpleclient_caffeine/src/test/java\",\nmetadata/io.prometheus/simpleclient_caffeine/index.json:8:    \"documentation-url\": \"https://repo.maven.apache.org/maven2/io/prometheus/simpleclient_caffeine/$version$/simpleclient_caffeine-$version$-javadoc.jar\",\nmetadata/io.prometheus/simpleclient_caffeine/index.json:9:    \"description\": \"simpleclient_caffeine adds a Prometheus Java client collector for Caffeine caches. It exports cache statistics such as hits, misses, requests, evictions, estimated size, and load timing as Prometheus metrics labeled by cache name.\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/github/ajalt/mordant/mordant-core-jvm/$version$/mordant-core-jvm-$version$-sources.jar\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:7:    \"test-code-url\" : \"https://github.com/ajalt/mordant/tree/$version$/mordant/src/jvmTest\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/github/ajalt/mordant/mordant-core-jvm/$version$/mordant-core-jvm-$version$-javadoc.jar\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:9:    \"description\" : \"Mordant Core is a Kotlin multiplatform library for rendering styled terminal output, including ANSI colors, text styling, widgets, tables, input handling, and terminal capability detection. The mordant-core-jvm artifact provides the JVM variant of the core APIs for command-line applications that need rich terminal rendering and interaction.\",\nmetadata/com.github.ajalt.mordant/mordant-core-jvm/index.json:10:    \"language\" : {\nmetadata/io.prometheus/simpleclient/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/prometheus/simpleclient/$version$/simpleclient-$version$-sources.jar\",\nmetadata/io.prometheus/simpleclient/index.json:7:    \"test-code-url\" : \"https://github.com/prometheus/client_java/tree/parent-$version$/simpleclient/src/test\",\nmetadata/io.prometheus/simpleclient/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/io/prometheus/simpleclient/$version$/simpleclient-$version$-javadoc.jar\",\nmetadata/io.prometheus/simpleclient/index.json:9:    \"description\" : \"Prometheus Simpleclient is the legacy Java client core used to define and register application metrics such as counters, gauges, histograms, and summaries for Prometheus scraping. It provides the central Collector and CollectorRegistry APIs used by the 0.16.x simpleclient modules while keeping runtime dependencies minimal.\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-xml/$version$/plexus-xml-$version$-sources.jar\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-xml/$version$/plexus-xml-$version$-source-release.zip\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-xml/$version$/plexus-xml-$version$-javadoc.jar\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:9:    \"description\" : \"Plexus XML provides utility classes for reading, writing, and manipulating XML in Maven and Plexus-based projects. It includes XML writer helpers, stream reader and writer utilities, XPP3 DOM support, and XML pull-parser classes.\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:25:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-xml/$version$/plexus-xml-$version$-sources.jar\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:27:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-xml/$version$/plexus-xml-$version$-source-release.zip\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:28:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/codehaus/plexus/plexus-xml/$version$/plexus-xml-$version$-javadoc.jar\",\nmetadata/org.codehaus.plexus/plexus-xml/index.json:29:    \"description\" : \"Plexus XML provides utility classes for reading, writing, and manipulating XML used by Maven and Plexus-based projects. It includes XML writer helpers, stream reader/writer utilities, XPP3 DOM support, and pull-parser classes extracted from the older plexus-utils package.\",\nmetadata/org.apache.hadoop/hadoop-annotations/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/org/apache/hadoop/hadoop-annotations/$version$/hadoop-annotations-$version$-sources.jar\",\nmetadata/org.apache.hadoop/hadoop-annotations/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/org.apache.hadoop/hadoop-annotations/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/apache/hadoop/hadoop-annotations/$version$/hadoop-annotations-$version$-javadoc.jar\",\nmetadata/org.apache.hadoop/hadoop-annotations/index.json:9:    \"description\" : \"Apache Hadoop Annotations provides Java annotations for declaring the intended audience and stability of Hadoop APIs. It also includes doclet tools that include or exclude annotated API elements when generating public or private Javadocs.\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-ffm-jvm/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/github/ajalt/mordant/mordant-jvm-ffm-jvm/$version$/mordant-jvm-ffm-jvm-$version$-sources.jar\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-ffm-jvm/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-ffm-jvm/index.json:8:    \"documentation-url\" : \"https://github.com/ajalt/mordant/blob/$version$/mordant-jvm-ffm/README.md\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-ffm-jvm/index.json:9:    \"description\" : \"Mordant is a Kotlin library for rendering styled terminal output, including colors, tables, widgets, Markdown, input, and animations. The mordant-jvm-ffm-jvm artifact provides Mordant's JVM terminal interface backed by Java's Foreign Function & Memory APIs for native terminal integration on JDK 22 or newer.\",\nmetadata/com.github.ajalt.mordant/mordant-jvm-ffm-jvm/index.json:10:    \"language\" : {\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/io/prometheus/simpleclient_tracer_otel_agent/$version$/simpleclient_tracer_otel_agent-$version$-sources.jar\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:7:    \"test-code-url\" : \"https://github.com/prometheus/client_java/tree/parent-$version$/integration_tests/it_exemplars_otel_agent\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/io/prometheus/simpleclient_tracer_otel_agent/$version$/simpleclient_tracer_otel_agent-$version$-javadoc.jar\",\nmetadata/io.prometheus/simpleclient_tracer_otel_agent/index.json:9:    \"description\" : \"This artifact provides the Prometheus Java client SpanContextSupplier implementation for applications using the OpenTelemetry Java agent. It reads the current O