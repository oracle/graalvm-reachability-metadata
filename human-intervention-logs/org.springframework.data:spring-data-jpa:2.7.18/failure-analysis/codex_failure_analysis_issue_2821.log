e@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 17, true, JpaSampleRole.USER);\\\\\\\\\\\\\\\\n            grace.addPurchase(new JpaSamplePurchase(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"manual\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 25));\\\\\\\\\\\\\\\\n            JpaSampleUser linus = user(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 54, true, JpaSampleRole.USER);\\\\\\\\\\\\\\\\n            JpaSampleUser inactive = user(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 28, false, JpaSampleRole.USER);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            repository.saveAll(Arrays.asList(ada, grace, linus, inactive));\\\\\\\\\\\\\\\\n            repository.flush();\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            assertThat(repository.findByActiveTrueOrderByUsernameAsc())\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            assertThat(repository.findFirstByEmail(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n                    .get()\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getAge)\\\\\\\\\\\\\\\\n                    .isEqualTo(36);\\\\\\\\\\\\\\\\n            assertThat(repository.findUsernamesAtLeastAge(18)).containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            Specification<JpaSampleUser> activeAdults = (root, query, criteriaBuilder) -> criteriaBuilder.and(\\\\\\\\\\\\\\\\n                    criteriaBuilder.isTrue(root.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")),\\\\\\\\\\\\\\\\n                    criteriaBuilder.greaterThanOrEqualTo(root.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"), 18));\\\\\\\\\\\\\\\\n            assertThat(repository.findAll(activeAdults, Sort.by(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"username\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")))\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            JpaSampleUser probe = new JpaSampleUser();\\\\\\\\\\\\\\\\n            probe.setEmail(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            ExampleMatcher matcher = ExampleMatcher.matching()\\\\\\\\\\\\\\\\n                    .withIgnorePaths(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"username\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"purchases\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            assertThat(repository.findAll(Example.of(probe, matcher)))\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            Page<JpaSampleUser> userPage = repository.findByRole(\\\\\\\\\\\\\\\\n                    JpaSampleRole.USER, PageRequest.of(0, 2, Sort.by(Sort.Direction.DESC, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")));\\\\\\\\\\\\\\\\n            assertThat(userPage.getTotalElements()).isEqualTo(3);\\\\\\\\\\\\\\\\n            assertThat(userPage.getContent())\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            assertThat(repository.findByRoleOrderByUsernameAsc(JpaSampleRole.USER))\\\\\\\\\\\\\\\\n                    .extracting(UsernameOnly::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            assertThat(repository.findWithPurchasesByUsername(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n                    .get()\\\\\\\\\\\\\\\\n                    .extracting(user -> user.getPurchases().size())\\\\\\\\\\\\\\\\n                    .isEqualTo(2);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            int updatedRows = repository.deactivateYoungerThan(18);\\\\\\\\\\\\\\\\n            assertThat(updatedRows).isEqualTo(1);\\\\\\\\\\\\\\\\n            assertThat(repository.findFirstByEmail(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n                    .get()\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::isActive)\\\\\\\\\\\\\\\\n                    .isEqualTo(false);\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Test\\\\\\\\\\\\\\\\n    void domainSortHelpersAndJavaTimeConvertersExposeStablePublicBehavior() {\\\\\\\\\\\\\\\\n        JpaSort unsafeSort = JpaSort.unsafe(Sort.Direction.DESC, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n                .andUnsafe(Sort.Direction.ASC, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        assertThat(unsafeSort).extracting(Sort.Order::getProperty)\\\\\\\\\\\\\\\\n                .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        assertThat(unsafeSort.getOrderFor(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").getDirection()).isEqualTo(Sort.Direction.DESC);\\\\\\\\\\\\\\\\n        assertThat(unsafeSort.getOrderFor(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").getDirection()).isEqualTo(Sort.Direction.ASC);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalDateConverter localDateConverter = new Jsr310JpaConverters.LocalDateConverter();\\\\\\\\\\\\\\\\n        LocalDate localDate = LocalDate.of(2024, 2, 29);\\\\\\\\\\\\\\\\n        Date dateColumn = localDateConverter.convertToDatabaseColumn(localDate);\\\\\\\\\\\\\\\\n        assertThat(localDateConverter.convertToEntityAttribute(dateColumn)).isEqualTo(localDate);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalDateTimeConverter localDateTimeConverter =\\\\\\\\\\\\\\\\n                new Jsr310JpaConverters.LocalDateTimeConverter();\\\\\\\\\\\\\\\\n        LocalDateTime localDateTime = LocalDateTime.of(2024, 2, 29, 8, 15, 30);\\\\\\\\\\\\\\\\n        Date dateTimeColumn = localDateTimeConverter.convertToDatabaseColumn(localDateTime);\\\\\\\\\\\\\\\\n        assertThat(localDateTimeConverter.convertToEntityAttribute(dateTimeColumn)).isEqualTo(localDateTime);\\\\\\\\\\\\\\\\n\\\\\\\\\\\