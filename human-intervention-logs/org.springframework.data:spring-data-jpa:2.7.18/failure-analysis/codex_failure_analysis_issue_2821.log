ableTransactionManagement\\\\\\\\\\\\\\\\n    @EnableJpaRepositories(basePackageClasses = Spring_data_jpaTest.class)\\\\\\\\\\\\\\\\n    public static class JpaTestConfiguration {\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        @Bean\\\\\\\\\\\\\\\\n        public DataSource dataSource() {\\\\\\\\\\\\\\\\n            DriverManagerDataSource dataSource = new DriverManagerDataSource();\\\\\\\\\\\\\\\\n            dataSource.setDriverClassName(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"org.h2.Driver\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            dataSource.setUrl(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"jdbc:h2:mem:spring-data-jpa-\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" + System.nanoTime()\\\\\\\\\\\\\\\\n                    + \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\";DB_CLOSE_DELAY=-1;DATABASE_TO_UPPER=false\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            dataSource.setUsername(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sa\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            dataSource.setPassword(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            return dataSource;\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        @Bean\\\\\\\\\\\\\\\\n        public LocalContainerEntityManagerFactoryBean entityManagerFactory(DataSource dataSource) {\\\\\\\\\\\\\\\\n            HibernateJpaVendorAdapter adapter = new HibernateJpaVendorAdapter();\\\\\\\\\\\\\\\\n            adapter.setDatabase(Database.H2);\\\\\\\\\\\\\\\\n            adapter.setGenerateDdl(true);\\\\\\\\\\\\\\\\n            adapter.setShowSql(false);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            Map<String, Object> properties = new HashMap<>();\\\\\\\\\\\\\\\\n            properties.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hibernate.hbm2ddl.auto\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"create-drop\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            properties.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hibernate.dialect\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 