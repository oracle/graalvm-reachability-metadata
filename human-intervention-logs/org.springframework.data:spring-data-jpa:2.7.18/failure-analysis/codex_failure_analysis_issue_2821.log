.findActiveUsernamesWithNativeQuery()).containsExactly(\\\\\\\"ada\\\\\\\", \\\\\\\"linus\\\\\\\");\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    void auditingCallbacksPopulateCreationAndModificationMetadata() {\\\\n        try (AnnotationConfigApplicationContext context =\\\\n                new AnnotationConfigApplicationContext(JpaTestConfiguration.class)) {\\\\n            JpaAuditedDocumentRepository repository = context.getBean(JpaAuditedDocumentRepository.class);\\\\n            MutableAuditorAware auditorAware = context.getBean(MutableAuditorAware.class);\\\\n\\\\n            auditorAware.setCurrentAuditor(\\\\\\\"creator\\\\\\\");\\\\n            JpaAuditedDocument saved = repository.saveAndFlush(new JpaAuditedDocument(\\\\\\\"initial title\\\\\\\"));\\\\n\\\\n            assertThat(saved.getCreatedBy()).isEqualTo(\\\\\\\"creator\\\\\\\");\\\\n            assertThat(saved.getLastModifiedBy()).isEqualTo(\\\\\\\"creator\\\\\\\");\\\\n            assertThat(saved.getCreatedAt()).isNotNull();\\\\n            assertThat(saved.getLastModifiedAt()).isNotNull();\\\\n\\\\n            auditorAware.setCurrentAuditor(\\\\\\\"editor\\\\\\\");\\\\n            saved.setTitle(\\\\\\\"revised title\\\\\\\");\\\\n            JpaAuditedDocument updated = repository.saveAndFlush(saved);\\\\n\\\\n            assertThat(updated.getTitle()).isEqualTo(\\\\\\\"revised title\\\\\\\");\\\\n            assertThat(updated.getCreatedBy()).isEqualTo(\\\\\\\"creator\\\\\\\");\\\\n            assertThat(updated.getLastModifiedBy()).isEqualTo(\\\\\\\"editor\\\\\\\");\\\\n            assertThat(updated.getCreatedAt()).isNotNull();\\\\n            assertThat(updated.getLastModifiedAt()).isNotNull();\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    void domainSortHelpersAndJavaTimeConvertersExposeStablePublicBehavior() {\\\\n        JpaSort unsafeSort = JpaSort.unsafe(Sort.Direction.DESC, \\\\\\\"LENGTH(username)\\\\\\\")\\\\n                .andUnsafe(Sort.Direction.ASC, \\\\\\\"LOWER(