ave received a copy of the CC0 legalcode along with this\\\\\\\\\\\\\\\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\\\\\\\\\\\\\\\n */\\\\\\\\\\\\\\\\npackage org_springframework_data.spring_data_jpa;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport java.time.Instant;\\\\\\\\\\\\\\\\nimport java.time.LocalDate;\\\\\\\\\\\\\\\\nimport java.time.LocalDateTime;\\\\\\\\\\\\\\\\nimport java.time.LocalTime;\\\\\\\\\\\\\\\\nimport java.time.ZoneId;\\\\\\\\\\\\\\\\nimport java.util.ArrayList;\\\\\\\\\\\\\\\\nimport java.util.Arrays;\\\\\\\\\\\\\\\\nimport java.util.Date;\\\\\\\\\\\\\\\\nimport java.util.HashMap;\\\\\\\\\\\\\\\\nimport java.util.List;\\\\\\\\\\\\\\\\nimport java.util.Map;\\\\\\\\\\\\\\\\nimport java.util.Optional;\\\\\\\\\\\\\\\\nimport javax.persistence.CascadeType;\\\\\\\\\\\\\\\\nimport javax.persistence.Entity;\\\\\\\\\\\\\\\\nimport javax.persistence.EntityManagerFactory;\\\\\\\\\\\\\\\\nimport javax.persistence.EnumType;\\\\\\\\\\\\\\\\nimport javax.persistence.Enumerated;\\\\\\\\\\\\\\\\nimport javax.persistence.FetchType;\\\\\\\\\\\\\\\\nimport javax.persistence.GeneratedValue;\\\\\\\\\\\\\\\\nimport javax.persistence.GenerationType;\\\\\\\\\\\\\\\\nimport javax.persistence.Id;\\\\\\\\\\\\\\\\nimport javax.persistence.JoinColumn;\\\\\\\\\\\\\\\\nimport javax.persistence.ManyToOne;\\\\\\\\\\\\\\\\nimport javax.persistence.OneToMany;\\\\\\\\\\\\\\\\nimport javax.persistence.Table;\\\\\\\\\\\\\\\\nimport javax.sql.DataSource;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport org.junit.jupiter.api.Test;\\\\\\\\\\\\\\\\nimport org.springframework.context.annotation.AnnotationConfigApplicationContext;\\\\\\\\\\\\\\\\nimport org.springframework.context.annotation.Bean;\\\\\\\\\\\\\\\\nimport org.springframework.context.annotation.Configuration;\\\\\\\\\\\\\\\\nimport org.springframework.data.domain.Example;\\\\\\\\\\\\\\\\nimport org.springframework.data.domain.ExampleMatcher;\\\\\\\\\\\\\\\\nimport org.springframework.data.domain.Page;\\\\\\\\\\\\\\\\nimport org.springframework.data.domain.PageRequest;\\\\\\\\\\\\\\\\nimport org.springframework.data.domain.Sort;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.convert.threeten.Jsr310JpaConverters;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.domain.JpaSort;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.domain.Specification;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.repository.EntityGraph;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.repository.JpaRepository;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.repository.JpaSpecificationExecutor;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.repository.Modifying;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.repository.Query;\\\\\\\\\\\\\\\\nimport org.springframework.data.jpa.repository.config.EnableJpaRepositories;\\\\\\\\\\\\\\\\nimport org.springframework.data.repository.query.Param;\\\\\\\\\\\\\\\\nimport org.springframework.jdbc.datasource.DriverManagerDataSource;\\\\\\\\\\\\\\\\nimport org.springframework.orm.jpa.JpaTransactionManager;\\\\\\\\\\\\\\\\nimport org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean;\\\\\\\\\\\\\\\\nimport org.springframework.orm.jpa.vendor.Database;\\\\\\\\\\\\\\\\nimport org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter;\\\\\\\\\\\\\\\\nimport org.springframework.transaction.PlatformTransactionManager;\\\\\\\\\\\\\\\\nimport org.springframework.transaction.annotation.EnableTransactionManagement;\\\\\\\\\\\\\\\\nimport org.springframework.transaction.annotation.Transactional;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport static org.assertj.core.api.Assertions.assertThat;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\npublic class Spring_data_jpaTest {\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Test\\\\\\\\\\\\\\\\n    void repositoryProxySupportsCrudQueriesSpecificationsExamplesPagingAndProjections() {\\\\\\\\\\\\\\\\n        try (AnnotationConfigApplicationContext context =\\\\\\\\\\\\\\\\n                new AnnotationConfigApplicationContext(JpaTestConfiguration.class)) {\\\\\\\\\\\\\\\\n            JpaSampleUserRepository repository = context.getBean(JpaSampleUserRepository.class);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            JpaSampleUser ada = user(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 36, true, JpaSampleRole.ADMIN);\\\\\\\\\\\\\\\\n            ada.addPurchase(new JpaSamplePurchase(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"compiler\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 120));\\\\\\\\\\\\\\\\n            ada.addPurchase(new JpaSamplePurchase(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"notebook\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 15));\\\\\\\\\\\\\\\\n            JpaSampleUser grace = user(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 17, true, JpaSampleRole.USER);\\\\\\\\\\\\\\\\n            grace.addPurchase(new JpaSamplePurchase(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"manual\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 25));\\\\\\\\\\\\\\\\n            JpaSampleUser linus = user(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 54, true, JpaSampleRole.USER);\\\\\\\\\\\\\\\\n            JpaSampleUser inactive = user(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 28, false, JpaSampleRole.USER);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            repository.saveAll(Arrays.asList(ada, grace, linus, inactive));\\\\\\\\\\\\\\\\n            repository.flush();\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            assertThat(repository.findByActiveTrueOrderByUsernameAsc())\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            assertThat(repository.findFirstByEmail(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n                    .get()\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getAge)\\\\\\\\\\\\\\\\n                    .isEqualTo(36);\\\\\\\\\\\\\\\\n            assertThat(repository.findUsernamesAtLeastAge(18)).containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            Specification<JpaSampleUser> activeAdults = (root, query, criteriaBuilder) -> criteriaBuilder.and(\\\\\\\\\\\\\\\\n                    criteriaBuilder.isTrue(root.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")),\\\\\\\\\\\\\\\\n                    criteriaBuilder.greaterThanOrEqualTo(root.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"), 18));\\\\\\\\\\\\\\\\n            assertThat(repository.findAll(activeAdults, Sort.by(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"username\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")))\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            JpaSampleUser probe = new JpaSampleUser();\\\\\\\\\\\\\\\\n            probe.setEmail(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            ExampleMatcher matcher = ExampleMatcher.matching()\\\\\\\\\\\\\\\\n                    .withIgnorePaths(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"username\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"purchases\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            assertThat(repository.findAll(Example.of(probe, matcher)))\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            Page<JpaSampleUser> userPage = repository.findByRole(\\\\\\\\\\\\\\\\n                    JpaSampleRole.USER, PageRequest.of(0, 2, Sort.by(Sort.Direction.DESC, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")));\\\\\\\\\\\\\\\\n            assertThat(userPage.getTotalElements()).isEqualTo(3);\\\\\\\\\\\\\\\\n            assertThat(userPage.getContent())\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            assertThat(repository.findByRoleOrderByUsernameAsc(JpaSampleRole.USER))\\\\\\\\\\\\\\\\n                    .extracting(UsernameOnly::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"inactive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            assertThat(repository.findWithPurchasesByUsername(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n                    .get()\\\\\\\\\\\\\\\\n                    .extracting(user -> user.getPurchases().size())\\\\\\\\\\\\\\\\n                    .isEqualTo(2);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            int updatedRows = repository.deactivateYoungerThan(18);\\\\\\\\\\\\\\\\n            assertThat(updatedRows).isEqualTo(1);\\\\\\\\\\\\\\\\n            assertThat(repository.findFirstByEmail(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n                    .get()\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::isActive)\\\\\\\\\\\\\\\\n                    .isEqualTo(false);\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Test\\\\\\\\\\\\\\\\n    void domainSortHelpersAndJavaTimeConvertersExposeStablePublicBehavior() {\\\\\\\\\\\\\\\\n        JpaSort unsafeSort = JpaSort.unsafe(Sort.Direction.DESC, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n                .andUnsafe(Sort.Direction.ASC, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        assertThat(unsafeSort).extracting(Sort.Order::getProperty)\\\\\\\\\\\\\\\\n                .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        assertThat(unsafeSort.getOrderFor(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").getDirection()).isEqualTo(Sort.Direction.DESC);\\\\\\\\\\\\\\\\n        assertThat(unsafeSort.getOrderFor(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").getDirection()).isEqualTo(Sort.Direction.ASC);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalDateConverter localDateConverter = new Jsr310JpaConverters.LocalDateConverter();\\\\\\\\\\\\\\\\n        LocalDate localDate = LocalDate.of(2024, 2, 29);\\\\\\\\\\\\\\\\n        Date dateColumn = localDateConverter.convertToDatabaseColumn(localDate);\\\\\\\\\\\\\\\\n        assertThat(localDateConverter.convertToEntityAttribute(dateColumn)).isEqualTo(localDate);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalDateTimeConverter localDateTimeConverter =\\\\\\\\\\\\\\\\n                new Jsr310JpaConverters.LocalDateTimeConverter();\\\\\\\\\\\\\\\\n        LocalDateTime localDateTime = LocalDateTime.of(2024, 2, 29, 8, 15, 30);\\\\\\\\\\\\\\\\n        Date dateTimeColumn = localDateTimeConverter.convertToDatabaseColumn(localDateTime);\\\\\\\\\\\\\\\\n        assertThat(localDateTimeConverter.convertToEntityAttribute(dateTimeColumn)).isEqualTo(localDateTime);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalTimeConverter localTimeConverter = new Jsr310JpaConverters.LocalTimeConverter();\\\\\\\\\\\\\\\\n        LocalTime localTime = LocalTime.of(8, 15, 30);\\\\\\\\\\\\\\\\n        Date timeColumn = localTimeConverter.convertToDatabaseColumn(localTime);\\\\\\\\\\\\\\\\n        assertThat(localTimeConverter.convertToEntityAttribute(timeColumn)).isEqualTo(localTime);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.InstantConverter instantConverter = new Jsr310JpaConverters.InstantConverter();\\\\\\\\\\\\\\\\n        Instant instant = Instant.parse(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"2024-02-29T08:15:30Z\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        Date instantColumn = instantConverter.convertToDatabaseColumn(instant);\\\\\\\\\\\\\\\\n        assertThat(instantConverter.convertToEntityAttribute(instantColumn)).isEqualTo(instant);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.ZoneIdConverter zoneIdConverter = new Jsr310JpaConverters.ZoneIdConverter();\\\\\\\\\\\\\\\\n        ZoneId zoneId = ZoneId.of(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Europe/Prague\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        String zoneIdColumn = zoneIdConverter.convertToDatabaseColumn(zoneId);\\\\\\\\\\\\\\\\n        assertThat(zoneIdConverter.convertToEntityAttribute(zoneIdColumn)).isEqualTo(zoneId);\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    private static JpaSampleUser user(\\\\\\\\\\\\\\\\n            String username, String email, int age, boolean active, JpaSampleRole role) {\\\\\\\\\\\\\\\\n        JpaSampleUser user = new JpaSampleUser();\\\\\\\\\\\\\\\\n        user.setUsername(username);\\\\\\\\\\\\\\\\n        user.setEmail(email);\\\\\\\\\\\\\\\\n        user.setAge(age);\\\\\\\\\\\\\\\\n        user.setActive(active);\\\\\\\\\\\\\\\\n        user.setRole(role);\\\\\\\\\\\\\\\\n        return user;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Configuration\\\\\\\\\\\\\\\\n    @EnableTransactionManagement\\\\\\\\\\\\\\\\n    @EnableJpaRepositories(basePackageClasses = Spring_data_jpaTest.class)\\\\\\\\\\\\\\\\n    public static class JpaTestConfiguration {\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        @Bean\\\\\\\\\\\\\\\\n        public DataSource dataSource() {\\\\\\\\\\\\\\\\n            DriverManagerDataSource dataSource = new DriverManagerDataSource();\\\\\\\\\\\\\\\\n            dataSource.setDriverClassName(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"org.h2.Driver\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            dataSource.setUrl(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"jdbc:h2:mem:spring-data-jpa-\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" + System.nanoTime()\\\\\\\\\\\\\\\\n                    + \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\";DB_CLOSE_DELAY=-1;DATABASE_TO_UPPER=false\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            dataSource.setUsername(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sa\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            dataSource.setPassword(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            return dataSource;\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        @Bean\\\\\\\\\\\\\\\\n        public LocalContainerEntityManagerFactoryBean entityManagerFactory(DataSource dataSource) {\\\\\\\\\\\\\\\\n            HibernateJpaVendorAdapter adapter = new HibernateJpaVendorAdapter();\\\\\\\\\\\\\\\\n            adapter.setDatabase(Database.H2);\\\\\\\\\\\\\\\\n            adapter.setGenerateDdl(true);\\\\\\\\\\\\\\\\n            adapter.setShowSql(false);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            Map<String, Object> properties = new HashMap<>();\\\\\\\\\\\\\\\\n            properties.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hibernate.hbm2ddl.auto\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"create-drop\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            properties.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hibernate.dialect\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"org.hibernate.dialect.H2Dialect\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            properties.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hibernate.format_sql\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"false\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            properties.put(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hibernate.show_sql\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"false\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            LocalContainerEntityManagerFactoryBean factory = new LocalContainerEntityManagerFactoryBean();\\\\\\\\\\\\\\\\n            factory.setDataSource(dataSource);\\\\\\\\\\\\\\\\n            factory.setJpaVendorAdapter(adapter);\\\\\\\\\\\\\\\\n            factory.setJpaPropertyMap(properties);\\\\\\\\\\\\\\\\n            factory.setPackagesToScan(Spring_data_jpaTest.class.getPackageName());\\\\\\\\\\\\\\\\n            return factory;\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        @Bean\\\\\\\\\\\\\\\\n        public PlatformTransactionManager transactionManager(EntityManagerFactory entityManagerFactory) {\\\\\\\\\\\\\\\\n            return new JpaTransactionManager(entityManagerFactory);\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n}\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ninterface JpaSampleUserRepository extends JpaRepository<JpaSampleUser, Long>, JpaSpecificationExecutor<JpaSampleUser> {\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    List<JpaSampleUser> findByActiveTrueOrderByUsernameAsc();\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    Optional<JpaSampleUser> findFirstByEmail(String email);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    Page<JpaSampleUser> findByRole(JpaSampleRole role, org.springframework.data.domain.Pageable pageable);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    List<UsernameOnly> findByRoleOrderByUsernameAsc(JpaSampleRole role);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Query(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"select u.username from JpaSampleUser u where u.age >= :minimumAge order by u.username\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    List<String> findUsernamesAtLeastAge(@Param(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"minimumAge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") int minimumAge);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @EntityGraph(attributePaths = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"purchases\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    Optional<JpaSampleUser> findWithPurchasesByUsername(String username);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Transactional\\\\\\\\\\\\\\\\n    @Modifying(clearAutomatically = true)\\\\\\\\\\\\\\\\n    @Query(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"update JpaSampleUser u set u.active = false where u.age < :minimumAge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    int deactivateYoungerThan(@Param(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"minimumAge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") int minimumAge);\\\\\\\\\\\\\\\\n}\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ninterface UsernameOnly {\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    String getUsername();\\\\\\\\\\\\\\\\n}\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nenum JpaSampleRole {\\\\\\\\\\\\