) {\\\\\\\\\\\\\\\\n        purchases.add(purchase);\\\\\\\\\\\\\\\\n        purchase.setUser(this);\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n}\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n@Entity(name = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"JpaSamplePurchase\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n@Table(name = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"jpa_sample_purchases\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\nclass JpaSamplePurchase {\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Id\\\\\\\\\\\\\\\\n    @GeneratedValue(strategy = GenerationType.IDENTITY)\\\\\\\\\\\\\\\\n    private Long id;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    private String itemName;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    private int amount;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @ManyToOne(fetch = FetchType.LAZY)\\\\\\\\\\\\\\\\n    @JoinColumn(name = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"user_id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    private JpaSampleUser user;\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    protected JpaSamplePurchase() {\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    JpaSamplePurchase(String itemName, int amount) {\\\\\\\\\\\\\\\\n        this.itemName = itemName;\\\\\\\\\\\\\\\\n        this.amount = amount;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    public Long getId() {\\\\\\\\\\\\\\\\n        return id;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    public String getItemName() {\\\\\\\\\\\\\\\\n        return itemName;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    public int getAmount() {\\\\\\\\\\\\\\\\n        return amount;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    public JpaSampleUser getUser() {\\\\\\\\\\\\\\\\n        return user;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    public void setUser(JpaSampleUser user) {\\\\\\\\\\\\\\\\n        this.user = user;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n}\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\"}], \\\\\\\\\\\\\\\"isError\\\\\\\\\\\\\\\": false, \\\\\\\\\\\\\\\"timestamp\\\\\\