\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        assertThat(unsafeSort).extracting(Sort.Order::getProperty)\\\\\\\\\\\\\\\\n                .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        assertThat(unsafeSort.getOrderFor(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LENGTH(username)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").getDirection()).isEqualTo(Sort.Direction.DESC);\\\\\\\\\\\\\\\\n        assertThat(unsafeSort.getOrderFor(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"LOWER(email)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").getDirection()).isEqualTo(Sort.Direction.ASC);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalDateConverter localDateConverter = new Jsr310JpaConverters.LocalDateConverter();\\\\\\\\\\\\\\\\n        LocalDate localDate = LocalDate.of(2024, 2, 29);\\\\\\\\\\\\\\\\n        Date dateColumn = localDateConverter.convertToDatabaseColumn(localDate);\\\\\\\\\\\\\\\\n        assertThat(localDateConverter.convertToEntityAttribute(dateColumn)).isEqualTo(localDate);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalDateTimeConverter localDateTimeConverter =\\\\\\\\\\\\\\\\n                new Jsr310JpaConverters.LocalDateTimeConverter();\\\\\\\\\\\\\\\\n        LocalDateTime localDateTime = LocalDateTime.of(2024, 2, 29, 8, 15, 30);\\\\\\\\\\\\\\\\n        Date dateTimeColumn = localDateTimeConverter.convertToDatabaseColumn(localDateTime);\\\\\\\\\\\\\\\\n        assertThat(localDateTimeConverter.convertToEntityAttribute(dateTimeColumn)).isEqualTo(localDateTime);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.LocalTimeConverter localTimeConverter = new Jsr310JpaConverters.LocalTimeConverter();\\\\\\\\\\\\\\\\n        LocalTime localTime = LocalTime.of(8, 15, 30);\\\\\\\\\\\\\\\\n        Date timeColumn = localTimeConverter.convertToDatabaseColumn(localTime);\\\\\\\\\\\\\\\\n        assertThat(localTimeConverter.convertToEntityAttribute(timeColumn)).isEqualTo(localTime);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.InstantConverter instantConverter = new Jsr310JpaConverters.InstantConverter();\\\\\\\\\\\\\\\\n        Instant instant = Instant.parse(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"2024-02-29T08:15:30Z\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        Date instantColumn = instantConverter.convertToDatabaseColumn(instant);\\\\\\\\\\\\\\\\n        assertThat(instantConverter.convertToEntityAttribute(instantColumn)).isEqualTo(instant);\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        Jsr310JpaConverters.ZoneIdConverter zoneIdConverter = new Jsr310JpaConverters.ZoneIdConverter();\\\\\\\\\\\\\\\\n        ZoneId zoneId = ZoneId.of(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Europe/Prague\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n        String zoneIdColumn = zoneIdConverter.convertToDatabaseColumn(zoneId);\\\\\\\\\\\\\\\\n        assertThat(zoneIdConverter.convertToEntityAttribute(zoneIdColumn)).isEqualTo(zoneId);\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    private static JpaSampleUser user(\\\\\\\\\\\\\\\\n            String username, String email, int age, boolean active, JpaSampleRole role) {\\\\\\\\\\\\\\\\n        JpaSampleUser user = new JpaSampleUser();\\\\\\\\\\\\\\\\n        user.setUsername(username);\\\\\\\\\\\\\\\\n        user.setEmail(email);\\\\\\\\\\\\\\\\n        user.setAge(age);\\\\\\\\\\\\\\\\n        user.setActive(active);\\\\\\\\\\\\\\\\n        user.setRole(role);\\\\\\\\\\\\\\\\n        return user;\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @Configuration\\\\\\\\\\\\\\\\n    @EnableTransactionManagement\\\\\\\\\\\\\\\\n    @EnableJpaRepositories(basePackageClasses = Spring_data_jpaTest.class)\\\\\\\\\\\\\\\\n    public static class JpaTestConfiguration {\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        @Bean\\\\\\\\\\\\\\\\n        public DataSource dataSource() {\\\\\