e\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"), 18));\\\\\\\\\\\\\\\\n            assertThat(repository.findAll(activeAdults, Sort.by(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"username\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")))\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ada\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"linus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            JpaSampleUser probe = new JpaSampleUser();\\\\\\\\\\\\\\\\n            probe.setEmail(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace@example.org\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            ExampleMatcher matcher = ExampleMatcher.matching()\\\\\\\\\\\\\\\\n                    .withIgnorePaths(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"username\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"purchases\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n            assertThat(repository.findAll(Example.of(probe, matcher)))\\\\\\\\\\\\\\\\n                    .extracting(JpaSampleUser::getUsername)\\\\\\\\\\\\\\\\n                    .containsExactly(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\");\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            Page<JpaSampleUser> userPage = repository.findByRole(\\\\\\\\\\\\\\\\n                    JpaSampleRole.USER, PageRequest.of(0, 2, Sort.by(Sort.Direction.DESC, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"age\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")));\\\\\\\\\\\\\\\\n            assertThat(userPage.getTotalElements()).isEqualTo(3);\\\\\\\\\\\\\\\\n            assertThat(userPage.getContent())\\\\\\\\\\\\\\\\n                    .extracting