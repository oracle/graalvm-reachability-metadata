itedDocumentRepository repository = context.getBean(JpaAuditedDocumentRepository.class);\n            MutableAuditorAware auditorAware = context.getBean(MutableAuditorAware.class);\n\n            auditorAware.setCurrentAuditor(\"creator\");\n            JpaAuditedDocument saved = repository.saveAndFlush(new JpaAuditedDocument(\"initial title\"));\n\n            assertThat(saved.getCreatedBy()).isEqualTo(\"creator\");\n            assertThat(saved.getLastModifiedBy()).isEqualTo(\"creator\");\n            assertThat(saved.getCreatedAt()).isNotNull();\n            assertThat(saved.getLastModifiedAt()).isNotNull();\n\n            auditorAware.setCurrentAuditor(\"editor\");\n            saved.setTitle(\"revised title\");\n            JpaAuditedDocument updated = repository.saveAndFlush(saved);\n\n            assertThat(updated.getTitle()).isEqualTo(\"revised title\");\n            assertThat(updated.getCreatedBy()).isEqualTo(\"creator\");\n            assertThat(updated.getLastModifiedBy()).isEqualTo(\"editor\");\n            assertThat(updated.getCreatedAt()).isNotNull();\n            assertThat(updated.getLastModifiedAt()).isNotNull();\n        }\n    }\n\n    @Test\n    void domainSortHelpersAndJavaTimeConvertersExposeStablePublicBehavior() {\n"}, {"oldText": "    @Configuration\n    @EnableTransactionManagement\n    @EnableJpaRepositories(basePackageClasses = Spring_data_jpaTest.class)\n    public static class JpaTestConfiguration {\n", "newText": "    @Configuration\n    @EnableTransactionManagement\n    @EnableJpaAuditing\n    @EnableJpaRepositories(basePackageClasses = Spring_data_jpaTest.class)\n    public static class JpaTestConfiguration {\n"}, {"oldText": "        @Bean\n        public PlatformTransactionManager transactionManager(EntityManagerFactory entityManagerFactory) {\n            return new JpaTransactionManager(entityManagerFactory);\n        }\n", "newText": "        @Bean\n        public MutableAuditorAware auditorAware() {\n            return new MutableAuditorAware();\n        }\n\n        @Bean\n        public PlatformTransactionManager transactionManager(EntityManagerFactory entityManagerFactory) {\n            return new JpaTransactionManager(entityManagerFactory);\n        }\n"}, {"oldText": "interface UsernameOnly {\n\n    String getUsername();\n}\n", "newText": "interface JpaAuditedDocumentRepository extends JpaRepository<JpaAuditedDocument, Long> {\n}\n\ninterface UsernameOnly {\n\n    String getUsername();\n}\n"}, {"oldText": "enum JpaSampleRole {\n    ADMIN,\n    USER\n}\n", "newText": "enum JpaSampleRole {\n    ADMIN,\n    USER\n}\n\nclass MutableAuditorAware implements AuditorAware<String> {\n\n    private String currentAuditor = \"auditor\";\n\n    @Override\n    public Optional<String> getCurrentAuditor() {\n        return Optional.of(currentAuditor);\n    }\n\n    void setCurrentAuditor(String currentAuditor) {\n        this.currentAuditor = currentAuditor;\n    }\n}\n\n@Entity(name = \"JpaAuditedDocument\")\n@EntityListeners(AuditingEntityListener.class)\n@Table(name = \"jpa_audited_documents\")\nclass JpaAuditedDocument {\n\n    @Id\n    @GeneratedValue(strategy = GenerationType.IDENTITY)\n    private Long id;\n\n    private String title;\n\n    @CreatedBy\n    private String createdBy;\n\n    @LastModifiedBy\n    private String lastModifiedBy;\n\n    @CreatedDate\n    private Instant createdAt;\n\n    @LastModifiedDate\n    private Instant lastModifiedAt;\n\n    protected JpaAuditedDocument() {\n    }\n\n    JpaAuditedDocument(String title) {\n        this.title = title;\n    }\n\n    public Long getId() {\n        return id;\n    }\n\n    public String getTitle() {\n        return title;\n    }\n\n    public void setTitle(String title) {\n        this.title = title;\n    }\n\n    public String getCreatedBy() {\n        return createdBy;\n    }\n\n    public String getLastModifiedBy() {\n        return lastModifiedBy;\n    }\n\n    public Instant getCreatedAt() {\n        return createdAt;\n