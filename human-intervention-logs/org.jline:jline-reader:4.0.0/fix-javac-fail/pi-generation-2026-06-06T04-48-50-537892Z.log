    Completer sub = completers.get(idx);\n            List<? extends CharSequence> args = line.words();\n            String arg = (args == null || i >= args.size()) ? \"\" : args.get(i).toString();\n\n            List<Candidate> subCandidates = new LinkedList<>();\n            sub.complete(reader, new ArgumentLine(arg, arg.length()), subCandidates);\n\n            boolean found = false;\n            for (Candidate cand : subCandidates) {\n                if (cand.value().equals(arg)) {\n                    found = true;\n                    break;\n                }\n            }\n            if (!found) {\n                return;\n            }\n        }\n\n        completer.complete(reader, line, candidates);\n    }\n\n    /**\n     * A simple implementation of ParsedLine for argument completion.\n     * <p>\n     * This class represents a single word with a cursor position, used for\n     * completing arguments in the ArgumentCompleter.\n     * </p>\n     */\n    public static class ArgumentLine implements ParsedLine {\n        private final String word;\n        private final int cursor;\n\n        /**\n         * Creates a new ArgumentLine with the specified word and cursor position.\n         *\n         * @param word the word being completed\n         * @param cursor the cursor position within the word\n         */\n        public ArgumentLine(String word, int cursor) {\n            this.word = word;\n            this.cursor = cursor;\n        }\n\n        @Override\n        public String word() {\n            return word;\n        }\n\n        @Override\n        public int wordCursor() {\n            return cursor;\n        }\n\n        @Override\n        public int wordIndex() {\n            return 0;\n        }\n\n        @Override\n        public List<String> words() {\n            return Collections.singletonList(word);\n        }\n\n        @Override\n        public String line() {\n            return word;\n        }\n\n        @Override\n        public int cursor() {\n            return cursor;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780721295293}}
