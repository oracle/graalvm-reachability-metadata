nput = new PipedInputStream(nanoWriter);\\n                Terminal terminal = TerminalBuilder.builder()\\n                        .name(\\\"jline-edit-buffer-test\\\")\\n                        .system(false)\\n                        .dumb(true)\\n                        .streams(nanoInput, terminalOutput)\\n                        .encoding(StandardCharsets.UTF_8)\\n                        .size(new Size(80, 24))\\n                        .build()) {\\n            Thread exitNanoThread = new Thread(() -> requestNanoExitUntilClosed(nanoWriter, editorClosed),\\n                    \\\"jline-nano-exit-input\\\");\\n            exitNanoThread.setDaemon(true);\\n            exitNanoThread.start();\\n            LineReader reader = LineReaderBuilder.builder()\\n                    .terminal(terminal)\\n                    .parser(new DefaultParser())\\n                    .build();\\n\\n            reader.editAndAddInBuffer(commandFile);\\n            editorClosed.set(true);\\n            exitNanoThread.join(1_000);\\n\\n            assertThat(reader.readLine()).isEqualTo(\\\"status\\\");\\n            assertThat(reader.readLine()).isEqualTo(\\\"checkout main\\\");\\n        } finally {\\n            editorClosed.set(true);\\n        }\\n\\n        assertThat(Files.readString(commandFile, StandardCharsets.UTF_8)).isEqualTo(\\\"status\\\\ncheckout main\\\\n\\\");\\n        assertThat(terminalOutput.toString(StandardCharsets.UTF_8)).contains(\\\"status\\\", \\\"checkout main\\\");\\n    }\\n\\n    private static void requestNanoExitUntilClosed(PipedOutputStream nanoWriter, AtomicBoolean editorClosed) {\\n        byte[] exitKey = KeyMap.ctrl('X').getBytes(StandardCharsets.UTF_8);\\n        try {\\n            while (!editorClosed.get()) {\\n                nanoWriter.write(exitKey);\\n                nanoWriter.flush();\\n                Thread.sleep(100);\\n            }\\n        } catch (IOException e) {\\n            editorClosed.set(true);\\n        } catch (Interrup