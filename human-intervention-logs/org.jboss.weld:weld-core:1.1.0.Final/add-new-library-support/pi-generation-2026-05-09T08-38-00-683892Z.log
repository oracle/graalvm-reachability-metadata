\n */\npackage org_jboss_weld.weld_core;\n\nimport org.jboss.weld.bean.proxy.AbstractBeanInstance;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\npublic class AbstractBeanInstanceTest {\n\n    @Test\n    void invokesSuppliedMethodOnCurrentBeanInstance() throws Throwable {\n        final GreetingService service = new GreetingService(\"hello\");\n        final ExposedBeanInstance beanInstance = new ExposedBeanInstance(service);\n        final Method method = GreetingService.class.getMethod(\"greet\", String.class);\n\n        final Object result = beanInstance.invoke(beanInstance.getInstance(), method, \"weld\");\n\n        assertEquals(\"hello, weld\", result);\n    }\n\n    @Test\n    void unwrapsInvocationTargetExceptionCause() throws Exception {\n        final GreetingService service = new GreetingService(\"unused\");\n        final ExposedBeanInstance beanInstance = new ExposedBeanInstance(service);\n        final Method method = GreetingService.class.getMethod(\"fail\");\n\n        final IllegalStateException exception = assertThrows(IllegalStateException.class,\n                () -> beanInstance.invoke(beanInstance.getInstance(), method));\n\n        assertEquals(\"boom\", exception.getMessage());\n    }\n\n    public static class GreetingService {\n        private final String greeting;\n\n        public GreetingService(String greeting) {\n            this.greeting = greeting;\n        }\n\n        public String greet(String name) {\n            return greeting + \", \" + name;\n        }\n\n        public void fail() {\n            throw new IllegalStateException(\"boom\");\n        }\n    }\n\n    private static class ExposedBeanInstance extends AbstractBeanInstance {\n        private final GreetingService service;\n\n        ExposedBeanInstance(GreetingService service) {\n            this.service = service;\n        }\n\n        @Override\n        public Object getInstance() {\n            return service;\n        }\n\n        @Override\n        public Class<?> getInstanceType() {\n            return service.getClass();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1760, "output": 1077, "cacheRead": 11776, "cacheWrite": 0, "totalTokens": 14613, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778315858167, "responseId": "resp_07cc3e87a82c8a8b0169fef2528d9c81968e9987b739a4bb4d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_dY8D48HgJOcAz2OUpw1HtRzu|fc_07cc3e87a82c8a8b0169fef25c4c4c8196bb8ed15f2967c987", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2410 bytes to tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/AbstractBeanInstanceTest.java"}], "isError": false, "timestamp": 1778315870724}]}
