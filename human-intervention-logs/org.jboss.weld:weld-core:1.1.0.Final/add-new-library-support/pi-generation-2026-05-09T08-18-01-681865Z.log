     public Namespace getRootNamespace()
     {
        // TODO I don't like this lazy init
        if (rootNamespace == null)
        {
           rootNamespace = new Namespace(createDynamicAccessibleIterable(new NamespaceTransform()));
        }
        return rootNamespace;
