rg.junit.jupiter.api.Test;\n\nimport javax.enterprise.context.spi.CreationalContext;\n\nimport java.util.Collections;\n\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class WeldInterceptorInstantiatorTest {\n\n    @Test\n    void createsClassMetadataInterceptorWithNoArgumentConstructor() {\n        final BeanManagerImpl beanManager = beanManager();\n        final CreationalContext<CountingInterceptor> creationalContext = beanManager.createCreationalContext(null);\n        final WeldInterceptorInstantiator<CountingInterceptor> instantiator = new WeldInterceptorInstantiator<>(\n                beanManager, creationalContext);\n\n        final CountingInterceptor interceptor = instantiator.createFor(new TestInterceptorReference(\n                new TestClassMetadata()));\n\n        assertNotNull(interceptor);\n        assertTrue(interceptor.wasConstructed());\n    }\n\n    private static BeanManagerImpl beanManager() {\n        final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();\n        final ClassTransformer classTransformer = new ClassTransformer(new TypeStore());\n        serviceRegistry.add(ClassTransformer.class, classTransformer);\n        final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager(\"weld-interceptor-instantiator-test\",\n                serviceRegistry, Enabled.EMPTY_ENABLED);\n        Container.initialize(beanManager, serviceRegistry);\n        serviceRegistry.add(InjectionTargetValidator.class, new InjectionTargetValidator(beanManager));\n        return beanManager;\n    }\n\n    public static class CountingInterceptor {\n        private final boolean constructed;\n\n        public CountingInterceptor() {\n            this.constructed = true;\n        }\n\n        boolean wasConstructed() {\n            return constructed;\n        }\n    }\n\n    private static class TestInterceptorReference implements InterceptorReference<Object> {\n        private final ClassMetadata<CountingInterceptor> classMetadata;\n\n        TestInterceptorReference(ClassMetadata<CountingInterceptor> classMetadata) {\n            this.classMetadata = classMetadata;\n        }\n\n        @Override\n        public Object getInterceptor() {\n            return classMetadata;\n        }\n\n        @Override\n        public ClassMetadata<?> getClassMetadata() {\n            return classMetadata;\n        }\n    }\n\n    private static class TestClassMetadata implements ClassMetadata<CountingInterceptor> {\n        @Override\n        public Iterable<MethodMetadata> getDeclaredMethods() {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public Class<CountingInterceptor> getJavaClass() {\n            return CountingInterceptor.class;\n        }\n\n        @Override\n        public String getClassName() {\n            return CountingInterceptor.class.getName();\n        }\n\n        @Override\n        public ClassMetadata<?> getSuperclass() {\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1071, "output": 1092, "cacheRead": 50176, "cacheWrite": 0, "totalTokens": 52339, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778314644353, "responseId": "resp_099fb7afd1de81d90169feed94fbdc8195a1be4173ef0c6fd5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_h0pfKs7LIKYgVXotBjq2AY8h|fc_099fb7afd1de81d90169feed99419081959ed47d3a8de9a49d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3823 bytes to tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/WeldInterceptorInstantiatorTest.java"}], "isError": false, "timestamp": 1778314655079}]}
