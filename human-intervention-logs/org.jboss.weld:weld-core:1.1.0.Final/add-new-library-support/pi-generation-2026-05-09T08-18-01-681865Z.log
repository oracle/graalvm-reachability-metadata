  package org_jboss_weld.weld_core;
  
  import org.jboss.weld.bean.SessionBean;
  import org.jboss.weld.bootstrap.api.ServiceRegistry;
  import org.jboss.weld.bootstrap.api.helpers.SimpleServiceRegistry;
  import org.jboss.weld.ejb.InternalEjbDescriptor;
  import org.jboss.weld.ejb.spi.BusinessInterfaceDescriptor;
  import org.jboss.weld.ejb.spi.EjbDescriptor;
  import org.jboss.weld.introspector.WeldClass;
  import org.jboss.weld.manager.BeanManagerImpl;
  import org.jboss.weld.manager.Enabled;
  import org.jboss.weld.metadata.TypeStore;
  import org.jboss.weld.resources.ClassTransformer;
  import org.junit.jupiter.api.Test;
  
  import javax.enterprise.event.Observes;
  
  import java.lang.reflect.Method;
  import java.lang.reflect.Type;
  import java.util.Collection;
  import java.util.Collections;
  import java.util.LinkedHashSet;
  import java.util.Set;
  
  import static org.junit.jupiter.api.Assertions.assertDoesNotThrow;
  
  public class SessionBeanTest {
  
      @Test
      void validatesObserverMethodsAgainstLocalAndRemoteBusinessInterfaces() {
          final ClassTransformer classTransformer = new ClassTransformer(new TypeStore());
          try {
              final WeldClass<ObserverSessionBean> weldClass = classTransformer.loadClass(ObserverSessionBean.class);
              final ExposedSessionBean sessionBean = new ExposedSessionBean(
                      weldClass,
                      new InternalEjbDescriptor<>(new TestEjbDescriptor()),
                      beanManager(),
                      new SimpleServiceRegistry());
  
              assertDoesNotThrow(sessionBean::verifyObserverMethods);
          } finally {
              classTransformer.cleanup();
          }
      }
  
      private static BeanManagerImpl beanManager() {
          final ServiceRegistry serviceRegistry = new SimpleServiceRegistry();
          return BeanManagerImpl.newRootManager("session-bean-test", serviceRegistry, Enabled.EMPTY_ENABLED);
      }
  
      public interface LocalBusinessInterface {
          void localBusinessMethod();
      }
  
      public interface RemoteBusinessInterface {
          void remoteBusinessMethod();
      }
  
      public static class ObserverSessionBean implements LocalBusinessInterface, RemoteBusinessInterface {
          @Override
          public void localBusinessMethod() {
          }
  
          @Override
          public void remoteBusinessMethod() {
          }
  
          public static void observes(@Observes Object event) {
          }
      }
  
      private static class ExposedSessionBean extends SessionBean<ObserverSessionBean> {
          ExposedSessionBean(WeldClass<ObserverSessionBean> type, InternalEjbDescriptor<ObserverSessionBean> ejbDescriptor,
                  BeanManagerImpl manager, ServiceRegistry services) {
              super(type, ejbDescriptor, "session-bean-test", manager, services);
          }
  
          void verifyObserverMethods() {
              checkObserverMethods();
          }
  
          @Override
          protected void initStereotypes() {
          }
  
          @Override
          protected void initAlternative() {
          }
  
          @Override
          protected void initInitializerMethods() {
          }
  
          @Override
          protected void initInjectableFields() {
          }
  
          @Override
          protected void initType() {
              this.type = getWeldAnnotated().getJavaClass();
          }
  
          @Override
          protected void initTypes() {
              final Set<Type> beanTypes = new LinkedHashSet<>();
              beanTypes.add(LocalBusinessInterface.class);
              beanTypes.add(RemoteBusinessInterface.class);
              beanTypes.add(Object.class);
              this.types = beanTypes;
          }
  
          @Override
          protected void initQualifiers() {
              this.qualifiers = Collections.emptySet();
          }
  
          @Override
          protected void initConstructor() {
          }
      }
  
      private static class TestEjbDescriptor implements EjbDescriptor<ObserverSessionBean> {
          @Override
          public Class<ObserverSessionBean> getBeanClass() {
              return ObserverSessionBean.class;
          }
  
          @Override
          public Collection<BusinessInterfaceDescriptor<?>> getLocalBusinessInterfaces() {
              return Collections.<BusinessInterfaceDescriptor<?>>singleton(new TestBusinessInterfaceDescriptor<>(
                      LocalBusinessInterface.class));
          }
  
          @Override
          public Collection<BusinessInterfaceDescriptor<?>> getRemoteBusinessInterfaces() {
