\n        } finally {\n            classTransformer.cleanup();\n        }\n    }\n\n    private static BeanManagerImpl beanManager() {\n        final ServiceRegistry serviceRegistry = new SimpleServiceRegistry();\n        return BeanManagerImpl.newRootManager(\"session-bean-test\", serviceRegistry, Enabled.EMPTY_ENABLED);\n    }\n\n    public interface LocalBusinessInterface {\n        void localBusinessMethod();\n    }\n\n    public interface RemoteBusinessInterface {\n        void remoteBusinessMethod();\n    }\n\n    public static class ObserverSessionBean implements LocalBusinessInterface, RemoteBusinessInterface {\n        @Override\n        public void localBusinessMethod() {\n        }\n\n        @Override\n        public void remoteBusinessMethod() {\n        }\n\n        public static void observes(@Observes Object event) {\n        }\n    }\n\n    private static class ExposedSessionBean extends SessionBean<ObserverSessionBean> {\n        ExposedSessionBean(WeldClass<ObserverSessionBean> type, InternalEjbDescriptor<ObserverSessionBean> ejbDescriptor,\n                BeanManagerImpl manager, ServiceRegistry services) {\n            super(type, ejbDescriptor, \"session-bean-test\", manager, services);\n        }\n\n        void checkObserverMethods() {\n            super.checkObserverMethods();\n        }\n\n        @Override\n        protected void initStereotypes() {\n        }\n\n        @Override\n        protected void initAlternative() {\n        }\n\n        @Override\n        protected void initInitializerMethods() {\n        }\n\n        @Override\n        protected void initInjectableFields() {\n        }\n\n        @Override\n        protected void initType() {\n            this.type = getWeldAnnotated().getJavaClass();\n        }\n\n        @Override\n        protected void initTypes() {\n            final Set<Type> beanTypes = new LinkedHashSet<>();\n            beanTypes.add(LocalBusinessInterface.class);\n            beanTypes.add(RemoteBusinessInterface.class);\n            beanTypes.add(Object.class);\n            this.types = beanTypes;\n        }\n\n        @Override\n        protected void initQualifiers() {\n            this.qualifiers = Collections.emptySet();\n        }\n\n        @Override\n        protected void initConstructor() {\n        }\n    }\n\n    private static class TestEjbDescriptor implements EjbDescriptor<ObserverSessionBean> {\n        @Override\n        public Class<ObserverSessionBean> getBeanClass() {\n            return ObserverSessionBean.class;\n        }\n\n        @Override\n        public Collection<BusinessInterfaceDescriptor<?>> getLocalBusinessInterfaces() {\n            return Collections.<BusinessInterfaceDescriptor<?>>singleton(new TestBusinessInterfaceDescriptor<>(\n                    LocalBusinessInterface.class));\n        }\n\n        @Override\n        public Collection<BusinessInterfaceDescriptor<?>> getRemoteBusinessInterfaces() {\n            return Collections.<BusinessInterfaceDescriptor<?>>singleton(new TestBusinessInterfaceDescriptor<>(\n                    RemoteBusinessInterface.class));\n        }\n\n        @Override\n        public String getEjbName() {\n            return \"observer-session-bean\";\n        }\n\n        @Override\n        public Collection<Method> getRemoveMethods() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public boolean isStateless() {\n            return true;\n        }\n\n        @Override\n        public boolean isSingleton() {\n            return false;\n        }\n\n        @Override\n        public boolean isStateful() {\n            return false;\n        }\n\n        @Override\n        public boolean isMessageDriven() {\n            return false;\n        }\n    }\n\n    private static class TestBusinessInterfaceDescriptor<T> implements BusinessInterfaceDescriptor<T> {\n        private final Class<T> businessInterface;\n\n        TestBusinessInterfaceDescriptor(Class<T> businessInterface) {\n            this.businessInterface = businessInterface;\n        }\n\n        @Override\n        public Class<T> getInterface() {\n            return businessInterface;\n        }\n    }\n}\n"}
