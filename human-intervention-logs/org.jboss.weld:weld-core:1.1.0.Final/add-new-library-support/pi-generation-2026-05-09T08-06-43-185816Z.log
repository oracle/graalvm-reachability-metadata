  package org_jboss_weld.weld_core;
  
  import javassist.bytecode.AccessFlag;
  import javassist.bytecode.ClassFile;
  import javassist.bytecode.MethodInfo;
  import org.jboss.weld.Container;
  import org.jboss.weld.bean.proxy.InterceptedSubclassFactory;
  import org.jboss.weld.bootstrap.api.helpers.SimpleServiceRegistry;
  import org.jboss.weld.introspector.MethodSignature;
  import org.jboss.weld.introspector.jlr.MethodSignatureImpl;
  import org.jboss.weld.manager.BeanManagerImpl;
  import org.jboss.weld.manager.Enabled;
  import org.jboss.weld.serialization.spi.ProxyServices;
  import org.junit.jupiter.api.BeforeAll;
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Method;
  import java.lang.reflect.Type;
  import java.util.HashSet;
  import java.util.LinkedHashSet;
  import java.util.List;
  import java.util.Set;
  
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class InterceptedSubclassFactoryTest {
  
      @BeforeAll
      static void initializeWeldContainer() {
          final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();
          serviceRegistry.add(ProxyServices.class, new TestProxyServices());
          final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager("intercepted-subclass-factory-test",
                  serviceRegistry, Enabled.EMPTY_ENABLED);
          Container.initialize(beanManager, serviceRegistry);
      }
  
      @Test
      void buildsInterceptedSubclassMethodsForBeanHierarchySpecialInterfacesAndBusinessInterfaces() throws Exception {
          final ExposedInterceptedSubclassFactory factory = new ExposedInterceptedSubclassFactory();
          final ClassFile subclass = new ClassFile(false, generatedSubclassName(), InterceptedBean.class.getName());
          subclass.setVersionToJava5();
          subclass.setAccessFlags(AccessFlag.PUBLIC);
  
          factory.addInterceptedMethods(subclass);
  
          final List<MethodInfo> generatedMethods = subclass.getMethods();
          assertContainsMethod(generatedMethods, "businessMethod");
          assertContainsMethod(generatedMethods, "businessMethod$$super");
          assertContainsMethod(generatedMethods, "superclassMethod");
          assertContainsMethod(generatedMethods, "superclassMethod$$super");
          assertContainsMethod(generatedMethods, "interfaceOperation");
          assertContainsMethod(generatedMethods, "getTargetInstance");
          assertContainsMethod(generatedMethods, "getTargetClass");
          assertContainsMethod(generatedMethods, "setHandler");
          assertContainsMethod(generatedMethods, "getHandler");
      }
  
      private static void assertContainsMethod(List<MethodInfo> methods, String methodName) {
          assertTrue(methods.stream().anyMatch(method -> method.getName().equals(methodName)),
                  () -> "Expected generated method " + methodName + " in " + methods);
      }
  
      private static String generatedSubclassName() {
          return InterceptedSubclassFactoryTest.class.getPackage().getName() + ".GeneratedInterceptedSubclassCoverage";
      }
  
      private static Set<Type> interceptedTypes() {
          final Set<Type> types = new LinkedHashSet<>();
          types.add(InterceptedBean.class);
          types.add(BusinessInterface.class);
          return types;
      }
  
      private static Set<MethodSignature> enhancedMethodSignatures() {
  
