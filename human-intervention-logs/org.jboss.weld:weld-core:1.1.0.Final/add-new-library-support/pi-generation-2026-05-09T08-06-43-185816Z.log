  package org_jboss_weld.weld_core;
  
  import org.jboss.weld.introspector.WeldClass;
  import org.jboss.weld.introspector.jlr.WeldFieldImpl;
  import org.jboss.weld.metadata.TypeStore;
  import org.jboss.weld.resources.ClassTransformer;
  import org.junit.jupiter.api.Test;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  
  public class WeldFieldImplTest {
  
      @Test
      void readsAndWritesFieldValuesThroughWeldFieldAbstraction() throws Exception {
          final ClassTransformer classTransformer = new ClassTransformer(new TypeStore());
          try {
              final FieldHolder holder = new FieldHolder();
              final WeldFieldImpl<String, FieldHolder> field = weldField(classTransformer);
  
              field.set(holder, "set-value");
  
              assertEquals("set-value", holder.value);
              assertEquals("set-value", field.get(holder));
  
              field.setOnInstance(holder, "instance-value");
  
              assertEquals("instance-value", holder.value);
              assertEquals("instance-value", field.get(holder));
          } finally {
              classTransformer.cleanup();
          }
      }
  
      @SuppressWarnings("unchecked")
      private static WeldFieldImpl<String, FieldHolder> weldField(ClassTransformer classTransformer) {
          final WeldClass<FieldHolder> weldClass = classTransformer.loadClass(FieldHolder.class);
          return (WeldFieldImpl<String, FieldHolder>) weldClass.<String>getDeclaredWeldField("value");
      }
  
      public static class FieldHolder {
          public String value = "initial";
      }
  }
