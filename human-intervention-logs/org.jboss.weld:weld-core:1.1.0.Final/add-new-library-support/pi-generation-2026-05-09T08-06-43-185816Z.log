          @Override
          protected void initTypes() {
              final Set<Type> beanTypes = new LinkedHashSet<>();
              beanTypes.add(LocalBusinessInterface.class);
              beanTypes.add(RemoteBusinessInterface.class);
              beanTypes.add(Object.class);
              this.types = beanTypes;
