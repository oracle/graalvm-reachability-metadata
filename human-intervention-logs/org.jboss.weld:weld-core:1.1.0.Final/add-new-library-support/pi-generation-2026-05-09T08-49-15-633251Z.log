  package org_jboss_weld.weld_core;
  
  import javassist.bytecode.Bytecode;
  import javassist.bytecode.ClassFile;
  import javassist.bytecode.MethodInfo;
  import org.jboss.weld.Container;
  import org.jboss.weld.bean.proxy.DecoratorProxyFactory;
  import org.jboss.weld.bootstrap.api.helpers.SimpleServiceRegistry;
  import org.jboss.weld.manager.BeanManagerImpl;
  import org.jboss.weld.manager.Enabled;
  import org.jboss.weld.serialization.ContextualStoreImpl;
  import org.jboss.weld.serialization.spi.ContextualStore;
  import org.jboss.weld.serialization.spi.ProxyServices;
  import org.junit.jupiter.api.BeforeAll;
  import org.junit.jupiter.api.Test;
  
  import javax.enterprise.context.Dependent;
  import javax.enterprise.context.spi.CreationalContext;
  import javax.enterprise.inject.spi.Bean;
  import javax.enterprise.inject.spi.InjectionPoint;
  import java.lang.annotation.Annotation;
  import java.lang.reflect.Type;
  import java.util.Collections;
  import java.util.LinkedHashSet;
  import java.util.Set;
  
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class DecoratorProxyFactoryTest {
  
      @BeforeAll
      static void initializeWeldContainer() {
          final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();
          serviceRegistry.add(ProxyServices.class, new TestProxyServices());
          serviceRegistry.add(ContextualStore.class, new ContextualStoreImpl());
          final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager("decorator-proxy-factory-test",
                  serviceRegistry, Enabled.EMPTY_ENABLED);
          Container.initialize(beanManager, serviceRegistry);
      }
  
      @Test
      void addsDecoratorProxyMethodsFromDecoratorClassHierarchy() {
          final TestBean bean = new TestBean();
          final ExposedDecoratorProxyFactory factory = new ExposedDecoratorProxyFactory(bean);
          final ClassFile proxyClass = new ClassFile(false, generatedProxyName(), AbstractDecorator.class.getName());
          final Bytecode initialValueBytecode = new Bytecode(proxyClass.getConstPool());
  
          factory.addProxyFields(proxyClass, initialValueBytecode);
          factory.addDecoratorMethods(proxyClass);
  
          assertTrue(hasMethod(proxyClass, "decorate"));
      }
  
      private static String generatedProxyName() {
          return DecoratorProxyFactoryTest.class.getPackage().getName() + ".GeneratedDecoratorProxyFactoryCoverage";
      }
  
      private static boolean hasMethod(ClassFile proxyClass, String methodName) {
          for (Object method : proxyClass.getMethods()) {
              final MethodInfo methodInfo = (MethodInfo) method;
              if (methodName.equals(methodInfo.getName())) {
                  return true;
              }
          }
          return false;
      }
  
      public abstract static class AbstractDecorator {
          public abstract String decorate(String value);
  
          public String concreteMethod(String value) {
              return "concrete:" + value;
          }
      }
  
      private static class ExposedDecoratorProxyFactory extends DecoratorProxyFactory<AbstractDecorator> {
          ExposedDecoratorProxyFactory(Bean<?> bean) {
              super(AbstractDecorator.class, null, bean);
          }
  
          void addProxyFields(ClassFile proxyClass, Bytecode initialValueBytecode) {
              addFields(proxyClass, initialValueBytecode);
          }
  
          void addDecoratorMethods(ClassFile proxyClass) {
              addMethodsFromClass(proxyClass);
          }
      }
  
      private static class TestBean implements Bean<AbstractDecorator> {
          @Override
          public Set<Type> getTypes() {
              final Set<Type> types = new LinkedHashSet<>();
              types.add(AbstractDecorator.class);
              types.add(Object.class);
              return types;
          }
  
          @Override
          public Set<Annotation> getQualifiers() {
              return Collections.emptySet();
          }
  
          @Override
          public Class<? extends Annotation> getScope() {
              return Dependent.class;
          }
  
          @Override
          public String getName() {
              return null;
          }
  
          @Override
          public Set<Class<? extends Annotation>> getStereotypes() {
              return Collections.emptySet();
          }
  
          @Override
          public Class<?> getBeanClass() {
              return AbstractDecorator.class;
          }
  
          @Override
          public boolean isAlternative() {
              return false;
          }
  
          @Override
          public boolean isNullable() {
              return false;
          }
  
          @Override
          public Set<InjectionPoint> getInjectionPoints() {
              return Collections.emptySet();
          }
  
          @Override
          public AbstractDecorator create(CreationalContext<AbstractDecorator> creationalContext) {
              return null;
          }
  
          @Override
          public void destroy(AbstractDecorator instance, CreationalContext<AbstractDecorator> creationalContext) {
          }
      }
  
      private static class TestProxyServices implements ProxyServices {
          @Override
          public ClassLoader getClassLoader(Class<?> proxiedBeanType) {
              return DecoratorProxyFactoryTest.class.getClassLoader();
          }
  
          @Override
          public Class<?> loadBeanClass(String className) {
              if (!AbstractDecorator.class.getName().equals(className)) {
                  throw new IllegalArgumentException(className);
              }
              return AbstractDecorator.class;
          }
  
          @Override
          public void cleanup() {
          }
      }
  }
