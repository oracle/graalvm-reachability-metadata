String serviceName();\n    }\n\n    public static class SampleBean {\n        private final String name;\n\n        public SampleBean() {\n            this(\"default\");\n        }\n\n        public SampleBean(String name) {\n            this.name = name;\n        }\n\n        public String name() {\n            return name;\n        }\n\n        public String echo(String value) {\n            return value;\n        }\n\n        @Override\n        public String toString() {\n            return name;\n        }\n    }\n\n    public static class PrebuiltProxy extends SampleBean implements ProxyObject {\n        private transient ThreadLocal<Object> firstSerializationPhaseComplete;\n        private MethodHandler methodHandler;\n\n        public PrebuiltProxy() {\n            super(\"prebuilt\");\n        }\n\n        @Override\n        public void setHandler(MethodHandler handler) {\n            methodHandler = handler;\n        }\n\n        @Override\n        public MethodHandler getHandler() {\n            return methodHandler;\n        }\n\n        ThreadLocal<Object> serializationPhase() {\n            return firstSerializationPhaseComplete;\n        }\n    }\n\n    private static class ExposedProxyFactory extends ProxyFactory<SampleBean> {\n        ExposedProxyFactory(String proxyName) {\n            super(SampleBean.class, proxyTypes(), proxyName, null);\n        }\n\n        void addProxyMembers(ClassFile proxyClass) {\n            final Bytecode initialValueBytecode = new Bytecode(proxyClass.getConstPool());\n            addFields(proxyClass, initialValueBytecode);\n            addConstructors(proxyClass, initialValueBytecode);\n            addMethods(proxyClass);\n        }\n    }\n\n    private static class PrebuiltProxyFactory extends ProxyFactory<PrebuiltProxy> {\n        PrebuiltProxyFactory() {\n            super(PrebuiltProxy.class, prebuiltProxyTypes(), generatedProxyName() + \"Prebuilt\", null);\n        }\n\n        @Override\n        public Class<Pre