  package org_jboss_weld.weld_core;
  
  import org.jboss.weld.resources.DefaultResourceLoader;
  import org.junit.jupiter.api.Test;
  
  import java.net.URL;
  import java.util.Collection;
  
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  public class DefaultResourceLoaderTest {
      private static final String MISSING_RESOURCE_NAME =
              "org_jboss_weld/weld_core/missing-resource-for-default-loader-test.txt";
  
      @Test
      void loadsClassWithContextClassLoader() {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());
          try {
              final Class<?> loadedClass = DefaultResourceLoader.INSTANCE.classForName(String.class.getName());
  
              assertSame(String.class, loadedClass);
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void loadsClassWithoutContextClassLoader() {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(null);
          try {
              final Class<?> loadedClass = DefaultResourceLoader.INSTANCE.classForName(String.class.getName());
  
              assertSame(String.class, loadedClass);
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void loadsResourceWithContextClassLoader() {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());
          try {
              final URL resource = DefaultResourceLoader.INSTANCE.getResource(MISSING_RESOURCE_NAME);
  
              assertNull(resource);
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void loadsResourceWithoutContextClassLoader() {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(null);
          try {
              final URL resource = DefaultResourceLoader.INSTANCE.getResource("/" + MISSING_RESOURCE_NAME);
  
              assertNull(resource);
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void loadsResourcesWithContextClassLoader() {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());
          try {
              final Collection<URL> resources = DefaultResourceLoader.INSTANCE.getResources(MISSING_RESOURCE_NAME);
  
              assertNotNull(resources);
              assertTrue(resources.isEmpty());
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void loadsResourcesWithoutContextClassLoader() {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          Thread.currentThread().setContextClassLoader(null);
          try {
              final Collection<URL> resources = DefaultResourceLoader.INSTANCE.getResources(MISSING_RESOURCE_NAME);
  
              assertNotNull(resources);
              assertTrue(resources.isEmpty());
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
