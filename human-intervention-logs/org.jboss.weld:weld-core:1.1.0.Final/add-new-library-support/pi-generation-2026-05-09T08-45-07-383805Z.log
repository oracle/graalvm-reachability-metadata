[tool-call] delta {"path":"tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/DecoratorProxyFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport javassist.bytecode.ClassFile;\nimport javassist.bytecode.MethodInfo;\nimport org.jboss.weld.Container;\nimport org.jboss.weld.bean.proxy.DecoratorProxyFactory;\nimport org.jboss.weld.bootstrap.api.helpers.SimpleServiceRegistry;\nimport org.jboss.weld.manager.BeanManagerImpl;\nimport org.jboss.weld.manager.Enabled;\nimport org.jboss.weld.serialization.ContextualStoreImpl;\nimport org.jboss.weld.serialization.spi.ContextualStore;\nimport org.jboss.weld.serialization.spi.ProxyServices;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\n\nimport javax.enterprise.context.Dependent;\nimport javax.enterprise.context.spi.CreationalContext;\nimport javax.enterprise.inject.spi.Bean;\nimport javax.enterprise.inject.spi.InjectionPoint;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.Type;\nimport java.util.Collections;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\n\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class DecoratorProxyFactoryTest {\n\n    @BeforeAll\n    static void initializeWeldContainer() {\n        final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();\n        serviceRegistry.add(ProxyServices.class, new TestProxyServices());\n        serviceRegistry.add(ContextualStore.class, new ContextualStoreImpl());\n        final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager(\"decorator-proxy-factory-test\",\n                serviceRegistry, Enabled.EMPTY_ENABLED);\n        Container.initialize(beanManager, serviceRegistry);\n    }\n\n    @Test\n    void addsDecoratorProxyMethodsFromDecoratorClassHierarchy() {\n        final TestBean bean = new TestBean();\n        final ExposedDecoratorProxyFactory factory = new ExposedDecoratorProxyFactory(bean);\n        final ClassFile proxyClass = new ClassFile(false, generatedProxyName(), AbstractDecorator.class.getName());\n\n        factory.addDecoratorMethods(proxyClass);\n\n        assertTrue(hasMethod(proxyClass, \"decorate\"));\n    }\n\n    private static String generatedProxyName() {\n        return DecoratorProxyFactoryTest.class.getPackage().getName() + \".GeneratedDecoratorProxyFactoryCoverage\";\n    }\n\n    private static boolean hasMethod(ClassFile proxyClass, String methodName) {\n        for (Object method : proxyClass.getMethods()) {\n            final MethodInfo methodInfo = (MethodInfo) method;\n            if (methodName.equals(methodInfo.getName())) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    public abstract static class AbstractDecorator {\n        public abstract String decorate(String value);\n\n        public String concreteMethod(String value) {\n            return \"concrete:\" + value;\n        }\n    }\n\n    private static class ExposedDecoratorProxyFactory extends DecoratorProxyFactory<AbstractDecorator> {\n        ExposedDecoratorProxyFactory(Bean<?> bean) {\n            super(AbstractDecorator.class, null, bean);\n        }\n\n        void addDecoratorMethods(ClassFile proxyClass) {\n            addMethodsFromClass(proxyClass);\n        }\n    }\n\n    private static class TestBean implements Bean<AbstractDecorator> {\n        @Override\n        public Set<Type> getTypes() {\n            final Set<Type> types = new LinkedHashSet<>();\n            types.add(AbstractDecorator.class);\n            types.add(Object.class);\n            return types;\n        }\n\n        @Override\n        public Set<Annotation> getQualifiers() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Class<? extends Annotation> getScope() {\n            return Dependent.class;\n        }\n\n        @Override\n        public String getName() {\n            return null;\n        }\n\n        @Override\n        public Set<Class<? extends Annotation>> getStereotypes() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Class<?> getBeanClass() {\n            return AbstractDecorator.class;\n        }\n\n        @Override\n        public boolean isAlternative() {\n            return false;\n        }\n\n        @Override\n        public boolean isNullable() {\n            return false;\n        }\n\n        @Override\n        public Set<InjectionPoint> getInjectionPoints() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public AbstractDecorator create(CreationalContext<AbstractDecorator> creationalContext) {\n            return null;\n        }\n\n        @Override\n        public void destroy(AbstractDecorator instance, CreationalContext<AbstractDecorator> creationalContext) {\n        }\n    }\n\n    private static class TestProxyServices implements ProxyServices {\n        @Override\n        public ClassLoader getClassLoader(Class<?> proxiedBeanType) {\n            return DecoratorProxyFactoryTest.class.getClassLoader();\n        }\n\n        @Override\n        public Class<?> loadBeanClass(String className) {\n            if (!AbstractDecorator.class.getName().equals(className)) {\n                throw new IllegalArgumentException(className);\n            }\n            return AbstractDecorator.class;\n        }\n\n        @Override\n        public void cleanup() {\n        }\n    }\n}\n"}
