ith this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport org.jboss.weld.bean.proxy.AbstractDecoratorMethodHandler;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\npublic class AbstractDecoratorMethodHandlerTest {\n\n    @Test\n    void invokesProceedMethodForConcreteDecoratorMethod() throws Throwable {\n        final AbstractDecoratorMethodHandler handler = new AbstractDecoratorMethodHandler(null, null, new Object());\n        final ConcreteDecorator decorator = new ConcreteDecorator(\"decorated\");\n        final Method method = ConcreteDecorator.class.getMethod(\"decorate\", String.class);\n\n        final Object result = handler.invoke(decorator, method, method, new Object[] {\"value\"});\n\n        assertEquals(\"decorated:value\", result);\n    }\n\n    public static class ConcreteDecorator {\n        private final String prefix;\n\n        public ConcreteDecorator(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String decorate(String value) {\n            return prefix + \":\" + value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1610, "output": 720, "cacheRead": 10752, "cacheWrite": 0, "totalTokens": 13082, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778316052154, "responseId": "resp_02048130c8716ec80169fef314a9e88190a83d2b87bff2434d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Ub5ZAIyyzMeFJ7fqL2DQMLgN|fc_02048130c8716ec80169fef31a49ec819085482a7d698d5bf0", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1299 bytes to tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/AbstractDecoratorMethodHandlerTest.java"}], "isError": false, "timestamp"