         \"org_jboss_weld/weld_core/missing-resource-for-default-loader-test.txt\";\n\n    @Test\n    void loadsClassWithContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());\n        try {\n            final Class<?> loadedClass = DefaultResourceLoader.INSTANCE.classForName(String.class.getName());\n\n            assertSame(String.class, loadedClass);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsClassWithoutContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(null);\n        try {\n            final Class<?> loadedClass = DefaultResourceLoader.INSTANCE.classForName(String.class.getName());\n\n            assertSame(String.class, loadedClass);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourceWithContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());\n        try {\n            final URL resource = DefaultResourceLoader.INSTANCE.getResource(MISSING_RESOURCE_NAME);\n\n            assertNull(resource);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourceWithoutContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(null);\n        try {\n            final URL resource = DefaultResourceLoader.INSTANCE.getResource(\"/\" + MISSING_RESOURCE_NAME);\n\n            assertNull(resource);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourcesWithContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());\n        try {\n            final Collection<URL> resources = DefaultResourceLoader.INSTANCE.getResources(MISSING_RESOURCE_NAME);\n\n            assertNotNull(resources);\n            assertTrue(resources.isEmpty());\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourcesWithoutContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(null);\n        try {\n            final Collection<URL> resources = DefaultResourceLoader.INSTANCE.getResources(MISSING_RESOURCE_NAME);\n\n            assertNotNull(resources);\n            assertTrue(resources.isEmpty());\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778312199216}, {"role": "toolResult", "toolCallId": "call_3hrXE3qURlhX1CTABdZodKMX|fc_08d32caf6a958cd40169fee406fc588193b498f3cdd370e601", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport javassist.bytecode.Bytecode;\nimport javassist.bytecode.ClassFile;\nimport javassist.util.proxy.MethodHandler;\nimport javassist.util.proxy.ProxyObject;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.jboss.weld.Container;\nimport org.jboss.weld.bean.proxy.BeanInstance;\nimport org.jboss.weld.bean.proxy.ProxyFactory;\nimport org.jboss.weld.bootstrap.api.helpers.SimpleServiceRegistry;\nimport org.jboss.weld.exceptions.WeldException;\nimport org.jboss.weld.manager.BeanManagerImpl;\nimport org.jboss.weld.manager.Enabled;\nimport org.jboss.weld.serialization.spi.ProxyServices;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Type;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\n\nimport static org.junit.jupiter.api.Assertions.assertFalse;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\npublic class ProxyFactoryTest {\n\n    @BeforeAll\n    static void initializeWeldContainer() {\n        final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();\n        serviceRegistry.add(ProxyServices.class, new TestProxyServices());\n        final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager(\"proxy-factory-test\", serviceRegistry,\n                Enabled.EMPTY_ENABLED);\n        Container.initialize(beanManager, serviceRegistry);\n    }\n\n    @Test\n    void generatesProxyClassModelFromBeanClassAndBusinessInterface() {\n        final ExposedProxyFactory factory = new ExposedProxyFactory(generatedProxyName());\n        final ClassFile proxyClass = new ClassFile(false, generatedProxyName(), SampleBean.class.getName());\n\n        factory.addProxyMembers(proxyClass);\n\n        assertFalse(proxyClass.getMethods().isEmpty());\n    }\n\n    @Test\n    void createsProxyInstanceAndInitializesProxyObjectHandler() {\n        final PrebuiltProxyFactory factory = new PrebuiltProxyFactory();\n        final SampleBean target = new SampleBean(\"created\");\n        final BeanInstance beanInstance = new SampleBeanInstance(target);\n\n        final PrebuiltProxy proxy = factory.create(beanInstance);\n\n        assertNotNull(proxy);\n        assertNotNull(proxy.serializationPhase());\n        assertNotNull(proxy.getHandler());\n    }\n\n    @Test\n    void attemptsToResolveOrGenerateProxyClassWithConfiguredClassLoader() {\n        final ExposedProxyFactory factory = new ExposedProxyFactory(generatedProxyName());\n\n        try {\n            final Class<SampleBean> proxyClass = factory.getProxyClass();\n\n            assertNotNull(proxyClass);\n        } catch (WeldException exception) {\n            assertNotNull(exception.getCause());\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n        }\n    }\n\n    private static String generatedProxyName() {\n        return ProxyFactoryTest.class.getPackage().getName() + \".GeneratedProxyFactoryCoverage\";\n    }\n\n    private static Set<Type> proxyTypes() {\n        final Set<Type> types = new LinkedHashSet<>();\n        types.add(SampleBean.class);\n        types.add(SampleService.class);\n        return types;\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public interface SampleService {\n        String serviceName();\n    }\n\n    public static class SampleBean {\n        private final String name;\n\n        public SampleBean() {\n            this(\"default\");\n        }\n\n        public SampleBean(String name) {\n            this.name = name;\n        }\n\n        public String name() {\n            return name;\n        }\n\n        public String echo(String value) {\n            return value;\n        }\n\n        @Override\n        public String toString() {\n            return name;\n        }\n    }\n\n    public static class PrebuiltProxy extends SampleBean implements ProxyObject {\n        private transient ThreadLocal<Object> firstSerializationPhaseComplete;\n        private MethodHandler methodHandler;\n\n        public PrebuiltProxy() {\n            super(\"prebuilt\");\n        }\n\n        @Override\n        public void setHandler(MethodHandler handler) {\n            methodHandler = handler;\n        }\n\n        @Override\n        public MethodHandler getHandler() {\n            return methodHandler;\n        }\n\n        ThreadLocal<Object> serializationPhase() {\n            return firstSerializationPhaseComplete;\n        }\n    }\n\n    private static class ExposedProxyFactory extends ProxyFactory<SampleBean> {\n        ExposedProxyFactory(String proxyName) {\n            super(SampleBean.class, proxyTypes(), proxyName, null);\n        }\n\n        void addProxyMembers(ClassFile proxyClass) {\n            final Bytecode initialValueBytecode = new Bytecode(proxyClass.getConstPool());\n            addFields(proxyClass, initialValueBytecode);\n            addConstructors(proxyClass, initialValueBytecode);\n            addMethods(proxyClass);\n        }\n    }\n\n    private static class PrebuiltProxyFactory extends ProxyFactory<PrebuiltProxy> {\n        PrebuiltProxyFactory() {\n            super(PrebuiltProxy.class, prebuiltProxyTypes(), generatedProxyName() + \"Prebuilt\", null);\n        }\n\n        @Override\n        public Class<PrebuiltProxy> getProxyClass() {\n            return PrebuiltProxy.class;\n        }\n    }\n\n    private static Set<Type> prebuiltProxyTypes() {\n        final Set<Type> types = new LinkedHashSet<>();\n        types.add(PrebuiltProxy.class);\n        return types;\n    }\n\n    private static class TestProxyServices implements ProxyServices {\n        @Override\n        public ClassLoader getClassLoader(Class<?> proxiedBeanType) {\n            return proxiedBeanType.getClassLoader();\n        }\n\n        @Override\n        public Class<?> loadBeanClass(String className) {\n            try {\n                return Class.forName(className, false, ProxyFactoryTest.class.getClassLoader());\n            } catch (ClassNotFoundException exception) {\n                throw new IllegalArgumentException(className, exception);\n            }\n        }\n\n        @Override\n        public void cleanup() {\n        }\n    }\n\n    private static class SampleBeanInstance implements BeanInstance {\n        private final SampleBean target;\n\n        SampleBeanInstance(SampleBean target) {\n            this.target = target;\n        }\n\n        @Override\n        public Object getInstance() {\n            return target;\n        }\n\n        @Override\n        public Class<?> getInstanceType() {\n            return target.getClass();\n        }\n\n        @Override\n        public Object invoke(Object instance, Method method, Object... arguments) throws Throwable {\n            assertSame(target, instance);\n            return method.invoke(target, arguments);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778312199216}, {"role": "toolResult", "toolCallId": "call_jaO0PF78pFHI3VN3inTiPuw7|fc_08d32caf6a958cd40169fee406fc688193819daab859fe2e15", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport javassist.util.proxy.MethodHandler;\nimport javassist.util.proxy.ProxyObject;\nimport org.jboss.weld.Container;\nimport org.jboss.weld.bean.proxy.util.SerializableProxy;\nimport org.jboss.weld.bootstrap.api.helpers.SimpleServiceRegistry;\nimport org.jboss.weld.manager.BeanManagerImpl;\nimport org.jboss.weld.manager.Enabled;\nimport org.jboss.weld.serialization.spi.ContextualStore;\nimport org.jboss.weld.serialization.spi.ProxyServices;\nimport org.jboss.weld.serialization.spi.helpers.SerializableContextual;\nimport org.jboss.weld.serialization.spi.helpers.SerializableContextualInstance;\nimport org.junit.jupiter.api.Test;\n\nimport javax.enterprise.context.Dependent;\nimport javax.enterprise.context.spi.Contextual;\nimport javax.enterprise.context.spi.CreationalContext;\nimport javax.enterprise.inject.spi.Bean;\nimport javax.enterprise.inject.spi.InjectionPoint;\nimport javax.enterprise.inject.spi.PassivationCapable;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.Type;\nimport java.util.Collections;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class SerializableProxyTest {\n    private static final String BEAN_ID = \"serializable-proxy-test-bean\";\n\n    @Test\n    void serializesProxyWrapperAndRestoresWrappedProxy() throws Exception {\n        final TestBean bean = new TestBean();\n        initializeWeldContainer(bean);\n        final SerializableProxyTestProxy proxy = new SerializableProxyTestProxy(\"serialized-value\");\n        final SerializableProxy serializableProxy = new SerializableProxy(proxy, bean);\n\n        final byte[] serializedProxy = serialize(serializableProxy);\n        final Object deserializedProxy = deserialize(serializedProxy);\n\n        assertTrue(deserializedProxy instanceof SerializableProxyTestProxy);\n        final SerializableProxyTestProxy restoredProxy = (SerializableProxyTestProxy) deserializedProxy;\n        assertEquals(\"serialized-value\", restoredProxy.value());\n    }\n\n    private static void initializeWeldContainer(TestBean bean) {\n        final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();\n        serviceRegistry.add(ProxyServices.class, new TestProxyServices());\n        serviceRegistry.add(ContextualStore.class, new TestContextualStore(bean));\n        final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager(\"serializable-proxy-test\", serviceRegistry,\n                Enabled.EMPTY_ENABLED);\n        Container.initialize(beanManager, serviceRegistry);\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        final ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return inputStream.readObject();\n        }\n    }\n\n    public static class SerializableProxyTestProxy implements ProxyObject, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String value;\n        private transient MethodHandler handler;\n\n        SerializableProxyTestProxy(String value) {\n            this.value = value;\n        }\n\n        public static Object deserializeProxy(ObjectInputStream inputStream) throws IOException, ClassNotFoundException {\n            return inputStream.readObject();\n        }\n\n        String value() {\n            return value;\n        }\n\n        @Override\n        public void setHandler(MethodHandler handler) {\n            this.handler = handler;\n        }\n\n        @Override\n        public MethodHandler getHandler() {\n            return handler;\n        }\n    }\n\n    private static class TestBean implements Bean<Object>, PassivationCapable {\n        @Override\n        public String getId() {\n            return BEAN_ID;\n        }\n\n        @Override\n        public Set<Type> getTypes() {\n            final Set<Type> types = new LinkedHashSet<>();\n            types.add(SerializableProxyTestProxy.class);\n            types.add(Object.class);\n            return types;\n        }\n\n        @Override\n        public Set<Annotation> getQualifiers() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Class<? extends Annotation> getScope() {\n            return Dependent.class;\n        }\n\n        @Override\n        public String getName() {\n            return null;\n        }\n\n        @Override\n        public Set<Class<? extends Annotation>> getStereotypes() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Class<?> getBeanClass() {\n            return SerializableProxyTestProxy.class;\n        }\n\n        @Override\n        public boolean isAlternative() {\n            return false;\n        }\n\n        @Override\n        public boolean isNullable() {\n            return false;\n        }\n\n        @Override\n        public Set<InjectionPoint> getInjectionPoints() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Object create(CreationalContext<Object> creationalContext) {\n            return null;\n        }\n\n        @Override\n        public void destroy(Object instance, CreationalContext<Object> creationalContext) {\n        }\n    }\n\n    private static class TestContextualStore implements ContextualStore {\n        private final TestBean bean;\n\n        TestContextualStore(TestBean bean) {\n            this.bean = bean;\n        }\n\n        @SuppressWarnings(\"unchecked\")\n        @Override\n        public <C extends Contextual<I>, I> C getContextual(String id) {\n            if (!BEAN_ID.equals(id)) {\n                throw new IllegalArgumentException(id);\n            }\n            return (C) bean;\n        }\n\n        @Override\n        public String putIfAbsent(Contextual<?> contextual) {\n            return BEAN_ID;\n        }\n\n        @Override\n        public <C extends Contextual<I>, I> SerializableContextual<C, I> getSerializableContextual(\n                Contextual<I> contextual) {\n            return null;\n        }\n\n        @Override\n        public <C extends Contextual<I>, I> SerializableContextualInstance<C, I> getSerializableContextualInstance(\n                Contextual<I> contextual, I instance, CreationalContext<I> creationalContext) {\n            return null;\n        }\n\n        @Override\n        public void cleanup() {\n        }\n    }\n\n    private static class TestProxyServices implements ProxyServices {\n        @Override\n        public ClassLoader getClassLoader(Class<?> proxiedBeanType) {\n            return SerializableProxyTest.class.getClassLoader();\n        }\n\n        @Override\n        public Class<?> loadBeanClass(String className) {\n            if (!SerializableProxyTestProxy.class.getName().equals(className)) {\n                throw new IllegalArgumentException(className);\n            }\n            return SerializableProxyTestProxy.class;\n        }\n\n        @Override\n        public void cleanup() {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778312199216}]}
