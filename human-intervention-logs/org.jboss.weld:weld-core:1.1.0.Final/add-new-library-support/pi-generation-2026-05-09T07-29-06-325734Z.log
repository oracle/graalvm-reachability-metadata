ssLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourceWithContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());\n        try {\n            final URL resource = DefaultResourceLoader.INSTANCE.getResource(RESOURCE_NAME);\n\n            assertNotNull(resource);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourceWithoutContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(null);\n        try {\n            final URL resource = DefaultResourceLoader.INSTANCE.getResource(\"/\" + RESOURCE_NAME);\n\n            assertNotNull(resource);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourcesWithContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(DefaultResourceLoaderTest.class.getClassLoader());\n        try {\n            final Collection<URL> resources = DefaultResourceLoader.INSTANCE.getResources(RESOURCE_NAME);\n\n            assertFalse(resources.isEmpty());\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsResourcesWithoutContextClassLoader() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        Thread.currentThread().setContextClassLoader(null);\n        try {\n            final Collection<URL> resources = DefaultResourceLoader.INSTANCE.getResources(RESOURCE_NAME);\n\n            assertFalse(resources.isEmpty());\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2872, "output": 995, "cacheRead": 11776, "cacheWrite": 0, "totalTokens": 15643, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778311695394, "responseId": "resp_0b0551ad72250d720169fee20fc35881a3b57639acf51dc23b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ra6zHLDU0JcHCXnZ7gjzN5OY|fc_0b0551ad72250d720169fee212628081a38488c24a1f37ea3c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3887 bytes to tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/DefaultResourceLoaderTest.java"}], "isError": false, "timestamp": 1778311703704}]}
