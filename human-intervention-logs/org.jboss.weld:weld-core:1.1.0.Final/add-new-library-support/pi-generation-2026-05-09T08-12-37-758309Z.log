[tool-call] delta {"path":"tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/ReflectionFactoryInstantiatorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport org.jboss.weld.util.reflection.instantiation.ReflectionFactoryInstantiator;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\nimport static org.junit.jupiter.api.Assertions.assertNull;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class ReflectionFactoryInstantiatorTest {\n\n    @Test\n    void instantiatesClassWithoutInvokingItsConstructor() {\n        ConstructorGuard.constructorCalls = 0;\n        final ReflectionFactoryInstantiator instantiator = new ReflectionFactoryInstantiator();\n\n        assertTrue(instantiator.isAvailable());\n        final ConstructorGuard instance = instantiator.instantiate(ConstructorGuard.class);\n\n        assertNotNull(instance);\n        assertNull(instance.value());\n        assertEquals(0, ConstructorGuard.constructorCalls);\n    }\n\n    public static class ConstructorGuard {\n        private static int constructorCalls;\n        private final String value;\n\n        public ConstructorGuard() {\n            constructorCalls++;\n            value = \"constructed\";\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n}\n"}
[tool-call] end id=call_bDANHiyiPv7SFz3zPG9almBn|fc_0f96123862dce0a90169feec6cb664819f97b4609efb6ccc10 name=write args={"path": "tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/ReflectionFactoryInstantiatorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport org.jboss.weld.util.reflection.instantiation.ReflectionFactoryInstantiator;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\nimport static org.junit.jupiter.api.Assertions.assertNull;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\npublic class ReflectionFactoryInstantiatorTest {\n\n    @Test\n    void instantiatesClassWithoutInvokingItsConstructor() {\n        ConstructorGuard.constructorCalls = 0;\n        final ReflectionFactoryInstantiator instantiator = new ReflectionFactoryInstantiator();\n\n        assertTrue(instantiator.isAvailable());\n        final ConstructorGuard instance = instantiator.instantiate(ConstructorGuard.class);\n\n        assertNotNull(instance);\n        assertNull(instance.value());\n        assertEquals(0, ConstructorGuard.constructorCalls);\n    }\n\n    public static class ConstructorGuard {\n        private static int constructorCalls;\n        private final String value;\n\n        public ConstructorGuard() {\n            constructorCalls++;\n            value = \"constructed\";\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n}\n"}
