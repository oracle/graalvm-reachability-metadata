\n        assertNotNull(instance);\n        assertNull(instance.value());\n        assertEquals(0, ConstructorGuard.constructorCalls);\n    }\n\n    public static class ConstructorGuard {\n        private static int constructorCalls;\n        private final String value;\n\n        public ConstructorGuard() {\n            constructorCalls++;\n            value = \"constructed\";\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2620, "output": 1098, "cacheRead": 11776, "cacheWrite": 0, "totalTokens": 15494, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778314336237, "responseId": "resp_0f96123862dce0a90169feec609ea4819fadead75c6927ef61"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_bDANHiyiPv7SFz3zPG9almBn|fc_0f96123862dce0a90169feec6cb664819f97b4609efb6ccc10", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1457 bytes to tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/ReflectionFactoryInstantiatorTest.java"}], "isError": false, "timestamp": 1778314352489}]}
