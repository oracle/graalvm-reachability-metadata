  public class SerializableProxyTest {
      private static final String BEAN_ID = "serializable-proxy-test-bean";
  
      @Test
      void serializesProxyWrapperAndRestoresWrappedProxy() throws Exception {
          final TestBean bean = new TestBean();
          initializeWeldContainer(bean);
          final SerializableProxyTestProxy proxy = new SerializableProxyTestProxy("serialized-value");
          final SerializableProxy serializableProxy = new SerializableProxy(proxy, bean);
  
          final byte[] serializedProxy = serialize(serializableProxy);
          final Object deserializedProxy = deserialize(serializedProxy);
  
          assertTrue(deserializedProxy instanceof SerializableProxyTestProxy);
          final SerializableProxyTestProxy restoredProxy = (SerializableProxyTestProxy) deserializedProxy;
          assertEquals("serialized-value", restoredProxy.value());
      }
  
