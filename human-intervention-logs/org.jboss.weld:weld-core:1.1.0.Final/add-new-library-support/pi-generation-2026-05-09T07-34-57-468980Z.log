nal String value;\n        private transient MethodHandler handler;\n\n        SerializableProxyTestProxy(String value) {\n            this.value = value;\n        }\n\n        public static Object deserializeProxy(ObjectInputStream inputStream) throws IOException, ClassNotFoundException {\n            return inputStream.readObject();\n        }\n\n        String value() {\n            return value;\n        }\n\n        @Override\n        public void setHandler(MethodHandler handler) {\n            this.handler = handler;\n        }\n\n        @Override\n        public MethodHandler getHandler() {\n            return handler;\n        }\n    }\n\n    private static class TestBean implements Bean<Object>, PassivationCapable {\n        @Override\n        public String getId() {\n            return BEAN_ID;\n        }\n\n        @Override\n        public Set<Type> getTypes() {\n            final Set<Type> types = new LinkedHashSet<>();\n            types.add(SerializableProxyTestProxy.class);\n            types.add(Object.class);\n            return types;\n        }\n\n        @Override\n        public Set<Annotation> getQualifiers() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Class<? extends Annotation> getScope() {\n            return Dependent.class;\n        }\n\n        @Override\n        public String getName() {\n            return null;\n        }\n\n        @Override\n        public Set<Class<? extends Annotation>> getStereotypes() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Class<?> getBeanClass() {\n            return SerializableProxyTestProxy.class;\n        }\n\n        @Override\n        public boolean isAlternative() {\n            return false;\n        }\n\n        @Override\n        public boolean isNullable() {\n            return false;\n        }\n\n        @Override\n        public Set<InjectionPoint> getInjectionPoints() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Object create(CreationalContext<Object> creationalContext) {\n            return null;\n        }\n\n        @Override\n        public void destroy(Object instance, CreationalContext<Object> creationalContext) {\n        }\n    }\n\n    private static class TestContextualStore implements ContextualStore {\n        private final TestBean bean;\n\n        TestContextualStore(TestBean bean) {\n            this.bean = bean;\n        }\n\n        @SuppressWarnings(\"unchecked\")\n        @Override\n        public <C extends Contextual<I>, I> C getContextual(String id) {\n            if (!BEAN_ID.equals(id)) {\n                throw new IllegalArgumentException(id);\n            }\n            return (C) bean;\n        }\n\n        @Override\n        public String putIfAbsent(Contextual<?> contextual) {\n            return BEAN_ID;\n        }\n\n        @Override\n        public <C extends Contextual<I>, I> SerializableContextual<C, I> getSerializableContextual(\n                Contextual<I> contextual) {\n            return null;\n        }\n\n        @Override\n        public <C extends Contextual<I>, I> SerializableContextualInstance<C, I> getSerializableContextualInstance(\n                Contextual<I> contextual, I instance, CreationalContext<I> creationalContext) {\n            return null;\n        }\n\n        @Override\n        public void cleanup() {\n        }\n    }\n\n    private static class TestProxyServices implements ProxyServices {\n        @Override\n        public ClassLoader getClassLoader(Class<?> proxiedBeanType) {\n            return SerializableProxyTest.class.getClassLoader();\n        }\n\n        @Override\n        public Class<?> loadBeanClass(String className) {\n            try {\n                return Class.forName(className, false, SerializableProxyTest.class.getClassLoader());\n            } catch (ClassNotFoundException exception) {\n                throw new Illega