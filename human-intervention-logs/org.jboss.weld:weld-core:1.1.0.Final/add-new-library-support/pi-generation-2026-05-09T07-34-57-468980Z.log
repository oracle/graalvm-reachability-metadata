              throw new IllegalArgumentException(CANNOT_PROXY_NON_CLASS_TYPE, type);
           }
           return this;
        }
  
        public static TypeInfo of(Set<? extends Type> types)
        {
           TypeInfo typeInfo = create();
           for (Type type : types)
           {
              typeInfo.add(type);
           }
           return typeInfo;
        }
  
        public static TypeInfo create()
        {
           return new TypeInfo();
        }
  
     }
  
