          final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();
          serviceRegistry.add(ProxyServices.class, new TestProxyServices());
          serviceRegistry.add(ContextualStore.class, new TestContextualStore(bean));
          final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager("serializable-proxy-test", serviceRegistry,
                  Enabled.EMPTY_ENABLED);
          Container.initialize(beanManager, serviceRegistry);
      }
  
      private static byte[] serialize(Object value) throws IOException {
          final ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {
              outputStream.writeObject(value);
