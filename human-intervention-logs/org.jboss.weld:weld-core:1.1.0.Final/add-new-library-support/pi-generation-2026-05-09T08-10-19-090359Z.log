Set<Annotation> annotations = Collections.<Annotation>singleton(new TestBindingLiteral());\n\n        final String parameterId = AnnotatedTypes.createParameterId(String.class, annotations);\n\n        assertEquals(\"java.lang.String[@\" + TestBinding.class.getName() + \"(name=alpha,priority=7)]\", parameterId);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface TestBinding {\n        String name();\n\n        int priority();\n    }\n\n    private static final class TestBindingLiteral implements TestBinding {\n        @Override\n        public String name() {\n            return \"alpha\";\n        }\n\n        @Override\n        public int priority() {\n            return 7;\n        }\n\n        @Override\n        public Class<? extends Annotation> annotationType() {\n            return TestBinding.class;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 758, "output": 1340, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25650, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778314177314, "responseId": "resp_04b82192b8e615ec0169feebc1daec81a08ace11899385539d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_iuoTMVMywZlB3sxHl8zQtaNd|fc_04b82192b8e615ec0169feebd0415881a0b49942e6f5dcf969", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1500 bytes to tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/AnnotatedTypesTest.java"}], "isError": false, "timestamp": 1778314194828}]}
