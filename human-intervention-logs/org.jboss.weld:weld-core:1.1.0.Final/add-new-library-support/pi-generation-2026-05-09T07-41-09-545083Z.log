ption {\n        final ExposedInterceptedSubclassFactory factory = new ExposedInterceptedSubclassFactory();\n        final ClassFile subclass = new ClassFile(false, generatedSubclassName(), InterceptedBean.class.getName());\n        subclass.setVersionToJava5();\n        subclass.setAccessFlags(AccessFlag.PUBLIC);\n\n        factory.addInterceptedMethods(subclass);\n\n        final List<MethodInfo> generatedMethods = subclass.getMethods();\n        assertContainsMethod(generatedMethods, \"businessMethod\");\n        assertContainsMethod(generatedMethods, \"businessMethod$$super\");\n        assertContainsMethod(generatedMethods, \"superclassMethod\");\n        assertContainsMethod(generatedMethods, \"superclassMethod$$super\");\n        assertContainsMethod(generatedMethods, \"interfaceOperation\");\n        assertContainsMethod(generatedMethods, \"getTargetInstance\");\n        assertContainsMethod(generatedMethods, \"getTargetClass\");\n        assertContainsMethod(generatedMethods, \"setHandler\");\n        assertContainsMethod(generatedMethods, \"getHandler\");\n    }\n\n    private static void assertContainsMethod(List<MethodInfo> methods, String methodName) {\n        assertTrue(methods.stream().anyMatch(method -> method.getName().equals(methodName)),\n                () -> \"Expected generated method \" + methodName + \" in \" + methods);\n    }\n\n    private static String generatedSubclassName() {\n        return InterceptedSubclassFactoryTest.class.getPackage().getName() + \".GeneratedInterceptedSubclassCoverage\";\n    }\n\n    private static Set<Type> interceptedTypes() {\n        final Set<Type> types = new LinkedHashSet<>();\n        types.add(InterceptedBean.class);\n        types.add(BusinessInterface.class);\n        return types;\n    }\n\n    private static Set<MethodSignature> enhancedMethodSignatures() {\n        final Set<MethodSignature> signatures = new HashSet<>();\n        signatures.add(signatureOf(InterceptedBean.class, \"businessMethod\", String.class));\n        signatures.add(signatureOf(InterceptedSuperclass.class, \"superclassMethod\", int.class));\n        return signatures;\n    }\n\n    private static MethodSignature signatureOf(Class<?> type, String methodName, Class<?>... parameterTypes) {\n        try {\n            final Method method = type.getDeclaredMethod(methodName, parameterTypes);\n            return new MethodSignatureImpl(method);\n        } catch (NoSuchMethodException exception) {\n            throw new AssertionError(exception);\n        }\n    }\n\n    public interface BusinessInterface {\n        String interfaceOperation(String value);\n    }\n\n    public static class InterceptedSuperclass {\n        public int superclassMethod(int value) {\n            return value + 1;\n        }\n    }\n\n    public static class InterceptedBean extends InterceptedSuperclass implements BusinessInterface {\n        public String businessMethod(String value) {\n            return value.toUpperCase();\n        }\n\n        @Override\n        public String interfaceOperation(String value) {\n            return value.trim();\n        }\n    }\n\n    private static class ExposedInterceptedSubclassFactory extends InterceptedSubclassFactory<InterceptedBean> {\n        ExposedInterceptedSubclassFactory() {\n            super(InterceptedBean.class, interceptedTypes(), generatedSubclassName(), null, enhancedMethodSignatures());\n        }\n\n        void addInterceptedMethods(ClassFile proxyClassType) {\n            addMethods(proxyClassType);\n        }\n    }\n\n    private static class TestProxyServices implements ProxyServices {\n        @Override\n        public ClassLoader getClassLoader(Class<?> proxiedBeanType) {\n            return proxiedBeanType.getClassLoader();\n        }\n\n        @Override\n        public Class<?> loadBeanClass(String className) {\n            try {\n                return Class.forName(className, false, InterceptedSubclassFactoryTest.class.getClassLoader());\n    