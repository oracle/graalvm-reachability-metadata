[tool-call] delta {"path":"tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/WeldFieldImplTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport org.jboss.weld.introspector.WeldClass;\nimport org.jboss.weld.introspector.jlr.WeldFieldImpl;\nimport org.jboss.weld.metadata.TypeStore;\nimport org.jboss.weld.resources.ClassTransformer;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\npublic class WeldFieldImplTest {\n\n    @Test\n    void readsAndWritesFieldValuesThroughWeldFieldAbstraction() throws Exception {\n        final ClassTransformer classTransformer = new ClassTransformer(new TypeStore());\n        try {\n            final FieldHolder holder = new FieldHolder();\n            final WeldFieldImpl<String, FieldHolder> field = weldField(classTransformer);\n\n            field.set(holder, \"set-value\");\n\n            assertEquals(\"set-value\", holder.value);\n            assertEquals(\"set-value\", field.get(holder));\n\n            field.setOnInstance(holder, \"instance-value\");\n\n            assertEquals(\"instance-value\", holder.value);\n            assertEquals(\"instance-value\", field.get(holder));\n        } finally {\n            classTransformer.cleanup();\n        }\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static WeldFieldImpl<String, FieldHolder> weldField(ClassTransformer classTransformer) {\n        final WeldClass<FieldHolder> weldClass = classTransformer.loadClass(FieldHolder.class);\n        return (WeldFieldImpl<String, FieldHolder>) weldClass.<String>getDeclaredWeldField(\"value\");\n    }\n\n    public static class FieldHolder {\n        public String value = \"initial\";\n    }\n}\n"}
[tool-call] end id=call_NXr2RyIeAiiHHTD9FHv5aekO|fc_09f8c9aedfac80500169fee5e2198c8192a2fbb18c88e73ed2 name=write args={"path": "tests/src/org.jboss.weld/weld-core/1.1.0.Final/src/test/java/org_jboss_weld/weld_core/WeldFieldImplTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_jboss_weld.weld_core;\n\nimport org.jboss.weld.introspector.WeldClass;\nimport org.jboss.weld.introspector.jlr.WeldFieldImpl;\nimport org.jboss.weld.metadata.TypeStore;\nimport org.jboss.weld.resources.ClassTransformer;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\n\npublic class WeldFieldImplTest {\n\n    @Test\n    void readsAndWritesFieldValuesThroughWeldFieldAbstraction() throws Exception {\n        final ClassTransformer classTransformer = new ClassTransformer(new TypeStore());\n        try {\n            final FieldHolder holder = new FieldHolder();\n            final WeldFieldImpl<String, FieldHolder> field = weldField(classTransformer);\n\n            field.set(holder, \"set-value\");\n\n            assertEquals(\"set-value\", holder.value);\n            assertEquals(\"set-value\", field.get(holder));\n\n            field.setOnInstance(holder, \"instance-value\");\n\n            assertEquals(\"instance-value\", holder.value);\n            assertEquals(\"instance-value\", field.get(holder));\n        } finally {\n            classTransformer.cleanup();\n        }\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static WeldFieldImpl<String, FieldHolder> weldField(ClassTransformer classTransformer) {\n        final WeldClass<FieldHolder> weldClass = classTransformer.loadClass(FieldHolder.class);\n        return (WeldFieldImpl<String, FieldHolder>) weldClass.<String>getDeclaredWeldField(\"value\");\n    }\n\n    public static class F