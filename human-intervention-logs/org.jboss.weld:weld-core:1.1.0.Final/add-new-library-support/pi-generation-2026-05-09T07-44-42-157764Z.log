  package org_jboss_weld.weld_core;
  
  import javassist.bytecode.Bytecode;
  import javassist.bytecode.ClassFile;
  import javassist.util.proxy.MethodHandler;
  import javassist.util.proxy.ProxyObject;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.jboss.weld.Container;
  import org.jboss.weld.bean.proxy.BeanInstance;
  import org.jboss.weld.bean.proxy.ProxyFactory;
  import org.jboss.weld.bootstrap.api.helpers.SimpleServiceRegistry;
  import org.jboss.weld.exceptions.WeldException;
  import org.jboss.weld.manager.BeanManagerImpl;
  import org.jboss.weld.manager.Enabled;
  import org.jboss.weld.serialization.spi.ProxyServices;
  import org.junit.jupiter.api.BeforeAll;
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Method;
  import java.lang.reflect.Type;
  import java.util.LinkedHashSet;
  import java.util.Set;
  
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  
  public class ProxyFactoryTest {
  
      @BeforeAll
      static void initializeWeldContainer() {
          final SimpleServiceRegistry serviceRegistry = new SimpleServiceRegistry();
          serviceRegistry.add(ProxyServices.class, new TestProxyServices());
          final BeanManagerImpl beanManager = BeanManagerImpl.newRootManager("proxy-factory-test", serviceRegistry,
                  Enabled.EMPTY_ENABLED);
          Container.initialize(beanManager, serviceRegistry);
      }
  
      @Test
      void generatesProxyClassModelFromBeanClassAndBusinessInterface() {
          final ExposedProxyFactory factory = new ExposedProxyFactory(generatedProxyName());
          final ClassFile proxyClass = new ClassFile(false, generatedProxyName(), SampleBean.class.getName());
  
          factory.addProxyMembers(proxyClass);
  
          assertFalse(proxyClass.getMethods().isEmpty());
      }
  
      @Test
      void createsProxyInstanceAndInitializesProxyObjectHandler() {
          final PrebuiltProxyFactory factory = new PrebuiltProxyFactory();
          final SampleBean target = new SampleBean("created");
          final BeanInstance beanInstance = new SampleBeanInstance(target);
  
          final PrebuiltProxy proxy = factory.create(beanInstance);
  
          assertNotNull(proxy);
          assertNotNull(proxy.serializationPhase());
          assertNotNull(proxy.getHandler());
      }
  
      @Test
      void attemptsToResolveOrGenerateProxyClassWithConfiguredClassLoader() {
          final ExposedProxyFactory factory = new ExposedProxyFactory(generatedProxyName());
  
          try {
              final Class<SampleBean> proxyClass = factory.getProxyClass();
  
              assertNotNull(proxyClass);
          } catch (WeldException exception) {
              assertNotNull(exception.getCause());
          } catch (Error error) {
              rethrowIfNotNativeImageDynamicClassLoadingError(error);
          }
      }
  
      private static String generatedProxyName() {
          return ProxyFactoryTest.class.getPackage().getName() + ".GeneratedProxyFactoryCoverage";
      }
  
      private static Set<Type> proxyTypes() {
          final Set<Type> types = new LinkedHashSet<>();
          types.add(SampleBean.class);
          types.add(SampleService.class);
          return types;
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      public interface SampleService {
          String serviceName();
      }
  
      public static class SampleBean {
          private final String name;
  
          public SampleBean() {
              this("default");
          }
  
          public SampleBean(String name) {
              this.name = name;
          }
  
          public String name() {
              return name;
          }
  
          public String echo(String value) {
              return value;
          }
  
          @Override
          public String toString() {
              return name;
          }
      }
  
      public static class PrebuiltProxy extends SampleBean implements ProxyObject {
          private transient ThreadLocal<Object> firstSerializationPhaseComplete;
          private MethodHandler methodHandler;
  
          public PrebuiltProxy() {
              super("prebuilt");
          }
  
          @Override
          public void setHandler(MethodHandler handler) {
              methodHandler = handler;
          }
  
          @Override
          public MethodHandler getHandler() {
              return methodHandler;
          }
  
          ThreadLocal<Object> serializationPhase() {
              return firstSerializationPhaseComplete;
          }
      }
  
      private static class ExposedProxyFactory extends ProxyFactory<SampleBean> {
          ExposedProxyFactory(String proxyName) {
              super(SampleBean.class, proxyTypes(), proxyName, null);
          }
  
          void addProxyMembers(ClassFile proxyClass) {
              final Bytecode initialValueBytecode = new Bytecode(proxyClass.getConstPool());
              addFields(proxyClass, initialValueBytecode);
              addConstructors(proxyClass, initialValueBytecode);
              addMethods(proxyClass);
          }
      }
  
      private static class PrebuiltProxyFactory extends ProxyFactory<PrebuiltProxy> {
          PrebuiltProxyFactory() {
              super(PrebuiltProxy.class, prebuiltProxyTypes(), generatedProxyName() + "Prebuilt", null);
          }
  
          @Override
          public Class<PrebuiltProxy> getProxyClass() {
              return PrebuiltProxy.class;
          }
      }
  
      private static Set<Type> prebuiltProxyTypes() {
          final Set<Type> types = new LinkedHashSet<>();
          types.add(PrebuiltProxy.class);
          return types;
      }
  
      private static class TestProxyServices implements ProxyServices {
          @Override
          public ClassLoader getClassLoader(Class<?> proxiedBeanType) {
              return proxiedBeanType.getClassLoader();
          }
  
          @Override
          public Class<?> loadBeanClass(String className) {
              try {
                  return Class.forName(className, false, ProxyFactoryTest.class.getClassLoader());
              } catch (ClassNotFoundException exception) {
                  throw new IllegalArgumentException(className, exception);
              }
          }
  
          @Override
          public void cleanup() {
          }
      }
  
