oracle/oci/sdk/oci-java-sdk-addons-oke-workload-identity/$version$/oci-java-sdk-addons-oke-workload-identity-$version$-javadoc.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-addons-oke-workload-identity/index.json:9:    \"description\" : \"This Oracle Cloud Infrastructure Java SDK add-on provides authentication support for OKE workload identity. It supplies an OkeWorkloadIdentityAuthenticationDetailsProvider and related token-exchange classes so workloads running on OCI Container Engine for Kubernetes can authenticate to OCI services with workload identity.\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-certificates/$version$/oci-java-sdk-certificates-$version$-sources.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:6:    \"repository-url\" : \"https://github.com/oracle/oci-java-sdk\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-certificates/$version$/oci-java-sdk-certificates-$version$-javadoc.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:9:    \"description\" : \"The Oracle Cloud Infrastructure Java SDK Certificates module provides client APIs and model classes for the OCI Certificates service. It lets Java applications retrieve certificate, certificate authority, and CA bundle data and list certificate bundle versions through OCI SDK clients.\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:46:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-certificates/$version$/oci-java-sdk-certificates-$version$-sources.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:47:    \"repository-url\" : \"https://github.com/oracle/oci-java-sdk\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:49:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-certificates/$version$/oci-java-sdk-certificates-$version$-javadoc.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificates/index.json:50:    \"description\" : \"The Oracle Cloud Infrastructure Java SDK Certificates module provides client APIs and model classes for the OCI Certificates service. It lets Java applications retrieve certificate, certificate authority, and CA bundle data and list certificate bundle versions through OCI SDK clients.\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificatesmanagement/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-certificatesmanagement/$version$/oci-java-sdk-certificatesmanagement-$version$-sources.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificatesmanagement/index.json:6:    \"repository-url\" : \"https://github.com/oracle/oci-java-sdk\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificatesmanagement/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-certificatesmanagement/$version$/oci-java-sdk-certificatesmanagement-$version$-javadoc.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-certificatesmanagement/index.json:9:    \"description\" : \"This artifact provides the Certificates Management service module for the Oracle Cloud Infrastructure Java SDK. It supplies JVM clients, requests, responses, and models for managing OCI certificates, certificate authorities, CA bundles, associations, versions, and related lifecycle operations.\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-circuitbreaker/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-circuitbreaker/$version$/oci-java-sdk-circuitbreaker-$version$-sources.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-circuitbreaker/index.json:6:    \"repository-url\" : \"https://github.com/oracle/oci-java-sdk\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-circuitbreaker/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-circuitbreaker/$version$/oci-java-sdk-circuitbreaker-$version$-javadoc.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-circuitbreaker/index.json:9:    \"description\" : \"This artifact provides the circuit breaker module used by the Oracle Cloud Infrastructure Java SDK. It wraps resilience4j circuit breaker support behind OCI SDK configuration and runtime APIs so SDK calls can fail fast when a service or endpoint is unhealthy.\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-common-httpclient-jersey3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-common-httpclient-jersey3/$version$/oci-java-sdk-common-httpclient-jersey3-$version$-sources.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-common-httpclient-jersey3/index.json:6:    \"repository-url\" : \"https://github.com/oracle/oci-java-sdk\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-common-httpclient-jersey3/index.json:7:    \"test-code-url\" : \"https://github.com/oracle/oci-java-sdk/tree/v$version$/bmc-common-httpclient-choices/bmc-common-httpclient-jersey3/src/test/java\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-common-httpclient-jersey3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/oracle/oci/sdk/oci-java-sdk-common-httpclient-jersey3/$version$/oci-java-sdk-common-httpclient-jersey3-$version$-javadoc.jar\",\nmetadata/com.oracle.oci.sdk/oci-java-sdk-common-httpclient-jersey3/index.json:9:    \"description\" : \"The artifact provides the Jersey 3 and Jakarta EE 9 HTTP client implementation used by the Oracle Cloud Infrastructure Java SDK. It connects the SDK's common HTTP client abstractions to Jersey client, JSON/Jackson, Jakarta REST, and Apache connector dependencies for making OCI service calls.\",\nmetadata/library-and-framework-list.json:882:    \"artifact\": \"com.oracle.oci.sdk:oci-java-sdk\",\nmetadata/library-and-framework-list.json:883:    \"description\": \"Oracle Cloud Infrastructure Java SDK\",\nmetadata/library-and-framework-list.json:888:          \"https://repo1.maven.org/maven2/com/oracle/oci/sdk/oci-java-sdk-addons-graalvm/\",\nmetadata/library-and-framework-list.json:889:          \"https://repo1.maven.org/maven2/com/oracle/oci/sdk/oci-java-sdk-addons-graalvm-jersey3/\"\nmetadata/library-and-framework-list.json:892:          \"https://github.com/oracle/oci-java-sdk/tree/master/bmc-addons/bmc-graalvm-addon/src/test/java/com/oracle/bmc/graalvm\",\nmetadata/library-and-framework-list.json:893:          \"https://github.com/oracle/oci-java-sdk/tree/master/bmc-addons/bmc-graalvm-jersey3-addon/src/test/java/com/oracle/bmc/graalvm\"\n"}], "isError": false, "timestamp": 1783637886658}}
