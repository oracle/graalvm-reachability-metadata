ecoder().decodePublicKey(pem);\n    74\t\n    75\t        assertThat(pem).contains(\"-----BEGIN PUBLIC KEY-----\");\n    76\t        assertThat(decodedPublicKey.getAlgorithm()).isEqualTo(\"RSA\");\n    77\t        assertThat(decodedPublicKey.getEncoded()).isEqualTo(keyPair.getPublic().getEncoded());\n    78\t    }\n    79\t\n    80\t    @Test\n    81\t    void pemEncoderAndDecoderRoundTripPrivateKey() throws Exception {\n    82\t        KeyPair keyPair = generateRsaKeyPair();\n    83\t\n    84\t        byte[] encodedPem = Pem.encoder().encode(keyPair.getPrivate());\n    85\t        PrivateKey decodedPrivateKey = Pem.decoder().decodePrivateKey(encodedPem);\n    86\t\n    87\t        assertThat(new String(encodedPem, StandardCharsets.UTF_8)).contains(\"-----BEGIN PRIVATE KEY-----\");\n    88\t        assertThat(decodedPrivateKey.getAlgorithm()).isEqualTo(\"RSA\");\n    89\t        assertThat(decodedPrivateKey.getEncoded()).isEqualTo(keyPair.getPrivate().getEncoded());\n    90\t    }\n    91\t\n    92\t    private static KeyPair generateRsaKeyPair() throws Exception {\n    93\t        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"RSA\");\n    94\t        keyPairGenerator.initialize(1024);\n    95\t        return keyPairGenerator.generateKeyPair();\n    96\t    }\n    97\t}\n","exit_code":0,"status":"completed"}}
