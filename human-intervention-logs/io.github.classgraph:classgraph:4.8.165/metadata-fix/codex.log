    exerciseClassGraphScan(isolatedClassLoader);\n            } catch (final Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            restoreJavaVersion(previousJavaVersion);\n        }\n    }\n\n    private static void exerciseClassGraphScan(final ClassLoader isolatedClassLoader)\n            throws Exception {\n        final Class<?> classGraphClass = Class.forName(\n                CLASS_GRAPH_CLASS_NAME, true, isolatedClassLoader);\n        final Constructor<?> classGraphConstructor = classGraphClass.getConstructor();\n        final Object classGraph = classGraphConstructor.newInstance();\n        invoke(classGraph, \"enableClassInfo\", new Class<?>[0]);\n        invoke(classGraph, \"acceptPackages\", new Class<?>[] { String[].class },\n                (Object) new String[] { TEST_PACKAGE_NAME });\n\n        final AutoCloseable scanResult = (AutoCloseable) invoke(\n                classGraph, \"scan\", new Class<?>[0]);\n        try {\n            final Object classInfo = invoke(\n                    scanResult, \"getClassInfo\", new Class<?>[] { String.class }, TEST_CLASS_NAME);\n            assertThat(classInfo).isNotNull();\n        } finally {\n            scanResult.close();\n        }\n    }\n\n    private static Object invoke(final Object target, final String methodName,\n            final Class<?>[] parameterTypes, final Object... args) throws Exception {\n        final Method method = target.getClass().getMethod(methodName, parameterTypes);\n        try {\n            return method.invoke(target, args);\n        } catch (final InvocationTargetException e) {\n            throw causeAsException(e.getCause());\n        }\n    }\n\n    private static Exception causeAsException(final Throwable cause) {\n        if (cause instanceof Error) {\n            throw (Error) cause;\n        }\n        if (cause instanceof Exception) {\n            return (Exception) cause;\n        }\n        return new RuntimeException(cause);\n    }\n\n    private static URL codeSourceUrl(final Class<?> type) {\n        final CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        assertThat(codeSource.getLocation()).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static void restoreJavaVersion(final String previousJavaVersion) {\n        if (previousJavaVersion == null) {\n            System.clearProperty(\"java.version\");\n        } else {\n            System.setProperty(\"java.version\", previousJavaVersion);\n        }\n    }\n\n    private static final class IsolatedClassGraphClassLoader extends URLClassLoader {\n        IsolatedClassGraphClassLoader(final URL[] urls, final ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(final String className, final boolean resolve)\n                throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(className)) {\n                Class<?> loadedClass = findLoadedClass(className);\n                if (loadedClass == null) {\n                    loadedClass = shouldLoadInIsolation(className)\n                            ? loadIsolatedClass(className)\n                            : super.loadClass(className, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> loadIsolatedClass(final String className) throws ClassNotFoundException {\n            try {\n                return findClass(className);\n            } catch (final ClassNotFoundException e) {\n                return super.loadClass(className, false);\n            }\n        }\n\n        private static boolean shouldLoadInIsolation(final String className) {\n            return className.startsWith(\"io.github.classgraph.\")\n                    || className.startsWith(\"nonapi.io.github.classgraph.\");\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
