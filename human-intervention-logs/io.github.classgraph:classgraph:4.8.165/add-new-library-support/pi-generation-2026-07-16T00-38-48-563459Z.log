  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  
  import io.github.classgraph.ClassGraph;
  
  public class CallStackReaderTest {
      @Test
      void scansCallerClassUsingTheDefaultClassLoaderDiscovery() {
          try (var scanResult = new ClassGraph().acceptClasses(CallStackReaderTest.class.getName()).enableClassInfo()
                  .scan()) {
              assertThat(scanResult.getClassInfo(CallStackReaderTest.class.getName())).isNotNull();
          }
      }
  }
