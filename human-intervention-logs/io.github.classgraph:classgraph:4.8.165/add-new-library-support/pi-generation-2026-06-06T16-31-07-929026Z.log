  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ClassGraph.CircumventEncapsulationMethod;
  import nonapi.io.github.classgraph.reflection.ReflectionUtils;
  
  public class StandardReflectionDriverTest {
      @AfterEach
      void resetReflectionDriverSelection() {
          ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;
      }
  
      @Test
      void accessesMembersThroughStandardReflectionDriver() {
          ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;
          final ReflectionUtils reflectionUtils = new ReflectionUtils();
          final ReflectionTarget target = new ReflectionTarget();
  
          assertThat(reflectionUtils.classForNameOrNull(ReflectionTarget.class.getName()))
                  .isEqualTo(ReflectionTarget.class);
          assertThat(reflectionUtils.getFieldVal(true, target, "message")).isEqualTo("initial");
          assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, "staticMessage"))
                  .isEqualTo("static");
          assertThat(reflectionUtils.invokeMethod(true, target, "append", String.class, " value"))
                  .isEqualTo("initial value");
          assertThat(reflectionUtils.invokeStaticMethod(true, ReflectionTarget.class, "staticGreeting", String.class,
                  "hi")).isEqualTo("hi static");
      }
  
      @Test
      void handlesInaccessibleJdkFieldWhenExceptionThrowingIsDisabled() {
          ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;
          final ReflectionUtils reflectionUtils = new ReflectionUtils();
  
          final Object value = reflectionUtils.getFieldVal(false, "classgraph", "value");
  
          assertThat(value == null || value.getClass().isArray()).isTrue();
      }
  
      @Test
      void initializesJvmDriverSupportThroughStandardReflectionDriver() {
          ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.JVM_DRIVER;
  
          final ReflectionUtils reflectionUtils = new ReflectionUtils();
  
          assertThat(reflectionUtils.classForNameOrNull(ReflectionTarget.class.getName()))
                  .isEqualTo(ReflectionTarget.class);
      }
  
      private static final class ReflectionTarget {
          private String message = "initial";
          private static String staticMessage = "static";
  
          private String append(final String suffix) {
              return message + suffix;
          }
  
          private static String staticGreeting(final String prefix) {
              return prefix + " " + staticMessage;
          }
      }
  }
