ResourceLock;\nimport org.junit.jupiter.api.parallel.Resources;\n\nimport io.github.classgraph.ClassGraph;\n\npublic class CallStackReaderTest {\n    private static final String CLASS_GRAPH_CLASS_NAME = \"io.github.classgraph.ClassGraph\";\n    private static final String TEST_PACKAGE_NAME = \"io_github_classgraph.classgraph\";\n    private static final String TEST_CLASS_NAME = TEST_PACKAGE_NAME + \".CallStackReaderTest\";\n\n    @Test\n    @ResourceLock(Resources.SYSTEM_PROPERTIES)\n    void scansClasspathWithJavaEightCallStackFallbackInIsolatedClassGraph() throws Exception {\n        final URL classGraphUrl = codeSourceUrl(ClassGraph.class);\n        final ClassLoader parentClassLoader = CallStackReaderTest.class.getClassLoader();\n        final String previousJavaVersion = System.getProperty(\"java.version\");\n\n        System.setProperty(\"java.version\", \"1.8.0_402\");\n        try (IsolatedClassGraphClassLoader isolatedClassLoader = new IsolatedClassGraphClassLoader(\n                new URL[] { classGraphUrl }, parentClassLoader)) {\n            try {\n                exerciseClassGraphScan(isolatedClassLoader);\n            } catch (final Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n            }\n        } finally {\n            restoreJavaVersion(previousJavaVersion);\n        }\n    }\n\n    private static void exerciseClassGraphScan(final ClassLoader isolatedClassLoader) throws Exception {\n        final Class<?> classGraphClass = Class.forName(CLASS_GRAPH_CLASS_NAME, true, isolatedClassLoader);\n        final Constructor<?> classGraphConstructor = classGraphClass.getConstructor();\n        final Object classGraph = classGraphConstructor.newInstance();\n        invoke(classGraph, \"enableClassInfo\", new Class<?>[0]);\n        invoke(classGraph, \"acceptPackages\", new Class<?>[] { String[].class },\n                (Object) new String[] { TEST_PACKAGE_NAME });\n\n        final AutoCloseable scanResult = (AutoCloseable) invoke(classGraph, \"scan\", new Class<?>[0]);\n        try {\n            final Object classInfo = invoke(scanResult, \"getClassInfo\", new Class<?>[] { String.class },\n                    TEST_CLASS_NAME);\n            assertThat(classInfo).isNotNull();\n        } finally {\n            scanResult.close();\n        }\n    }\n\n    private static Object invoke(final Object target, final String methodName, final Class<?>[] parameterTypes,\n            final Object... args) throws Exception {\n        final Method method = target.getClass().getMethod(methodName, parameterTypes);\n        try {\n            return method.invoke(target, args);\n        } catch (final InvocationTargetException e) {\n            throw causeAsException(e.getCause());\n        }\n    }\n\n    private static Exception causeAsException(final Throwable cause) {\n        if (cause instanceof Error) {\n            throw (Error) cause;\n        }\n        if (cause instanceof Exception) {\n            return (Exception) cause;\n        }\n        return new RuntimeException(cause);\n    }\n\n    private static URL codeSourceUrl(final Class<?> type) {\n        final CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        assertThat(codeSource.getLocation()).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static void restoreJavaVersion(final String previousJavaVersion) {\n        if (previousJavaVersion == null) {\n            System.clearProperty(\"java.version\");\n        } else {\n            System.setProperty(\"java.version\", previousJavaVersion);\n        }\n    }\n\n    private static final class IsolatedClassGraphClassLoader extends URLClassLoader {\n        IsolatedClassGraphClassLoader(final URL[] urls, final ClassLoader parent) {\n            super(urls, parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(final String className, final boolean resolve)\n                throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(className)) {\n                Class<?> loadedClass = findLoadedClass(className);\n                if (loadedClass == null) {\n                    loadedClass = shouldLoadInIsolation(className)\n                            ? loadIsolatedClass(className)\n                            : super.loadClass(className, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> loadIsolatedClass(final String className) throws ClassNotFoundException {\n            try {\n                return findClass(className);\n            } catch (final ClassNotFoundException e) {\n                return super.loadClass(className, false);\n            }\n        }\n\n        private static boolean shouldLoadInIsolation(final String className) {\n            return className.startsWith(\"io.github.classgraph.\")\n                    || className.startsWith(\"nonapi.io.github.classgraph.\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2647, "output": 2143, "cacheRead": 57344, "cacheWrite": 0, "totalTokens": 62134, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780768576159, "responseId": "resp_0eb74b9aad09859f016a245f40c3188190b2003e7a8fb21cdc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_e1OvpUVJ5oCzVpLynwqNgBpc|fc_0eb74b9aad09859f016a245f5555a481909a29c6fa302be940", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5705 bytes to tests/src/io.github.classgraph/classgraph/4.8.165/src/test/java/io_github_classgraph/classgraph/CallStackReaderTest.java"}], "isError": false, "timestamp": 178076860719