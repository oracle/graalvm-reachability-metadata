  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Permission;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.parallel.ResourceLock;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ScanResult;
  
  public class CallStackReaderTest {
      private static final String CALL_STACK_READER_CLASS_NAME = "nonapi.io.github.classgraph.classpath.CallStackReader";
  
      @Test
      @ResourceLock("java.lang.SecurityManager")
      void scansClasspathWhenStackWalkerClassReferencesAreDenied() {
          final SecurityManager previousSecurityManager = System.getSecurityManager();
          final boolean securityManagerInstalled = installSecurityManagerIfSupported(
                  new DenyStackWalkerClassReferencesSecurityManager());
          boolean testClassDiscovered = false;
  
          try {
              try (ScanResult scanResult = new ClassGraph()
                      .enableClassInfo()
                      .acceptPackages(CallStackReaderTest.class.getPackageName())
                      .scan()) {
                  testClassDiscovered = scanResult.getClassInfo(CallStackReaderTest.class.getName()) != null;
              }
          } finally {
              if (securityManagerInstalled || previousSecurityManager != null) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
  
          assertThat(testClassDiscovered).isTrue();
      }
  
      private static boolean installSecurityManagerIfSupported(final SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (final UnsupportedOperationException | SecurityException e) {
              return false;
          }
      }
  
      private static final class DenyStackWalkerClassReferencesSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(final Permission permission) {
              if ("getStackWalkerWithClassReference".equals(permission.getName()) && calledFromCallStackReader()) {
                  throw new SecurityException("StackWalker class references denied for fallback coverage");
              }
          }
  
          private boolean calledFromCallStackReader() {
              for (final Class<?> callStackClass : getClassContext()) {
                  if (CALL_STACK_READER_CLASS_NAME.equals(callStackClass.getName())) {
                      return true;
                  }
              }
              return false;
          }
  
          @Override
          public void checkPermission(final Permission permission, final Object context) {
              checkPermission(permission);
          }
