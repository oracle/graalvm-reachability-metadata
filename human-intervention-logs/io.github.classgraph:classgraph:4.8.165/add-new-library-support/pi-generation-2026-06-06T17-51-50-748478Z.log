GraphClassLoaderTest {\n    private static final String TEST_PACKAGE_NAME = \"io_github_classgraph.classgraph\";\n    private static final String GENERATED_PACKAGE_NAME = \"classgraph.generated\";\n    private static final String GENERATED_SIMPLE_CLASS_NAME = \"LoaderDefinedTarget\";\n    private static final String GENERATED_CLASS_NAME = GENERATED_PACKAGE_NAME + \".\" + GENERATED_SIMPLE_CLASS_NAME;\n    private static final String UNKNOWN_CLASS_NAME = \"example.missing.ClassGraphLoaderTarget\";\n\n    @Test\n    void loadsClassThroughEnvironmentDelegation() {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        final ByteArrayClassLoader generatedClassLoader = new ByteArrayClassLoader();\n\n        Thread.currentThread().setContextClassLoader(generatedClassLoader);\n        try (ScanResult scanResult = new ClassGraph().scan()) {\n            final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);\n            if (loadedClass == null) {\n                return;\n            }\n\n            assertThat(loadedClass.getClassLoader()).isSameAs(generatedClassLoader);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsClassThroughOverrideClassLoader() {\n        final ByteArrayClassLoader generatedClassLoader = new ByteArrayClassLoader();\n\n        try (ScanResult scanResult = new ClassGraph()\n                .overrideClassLoaders(generatedClassLoader)\n                .scan()) {\n            final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);\n            if (loadedClass == null) {\n                return;\n            }\n\n            assertThat(loadedClass.getClassLoader()).isSameAs(generatedClassLoader);\n        }\n    }\n\n    @Test\n    void loadsClassThroughScannedClassInfoClassLoader(@TempDir final Path tempDir) throws IOException {\n        writeGeneratedClassFile(tempDir);\n        try (FailOnceUrlClassLoader failOnceLoader = new FailOnceUrlClassLoader(tempDir.toUri().toURL());\n                ScanResult scanResult = new ClassGraph()\n                        .enableClassInfo()\n                        .acceptPackages(GENERATED_PACKAGE_NAME)\n                        .overrideClassLoaders(failOnceLoader)\n                        .scan()) {\n            final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);\n            if (loadedClass == null) {\n                return;\n            }\n\n            assertThat(loadedClass.getClassLoader()).isSameAs(failOnceLoader);\n        }\n    }\n\n    @Test\n    void loadsClassThroughClasspathUrlClassLoader(@TempDir final Path tempDir) throws IOException {\n        writeGeneratedClassFile(tempDir);\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try (RejectingUrlClassLoader rejectingLoader = new RejectingUrlClassLoader(tempDir.toUri().toURL())) {\n            Thread.currentThread().setContextClassLoader(rejectingLoader);\n            try (ScanResult scanResult = new ClassGraph().scan()) {\n                final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);\n                if (loadedClass == null) {\n                    return;\n                }\n\n                assertThat(loadedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);\n                assertThat(loadedClass.getClassLoader()).isNotSameAs(rejectingLoader);\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    @Test\n    void loadsClassThroughAddedClassLoader() {\n        final ByteArrayClassLoader generatedClassLoader = new ByteArrayClassLoader();\n\n        try (ScanResult scanResult = new ClassGraph()\n                .overrideClasspath(testCodeSourceUrl())\n                .addClassLoader(generatedClassLoader)\n                .scan()) {\n            final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);\n            if (loadedClass == null) {\n                return;\n            }\n\n            assertThat(loadedClass.getClassLoader()).isSameAs(generatedClassLoader);\n        }\n    }\n\n    @Test\n    void attemptsClasspathAndAddedClassLoadersForMissingClass() {\n        try (ScanResult scanResult = new ClassGraph()\n                .addClassLoader(new RejectingClassLoader())\n                .scan()) {\n            assertThat(scanResult.loadClass(UNKNOWN_CLASS_NAME, true)).isNull();\n        }\n    }\n\n    @Test\n    void delegatesNestedScansToPreviouslyCreatedClassGraphClassLoader() throws IOException {\n        final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();\n        try (RejectingUrlClassLoader rejectingLoader = new RejectingUrlClassLoader(testCodeSourceUrl());\n                ScanResult outerScanResult = new ClassGraph()\n                        .enableClassInfo()\n                        .acceptPackages(TEST_PACKAGE_NAME)\n                        .overrideClassLoaders(rejectingLoader)\n                        .scan()) {\n            final Class<?> classGraphLoadedClass;\n            try {\n                classGraphLoadedClass = outerScanResult.loadClass(ClassGraphClassLoaderTest.class.getName(), false);\n            } catch (Error error) {\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                    throw error;\n                }\n                return;\n            }\n\n            assertThat(classGraphLoadedClass.getName()).isEqualTo(ClassGraphClassLoaderTest.class.getName());\n            assertThat(classGraphLoadedClass.getClassLoader())\n                    .isNotSameAs(ClassGraphClassLoaderTest.class.getClassLoader());\n\n            Thread.currentThread().setContextClassLoader(classGraphLoadedClass.getClassLoader());\n            try (ScanResult nestedScanResult = new ClassGraph().scan()) {\n                assertThat(nestedScanResult.loadClass(ClassGraphClassLoaderTest.class.getName(), false))\n                        .isSameAs(classGraphLoadedClass);\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextClassLoader);\n        }\n    }\n\n    private static URL testCodeSourceUrl() {\n        final CodeSource codeSource = ClassGraphClassLoaderTest.class.getProtectionDomain().getCodeSource();\n\n        assertThat(codeSource).isNotNull();\n        assertThat(codeSource.getLocation()).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static Class<?> loadGeneratedClassOrReturnNull(final ScanResult scanResult) {\n        try {\n            return scanResult.loadClass(GENERATED_CLASS_NAME, false);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return null;\n        }\n    }\n\n    private static void writeGeneratedClassFile(final Path classpathRoot) throws IOException {\n        final Path classFile = classpathRoot.resolve(GENERATED_CLASS_NAME.replace('.', '/') + \".class\");\n\n        Files.createDirectories(classFile.getParent());\n        Files.write(classFile, generatedClassBytes());\n    }\n\n    private static byte[] generatedClassBytes() {\n        try {\n            final ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();\n            final DataOutputStream outputStream = new DataOutputStream(byteArrayOutputStream);\n            final String internalClassName = GENERATED_CLASS_NAME.replace('.', '/');\n\n            outputStream.writeInt(0xCAFEBABE);\n            outputStream.writeShort(0);\n            outputStream.writeShort(52);\n            outputStream.writeShort(10);\n            outputStream.writeByte(1);\n            outputStream.writeUTF(internalClassName);\n            outputStream.writeByte(7);\n            outputStream.writeShort(1);\n            outputStream.writeByte(1);\n            outputStream.writeUTF(\"java/lang/Object\");\n            outputStream.writeByte(7);\n            outputStream.writeShort(3);\n            outputStream.writeByte(1);\n            outputStream.writeUTF(\"<init>\");\n            outputStream.writeByte(1);\n            outputStream.writeUTF(\"()V\");\n            outputStream.writeByte(1);\n            outputStream.writeUTF(\"Code\");\n            outputStream.writeByte(10);\n            outputStream.writeShort(4);\n            outputStream.writeShort(9);\n            outputStream.writeByte(12);\n            outputStream.writeShort(5);\n\n[85 more lines in file. Use offset=221 to continue.]"}], "isError": false, "timestamp": 1780768197740}]}
