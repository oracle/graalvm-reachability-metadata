[tool-call] delta {"path":"tests/src/io.github.classgraph/classgraph/4.8.165/src/test/java/io_github_classgraph/classgraph/JSONDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.List;\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\n\nimport nonapi.io.github.classgraph.json.JSONDeserializer;\n\npublic class JSONDeserializerTest {\n    @Test\n    void deserializesNestedArrays() {\n        final String json = \"\"\"\n                {\n                  \"matrix\": [[1, 2], [3]]\n                }\n                \"\"\";\n\n        final ArrayHolder holder = JSONDeserializer.deserializeObject(ArrayHolder.class, json);\n\n        assertThat(holder.matrix).isDeepEqualTo(new int[][] { { 1, 2 }, { 3 } });\n    }\n\n    @Test\n    void deserializesFieldValuesUsingSizeHintAndDefaultConstructors() {\n        final String json = \"\"\"\n                {\n                  \"attributes\": {\n                    \"first\": \"alpha\",\n                    \"second\": \"beta\"\n                  },\n                  \"nested\": {\n                    \"name\": \"child\"\n                  }\n                }\n                \"\"\";\n\n        final ConstructorFieldHolder holder = JSONDeserializer.deserializeObject(ConstructorFieldHolder.class,\n                json);\n\n        assertThat(holder.attributes).containsEntry(\"first\", \"alpha\").containsEntry(\"second\", \"beta\");\n        assertThat(holder.nested.name).isEqualTo(\"child\");\n    }\n\n    @Test\n    void deserializesCollectionElementsUsingSizeHintAndDefaultConstructors() {\n        final String json = \"\"\"\n                {\n                  \"maps\": [\n                    {\"one\": \"1\"},\n                    {\"two\": \"2\", \"three\": \"3\"}\n                  ],\n                  \"nestedItems\": [\n                    {\"name\": \"first\"},\n                    {\"name\": \"second\"}\n                  ]\n                }\n                \"\"\";\n\n        final CollectionHolder holder = JSONDeserializer.deserializeObject(CollectionHolder.class, json);\n\n        assertThat(holder.maps).hasSize(2);\n        assertThat(holder.maps.get(0)).containsEntry(\"one\", \"1\");\n        assertThat(holder.maps.get(1)).containsEntry(\"two\", \"2\").containsEntry(\"three\", \"3\");\n        assertThat(holder.nestedItems).extracting(item -> item.name).containsExactly(\"first\", \"second\");\n    }\n\n    public static final class ArrayHolder {\n        public int[][] matrix;\n\n        public ArrayHolder() {\n        }\n    }\n\n    public static final class ConstructorFieldHolder {\n        public Map<String, String> attributes;\n        public NestedValue nested;\n\n        public ConstructorFieldHolder() {\n        }\n    }\n\n    public static final class CollectionHolder {\n        public List<Map<String, String>> maps;\n        public List<NestedValue> nestedItems;\n\n        public CollectionHolder() {\n        }\n    }\n\n    public static final class NestedValue {\n        public String name;\n\n        public NestedValue() {\n        }\n    }\n}\n"}
