       7	package io_github_classgraph.classgraph;
       8	
       9	import static org.assertj.core.api.Assertions.assertThat;
      10	
      11	import java.lang.reflect.Field;
      12	import java.lang.reflect.Method;
      13	
      14	import org.junit.jupiter.api.AfterEach;
      15	import org.junit.jupiter.api.Test;
      16	
      17	import io.github.classgraph.ClassGraph;
      18	import io.github.classgraph.ClassGraph.CircumventEncapsulationMethod;
      19	import nonapi.io.github.classgraph.reflection.ReflectionUtils;
      20	
      21	public class NarcissusReflectionDriverTest {
      22	    @AfterEach
      23	    void resetReflectionDriverSelection() {
      24	        ReflectionTarget.staticMessage = "static";
      25	        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;
      26	    }
      27	
      28	    @Test
      29	    void accessesMembersThroughNarcissusReflectionDriver() throws ReflectiveOperationException {
      30	        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NARCISSUS;
      31	        final ReflectionUtils reflectionUtils = new ReflectionUtils();
      32	        final ReflectionTarget target = new ReflectionTarget();
      33	
      34	        assertThat(reflectionUtils.reflectionDriver.getClass().getName())
      35	                .isEqualTo("nonapi.io.github.classgraph.reflection.NarcissusReflectionDriver");
      36	        assertThat(reflectionUtils.classForNameOrNull(ReflectionTarget.class.getName()))
      37	                .isEqualTo(ReflectionTarget.class);
      38	        assertThat(reflectionUtils.getFieldVal(true, target, "message")).isEqualTo("initial");
      39	        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, "staticMessage"))
      40	                .isEqualTo("static");
      41	        assertThat(reflectionUtils.invokeMethod(true, target, "append", String.class, " value"))
      42	                .isEqualTo("initial value");
      43	        assertThat(reflectionUtils.invokeStaticMethod(true, ReflectionTarget.class, "staticGreeting", String.class,
      44	                "hi")).isEqualTo("hi static");
      45	    }
      46	
      47	    @Test
      48	    void invokesPackagePrivateDriverOperationsNotExposedByReflectionUtils() throws Exception {
      49	        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NARCISSUS;
      50	        final ReflectionUtils reflectionUtils = new ReflectionUtils();
      51	        final ReflectionTarget target = new ReflectionTarget();
      52	        final Object reflectionDriver = reflectionUtils.reflectionDriver;
      53	        final Field messageField = ReflectionTarget.class.getDeclaredField("message");
      54	        final Field staticMessageField = ReflectionTarget.class.getDeclaredField("staticMessage");
      55	
      56	        assertThat(invokeReflectionDriver(reflectionDriver, "getDeclaredConstructors",
      57	                new Class<?>[] { Class.class }, ReflectionTarget.class)).isNotNull();
      58	
      59	        invokeReflectionDriver(reflectionDriver, "setField", new Class<?>[] { Object.class, Field.class, Object.class },
      60	                target, messageField, "updated");
      61	        assertThat(reflectionUtils.getFieldVal(true, target, "message")).isEqualTo("updated");
      62	
      63	        invokeReflectionDriver(reflectionDriver, "setStaticField", new Class<?>[] { Field.class, Object.class },
      64	                staticMessageField, "changed");
      65	        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, "staticMessage"))
      66	                .isEqualTo("changed");
      67	    }
      68	
      69	    private static Object invokeReflectionDriver(final Object reflectionDriver, final String methodName,
      70	            final Class<?>[] parameterTypes, final Object... args) throws ReflectiveOperationException {
      71	        final Method driverMethod = reflectionDriver.getClass().getDeclaredMethod(methodName, parameterTypes);
      72	        driverMethod.setAccessible(true);
      73	        return driverMethod.invoke(reflectionDriver, args);
      74	    }
      75	
      76	    private static final class ReflectionTarget {
      77	        private String message = "initial";
      78	        private static String staticMessage = "static";
      79	
      80	        private String append(final String suffix) {
      81	            return message + suffix;
      82	        }
      83	
      84	        private static String staticGreeting(final String prefix) {
      85	            return prefix + " " + staticMessage;
      86	        }
      87	    }
      88	}
