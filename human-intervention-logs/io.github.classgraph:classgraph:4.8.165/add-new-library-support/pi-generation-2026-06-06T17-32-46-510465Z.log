keMethod(true, target, \"append\", String.class, \" value\"))\n                .isEqualTo(\"initial value\");\n        assertThat(reflectionUtils.invokeStaticMethod(true, ReflectionTarget.class, \"staticGreeting\", String.class,\n                \"hi\")).isEqualTo(\"hi static\");\n    }\n\n    @Test\n    void invokesPackagePrivateDriverOperationsNotExposedByReflectionUtils() throws Exception {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NARCISSUS;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n        final ReflectionTarget target = new ReflectionTarget();\n        final Object reflectionDriver = reflectionUtils.reflectionDriver;\n        final Field messageField = ReflectionTarget.class.getDeclaredField(\"message\");\n        final Field staticMessageField = ReflectionTarget.class.getDeclaredField(\"staticMessage\");\n\n        assertThat(invokeReflectionDriver(reflectionDriver, \"getDeclaredConstructors\",\n                new Class<?>[] { Class.class }, ReflectionTarget.class)).isNotNull();\n\n        invokeReflectionDriver(reflectionDriver, \"setField\", new Class<?>[] { Object.class, Field.class, Object.class },\n                target, messageField, \"updated\");\n        assertThat(reflectionUtils.getFieldVal(true, target, \"message\")).isEqualTo(\"updated\");\n\n        invokeReflectionDriver(reflectionDriver, \"setStaticField\", new Class<?>[] { Field.class, Object.class },\n                staticMessageField, \"changed\");\n        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, \"staticMessage\"))\n                .isEqualTo(\"changed\");\n    }\n\n    private static Object invokeReflectionDriver(final Object reflectionDriver, final String methodName,\n            final Class<?>[] parameterTypes, final Object... args) throws ReflectiveOperationException {\n        final Method driverMethod = reflectionDriver.getClass().getDeclaredMethod(methodName, parameterTypes);\n        driverMethod.setAccessible(true);\n        return driverMethod.invoke(reflectionDriver, args);\n    }\n\n    private static final class ReflectionTarget {\n        private String message = \"initial\";\n        private static String staticMessage = \"static\";\n\n        private String append(final String suffix) {\n            return message + suffix;\n        }\n\n        private static String staticGreeting(final String prefix) {\n            return prefix + \" \" + staticMessage;\n        }\n    }\n}\n"}
