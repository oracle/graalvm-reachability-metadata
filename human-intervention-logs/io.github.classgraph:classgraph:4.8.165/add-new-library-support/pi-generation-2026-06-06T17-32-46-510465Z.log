main/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport io.github.classgraph.ClassGraph;\nimport io.github.classgraph.ClassGraph.CircumventEncapsulationMethod;\nimport nonapi.io.github.classgraph.reflection.ReflectionUtils;\n\npublic class NarcissusReflectionDriverTest {\n    @AfterEach\n    void resetReflectionDriverSelection() {\n        ReflectionTarget.staticMessage = \"static\";\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;\n    }\n\n    @Test\n    void accessesMembersThroughNarcissusReflectionDriver() throws ReflectiveOperationException {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NARCISSUS;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n        final ReflectionTarget target = new ReflectionTarget();\n\n        assertThat(reflectionUtils.reflectionDriver.getClass().getName())\n                .isEqualTo(\"nonapi.io.github.classgraph.reflection.NarcissusReflectionDriver\");\n        assertThat(reflectionUtils.classForNameOrNull(ReflectionTarget.class.getName()))\n                .isEqualTo(ReflectionTarget.class);\n        assertThat(reflectionUtils.getFieldVal(true, target, \"message\")).isEqualTo(\"initial\");\n        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, \"staticMessage\"))\n                .isEqualTo(\"static\");\n        assertThat(reflectionUtils.invokeMethod(true, target, \"append\", String.class, \" value\"))\n                .isEqualTo(\"initial value\");\n        assertThat(reflectionUtils.invokeStaticMethod(true, ReflectionTarget.class, \"staticGreeting\", String.class,\n                \"hi\")).isEqualTo(\"hi static\");\n    }\n\n    @Test\n    void invokesPackagePrivateDriverOperationsNotExposedByReflectionUtils() throws Exception {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NARCISSUS;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n        final ReflectionTarget target = new ReflectionTarget();\n        final Object reflectionDriver = reflectionUtils.reflectionDriver;\n        final Field messageField = ReflectionTarget.class.getDeclaredField(\"message\");\n        final Field staticMessageField = ReflectionTarget.class.getDeclaredField(\"staticMessage\");\n\n        assertThat(invokeReflectionDriver(reflectionDriver, \"getDeclaredConstructors\",\n                new Class<?>[] { Class.class }, ReflectionTarget.class)).isNotNull();\n\n        invokeReflectionDriver(reflectionDriver, \"setField\", new Class<?>[] { Object.class, Field.class, Object.class },\n                target, messageField, \"updated\");\n        assertThat(reflectionUtils.getFieldVal(true, target, \"message\")).isEqualTo(\"updated\");\n\n        invokeReflectionDriver(reflectionDriver, \"setStaticField\", new Class<?>[] { Field.class, Object.class },\n                staticMessageField, \"changed\");\n        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, \"staticMessage\"))\n                .isEqualTo(\"changed\");\n    }\n\n    private static Object invokeReflectionDriver(final Object reflectionDriver, final String methodName,\n            final Class<?>[] parameterTypes, final Object... args) throws ReflectiveOperationException {\n        final Method driverMethod = reflectionDriver.getClass().getDeclaredMethod(methodName, parameterTypes);\n        driverMethod.setAccessible(true);\n        return driverMethod.invoke(reflectionDriver, args);\n    }\n\n    private static final class ReflectionTarget {\n        private String message = \"initial\";\n        private static String staticMessage = \"static\";\n\n        private String append(final String suffix) {\n            return message + suffix;\n        }\n\n        private static String staticGreeting(final String prefix) {\n            return prefix + \" \" + staticMessage;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 10934, "output": 2228, "cacheRead": 39424, "cacheWrite": 0, "totalTokens": 52586, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780767056542, "responseId": "resp_07d3aef62b557ac3016a24595120908190b5c8d8c1abd855b1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZYv8zdfgEO3jHNeKbsAyyIkz|fc_07d3aef62b557ac3016a24597b11a0819085a49db789d36d0d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4205 bytes to tests/src/io.github.classgraph/classgraph/4.8.165/src/test/java/io_github_classgraph/classgraph/NarcissusReflectionDriverTest.java"}], "isError": false, "timestamp": 1780767110648}]}
