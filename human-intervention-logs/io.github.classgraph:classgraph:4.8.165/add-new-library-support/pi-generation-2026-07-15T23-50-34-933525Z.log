  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  
  import nonapi.io.github.classgraph.json.JSONSerializer;
  
  public class JSONUtilsTest {
      @Test
      void serializesPrimitiveFieldsAndSkipsInaccessibleInheritedFields() {
          final String json = JSONSerializer.serializeObject(new PrimitiveValues());
  
          assertThat(json).contains("\"booleanValue\":true", "\"byteValue\":7", "\"charValue\":\"x\"",
                  "\"doubleValue\":6.25", "\"floatValue\":5.5", "\"intValue\":1", "\"longValue\":2",
                  "\"shortValue\":3", "\"stringValue\":\"value\"");
      }
  
      private static final class PrimitiveValues extends Throwable {
          private static final long serialVersionUID = 1L;
  
          private boolean booleanValue = true;
          private byte byteValue = 7;
          private char charValue = 'x';
          private double doubleValue = 6.25;
          private float floatValue = 5.5F;
          private int intValue = 1;
          private long longValue = 2L;
          private short shortValue = 3;
          private String stringValue = "value";
      }
  }
