[tool-call] delta {"path":"tests/src/io.github.classgraph/classgraph/4.8.165/src/test/java/io_github_classgraph/classgraph/FieldTypeInfoTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\n\nimport nonapi.io.github.classgraph.json.JSONDeserializer;\n\npublic class FieldTypeInfoTest {\n    @Test\n    void deserializesPrimitiveClassAndReferenceFields() {\n        final DeserializationTarget deserialized = JSONDeserializer.deserializeObject(DeserializationTarget.class, \"\"\"\n                {\n                  \"booleanValue\": true,\n                  \"byteValue\": 7,\n                  \"charValue\": \"x\",\n                  \"classValue\": \"java.lang.String\",\n                  \"doubleValue\": 6.25,\n                  \"floatValue\": 5.5,\n                  \"intValue\": 1,\n                  \"longValue\": 2,\n                  \"shortValue\": 3,\n                  \"stringValue\": \"value\",\n                  \"nullValue\": null\n                }\n                \"\"\");\n\n        assertThat(deserialized.booleanValue).isTrue();\n        assertThat(deserialized.byteValue).isEqualTo((byte) 7);\n        assertThat(deserialized.charValue).isEqualTo('x');\n        assertThat(deserialized.classValue).isEqualTo(String.class);\n        assertThat(deserialized.doubleValue).isEqualTo(6.25);\n        assertThat(deserialized.floatValue).isEqualTo(5.5F);\n        assertThat(deserialized.intValue).isEqualTo(1);\n        assertThat(deserialized.longValue).isEqualTo(2L);\n        assertThat(deserialized.shortValue).isEqualTo((short) 3);\n        assertThat(deserialized.stringValue).isEqualTo(\"value\");\n        assertThat(deserialized.nullValue).isNull();\n    }\n\n    public static class DeserializationTarget {\n        public boolean booleanValue;\n        public byte byteValue;\n        public char charValue;\n        public Class<?> classValue;\n        public double doubleValue;\n        public float floatValue;\n        public int intValue;\n        public long longValue;\n        public short shortValue;\n        public String stringValue;\n        public String nullValue;\n    }\n}\n"}
