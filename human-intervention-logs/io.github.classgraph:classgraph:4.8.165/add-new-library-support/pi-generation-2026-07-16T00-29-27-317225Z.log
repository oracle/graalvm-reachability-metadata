       */
      public Constructor<?> getConstructorForFieldTypeWithSizeHint(final Type fieldTypeFullyResolved,
              final ClassFieldCache classFieldCache) {
          if (!isTypeVariable) {
              return constructorForFieldTypeWithSizeHint;
          } else {
