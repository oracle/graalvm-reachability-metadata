[tool-call] delta {"path":"tests/src/io.github.classgraph/classgraph/4.8.165/src/test/java/io_github_classgraph/classgraph/JSONDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.LinkedList;\n\nimport org.junit.jupiter.api.Test;\n\nimport nonapi.io.github.classgraph.json.JSONDeserializer;\n\npublic class JSONDeserializerTest {\n    @Test\n    void deserializesNestedArrays() {\n        final ArrayTarget deserialized = JSONDeserializer.deserializeObject(ArrayTarget.class, \"\"\"\n                {\n                  \"values\": [\"first\", \"second\"]\n                }\n                \"\"\");\n\n        assertThat(deserialized.values).containsExactly(\"first\", \"second\");\n    }\n\n    @Test\n    void deserializesNestedObjectsAndCollections() {\n        final CollectionTarget deserialized = JSONDeserializer.deserializeObject(CollectionTarget.class, \"\"\"\n                {\n                  \"defaultValues\": [\"first\", \"second\"],\n                  \"nestedValue\": {\"value\": \"nested\"},\n                  \"sizedValues\": [{\"value\": \"one\"}, {\"value\": \"two\"}]\n                }\n                \"\"\");\n\n        assertThat(deserialized.defaultValues).containsExactly(\"first\", \"second\");\n        assertThat(deserialized.nestedValue.value).isEqualTo(\"nested\");\n        assertThat(deserialized.sizedValues).extracting(value -> value.value).containsExactly(\"one\", \"two\");\n    }\n\n    public static class ArrayTarget {\n        public String[] values;\n    }\n\n    public static class CollectionTarget {\n        public LinkedList<String> defaultValues;\n        public NestedValue nestedValue;\n        public ArrayList<NestedValue> sizedValues;\n    }\n\n    public static class NestedValue {\n        public String value;\n    }\n}\n"}
