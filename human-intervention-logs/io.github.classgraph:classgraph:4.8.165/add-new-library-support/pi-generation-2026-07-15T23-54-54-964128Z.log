[tool-call] delta {"path":"tests/src/io.github.classgraph/classgraph/4.8.165/src/test/java/io_github_classgraph/classgraph/JVMDriverReflectionDriverTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport io.github.classgraph.ClassGraph;\nimport io.github.classgraph.ClassGraph.CircumventEncapsulationMethod;\nimport nonapi.io.github.classgraph.reflection.ReflectionUtils;\n\npublic class JVMDriverReflectionDriverTest {\n    private final CircumventEncapsulationMethod originalMethod = ClassGraph.CIRCUMVENT_ENCAPSULATION;\n\n    @AfterEach\n    void restoreCircumventEncapsulationMethod() {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = originalMethod;\n    }\n\n    @Test\n    void usesJvmDriverToAccessPrivateMembers() {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.JVM_DRIVER;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n        final ReflectiveTarget target = new ReflectiveTarget();\n\n        assertThat(reflectionUtils.classForNameOrNull(ReflectiveTarget.class.getName()))\n                .isEqualTo(ReflectiveTarget.class);\n        assertThat(reflectionUtils.getFieldVal(true, target, \"message\")).isEqualTo(\"initial\");\n        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectiveTarget.class, \"DEFAULT_MESSAGE\"))\n                .isEqualTo(\"default\");\n        assertThat(reflectionUtils.invokeMethod(true, target, \"messageWithSuffix\", String.class, \" value\"))\n                .isEqualTo(\"initial value\");\n        assertThat(reflectionUtils.invokeStaticMethod(true, ReflectiveTarget.class, \"defaultMessage\"))\n                .isEqualTo(\"default\");\n    }\n\n    private static final class ReflectiveTarget {\n        private static final String DEFAULT_MESSAGE = \"default\";\n\n        private final String message = \"initial\";\n\n        private String messageWithSuffix(final String suffix) {\n            return message + suffix;\n        }\n\n        private static String defaultMessage() {\n            return DEFAULT_MESSAGE;\n        }\n    }\n}\n"}
