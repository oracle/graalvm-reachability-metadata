aph.reflection.ReflectionUtils;\n\npublic class JSONUtilsTest {\n    @Test\n    void serializesPrimitiveAndObjectFields() {\n        final PrimitiveFieldValues values = new PrimitiveFieldValues();\n\n        final String json = JSONSerializer.serializeObject(values);\n\n        assertThat(json)\n                .contains(\"\\\"booleanValue\\\":true\")\n                .contains(\"\\\"byteValue\\\":7\")\n                .contains(\"\\\"charValue\\\":\\\"Z\\\"\")\n                .contains(\"\\\"doubleValue\\\":1.5\")\n                .contains(\"\\\"floatValue\\\":2.5\")\n                .contains(\"\\\"intValue\\\":42\")\n                .contains(\"\\\"longValue\\\":123456789\")\n                .contains(\"\\\"objectValue\\\":\\\"text\\\"\")\n                .contains(\"\\\"shortValue\\\":12\");\n    }\n\n    @Test\n    void reportsInaccessibleJdkFieldWithoutThrowing() throws NoSuchFieldException {\n        final Field field = String.class.getDeclaredField(\"value\");\n\n        final boolean accessible = JSONUtils.makeAccessible(field, new ReflectionUtils());\n\n        assertThat(accessible).isFalse();\n    }\n\n    private static final class PrimitiveFieldValues {\n        private int intValue = 42;\n        private long longValue = 123456789L;\n        private short shortValue = 12;\n        private double doubleValue = 1.5D;\n        private float floatValue = 2.5F;\n        private boolean booleanValue = true;\n        private byte byteValue = 7;\n        private char charValue = 'Z';\n        private String objectValue = \"text\";\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1574, "output": 2333, "cacheRead": 33792, "cacheWrite": 0, "totalTokens": 37699, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780764651295, "responseId": "resp_05b7869a994ac52d016a244febfd508194a1f33e30535ad211"}}
