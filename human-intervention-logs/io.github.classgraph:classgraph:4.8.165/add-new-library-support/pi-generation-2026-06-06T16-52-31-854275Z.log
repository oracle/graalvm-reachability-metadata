ue = 42;\n        private long longValue = 123456789L;\n        private short shortValue = 12;\n        private double doubleValue = 1.5D;\n        private float floatValue = 2.5F;\n        private boolean booleanValue = true;\n        private byte byteValue = 7;\n        private char charValue = 'Z';\n        private String objectValue = \"text\";\n    }\n}\n"}
