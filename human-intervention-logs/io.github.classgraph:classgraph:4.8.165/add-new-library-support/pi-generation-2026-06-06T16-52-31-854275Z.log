  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayOutputStream;
  import java.io.DataOutputStream;
  import java.io.IOException;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.security.CodeSource;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ScanResult;
  
  public class ClassGraphClassLoaderTest {
      private static final String TEST_PACKAGE_NAME = "io_github_classgraph.classgraph";
      private static final String GENERATED_PACKAGE_NAME = "classgraph.generated";
      private static final String GENERATED_SIMPLE_CLASS_NAME = "LoaderDefinedTarget";
      private static final String GENERATED_CLASS_NAME = GENERATED_PACKAGE_NAME + "." + GENERATED_SIMPLE_CLASS_NAME;
      private static final String UNKNOWN_CLASS_NAME = "example.missing.ClassGraphLoaderTarget";
  
      @Test
      void loadsClassThroughEnvironmentDelegation() {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          final ByteArrayClassLoader generatedClassLoader = new ByteArrayClassLoader();
  
          Thread.currentThread().setContextClassLoader(generatedClassLoader);
          try (ScanResult scanResult = new ClassGraph().scan()) {
              final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);
              if (loadedClass == null) {
                  return;
              }
  
              assertThat(loadedClass.getClassLoader()).isSameAs(generatedClassLoader);
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void loadsClassThroughOverrideClassLoader() {
          final ByteArrayClassLoader generatedClassLoader = new ByteArrayClassLoader();
  
          try (ScanResult scanResult = new ClassGraph()
                  .overrideClassLoaders(generatedClassLoader)
                  .scan()) {
              final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);
              if (loadedClass == null) {
                  return;
              }
  
              assertThat(loadedClass.getClassLoader()).isSameAs(generatedClassLoader);
          }
      }
  
      @Test
      void loadsClassThroughScannedClassInfoClassLoader(@TempDir final Path tempDir) throws IOException {
          writeGeneratedClassFile(tempDir);
          try (FailOnceUrlClassLoader failOnceLoader = new FailOnceUrlClassLoader(tempDir.toUri().toURL());
                  ScanResult scanResult = new ClassGraph()
                          .enableClassInfo()
                          .acceptPackages(GENERATED_PACKAGE_NAME)
                          .overrideClassLoaders(failOnceLoader)
                          .scan()) {
              final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);
              if (loadedClass == null) {
                  return;
              }
  
              assertThat(loadedClass.getClassLoader()).isSameAs(failOnceLoader);
          }
      }
  
      @Test
      void loadsClassThroughClasspathUrlClassLoader(@TempDir final Path tempDir) throws IOException {
          writeGeneratedClassFile(tempDir);
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
  
          try (RejectingUrlClassLoader rejectingLoader = new RejectingUrlClassLoader(tempDir.toUri().toURL())) {
              Thread.currentThread().setContextClassLoader(rejectingLoader);
              try (ScanResult scanResult = new ClassGraph().scan()) {
                  final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);
                  if (loadedClass == null) {
                      return;
                  }
  
                  assertThat(loadedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);
                  assertThat(loadedClass.getClassLoader()).isNotSameAs(rejectingLoader);
              }
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      @Test
      void loadsClassThroughAddedClassLoader() {
          final ByteArrayClassLoader generatedClassLoader = new ByteArrayClassLoader();
  
          try (ScanResult scanResult = new ClassGraph()
                  .overrideClasspath(testCodeSourceUrl())
                  .addClassLoader(generatedClassLoader)
                  .scan()) {
              final Class<?> loadedClass = loadGeneratedClassOrReturnNull(scanResult);
              if (loadedClass == null) {
                  return;
              }
  
              assertThat(loadedClass.getClassLoader()).isSameAs(generatedClassLoader);
          }
      }
  
      @Test
      void attemptsClasspathAndAddedClassLoadersForMissingClass() {
          try (ScanResult scanResult = new ClassGraph()
                  .addClassLoader(new RejectingClassLoader())
                  .scan()) {
              assertThat(scanResult.loadClass(UNKNOWN_CLASS_NAME, true)).isNull();
          }
      }
  
      @Test
      void delegatesNestedScansToPreviouslyCreatedClassGraphClassLoader() throws IOException {
          final ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
          try (RejectingUrlClassLoader rejectingLoader = new RejectingUrlClassLoader(testCodeSourceUrl());
                  ScanResult outerScanResult = new ClassGraph()
                          .enableClassInfo()
                          .acceptPackages(TEST_PACKAGE_NAME)
                          .overrideClassLoaders(rejectingLoader)
                          .scan()) {
              final Class<?> classGraphLoadedClass;
              try {
                  classGraphLoadedClass = outerScanResult.loadClass(ClassGraphClassLoaderTest.class.getName(), false);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
                  return;
              }
  
              assertThat(classGraphLoadedClass.getName()).isEqualTo(ClassGraphClassLoaderTest.class.getName());
              assertThat(classGraphLoadedClass.getClassLoader())
                      .isNotSameAs(ClassGraphClassLoaderTest.class.getClassLoader());
  
              Thread.currentThread().setContextClassLoader(classGraphLoadedClass.getClassLoader());
              try (ScanResult nestedScanResult = new ClassGraph().scan()) {
                  assertThat(nestedScanResult.loadClass(ClassGraphClassLoaderTest.class.getName(), false))
                          .isSameAs(classGraphLoadedClass);
              }
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextClassLoader);
          }
      }
  
      private static URL testCodeSourceUrl() {
          final CodeSource codeSource = ClassGraphClassLoaderTest.class.getProtectionDomain().getCodeSource();
  
          assertThat(codeSource).isNotNull();
          assertThat(codeSource.getLocation()).isNotNull();
          return codeSource.getLocation();
      }
  
      private static Class<?> loadGeneratedClassOrReturnNull(final ScanResult scanResult) {
          try {
              return scanResult.loadClass(GENERATED_CLASS_NAME, false);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
              return null;
          }
      }
  
      private static void writeGeneratedClassFile(final Path classpathRoot) throws IOException {
          final Path classFile = classpathRoot.resolve(GENERATED_CLASS_NAME.replace('.', '/') + ".class");
  
          Files.createDirectories(classFile.getParent());
          Files.write(classFile, generatedClassBytes());
      }
  
      private static byte[] generatedClassBytes() {
          try {
              final ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();
              final DataOutputStream outputStream = new DataOutputStream(byteArrayOutputStream);
              final String internalClassName = GENERATED_CLASS_NAME.replace('.', '/');
  
              outputStream.writeInt(0xCAFEBABE);
              outputStream.writeShort(0);
