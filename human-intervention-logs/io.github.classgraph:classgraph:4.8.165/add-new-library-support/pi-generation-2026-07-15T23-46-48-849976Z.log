  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.concurrent.Callable;
  
  import org.junit.jupiter.api.Test;
  
  import nonapi.io.github.classgraph.reflection.ReflectionUtils;
  
  public class StandardReflectionDriverTest {
      @Test
      void usesStandardReflectionToAccessMembersAndInvokeMethods() throws Throwable {
          final ReflectionUtils reflectionUtils = new ReflectionUtils();
          final ReflectiveTarget target = new ReflectiveTarget();
  
          assertThat(reflectionUtils.classForNameOrNull(ReflectiveTarget.class.getName()))
                  .isEqualTo(ReflectiveTarget.class);
          assertThat(reflectionUtils.getFieldVal(true, target, "message")).isEqualTo("initial");
          assertThat(reflectionUtils.getStaticFieldVal(true, ReflectiveTarget.class, "DEFAULT_MESSAGE"))
                  .isEqualTo("default");
          assertThat(reflectionUtils.invokeMethod(true, target, "messageWithSuffix", String.class, " value"))
                  .isEqualTo("initial value");
          assertThat(reflectionUtils.invokeStaticMethod(true, ReflectiveTarget.class, "defaultMessage"))
                  .isEqualTo("default");
          assertThat(reflectionUtils.doPrivileged(new Callable<String>() {
              @Override
              public String call() {
                  return "privileged";
              }
          })).isEqualTo("privileged");
      }
  
      private static final class ReflectiveTarget {
          private static final String DEFAULT_MESSAGE = "default";
  
          private final String message = "initial";
  
          private String messageWithSuffix(final String suffix) {
              return message + suffix;
          }
  
          private static String defaultMessage() {
              return DEFAULT_MESSAGE;
          }
      }
  }
