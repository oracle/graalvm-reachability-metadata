  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.URL;
  import java.net.URLClassLoader;
  
  import io.github.classgraph.ClassGraph;
  import io.github.classgraph.ScanResult;
  import org.junit.jupiter.api.Test;
  
  public class ClassGraphClassLoaderTest {
      private static final String MISSING_CLASS_NAME = "io.github.classgraph.testsupport.MissingClass";
  
      @Test
      void returnsNullForClassAbsentFromTheScannedClasspath() {
          try (ScanResult scanResult = new ClassGraph().enableClassInfo().scan()) {
              assertThat(scanResult.loadClass(ClassGraph.class.getName(), true)).isEqualTo(ClassGraph.class);
              assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();
          }
      }
  
      @Test
      void delegatesClassLoadingToOverriddenClassLoaders() {
          try (ScanResult scanResult = new ClassGraph().enableClassInfo().acceptClasses(ClassGraph.class.getName())
                  .overrideClassLoaders(ClassGraph.class.getClassLoader()).scan()) {
              assertThat(scanResult.loadClass(ClassGraph.class.getName(), true)).isEqualTo(ClassGraph.class);
              assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();
          }
      }
  
      @Test
      void triesAddedClassLoadersAfterTheScannedClasspath() throws Exception {
          try (URLClassLoader additionalClassLoader = new URLClassLoader(new URL[0],
                  ClassLoader.getPlatformClassLoader());
                  ScanResult scanResult = new ClassGraph().enableClassInfo().acceptClasses(ClassGraph.class.getName())
                          .addClassLoader(additionalClassLoader).scan()) {
              assertThat(scanResult.loadClass(MISSING_CLASS_NAME, true)).isNull();
          }
      }
  }
