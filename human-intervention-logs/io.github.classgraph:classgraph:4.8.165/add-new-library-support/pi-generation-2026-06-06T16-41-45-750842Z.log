       }\n     }\n+\n+    private static final class FailOnceUrlClassLoader extends URLClassLoader {\n+        private boolean generatedClassRejected;\n+\n+        FailOnceUrlClassLoader(final URL url) {\n+            super(new URL[] { url }, null);\n+        }\n+\n+        @Override\n+        public Class<?> loadClass(final String name) throws ClassNotFoundException {\n+            if (GENERATED_CLASS_NAME.equals(name) && !generatedClassRejected) {\n+                generatedClassRejected = true;\n+                throw new ClassNotFoundException(name);\n+            }\n+            return super.loadClass(name);\n+        }\n+    }\n+\n+    private static final class ByteArrayClassLoader extends ClassLoader {\n+        ByteArrayClassLoader() {\n+            super(null);\n+        }\n+\n+        @Override\n+        protected Class<?> findClass(final String name) throws ClassNotFoundException {\n+            if (!GENERATED_CLASS_NAME.equals(name)) {\n+                throw new ClassNotFoundException(name);\n+            }\n+            final byte[] classBytes = generatedClassBytes();\n+            return defineClass(name, classBytes, 0, classBytes.length);\n+        }\n+    }\n }\n M tests/src/io.github.classgraph/classgraph/4.8.165/src/test/java/io_github_classgraph/classgraph/ClassGraphClassLoaderTest.java\n"}], "isError": false, "timestamp": 1780764339518}]}
