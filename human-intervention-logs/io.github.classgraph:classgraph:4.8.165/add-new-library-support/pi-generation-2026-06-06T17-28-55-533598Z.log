       *     Minus ← "-"
       * 
       *     IntegralPart ← "0" / [1-9] [0-9]*
       * 
       *     FractionalPart ← "." [0-9]+
       * 
       *     ExponentPart ← ( "e" / "E" ) ( "+" / "-" )? [0-9]+
       * 
       * </pre>
       *
       * @return the number
       * @throws ParseException
       *             if parsing fails
       */
      private Number parseNumber() throws ParseException {
