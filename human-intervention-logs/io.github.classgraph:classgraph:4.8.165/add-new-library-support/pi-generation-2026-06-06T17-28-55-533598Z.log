          } else if (peekMatches("-Infinity")) {
              advance(9);
              return Double.NEGATIVE_INFINITY;
          } else if (peekMatches("NaN")) {
              advance(3);
              return Double.NaN;
          }
          if (peek() == '-') {
              next();
          }
          final int integralStartIdx = getPosition();
          for (; hasMore(); next()) {
              final char c = peek();
              if (c < '0' || c > '9') {
