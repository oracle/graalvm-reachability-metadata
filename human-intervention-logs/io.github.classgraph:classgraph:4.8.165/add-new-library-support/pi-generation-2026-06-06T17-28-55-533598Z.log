  package io_github_classgraph.classgraph;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  
  import nonapi.io.github.classgraph.json.JSONDeserializer;
  
  public class FieldTypeInfoTest {
      @Test
      void deserializesEveryPrimitiveAndBasicObjectField() {
          final String json = """
                  {
                    "booleanValue": true,
                    "byteValue": 7,
                    "charValue": "Z",
                    "classValue": "java.lang.String",
                    "doubleValue": 1.5,
                    "floatValue": 2.5,
                    "intValue": 42,
                    "longValue": 12345678901,
                    "nullValue": null,
                    "objectValue": "object text",
                    "shortValue": 12
                  }
                  """;
  
          final DeserializedFieldValues values = JSONDeserializer.deserializeObject(DeserializedFieldValues.class,
                  json);
  
          assertThat(values.booleanValue).isTrue();
          assertThat(values.byteValue).isEqualTo((byte) 7);
          assertThat(values.charValue).isEqualTo('Z');
          assertThat(values.classValue).isEqualTo(String.class);
          assertThat(values.doubleValue).isEqualTo(1.5D);
          assertThat(values.floatValue).isEqualTo(2.5F);
          assertThat(values.intValue).isEqualTo(42);
          assertThat(values.longValue).isEqualTo(12_345_678_901L);
          assertThat(values.nullValue).isNull();
          assertThat(values.objectValue).isEqualTo("object text");
          assertThat(values.shortValue).isEqualTo((short) 12);
      }
  
      public static final class DeserializedFieldValues {
          public int intValue;
          public long longValue;
          public short shortValue;
          public double doubleValue;
          public float floatValue;
          public boolean booleanValue;
          public byte byteValue;
          public char charValue;
          public Class<?> classValue;
          public String nullValue = "initial";
          public Object objectValue;
  
          public DeserializedFieldValues() {
          }
      }
  }
