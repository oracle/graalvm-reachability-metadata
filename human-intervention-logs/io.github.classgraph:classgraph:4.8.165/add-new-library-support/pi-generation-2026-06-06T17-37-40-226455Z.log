ertions.assertThat;\n\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport io.github.classgraph.ClassGraph;\nimport io.github.classgraph.ClassGraph.CircumventEncapsulationMethod;\nimport nonapi.io.github.classgraph.reflection.ReflectionUtils;\n\npublic class NarcissusReflectionDriverTest {\n    @AfterEach\n    void resetReflectionDriverSelection() {\n        ReflectionTarget.staticMessage = \"static\";\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;\n    }\n\n    @Test\n    void accessesMembersThroughNarcissusReflectionDriver() throws ReflectiveOperationException {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NARCISSUS;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n        final ReflectionTarget target = new ReflectionTarget();\n        final Object reflectionDriver = reflectionUtils.reflectionDriver;\n\n        assertThat(reflectionDriver.getClass().getName())\n                .isEqualTo(\"nonapi.io.github.classgraph.reflection.NarcissusReflectionDriver\");\n        assertThat(reflectionUtils.classForNameOrNull(ReflectionTarget.class.getName()))\n                .isEqualTo(ReflectionTarget.class);\n        assertThat(reflectionUtils.getFieldVal(true, target, \"message\")).isEqualTo(\"initial\");\n        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, \"staticMessage\"))\n                .isEqualTo(\"static\");\n        assertThat(reflectionUtils.invokeMethod(true, target, \"append\", String.class, \" value\"))\n                .isEqualTo(\"initial value\");\n        assertThat(reflectionUtils.invokeStaticMethod(true, ReflectionTarget.class, \"staticGreeting\", String.class,\n                \"hi\")).isEqualTo(\"hi static\");\n    }\n\n    @Test\n    void invokesPackagePrivateDriverOperationsNotExposedByReflectionUtils() throws Exception {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NARCISSUS;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n        final ReflectionTarget target = new ReflectionTarget();\n        final Object reflectionDriver = reflectionUtils.reflectionDriver;\n        final Field messageField = ReflectionTarget.class.getDeclaredField(\"message\");\n        final Field staticMessageField = ReflectionTarget.class.getDeclaredField(\"staticMessage\");\n\n        assertThat(invokeReflectionDriver(reflectionDriver, \"getDeclaredConstructors\",\n                new Class<?>[] { Class.class }, ReflectionTarget.class)).isNotNull();\n\n        invokeReflectionDriver(reflectionDriver, \"setField\", new Class<?>[] { Object.class, Field.class, Object.class },\n                target, messageField, \"updated\");\n        assertThat(reflectionUtils.getFieldVal(true, target, \"message\")).isEqualTo(\"updated\");\n\n        invokeReflectionDriver(reflectionDriver, \"setStaticField\", new Class<?>[] { Field.class, Object.class },\n                staticMessageField, \"changed\");\n        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, \"staticMessage\"))\n                .isEqualTo(\"changed\");\n    }\n\n    private static Object invokeReflectionDriver(final Object reflectionDriver, final String methodName,\n            final Class<?>[] parameterTypes, final Object... args) throws ReflectiveOperationException {\n        final Method driverMethod = reflectionDriver.getClass().getDeclaredMethod(methodName, parameterTypes);\n        driverMethod.setAccessible(true);\n        return driverMethod.invoke(reflectionDriver, args);\n    }\n\n    private static final class ReflectionTarget {\n        private String message = \"initial\";\n        private static String staticMessage = \"static\";\n\n        private String append(final String suffix) {\n            return message + suffix;\n        }\n\n        private static String staticGreeting(final String prefix) {\n            return prefix + \" \" + staticMessage;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780767224950}, {"role": "toolResult", "toolCallId": "call_YIgmc4vLQg0S5ssddxiRVwQF|fc_04c366b99325990b016a2459f8bf2081939e57443e785954f3", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_classgraph.classgraph;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport io.github.classgraph.ClassGraph;\nimport io.github.classgraph.ClassGraph.CircumventEncapsulationMethod;\nimport nonapi.io.github.classgraph.reflection.ReflectionUtils;\n\npublic class StandardReflectionDriverTest {\n    @AfterEach\n    void resetReflectionDriverSelection() {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;\n    }\n\n    @Test\n    void accessesMembersThroughStandardReflectionDriver() {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n        final ReflectionTarget target = new ReflectionTarget();\n\n        assertThat(reflectionUtils.classForNameOrNull(ReflectionTarget.class.getName()))\n                .isEqualTo(ReflectionTarget.class);\n        assertThat(reflectionUtils.getFieldVal(true, target, \"message\")).isEqualTo(\"initial\");\n        assertThat(reflectionUtils.getStaticFieldVal(true, ReflectionTarget.class, \"staticMessage\"))\n                .isEqualTo(\"static\");\n        assertThat(reflectionUtils.invokeMethod(true, target, \"append\", String.class, \" value\"))\n                .isEqualTo(\"initial value\");\n        assertThat(reflectionUtils.invokeStaticMethod(true, ReflectionTarget.class, \"staticGreeting\", String.class,\n                \"hi\")).isEqualTo(\"hi static\");\n    }\n\n    @Test\n    void handlesInaccessibleJdkFieldWhenExceptionThrowingIsDisabled() {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.NONE;\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n\n        final Object value = reflectionUtils.getFieldVal(false, \"classgraph\", \"value\");\n\n        assertThat(value == null || value.getClass().isArray()).isTrue();\n    }\n\n    @Test\n    void initializesJvmDriverSupportThroughStandardReflectionDriver() {\n        ClassGraph.CIRCUMVENT_ENCAPSULATION = CircumventEncapsulationMethod.JVM_DRIVER;\n\n        final ReflectionUtils reflectionUtils = new ReflectionUtils();\n\n        assertThat(reflectionUtils.classForNameOrNull(ReflectionTarget.class.getName()))\n                .isEqualTo(ReflectionTarget.class);\n    }\n\n    private static final class ReflectionTarget {\n        private String message = \"initial\";\n        private static String staticMessage = \"static\";\n\n        private String append(final String suffix) {\n            return message + suffix;\n        }\n\n        private static String staticGreeting(final String prefix) {\n            return prefix + \" \" + staticMessage;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780767224951}, {"role": "toolResult", "toolCallId": "call_SiUVYUz9rg8lXi7C1QoZMmUE|fc_04c366b99325990b016a2459f8bf2881939b6dec310f1da024", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.github.classgraph:classgraph:$libraryVersion\"\