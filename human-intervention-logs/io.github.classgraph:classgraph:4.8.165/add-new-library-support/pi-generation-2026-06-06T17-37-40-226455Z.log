<?>... parameterTypes)\n            throws NoSuchMethodException {\n        for (Class<?> currentType = type; currentType != null; currentType = currentType.getSuperclass()) {\n            try {\n                final Method method = currentType.getDeclaredMethod(methodName, parameterTypes);\n                method.setAccessible(true);\n                return method;\n            } catch (final NoSuchMethodException e) {\n                for (final Class<?> interfaceType : currentType.getInterfaces()) {\n                    try {\n                        final Method method = interfaceType.getDeclaredMethod(methodName, parameterTypes);\n                        method.setAccessible(true);\n                        return method;\n                    } catch (final NoSuchMethodException ignored) {\n                        // Try the next interface.\n                    }\n                }\n            }\n        }\n        throw new NoSuchMethodException(type.getName() + \".\" + methodName);\n    }\n\n    private static Unsafe unsafe() throws ReflectiveOperationException {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3094, "output": 1460, "cacheRead": 54272, "cacheWrite": 0, "totalTokens": 58826, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780767420857, "responseId": "resp_04c366b99325990b016a245abd76c881938197fa1c6e1ca86f"}}
