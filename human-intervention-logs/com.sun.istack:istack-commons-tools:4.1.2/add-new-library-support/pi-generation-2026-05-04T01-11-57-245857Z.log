  package com_sun_istack.istack_commons_tools;
  
  import com.sun.istack.tools.ParallelWorldClassLoader;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Base64;
  import java.util.Enumeration;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertSame;
  
  public class ParallelWorldClassLoaderTest {
      private static final String PREFIX = "parallel-world/";
      private static final String CLASS_NAME = "ParallelWorldClassLoaderLoaded";
      private static final String CLASS_RESOURCE = CLASS_NAME + ".class";
      private static final String TEXT_RESOURCE = "sample.txt";
      private static final byte[] CLASS_BYTES = Base64.getMimeDecoder().decode("""
              yv66vgAAADQAEQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+
              AQADKClWCAAIAQAGbG9hZGVkBwAKAQAeUGFyYWxsZWxXb3JsZENsYXNzTG9hZGVy
              TG9hZGVkAQAEQ29kZQEAD0xpbmVOdW1iZXJUYWJsZQEAB21lc3NhZ2UBABQoKUxq
              YXZhL2xhbmcvU3RyaW5nOwEAClNvdXJjZUZpbGUBACNQYXJhbGxlbFdvcmxkQ2xh
              c3NMb2FkZXJMb2FkZWQuamF2YQAhAAkAAgAAAAAAAgABAAUABgABAAsAAAAdAAEA
              AQAAAAUqtwABsQAAAAEADAAAAAYAAQAAAAEAAQANAA4AAQALAAAAGwABAAEAAAAD
              EgewAAAAAQAMAAAABgABAAAAAwABAA8AAAACABA=
              """);
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void findsClassBytesInParallelWorld() throws Exception {
          Path root = temporaryDirectory.resolve("classes");
          writeParallelWorldResource(root, CLASS_RESOURCE, CLASS_BYTES);
  
          try (URLClassLoader parent = resourceLoader(root);
                  ExposedParallelWorldClassLoader loader = new ExposedParallelWorldClassLoader(parent)) {
              try {
                  Class<?> loadedClass = loader.findParallelWorldClass(CLASS_NAME);
  
                  assertEquals(CLASS_NAME, loadedClass.getName());
                  assertSame(loader, loadedClass.getClassLoader());
              } catch (Error error) {
                  rethrowUnlessUnsupportedDynamicClassLoading(error);
              }
          }
      }
  
      @Test
      void findsSingleResourceInParallelWorld() throws Exception {
          Path root = temporaryDirectory.resolve("resources");
          writeParallelWorldResource(root, TEXT_RESOURCE, "hello".getBytes(StandardCharsets.UTF_8));
  
          try (URLClassLoader parent = resourceLoader(root);
                  ExposedParallelWorldClassLoader loader = new ExposedParallelWorldClassLoader(parent)) {
              URL resource = loader.findParallelWorldResource(TEXT_RESOURCE);
  
              assertNotNull(resource);
              try (InputStream inputStream = resource.openStream()) {
                  assertEquals("hello", new String(inputStream.readAllBytes(), StandardCharsets.UTF_8));
              }
          }
      }
  
      @Test
      void asksParentForAllResourcesInParallelWorld() throws Exception {
          Path firstRoot = temporaryDirectory.resolve("first-resources");
          Path secondRoot = temporaryDirectory.resolve("second-resources");
          writeParallelWorldResource(firstRoot, TEXT_RESOURCE, "first".getBytes(StandardCharsets.UTF_8));
          writeParallelWorldResource(secondRoot, TEXT_RESOURCE, "second".getBytes(StandardCharsets.UTF_8));
  
          try (URLClassLoader parent = resourceLoader(firstRoot, secondRoot);
                  ExposedParallelWorldClassLoader loader = new ExposedParallelWorldClassLoader(parent)) {
              Enumeration<URL> parentResources = parent.getResources(PREFIX + TEXT_RESOURCE);
              assertNotNull(parentResources.nextElement());
              assertNotNull(parentResources.nextElement());
              assertFalse(parentResources.hasMoreElements());
  
              Enumeration<URL> resources = loader.findParallelWorldResources(TEXT_RESOURCE);
  
              assertFalse(resources.hasMoreElements());
          }
      }
  
      private static void writeParallelWorldResource(Path root, String name, byte[] bytes) throws IOException {
          Path resource = root.resolve(PREFIX).resolve(name);
          Files.createDirectories(resource.getParent());
          Files.write(resource, bytes);
      }
  
      private static URLClassLoader resourceLoader(Path... roots) throws IOException {
          URL[] urls = new URL[roots.length];
          for (int index = 0; index < roots.length; index++) {
              urls[index] = roots[index].toUri().toURL();
          }
          return new URLClassLoader(urls, null);
      }
  
      private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static final class ExposedParallelWorldClassLoader extends ParallelWorldClassLoader {
          ExposedParallelWorldClassLoader(ClassLoader parent) {
              super(parent, PREFIX);
          }
  
          Class<?> findParallelWorldClass(String name) throws ClassNotFoundException {
              return findClass(name);
          }
  
          URL findParallelWorldResource(String name) {
              return findResource(name);
          }
  
          Enumeration<URL> findParallelWorldResources(String name) throws IOException {
              return findResources(name);
          }
      }
  }
