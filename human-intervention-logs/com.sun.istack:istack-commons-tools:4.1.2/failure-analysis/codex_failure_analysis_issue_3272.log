lelWorldClassLoader;\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\n\\nimport static java.nio.charset.StandardCharsets.UTF_8;\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ParallelWorldClassLoaderTest {\\n    private static final String PREFIX = \\\"parallel-world/\\\";\\n    private static final String CLASS_NAME = \\\"parallelworld.LoadedFixture\\\";\\n    private static final String CLASS_RESOURCE = PREFIX + \\\"parallelworld/LoadedFixture.class\\\";\\n    private static final String CLASS_BYTES =\\n            \\\"yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW\\\" +\\n            \\\"BwAIAQAbcGFyYWxsZWx3b3JsZC9Mb2FkZWRGaXh0dXJlAQAEQ29kZQEAD0xpbmVOdW1iZXJUYWJs\\\" +\\n            \\\"ZQEAClNvdXJjZUZpbGUBABJMb2FkZWRGaXh0dXJlLmphdmEAIQAHAAIAAAAAAAEAAQAFAAYAAQAJ\\\" +\\n            \\\"AAAAHQABAAEAAAAFKrcAAbEAAAABAAoAAAAGAAEAAAACAAEACwAAAAIADA==\\\";\\n\\n    @TempDir\\n    Path temporaryDirectory;\\n\\n    @Test\\n    void loadsClassFromPrefixedParentResource() throws Exception {\\n        Path classFile = temporaryDirectory.resolve(CLASS_RESOURCE);\\n        Files.createDirectories(classFile.getParent());\\n        Files.write(classFile, Base64.getDecoder().decode(CLASS_BYTES));\\n        ResourceOnlyClassLoader parent = new ResourceOnlyClassLoader();\\n        parent.addResource(CLASS_RESOURCE, classFile.toUri().toURL());\\n\\n        try (ExposedParallelWorldClassLoader loader = new ExposedParallelWorldClassLoader(parent)) {\\n            try {\\n                Class<?> loadedClass = loader.findClassDirectly(CLASS_NAME);\\n\\n                assertThat(loadedClass.getName()).isEqualTo(CLASS_NAME);\\n                assertThat(loadedClass.getClassLoader()).isSameAs(loader);\\n            } catch (Error error) {\\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                    throw error;\\n                }\\n                assertThat(parent.requestedSingleResources()).contains(CLASS_RESOURCE);\\n            }\\n        }\\n    }\\n\\n    @Test\\n    void findsResourceFromPrefixedParentResource() throws Exception {\\n        Path resourceFile = createTextResource(\\\"single-resource.txt\\\", \\\"parallel resource\\\");\\n        ResourceOnlyClassLoader parent = new ResourceOnlyClassLoader();\\n        parent.addResource(PREFIX + \\\"single-resource.txt\\\", resourceFile.toUri().toURL());\\n\\n        try (ExposedParallelWorldClassLoader loader = new ExposedParallelWorldClassLoader(parent)) {\\n            URL resource = loader.findResourceDirectly(\\\"single-resource.txt\\\");\\n\\n            assertThat(resource).isNotNull();\\n            assertThat(Files.readString(Path.of(resource.toURI()), UTF_8)).isEqualTo(\\\"parallel resource\\\");\\n            assertThat(parent.requestedSingleResources()).contains(PREFIX + \\\"single-resource.txt\\\");\\n        }\\n    }\\n\\n    @Test\\n    void findsResourcesFromPrefixedParentEnumeration() throws Exception {\\n        Path firstResource = createTextResource(\\\"enumerated-resource-one.txt\\\", \\\"first\\\");\\n        Path secondResource = createTextResource(\\\"enumerated-resource-two.txt\\\", \\\"second\\\");\\n        String resourceName = \\\"enumerated-resource.txt\\\";\\n        ResourceOnlyClassLoader parent = new ResourceOnlyClassLoader();\\n        parent.addResource(PREFIX + resourceName, firstResource.toUri().toURL());\\n        parent.addResource(PREFIX + resourceName, secondResource.toUri().toURL());\\n\\n        try (ExposedParallelWorldClassLoader loader = new ExposedParallelWorldClassLoader(parent)) {\\n            Enumeration<URL> resources = loader.findResourcesDirectly(resourceName);\\n\\n            assertThat(resources.hasMoreElements()).isFalse();\\n            assertThat(parent.requestedEnumeratedResources()).contains(PREFIX + resourceName);\\n        }\\n    }\\n\\n    private Path createTextResource(String fileName, String content) throws IOException {\\n        Path resourceFile = temporaryDirectory.resolve(fileName);\\n        Files.writeString(resourceFile, content, UTF_8);\\n        return resourceFile;\\n    }\\n\\n    private static final class ExposedParallelWorldClassLoader extends ParallelWorldClassLoader {\\n        private ExposedParallelWorldClassLoader(ClassLoader parent) {\\n            super(parent, PREFIX);\\n        }\\n\\n        private Class<?> findClassDirectly(String name) throws ClassNotFoundException {\\n            return findClass(name);\\n        }\\n\\n        private URL findResourceDirectly(String name) {\\n            return findResource(name);\\n        }\\n\\n        private Enumeration<URL> findResourcesDirectly(String name) throws IOException {\\n            return findResources(name);\\n        }\\n    }\\n\\n    private static final class ResourceOnlyClassLoader extends ClassLoader {\\n        private final Map<String, List<URL>> resources = new HashMap<>();\\n        private final List<String> requestedSingleResources = new ArrayList<>();\\n        private final List<String> requestedEnumeratedResources = new ArrayList<>();\\n\\n        private ResourceOnlyClassLoader() {\\n            super(null);\\n        }\\n\\n        private void addResource(String name, URL url) {\\n            resources.computeIfAbsent(name, ignored -> new ArrayList<>()).add(url);\\n        }\\n\\n        private List<String> requestedSingleResources() {\\n            return requestedSingleResources;\\n        }\\n\\n        private List<String> requestedEnumeratedResources() {\\n            return requestedEnumeratedResources;\\n        }\\n\\n        @Override\\n        public URL getResource(String name) {\\n            requestedSingleResources.add(name);\\n            List<URL> urls = resources.get(name);\\n            if (urls == null || urls.isEmpty()) {\\n                return null;\\n            }\\n            return urls.get(0);\\n        }\\n\\n        @Override\\n        public Enumeration<URL> getResources(String name) {\\n            requestedEnumeratedResources.add(name);\\n            List<URL> urls = resources.get(name);\\n            if (urls == null) {\\n                return Collections.emptyEnumeration();\\n            }\\n            return Collections.enumeration(urls);\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 2547, \"output\": 3211, \"cacheRead\": 23040, \"cacheWrite\": 0, \"totalTokens\": 28798, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777736807132, \"responseId\": \"resp_02a636a2e022bdda0169f61c679a9081a1a52ceb29f62f2aa7\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_wTzM3n33V6MnoKYOHbkSMQr9|fc_02a636a2e022bdda0169f61c7fa1cc81a188d68b954c17df8b\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 6591 bytes to tests/src/com.sun.istack/istack-commons-tools/4.1.2/src/test/java/com_sun_istack/istack_commons_tools/ParallelWorldClassLoaderTest.java\"}], \"isError\": false, \"timestamp\": 1777736839546}]}\nhuman-intervention-logs/com.sun.istack:istack-commons-tools:4.1.2/add-new-library-support/pi-generation-2026-05-02T15-47-58-619631Z.log:1674:[tool-call] delta {\"path\":\"tests/src/com.sun.istack/istack-commons-tools/4.1.2/src/test/java/com_sun_istack/istack_commons_tools/ParallelWorldClassLoaderTest.java\"}\nhuman-intervention-logs/com.sun.istack:istack-commons-tools:4.1.2/add-new-library-support/pi-generation-2026-05-02T15-47-58-619631Z.log:1675:[tool-call] end id=call_jfVQwns8FlfAzTrZMgbFFpOO|fc_02a636a2e022bdda0169f61c8bc8d881a1940847462d538f37 name=read args={\"path\": \"tests/src/com.sun.istack/istack-commons-tools/4.1.2/src/test/java/com_sun_istack/istack_commons_tools/ParallelWorldClassLoaderTes