ss = loader.findClassDirectly(CLASS_NAME);\\\\n\\\\n                assertThat(loadedClass.getName()).isEqualTo(CLASS_NAME);\\\\n                assertThat(loadedClass.getClassLoader()).isSameAs(loader);\\\\n            } catch (Error error) {\\\\n                if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\\\n                    throw error;\\\\n                }\\\\n                assertThat(parent.requestedSingleResources()).contains(CLASS_RESOURCE);\\\\n            }\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    void findsResourceFromPrefixedParentResource() throws Exception {\\\\n        Path resourceFile = createTextResource(\\\\\\\"single-resource.txt\\\\\\\", \\\\\\\"parallel resource\\\\\\\");\\\\n        ResourceOnlyClassLoader parent = new ResourceOnlyClassLoader();\\\\n        parent.addResource(PREFIX + \\\\\\\"single-resource.txt\\\\\\\", resourceFile.toUri().toURL());\\\\n\\\\n        try (ExposedParallelWorldClassLoader loader = new ExposedParallelWorldClassLoader(parent)) {\\\\n            URL resource = loader.findResourceDirectly(\\\\\\\"single-resource.txt\\\\\\\");\\\\n\\\\n            assertThat(resource).isNotNull();\\\\n            assertThat(Files.readString(Path.of(resource.toURI()), UTF_8)).isEqualTo(\\\\\\\"parallel resource\\\\\\\");\\\\n            assertThat(parent.requestedSingleResources()).contains(PREFIX + \\\\\\\"single-resource.txt\\\\\\\");\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    void findsResourcesFromPrefixedParentEnumeration() throws Exception {\\\\n        Path firstResource = createTextResource(\\\\\\\"enumerated-resource-one.txt\\\\\\\", \\\\\\\"first\\\\\\\");\\\\n        Path secondResource = createTextResource(\\\\\\\"enumerated-resource-two.txt\\\\\\\", \\\\\\\"second\\\\\\\");\\\\n        String resourceName = \\\\\\\"enumerated-resource.txt\\\\\\\";\\\\n        ResourceOnlyClassLoader parent = new ResourceOnlyClassLoader();\\\\n        parent.addResource(PREFIX + resourceName, firstRe