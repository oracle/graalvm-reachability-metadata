 byte[] serialize(final ReferenceMapSerializationHarness harness) throws IOException {\n        final ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(harness);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static ReferenceMapSerializationHarness deserialize(final byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            final Object deserialized = objectInputStream.readObject();\n            assertThat(deserialized).isInstanceOf(ReferenceMapSerializationHarness.class);\n            return (ReferenceMapSerializationHarness) deserialized;\n        }\n    }\n\n    private static Method serializationMethod(final String name, final Class<?> parameterType) {\n        try {\n            final Method method = ReferenceMap.class.getDeclaredMethod(name, parameterType);\n            method.setAccessible(true);\n            return method;\n        } catch (NoSuchMethodException exception) {\n            throw new ExceptionInInitializerError(exception);\n        }\n    }\n\n    private static void invokeReferenceMapWriteObject(final ReferenceMap map, final ObjectOutputStream output)\n            throws IOException {\n        try {\n            REFERENCE_MAP_WRITE_OBJECT.invoke(map, output);\n        } catch (IllegalAccessException exception) {\n            throw new IOException(\"Could not invoke ReferenceMap.writeObject\", exception);\n        } catch (InvocationTargetException exception) {\n            final Throwable cause = exception.getCause();\n            if (cause instanceof IOException) {\n                throw (IOException) cause;\n            }\n            throw new IOException(\"ReferenceMap.writeObject failed\", cause);\n        }\n    }\n\n    private static void invokeReferenceMapReadObject(final ReferenceMap map, final ObjectInputStream input)\n            throws IOException, ClassNotFoundException {\n        try {\n            REFERENCE_MAP_READ_OBJECT.invoke(map, input);\n        } catch (IllegalAccessException exception) {\n            throw new IOException(\"Could not invoke ReferenceMap.readObject\", exception);\n        } catch (InvocationTargetException exception) {\n            final Throwable cause = exception.getCause();\n            if (cause instanceof IOException) {\n                throw (IOException) cause;\n            }\n            if (cause instanceof ClassNotFoundException) {\n                throw (ClassNotFoundException) cause;\n            }\n            throw new IOException(\"ReferenceMap.readObject failed\", cause);\n        }\n    }\n\n    /**\n     * ReferenceMap declares private Java serialization hooks, but this shaded copy is not Serializable.\n     * The harness supplies the active serialization context those hooks require.\n     */\n    private static final class ReferenceMapSerializationHarness implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private transient ReferenceMap map;\n\n        private ReferenceMapSerializationHarness(final ReferenceMap map) {\n            this.map = map;\n        }\n\n        private ReferenceMap map() {\n            return map;\n        }\n\n        private void writeObject(final ObjectOutputStream output) throws IOException {\n            invokeReferenceMapWriteObject(map, output);\n        }\n\n        private void readObject(final ObjectInputStream input) throws IOException, ClassNotFoundException {\n            map = new ReferenceMap(ReferenceMap.HARD, ReferenceMap.HARD, 4, 0.75f);\n            invokeReferenceMapReadObject(map, input);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
