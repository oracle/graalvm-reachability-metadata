      public <T> List<Key<T>> getKeysByRefs(final List<DBRef> refs) {
          final List<Key<T>> keys = new ArrayList<Key<T>>(refs.size());
          for (final DBRef ref : refs) {
              final Key<T> testKey = refToKey(ref);
              keys.add(testKey);
          }
          return keys;
      }
  
      /**
