      public MappedClass getMappedClass(final Object obj) {
          if (obj == null) {
              return null;
          }
  
          Class type = (obj instanceof Class) ? (Class) obj : obj.getClass();
          if (ProxyHelper.isProxy(obj)) {
              type = ProxyHelper.getReferentClass(obj);
          }
  
