  @Test\n    public void createsNoArgumentInstancesWithDeclaredConstructor() {\n        final DefaultCreator creator = new DefaultCreator();\n\n        final DefaultCreatorNoArgsDocument document = creator.createInstance(DefaultCreatorNoArgsDocument.class);\n\n        assertThat(document.value()).isEqualTo(\"created\");\n    }\n\n    @Test\n    public void resolvesClassNameFromDatabaseObjectWithoutCaching() {\n        final DefaultCreator creator = new DefaultCreator();\n        final DBObject dbObject = new BasicDBObject()\n                .append(Mapper.CLASS_NAME_FIELDNAME, DefaultCreatorNoArgsDocument.class.getName());\n\n        final DefaultCreatorNoArgsDocument document = creator.createInstance(\n                DefaultCreatorNoArgsDocument.class,\n                dbObject);\n\n        assertThat(document.value()).isEqualTo(\"created\");\n        assertThat(creator.getClassNameCache()).isEmpty();\n    }\n\n    @Test\n    public void resolvesClassNameFromDatabaseObjectWithCaching() {\n        final MapperOptions options = new MapperOptions();\n        options.setCacheClassLookups(true);\n        final DefaultCreator creator = new DefaultCreator(options);\n        final String className = DefaultCreatorNoArgsDocument.class.getName();\n        final DBObject dbObject = new BasicDBObject()\n                .append(Mapper.CLASS_NAME_FIELDNAME, className);\n\n        final DefaultCreatorNoArgsDocument document = creator.createInstance(\n                DefaultCreatorNoArgsDocument.class,\n                dbObject);\n\n        assertThat(document.value()).isEqualTo(\"created\");\n        assertThat(creator.getClassNameCache()).containsEntry(className, DefaultCreatorNoArgsDocument.class);\n    }\n\n    @Test\n    public void createsInstancesUsingConstructorArgumentsFromMappedField() throws Exception {\n        final MappedField field = mappedField(\"constructorArgumentDocument\");\n        final DBObject dbObject = new BasicDBObject()\n                .append(\"name\", \"morphia\")\n                .append(\"count\", Integer.valueOf(132));\n        final DefaultCreator creator = new DefaultCreator();\n\n        final Object instance = creator.createInstance(null, field, dbObject);\n\n        assertThat(instance).isInstanceOf(DefaultCreatorConstructorArgumentDocument.class);\n        final DefaultCreatorConstructorArgumentDocument document = (DefaultCreatorConstructorArgumentDocument) instance;\n        assertThat(document.name()).isEqualTo(\"morphia\");\n        assertThat(document.count()).isEqualTo(132);\n    }\n\n    @Test\n    public void createsCollectionsWithMappedConcreteConstructor() throws Exception {\n        final MappedField field = mappedField(\"names\");\n        final DefaultCreator creator = new DefaultCreator();\n\n        final List<?> names = creator.createList(field);\n\n        assertThat(names).isInstanceOf(DefaultCreatorCustomStringList.class);\n    }\n\n    private static MappedField mappedField(final String javaFieldName) throws Exception {\n        final Field field = DefaultCreatorMappedFields.class.getDeclaredField(javaFieldName);\n        final Constructor<MappedField> constructor = MappedField.class.getDeclaredConstructor(\n                Field.class,\n                Class.class,\n                Mapper.class);\n        constructor.setAccessible(true);\n        return constructor.newInstance(field, DefaultCreatorMappedFields.class, null);\n    }\n}\n\nfinal class DefaultCreatorNoArgsDocument {\n    private final String value;\n\n    private DefaultCreatorNoArgsDocument() {\n        value = \"created\";\n    }\n\n    String value() {\n        return value;\n    }\n}\n\nfinal class DefaultCreatorConstructorArgumentDocument {\n    private final String name;\n    private final Integer count;\n\n    private DefaultCreatorConstructorArgumentDocument(final String name, final Integer count) {\n        this.name = name;\n        this.count = count;\n    }\n\n    String name() {\n        return name;\n    }\n\n    Integer count() {\n        return count;\n    }\n}\n\nfinal class DefaultCreatorMappedFields {\n    @Embedded(concreteClass = DefaultCreatorCustomStringList.class)\n    private List<String> names;\n\n    @ConstructorArgs({\"name\", \"count\"})\n    private DefaultCreatorConstructorArgumentDocument constructorArgumentDocument;\n}\n\nfinal class DefaultCreatorCustomStringList extends ArrayList<String> {\n    private static final long serialVersionUID = 1L;\n}\n"}], "isError": false, "timestamp": 1778541780297}]}
