      public MappedField getMappedField(final String storedName) {
          for (final MappedField mf : persistenceFields) {
              for (final String n : mf.getLoadNames()) {
                  if (storedName.equals(n)) {
                      return mf;
                  }
              }
          }
  
          return null;
      }
  
      /**
