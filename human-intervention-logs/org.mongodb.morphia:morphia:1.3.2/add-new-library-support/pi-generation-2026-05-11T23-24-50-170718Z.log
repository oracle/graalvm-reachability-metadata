  package org_mongodb_morphia.morphia;
  
  import com.mongodb.BasicDBObject;
  import com.mongodb.DBObject;
  import org.junit.jupiter.api.Test;
  import org.mongodb.morphia.annotations.Entity;
  import org.mongodb.morphia.annotations.EntityListeners;
  import org.mongodb.morphia.annotations.PrePersist;
  import org.mongodb.morphia.mapping.MappedClass;
  import org.mongodb.morphia.mapping.Mapper;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MappedClassTest {
      @Test
      public void callsEntityAndListenerLifecycleMethodsWithSupportedSignatures() {
          LifecycleEventRecorder.clear();
          final Mapper mapper = new Mapper();
          final MappedClass mappedClass = mapper.getMappedClass(LifecycleDocument.class);
          final LifecycleDocument document = new LifecycleDocument();
          final DBObject source = new BasicDBObject("source", "initial");
  
          final DBObject result = mappedClass.callLifecycleMethods(PrePersist.class, document, source, mapper);
  
          assertThat(LifecycleEventRecorder.events()).contains(
                  "entity-no-args",
                  "entity-db-object:initial",
                  "listener-no-args",
                  "listener-entity:document",
                  "listener-entity-and-db-object:initial");
          assertThat(result.get("listener")).isEqualTo("replacement");
      }
  
      @Entity
      @EntityListeners(LifecycleListener.class)
      public static final class LifecycleDocument {
          private final String name = "document";
  
          @PrePersist
          public void beforePersistWithoutArguments() {
              LifecycleEventRecorder.record("entity-no-args");
          }
  
          @PrePersist
          public void beforePersistWithDatabaseObject(final DBObject dbObject) {
              LifecycleEventRecorder.record("entity-db-object:" + dbObject.get("source"));
          }
      }
  
      public static final class LifecycleListener {
          public LifecycleListener() {
          }
  
          @PrePersist
          public void beforePersistWithoutArguments() {
              LifecycleEventRecorder.record("listener-no-args");
          }
  
          @PrePersist
          public void beforePersistWithEntity(final LifecycleDocument document) {
              LifecycleEventRecorder.record("listener-entity:" + document.name);
          }
  
          @PrePersist
          public DBObject beforePersistWithEntityAndDatabaseObject(final LifecycleDocument document,
                                                                   final DBObject dbObject) {
              LifecycleEventRecorder.record("listener-entity-and-db-object:" + dbObject.get("source"));
              return new BasicDBObject("listener", "replacement");
          }
      }
  
      private static final class LifecycleEventRecorder {
          private static final List<String> EVENTS = new ArrayList<String>();
  
          private LifecycleEventRecorder() {
          }
  
          private static void clear() {
              EVENTS.clear();
          }
  
          private static void record(final String event) {
              EVENTS.add(event);
          }
  
          private static List<String> events() {
              return new ArrayList<String>(EVENTS);
          }
      }
  }
