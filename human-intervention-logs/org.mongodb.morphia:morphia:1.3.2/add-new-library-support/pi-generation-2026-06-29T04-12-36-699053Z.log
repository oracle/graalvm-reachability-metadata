      public Annotation getFirstAnnotation(final Class<? extends Annotation> clazz) {
          final List<Annotation> found = foundAnnotations.get(clazz);
          return found == null || found.isEmpty() ? null : found.get(0);
      }
  
      /**
       * @return the idField
