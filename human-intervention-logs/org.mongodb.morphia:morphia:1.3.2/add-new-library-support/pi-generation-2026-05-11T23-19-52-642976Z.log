  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_mongodb_morphia.morphia;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.mongodb.morphia.utils.ReflectionUtils;
  
  import java.io.IOException;
  import java.lang.reflect.Field;
  import java.lang.reflect.GenericArrayType;
  import java.lang.reflect.Method;
  import java.lang.reflect.Type;
  import java.net.URL;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Arrays;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  import java.util.Set;
  import java.util.jar.JarEntry;
  import java.util.jar.JarOutputStream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class ReflectionUtilsTest {
      private static final String TEST_PACKAGE_NAME = "org_mongodb_morphia.morphia";
      private static final String TEST_PACKAGE_PATH = "org_mongodb_morphia/morphia";
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      public void scansDeclaredAndInheritedFields() {
          final Field[] fields = ReflectionUtils.getDeclaredAndInheritedFields(ChildDocument.class, false);
  
          assertThat(fields)
                  .extracting(Field::getName)
                  .contains("childField", "parentField")
                  .doesNotContain("childFinalField", "staticChildField", "parentFinalField", "staticParentField");
      }
  
      @Test
      public void scansDeclaredAndInheritedMethods() {
          final List<Method> methods = ReflectionUtils.getDeclaredAndInheritedMethods(ChildDocument.class);
  
          assertThat(methods)
                  .extracting(Method::getName)
                  .contains("childMethod", "parentMethod")
                  .doesNotContain("staticChildMethod", "staticParentMethod");
      }
  
      @Test
      public void scansClassesFromDirectoryResource() throws Exception {
          final Path packageDirectory = temporaryDirectory.resolve(TEST_PACKAGE_PATH);
          Files.createDirectories(packageDirectory);
          Files.createFile(packageDirectory.resolve(DirectoryScannedType.class.getSimpleName() + ".class"));
  
          final URL packageUrl = packageDirectory.toUri().toURL();
          final ClassLoader loader = new PackageResourceClassLoader(
                  packageUrl,
                  ReflectionUtilsTest.class.getClassLoader());
  
          final Set<Class<?>> classes = ReflectionUtils.getClasses(loader, TEST_PACKAGE_NAME);
  
          assertThat(classes).contains(DirectoryScannedType.class);
      }
  
      @Test
      public void scansClassesFromJarEntries() throws Exception {
          final Path jarPath = temporaryDirectory.resolve("reflection-utils-scan.jar");
          try (JarOutputStream output = new JarOutputStream(Files.newOutputStream(jarPath))) {
              final String entryName = TEST_PACKAGE_PATH + "/" + JarScannedType.class.getSimpleName() + ".class";
              output.putNextEntry(new JarEntry(entryName));
              output.closeEntry();
          }
  
          final ClassLoader loader = ReflectionUtilsTest.class.getClassLoader();
          final Set<Class<?>> classes = ReflectionUtils.getFromJARFile(loader, jarPath.toString(), TEST_PACKAGE_PATH);
  
          assertThat(classes).contains(JarScannedType.class);
      }
  
      @Test
      public void convertsListsToPrimitiveArrays() {
          final Object array = ReflectionUtils.convertToArray(int.class, Arrays.asList(1, 2, 3));
  
          assertThat(array).isInstanceOf(int[].class);
          assertThat((int[]) array).containsExactly(1, 2, 3);
      }
  
      @Test
      public void resolvesGenericArrayTypesToArrayClasses() {
          final Class<?> arrayClass = ReflectionUtils.getClass(new GenericArrayTypeOf(DirectoryScannedType.class));
  
          assertThat(arrayClass).isEqualTo(DirectoryScannedType[].class);
      }
  
      @Test
      public void resolvesReifiableArrayParameterizedFields() {
          final Field field = fieldNamed(ReifiableArrayFieldDocument.class, "arrayValues");
  
          assertThat(ReflectionUtils.getParameterizedClass(field)).isEqualTo(DirectoryScannedType[].class);
      }
  
      @Test
      public void rejectsParameterizedFieldsWithGenericArrayArguments() {
          final Field field = fieldNamed(GenericArrayFieldDocument.class, "genericArrayValues");
  
          assertThatThrownBy(() -> ReflectionUtils.getParameterizedClass(field))
                  .isInstanceOf(ClassCastException.class);
      }
  
      private static Field fieldNamed(final Class<?> type, final String name) {
          for (final Field field : ReflectionUtils.getDeclaredAndInheritedFields(type, true)) {
              if (name.equals(field.getName())) {
                  return field;
              }
          }
          throw new AssertionError("Field not found: " + name);
      }
  
      private static final class PackageResourceClassLoader extends ClassLoader {
          private final URL packageUrl;
  
          private PackageResourceClassLoader(final URL packageUrl, final ClassLoader parent) {
              super(parent);
              this.packageUrl = packageUrl;
          }
  
          @Override
          public Enumeration<URL> getResources(final String name) throws IOException {
              if (TEST_PACKAGE_PATH.equals(name)) {
                  return Collections.enumeration(Collections.singletonList(packageUrl));
              }
              return super.getResources(name);
          }
      }
  
      private static final class GenericArrayTypeOf implements GenericArrayType {
          private final Type componentType;
  
          private GenericArrayTypeOf(final Type componentType) {
              this.componentType = componentType;
          }
  
          @Override
          public Type getGenericComponentType() {
              return componentType;
          }
      }
  
      private static class ParentDocument {
          private static String staticParentField;
          private final String parentFinalField = "final";
          private String parentField;
  
          void parentMethod() {
          }
  
          static void staticParentMethod() {
          }
      }
  
      private static final class ChildDocument extends ParentDocument {
          private static String staticChildField;
          private final int childFinalField = 1;
          private int childField;
  
          void childMethod() {
          }
  
          static void staticChildMethod() {
          }
      }
  
      private static final class ReifiableArrayFieldDocument {
          private List<DirectoryScannedType[]> arrayValues;
      }
  
      private static final class GenericArrayFieldDocument {
          private List<List<String>[]> genericArrayValues;
      }
  }
  
  final class DirectoryScannedType {
  }
  
  final class JarScannedType {
  }
