       */
      private static final class ReferenceMapSerializationHarness implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private transient ReferenceMap map;
  
          private ReferenceMapSerializationHarness(final ReferenceMap map) {
              this.map = map;
          }
  
          private ReferenceMap map() {
              return map;
          }
  
          private void writeObject(final ObjectOutputStream output) throws IOException {
              invokeReferenceMapWriteObject(map, output);
          }
  
          private void readObject(final ObjectInputStream input) throws IOException, ClassNotFoundException {
              map = new ReferenceMap(ReferenceMap.HARD, ReferenceMap.HARD, 4, 0.75f);
              invokeReferenceMapReadObject(map, input);
          }
      }
  }
