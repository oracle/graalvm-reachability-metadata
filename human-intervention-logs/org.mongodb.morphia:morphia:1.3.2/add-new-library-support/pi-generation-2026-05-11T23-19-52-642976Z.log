  package org_mongodb_morphia.morphia;
  
  import org.junit.jupiter.api.Test;
  import relocated.morphia.org.apache.commons.collections.ReferenceMap;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReferenceMapTest {
      private static final Method REFERENCE_MAP_READ_OBJECT = serializationMethod(
              "readObject",
              ObjectInputStream.class);
      private static final Method REFERENCE_MAP_WRITE_OBJECT = serializationMethod(
              "writeObject",
              ObjectOutputStream.class);
  
      @Test
      public void serializesEntriesThroughReferenceMapHooks() throws Exception {
          final ReferenceMap original = new ReferenceMap(ReferenceMap.HARD, ReferenceMap.HARD, 4, 0.75f);
          original.put("name", "morphia");
          original.put(Integer.valueOf(132), "release");
  
          final byte[] serialized = serialize(new ReferenceMapSerializationHarness(original));
          final ReferenceMap restored = deserialize(serialized).map();
  
          assertThat(restored.get("name")).isEqualTo("morphia");
          assertThat(restored.get(Integer.valueOf(132))).isEqualTo("release");
          assertThat(restored.size()).isEqualTo(2);
      }
  
      private static byte[] serialize(final ReferenceMapSerializationHarness harness) throws IOException {
          final ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {
              objectOutputStream.writeObject(harness);
          }
          return outputStream.toByteArray();
      }
  
      private static ReferenceMapSerializationHarness deserialize(final byte[] serialized)
              throws IOException, ClassNotFoundException {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              final Object deserialized = objectInputStream.readObject();
              assertThat(deserialized).isInstanceOf(ReferenceMapSerializationHarness.class);
              return (ReferenceMapSerializationHarness) deserialized;
          }
      }
  
      private static Method serializationMethod(final String name, final Class<?> parameterType) {
          try {
              final Method method = ReferenceMap.class.getDeclaredMethod(name, parameterType);
              method.setAccessible(true);
              return method;
          } catch (NoSuchMethodException exception) {
              throw new ExceptionInInitializerError(exception);
          }
      }
  
      private static void invokeReferenceMapWriteObject(final ReferenceMap map, final ObjectOutputStream output)
              throws IOException {
          try {
              REFERENCE_MAP_WRITE_OBJECT.invoke(map, output);
          } catch (IllegalAccessException exception) {
              throw new IOException("Could not invoke ReferenceMap.writeObject", exception);
          } catch (InvocationTargetException exception) {
              final Throwable cause = exception.getCause();
              if (cause instanceof IOException) {
                  throw (IOException) cause;
              }
              throw new IOException("ReferenceMap.writeObject failed", cause);
          }
      }
  
      private static void invokeReferenceMapReadObject(final ReferenceMap map, final ObjectInputStream input)
              throws IOException, ClassNotFoundException {
          try {
              REFERENCE_MAP_READ_OBJECT.invoke(map, input);
          } catch (IllegalAccessException exception) {
              throw new IOException("Could not invoke ReferenceMap.readObject", exception);
          } catch (InvocationTargetException exception) {
              final Throwable cause = exception.getCause();
              if (cause instanceof IOException) {
                  throw (IOException) cause;
              }
              if (cause instanceof ClassNotFoundException) {
                  throw (ClassNotFoundException) cause;
              }
              throw new IOException("ReferenceMap.readObject failed", cause);
          }
