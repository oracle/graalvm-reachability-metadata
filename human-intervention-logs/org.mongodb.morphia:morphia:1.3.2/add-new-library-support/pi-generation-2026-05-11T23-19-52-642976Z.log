      assertThat(restored.get(Integer.valueOf(132))).isEqualTo(\"release\");\n        assertThat(restored.size()).isEqualTo(2);\n    }\n\n    private static byte[] serialize(final ReferenceMapSerializationHarness harness) throws IOException {\n        final ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(harness);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static ReferenceMapSerializationHarness deserialize(final byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            final Object deserialized = objectInputStream.readObject();\n            assertThat(deserialized).isInstanceOf(ReferenceMapSerializationHarness.class);\n            return (ReferenceMapSerializationHarness) deserialized;\n        }\n    }\n\n    private static Method serializationMethod(final String name, final Class<?> parameterType) {\n        try {\n            final Method method = ReferenceMap.class.getDeclaredMethod(name, parameterType);\n            method.setAccessible(true);\n            return method;\n        } catch (NoSuchMethodException exception) {\n            throw new ExceptionInInitializerError(exception);\n        }\n    }\n\n    private static void invokeReferenceMapWriteObject(final ReferenceMap map, final ObjectOutputStream output)\n            throws IOException {\n        try {\n            REFERENCE_MAP_WRITE_OBJECT.invoke(map, output);\n        } catch (IllegalAccessException exception) {\n            throw new IOException(\"Could not invoke ReferenceMap.writeObject\", exception);\n        } catch (InvocationTargetException exception) {\n            final Throwable cause = exception.getCause();\n            if (cause instanceof IOException) {\