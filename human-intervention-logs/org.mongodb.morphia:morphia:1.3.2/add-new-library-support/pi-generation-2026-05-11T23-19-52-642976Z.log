ertThat(defaults.value()).isNull();\n\n        final ValidationBuilder validation = new ValidationBuilder()\n                .value(\"{ status: { $exists: true } }\")\n                .level(ValidationLevel.MODERATE)\n                .action(ValidationAction.WARN);\n\n        assertThat(validation.value()).isEqualTo(\"{ status: { $exists: true } }\");\n        assertThat(validation.level()).isEqualTo(ValidationLevel.MODERATE);\n        assertThat(validation.action()).isEqualTo(ValidationAction.WARN);\n        assertThat(validation.toString())\n                .contains(org.mongodb.morphia.annotations.Validation.class.getName())\n                .contains(\"status\")\n                .contains(\"MODERATE\")\n                .contains(\"WARN\");\n    }\n\n    @Test\n    public void ensureIndexesCopiesAnnotationValuesThroughBuilders() {\n        final CapturingMongoDatabase database = new CapturingMongoDatabase(\"annotationBuilderTest\");\n        final FakeMongoClient client = new FakeMongoClient(database);\n        try {\n            final Morphia morphia = new Morphia().map(AnnotationBuilderIndexedEntity.class);\n            final Datastore datastore = morphia.createDatastore(client, database.name());\n\n            datastore.ensureIndexes(AnnotationBuilderIndexedEntity.class);\n\n            assertThat(database.indexes())\n                    .extracting(CreatedIndex::name)\n                    .contains(\"topLevelCategoryIndex\", \"fieldNameIndex\");\n            assertThat(database.indexes())\n                    .filteredOn(index -> \"fieldNameIndex\".equals(index.name()))\n                    .singleElement()\n                    .satisfies(index -> assertThat(index.options().isUnique()).isTrue());\n        } finally {\n            client.close();\n        }\n    }\n\n    private static final class FakeMongoClient extends MongoClient {\n        private final CapturingMongoDatabase database;\n\n        private FakeMongoClient(final CapturingMongoDatabase database) {\n            super(new ServerAddress(\"127.0.0.1\", 1), MongoClientOptions.builder()\n                    .connectTimeout(10)\n                    .serverSelectionTimeout(10)\n                    .build());\n            this.database = database;\n        }\n\n        @Override\n        public MongoDatabase getDatabase(final String databaseName) {\n            assertThat(databaseName).isEqualTo(database.name());\n            return database.proxy();\n        }\n\n        @Override\n        public DB getDB(final String databaseName) {\n            return super.getDB(databaseName);\n        }\n\n        @Override\n        public WriteConcern getWriteConcern() {\n            return WriteConcern.ACKNOWLEDGED;\n        }\n    }\n\n    private static final class CapturingMongoDatabase implements InvocationHandler {\n        private final String name;\n        private final List<CreatedIndex> indexes = new ArrayList<CreatedIndex>();\n        private final MongoCollection<?> collection;\n        private final MongoDatabase proxy;\n\n        private CapturingMongoDatabase(final String name) {\n            this.name = name;\n            collection = collectionProxy(indexes);\n            proxy = (MongoDatabase) Proxy.newProxyInstance(\n                    MongoDatabase.class.getClassLoader(),\n                    new Class<?>[] {MongoDatabase.class},\n                    this);\n        }\n\n        private String name() {\n            return name;\n        }\n\n        private List<CreatedIndex> indexes() {\n            return Collections.unmodifiableList(indexes);\n        }\n\n        private MongoDatabase proxy() {\n            return proxy;\n        }\n\n        @Override\n        public Object invoke(final Object proxy, final Method method, final Object[] args) {\n            if (\"getName\".equals(method.getName())) {\n                return name;\n            }\n            if (\"getCodecRegistry\".equals(method.getName())) {\n                return MongoClient.getDefaultCodecRegistry();\n            }\n            if (\"getCollection\".equals(method.getName())) {\n                return collection;\n            }\n            if (\"toString\".equals(method.getName())) {\n                return \"CapturingMongoDatabase(\" + name + \")\";\n            }\n            return defaultValue(method.getReturnType());\n        }\n    }\n\n    private static MongoCollection<?> collectionProxy(final List<CreatedIndex> indexes) {\n        return (MongoCollection<?>) Proxy.newProxyInstance(\n                MongoCollection.class.getClassLoader(),\n                new Class<?>[] {MongoCollection.class},\n                new CapturingMongoCollection(indexes));\n    }\n\n    private static final class CapturingMongoCollection implements InvocationHandler {\n        private final List<CreatedIndex> indexes;\n\n        private CapturingMongoCollection(final List<CreatedIndex> indexes) {\n            this.indexes = indexes;\n        }\n\n        @Override\n        public Object invoke(final Object proxy, final Method method, final Object[] args) {\n            if (\"createIndex\".equals(method.getName()) && args.length == 2) {\n                final IndexOptions options = (IndexOptions) args[1];\n                indexes.add(new CreatedIndex(options));\n                return options.getName();\n            }\n            if (\"getCodecRegistry\".equals(method.getName())) {\n                return MongoClient.getDefaultCodecRegistry();\n            }\n            if (\"toString\".equals(method.getName())) {\n                return \"CapturingMongoCollection\";\n            }\n            return defaultValue(method.getReturnType());\n        }\n    }\n\n    private static Object defaultValue(final Class<?> returnType) {\n        if (returnType == Boolean.TYPE) {\n            return Boolean.FALSE;\n        }\n        if (returnType == Byte.TYPE) {\n            return Byte.valueOf((byte) 0);\n        }\n        if (returnType == Short.TYPE) {\n            return Short.valueOf((short) 0);\n        }\n        if (returnType == Integer.TYPE) {\n            return Integer.valueOf(0);\n        }\n        if (returnType == Long.TYPE) {\n            return Long.valueOf(0L);\n        }\n        if (returnType == Float.TYPE) {\n            return Float.valueOf(0F);\n        }\n        if (returnType == Double.TYPE) {\n            return Double.valueOf(0D);\n        }\n        if (returnType == Character.TYPE) {\n            return Character.valueOf('\\0');\n        }\n        return null;\n    }\n\n    private static final class CreatedIndex {\n        private final IndexOptions options;\n\n        private CreatedIndex(final IndexOptions options) {\n            this.options = options;\n        }\n\n        private String name() {\n            return options.getName();\n        }\n\n        private IndexOptions options() {\n            return options;\n        }\n    }\n\n    @SuppressWarnings(\"deprecation\")\n    @Entity(\"annotationBuilderIndexedEntity\")\n    @Indexes(@Index(\n            fields = @Field(\"category\"),\n            options = @org.mongodb.morphia.annotations.IndexOptions(name = \"topLevelCategoryIndex\")))\n    private static final class AnnotationBuilderIndexedEntity {\n        @Id\n        private ObjectId id;\n\n        private String category;\n\n        @Indexed(options = @org.mongodb.morphia.annotations.IndexOptions(name = \"fieldNameIndex\", unique = true))\n        private String name;\n    }\n}\n"}
