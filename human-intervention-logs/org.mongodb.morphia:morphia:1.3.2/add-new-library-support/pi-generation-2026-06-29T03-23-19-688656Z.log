      MappedField(final Field f, final Class<?> clazz, final Mapper mapper) {
          f.setAccessible(true);
          field = f;
          persistedClass = clazz;
          realType = field.getType();
          genericType = field.getGenericType();
          discover(mapper);
      }
  
      /**
