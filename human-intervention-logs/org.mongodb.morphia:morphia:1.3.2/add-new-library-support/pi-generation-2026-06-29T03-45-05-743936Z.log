       */
      IndexBuilder name(final String name) {
          put("name", name);
          return this;
      }
  
      /**
       * Create the index with the sparse option
       */
      IndexBuilder sparse(final boolean sparse) {
          put("sparse", sparse);
          return this;
      }
  
      /**
