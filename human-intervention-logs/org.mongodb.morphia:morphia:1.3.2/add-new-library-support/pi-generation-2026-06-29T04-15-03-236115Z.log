ib\", module: \"cglib\"\n        exclude group: \"cglib\", module: \"cglib-nodep\"\n        exclude group: \"com.thoughtworks.proxytoys\", module: \"proxytoys\"\n    }\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782706438202}, {"role": "toolResult", "toolCallId": "call_TnDsesyon8QeEcyycaDGbFHd|fc_03fed2454bef6a32016a41f10601248196be05e955ab7ec2ef", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mongodb_morphia.morphia;\n\nimport com.mongodb.BasicDBObject;\nimport org.junit.jupiter.api.Test;\nimport org.mongodb.morphia.annotations.Entity;\nimport org.mongodb.morphia.annotations.Id;\nimport org.mongodb.morphia.annotations.Version;\nimport org.mongodb.morphia.mapping.Mapper;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MapperTest {\n    @Test\n    public void readsAnnotatedIdFieldFromMappedEntity() {\n        final Mapper mapper = new Mapper();\n        final VersionedEntity entity = new VersionedEntity(\"entity-id\");\n\n        final Object id = mapper.getId(entity);\n\n        assertThat(id).isEqualTo(\"entity-id\");\n    }\n\n    @Test\n    public void updatesKeyAndVersionFieldsFromDocument() {\n        final Mapper mapper = new Mapper();\n        final VersionedEntity entity = new VersionedEntity(\"existing-id\");\n        final BasicDBObject document = new BasicDBObject(Mapper.ID_KEY, \"existing-id\")\n                .append(\"version\", 2L);\n\n        mapper.updateKeyAndVersionInfo(null, document, mapper.createEntityCache(), entity);\n\n        assertThat(entity.id).isEqualTo(\"existing-id\");\n        assertThat(entity.version).isEqualTo(2L);\n    }\n\n    @Entity(\"mapper_versioned_entities\")\n    public static final class VersionedEntity {\n        @Id\n        private String id;\n        @Version\n        private Long version;\n\n        private VersionedEntity() {\n        }\n\n        private VersionedEntity(final String id) {\n            this.id = id;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782706438202}, {"role": "toolResult", "toolCallId": "call_UBZcZLjbpUJdguijrp6Pw7oQ|fc_03fed2454bef6a32016a41f106012c81969e4a9bf7ad7c69ea", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classThreshold\": 15,\n  \"completedClasses\": [\n    \"org.mongodb.morphia.logging.MorphiaLoggerFactory\",\n    \"org.mongodb.morphia.mapping.MappedField\",\n    \"org.mongodb.morphia.AnnotationBuilder\",\n    \"org.mongodb.morphia.mapping.MappedClass\",\n    \"org.mongodb.morphia.converters.ByteConverter\",\n    \"org.mongodb.morphia.mapping.Mapper\"\n  ],\n  \"coordinate\": \"org.mongodb.morphia:morphia:1.3.2\",\n  \"currentChunkClassCount\": 15,\n  \"exhaustedClasses\": [\n    \"org.mongodb.morphia.utils.ReflectionUtils\",\n    \"org.mongodb.morphia.mapping.DefaultCreator\",\n    \"relocated.morphia.org.apache.commons.collections.ReferenceMap\"\n  ],\n  \"failedClasses\": [\n    \"org.mongodb.morphia.mapping.DefaultCreator\"\n  ],\n  \"issueNumber\": 2797,\n  \"latestChunkCommit\": null,\n  \"latestChunkPullRequest\": null,\n  \"skippedClasses\": []\n}\n"}], "isError": false, "timestamp": 1782706438202}]}
