  package org_mongodb_morphia.morphia;
  
  import com.mongodb.BasicDBObject;
  import com.mongodb.DBObject;
  import org.junit.jupiter.api.Test;
  import org.mongodb.morphia.annotations.ConstructorArgs;
  import org.mongodb.morphia.annotations.Embedded;
  import org.mongodb.morphia.mapping.DefaultCreator;
  import org.mongodb.morphia.mapping.MappedField;
  import org.mongodb.morphia.mapping.Mapper;
  import org.mongodb.morphia.mapping.MapperOptions;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.util.ArrayList;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DefaultCreatorTest {
      @Test
      public void createsNoArgumentInstancesWithDeclaredConstructor() {
          final DefaultCreator creator = new DefaultCreator();
  
          final DefaultCreatorNoArgsDocument document = creator.createInstance(DefaultCreatorNoArgsDocument.class);
  
          assertThat(document.value()).isEqualTo("created");
      }
  
      @Test
      public void resolvesClassNameFromDatabaseObjectWithoutCaching() {
          final DefaultCreator creator = new DefaultCreator();
          final DBObject dbObject = new BasicDBObject()
                  .append(Mapper.CLASS_NAME_FIELDNAME, DefaultCreatorNoArgsDocument.class.getName());
  
          final DefaultCreatorNoArgsDocument document = creator.createInstance(
                  DefaultCreatorNoArgsDocument.class,
                  dbObject);
  
          assertThat(document.value()).isEqualTo("created");
          assertThat(creator.getClassNameCache()).isEmpty();
      }
  
      @Test
      public void resolvesClassNameFromDatabaseObjectWithCaching() {
          final MapperOptions options = new MapperOptions();
          options.setCacheClassLookups(true);
          final DefaultCreator creator = new DefaultCreator(options);
          final String className = DefaultCreatorNoArgsDocument.class.getName();
          final DBObject dbObject = new BasicDBObject()
                  .append(Mapper.CLASS_NAME_FIELDNAME, className);
  
          final DefaultCreatorNoArgsDocument document = creator.createInstance(
                  DefaultCreatorNoArgsDocument.class,
                  dbObject);
  
          assertThat(document.value()).isEqualTo("created");
          assertThat(creator.getClassNameCache()).containsEntry(className, DefaultCreatorNoArgsDocument.class);
      }
  
      @Test
      public void createsInstancesUsingConstructorArgumentsFromMappedField() throws Exception {
          final MappedField field = mappedField("constructorArgumentDocument");
          final DBObject dbObject = new BasicDBObject()
                  .append("name", "morphia")
                  .append("count", Integer.valueOf(132));
          final DefaultCreator creator = new DefaultCreator();
  
          final Object instance = creator.createInstance(null, field, dbObject);
  
          assertThat(instance).isInstanceOf(DefaultCreatorConstructorArgumentDocument.class);
          final DefaultCreatorConstructorArgumentDocument document = (DefaultCreatorConstructorArgumentDocument) instance;
          assertThat(document.name()).isEqualTo("morphia");
          assertThat(document.count()).isEqualTo(132);
      }
  
      @Test
      public void createsCollectionsWithMappedConcreteConstructor() throws Exception {
          final MappedField field = mappedField("names");
          final DefaultCreator creator = new DefaultCreator();
  
          final List<?> names = creator.createList(field);
  
          assertThat(names).isInstanceOf(DefaultCreatorCustomStringList.class);
      }
  
      private static MappedField mappedField(final String javaFieldName) throws Exception {
          final Field field = DefaultCreatorMappedFields.class.getDeclaredField(javaFieldName);
          final Constructor<MappedField> constructor = MappedField.class.getDeclaredConstructor(
                  Field.class,
                  Class.class,
                  Mapper.class);
          constructor.setAccessible(true);
          return constructor.newInstance(field, DefaultCreatorMappedFields.class, null);
      }
  }
  
  final class DefaultCreatorNoArgsDocument {
      private final String value;
  
      private DefaultCreatorNoArgsDocument() {
          value = "created";
      }
  
      String value() {
          return value;
      }
  }
  
  final class DefaultCreatorConstructorArgumentDocument {
      private final String name;
      private final Integer count;
  
      private DefaultCreatorConstructorArgumentDocument(final String name, final Integer count) {
          this.name = name;
          this.count = count;
      }
  
      String name() {
          return name;
      }
  
      Integer count() {
          return count;
      }
  }
  
  final class DefaultCreatorMappedFields {
      @Embedded(concreteClass = DefaultCreatorCustomStringList.class)
      private List<String> names;
  
      @ConstructorArgs({"name", "count"})
      private DefaultCreatorConstructorArgumentDocument constructorArgumentDocument;
  }
  
  final class DefaultCreatorCustomStringList extends ArrayList<String> {
      private static final long serialVersionUID = 1L;
  }
