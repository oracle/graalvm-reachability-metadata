r.api.Test;\nimport relocated.morphia.org.apache.commons.collections.ReferenceMap;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReferenceMapTest {\n    private static final Method REFERENCE_MAP_READ_OBJECT = serializationMethod(\n            \"readObject\",\n            ObjectInputStream.class);\n    private static final Method REFERENCE_MAP_WRITE_OBJECT = serializationMethod(\n            \"writeObject\",\n            ObjectOutputStream.class);\n\n    @Test\n    public void serializesEntriesThroughReferenceMapHooks() throws Exception {\n        final ReferenceMap original = new ReferenceMap(ReferenceMap.HARD, ReferenceMap.HARD, 4, 0.75f);\n        original.put(\"name\", \"morphia\");\n        original.put(Integer.valueOf(132), \"release\");\n\n        final byte[] serialized = serialize(new ReferenceMapSerializationHarness(original));\n        final ReferenceMap restored = deserialize(serialized).map();\n\n        assertThat((Map<?, ?>) restored)\n                .containsEntry(\"name\", \"morphia\")\n                .containsEntry(Integer.valueOf(132), \"release\");\n        assertThat(restored.size()).isEqualTo(2);\n    }\n\n    private static byte[] serialize(final ReferenceMapSerializationHarness harness) throws IOException {\n        final ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(harness);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static ReferenceMapSerializationHarness deserialize(final byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            final Object deserialized = objectInputStream.readObject();\n            assertThat(deserialized).isInstanceOf(ReferenceMapSerializationHarness.class);\n            return (ReferenceMapSerializationHarness) deserialized;\n        }\n    }\n\n    private static Method serializationMethod(final String name, final Class<?> parameterType) {\n        try {\n            final Method method = ReferenceMap.class.getDeclaredMethod(name, parameterType);\n            method.setAccessible(true);\n            return method;\n        } catch (NoSuchMethodException exception) {\n            throw new ExceptionInInitializerError(exception);\n        }\n    }\n\n    private static void invokeReferenceMapWriteObject(final ReferenceMap map, final ObjectOutputStream output)\n            throws IOException {\n        try {\n            REFERENCE_MAP_WRITE_OBJECT.invoke(map, output);\n        } catch (IllegalAccessException exception) {\n            throw new IOException(\"Could not invoke ReferenceMap.writeObject\", exception);\n        } catch (InvocationTargetException exception) {\n            final Throwable cause = exception.getCause();\n            if (cause instanceof IOException) {\n                throw (IOException) cause;\n            }\n            throw new IOException(\"ReferenceMap.writeObject failed\", cause);\n        }\n    }\n\n    private static void invokeReferenceMapReadObject(final ReferenceMap map, final ObjectInputStream input)\n            throws IOException, ClassNotFoundException {\n        try {\n            REFERENCE_MAP_READ_OBJECT.invoke(map, input);\n        } catch (IllegalAccessException exception) {\n            throw new IOException(\"Could not invoke ReferenceMap.readObject\", exception);\n        } catch (InvocationTargetException exception) {\n            final Throwable cause = exception.getCause();\n            if (cause instanceof IOException) {\n                throw (IOException) cause;\n            }\n            if (cause instanceof ClassNotFoundException) {\n                throw (ClassNotFoundException) cause;\n            }\n            throw new IOException(\"ReferenceMap.readObject failed\", cause);\n        }\n    }\n\n    /**\n     * ReferenceMap declares private Java serialization hooks, but this shaded copy is not Serializable.\n     * The harness supplies the active serialization context those hooks require.\n     */\n    private static final class ReferenceMapSerializationHarness implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private transient ReferenceMap map;\n\n        private ReferenceMapSerializationHarness(final ReferenceMap map) {\n            this.map = map;\n        }\n\n        private ReferenceMap map() {\n            return map;\n        }\n\n        private void writeObject(final ObjectOutputStream output) throws IOException {\n            invokeReferenceMapWriteObject(map, output);\n        }\n\n        private void readObject(final ObjectInputStream input) throws IOException, ClassNotFoundException {\n            map = new ReferenceMap(ReferenceMap.HARD, ReferenceMap.HARD, 4, 0.75f);\n            invokeReferenceMapReadObject(map, input);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3806, "output": 2264, "cacheRead": 36352, "cacheWrite": 0, "totalTokens": 42422, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778541216204, "responseId": "resp_03498ac31ecbf26f016a0262a0cbcc819dbd99cb4f866c14ff"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_cJRRnfaw1c8m1ClBqoIRK8UY|fc_03498ac31ecbf26f016a0262b1bbe4819d950f43375c882182", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5502 bytes to t