eption.class)\n                .hasMessage(ReferenceMap.class.getName());\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        final ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2833, "output": 943, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 37056, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782704019646, "responseId": "resp_03f7d34eced8103b016a41e79421588197ac4ab6ace8957b5b"}}
