          if (isSet()) {
              sb.append(" set:true,");
          }
          if (isCollection) {
              sb.append(" collection:true,");
          }
          if (isArray) {
              sb.append(" array:true,");
          }
  
          //remove last comma
          if (sb.charAt(sb.length() - 1) == ',') {
              sb.setLength(sb.length() - 1);
          }
  
          sb.append("); ").append(foundAnnotations.toString());
          return sb.toString();
