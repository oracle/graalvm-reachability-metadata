                                  return classToTest;
                              }
                              typeToTest = resolvedTypes.get(typeToTest);
                          }
                      }
                      resolvedTypes.put(typeParameters[i], actualTypeArguments[i]);
                  }
  
                  if (!rawType.equals(Object.class)) {
                      type = rawType.getGenericSuperclass();
                  }
              }
          }
  
          return null;
      }
  }
