[tool-call] delta {"path":"tests/src/org.mongodb.morphia/morphia/1.3.2/src/test/java/org_mongodb_morphia/morphia/ReflectionUtilsTest.java","edits":[{"oldText":"    public void rejectsParameterizedFieldsWithGenericArrayArguments() throws Exception {\n        final Field field = GenericArrayFieldDocument.class.getDeclaredField(\"genericArrayValues\");\n\n        assertThatThrownBy(() -> ReflectionUtils.getParameterizedClass(field))\n                .isInstanceOf(ClassCastException.class);\n    }\n\n    private static final class PackageResourceClassLoader extends ClassLoader {","newText":"    public void rejectsParameterizedFieldsWithGenericArrayArguments() {\n        final Field field = fieldNamed(GenericArrayFieldDocument.class, \"genericArrayValues\");\n\n        assertThatThrownBy(() -> ReflectionUtils.getParameterizedClass(field))\n                .isInstanceOf(ClassCastException.class);\n    }\n\n    private static Field fieldNamed(final Class<?> type, final String name) {\n        for (final Field field : ReflectionUtils.getDeclaredAndInheritedFields(type, true)) {\n            if (name.equals(field.getName())) {\n                return field;\n            }\n        }\n        throw new AssertionError(\"Field not found: \" + name);\n    }\n\n    private static final class PackageResourceClassLoader extends ClassLoader {"}]}
