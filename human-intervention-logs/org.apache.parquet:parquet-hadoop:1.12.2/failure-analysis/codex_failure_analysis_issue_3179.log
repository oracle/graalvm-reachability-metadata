che.parquet/parquet-hadoop/1.12.2/src/test/java/org_apache_parquet/parquet_hadoop/CleanUtilTest.java\\n@@ -9,16 +9,32 @@ package org_apache_parquet.parquet_hadoop;\\n import java.nio.ByteBuffer;\\n \\n import org.apache.parquet.hadoop.codec.CleanUtil;\\n+import org.junit.jupiter.api.Tag;\\n import org.junit.jupiter.api.Test;\\n \\n import static org.junit.jupiter.api.Assertions.assertDoesNotThrow;\\n \\n public class CleanUtilTest {\\n+    private static final String LEGACY_CLEANER_TAG = \\\"legacy-clean-util\\\";\\n+    private static final String JAVA_VERSION_PROPERTY = \\\"java.version\\\";\\n+\\n+    @Test\\n+    @Tag(LEGACY_CLEANER_TAG)\\n+    void cleanDirectBufferCanUseLegacyCleanerReflection() {\\n+        String previousJavaVersion = System.getProperty(JAVA_VERSION_PROPERTY);\\n+        try {\\n+            System.setProperty(JAVA_VERSION_PROPERTY, \\\"1.8.0\\\");\\n+            ByteBuffer directBuffer = newDirectBuffer();\\n+\\n+            assertDoesNotThrow(() -> CleanUtil.cleanDirectBuffer(directBuffer));\\n+        } finally {\\n+            restoreJavaVersion(previousJavaVersion);\\n+        }\\n+    }\\n+\\n     @Test\\n     void cleanDirectBufferAcceptsDirectByteBuffer() {\\n-        ByteBuffer directBuffer = ByteBuffer.allocateDirect(32);\\n-        directBuffer.put((byte) 1);\\n-        directBuffer.flip();\\n+        ByteBuffer directBuffer = newDirectBuffer();\\n \\n         assertDoesNotThrow(() -> CleanUtil.cleanDirectBuffer(directBuffer));\\n     }\\n@@ -31,4 +47,19 @@ public class CleanUtilTest {\\n \\n         assertDoesNotThrow(() -> CleanUtil.cleanDirectBuffer(heapBuffer));\\n     }\\n+\\n+    private static ByteBuffer newDirectBuffer() {\\n+        ByteBuffer directBuffer = ByteBuffer.allocateDirect(32);\\n+        directBuffer.put((byte) 1);\\n+        directBuffer.flip();\\n+        return directBuffer;\\n+    }\\n+\\n+    private static void restoreJavaVersion(String previousJavaVersion) {\\n+        if (previousJavaVersion == null) {