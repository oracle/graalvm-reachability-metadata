st.java\", \"edits\": [{\"oldText\": \"import java.io.IOException;\\nimport java.io.InputStream;\\nimport java.lang.reflect.InvocationTargetException;\\nimport java.lang.reflect.Method;\\nimport java.nio.ByteBuffer;\\n\", \"newText\": \"import java.io.File;\\nimport java.lang.reflect.InvocationTargetException;\\nimport java.lang.reflect.Method;\\nimport java.net.URL;\\nimport java.net.URLClassLoader;\\nimport java.nio.ByteBuffer;\\nimport java.util.ArrayList;\\nimport java.util.List;\\n\"}, {\"oldText\": \"    private static void invokeCleanDirectBufferFromIsolatedCleanUtil() throws Exception {\\n        ClassLoader parentClassLoader = CleanUtilTest.class.getClassLoader();\\n        ClassLoader classLoader = new IsolatedCleanUtilClassLoader(parentClassLoader);\\n        Class<?> cleanUtilClass = classLoader.loadClass(CLEAN_UTIL_CLASS_NAME);\\n        Method cleanDirectBuffer = cleanUtilClass.getMethod(\\\"cleanDirectBuffer\\\", ByteBuffer.class);\\n        ByteBuffer directBuffer = ByteBuffer.allocateDirect(32);\\n        directBuffer.put((byte) 1);\\n        directBuffer.flip();\\n\\n        try {\\n            cleanDirectBuffer.invoke(null, directBuffer);\\n        } catch (InvocationTargetException exception) {\\n            Throwable cause = exception.getCause();\\n            if (cause instanceof Exception nestedException) {\\n                throw nestedException;\\n            }\\n            if (cause instanceof Error nestedError) {\\n                throw nestedError;\\n            }\\n            throw exception;\\n        }\\n    }\\n\", \"newText\": \"    private static void invokeCleanDirectBufferFromIsolatedCleanUtil() throws Exception {\\n        ClassLoader parentClassLoader = CleanUtilTest.class.getClassLoader();\\n        try (URLClassLoader classLoader = new IsolatedCleanUtilClassLoader(testClasspathUrls(), parentClassLoader)) {\\n            Class<?> cleanUtilClass = classLoader.loadClass(CLEAN_UTIL_CLASS_NAME);\\n            Method cleanDirectBuffer = cleanUtilClass.getMethod(\\\"cleanDirectBuffer\\\", ByteBuffer.class);\\n            ByteBuffer directBuffer = ByteBuffer.allocateDirect(32);\\n            directBuffer.put((byte) 1);\\n            directBuffer.flip();\\n\\n            try {\\n                cleanDirectBuffer.invoke(null, directBuffer);\\n            } catch (InvocationTargetException exception) {\\n                Throwable cause = exception.getCause();\\n                if (cause instanceof Exception nestedException) {\\n                    throw nestedException;\\n                }\\n                if (cause instanceof Error nestedError) {\\n                    throw nestedError;\\n                }\\n                throw exception;\\n            }\\n        }\\n    }\\n\\n    private static URL[] testClasspathUrls() throws Exception {\\n        List<URL> urls = new ArrayList<>();\\n        for (String entry : System.getProperty(\\\"java.class.path\\\").split(File.pathSeparator)) {\\n            if (!entry.isBlank()) {\\n                urls.add(new File(entry).toURI().toURL());\\n            }\\n        }\\n        return urls.toArray(URL[]::new);\\n    }\\n\"}, {\"oldText\": \"    private static final class IsolatedCleanUtilClassLoader extends ClassLoader {\\n        private IsolatedCleanUtilClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            if (!CLEAN_UTIL_CLASS_NAME.equals(name)) {\\n                return super.loadClass(name, resolve);\\n            }\\n\\n            Class<?> loadedClass = findLoadedClass(name);\\n            if (loadedClass == null) {\\n                loadedClass = findClass(name);\\n            }\\n            if (resolve) {\\n                resolveClass(loadedClass);\\n            }\\n            return loadedClass;\\n        }\\n\\n        @Override\\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\\n            if (!CLEAN_UTIL_CLASS_NAME.equals(name)) {\\n                return super.findClass(name);\\n            }\\n\\n            String resourceName = name.replace('.', '/') + \\\".class\\\";\\n            try (InputStream classBytes = getParent().getResourceAsStream(resourceName)) {\\n                if (classBytes == null) {\\n                    throw new ClassNotFoundException(name);\\n                }\\n                byte[] bytes = classBytes.readAllBytes();\\n                return defineClass(name, bytes, 0, bytes.length);\\n            } catch (IOException exception) {\\n                throw new ClassNotFoundException(name, exception);\\n            }\\n        }\\n    }\\n\", \"newText\": \"    private static final class IsolatedCleanUtilClassLoader extends URLClassLoader {\\n        private IsolatedCleanUtilClassLoader(URL[] urls, ClassLoader parent) {\\n            super(urls, parent);\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            if (!CLEAN_UTIL_CLASS_NAME.equals(name)) {\\n                return super.loadClass(name, resolve);\\n            }\\n\\n            synchronized (getClassLoadingLock(name)) {\\n                Class<?> loadedClass = findLoadedClass(name);\\n                if (loadedClass == null) {\\n                    loadedClass = findClass(name);\\n                }\\n                if (resolve) {\\n                    resolveClass(loadedClass);\\n                }\\n                return loadedClass;\\n            }\\n        }\\n    }\\n\"}]}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1378, \"output\": 3305, \"cacheRead\": 26112, \"cacheWrite\": 0, \"totalTokens\": 30795, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778276025373, \"res