\n * {@code metadata/<group>/<artifact>/<version>/test/build/reports/dynamic-access/dynamic-access-coverage.json}\\n * and has this shape:\\n *\\n * <pre>{@code\\n * {\\n *   \\\"coordinate\\\": \\\"group:artifact:version\\\",\\n *   \\\"hasDynamicAccess\\\": true,\\n *   \\\"totals\\\": {\\n *     \\\"totalCalls\\\": 10,\\n *     \\\"coveredCalls\\\": 6\\n *   },\\n *   \\\"classes\\\": [\\n *     {\\n *       \\\"className\\\": \\\"com.example.Foo\\\",\\n *       \\\"sourceFile\\\": \\\"Foo.java\\\",\\n *       \\\"totalCalls\\\": 4,\\n *       \\\"coveredCalls\\\": 2,\\n *       \\\"callSites\\\": [\\n *         {\\n *           \\\"metadataType\\\": \\\"reflection\\\",\\n *           \\\"trackedApi\\\": \\\"java.lang.Class#forName(java.lang.String)\\\",\\n *           \\\"frame\\\": \\\"com.example.Foo.load(Foo.java:10)\\\",\\n *           \\\"line\\\": 10,\\n *           \\\"covered\\\": true\\n *         }\\n *       ]\\n *     }\\n *   ]\\n * }\\n * }</pre>\\n *\\n * <p>The JSON payload is emitted from {@link LibraryStatsModels.DynamicAccessCoverageReport}.\\n */\\n@SuppressWarnings(\\\"unused\\\")\\npublic abstract class GenerateDynamicAccessCoverageReportTask extends AbstractLibraryStatsTask {\\n\\n    @TaskAction\\n    public void generate() {\\n        List<String> coordinates = resolveRequestedCoordinates();\\n        for (String coordinate : coordinates) {\\n            generateReportsForCoordinate(coordinate);\\n            List<Path> libraryJars = listLibraryJars(coordinate);\\n            LibraryStatsModels.DynamicAccessCoverageReport report = LibraryStatsSupport.buildDynamicAccessCoverageReport(\\n                    coordinate,\\n                    libraryJars,\\n                    getDynamicAccessDir(coordinate),\\n                    getJacocoReport(coordinate)\\n            );\\n            Path outputFile = getDynamicAccessCoverageReport(coordinate);\\n            LibraryStatsSupport.writeJson(outputFile, report);\\n            getLogger().quiet(\\\"Wrote dynamic-access coverage report for {} to {}.\\\", coordinate, outputFile);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778276197089}]}\n3587:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_KKIRmDXwUcHFOXplST8kd4fY|fc_01d3ce057da11f900169fe576efa94819da5c6e6e6f385d4b0\", \"toolName\": \"bash\", \"content\": [{\"type\": \"text\", \"text\": \"tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/AbstractLibraryStatsTask.java:130:    protected boolean generateReportsForCoordinate(String coordinates) {\\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/AbstractLibraryStatsTask.java:131:        CommandResult jacoco = runGradle(List.of(\\\"jacocoTestReport\\\", \\\"-Pcoordinates=\\\" + coordinates), true);\\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/AbstractLibraryStatsTask.java:189:                .resolve(\\\"jacocoTestReport.xml\\\");\\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/AbstractLibraryStatsTask.java:226:        boolean dynamicAccessAvailable = generateReportsForCoordinate(coordinates);\\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/GenerateDynamicAccessCoverageReportTask.java:60:            generateReportsForCoordinate(coordinate);\\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/JacocoTestReportInvocationTask.java:12: * Task that is used to run JaCoCo report generation (\\\"jacocoTestReport\\\") on subprojects.\\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/JacocoTestReportInvocationTask.java:21:                \\\"jacocoTestReport\\\"\\ntests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:215:// gradle jacocoTestReport -Pcoordinates=<maven-coordinates>\\ntests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:216:t