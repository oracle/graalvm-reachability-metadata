lcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_parquet.parquet_hadoop;\n\nimport java.nio.ByteBuffer;\n\nimport org.apache.parquet.hadoop.codec.CleanUtil;\nimport org.junit.jupiter.api.MethodOrderer;\nimport org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\n\nimport static org.junit.jupiter.api.Assertions.assertDoesNotThrow;\n\n@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\npublic class CleanUtilTest {\n    private static final String JAVA_VERSION_PROPERTY = \"java.version\";\n\n    @Test\n    @Order(1)\n    void cleanDirectBufferCanUseLegacyCleanerReflection() {\n        String previousJavaVersion = System.getProperty(JAVA_VERSION_PROPERTY);\n        try {\n            System.setProperty(JAVA_VERSION_PROPERTY, \"1.8.0\");\n            ByteBuffer directBuffer = newDirectBuffer();\n\n            assertDoesNotThrow(() -> CleanUtil.cleanDirectBuffer(directBuffer));\n        } finally {\n            restoreJavaVersion(previousJavaVersion);\n        }\n    }\n\n    @Test\n    @Order(2)\n    void cleanDirectBufferAcceptsDirectByteBuffer() {\n        ByteBuffer directBuffer = newDirectBuffer();\n\n        assertDoesNotThrow(() -> CleanUtil.cleanDirectBuffer(directBuffer));\n    }\n\n    @Test\n    @Order(3)\n    void cleanDirectBufferSwallowsUnsupportedHeapByteBufferCleanup() {\n        ByteBuffer heapBuffer = ByteBuffer.allocate(32);\n        heapBuffer.put((byte) 1);\n        heapBuffer.flip();\n\n        assertDoesNotThrow(() -> CleanUtil.cleanDirectBuffer(heapBuffer));\n    }\n\n    private static ByteBuffer newDirectBuffer() {\n        ByteBuffer directBuffer = ByteBuffer.allocateDirect(32);\n        directBuffer.put((byte) 1);\n        directBuffer.flip();\n        return directBuffer;\n    }\n\n    private static void restoreJavaVersion(String previousJavaVersion) {\n        if (previousJavaVersion == null) {\n            System.clearProperty(JAVA_VERSION_PROPERTY);\n        } else {\n            System.setProperty(JAVA_VERSION_PROPERTY, previousJavaVersion);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 735, "output": 1411, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 44130, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778276139909, "responseId": "resp_01d3ce057da11f900169fe572db4b4819da2cd9ea833612263"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Hvlr5t8c0NJeVUKsfkVRSqvz|fc_01d3ce057da11f900169fe573a8c30819d95a46ff7ede90bb6", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2195 bytes to tests/src/org.apache.parquet/parquet-hadoop/1.12.2/src/test/java/org_apache_parquet/parquet_hadoop/CleanUtilTest.java"}], "isError": false, "timestamp": 1778276157875}]}
