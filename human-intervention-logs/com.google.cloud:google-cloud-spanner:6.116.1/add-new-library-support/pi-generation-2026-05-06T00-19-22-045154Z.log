  public class ClientSideStatementPartitionExecutorTest {
      @Test
      void executePartitionStatementDelegatesToPartitionQuery() throws Exception {
          PartitioningSpanner spanner = new PartitioningSpanner();
          Server server = ServerBuilder.forPort(0).addService(spanner).build().start();
