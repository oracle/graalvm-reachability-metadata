[tool-call] delta {"path":"tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ClientSideStatementSetExecutorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.cloud.spanner.Statement;\nimport com.google.cloud.spanner.connection.Connection;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport com.google.cloud.spanner.connection.SpannerPool;\nimport com.google.cloud.spanner.connection.StatementResult;\nimport com.google.protobuf.Empty;\nimport com.google.protobuf.Value;\nimport com.google.spanner.v1.CreateSessionRequest;\nimport com.google.spanner.v1.DeleteSessionRequest;\nimport com.google.spanner.v1.ExecuteSqlRequest;\nimport com.google.spanner.v1.PartialResultSet;\nimport com.google.spanner.v1.ResultSetMetadata;\nimport com.google.spanner.v1.Session;\nimport com.google.spanner.v1.SpannerGrpc;\nimport com.google.spanner.v1.StructType;\nimport com.google.spanner.v1.Type;\nimport com.google.spanner.v1.TypeCode;\nimport io.grpc.Server;\nimport io.grpc.ServerBuilder;\nimport io.grpc.Status;\nimport io.grpc.stub.StreamObserver;\nimport java.util.concurrent.TimeUnit;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementSetExecutorTest {\n    @Test\n    void executesSetStatementsWithOneAndTwoExecutorParameters() throws Exception {\n        Server server = ServerBuilder.forPort(0).addService(new DialectSpannerService()).build().start();\n        try {\n            ConnectionOptions options =\n                    ConnectionOptions.newBuilder()\n                            .setUri(\n                                    String.format(\n                                            \"cloudspanner://localhost:%d/projects/p/instances/i/databases/d\"\n                                                    + \"?usePlainText=true;trackConnectionLeaks=false;trackSessionLeaks=false\"\n                                                    + \";numChannels=1;minSessions=0;maxSessions=1\",\n                                            server.getPort()))\n                            .build();\n\n            try (Connection connection = options.getConnection()) {\n                assertNoResult(\n                        connection.execute(Statement.of(\"set autocommit = false\")),\n                        StatementResult.ClientSideStatementType.SET_AUTOCOMMIT);\n                assertThat(connection.isAutocommit()).isFalse();\n\n                assertNoResult(\n                        connection.execute(Statement.of(\"set retry_aborts_internally = false\")),\n                        StatementResult.ClientSideStatementType.SET_RETRY_ABORTS_INTERNALLY);\n                assertThat(connection.isRetryAbortsInternally()).isFalse();\n            } finally {\n                SpannerPool.closeSpannerPool();\n            }\n        } finally {\n            server.shutdownNow();\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n\n    private static void assertNoResult(\n            StatementResult result, StatementResult.ClientSideStatementType statementType) {\n        assertThat(result.getResultType()).isEqualTo(StatementResult.ResultType.NO_RESULT);\n        assertThat(result.getClientSideStatementType()).isEqualTo(statementType);\n    }\n\n    private static final class DialectSpannerService extends SpannerGrpc.SpannerImplBase {\n        private static final String DIALECT_SQL_PREFIX = \"select option_value from information_schema.database_options\";\n\n        @Override\n        public void createSession(CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(\n                    Session.newBuilder()\n                            .setName(request.getDatabase() + \"/sessions/test-session\")\n                            .setMultiplexed(true)\n                            .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void deleteSession(DeleteSessionRequest request, StreamObserver<Empty> responseObserver) {\n            responseObserver.onNext(Empty.getDefaultInstance());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            if (!request.getSql().toLowerCase().startsWith(DIALECT_SQL_PREFIX)) {\n                responseObserver.onError(\n                        Status.UNIMPLEMENTED\n                                .withDescription(\"Unexpected SQL: \" + request.getSql())\n                                .asRuntimeException());\n                return;\n            }\n            responseObserver.onNext(\n                    PartialResultSet.newBuilder()\n                            .setMetadata(\n                                    ResultSetMetadata.newBuilder()\n                                            .setRowType(\n                                                    StructType.newBuilder()\n                                                            .addFields(\n                                                                    StructType.Field.newBuilder()\n                                                                            .setName(\"option_value\")\n                                                                            .setType(\n                                                                                    Type.newBuilder()\n                                                                                            .setCode(TypeCode.STRING)\n                                                                                            .build())\n                                                                            .build())\n                                                            .build())\n                                            .build())\n                            .addValues(Value.newBuilder().setStringValue(\"GOOGLE_STANDARD_SQL\").build())\n                            .build());\n            responseObserver.onCompleted();\n        }\n    }\n}\n"}
