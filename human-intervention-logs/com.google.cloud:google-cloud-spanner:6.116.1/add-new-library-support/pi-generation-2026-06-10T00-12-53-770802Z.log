[tool-call] delta {"path":"tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ClientSideStatementValueConvertersInnerCredentialsProviderConverterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.api.gax.core.CredentialsProvider;\nimport com.google.auth.Credentials;\nimport com.google.auth.oauth2.NoCredentials;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport java.io.IOException;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementValueConvertersInnerCredentialsProviderConverterTest {\n    @Test\n    void buildsConnectionOptionsWithCredentialsProviderFromUri() {\n        String previousValue = System.getProperty(ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY);\n        System.setProperty(ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY, \"true\");\n        try {\n            ConnectionOptions options =\n                    ConnectionOptions.newBuilder()\n                            .setUri(\n                                    \"cloudspanner://localhost:9010/projects/test-project/instances/\"\n                                            + \"test-instance/databases/test-database?usePlainText=true;\"\n                                            + \"credentialsProvider=\"\n                                            + TestCredentialsProvider.class.getName())\n                            .build();\n\n            assertThat(options.getCredentials()).isSameAs(NoCredentials.getInstance());\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY);\n            } else {\n                System.setProperty(\n                        ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY, previousValue);\n            }\n        }\n    }\n\n    public static class TestCredentialsProvider implements CredentialsProvider {\n        public TestCredentialsProvider() {}\n\n        @Override\n        public Credentials getCredentials() throws IOException {\n            return NoCredentials.getInstance();\n        }\n    }\n}\n"}
