  package com_google_cloud.google_cloud_spanner;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.api.gax.grpc.InstantiatingGrpcChannelProvider;
  import com.google.api.gax.rpc.TransportChannelProvider;
  import com.google.cloud.spanner.connection.ConnectionOptions;
  import org.junit.jupiter.api.Test;
  
  public class ConnectionOptionsTest {
      @Test
      void createsExternalChannelProviderFromConnectionUri() {
          String propertyName = ConnectionOptions.ENABLE_CHANNEL_PROVIDER_SYSTEM_PROPERTY;
          String previousValue = System.getProperty(propertyName);
          System.setProperty(propertyName, "true");
          TestExternalChannelProvider.reset();
          try {
              String uri =
                      "cloudspanner://localhost:9010/projects/test-project/instances/test-instance/"
                              + "databases/test-database?usePlainText=true;channelProvider="
                              + TestExternalChannelProvider.class.getName();
  
              ConnectionOptions options = ConnectionOptions.newBuilder().setUri(uri).build();
              TransportChannelProvider provider = options.getChannelProvider();
  
              assertThat(provider).isInstanceOf(InstantiatingGrpcChannelProvider.class);
              assertThat(TestExternalChannelProvider.host).isEqualTo("localhost");
              assertThat(TestExternalChannelProvider.port).isEqualTo(9010);
          } finally {
              if (previousValue == null) {
                  System.clearProperty(propertyName);
              } else {
                  System.setProperty(propertyName, previousValue);
              }
          }
      }
  
      public static class TestExternalChannelProvider
              implements ConnectionOptions.ExternalChannelProvider {
          static String host;
          static int port;
  
          public TestExternalChannelProvider() {}
  
          static void reset() {
              host = null;
              port = -1;
          }
  
          @Override
          public TransportChannelProvider getChannelProvider(String host, int port) {
              TestExternalChannelProvider.host = host;
              TestExternalChannelProvider.port = port;
              return InstantiatingGrpcChannelProvider.newBuilder()
                      .setEndpoint(String.format("%s:%d", host, port))
                      .build();
          }
      }
  }
