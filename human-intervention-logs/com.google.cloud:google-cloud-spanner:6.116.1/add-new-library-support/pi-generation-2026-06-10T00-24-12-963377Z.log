  package com_google_cloud.google_cloud_spanner;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.api.gax.core.CredentialsProvider;
  import com.google.auth.Credentials;
  import com.google.auth.oauth2.AccessToken;
  import com.google.auth.oauth2.GoogleCredentials;
  import com.google.cloud.spanner.connection.ConnectionOptions;
  import org.junit.jupiter.api.Test;
  
  public class ClientSideStatementValueConvertersInnerCredentialsProviderConverterTest {
      @Test
      void buildsConnectionOptionsWithCredentialsProviderFromUri() {
          String propertyName = ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY;
          String previousValue = System.getProperty(propertyName);
          System.setProperty(propertyName, "true");
          try {
              String uri =
                      "cloudspanner:/projects/test-project/instances/test-instance/databases/"
                              + "test-database?credentialsProvider="
                              + TestCredentialsProvider.class.getName();
  
              ConnectionOptions options = ConnectionOptions.newBuilder().setUri(uri).build();
  
              assertThat(options.getCredentials()).isInstanceOf(GoogleCredentials.class);
          } finally {
              if (previousValue == null) {
                  System.clearProperty(propertyName);
              } else {
                  System.setProperty(propertyName, previousValue);
              }
          }
      }
  
      public static class TestCredentialsProvider implements CredentialsProvider {
          public TestCredentialsProvider() {}
  
          @Override
          public Credentials getCredentials() {
              return GoogleCredentials.create(new AccessToken("test-token", null));
          }
      }
  }
