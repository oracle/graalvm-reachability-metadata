[tool-call] delta {"path":"tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ClientSideStatementExplainExecutorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.cloud.spanner.ResultSet;\nimport com.google.cloud.spanner.SessionPoolOptions;\nimport com.google.cloud.spanner.Statement;\nimport com.google.cloud.spanner.connection.Connection;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport com.google.cloud.spanner.connection.StatementResult;\nimport com.google.spanner.v1.BatchCreateSessionsRequest;\nimport com.google.spanner.v1.BatchCreateSessionsResponse;\nimport com.google.spanner.v1.CreateSessionRequest;\nimport com.google.spanner.v1.ExecuteSqlRequest;\nimport com.google.spanner.v1.PartialResultSet;\nimport com.google.spanner.v1.PlanNode;\nimport com.google.spanner.v1.QueryPlan;\nimport com.google.spanner.v1.ResultSetStats;\nimport com.google.spanner.v1.Session;\nimport com.google.spanner.v1.SpannerGrpc;\nimport io.grpc.Server;\nimport io.grpc.ServerBuilder;\nimport io.grpc.stub.StreamObserver;\nimport java.util.concurrent.TimeUnit;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementExplainExecutorTest {\n    @Test\n    void executesPostgreSqlExplainStatementThroughConnection() throws Exception {\n        ExplainSpannerService service = new ExplainSpannerService();\n        Server server = ServerBuilder.forPort(0).addService(service).build().start();\n        ConnectionOptions options =\n                ConnectionOptions.newBuilder()\n                        .setUri(\n                                String.format(\n                                        \"cloudspanner://127.0.0.1:%d/projects/test-project/\"\n                                                + \"instances/test-instance/databases/test-database?\"\n                                                + \"usePlainText=true;dialect=POSTGRESQL\",\n                                        server.getPort()))\n                        .setSessionPoolOptions(\n                                SessionPoolOptions.newBuilder()\n                                        .setMinSessions(0)\n                                        .setMaxSessions(1)\n                                        .setAutoDetectDialect(false)\n                                        .build())\n                        .build();\n\n        Connection connection = null;\n        try {\n            connection = options.getConnection();\n\n            StatementResult result = connection.execute(Statement.of(\"explain select 1\"));\n\n            assertThat(result.getResultType()).isEqualTo(StatementResult.ResultType.RESULT_SET);\n            assertThat(result.getClientSideStatementType())\n                    .isEqualTo(StatementResult.ClientSideStatementType.EXPLAIN);\n            try (ResultSet resultSet = result.getResultSet()) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getString(\"QUERY PLAN\")).contains(\"Constant Scan\");\n                assertThat(resultSet.next()).isFalse();\n            }\n            assertThat(service.seenExplainRequest).isTrue();\n        } finally {\n            try {\n                if (connection != null) {\n                    connection.close();\n                }\n                ConnectionOptions.closeSpanner();\n            } finally {\n                server.shutdownNow();\n                assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n            }\n        }\n    }\n\n    private static final class ExplainSpannerService extends SpannerGrpc.SpannerImplBase {\n        private boolean seenExplainRequest;\n\n        @Override\n        public void createSession(\n                CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(session(request.getDatabase() + \"/sessions/test-session\"));\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void batchCreateSessions(\n                BatchCreateSessionsRequest request,\n                StreamObserver<BatchCreateSessionsResponse> responseObserver) {\n            responseObserver.onNext(\n                    BatchCreateSessionsResponse.newBuilder()\n                            .addSession(session(request.getDatabase() + \"/sessions/test-session\"))\n                            .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            seenExplainRequest = true;\n            assertThat(request.getSql()).isEqualTo(\"select 1\");\n            assertThat(request.getQueryMode()).isEqualTo(ExecuteSqlRequest.QueryMode.PLAN);\n            responseObserver.onNext(\n                    PartialResultSet.newBuilder()\n                            .setStats(\n                                    ResultSetStats.newBuilder()\n                                            .setQueryPlan(\n                                                    QueryPlan.newBuilder()\n                                                            .addPlanNodes(\n                                                                    PlanNode.newBuilder()\n                                                                            .setIndex(0)\n                                                                            .setKind(\n                                                                                    PlanNode.Kind\n                                                                                            .RELATIONAL)\n                                                                            .setDisplayName(\n                                                                                    \"Constant Scan\"))))\n                            .build());\n            responseObserver.onCompleted();\n        }\n\n        private static Session session(String name) {\n            return Session.newBuilder().setName(name).build();\n        }\n    }\n}\n"}
[tool-call] end id=call_pZu9E8NGBo4IYjq17LUlg27u|fc_071b341cc7b502d6016a28ae2da2dc8195b458b9478c169e18 name=write args={"path": "tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ClientSideStatementExplainExecutorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.cloud.spanner.ResultSet;\nimport com.google.cloud.spanner.SessionPoolOptions;\nimport com.google.cloud.spanner.Statement;\nimport com.google.cloud.spanner.connection.Connection;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport com.google.cloud.spanner.connection.StatementResult;\nimport com.google.spanner.v1.BatchCreateSessionsRequest;\nimport com.google.spanner.v1.BatchCreateSessionsResponse;\nimport com.google.spanner.v1.CreateSessionRequest;\nimport com.google.spanner.v1.ExecuteSqlRequest;\nimport com.google.spanner.v1.PartialResultSet;\nimport com.google.spanner.v1.PlanNode;\nimport com.google.spanner.v1.QueryPlan;\nimport com.google.spanner.v1.ResultSetStats;\nimport com.google.spanner.v1.Session;\nimport com.google.spanner.v1.SpannerGrpc;\nimport io.grpc.Server;\nimport io.grpc.ServerBuilder;\nimport io.grpc.stub.StreamObserver;\nimport java.util.concurrent.TimeUnit;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementExplainExecutorTest {\n    @Test\n    void executesPostgreSqlExplainStatementThroughConnection() throws Exception {\n        ExplainSpannerService service = new ExplainSpannerService();\n        Server server = ServerBuilder.forPort(0).addService(service).build().start();\n        ConnectionOptions options =\n                ConnectionOptions.newBuilder()\n                        .setUri(\n                                String.format(\n                                        \"cloudspanner://127.0.0.1:%d/projects/test-project/\"\n                                                + \"instances/test-instance/databases/test-database?\"\n                                                + \"usePlainText=true;dialect=POSTGRESQL\",\n                                        server.getPort()))\n                        .setSessionPoolOptions(\n                                SessionPoolOptions.newBuilder()\n                                        .setMinSessions(0)\n                                        .setMaxSessions(1)\n                                        .setAutoDetectDialect(false)\n                                        .build())\n                        .build();\n\n        Connection connection = null;\n        try {\n            connection = options.getConnection();\n\n            StatementResult result = connection.execute(Statement.of(\"explain select 1\"));\n\n            assertThat(result.getResultType()).isEqualTo(StatementResult.ResultType.RESULT_SET);\n            assertThat(result.getClientSideStatementType())\n                    .isEqualTo(StatementResult.ClientSideStatementType.EXPLAIN);\n            try (ResultSet resultSet = result.getResultSet()) {\n                assertThat(resultSet.next()).isTrue();\n                assertThat(resultSet.getString(\"QUERY PLAN\")).contains(\"Constant Scan\");\n                assertThat(resultSet.next()).isFalse();\n            }\n            assertThat(service.seenExplainRequest).isTrue();\n        } finally {\n            try {\n                if (connection != null) {\n                    connection.close();\n                }\n                ConnectionOptions.closeSpanner();\n            } finally {\n                server.shutdownNow();\n                assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n            }\n        }\n    }\n\n    private static final class ExplainSpannerService extends SpannerGrpc.SpannerImplBase {\n        private boolean seenExplainRequest;\n\n        @Override\n        public void createSession(\n                CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(session(request.getDatabase() + \"/sessions/test-session\"));\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void batchCreateSessions(\n                BatchCreateSessionsRequest request,\n                StreamObserver<BatchCreateSessionsResponse> responseObserver) {\n            responseObserver.onNext(\n                    BatchCreateSessionsResponse.newBuilder()\n                            .addSession(session(request.getDatabase() + \"/sessions/test-session\"))\n                            .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            seenExplainRequest = true;\n            assertThat(request.getSql()).isEqualTo(\"select 1\");\n            assertThat(request.getQueryMode()).isEqualTo(ExecuteSqlRequest.QueryMode.PLAN);\n            responseObserver.onNext(\n                    PartialResultSet.newBuilder()\n                            .setStats(\n                                    ResultSetStats.newBuilder()\n                                            .setQueryPlan(\n                                                    QueryPlan.newBuilder()\n                                                            .addPlanNodes(\n                                                                    PlanNode.newBuilder()\n                                                                            .setIndex(0)\n                                                                            .setKind(\n                                                               