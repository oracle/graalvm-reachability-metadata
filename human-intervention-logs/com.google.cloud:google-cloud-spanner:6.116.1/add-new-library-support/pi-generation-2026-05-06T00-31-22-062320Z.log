  package com_google_cloud.google_cloud_spanner;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.cloud.spanner.ResultSet;
  import com.google.cloud.spanner.Statement;
  import com.google.cloud.spanner.connection.Connection;
  import com.google.cloud.spanner.connection.ConnectionOptions;
  import com.google.cloud.spanner.connection.StatementResult;
  import com.google.cloud.spanner.connection.StatementResult.ClientSideStatementType;
  import com.google.cloud.spanner.connection.StatementResult.ResultType;
  import com.google.protobuf.ByteString;
  import com.google.protobuf.ListValue;
  import com.google.protobuf.Timestamp;
  import com.google.protobuf.Value;
  import com.google.spanner.v1.BeginTransactionRequest;
  import com.google.spanner.v1.CreateSessionRequest;
  import com.google.spanner.v1.ExecuteSqlRequest;
  import com.google.spanner.v1.PartialResultSet;
  import com.google.spanner.v1.Partition;
  import com.google.spanner.v1.PartitionQueryRequest;
  import com.google.spanner.v1.PartitionResponse;
  import com.google.spanner.v1.ResultSetMetadata;
  import com.google.spanner.v1.Session;
  import com.google.spanner.v1.SpannerGrpc;
  import com.google.spanner.v1.StructType;
  import com.google.spanner.v1.Transaction;
  import com.google.spanner.v1.Type;
  import com.google.spanner.v1.TypeCode;
  import io.grpc.Server;
  import io.grpc.ServerBuilder;
  import io.grpc.stub.StreamObserver;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicReference;
  import org.junit.jupiter.api.Test;
  
  public class ClientSideStatementRunPartitionExecutorTest {
      @Test
      void executeRunPartitionStatementDelegatesToRunPartition() throws Exception {
          PartitionExecutionSpanner spanner = new PartitionExecutionSpanner();
          Server server = ServerBuilder.forPort(0).addService(spanner).build().start();
          try {
              ConnectionOptions options = ConnectionOptions.newBuilder()
                      .setUri("cloudspanner://localhost:" + server.getPort()
                              + "/projects/test-project/instances/test-instance/databases/"
                              + "test-database"
                              + "?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1"
                              + ";trackConnectionLeaks=false")
                      .build();
  
              try (Connection connection = options.getConnection()) {
                  String partitionId;
                  Statement partitionStatement = Statement.of("partition select 1");
                  StatementResult partitionResult = connection.execute(partitionStatement);
                  try (ResultSet partitions = partitionResult.getResultSet()) {
                      assertThat(partitions.next()).isTrue();
                      partitionId = partitions.getString("PARTITION");
                      assertThat(partitions.next()).isFalse();
                  }
  
                  Statement runPartitionStatement = Statement.of(
                          "run partition '" + partitionId + "'");
                  StatementResult result = connection.execute(runPartitionStatement);
  
                  assertThat(result.getResultType()).isEqualTo(ResultType.RESULT_SET);
                  assertThat(result.getClientSideStatementType())
                          .isEqualTo(ClientSideStatementType.RUN_PARTITION);
                  assertThat(spanner.partitionedSql.get()).isEqualTo("select 1");
                  try (ResultSet rows = result.getResultSet()) {
                      assertThat(rows.next()).isTrue();
                      assertThat(rows.getString("VALUE")).isEqualTo("partition-row");
                      assertThat(rows.next()).isFalse();
                  }
                  assertThat(spanner.executedPartitionToken.get()).isEqualTo("partition-token");
              }
          } finally {
              server.shutdownNow();
              assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();
          }
      }
  
      private static final class PartitionExecutionSpanner extends SpannerGrpc.SpannerImplBase {
          private static final String DIALECT = "GOOGLE_STANDARD_SQL";
          private static final ResultSetMetadata DIALECT_METADATA = ResultSetMetadata.newBuilder()
                  .setRowType(StructType.newBuilder()
                          .addFields(StructType.Field.newBuilder()
                                  .setName("option_value")
                                  .setType(Type.newBuilder().setCode(TypeCode.STRING).build())
                                  .build())
                          .build())
                  .build();
          private static final ResultSetMetadata ROW_METADATA = ResultSetMetadata.newBuilder()
                  .setRowType(StructType.newBuilder()
                          .addFields(StructType.Field.newBuilder()
                                  .setName("VALUE")
                                  .setType(Type.newBuilder().setCode(TypeCode.STRING).build())
                                  .build())
                          .build())
                  .build();
  
          private final AtomicReference<String> partitionedSql = new AtomicReference<>();
          private final AtomicReference<String> executedPartitionToken = new AtomicReference<>();
  
          @Override
          public void createSession(
                  CreateSessionRequest request, StreamObserver<Session> responseObserver) {
              responseObserver.onNext(Session.newBuilder()
                      .setName(request.getDatabase() + "/sessions/test-session")
                      .setMultiplexed(request.getSession().getMultiplexed())
                      .build());
              responseObserver.onCompleted();
          }
  
          @Override
          public void executeStreamingSql(
                  ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {
              if (!request.getPartitionToken().isEmpty()) {
                  executedPartitionToken.set(request.getPartitionToken().toStringUtf8());
                  responseObserver.onNext(PartialResultSet.newBuilder()
                          .setMetadata(ROW_METADATA)
                          .addValues(Value.newBuilder().setStringValue("partition-row").build())
                          .build());
              } else {
                  responseObserver.onNext(PartialResultSet.newBuilder()
                          .setMetadata(DIALECT_METADATA)
                          .addValues(Value.newBuilder().setStringValue(DIALECT).build())
                          .build());
              }
              responseObserver.onCompleted();
          }
  
          @Override
          public void executeSql(
                  ExecuteSqlRequest request,
                  StreamObserver<com.google.spanner.v1.ResultSet> responseObserver) {
              responseObserver.onNext(com.google.spanner.v1.ResultSet.newBuilder()
                      .setMetadata(DIALECT_METADATA)
                      .addRows(ListValue.newBuilder()
                              .addValues(Value.newBuilder().setStringValue(DIALECT).build())
                              .build())
                      .build());
              responseObserver.onCompleted();
          }
  
          @Override
          public void beginTransaction(
                  BeginTransactionRequest request, StreamObserver<Transaction> responseObserver) {
              responseObserver.onNext(Transaction.newBuilder()
                      .setId(ByteString.copyFromUtf8("test-transaction"))
                      .setReadTimestamp(Timestamp.newBuilder().setSeconds(1).build())
                      .build());
              responseObserver.onCompleted();
          }
  
          @Override
          public void partitionQuery(
                  PartitionQueryRequest request, StreamObserver<PartitionResponse> responseObserver) {
              partitionedSql.set(request.getSql());
              responseObserver.onNext(PartitionResponse.newBuilder()
                      .addPartitions(Partition.newBuilder()
                              .setPartitionToken(ByteString.copyFromUtf8("partition-token"))
                              .build())
                      .build());
              responseObserver.onCompleted();
          }
      }
  }
