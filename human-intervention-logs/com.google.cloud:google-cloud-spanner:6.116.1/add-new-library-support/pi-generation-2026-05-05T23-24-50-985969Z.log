edentialsProviderConverterTest {\n    @Test\n    void connectionOptionsCreatesCredentialsProviderFromUriClassName() {\n        RecordingCredentialsProvider.reset();\n        String propertyName = ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY;\n        String previousValue = System.getProperty(propertyName);\n        System.setProperty(propertyName, \"true\");\n        try {\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(\"cloudspanner:/projects/test-project/instances/test-instance/databases/test-database\"\n                            + \"?credentialsProvider=\" + RecordingCredentialsProvider.class.getName()\n                            + \";usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                            + \";trackConnectionLeaks=false\")\n                    .build();\n\n            assertThat(options.getCredentials()).isSameAs(NoCredentials.getInstance());\n            assertThat(RecordingCredentialsProvider.constructorCalls()).isEqualTo(1);\n            assertThat(RecordingCredentialsProvider.credentialsCalls()).isEqualTo(1);\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(propertyName);\n            } else {\n                System.setProperty(propertyName, previousValue);\n            }\n            RecordingCredentialsProvider.reset();\n        }\n    }\n\n    public static final class RecordingCredentialsProvider implements CredentialsProvider {\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\n        private static final AtomicInteger CREDENTIALS_CALLS = new AtomicInteger();\n\n        public RecordingCredentialsProvider() {\n            CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public Credentials getCredentials() throws IOException {\n            CREDENTIALS_CALLS.incrementAndGet();\n            return NoCredentials.getInstance();\n      