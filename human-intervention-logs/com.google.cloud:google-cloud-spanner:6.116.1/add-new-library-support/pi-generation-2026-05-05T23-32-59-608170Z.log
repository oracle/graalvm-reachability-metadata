  import io.grpc.stub.StreamObserver;
  import java.util.concurrent.TimeUnit;
  import org.junit.jupiter.api.Test;
  
  public class ClientSideStatementSetExecutorTest {
      @Test
      void executeSetStatementsWithAndWithoutLocalSupport() throws Exception {
          Server server = ServerBuilder.forPort(0)
                  .addService(new DialectOnlySpanner())
                  .build()
                  .start();
          try {
              ConnectionOptions options = ConnectionOptions.newBuilder()
                      .setUri("cloudspanner://localhost:" + server.getPort()
                              + "/projects/test-project/instances/test-instance/databases/test-database"
                              + "?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1"
                              + ";trackConnectionLeaks=false")
                      .build();
  
              try (Connection connection = options.getConnection()) {
                  StatementResult retryAbortsResult = connection.execute(
                          Statement.of("set retry_aborts_internally = false"));
                  assertNoResult(
                          retryAbortsResult, ClientSideStatementType.SET_RETRY_ABORTS_INTERNALLY);
                  assertThat(connection.isRetryAbortsInternally()).isFalse();
  
                  StatementResult autocommitResult = connection.execute(
                          Statement.of("set autocommit = false"));
                  assertNoResult(autocommitResult, ClientSideStatementType.SET_AUTOCOMMIT);
                  assertThat(connection.isAutocommit()).isFalse();
              }
          } finally {
              server.shutdownNow();
              assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();
          }
      }
  
      private static void assertNoResult(
              StatementResult result, ClientSideStatementType clientSideStatementType) {
          assertThat(result.getResultType()).isEqualTo(ResultType.NO_RESULT);
          assertThat(result.getClientSideStatementType()).isEqualTo(clientSideStatementType);
      }
  
      private static final class DialectOnlySpanner extends SpannerGrpc.SpannerImplBase {
          private static final String DIALECT = "GOOGLE_STANDARD_SQL";
          private static final ResultSetMetadata DIALECT_METADATA = ResultSetMetadata.newBuilder()
                  .setRowType(StructType.newBuilder()
                          .addFields(StructType.Field.newBuilder()
                                  .setName("option_value")
                                  .setType(Type.newBuilder().setCode(TypeCode.STRING).build())
                                  .build())
                          .build())
                  .build();
  
          @Override
          public void createSession(
                  CreateSessionRequest request, StreamObserver<Session> responseObserver) {
              responseObserver.onNext(Session.newBuilder()
                      .setName(request.getDatabase() + "/sessions/test-session")
                      .setMultiplexed(request.getSession().getMultiplexed())
                      .build());
              responseObserver.onCompleted();
          }
  
          @Override
          public void executeStreamingSql(
                  ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {
              responseObserver.onNext(PartialResultSet.newBuilder()
                      .setMetadata(DIALECT_METADATA)
                      .addValues(Value.newBuilder().setStringValue(DIALECT).build())
                      .build());
              responseObserver.onCompleted();
          }
  
          @Override
          public void executeSql(
                  ExecuteSqlRequest request, StreamObserver<ResultSet> responseObserver) {
              responseObserver.onNext(ResultSet.newBuilder()
                      .setMetadata(DIALECT_METADATA)
                      .addRows(ListValue.newBuilder()
                              .addValues(Value.newBuilder().setStringValue(DIALECT).build())
                              .build())
                      .build());
              responseObserver.onCompleted();
          }
      }
  }
