  package com_google_cloud.google_cloud_spanner;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.google.api.gax.core.CredentialsProvider;
  import com.google.auth.Credentials;
  import com.google.cloud.NoCredentials;
  import com.google.cloud.spanner.connection.ConnectionOptions;
  import java.io.IOException;
  import java.util.concurrent.atomic.AtomicInteger;
  import org.junit.jupiter.api.Test;
  
  public class ClientSideStatementValueConvertersInnerCredentialsProviderConverterTest {
      @Test
      void connectionOptionsCreatesCredentialsProviderFromUriClassName() {
          RecordingCredentialsProvider.reset();
          String propertyName = ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY;
          String previousValue = System.getProperty(propertyName);
          System.setProperty(propertyName, "true");
          try {
              String databaseUri = "cloudspanner:/projects/test-project/instances/test-instance"
                      + "/databases/test-database";
              String uri = databaseUri
                      + "?credentialsProvider="
                      + RecordingCredentialsProvider.class.getName()
                      + ";usePlainText=true;minSessions=0;maxSessions=1;numChannels=1"
                      + ";trackConnectionLeaks=false";
              ConnectionOptions options = ConnectionOptions.newBuilder()
                      .setUri(uri)
                      .build();
  
              assertThat(options.getCredentials())
                      .isSameAs(RecordingCredentialsProvider.credentials());
              assertThat(RecordingCredentialsProvider.constructorCalls()).isGreaterThanOrEqualTo(1);
              assertThat(RecordingCredentialsProvider.credentialsCalls()).isEqualTo(1);
          } finally {
              if (previousValue == null) {
                  System.clearProperty(propertyName);
              } else {
                  System.setProperty(propertyName, previousValue);
              }
              RecordingCredentialsProvider.reset();
          }
      }
  
      public static final class RecordingCredentialsProvider implements CredentialsProvider {
          private static final Credentials CREDENTIALS = NoCredentials.getInstance();
          private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();
          private static final AtomicInteger CREDENTIALS_CALLS = new AtomicInteger();
  
          public RecordingCredentialsProvider() {
              CONSTRUCTOR_CALLS.incrementAndGet();
          }
  
          @Override
          public Credentials getCredentials() throws IOException {
              CREDENTIALS_CALLS.incrementAndGet();
              return CREDENTIALS;
          }
  
          private static Credentials credentials() {
              return CREDENTIALS;
          }
  
          private static int constructorCalls() {
              return CONSTRUCTOR_CALLS.get();
          }
  
          private static int credentialsCalls() {
              return CREDENTIALS_CALLS.get();
          }
  
          private static void reset() {
              CONSTRUCTOR_CALLS.set(0);
              CREDENTIALS_CALLS.set(0);
          }
      }
  }
