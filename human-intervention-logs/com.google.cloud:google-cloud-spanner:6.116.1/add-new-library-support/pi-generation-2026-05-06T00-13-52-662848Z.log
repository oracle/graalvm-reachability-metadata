ecutor implements ClientSideStatementExecutor {\n  private final Method method;\n\n  /**\n   * Creates and compiles the given {@link ClientSideStatementImpl}.\n   *\n   * @param statement The statement to compile.\n   * @throws CompileException If the statement could not be compiled. This should never happen, as\n   *     it would indicate that an invalid statement has been defined in the source file.\n   */\n  ClientSideStatementNoParamExecutor(ClientSideStatementImpl statement) throws CompileException {\n    try {\n      this.method = ConnectionStatementExecutor.class.getDeclaredMethod(statement.getMethodName());\n    } catch (NoSuchMethodException | SecurityException e) {\n      throw new CompileException(e, statement);\n    }\n  }\n\n  @Override\n  public StatementResult execute(ConnectionStatementExecutor connection, ParsedStatement statement)\n      throws Exception {\n    return (StatementResult) method.invoke(connection);\n  }\n}\n"}], "isError": false, "timestamp": 1778026357795}, {"role": "toolResult", "toolCallId": "call_YBjDkBxDnZW0RbjqX8F2UVJR|fc_0b53d7790f88bb830169fa87757ab881a0ba4d25c7bf722d14", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.cloud.spanner.Statement;\nimport com.google.cloud.spanner.connection.Connection;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport com.google.cloud.spanner.connection.StatementResult;\nimport com.google.cloud.spanner.connection.StatementResult.ClientSideStatementType;\nimport com.google.cloud.spanner.connection.StatementResult.ResultType;\nimport com.google.protobuf.ListValue;\nimport com.google.protobuf.Value;\nimport com.google.spanner.v1.CreateSessionRequest;\nimport com.google.spanner.v1.ExecuteSqlRequest;\nimport com.google.spanner.v1.PartialResultSet;\nimport com.google.spanner.v1.ResultSet;\nimport com.google.spanner.v1.ResultSetMetadata;\nimport com.google.spanner.v1.Session;\nimport com.google.spanner.v1.SpannerGrpc;\nimport com.google.spanner.v1.StructType;\nimport com.google.spanner.v1.Type;\nimport com.google.spanner.v1.TypeCode;\nimport io.grpc.Server;\nimport io.grpc.ServerBuilder;\nimport io.grpc.stub.StreamObserver;\nimport java.util.concurrent.TimeUnit;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementBeginExecutorTest {\n    @Test\n    void executeBeginTransactionWithIsolationLevelStartsClientSideTransaction() throws Exception {\n        Server server = ServerBuilder.forPort(0)\n                .addService(new DialectOnlySpanner())\n                .build()\n                .start();\n        try {\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(\"cloudspanner://localhost:\" + server.getPort()\n                            + \"/projects/test-project/instances/test-instance/databases/test-database\"\n                            + \"?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                            + \";trackConnectionLeaks=false\")\n                    .build();\n\n            try (Connection connection = options.getConnection()) {\n                StatementResult result = connection.execute(\n                        Statement.of(\"begin transaction isolation level repeatable read\"));\n\n                assertThat(result.getResultType()).isEqualTo(ResultType.NO_RESULT);\n                assertThat(result.getClientSideStatementType()).isEqualTo(ClientSideStatementType.BEGIN);\n                assertThat(connection.isInTransaction()).isTrue();\n                assertThat(connection.isTransactionStarted()).isFalse();\n            }\n        } finally {\n            server.shutdownNow();\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n\n    private static final class DialectOnlySpanner extends SpannerGrpc.SpannerImplBase {\n        private static final String DIALECT = \"GOOGLE_STANDARD_SQL\";\n        private static final ResultSetMetadata DIALECT_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder()\n                        .addFields(StructType.Field.newBuilder()\n                                .setName(\"option_value\")\n                                .setType(Type.newBuilder().setCode(TypeCode.STRING).build())\n                                .build())\n                        .build())\n                .build();\n\n        @Override\n        public void createSession(\n                CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(Session.newBuilder()\n                    .setName(request.getDatabase() + \"/sessions/test-session\")\n                    .setMultiplexed(request.getSession().getMultiplexed())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            responseObserver.onNext(PartialResultSet.newBuilder()\n                    .setMetadata(DIALECT_METADATA)\n                    .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeSql(\n                ExecuteSqlRequest request, StreamObserver<ResultSet> responseObserver) {\n            responseObserver.onNext(ResultSet.newBuilder()\n                    .setMetadata(DIALECT_METADATA)\n                    .addRows(ListValue.newBuilder()\n                            .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                            .build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778026357796}, {"role": "toolResult", "toolCallId": "call_eCUi1l2tqBHVUj9fkkPLiACc|fc_0b53d7790f88bb830169fa87757ac081a0ba4815ba3c6f8399", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.cloud.spanner.ResultSet;\nimport com.google.cloud.spanner.Statement;\nimport com.google.cloud.spanner.connection.Connection;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport com.google.cloud.spanner.connection.StatementResult;\nimport com.google.cloud.spanner.connection.StatementResult.ResultType;\nimport com.google.protobuf.ListValue;\nimport com.google.protobuf.Timestamp;\nimport com.google.protobuf.Value;\nimport com.google.spanner.v1.CreateSessionRequest;\nimport com.google.spanner.v1.ExecuteSqlRequest;\nimport com.google.spanner.v1.PartialResultSet;\nimport com.google.spanner.v1.PlanNode;\nimport com.google.spanner.v1.QueryPlan;\nimport com.google.spanner.v1.ResultSetMetadata;\nimport com.google.spanner.v1.ResultSetStats;\nimport com.google.spanner.v1.Session;\nimport com.google.spanner.v1.SpannerGrpc;\nimport com.google.spanner.v1.StructType;\nimport com.google.spanner.v1.Transaction;\nimport com.google.spanner.v1.Type;\nimport com.google.spanner.v1.TypeCode;\nimport io.grpc.Server;\nimport io.grpc.ServerBuilder;\nimport io.grpc.stub.StreamObserver;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicReference;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementExplainExecutorTest {\n    @Test\n    void executeExplainStatementReturnsQueryPlan() throws Exception {\n        ExplainSpanner spanner = new ExplainSpanner();\n        Server server = ServerBuilder.forPort(0)\n                .addService(spanner)\n                .build()\n                .start();\n        try {\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(\"cloudspanner://localhost:\" + server.getPort()\n                            + \"/projects/test-project/instances/test-instance/databases/test-database\"\n                            + \"?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                            + \";trackConnectionLeaks=false;dialect=POSTGRESQL\")\n                    .build();\n\n            try (Connection connection = options.getConnection()) {\n                StatementResult result = connection.execute(Statement.of(\"explain select 1\"));\n\n                assertThat(result.getResultType()).isEqualTo(ResultType.RESULT_SET);\n                try (ResultSet resultSet = result.getResultSet()) {\n                    assertThat(resultSet.next()).isTrue();\n                    assertThat(resultSet.getString(\"QUERY PLAN\")).isEqualTo(\"Distributed Union\");\n                    assertThat(resultSet.next()).isFalse();\n                }\n            }\n\n            assertThat(spanner.planSql()).isEqualTo(\"select 1\");\n        } finally {\n            server.shutdownNow();\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n\n    private static final class ExplainSpanner extends SpannerGrpc.SpannerImplBase {\n        private static final String DIALECT = \"POSTGRESQL\";\n        private static final ResultSetMetadata DIALECT_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder()\n                        .addFields(StructType.Field.newBuilder()\n                                .setName(\"option_value\")\n                                .setType(Type.newBuilder().setCode(TypeCode.STRING).build())\n                                .build())\n                        .build())\n                .build();\n        private static final ResultSetMetadata PLAN_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder().build())\n                .setTransaction(Transaction.newBuilder()\n                        .setReadTimestamp(Timestamp.newBuilder().setSeconds(1).build())\n                        .build())\n                .build();\n        private static final ResultSetStats QUERY_PLAN_STATS = ResultSetStats.newBuilder()\n                .setQueryPlan(QueryPlan.newBuilder()\n                        .addPlanNodes(PlanNode.newBuilder()\n                                .setIndex(0)\n                                .setDisplayName(\"Distributed Union\")\n                                .build())\n                        .build())\n                .build();\n\n        private final AtomicReference<String> planSql = new AtomicReference<>();\n\n        @Override\n        public void createSession(\n                CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(Session.newBuilder()\n                    .setName(request.getDatabase() + \"/sessions/test-session\")\n                    .setMultiplexed(request.getSession().getMultiplexed())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            if (request.getQueryMode() == ExecuteSqlRequest.QueryMode.PLAN) {\n                planSql.set(request.getSql());\n                responseObserver.onNext(PartialResultSet.newBuilder()\n                        .setMetadata(PLAN_METADATA)\n                        .setStats(QUERY_PLAN_STATS)\n                        .build());\n            } else {\n                responseObserver.onNext(PartialResultSet.newBuilder()\n                        .setMetadata(DIALECT_METADATA)\n                        .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                        .build());\n            }\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeSql(\n                ExecuteSqlRequest request,\n                StreamObserver<com.google.spanner.v1.ResultSet> responseObserver) {\n            responseObserver.onNext(com.google.spanner.v1.ResultSet.newBuilder()\n                    .setMetadata(DIALECT_METADATA)\n                    .addRows(ListValue.newBuilder()\n                            .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                            .build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        private String planSql() {\n            return planSql.get();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778026357796}, {"role": "toolResult", "toolCallId": "call_FYopTRUnRk29QT5YlhfK9jVc|fc_0b53d7790f88bb830169fa87757ac881a08885eccb7445a1f7", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.api.gax.rpc.TransportChannel;\nimport com.google.api.gax.rpc.TransportChannelProvider;\nimport com.google.auth.Credentials;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport java.io.IOException;\nimport java.util.Map;\nimport java.util.concurrent.Executor;\nimport java.util.concurrent.ScheduledExecutorService;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicReference;\nimport org.junit.jupiter.api.Test;\n\npublic class ConnectionOptionsTest {\n    @Test\n    void getChannelProviderCreatesExternalProviderFromUriClassName() {\n        RecordingExternalChannelProvider.reset();\n        String propertyName = ConnectionOptions.ENABLE_CHANNEL_PROVIDER_SYSTEM_PROPERTY;\n        String previousValue = System.getProperty(propertyName);\n        System.setProperty(propertyName, \"true\");\n        try {\n            String databaseUri = \"cloudspanner:/projects/test-project/instances/test-instance\"\n                    + \"/databases/test-database\";\n            String uri = databaseUri\n                    + \"?channelProvider=\"\n                    + RecordingExternalChannelProvider.class.getName()\n                    + \";usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                    + \";trackConnectionLeaks=false\";\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(uri)\n                    .build();\n\n            TransportChannelProvider channelProvider = options.getChannelProvider();\n\n            assertThat(channelProvider)\n                    .isSameAs(RecordingExternalChannelProvider.channelProvider());\n            assertThat(RecordingExternalChannelProvider.constructorCalls()).isEqualTo(1);\n            assertThat(RecordingExternalChannelProvider.channelProviderCalls()).isEqualTo(1);\n            assertThat(RecordingExternalChannelProvider.host()).isNotBlank();\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(propertyName);\n            } else {\n                System.setProperty(propertyName, previousValue);\n            }\n            RecordingExternalChannelProvider.reset();\n        }\n    }\n\n    public static final class RecordingExternalChannelProvider\n            implements ConnectionOptions.ExternalChannelProvider {\n        private static final TransportChannelProvider CHANNEL_PROVIDER =\n                new RecordingTransportChannelProvider();\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\n        private static final AtomicInteger CHANNEL_PROVIDER_CALLS = new AtomicInteger();\n        private static final AtomicReference<String> HOST = new AtomicReference<>();\n\n        public RecordingExternalChannelProvider() {\n            CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public TransportChannelProvider getChannelProvider(String host, int port) {\n            CHANNEL_PROVIDER_CALLS.incrementAndGet();\n            HOST.set(host);\n            return CHANNEL_PROVIDER;\n        }\n\n        private static TransportChannelProvider channelProvider() {\n            return CHANNEL_PROVIDER;\n        }\n\n        private static int constructorCalls() {\n            return CONSTRUCTOR_CALLS.get();\n        }\n\n        private static int channelProviderCalls() {\n            return CHANNEL_PROVIDER_CALLS.get();\n        }\n\n        private static String host() {\n            return HOST.get();\n        }\n\n        private static void reset() {\n            CONSTRUCTOR_CALLS.set(0);\n            CHANNEL_PROVIDER_CALLS.set(0);\n            HOST.set(null);\n        }\n    }\n\n    public static final class RecordingTransportChannelProvider\n            implements TransportChannelProvider {\n        @Override\n        public TransportChannel getTransportChannel() throws IOException {\n            throw new UnsupportedOperationException(\"The test only verifies provider creation\");\n        }\n\n        @Override\n        public String getTransportName() {\n            return \"recording\";\n        }\n\n        @Override\n        public boolean needsEndpoint() {\n            return false;\n        }\n\n        @Override\n        public boolean needsCredentials() {\n            return false;\n        }\n\n        @Override\n        public boolean needsExecutor() {\n            return false;\n        }\n\n        @Override\n        public boolean needsHeaders() {\n            return false;\n        }\n\n        @Override\n        public boolean shouldAutoClose() {\n            return false;\n        }\n\n        @Override\n        public TransportChannelProvider withEndpoint(String endpoint) {\n            return this;\n        }\n\n        @Override\n        public TransportChannelProvider withCredentials(Credentials credentials) {\n            return this;\n        }\n\n        @Override\n        public TransportChannelProvider withHeaders(Map<String, String> headers) {\n            return this;\n        }\n\n        @Override\n        public TransportChannelProvider withPoolSize(int poolSize) {\n            return this;\n        }\n\n        @Override\n        public TransportChannelProvider withExecutor(ScheduledExecutorService executor) {\n            return this;\n        }\n\n        @Override\n        public TransportChannelProvider withExecutor(Executor executor) {\n            return this;\n        }\n\n        @Override\n        public boolean acceptsPoolSize() {\n            return false;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778026357797}]}
