  public class ClientSideStatementBeginExecutorTest {
      @Test
      void executeBeginTransactionWithIsolationLevelStartsClientSideTransaction() throws Exception {
          Server server = ServerBuilder.forPort(0)
                  .addService(new DialectOnlySpanner())
                  .build()
                  .start();
          try {
              ConnectionOptions options = ConnectionOptions.newBuilder()
