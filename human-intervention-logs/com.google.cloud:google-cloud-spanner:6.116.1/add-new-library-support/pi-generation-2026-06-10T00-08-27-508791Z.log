ions(\n                BatchCreateSessionsRequest request,\n                StreamObserver<BatchCreateSessionsResponse> responseObserver) {\n            responseObserver.onNext(\n                    BatchCreateSessionsResponse.newBuilder()\n                            .addSession(session(request.getDatabase() + \"/sessions/test-session\"))\n                            .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            responseObserver.onNext(\n                    PartialResultSet.newBuilder()\n                            .setMetadata(\n                                    ResultSetMetadata.newBuilder()\n                                            .setRowType(\n                                                    StructType.newBuilder()\n                                                            .addFields(\n                                                                    StructType.Field.newBuilder()\n                                                                            .setName(\"option_value\")\n                                                                            .setType(stringType()))))\n                            .setChunkedValue(false)\n                            .addValues(Value.newBuilder().setStringValue(\"GOOGLE_STANDARD_SQL\"))\n                            .setResumeToken(ByteString.EMPTY)\n                            .build());\n            responseObserver.onCompleted();\n        }\n\n        private static Type stringType() {\n            return Type.newBuilder().setCode(TypeCode.STRING).build();\n        }\n\n        private static Session session(String name) {\n            return Session.newBuilder().setName(name).build();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781050037071}}
