1778024536198}, {"role": "toolResult", "toolCallId": "call_JIi5PZeJRsGu3jVEjnvxz4NR|fc_073c674d53aedf3a0169fa8057ce54819797eab923cc0720d1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.api.gax.grpc.GrpcInterceptorProvider;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport io.grpc.ClientInterceptor;\nimport java.util.Collections;\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementValueConvertersInnerGrpcInterceptorProviderConverterTest {\n    @Test\n    void connectionOptionsCreatesGrpcInterceptorProviderFromUriClassName() {\n        RecordingGrpcInterceptorProvider.reset();\n        String propertyName = ConnectionOptions.ENABLE_GRPC_INTERCEPTOR_PROVIDER_SYSTEM_PROPERTY;\n        String previousValue = System.getProperty(propertyName);\n        System.setProperty(propertyName, \"true\");\n        try {\n            String databaseUri = \"cloudspanner:/projects/test-project/instances/test-instance\"\n                    + \"/databases/test-database\";\n            String uri = databaseUri\n                    + \"?grpc_interceptor_provider=\"\n                    + RecordingGrpcInterceptorProvider.class.getName()\n                    + \";usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                    + \";trackConnectionLeaks=false\";\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(uri)\n                    .build();\n\n            GrpcInterceptorProvider provider = options.getGrpcInterceptorProvider();\n\n            assertThat(provider).isInstanceOf(RecordingGrpcInterceptorProvider.class);\n            assertThat(provider.getInterceptors()).isEmpty();\n            assertThat(RecordingGrpcInterceptorProvider.constructorCalls()).isEqualTo(1);\n            assertThat(RecordingGrpcInterceptorProvider.interceptorsCalls()).isEqualTo(1);\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(propertyName);\n            } else {\n                System.setProperty(propertyName, previousValue);\n            }\n            RecordingGrpcInterceptorProvider.reset();\n        }\n    }\n\n    public static final class RecordingGrpcInterceptorProvider implements GrpcInterceptorProvider {\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\n        private static final AtomicInteger INTERCEPTORS_CALLS = new AtomicInteger();\n\n        public RecordingGrpcInterceptorProvider() {\n            CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public List<ClientInterceptor> getInterceptors() {\n            INTERCEPTORS_CALLS.incrementAndGet();\n            return Collections.emptyList();\n        }\n\n        private static int constructorCalls() {\n            return CONSTRUCTOR_CALLS.get();\n        }\n\n        private static int interceptorsCalls() {\n            return INTERCEPTORS_CALLS.get();\n        }\n\n        private static void reset() {\n            CONSTRUCTOR_CALLS.set(0);\n            INTERCEPTORS_CALLS.set(0);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778024536198}, {"role": "toolResult", "toolCallId": "call_V71eeKlTdamR7IjMvnqUIsI6|fc_073c674d53aedf3a0169fa8057ce5c8197afa726c76628f8ad", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.api.gax.core.CredentialsProvider;\nimport com.google.auth.Credentials;\nimport com.google.cloud.NoCredentials;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport java.io.IOException;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementValueConvertersInnerCredentialsProviderConverterTest {\n    @Test\n    void connectionOptionsCreatesCredentialsProviderFromUriClassName() {\n        RecordingCredentialsProvider.reset();\n        String propertyName = ConnectionOptions.ENABLE_CREDENTIALS_PROVIDER_SYSTEM_PROPERTY;\n        String previousValue = System.getProperty(propertyName);\n        System.setProperty(propertyName, \"true\");\n        try {\n            String databaseUri = \"cloudspanner:/projects/test-project/instances/test-instance\"\n                    + \"/databases/test-database\";\n            String uri = databaseUri\n                    + \"?credentialsProvider=\"\n                    + RecordingCredentialsProvider.class.getName()\n                    + \";usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                    + \";trackConnectionLeaks=false\";\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(uri)\n                    .build();\n\n            assertThat(options.getCredentials())\n                    .isSameAs(RecordingCredentialsProvider.credentials());\n            assertThat(RecordingCredentialsProvider.constructorCalls()).isGreaterThanOrEqualTo(1);\n            assertThat(RecordingCredentialsProvider.credentialsCalls()).isEqualTo(1);\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(propertyName);\n            } else {\n                System.setProperty(propertyName, previousValue);\n            }\n            RecordingCredentialsProvider.reset();\n        }\n    }\n\n    public static final class RecordingCredentialsProvider implements CredentialsProvider {\n        private static final Credentials CREDENTIALS = NoCredentials.getInstance();\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\n        private static final AtomicInteger CREDENTIALS_CALLS = new AtomicInteger();\n\n        public RecordingCredentialsProvider() {\n            CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public Credentials getCredentials() throws IOException {\n            CREDENTIALS_CALLS.incrementAndGet();\n            return CREDENTIALS;\n        }\n\n        private static Credentials credentials() {\n            return CREDENTIALS;\n        }\n\n        private static int constructorCalls() {\n            return CONSTRUCTOR_CALLS.get();\n        }\n\n        private static int credentialsCalls() {\n            return CREDENTIALS_CALLS.get();\n        }\n\n        private static void reset() {\n            CONSTRUCTOR_CALLS.set(0);\n            CREDENTIALS_CALLS.set(0);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778024536199}]}
