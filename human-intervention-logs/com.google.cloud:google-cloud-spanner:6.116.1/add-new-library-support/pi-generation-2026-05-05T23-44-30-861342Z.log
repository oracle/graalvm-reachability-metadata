oj67Gtc6|fc_073c674d53aedf3a0169fa809288908197a3487bcf7afad262", "name": "write", "arguments": {"path": "tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ConnectionOptionsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.api.gax.grpc.InstantiatingGrpcChannelProvider;\nimport com.google.api.gax.rpc.TransportChannelProvider;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicReference;\nimport org.junit.jupiter.api.Test;\n\npublic class ConnectionOptionsTest {\n    @Test\n    void getChannelProviderCreatesExternalProviderFromUriClassName() {\n        RecordingExternalChannelProvider.reset();\n        String propertyName = ConnectionOptions.ENABLE_CHANNEL_PROVIDER_SYSTEM_PROPERTY;\n        String previousValue = System.getProperty(propertyName);\n        System.setProperty(propertyName, \"true\");\n        try {\n            String databaseUri = \"cloudspanner:/projects/test-project/instances/test-instance\"\n                    + \"/databases/test-database\";\n            String uri = databaseUri\n                    + \"?channelProvider=\"\n                    + RecordingExternalChannelProvider.class.getName()\n                    + \";usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                    + \";trackConnectionLeaks=false\";\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(uri)\n                    .build();\n\n            TransportChannelProvider channelProvider = options.getChannelProvider();\n\n            assertThat(channelProvider).isSameAs(RecordingExternalChannelProvider.channelProvider());\n            assertThat(RecordingExternalChannelProvider.constructorCalls()).isEqualTo(1);\n            assertThat(RecordingExternalChannelProvider.channelProviderCalls()).isEqualTo(1);\n            assertThat(RecordingExternalChannelProvider.host()).isNotBlank();\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(propertyName);\n            } else {\n                System.setProperty(propertyName, previousValue);\n            }\n            RecordingExternalChannelProvider.reset();\n        }\n    }\n\n    public static final class RecordingExternalChannelProvider\n            implements ConnectionOptions.ExternalChannelProvider {\n        private static final TransportChannelProvider CHANNEL_PROVIDER =\n                InstantiatingGrpcChannelProvider.newBuilder()\n                        .setEndpoint(\"localhost:9010\")\n                        .build();\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\n        private static final AtomicInteger CHANNEL_PROVIDER_CALLS = new AtomicInteger();\n        private static final AtomicReference<String> HOST = new AtomicReference<>();\n        private static final AtomicInteger PORT = new AtomicInteger();\n\n        public RecordingExternalChannelProvider() {\n            CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public TransportChannelProvider getChannelProvider(String host, int port) {\n            CHANNEL_PROVIDER_CALLS.incrementAndGet();\n            HOST.set(host);\n            PORT.set(port);\n            return CHANNEL_PROVIDER;\n        }\n\n        private static TransportChannelProvider channelProvider() {\n            return CHANNEL_PROVIDER;\n        }\n\n        private static int constructorCalls() {\n            return CONSTRUCTOR_CALLS.get();\n        }\n\n        private static int channelProviderCalls() {\n            return CHANNEL_PROVIDER_CALLS.get();\n        }\n\n        private static String host() {\n            return HOST.get();\n        }\n\n        private static void reset() {\n            CONSTRUCTOR_CALLS.set(0);\n            CHANNEL_PROVIDER_CALLS.set(0);\n            HOST.set(null);\n            PORT.set(0);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ConnectionOptionsTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_google_cloud.google_cloud_spanner;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport com.google.api.gax.grpc.InstantiatingGrpcChannelProvider;\\nimport com.google.api.gax.rpc.TransportChannelProvider;\\nimport com.google.cloud.spanner.connection.ConnectionOptions;\\nimport java.util.concurrent.atomic.AtomicInteger;\\nimport java.util.concurrent.atomic.AtomicReference;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class ConnectionOptionsTest {\\n    @Test\\n    void getChannelProviderCreatesExternalProviderFromUriClassName() {\\n        RecordingExternalChannelProvider.reset();\\n        String propertyName = ConnectionOptions.ENABLE_CHANNEL_PROVIDER_SYSTEM_PROPERTY;\\n        String previousValue = System.getProperty(propertyName);\\n        System.setProperty(propertyName, \\\"true\\\");\\n        try {\\n            String databaseUri = \\\"cloudspanner:/projects/test-project/instances/test-instance\\\"\\n                    + \\\"/databases/test-database\\\";\\n            String uri = databaseUri\\n                    + \\\"?channelProvider=\\\"\\n                    + RecordingExternalChannelProvider.class.getName()\\n                    + \\\";usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\\\"\\n                    + \\\";trackConnectionLeaks=false\\\";\\n            ConnectionOptions options = ConnectionOptions.newBuilder()\\n                    .setUri(uri)\\n                    .build();\\n\\n            TransportChannelProvider channelProvider = options.getChannelProvider();\\n\\n            assertThat(channelProvider).isSameAs(RecordingExternalChannelProvider.channelProvider());\\n            assertThat(RecordingExternalChannelProvider.constructorCalls()).isEqualTo(1);\\n            assertThat(RecordingExternalChannelProvider.channelProviderCalls()).isEqualTo(1);\\n            assertThat(RecordingExternalChannelProvider.host()).isNotBlank();\\n        } finally {\\n            if (previousValue == null) {\\n                System.clearProperty(propertyName);\\n            } else {\\n                System.setProperty(propertyName, previousValue);\\n            }\\n            RecordingExternalChannelProvider.reset();\\n        }\\n    }\\n\\n    public static final class RecordingExternalChannelProvider\\n            implements ConnectionOptions.ExternalChannelProvider {\\n        private static final TransportChannelProvider CHANNEL_PROVIDER =\\n                InstantiatingGrpcChannelProvider.newBuilder()\\n                        .setEndpoint(\\\"localhost:9010\\\")\\n                        .build();\\n        private static final AtomicInteger CONSTRUCTOR_CALLS = new AtomicInteger();\\n        private static final AtomicInteger CHANNEL_PROVIDER_CALLS = new AtomicInteger();\\n        private static final AtomicReference<String> HOST = new AtomicReference<>();\\n        private static final AtomicInteger PORT = new AtomicInteger();\\n\\n        public RecordingExternalChannelProvider() {\\n            CONSTRUCTOR_CALLS.incrementAndGet();\\n        }\\n\\n        @Override\\n        public TransportChannelProvider getChannelProvider(String host, int port) {\\n            CHANNEL_PROVIDER_CALLS.incrementAndGet();\\n            HOST.set(host);\\n            PORT.set(port);\\n            return CHANNEL_PROVIDER;\\n        }\\n\\n        private static TransportChannelProvider channelProvider() {\\n            return CHANNEL_PROVIDER;\\n        }\\n\\n        private static int constructorCalls() {\\n            return CONSTRUCTOR_CALLS.get();\\n        }\\n\\n        private static int channelProviderCalls() {\\n            return CHANNEL_PROVIDER_CALLS.get();\\n        }\\n\\n        private static String host() {\\n            return HOST.get();\\n        }\\n\\n        private static void reset() {\\n            CONSTRUCTOR_CALLS.set(0);\\n            CHANNEL_PROVIDER_CALLS.set(0);\\n            HOST.set(null);\\n            PORT.set(0);\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 517, "output": 1275, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 24320, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778024587433, "responseId": "resp_073c674d53aedf3a0169fa808c1f7881979dcbccdb08fc7d5e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_X60E0EqZ9slWvmFnoj67Gtc6|fc_073c674d53aedf3a0169fa809288908197a3487bcf7afad262", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3977 bytes to tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ConnectionOptionsTest.java"}], "isError": false, "timestamp": 1778024598930}]}
