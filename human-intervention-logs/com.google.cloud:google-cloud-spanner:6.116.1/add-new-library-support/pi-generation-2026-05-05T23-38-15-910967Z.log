uilder.forPort(0)\n                .addService(spanner)\n                .build()\n                .start();\n        try {\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(\"cloudspanner://localhost:\" + server.getPort()\n                            + \"/projects/test-project/instances/test-instance/databases/test-database\"\n                            + \"?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                            + \";trackConnectionLeaks=false;dialect=POSTGRESQL\")\n                    .build();\n\n            try (Connection connection = options.getConnection()) {\n                StatementResult result = connection.execute(Statement.of(\"explain select 1\"));\n\n                assertThat(result.getResultType()).isEqualTo(ResultType.RESULT_SET);\n                try (ResultSet resultSet = result.getResultSet()) {\n                    assertThat(resultSet.next()).isTrue();\n                    assertThat(resultSet.getString(\"QUERY PLAN\")).isEqualTo(\"Distributed Union\");\n                    assertThat(resultSet.next()).isFalse();\n                }\n            }\n\n            assertThat(spanner.planSql()).isEqualTo(\"select 1\");\n        } finally {\n            server.shutdownNow();\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n\n    private static final class ExplainSpanner extends SpannerGrpc.SpannerImplBase {\n        private static final String DIALECT = \"POSTGRESQL\";\n        private static final ResultSetMetadata DIALECT_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder()\n                        .addFields(StructType.Field.newBuilder()\n                                .setName(\"option_value\")\n                                .setType(Type.newBuilder().setCode(TypeCode.STRING).build())\n                                .build())\n                        .build())\n                .build();\n        private static final ResultSetMetadata EMPTY_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder().build())\n                .build();\n        private static final ResultSetStats QUERY_PLAN_STATS = ResultSetStats.newBuilder()\n                .setQueryPlan(QueryPlan.newBuilder()\n                        .addPlanNodes(PlanNode.newBuilder()\n                                .setIndex(0)\n                                .setDisplayName(\"Distributed Union\")\n                                .build())\n                        .build())\n                .build();\n\n        private final AtomicReference<String> planSql = new AtomicReference<>();\n\n        @Override\n        public void createSession(\n                CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(Session.newBuilder()\n                    .setName(request.getDatabase() + \"/sessions/test-session\")\n                    .setMultiplexed(request.getSession().getMultiplexed())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            if (request.getQueryMode() == ExecuteSqlRequest.QueryMode.PLAN) {\n                planSql.set(request.getSql());\n                responseObserver.onNext(PartialResultSet.newBuilder()\n                        .setMetadata(EMPTY_METADATA)\n                        .setStats(QUERY_PLAN_STATS)\n                        .build());\n            } else {\n                responseObserver.onNext(PartialResultSet.newBuilder()\n                        .setMetadata(DIALECT_METADATA)\n                        .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                        .build());\n            }\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeSql(\n                ExecuteSqlRequest request,\n                StreamObserver<com.google.spanner.v1.ResultSet> responseObserver) {\n            responseObserver.onNext(com.google.spanner.v1.ResultSet.newBuilder()\n                    .setMetadata(DIALECT_METADATA)\n                    .addRows(ListValue.newBuilder()\n                            .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                            .build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        private String planSql() {\n            return planSql.get();\n        }\n    }\n}\n"}
