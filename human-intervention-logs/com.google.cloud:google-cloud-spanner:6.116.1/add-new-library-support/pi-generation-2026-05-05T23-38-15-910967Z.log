J imported, and I definitely need to create a file.\"}]}"}, {"type": "toolCall", "id": "call_yxtUqRAs8jboRcD49C3T764q|fc_0cba842c336de4260169fa7f471fc8819e8f89f9ec28f1e762", "name": "write", "arguments": {"path": "tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ClientSideStatementExplainExecutorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_cloud.google_cloud_spanner;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.cloud.spanner.ResultSet;\nimport com.google.cloud.spanner.Statement;\nimport com.google.cloud.spanner.connection.Connection;\nimport com.google.cloud.spanner.connection.ConnectionOptions;\nimport com.google.cloud.spanner.connection.StatementResult;\nimport com.google.cloud.spanner.connection.StatementResult.ResultType;\nimport com.google.protobuf.ListValue;\nimport com.google.protobuf.Value;\nimport com.google.spanner.v1.CreateSessionRequest;\nimport com.google.spanner.v1.ExecuteSqlRequest;\nimport com.google.spanner.v1.PartialResultSet;\nimport com.google.spanner.v1.PlanNode;\nimport com.google.spanner.v1.QueryPlan;\nimport com.google.spanner.v1.ResultSetMetadata;\nimport com.google.spanner.v1.ResultSetStats;\nimport com.google.spanner.v1.Session;\nimport com.google.spanner.v1.SpannerGrpc;\nimport com.google.spanner.v1.StructType;\nimport com.google.spanner.v1.Type;\nimport com.google.spanner.v1.TypeCode;\nimport io.grpc.Server;\nimport io.grpc.ServerBuilder;\nimport io.grpc.stub.StreamObserver;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicReference;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementExplainExecutorTest {\n    @Test\n    void executeExplainStatementReturnsQueryPlan() throws Exception {\n        ExplainSpanner spanner = new ExplainSpanner();\n        Server server = ServerBuilder.forPort(0)\n                .addService(spanner)\n                .build()\n                .start();\n        try {\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(\"cloudspanner://localhost:\" + server.getPort()\n                            + \"/projects/test-project/instances/test-instance/databases/test-database\"\n                            + \"?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                            + \";trackConnectionLeaks=false;dialect=POSTGRESQL\")\n                    .build();\n\n            try (Connection connection = options.getConnection()) {\n                StatementResult result = connection.execute(Statement.of(\"explain select 1\"));\n\n                assertThat(result.getResultType()).isEqualTo(ResultType.RESULT_SET);\n                try (ResultSet resultSet = result.getResultSet()) {\n                    assertThat(resultSet.next()).isTrue();\n                    assertThat(resultSet.getString(\"QUERY PLAN\")).isEqualTo(\"Distributed Union\");\n                    assertThat(resultSet.next()).isFalse();\n                }\n            }\n\n            assertThat(spanner.planSql()).isEqualTo(\"select 1\");\n        } finally {\n            server.shutdownNow();\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n\n    private static final class ExplainSpanner extends SpannerGrpc.SpannerImplBase {\n        private static final String DIALECT = \"POSTGRESQL\";\n        private static final ResultSetMetadata DIALECT_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder()\n                        .addFields(StructType.Field.newBuilder()\n                                .setName(\"option_value\")\n                                .setType(Type.newBuilder().setCode(TypeCode.STRING).build())\n                                .build())\n                        .build())\n                .build();\n        private static final ResultSetMetadata EMPTY_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder().build())\n                .build();\n        private static final ResultSetStats QUERY_PLAN_STATS = ResultSetStats.newBuilder()\n                .setQueryPlan(QueryPlan.newBuilder()\n                        .addPlanNodes(PlanNode.newBuilder()\n                                .setIndex(0)\n                                .setDisplayName(\"Distributed Union\")\n                                .build())\n                        .build())\n                .build();\n\n        private final AtomicReference<String> planSql = new AtomicReference<>();\n\n        @Override\n        public void createSession(\n                CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(Session.newBuilder()\n                    .setName(request.getDatabase() + \"/sessions/test-session\")\n                    .setMultiplexed(request.getSession().getMultiplexed())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            if (request.getQueryMode() == ExecuteSqlRequest.QueryMode.PLAN) {\n                planSql.set(request.getSql());\n                responseObserver.onNext(PartialResultSet.newBuilder()\n                        .setMetadata(EMPTY_METADATA)\n                        .setStats(QUERY_PLAN_STATS)\n                        .build());\n            } else {\n                responseObserver.onNext(PartialResultSet.newBuilder()\n                        .setMetadata(DIALECT_METADATA)\n                        .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                        .build());\n            }\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeSql(\n                ExecuteSqlRequest request,\n                StreamObserver<com.google.spanner.v1.ResultSet> responseObserver) {\n            responseObserver.onNext(com.google.spanner.v1.ResultSet.newBuilder()\n                    .setMetadata(DIALECT_METADATA)\n                    .addRows(ListValue.newBuilder()\n                            .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                            .build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        private String planSql() {\n            return planSql.get();\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ClientSideStatementExplainExecutorTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_google_cloud.google_cloud_spanner;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport com.google.cloud.spanner.ResultSet;\\nimport com.google.cloud.spanner.Statement;\\nimport com.google.cloud.spanner.connection.Connection;\\nimport com.google.cloud.spanner.connection.ConnectionOptions;\\nimport com.google.cloud.spanner.connection.StatementResult;\\nimport com.google.cloud.spanner.connection.StatementResult.ResultType;\\nimport com.google.protobuf.ListValue;\\nimport com.google.protobuf.Value;\\nimport com.google.spanner.v1.CreateSessionRequest;\\nimport com.google.spanner.v1.ExecuteSqlRequest;\\nimport com.google.spanner.v1.PartialResultSet;\\nimport com.google.spanner.v1.PlanNode;\\nimport com.google.spanner.v1.QueryPlan;\\nimport com.google.spanner.v1.ResultSetMetadata;\\nimport com.google.spanner.v1.ResultSetStats;\\nimport com.google.spanner.v1.Session;\\nimport com.google.spanner.v1.SpannerGrpc;\\nimport com.google.spanner.v1.StructType;\\nimport com.google.spanner.v1.Type;\\nimport com.google.spanner.v1.TypeCode;\\nimport io.grpc.Server;\\nimport io.grpc.ServerBuilder;\\nimport io.grpc.stub.StreamObserver;\\nimport java.util.concurrent.TimeUnit;\\nimport java.util.concurrent.atomic.AtomicReference;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class ClientSideStatementExplainExecutorTest {\\n    @Test\\n    void executeExplainStatementReturnsQueryPlan() throws Exception {\\n        ExplainSpanner spanner = new ExplainSpanner();\\n        Server server = ServerBuilder.forPort(0)\\n                .addService(spanner)\\n                .build()\\n                .start();\\n        try {\\n            ConnectionOptions options = ConnectionOptions.newBuilder()\\n                    .setUri(\\\"cloudspanner://localhost:\\\" + server.getPort()\\n                            + \\\"/projects/test-project/instances/test-instance/databases/test-database\\\"\\n                            + \\\"?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\\\"\\n                            + \\\";trackConnectionLeaks=false;dialect=POSTGRESQL\\\")\\n                    .build();\\n\\n            try (Connection connection = options.getConnection()) {\\n                StatementResult result = connection.execute(Statement.of(\\\"explain select 1\\\"));\\n\\n                assertThat(result.getResultType()).isEqualTo(ResultType.RESULT_SET);\\n                try (ResultSet resultSet = result.getResultSet()) {\\n                    assertThat(resultSet.next()).isTrue();\\n                    assertThat(resultSet.getString(\\\"QUERY PLAN\\\")).isEqualTo(\\\"Distributed Union\\\");\\n                    assertThat(resultSet.next()).isFalse();\\n                }\\n            }\\n\\n            assertThat(spanner.planSq