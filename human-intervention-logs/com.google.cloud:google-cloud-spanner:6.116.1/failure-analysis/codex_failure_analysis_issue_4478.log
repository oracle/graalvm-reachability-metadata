d via CC0\\\\n *\\\\n * You should have received a copy of the CC0 legalcode along with this\\\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\\\n */\\\\npackage com_google_cloud.google_cloud_spanner;\\\\n\\\\nimport static org.assertj.core.api.Assertions.assertThat;\\\\n\\\\nimport com.google.cloud.spanner.Statement;\\\\nimport com.google.cloud.spanner.connection.Connection;\\\\nimport com.google.cloud.spanner.connection.ConnectionOptions;\\\\nimport com.google.cloud.spanner.connection.SpannerPool;\\\\nimport com.google.cloud.spanner.connection.StatementResult;\\\\nimport com.google.protobuf.Empty;\\\\nimport com.google.protobuf.Value;\\\\nimport com.google.spanner.v1.CreateSessionRequest;\\\\nimport com.google.spanner.v1.DeleteSessionRequest;\\\\nimport com.google.spanner.v1.ExecuteSqlRequest;\\\\nimport com.google.spanner.v1.PartialResultSet;\\\\nimport com.google.spanner.v1.ResultSetMetadata;\\\\nimport com.google.spanner.v1.Session;\\\\nimport com.google.spanner.v1.SpannerGrpc;\\\\nimport com.google.spanner.v1.StructType;\\\\nimport com.google.spanner.v1.Type;\\\\nimport com.google.spanner.v1.TypeCode;\\\\nimport io.grpc.Server;\\\\nimport io.grpc.ServerBuilder;\\\\nimport io.grpc.Status;\\\\nimport io.grpc.stub.StreamObserver;\\\\nimport java.util.concurrent.TimeUnit;\\\\nimport org.junit.jupiter.api.Test;\\\\n\\\\npublic class ClientSideStatementSetExecutorTest {\\\\n    @Test\\\\n    void executesSetStatementsWithOneAndTwoExecutorParameters() throws Exception {\\\\n        Server server = ServerBuilder.forPort(0).addService(new DialectSpannerService()).build().start();\\\\n        try {\\\\n            ConnectionOptions options =\\\\n                    ConnectionOptions.newBuilder()\\\\n                            .setUri(\\\\n                                    String.format(\\\\n                                            \\\\\\\"cloudspanner://localhost:%d/projects/p/instances/i/databases/d\\\\\\\"\\\\n                                                    + \\\\\\\"?usePlainText=true;trackConnectionLeaks=false;trackSessionLeaks=false\\\\\\\"\\\\n                                                    + \\\\\\\";numChannels=1;minSessions=0;maxSessions=1\\\\\\\",\\\\n                                            server.getPort()))\\\\n                            .build();\\\\n\\\\n            try (Connection connection = options.getConnection()) {\\\\n                assertNoResult(\\\\n                        connection.execute(Statement.of(\\\\\\\"set autocommit = false\\\\\\\")),\\\\n                        StatementResult.ClientSideStatementType.SET_AUTOCOMMIT);\\\\n                assertThat(connection.isAutocommit()).isFalse();\\\\n\\\\n                assertNoResult(\\\\n                        connection.execute(Statement.of(\\\\\\\"set retry_aborts_internally = false\\\\\\\")),\\\\n                        StatementResult.ClientSideStatementType.SET_RETRY_ABORTS_INTERNALLY);\\\\n                assertThat(connection.isRetryAbortsInternally()).isFalse();\\\\n            } finally {\\\\n                SpannerPool.closeSpannerPool();\\\\n            }\\\\n        } finally {\\\\n            server.shutdownNow();\\\\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\\\\n        }\\\\n    }\\\\n\\\\n    private static void assertNoResult(\\\\n            StatementResult result, StatementResult.ClientSideStatementType statementType) {\\\\n        assertThat(result.getResultType()).isEqualTo(StatementResult.ResultType.NO_RESULT);\\\\n        assertThat(result.getClientSideStatementType()).isEqualTo(statementType);\\\\n    }\\\\n\\\\n    private static final class DialectSpannerService extends SpannerGrpc.SpannerImplBase {\\\\n        private static final String DIALECT_SQL_PREFIX = \\\\\\\"select option_value from information_schema.database_options\\\\\\\";\\\\n\\\\n        @Override\\\\n        public void createSession(CreateSessionRequest request, StreamObserver<Session> responseObserver) {\\\\n            responseObserver.onNext(\\\\n                    Session.newBuilder()\\\\n                            .setName(request.getDatabase() + \\\\\\\"/sessions/test-session\\\\\\\")\\\\n                            .setMultiplexed(true)\\\\n                            .build());\\\\n            responseObserver.onCompleted();\\\\n        }\\\\n\\\\n        @Override\\\\n        public void deleteSession(DeleteSessionRequest request, StreamObserver<Empty> responseObserver) {\\\\n            responseObserver.onNext(Empty.getDefaultInstance());\\\\n            responseObserver.onCompleted();\\\\n        }\\\\n\\\\n        @Override\\\\n        public void executeStreamingSql(\\\\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\\\\n            if (!request.getSql().toLowerCase().startsWith(DIALECT_SQL_PREFIX)) {\\\\n                responseObserver.onError(\\\\n                        Status.UNIMPLEMENTED\\\\n                                .withDescription(\\\\\\\"Unexpected SQL: \\\\\\\" + request.getSql())\\\\n                                .asRuntimeException());\\\\n                return;\\\\n            }\\\\n            responseObserver.onNext(\\\\n                    PartialResultSet.newBuilder()\\\\n                            .setMetadata(\\\\n                                    ResultSetMetadata.newBuilder()\\\\n                                            .setRowType(\\\\n                                                    StructType.newBuilder()\\\\n                                                            .addFields(\\\\n                                                                    StructType.Field.newBuilder()\\\\n                                                                            .setName(\\\\\\\"option_value\\\\\\\")\\\\n                                                                            .setType(\\\\n                                                                                    Type.newBuilder()\\\\n                                                                                            .setCode(TypeCode.STRING)\\\\n                                                                                            .build())\\\\n                                                                            .build())\\\\n                                                            .build())\\\\n                                            .build())\\\\n                            .addValues(Value.newBuilder().setStringValue(\\\\\\\"GOOGLE_STANDARD_SQL\\\\\\\").build())\\\\n                            .build());\\\\n            responseObserver.onCompleted();\\\\n        }\\\\n    }\\\\n}\\\\n\\\"}\\n8133:[tool-call] end id=call_Jwhx7K8KfbHA86YYEJAgUR6I|fc_0072a0aaf99decd50169f778b6f4a481979c36b6a337ca66ef name=write args={\\\"path\\\": \\\"tests/src/com.google.cloud/google-cloud-spanner/6.116.1/src/test/java/com_google_cloud/google_cloud_spanner/ClientSideStatementSetExecutorTest.java\\\", \\\"content\\\": \\\"/*\\\\n * Copyright and related rights waived via CC0\\\\n *\\\\n * You should have received a copy of the CC0 legalcode along with this\\\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\\\n */\\\\npackage com_google_cloud.google_cloud_spanner;\\\\n\\\\nimport static org.assertj.core.api.Assertions.assertThat;\\\\n\\\\nimport com.google.cloud.spanner.Statement;\\\\nimport com.google.cloud.spanner.connection.Connection;\\\\nimport com.google.cloud.spanner.connection.ConnectionOptions;\\\\nimport com.google.cloud.spanner.connection.SpannerPool;\\\\nimport com.google.cloud.spanner.connection.StatementResult;\\\\nimport com.google.protobuf.Empty;\\\\nimport com.google.protobuf.Value;\\\\nimport com.google.spanner.v1.CreateSessionRequest;\\\\nimport com.google.spanner.v1.DeleteSessionRequest;\\\\nimport com.google.spanner.v1.ExecuteSqlRequest;\\\\nimport com.google.spanner.v1.PartialResultSet;\\\\nimport com.google.spanner.v1.ResultSetMetadata;\\\\nimport com.google.spanner.v1.Session;\\\\nimport com.google.spanner.v1.SpannerGrpc;\\\\nimport com.google.spanner.v1.StructType;\\\\nimport com.google.spanner.v1.Type;\\\\nimport com.google.spanner.v1.TypeCode;\\\\nimport io.grpc.Server;\\\\nimport io.grpc.ServerBuilder;\\\\nimport io.grpc.Status;\\\\nimport io.grpc.stub.StreamObserver;\\\\nimport java.util.concurrent.TimeUnit;\\\\nimport org.junit.jupiter.api.Test;\\\\n\\\\npublic class ClientSideStatementSetExecutorTest {\\\\n    @Test\\\\n    void executesSetStatementsWithOneAndTwoExecutorParameters() throws Exception {\\\\n        Server server = ServerBuilder.forPort(0).addService(new DialectSpannerService()).build().start();\\\\n        try {\\\\n            ConnectionOptions options =\\\\n                    ConnectionOptions.newBuilder()\\\\n                            .setUri(\\\\n                                    String.format(\\\\n                                            \\\\\\\"cloudspanner://localhost:%d/projects/p/instances/i/databases/d\\\\\\\"\\\\n                                                    + \\\\\\\"?usePlainText=true;trackConnectionLeaks=false;trackSessionLeaks=false\\\\\\\"\\\\n                                                    + \\\\\\\";numChannels=1;minSessions=0;maxSessions=1\\\\\\\",\\\\n                                            server.getPort()))\\\\n                            .build();\\\\n\\\\n            try (Connection connection = options.getConnection()) {\\\\n                assertNoResult(\\\\n                        connection.execute(Statement.of(\\\\\\\"set autocommit = false\\\\\\\")),\\\\n                        StatementResult.ClientSideStatementType.SET_AUTOCOMMIT);\\\\n                assertThat(connection.isAutocommit()).isFalse();\\\\n\\\\n                assertNoResult(\\\\n                        connection.execute(Statement.of(\\\\\\\"set retry_aborts_internally = false\\\\\\\")),\\\\n                        StatementResult.ClientSideStatementType.SET_RETRY_ABORTS_INTERNALLY);\\\\n                assertThat(connection.isRetryAbortsInternally()).isFalse();\\\\n            } finally {\\\\n                SpannerPool.closeSpannerPool();\\\\n            }\\\\n        } finally {\\\\n            server.shutdownNow();\\\\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\\\\n        }\\\\n    }\\\\n\\\\n    private static void assertNoResult(\\\\n            StatementResult result, StatementResult.ClientSideStatementType statementType) {\\\\n        assertThat(result.getResultType()).isEqualTo(StatementResult.ResultType.NO_RESULT);\\\\n        assertThat(result.getClientSideStatementType()).isEqualTo(statementType);\\\\n    }\\\\n\\\\n    private static final class DialectSpannerService extends SpannerGrpc.SpannerImplBase {\\\\n        private static final String DIALECT_SQL_PREFIX = \\\\\\\"select option_value from information_schema.database_options\\\\\\\";\\\\n\\\\n        @Override\\\\n        public void createSession(CreateSessionRequest request, StreamObserver<Session> responseObserver) {\\\\n            responseObserver.onNext(\\\\n                    Session.newBuilder()\\\\n                            .setName(request.getDatabase() + \\\\\\\"/sessions/test-session\\\\\\\")\\\\n                            .setMultiplexed(true)\\\\n                            .build());\\\\n            responseObserver.onCompleted();\\\\n        }\\\\n\\\\n        @Override\\\\n        public void deleteSession(DeleteSessionRequest request, StreamObserver<Empty> responseObserver) {\\\\n            responseObserver.onNext(Empty.getDefaultInstance());\\\\n            responseObserver.onCompleted();\\\\n        }\\\\n\\\\n        @Override\\\\n        public void executeStreamingSql(\\\\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\\\\n            if (!request.getSql().toLowerCase().startsWith(DIALECT_SQL_PREFIX)) {\\\\n                responseObserver.onError(\\\\n                        Status.UNIMPLEMENTED\\\\n                                .withDescription(\\\\\\\"Unexpected SQL: \\\\\\\" + request.getSql())\\\\n                                .asRuntimeException());\\\\n                return;\\\\n            }\\\\n            responseObserver.onNext(\\\\n                    PartialResultSet.newBuilder()\\\\n                            .setMetadata(\\\\n                                    ResultSetMetadata.newBuilder()\\\\n                                            .setRowType(\\\\n                                                    StructType.newBuilder()\\\\n                                                            .addFields(\\\\n                                                                    StructType.Field.newBuilder()\\\\n                                                                            .setName(\\\\\\\"option_value\\\\\\\")\\\\n                                                                            .setType(\\\\n                                                                                    Type.newBuilder()\\\\n                                                                                            .setCode(TypeCode.STRING)\\\\n                                                                                            .build())\\\\n                                                                            .build())\\\\n                                                            .build())\\\\n                                            .build())\\\\n                            .addValues(Value.newBuilder().setStringValue(\\\\\\\"GOOGLE_STANDARD_SQL\\\\\\\").build())\\\\n                            .build());\\\\n            responseObserver.onCompleted();\\\\n        }\\\\n    }\\\\n}\\\\n\\\"}\\n8134:[recv] {\\\"type\\\": \\\"message_end\\\", \\\"message\\\": {\\\"role\\\": \\\"assistant\\\", \\\"content\\\": [{\\\"type\\\": \\\"thinking\\\", \\\"thinking\\\": \\\"**Considering test setup**\\\\n\\\\nI’m thinking about whether to set multiplexed to true for the createSession response. It seems like I might need the session fields to be multiplexed, and I should add a test file while considering making it public since the rules say top-level test classes should be public. I also need to remember to add AssertJ imports. \\\\n\\\\nI’m contemplating the implications of using Native Image support for gRPC, especially concerning metadata for reflective access in tests.\\\\n\\\\n**Evaluating gRPC setup**\\\\n\\\\nI’m contemplating whether using Netty is excessive for my needs. I could switch to `io.grpc.inprocess` if the dependencies support it, but I’d have to explicitly add the dependency. Using an in-process server/client avoids the complications of ports and Netty, though I can't supply a channel provider unless the class is public. \\\\n\\\\nIt seems that the connection options could add more complexity. Maybe it’s simpler to stick with Netty. I need to consider how to handle session pools and executed dialect queries effectively as well.\\\\n\\\\n**Finalizing server connection**\\\\n\\\\nI need to close the server after using the pool, and it sounds like using a try/finally block or a try-with-resources approach would be best for managing that. \\\\n\\\\nI’m considering using a unique database name to prevent Spanner pool reuse across tests—maybe a UUID would work well for that. The URI with a random port should suffice. I'll also need to ensure I execute the SQL statement properly and assert the ClientSideStatementType. Do I need to set autocommit to false and then back to true?\\\\n\\\\n**Reviewing connection setup**\\\\n\\\\nI'm considering how the `ConnectionImpl` constructor uses `getDialect` in the connection state supplier. It looks like it calls `getDefaultIsolationLevel` but doesn't use a parser at that point. Then, the execute method calls the parser. Should I add a dedicated class for a one-to-one relationship here? I'm thinking about whether we should remove the placeholder or leave it in place. It's a bit unclear, so I need to weigh my options!\\\", \\\"thinkingSignature\\\": \\\"{\\\\\\\"id\\\\\\\":\\\\\\\"rs_0072a0aaf99decd50169f778a4e1b08197926d696dd67e138d\\\\\\\",\\\\\\\"type\\\\\\\":\\\\\\\"reasoning\\\\\\\",\\\\\\\"encrypted_content\\\\\\\":\\\\\\\"gAAAAABp93i2Mqa2anYwbXrN3XEX1AkTJSpFe8PlasQR5vbWX_CKhLhqdi6grOF5Ie29MI987d2aR66-uFRLZ9Y4cbrcnR8by7yUOnyoDQDvfUBHrVqYQtPFzvr_eW146wYLGXEN_IATArRMuTNeXStVxKvzGw44vS7Zs0cz13A161Gv1x19EhQV0DgZJaG8h9Ae-O2ltPj0EQpYx4HNO22wrOx39OmDVGVB3QHNDpf9sp56uJJaFLHbND2Z8HDNLIGupbT7-RSqCx-LEthILeC-ayEorvxRrb8Q0NJnou3ImEHeaa0lnEwGEFm5t15bs82BcfvksKxW--z2nt8EGgWNrRerd-t_jwPfkle3-MO5w3XaxFQU2maAP_hm-zXXN9FvTUULaOIYt0xRU4eQ-UOuGI-DsgO0EHiNywY0LZCJoomCIZNz_fjijbkkFsY7E4JWYe8Kl12OlQcipmAukcp1HvcaXuWS0VhDra-20XAET_AHQ35QxD35LHFZi9cCWEFzw1ft5ciTM_gU4XzDr4i1_hx9zJjVeAXPLNEYFzHh_JmXaWQBe7MPIU7t2dvCGZBCQ5cEauJK4WQtn4b-pnKOdd4V91iFfjtTEdaaCcyUWWeuMgU2yNfuW6EYW2kO2hZRqcIEpAAJmgPSe0tp-nYnjIGKDR5vSaxgkVzmy7ziT73Sg-vpj7s-KkDBaY3lKOwK243iQyRaVQjoatQmSoCNDMRoQfRoNCnuWyTKYRyrk9Gk6k_TaQ18HSHT8MH1sVd8zhYRnW45llQV3MUvKDjAK6ASac2F3V9txdUjILaXhT2f_Z87jVAWjZ3eyCsB5K-ruOXPWE6FY6r_489PJ9prpCLV3S1XFzQ5UeyjDQ3kIlN09dvy9VrqGiHOFVklpaPJoulBg-l3HrhWqP0jZifJ9l9H2Q95MkJtHHaWldwE9w9LSFMZdcFOc--sC_MKUTMMt-mwYSP_3lJAqIYSCpPwiGfhpoqfSeVfxEeM8U1Z9s5TfZ-kYIZNQdGI0hPuK8TRNeBlLNarylqooI3wz2nJaTyKNwz5AMLe2a1AHu3B2h3Q94w2kvhPJXwitUUFLpb-yqFWqagp7teDYD2x2g2t6kD7VamQpBm4TikElqpWSfXxOqh505eXLzdNPIwO7sonjg3jkuU3okNzD8jbDE6NJEBJPZU6UllVGMp1VVKWF5WUtpH-qcE376A9iKQXvEN1-NWBre9AbmhCi7hH66K1ehCc4P8adlJzXztTP3LKsskKJtGh_5SXTIBvMvJOmqJANezqNDKnbyUBdKxjPNZQ44gRsZTe7cIw2jhHoA_gOIbInIJZDOIm_kUTeJwD3RwPQvGde6MuH1vMLgxzAUkO3WcklPoHsNoGKauVapDsHwhFyMp3AcK2N7IRU-GoYs_166NRnnoFp77ulpTJTu1d7kCIiyLxu2Epwp7vS6-veNkeh6sqFZnf2SoMtK1Q1UJgcLm5z61JqkBf7Cfqzz0boa7QxPfwtDzJoEk5C02XmpZoAMf95qcfY8bFH4n2pvOBmuudmrgA3FyQUGFmxC7adC91IZnviSSdB45kDnXNPi7JgIsi7