AtomicReference;\nimport org.junit.jupiter.api.Test;\n\npublic class ClientSideStatementPartitionExecutorTest {\n    @Test\n    void executePartitionStatementDelegatesToPartitionQuery() throws Exception {\n        PartitioningSpanner spanner = new PartitioningSpanner();\n        Server server = ServerBuilder.forPort(0).addService(spanner).build().start();\n        try {\n            ConnectionOptions options = ConnectionOptions.newBuilder()\n                    .setUri(\"cloudspanner://localhost:\" + server.getPort()\n                            + \"/projects/test-project/instances/test-instance/databases/\"\n                            + \"test-database\"\n                            + \"?usePlainText=true;minSessions=0;maxSessions=1;numChannels=1\"\n                            + \";trackConnectionLeaks=false\")\n                    .build();\n\n            try (Connection connection = options.getConnection()) {\n                StatementResult result = connection.execute(Statement.of(\"partition select 1\"));\n\n                assertThat(result.getResultType()).isEqualTo(ResultType.RESULT_SET);\n                assertThat(result.getClientSideStatementType())\n                        .isEqualTo(ClientSideStatementType.PARTITION);\n                assertThat(spanner.partitionedSql.get()).isEqualTo(\"select 1\");\n                try (com.google.cloud.spanner.ResultSet partitions = result.getResultSet()) {\n                    assertThat(partitions.next()).isTrue();\n                    assertThat(partitions.getString(\"PARTITION\")).isNotEmpty();\n                    assertThat(partitions.next()).isFalse();\n                }\n            }\n        } finally {\n            server.shutdownNow();\n            assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n        }\n    }\n\n    private static final class PartitioningSpanner extends SpannerGrpc.SpannerImplBase {\n        private static final String DIALECT = \"GOOGLE_STANDARD_SQL\";\n        private static final ResultSetMetadata DIALECT_METADATA = ResultSetMetadata.newBuilder()\n                .setRowType(StructType.newBuilder()\n                        .addFields(StructType.Field.newBuilder()\n                                .setName(\"option_value\")\n                                .setType(Type.newBuilder().setCode(TypeCode.STRING).build())\n                                .build())\n                        .build())\n                .build();\n\n        private final AtomicReference<String> partitionedSql = new AtomicReference<>();\n\n        @Override\n        public void createSession(\n                CreateSessionRequest request, StreamObserver<Session> responseObserver) {\n            responseObserver.onNext(Session.newBuilder()\n                    .setName(request.getDatabase() + \"/sessions/test-session\")\n                    .setMultiplexed(request.getSession().getMultiplexed())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeStreamingSql(\n                ExecuteSqlRequest request, StreamObserver<PartialResultSet> responseObserver) {\n            responseObserver.onNext(PartialResultSet.newBuilder()\n                    .setMetadata(DIALECT_METADATA)\n                    .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void executeSql(\n                ExecuteSqlRequest request, StreamObserver<ResultSet> responseObserver) {\n            responseObserver.onNext(ResultSet.newBuilder()\n                    .setMetadata(DIALECT_METADATA)\n                    .addRows(ListValue.newBuilder()\n                            .addValues(Value.newBuilder().setStringValue(DIALECT).build())\n                            .build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void beginTransaction(\n                BeginTransactionRequest request, StreamObserver<Transaction> responseObserver) {\n            responseObserver.onNext(Transaction.newBuilder()\n                    .setId(ByteString.copyFromUtf8(\"test-transaction\"))\n                    .setReadTimestamp(Timestamp.newBuilder().setSeconds(1).build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n\n        @Override\n        public void partitionQuery(\n                PartitionQueryRequest request, StreamObserver<PartitionResponse> responseObserver) {\n            partitionedSql.set(request.getSql());\n            responseObserver.onNext(PartitionResponse.newBuilder()\n                    .addPartitions(Partition.newBuilder()\n                            .setPartitionToken(ByteString.copyFromUtf8(\"partition-token\"))\n                            .build())\n                    .build());\n            responseObserver.onCompleted();\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
