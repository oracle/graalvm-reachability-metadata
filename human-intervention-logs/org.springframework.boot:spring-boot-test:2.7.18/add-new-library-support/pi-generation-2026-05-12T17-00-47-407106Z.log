      @Import(TrackingDeterminableImports.class)
      static class TestCaseWithDeterminedImports {
  
      }
  
      public static final class TrackingDeterminableImports implements DeterminableImports {
  
          private static final AtomicInteger instantiations = new AtomicInteger();
  
