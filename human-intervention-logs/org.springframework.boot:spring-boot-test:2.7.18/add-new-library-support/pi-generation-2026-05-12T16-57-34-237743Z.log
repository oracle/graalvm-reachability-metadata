[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot-test/2.7.18/src/test/java/org_springframework_boot/spring_boot_test/AssertProviderApplicationContextInvocationHandlerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot_test;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.test.context.assertj.AssertableApplicationContext;\nimport org.springframework.context.support.GenericApplicationContext;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AssertProviderApplicationContextInvocationHandlerTest {\n\n    @Test\n    void delegatesApplicationContextMethodsToSourceContext() {\n        GenericApplicationContext context = new GenericApplicationContext();\n        context.setId(\"delegated-context\");\n        context.refresh();\n\n        AssertableApplicationContext assertableContext = AssertableApplicationContext.get(() -> context);\n        try {\n            assertThat(assertableContext.getId()).isEqualTo(\"delegated-context\");\n        }\n        finally {\n            assertableContext.close();\n        }\n    }\n\n}\n"}
