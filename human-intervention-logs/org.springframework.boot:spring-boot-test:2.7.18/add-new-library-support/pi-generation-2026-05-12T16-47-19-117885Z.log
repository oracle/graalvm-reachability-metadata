[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot-test/2.7.18/src/test/java/org_springframework_boot/spring_boot_test/FilteredClassLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot_test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.test.context.FilteredClassLoader;\n\npublic class FilteredClassLoaderTest {\n\n    private static final String VISIBLE_RESOURCE = \"org_springframework_boot/spring_boot_test/filtered-class-loader-visible.txt\";\n\n    private static final String HIDDEN_RESOURCE = \"org_springframework_boot/spring_boot_test/filtered-class-loader-hidden.txt\";\n\n    @Test\n    void getResourceDelegatesToParentForVisibleResource() {\n        FilteredClassLoader classLoader = new FilteredClassLoader(HIDDEN_RESOURCE::equals);\n\n        URL resource = classLoader.getResource(VISIBLE_RESOURCE);\n\n        assertThat(resource).isNotNull();\n    }\n\n    @Test\n    void getResourcesDelegatesToParentForVisibleResource() throws IOException {\n        FilteredClassLoader classLoader = new FilteredClassLoader(HIDDEN_RESOURCE::equals);\n\n        Enumeration<URL> resources = classLoader.getResources(VISIBLE_RESOURCE);\n        List<URL> resourceList = Collections.list(resources);\n\n        assertThat(resourceList).isNotEmpty();\n    }\n\n}\n"}
