atesCustomizerKeyForDeterminedImports() {\n        TrackingDetermininableImports.instantiations.set(0);\n\n        TestContextManager testContextManager = new TestContextManager(TestCaseWithDeterminedImports.class);\n\n        assertThat(testContextManager).isNotNull();\n        assertThat(TrackingDetermininableImports.instantiations).hasValue(1);\n    }\n\n    @Import(TrackingDetermininableImports.class)\n    static class TestCaseWithDeterminedImports {\n\n    }\n\n    public static final class TrackingDetermininableImports implements DeterminableImports {\n\n        private static final AtomicInteger instantiations = new AtomicInteger();\n\n        public TrackingDetermininableImports() {\n            instantiations.incrementAndGet();\n        }\n\n        @Override\n        public Set<Object> determineImports(AnnotationMetadata metadata) {\n            assertThat(metadata.getClassName()).isEqualTo(TestCaseWithDeterminedImports.class.getName());\n            return Collections.singleton(ImportedConfiguration.class.getName());\n        }\n\n    }\n\n    static class ImportedConfiguration {\n\n    }\n\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1185, "output": 993, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 17538, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778604605563, "responseId": "resp_06d193982a19d9ee016a035a3efea481939fd105a8c5b5e37c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_3ZuYRkkn7uMIpdVCFEcCr9lC|fc_06d193982a19d9ee016a035a4700c08193a392a5e7ecdb7873", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1876 bytes to tests/src/org.springframework.boot/spring-boot-test/2.7.18/src/test/java/org_springframework_boot/spring_boot_test/ImportsContextCustomizerInnerContextCustomizerKeyTest.java"}], "isError": false, "timestamp": 1778604619624}]}
