  package org_springframework_boot.spring_boot_test;
  
  import java.io.IOException;
  import java.net.URL;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.test.context.FilteredClassLoader;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FilteredClassLoaderTest {
  
      private static final String VISIBLE_RESOURCE = "filtered-class-loader-visible.txt";
  
      private static final String HIDDEN_RESOURCE = "filtered-class-loader-hidden.txt";
  
      @Test
      void getResourceDelegatesToParentForVisibleResource() throws IOException {
          try (FilteredClassLoader classLoader = new FilteredClassLoader(HIDDEN_RESOURCE::equals)) {
              URL resource = classLoader.getResource(VISIBLE_RESOURCE);
  
              assertThat(resource).isNotNull();
          }
      }
  
      @Test
      void getResourcesDelegatesToParentForVisibleResource() throws IOException {
          try (FilteredClassLoader classLoader = new FilteredClassLoader(HIDDEN_RESOURCE::equals)) {
              Enumeration<URL> resources = classLoader.getResources(VISIBLE_RESOURCE);
              List<URL> resourceList = Collections.list(resources);
  
              assertThat(resourceList).isNotEmpty();
          }
      }
  
  }
