zlyServerFactory;\nimport com.sun.jersey.api.core.DefaultResourceConfig;\nimport com.sun.jersey.api.core.ResourceConfig;\nimport javax.ws.rs.GET; import javax.ws.rs.Path; import javax.ws.rs.core.UriBuilder;\nimport java.net.*; import java.nio.charset.StandardCharsets;\nimport org.glassfish.grizzly.http.server.HttpServer;\npublic class TestJerseyGrizzly {\n  @Path(\"/hello\") public static class HelloResource { @GET public String hello() { return \"hello\"; } }\n  public static void main(String[] args) throws Exception {\n    ResourceConfig config = new DefaultResourceConfig(HelloResource.class);\n    config.getFeatures().put(ResourceConfig.FEATURE_DISABLE_WADL, true);\n    HttpServer server = GrizzlyServerFactory.createHttpServer(UriBuilder.fromUri(\"http://127.0.0.1/\").port(0).build(), config);\n    try { int port = server.getListeners().iterator().next().getPort();\n      HttpURLConnection conn = (HttpURLConnection) new URL(\"http://127.0.0.1:\" + port + \"/hello\").openConnection();\n      System.out.println(conn.getResponseCode()); System.out.println(new String(conn.getInputStream().readAllBytes(), StandardCharsets.UTF_8));\n    } finally { server.stop(); }\n  }\n}\nEOF\njavac -cp \"$(cat cp.txt)\" TestJerseyGrizzly.java && java -cp \".:$(cat cp.txt)\" TestJerseyGrizzly", "timeout": 120}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1105, "output": 981, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 17958, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782654542504, "responseId": "resp_04715431ba2212ec016a41264edbe8819787cd53bb3ea097da"}}
