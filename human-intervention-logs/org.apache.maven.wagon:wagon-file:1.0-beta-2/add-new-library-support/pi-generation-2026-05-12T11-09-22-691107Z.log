      {
          Wagon wagon = (Wagon) lookup( Wagon.ROLE, getProtocol() );
  
          Debug debug = new Debug();
  
          wagon.addSessionListener( debug );
  
          wagon.addTransferListener( debug );
  
          return wagon;
      }
  
      private void message( String message )
      {
          System.out.println( message );
      }
  
