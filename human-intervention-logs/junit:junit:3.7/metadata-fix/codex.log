{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/junit/junit/3.7/src/test/java/junit_junit/AwtuiTestRunnerTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage junit_junit;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.awt.Frame;\nimport java.awt.List;\nimport java.awt.TextField;\nimport java.util.ArrayList;\nimport java.util.Vector;\n\nimport org.junit.jupiter.api.Test;\n\nimport junit.awtui.TestRunner;\nimport junit.framework.TestCase;\nimport junit.framework.TestResult;\n\npublic class AwtuiTestRunnerTest {\n\n    @Test\n    void createsUserInterfaceWithFrameIconFromRunnerResource() {\n        ExposedAwtTestRunner runner = new ExposedAwtTestRunner();\n        Frame frame = null;\n        try {\n            frame = runner.newUserInterface(ReloadableTestCase.class.getName());\n\n            assertThat(frame.getIconImage()).isNotNull();\n        } finally {\n            if (frame != null) {\n                frame.dispose();\n            }\n        }\n    }\n\n    @Test\n    void rerunsSelectedTestCaseThroughStringConstructor() {\n        ReloadableTestCase.constructedNames.clear();\n        ReloadableTestCase.executedNames.clear();\n        ExposedAwtTestRunner runner = new ExposedAwtTestRunner();\n        ReloadableTestCase original = new ReloadableTestCase(\"testRecordsName\");\n        runner.prepareSelectedFailure(original);\n        runner.setLoading(false);\n\n        runner.rerun();\n\n        assertThat(ReloadableTestCase.constructedNames).containsExactly(\"testRecordsName\", \"testRecordsName\");\n        assertThat(ReloadableTestCase.executedNames).containsExactly(\"testRecordsName\");\n        assertThat(runner.statusText()).isEqualTo(original + \" was successful\");\n    }\n\n    public static class ReloadableTestCase extends TestCase {\n        static final ArrayList<String> constructedNames = new ArrayList<>();\n        static final ArrayList<String> executedNames = new ArrayList<>();\n\n        public ReloadableTestCase(String name) {\n            super(name);\n            constructedNames.add(name);\n        }\n\n        public void testRecordsName() {\n            executedNames.add(getName());\n        }\n    }\n\n    private static class ExposedAwtTestRunner extends TestRunner {\n        Frame newUserInterface(String suiteName) {\n            return createUI(suiteName);\n        }\n\n        void prepareSelectedFailure(TestCase testCase) {\n            fFailureList = new List(1);\n            fFailureList.add(testCase.toString());\n            fFailureList.select(0);\n            fFailedTests = new Vector();\n            fFailedTests.addElement(testCase);\n            fStatusLine = new TextField();\n        }\n\n        String statusText() {\n            return fStatusLine.getText();\n        }\n\n        @Override\n        protected TestResult createTestResult() {\n            return new TestResult();\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
