ertThat(view.getComponent()).isInstanceOf(JLabel.class);\n    }\n\n    @Test\n    void createsConfiguredTestCollectorByClassNameWhenBrowsing() throws IOException {\n        EmptyTestCollector.createdInstances = 0;\n        ExposedTestRunner runner = runnerWithPreferences(\"TestCollectorClass=\" + EmptyTestCollector.class.getName());\n\n        Throwable thrown = catchThrowable(runner::browseTestClasses);\n\n        assertThat(EmptyTestCollector.createdInstances).isEqualTo(1);\n        assertThat(thrown).isInstanceOfAny(HeadlessException.class, NullPointerException.class);\n    }\n\n    @Test\n    void createsLogoFromRunnerResource() throws IOException {\n        ExposedTestRunner runner = runnerWithPreferences();\n\n        JLabel logo = runner.newLogo();\n        Icon icon = TestRunner.getIconResource(BaseTestRunner.class, \"logo.gif\");\n\n        assertThat(logo.getIcon()).isNotNull();\n        assertThat(icon).isNotNull();\n        assertThat(logo.getToolTipText()).startsWith(\"JUnit Version \");\n    }\n\n    @Test\n    void rerunReloadsTestCaseThroughStringConstructor() throws Throwable {\n        ExposedTestRunner runner = runnerWithPreferences();\n        runner.setLoading(false);\n        ReloadableTestCase.constructedNames.clear();\n        ReloadableTestCase original = new ReloadableTestCase(\"testNeverRuns\");\n\n        Method rerunTest = TestRunner.class.getDeclaredMethod(\"rerunTest\", junit.framework.Test.class);\n        rerunTest.setAccessible(true);\n        Throwable thrown = catchThrowable(() -> rerunTest.invoke(runner, original));\n\n        assertThat(thrown).isInstanceOf(InvocationTargetException.class);\n        assertThat(((InvocationTargetException) thrown).getCause()).isInstanceOf(NullPointerException.class);\n        assertThat(ReloadableTestCase.constructedNames).containsExactly(\"testNeverRuns\", \"testNeverRuns\");\n    }\n\n    private ExposedTestRunner runnerWithPreferences(String... lines) throws IOException {\n        previousUserHome = System.getProperty(\"user.home\");\n        System.setProperty(\"user.home\", temporaryHome.toString());\n        if (lines.length > 0) {\n            Files.writeString(temporaryHome.resolve(\"junit.properties\"), String.join(System.lineSeparator(), lines));\n        }\n        return new ExposedTestRunner();\n    }\n\n    public static class RecordingFailureDetailView implements FailureDetailView {\n        private final JLabel component = new JLabel(\"failure details\");\n\n        @Override\n        public void clear() {\n            component.setText(\"\");\n        }\n\n        @Override\n        public Component getComponent() {\n            return component;\n        }\n\n        @Override\n        public void showFailure(TestFailure failure) {\n            component.setText(failure.toString());\n        }\n    }\n\n    public static class EmptyTestCollector implements TestCollector {\n        static int createdInstances;\n\n        public EmptyTestCollector() {\n            createdInstances++;\n        }\n\n        @Override\n        public Enumeration collectTests() {\n            return Collections.enumeration(Collections.emptyList());\n        }\n    }\n\n    public static class ReloadableTestCase extends TestCase {\n        static final List<String> constructedNames = new ArrayList<>();\n\n        public ReloadableTestCase(String name) {\n            super(name);\n            constructedNames.add(name);\n        }\n\n        public void testNeverRuns() {\n        }\n    }\n\n    private static class ExposedTestRunner extends TestRunner {\n        FailureDetailView newFailureDetailView() {\n            return createFailureDetailView();\n        }\n\n        JLabel newLogo() {\n            return createLogo();\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
