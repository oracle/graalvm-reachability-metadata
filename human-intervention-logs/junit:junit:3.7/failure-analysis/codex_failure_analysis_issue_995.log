tomicInteger constructedCollectors = new AtomicInteger();\\n\\n    @TempDir\\n    Path tempHome;\\n\\n    @Test\\n    @Order(1)\\n    void createsConfiguredFailureDetailViewAndLoadsSwingIconResource() throws Exception {\\n        ExposedTestRunner runner = newRunnerWithPreferences(\\n                \\\"FailureViewClass=junit.swingui.DefaultFailureDetailView\\\");\\n\\n        FailureDetailView view = runner.newFailureDetailView();\\n        Component component = view.getComponent();\\n\\n        assertThat(component).isNotNull();\\n        assertThat(view.getClass().getName()).isEqualTo(\\\"junit.swingui.DefaultFailureDetailView\\\");\\n        assertThat(TestRunner.getIconResource(BaseTestRunner.class, \\\"logo.gif\\\")).isNotNull();\\n    }\\n\\n    @Test\\n    @Order(3)\\n    void createsConfiguredTestCollectorBeforeOpeningBrowserDialog() throws Exception {\\n        assertThat(new EmptyTestCollector().collectTests().hasMoreElements()).isFalse();\\n        constructedCollectors.set(0);\\n        ExposedTestRunner runner = newRunnerWithPreferences(\\n                \\\"TestCollectorClass=\\\" + EmptyTestCollector.class.getName());\\n        Timer dialogCloser = new Timer(50, ignored -> closeShowingDialogs());\\n        dialogCloser.setRepeats(true);\\n        JFrame frame = createRunnerUi(runner);\\n\\n        try {\\n            dialogCloser.start();\\n            runner.browseTestClasses();\\n        } finally {\\n            dialogCloser.stop();\\n            closeShowingDialogs();\\n            SwingUtilities.invokeAndWait(frame::dispose);\\n        }\\n\\n        assertThat(constructedCollectors.get()).isGreaterThanOrEqualTo(1);\\n    }\\n\\n    @Test\\n    @Order(2)\\n    void rerunsSelectedTestCaseThroughSwingRunner() throws Exception {\\n        ExposedTestRunner runner = newRunnerWithPreferences();\\n        runner.setLoading(false);\\n        failNextRun.set(true);\\n\\n        JFrame frame = createRunnerUi(runner);\\n        try {\\n            runner.runSingleTest(new RerunnableJunit3TestCase(\\\"testFailsOnceThenPassesOnRerun\\\"));\\n            waitUntil(() -> runner.rerunButton().isEnabled() && runner.runButton().getText().equals(\\\"Run\\\"));\\n\\n            SwingUtilities.invokeAndWait(() -> runner.rerunButton().doClick());\\n            waitUntil(() -> runner.statusText().contains(\\\"was successful\\\"));\\n\\n            assertThat(failNextRun.get()).isFalse();\\n            assertThat(runner.statusText()).contains(\\\"testFailsOnceThenPassesOnRerun\\\");\\n        } finally {\\n            SwingUtilities.invokeAndWait(frame::dispose);\\n        }\\n    }\\n\\n    private JFrame createRunnerUi(ExposedTestRunner runner) {\\n        String previousHome = System.getProperty(\\\"user.home\\\");\\n        System.setProperty(\\\"user.home\\\", tempHome.toString());\\n        try {\\n            return runner.createRunnerUi();\\n        } finally {\\n            restoreProperty(\\\"user.home\\\", previousHome);\\n        }\\n    }\\n\\n    private ExposedTestRunner newRunnerWithPreferences(String... properties) throws IOException {\\n        Files.write(\\n                tempHome.resolve(\\\"junit.properties\\\"),\\n                Arrays.asList(properties),\\n                StandardCharsets.ISO_8859_1);\\n        String previousHome = System.getProperty(\\\"user.home\\\");\\n        System.setProperty(\\\"user.home\\\", tempHome.toString());\\n        try {\\n            return new ExposedTestRunner();\\n        } finally {\\n            restoreProperty(\\\"user.home\\\", previousHome);\\n        }\\n    }\\n\\n    private static void restoreProperty(String name, String previousValue) {\\n        if (previousValue == null) {\\n            System.clearProperty(name);\\n        } else {\\n            System.setProperty(name, previousValue);\\n        }\\n    }\\n\\n    private static void closeShowingDialogs() {\\n        for (Window window : Window.getWindows()) {\\n            if (window instanceof Dialog && window.isShowing()) {\\n                window.dispose();\\n            }\\n        }\\n    }\\n\\n    private static void waitUntil(BooleanSupplier condition) throws Exception {\\n        long deadline = System.nanoTime() + Duration.ofSeconds(5).toNanos();\\n        while (System.nanoTime() < deadline) {\\n            if (condition.getAsBoolean()) {\\n                return;\\n            }\\n            SwingUtilities.invokeAndWait(() -> {\\n            });\\n            Thread.sleep(25);\\n        }\\n        assertThat(condition.getAsBoolean()).isTrue();\\n    }\\n\\n    public static final class EmptyTestCollector implements TestCollector {\\n        public EmptyTestCollector() {\\n            constructedCollectors.incrementAndGet();\\n        }\\n\\n        @Override\\n        public Enumeration collectTests() {\\n            return Collections.emptyEnumeration();\\n        }\\n    }\\n\\n    public static final class RerunnableJunit3TestCase extends TestCase {\\n        public RerunnableJunit3TestCase(String name) {\\n            super(name);\\n        }\\n\\n        public void testFailsOnceThenPassesOnRerun() {\\n            if (failNextRun.getAndSet(false)) {\\n                throw new AssertionFailedError(\\\"first run fails so the Swing runner can rerun it\\\");\\n            }\\n        }\\n    }\\n\\n    private static final class ExposedTestRunner extends TestRunner {\\n        private JButton rerunButton;\\n        private JButton runButton;\\n        private JFrame frame;\\n        private StatusLine statusLine;\\n\\n        FailureDetailView newFailureDetailView() {\\n            return createFailureDetailView();\\n        }\\n\\n        JFrame createRunnerUi() {\\n            start(new String[0]);\\n            return frame;\\n        }\\n\\n        void runSingleTest(junit.framework.Test test) {\\n            runTest(test);\\n        }\\n\\n        JButton rerunButton() {\\n            return rerunButton;\\n        }\\n\\n        JButton runButton() {\\n            return runButton;\\n        }\\n\\n        String statusText() {\\n            return statusLine.getText();\\n        }\\n\\n        @Override\\n        protected JFrame createUI(String suiteName) {\\n            frame = super.createUI(suiteName);\\n            return frame;\\n        }\\n\\n        @Override\\n        protected JButton createRunButton() {\\n            runButton = super.createRunButton();\\n            return runButton;\\n        }\\n\\n        @Override\\n        protected JPanel createFailedPanel() {\\n            JPanel panel = super.createFailedPanel();\\n            rerunButton = (JButton) panel.getComponent(0);\\n            return panel;\\n        }\\n\\n        @Override\\n        protected StatusLine createStatusLine() {\\n            statusLine = super.createStatusLine();\\n            return statusLine;\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_7\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/junit/junit/3.7/src/test/java/legacy/junit3/Junit37MetadataTest.java\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_7\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/junit/junit/3.7/src/test/java/legacy/junit3/Junit37MetadataTest.java\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage legacy.junit3;\\n\\nimport junit.framework.AssertionFailedError;\\nimport junit.framework.TestResult;\\nimport junit.framework.TestSuite;\\nimport junit.runner.BaseTestRunner;\\nimport junit.runner.TestCaseClassLoader;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.io.ByteArrayO