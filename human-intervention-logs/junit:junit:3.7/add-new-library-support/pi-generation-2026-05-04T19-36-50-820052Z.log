  package junit_junit;
  
  import static org.junit.jupiter.api.Assertions.assertSame;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import org.junit.internal.builders.AnnotatedBuilder;
  import org.junit.jupiter.api.Test;
  import org.junit.runner.Description;
  import org.junit.runner.Runner;
  import org.junit.runner.notification.RunNotifier;
  import org.junit.runners.model.RunnerBuilder;
  
  public class AnnotatedBuilderTest {
  
      @Test
      void buildsRunnerUsingClassConstructor() throws Exception {
          RunnerBuilder suiteBuilder = new EmptyRunnerBuilder();
          AnnotatedBuilder builder = new AnnotatedBuilder(suiteBuilder);
  
          Runner runner = builder.buildRunner(ClassConstructorRunner.class, SampleTest.class);
  
          assertTrue(runner instanceof ClassConstructorRunner);
          ClassConstructorRunner classConstructorRunner = (ClassConstructorRunner) runner;
          assertSame(SampleTest.class, classConstructorRunner.testClass);
      }
  
      @Test
      void buildsRunnerUsingClassAndRunnerBuilderConstructor() throws Exception {
          RunnerBuilder suiteBuilder = new EmptyRunnerBuilder();
          AnnotatedBuilder builder = new AnnotatedBuilder(suiteBuilder);
  
          Runner runner = builder.buildRunner(ClassAndBuilderConstructorRunner.class, SampleTest.class);
  
          assertTrue(runner instanceof ClassAndBuilderConstructorRunner);
          ClassAndBuilderConstructorRunner classAndBuilderConstructorRunner = (ClassAndBuilderConstructorRunner) runner;
          assertSame(SampleTest.class, classAndBuilderConstructorRunner.testClass);
          assertSame(suiteBuilder, classAndBuilderConstructorRunner.suiteBuilder);
      }
  
      public static class ClassConstructorRunner extends Runner {
          private final Class<?> testClass;
  
          public ClassConstructorRunner(Class<?> testClass) {
              this.testClass = testClass;
          }
  
          @Override
          public Description getDescription() {
              return Description.createSuiteDescription(testClass);
          }
  
          @Override
          public void run(RunNotifier notifier) {
              Description description = getDescription();
              notifier.fireTestStarted(description);
              notifier.fireTestFinished(description);
          }
      }
  
      public static class ClassAndBuilderConstructorRunner extends Runner {
          private final Class<?> testClass;
          private final RunnerBuilder suiteBuilder;
  
          public ClassAndBuilderConstructorRunner(Class<?> testClass, RunnerBuilder suiteBuilder) {
              this.testClass = testClass;
              this.suiteBuilder = suiteBuilder;
          }
  
          @Override
          public Description getDescription() {
              return Description.createSuiteDescription(testClass);
          }
  
          @Override
          public void run(RunNotifier notifier) {
              Description description = getDescription();
              notifier.fireTestStarted(description);
              notifier.fireTestFinished(description);
          }
      }
  
      public static class EmptyRunnerBuilder extends RunnerBuilder {
          @Override
          public Runner runnerForClass(Class<?> testClass) {
              return null;
          }
      }
  
      public static class SampleTest {
      }
  }
