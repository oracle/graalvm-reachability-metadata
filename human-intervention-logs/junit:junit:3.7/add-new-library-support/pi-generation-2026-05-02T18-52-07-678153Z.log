  package legacy.junit3;
  
  import junit.awtui.TestRunner;
  import junit.framework.AssertionFailedError;
  import junit.framework.TestCase;
  import junit.framework.TestResult;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import java.awt.Frame;
  import java.nio.file.Path;
  import java.util.Vector;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JunitAwtuiTestRunnerTest {
      @TempDir
      Path tempHome;
  
      @Test
      void rerunsSelectedTestCaseThroughAwtRunner() {
          String previousHome = System.getProperty("user.home");
          System.setProperty("user.home", tempHome.toString());
          ExposedAwtTestRunner runner;
          try {
              runner = new ExposedAwtTestRunner();
          } finally {
              restoreProperty("user.home", previousHome);
          }
          runner.setLoading(false);
  
          Frame frame = runner.createRunnerUi();
          try {
              runner.recordFailedTest(new PassingJunit3TestCase("testPassesWhenRerun"));
  
              assertThat(runner.rerunButtonEnabled()).isTrue();
  
              runner.rerun();
  
              assertThat(runner.statusText()).contains("testPassesWhenRerun").contains("was successful");
          } finally {
              frame.dispose();
          }
      }
  
      private static void restoreProperty(String name, String previousValue) {
          if (previousValue == null) {
              System.clearProperty(name);
          } else {
              System.setProperty(name, previousValue);
          }
      }
  
      public static final class PassingJunit3TestCase extends TestCase {
          public PassingJunit3TestCase(String name) {
              super(name);
          }
  
          public void testPassesWhenRerun() {
              assertTrue(true);
          }
      }
  
      private static final class ExposedAwtTestRunner extends TestRunner {
          Frame createRunnerUi() {
              fFrame = createUI(null);
              fExceptions = new Vector();
              fFailedTests = new Vector();
              return fFrame;
          }
  
          void recordFailedTest(TestCase testCase) {
              AssertionFailedError failure = new AssertionFailedError("recorded failure for AWT rerun");
              fTestResult = new TestResult();
              fTestResult.addFailure(testCase, failure);
              addFailure(testCase, failure);
          }
  
          boolean rerunButtonEnabled() {
              return fRerunButton.isEnabled();
          }
  
          String statusText() {
              return fStatusLine.getText();
          }
      }
  }
