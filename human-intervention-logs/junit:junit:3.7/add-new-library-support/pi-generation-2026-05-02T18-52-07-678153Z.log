  package legacy.junit3;
  
  import junit.framework.AssertionFailedError;
  import junit.framework.TestResult;
  import junit.framework.TestSuite;
  import junit.runner.BaseTestRunner;
  import junit.runner.TestCaseClassLoader;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayOutputStream;
  import java.io.InputStream;
  import java.io.PrintStream;
  import java.nio.charset.StandardCharsets;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  class Junit37MetadataTest {
  
      @Test
      void textRunnerBuildsWarningSuiteForLibraryClass() {
          TestSuite suite = new TestSuite(TestSuite.class);
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          junit.textui.TestRunner runner = new junit.textui.TestRunner(new PrintStream(output));
  
          TestResult result = runner.doRun(suite, false);
  
          assertThat(result.runCount()).isEqualTo(1);
          assertThat(result.failureCount()).isEqualTo(1);
          assertThat(result.errorCount()).isZero();
          assertThat(output.toString(StandardCharsets.UTF_8)).contains("FAILURES!!!");
      }
  
      @Test
      void baseRunnerLoadsLibrarySuiteByName() {
          RecordingBaseTestRunner runner = new RecordingBaseTestRunner();
          runner.setLoading(false);
  
          junit.framework.Test loadedTest = runner.getTest("junit.framework.TestSuite");
  
          assertThat(loadedTest)
                  .as("runFailed message: %s", runner.failedMessage())
                  .isInstanceOf(TestSuite.class);
          assertThat(runner.failedMessage()).isNull();
          assertThat(loadedTest.countTestCases()).isEqualTo(1);
      }
  
      @Test
      void testCaseClassLoaderLoadsExcludedPackagesResource() throws Exception {
          TestCaseClassLoader loader = new TestCaseClassLoader();
  
          try (InputStream stream = loader.getResourceAsStream("junit/runner/excluded.properties")) {
              assertThat(stream).isNotNull();
              assertThat(new String(stream.readAllBytes(), StandardCharsets.ISO_8859_1))
                      .contains("excluded.0=sun.*")
                      .contains("excluded.5=java.*");
          }
      }
  
      private static final class RecordingBaseTestRunner extends BaseTestRunner {
          private String failedMessage;
  
          @Override
          public void addError(junit.framework.Test test, Throwable throwable) {
          }
  
          @Override
          public void addFailure(junit.framework.Test test, AssertionFailedError assertionFailedError) {
          }
  
          @Override
          public void endTest(junit.framework.Test test) {
          }
  
          @Override
          protected void runFailed(String message) {
              failedMessage = message;
          }
  
          @Override
          public void startTest(junit.framework.Test test) {
          }
  
          String failedMessage() {
              return failedMessage;
          }
      }
  }
