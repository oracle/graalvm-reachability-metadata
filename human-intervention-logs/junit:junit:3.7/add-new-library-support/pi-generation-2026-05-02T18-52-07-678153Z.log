     604		synchronized public void runSuite() {
     605			if (fRunner != null) {
     606				fTestResult.stop();
     607			} else {
     608				setLoading(shouldReload());
     609				reset();
     610				showInfo("Load Test Case...");
     611				final String suiteName= getSuiteText();
     612				final Test testSuite= getTest(suiteName);		
     613				if (testSuite != null) {
     614					addToHistory(suiteName);
     615					doRunTest(testSuite);
     616				}
     617			}
     618		}
