              if (!failed && failingClassName.equals(name)) {
                  failed = true;
                  recordLoad(name);
                  throw new ClassNotFoundException(name);
              }
              return super.loadClass(name);
          }
  
          boolean failedInitialLoad() {
              return failed;
          }
      }
