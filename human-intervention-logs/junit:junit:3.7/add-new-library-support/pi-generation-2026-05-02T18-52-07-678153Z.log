     668		private void saveHistory() throws IOException {
     669			BufferedWriter bw= new BufferedWriter(new FileWriter(getSettingsFile()));
     670			try {
     671				for (int i= 0; i < fSuiteCombo.getItemCount(); i++) {
     672					String testsuite= fSuiteCombo.getItemAt(i).toString();
     673					bw.write(testsuite, 0, testsuite.length());
     674					bw.newLine();
     675				}
     676			} finally {
     677				bw.close();
     678			}
     679		}
