tream inputStream = fixtureClass.getClassLoader().getResourceAsStream(resourceName)) {\n            assertThat(inputStream).as(resourceName).isNotNull();\n            Files.copy(inputStream, target);\n        }\n    }\n\n    private static void restoreProperty(String name, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, previousValue);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static final class SuiteMethodFixture {\n        public static junit.framework.Test suite() {\n            return new TestSuite();\n        }\n    }\n\n    public static final class PublicJunit3Case extends TestCase {\n        public PublicJunit3Case(String name) {\n            super(name);\n        }\n\n        public void testPasses() {\n            assertTrue(true);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 4822, "output": 1675, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 33121, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777747877246, "responseId": "resp_084e99528762e5290169f647a5d4288195b5bb3771c7290457"}}
