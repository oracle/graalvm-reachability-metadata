     705	
     706		private void showFailureDetail(Test test) {
     707			if (test != null) {
     708				ListModel failures= getFailures();
     709				for (int i= 0; i < failures.getSize(); i++) {
     710					TestFailure failure= (TestFailure)failures.getElementAt(i);
     711					if (failure.failedTest() == test) {
     712						fFailureView.showFailure(failure);
     713						return;
     714					}
     715				}
     716			}
     717			fFailureView.clear();
     718		}
