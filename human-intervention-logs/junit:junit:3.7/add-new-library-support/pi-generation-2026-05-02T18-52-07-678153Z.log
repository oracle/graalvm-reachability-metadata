  package legacy.junit3;
  
  import junit.framework.TestCase;
  import junit.framework.TestSuite;
  import junit.runner.LoadingTestCollector;
  import junit.runner.TestCollector;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.ArrayList;
  import java.util.Enumeration;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LoadingTestCollectorTest {
      @TempDir
      Path classpathRoot;
  
      @Test
      void collectTestsLoadsCandidateClassesAndInspectsSuiteAndConstructor() throws Exception {
          copyClassFile(SuiteMethodFixture.class, classpathRoot);
          copyClassFile(PublicJunit3Case.class, classpathRoot);
          String previousClassPath = System.getProperty("java.class.path");
          System.setProperty("java.class.path", classpathRoot.toString());
          try {
              LoadingTestCollector collector = new LoadingTestCollector();
              List<String> collectedTestNames = collectTestNames(collector.collectTests());
  
              assertThat(collectedTestNames)
                      .contains(SuiteMethodFixture.class.getName())
                      .contains(PublicJunit3Case.class.getName());
          } catch (Error error) {
              rethrowUnlessUnsupportedDynamicClassLoading(error);
          } finally {
              restoreProperty("java.class.path", previousClassPath);
          }
      }
  
      @Test
      void freshlyLoadedCollectorInitializesLegacyClassLiteralsDuringCollection() throws Exception {
          copyClassFile(PublicJunit3Case.class, classpathRoot);
          String previousClassPath = System.getProperty("java.class.path");
          System.setProperty("java.class.path", classpathRoot.toString());
          try {
              TestCollector collector = newFreshLoadingTestCollector();
              List<String> collectedTestNames = collectTestNames(collector.collectTests());
  
              assertThat(collectedTestNames).contains(PublicJunit3Case.class.getName());
          } catch (Error error) {
              rethrowUnlessUnsupportedDynamicClassLoading(error);
          } finally {
              restoreProperty("java.class.path", previousClassPath);
          }
      }
  
      private static TestCollector newFreshLoadingTestCollector() throws ReflectiveOperationException {
          ClassLoader parent = LoadingTestCollectorTest.class.getClassLoader();
          ClassLoader classLoader = new FreshLoadingTestCollectorClassLoader(parent);
          return classLoader.loadClass(LoadingTestCollector.class.getName())
                  .asSubclass(TestCollector.class)
                  .getConstructor()
                  .newInstance();
      }
  
      private static List<String> collectTestNames(Enumeration<?> collected) {
          List<String> collectedTestNames = new ArrayList<>();
          while (collected.hasMoreElements()) {
              collectedTestNames.add((String) collected.nextElement());
          }
          return collectedTestNames;
      }
  
      private static void copyClassFile(Class<?> fixtureClass, Path classpathRoot) throws IOException {
          String resourceName = fixtureClass.getName().replace('.', '/') + ".class";
          Path target = classpathRoot.resolve(resourceName);
          Files.createDirectories(target.getParent());
          try (InputStream inputStream = fixtureClass.getClassLoader().getResourceAsStream(resourceName)) {
              assertThat(inputStream).as(resourceName).isNotNull();
              Files.copy(inputStream, target);
          }
      }
  
      private static void restoreProperty(String name, String previousValue) {
          if (previousValue == null) {
              System.clearProperty(name);
          } else {
              System.setProperty(name, previousValue);
          }
      }
  
      private static void rethrowUnlessUnsupportedDynamicClassLoading(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static final class FreshLoadingTestCollectorClassLoader extends ClassLoader {
          private static final String TARGET_CLASS_NAME = "junit.runner.LoadingTestCollector";
  
          FreshLoadingTestCollectorClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!TARGET_CLASS_NAME.equals(name)) {
                  return super.loadClass(name, resolve);
              }
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      loadedClass = defineTargetClass();
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private Class<?> defineTargetClass() throws ClassNotFoundException {
              String resourceName = TARGET_CLASS_NAME.replace('.', '/') + ".class";
              try (InputStream inputStream = getParent().getResourceAsStream(resourceName)) {
                  if (inputStream == null) {
                      throw new ClassNotFoundException(TARGET_CLASS_NAME);
                  }
                  byte[] classBytes = inputStream.readAllBytes();
                  return defineClass(TARGET_CLASS_NAME, classBytes, 0, classBytes.length);
              } catch (IOException exception) {
                  throw new ClassNotFoundException(TARGET_CLASS_NAME, exception);
              }
          }
      }
  
      public static final class SuiteMethodFixture {
          public static junit.framework.Test suite() {
              return new TestSuite();
          }
      }
  
      public static final class PublicJunit3Case extends TestCase {
          public PublicJunit3Case(String name) {
              super(name);
          }
  
          public void testPasses() {
              assertTrue(true);
          }
      }
  }
