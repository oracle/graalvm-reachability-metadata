 childTemporaryFolder.create();\n            File childFolder = childTemporaryFolder.getRoot();\n\n            assertThat(parentFolder).isDirectory();\n            assertThat(childFolder).isDirectory();\n            assertThat(childFolder.getParentFile().getCanonicalFile()).isEqualTo(parentFolder.getCanonicalFile());\n        } finally {\n            if (childTemporaryFolder != null) {\n                childTemporaryFolder.delete();\n            }\n            parentTemporaryFolder.delete();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 349, "output": 1386, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 21703, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777950510999, "responseId": "resp_0f1afc637cd446c70169f95f2f73208195ad46ce17af28f10d"}}
