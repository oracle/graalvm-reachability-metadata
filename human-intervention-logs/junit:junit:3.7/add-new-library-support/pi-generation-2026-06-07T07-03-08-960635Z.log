idatedMethodAnnotation() {\n        System.clearProperty(VALIDATED_METHOD_PROPERTY);\n\n        List<Exception> validationErrors = new AnnotationsValidator()\n                .validateTestClass(new TestClass(ValidatedTestCase.class));\n\n        assertThat(validationErrors).isEmpty();\n        assertThat(System.getProperty(VALIDATED_METHOD_PROPERTY)).isEqualTo(\"passingTest\");\n    }\n"}, {"oldText": "    public static class RecordingMethodAnnotationValidator extends AnnotationValidator {\n        public RecordingMethodAnnotationValidator() {\n            VALIDATOR_CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public List<Exception> validateAnnotatedMethod(final FrameworkMethod method) {\n            VALIDATED_METHOD.set(method.getName());\n            return Collections.emptyList();\n        }\n    }\n", "newText": "    public static class RecordingMethodAnnotationValidator extends AnnotationValidator {\n        @Override\n        public List<Exception> validateAnnotatedMethod(final FrameworkMethod method) {\n            System.setProperty(VALIDATED_METHOD_PROPERTY, method.getName());\n            return Collections.emptyList();\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1227, "output": 1122, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 44333, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780815957496, "responseId": "resp_0442c01d25855ac2016a25185671e48195ab3e7add62e3c54f"}}
