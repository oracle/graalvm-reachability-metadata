  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  import java.util.Collections;
  import java.util.List;
  import java.util.concurrent.atomic.AtomicInteger;
  import java.util.concurrent.atomic.AtomicReference;
  
  import org.junit.jupiter.api.Test;
  import org.junit.runners.model.TestClass;
  import org.junit.validator.AnnotationValidator;
  import org.junit.validator.AnnotationsValidator;
  import org.junit.validator.ValidateWith;
  
  public class AnnotationValidatorFactoryTest {
      private static final AtomicInteger VALIDATOR_CONSTRUCTOR_CALLS = new AtomicInteger();
      private static final AtomicReference<Class<?>> VALIDATED_CLASS = new AtomicReference<>();
  
      @Test
      void createsAnnotationValidatorForValidatedClassAnnotation() {
          VALIDATOR_CONSTRUCTOR_CALLS.set(0);
          VALIDATED_CLASS.set(null);
  
          List<Exception> validationErrors = new AnnotationsValidator()
                  .validateTestClass(new TestClass(ValidatedTestCase.class));
  
          assertThat(validationErrors).isEmpty();
          assertThat(VALIDATOR_CONSTRUCTOR_CALLS).hasValue(1);
          assertThat(VALIDATED_CLASS).hasValue(ValidatedTestCase.class);
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      @ValidateWith(RecordingAnnotationValidator.class)
      public @interface ValidatedAnnotation {
      }
  
      @ValidatedAnnotation
      public static class ValidatedTestCase {
          @org.junit.Test
          public void passingTest() {
          }
      }
  
      public static class RecordingAnnotationValidator extends AnnotationValidator {
          public RecordingAnnotationValidator() {
              VALIDATOR_CONSTRUCTOR_CALLS.incrementAndGet();
          }
  
          @Override
          public List<Exception> validateAnnotatedClass(final TestClass testClass) {
              VALIDATED_CLASS.set(testClass.getJavaClass());
              return Collections.emptyList();
          }
      }
  }
