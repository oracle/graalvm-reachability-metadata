sAnnotationValidatorForValidatedClassAnnotation() {\n        VALIDATOR_CONSTRUCTOR_CALLS.set(0);\n        VALIDATED_CLASS.set(null);\n\n        Result result = JUnitCore.runClasses(ValidatedTestCase.class);\n\n        assertThat(result.wasSuccessful()).isTrue();\n        assertThat(result.getRunCount()).isEqualTo(1);\n        assertThat(VALIDATOR_CONSTRUCTOR_CALLS).hasValue(1);\n        assertThat(VALIDATED_CLASS).hasValue(ValidatedTestCase.class);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    @ValidateWith(RecordingAnnotationValidator.class)\n    public @interface ValidatedAnnotation {\n    }\n\n    @ValidatedAnnotation\n    public static class ValidatedTestCase {\n        @org.junit.Test\n        public void passingTest() {\n        }\n    }\n\n    public static class RecordingAnnotationValidator extends AnnotationValidator {\n        public RecordingAnnotationValidator() {\n            VALIDATOR_CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public List<Exception> validateAnnotatedClass(final TestClass testClass) {\n            VALIDATED_CLASS.set(testClass.getJavaClass());\n            return Collections.emptyList();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1164, "output": 747, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 30071, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780815759294, "responseId": "resp_0442c01d25855ac2016a25178ffbb48195938d20e007da8b84"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ojl4bxg1dxX946iB1hq6qMIn|fc_0442c01d25855ac2016a251796876481959e7b81d346a3f7c9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2194 bytes to tests/src/junit/junit/3.7/src/test/java/junit_junit/AnnotationValidatorFactoryTest.java"}], "isError": false, "timestamp": 1780815771029}]}
