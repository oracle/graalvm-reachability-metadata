ew JButton(\"Run\");\r\n   176\t\t\tfRerunButton.setEnabled(false);\r\n   177\t\t\tfRerunButton.addActionListener(\r\n   178\t\t\t\tnew ActionListener() {\r\n   179\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   180\t\t\t\t\t\trerun();\r\n   181\t\t\t\t\t}\r\n   182\t\t\t\t}\r\n   183\t\t\t);\r\n   184\t\t\tfailedPanel.add(fRerunButton);\r\n   185\t\t\treturn failedPanel;\r\n   186\t\t}\r\n   187\t\t\t\t\r\n   188\t\tprotected FailureDetailView createFailureDetailView() {\r\n   189\t\t\tString className= BaseTestRunner.getPreference(FAILUREDETAILVIEW_KEY);\r\n   190\t\t\tif (className != null) {\t\t\t\r\n   191\t\t\t\tClass viewClass= null;\r\n   192\t\t\t\ttry {\r\n   193\t\t\t\t\tviewClass= Class.forName(className);\r\n   194\t\t\t\t\treturn (FailureDetailView)viewClass.newInstance();\r\n   195\t\t\t\t} catch(Exception e) {\r\n   196\t\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"Could not create Failure DetailView - using default view\");\r\n   197\t\t\t\t}\r\n   198\t\t\t}\r\n   199\t\t\treturn new DefaultFailureDetailView();\r\n   200\t\t}\r\n   201\t\r\n   202\t\t/**\r\n   203\t\t * Creates the JUnit menu. Clients override this\r\n   204\t\t * method to add additional menu items.\r\n   205\t\t */\r\n   206\t\tprotected JMenu createJUnitMenu() {\r\n   207\t\t\tJMenu menu= new JMenu(\"JUnit\");\r\n   208\t\t\tmenu.setMnemonic('J');\r\n   209\t\t\tJMenuItem mi1= new JMenuItem(\"About...\");\r\n   210\t\t\tmi1.addActionListener(\r\n   211\t\t\t    new ActionListener() {\r\n   212\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   213\t\t\t            about();\r\n   214\t\t\t        }\r\n   215\t\t\t    }\r\n   216\t\t\t);\r\n   217\t\t\tmi1.setMnemonic('A');\r\n   218\t\t\tmenu.add(mi1);\r\n   219\t\t\t\r\n   220\t\t\tmenu.addSeparator();\r\n   221\t\t\tJMenuItem mi2= new JMenuItem(\" Exit \");\r\n   222\t\t\tmi2.addActionListener(\r\n   223\t\t\t    new ActionListener() {\r\n   224\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   225\t\t\t            terminate();\r\n   226\t\t\t        }\r\n   227\t\t\t    }\r\n   228\t\t\t);\r\n   229\t\t\tmi2.setMnemonic('x');\r\n   230\t\t\tmenu.add(mi2);\r\n   231\t\r\n   232\t\t\treturn menu;\r\n   233\t\t}\r\n   234\t\t\r\n   235\t\tprotected JFrame createFrame(String title) {\r\n   236\t\t\tJFrame frame= new JFrame(\"JUnit\");\r\n   237\t\t\tImage icon= loadFrameIcon();\t\r\n   238\t\t\tif (icon != null)\r\n   239\t\t\t\tframe.setIconImage(icon);\r\n   240\t\t\tframe.getContentPane().setLayout(new BorderLayout(0, 0));\r\n   241\t\t\t\r\n   242\t\t\tframe.addWindowListener(\r\n   243\t\t\t\tnew WindowAdapter() {\r\n   244\t\t\t\t\tpublic void windowClosing(WindowEvent e) {\r\n   245\t\t\t\t\t\tterminate();\r\n   246\t\t\t\t\t}\r\n   247\t\t\t\t}\r\n   248\t\t\t);\r\n   249\t\t\treturn frame;\r\n   250\t\t}\r\n   251\t\t\r\n   252\t\tprotected JLabel createLogo() {\r\n   253\t\t\tJLabel label;\r\n   254\t\t\tIcon icon= getIconResource(BaseTestRunner.class, \"logo.gif\");\r\n   255\t\t\tif (icon != null) \r\n   256\t\t\t\tlabel= new JLabel(icon);\r\n   257\t\t\telse\r\n   258\t\t\t\tlabel= new JLabel(\"JV\");\r\n   259\t\t\tlabel.setToolTipText(\"JUnit Version \"+Version.id());\r\n   260\t\t\treturn label;\r\n   261\t\t}\r\n   262\t\t\r\n   263\t\tprotected void createMenus(JMenuBar mb) {\r\n   264\t\t\tmb.add(createJUnitMenu());\r\n   265\t\t}\r\n   266\t\t\t\r\n   267\t\tprotected JCheckBox createUseLoaderCheckBox() {\r\n   268\t\t\tboolean useLoader= useReloadingTestSuiteLoader();\r\n   269\t\t\tJCheckBox box= new JCheckBox(\"Reload classes every run\", useLoader);\r\n   270\t\t\tbox.setToolTipText(\"Use a custom class loader to reload the classes for every run\");\r\n   271\t\t\tif (inVAJava())\r\n   272\t\t\t\tbox.setVisible(false);\r\n   273\t\t\treturn box;\r\n   274\t\t}\r\n   275\t\t\r\n   276\t\tprotected JButton createQuitButton() {\r\n   277\t\t\t // spaces required to avoid layout flicker\r\n   278\t\t\t // Exit is shorter than Stop that shows in the same column\r\n   279\t\t\tJButton quit= new JButton(\" Exit \"); \r\n   280\t\t\tquit.addActionListener(\r\n   281\t\t\t\tnew ActionListener() {\r\n   282\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   283\t\t\t\t\t\tterminate();\r\n   284\t\t\t\t\t}\r\n   285\t\t\t\t}\r\n   286\t\t\t);\r\n   287\t\t\treturn quit;\r\n   288\t\t}\r\n   289\t\t\r\n   290\t\tprotected JButton createRunButton() {\r\n   291\t\t\tJButton run= new JButton(\"Run\");\r\n   292\t\t\trun.setEnabled(true);\r\n   293\t\t\trun.addActionListener(\r\n   294\t\t\t\tnew ActionListener() {\r\n   295\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   296\t\t\t\t\t\trunSuite();\r\n   297\t\t\t\t\t}\r\n   298\t\t\t\t}\r\n   299\t\t\t);\r\n   300\t\t\treturn run;\r\n   301\t\t}\r\n   302\t\t\r\n   303\t\tprotected Component createBrowseButton() {\r\n   304\t\t\tJButton browse= new JButton(\"...\");\r\n   305\t\t\tbrowse.setToolTipText(\"Select a Test class\");\r\n   306\t\t\tbrowse.addActionListener(\r\n   307\t\t\t\tnew ActionListener() {\r\n   308\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   309\t\t\t\t\t\tbrowseTestClasses();\r\n   310\t\t\t\t\t}\r\n   311\t\t\t\t}\r\n   312\t\t\t);\r\n   313\t\t\treturn browse;\t\t\r\n   314\t\t}\r\n   315\t\t\r\n   316\t\tprotected StatusLine createStatusLine() {\r\n   317\t\t\treturn new StatusLine(420);\r\n   318\t\t}\r\n   319\t\t\r\n   320\t\tprotected JComboBox createSuiteCombo() {\r\n   321\t\t\tJComboBox combo= new JComboBox();\r\n   322\t\t\tcombo.setEditable(true);\r\n   323\t\t\tcombo.setLightWeightPopupEnabled(false);\r\n   324\t\t\t\r\n   325\t\t\tcombo.getEditor().getEditorComponent().addKeyListener(\r\n   326\t\t\t\tnew KeyAdapter() {\r\n   327\t\t\t\t\tpublic void keyTyped(KeyEvent e) {\r\n   328\t\t\t\t\t\ttextChanged();\r\n   329\t\t\t\t\t\tif (e.getKeyChar() == KeyEvent.VK_ENTER)\r\n   330\t\t\t\t\t\t\trunSuite();\r\n   331\t\t\t\t\t}\r\n   332\t\t\t\t}\r\n   333\t\t\t);\r\n   334\t\t\ttry {\r\n   335\t\t\t\tloadHistory(combo);\r\n   336\t\t\t} catch (IOException e) {\r\n   337\t\t\t\t// fails the first time\r\n   338\t\t\t}\r\n   339\t\t\tcombo.addItemListener(\r\n   340\t\t\t\tnew ItemListener() {\r\n   341\t\t\t\t\tpublic void itemStateChanged(ItemEvent event) {\r\n   342\t\t\t\t\t\tif (event.getStateChange() == ItemEvent.SELECTED) {\r\n   343\t\t\t\t\t\t\ttextChanged();\r\n   344\t\t\t\t\t\t}\r\n   345\t\t\t\t\t}\r\n   346\t\t\t\t}\r\n   347\t\t\t);\r\n   348\t\t\treturn combo;\r\n   349\t\t}\r\n   350\t\t\r\n   351\t\tprotected JTabbedPane createTestRunViews() {\r\n   352\t\t\tJTabbedPane pane= new JTabbedPane(JTabbedPane.BOTTOM);\r\n   353\t\r\n   354\t\t\tFailureRunView lv= new FailureRunView(this);\r\n   355\t\t\tfTestRunViews.addElement(lv);\r\n   356\t\t\tlv.addTab(pane);\r\n   357\t\t\t\r\n   358\t\t\tTestHierarchyRunView tv= new TestHierarchyRunView(this);\r\n   359\t\t\tfTestRunViews.addElement(tv);\r\n   360\t\t\ttv.addTab(pane);\r\n   361\t\t\t\r\n   362\t\t\tpane.addChangeListener(\r\n   363\t\t\t\tnew ChangeListener() {\r\n   364\t\t\t\t\tpublic void stateChanged(ChangeEvent e) {\r\n   365\t\t\t\t\t\ttestViewChanged();\r\n   366\t\t\t\t\t}\r\n   367\t\t\t\t}\r\n   368\t\t\t);\r\n   369\t\t\treturn pane;\r\n   370\t\t}\r\n   371\t\t\r\n   372\t\tpublic void testViewChanged() {\r\n   373\t\t\tTestRunView view= (TestRunView)fTestRunViews.elementAt(fTestViewTab.getSelectedIndex());\r\n   374\t\t\tview.activate();\r\n   375\t\t}\r\n   376\t\t\r\n   377\t\tprotected TestResult createTestResult() {\r\n   378\t\t\treturn new TestResult();\r\n   379\t\t}\r\n   380\t\t\r\n   381\t\tprotected JFrame createUI(String suiteName) {\t\r\n   382\t\t\tJFrame frame= createFrame(\"JUnit\");\t\r\n   383\t\t\tJMenuBar mb= new JMenuBar();\r\n   384\t\t\tcreateMenus(mb);\r\n   385\t\t\tframe.setJMenuBar(mb);\r\n   386\t\t\r\n   387\t\t\tJLabel suiteLabel= new JLabel(\"Test class name:\");\r\n   388\t\t\tfSuiteCombo= createSuiteCombo();\r\n   389\t\t\tfRun= createRunButton();\r\n   390\t\t\tframe.getRootPane().setDefaultButton(fRun);\r\n   391\t\t\tComponent browseButton= createBrowseButton();\r\n   392\t\t\t\r\n   393\t\t\tfUseLoadingRunner= createUseLoaderCheckBox();\r\n   394\t\t\tfProgressIndicator= new ProgressBar();\r\n   395\t\t\tfCounterPanel= createCounterPanel();\r\n   396\t\t\t\r\n   397\t\t\tJLabel failureLabel= new JLabel(\"Errors and Failures:\");\r\n   398\t\t\tfFailures= new DefaultListModel();\r\n   399\t\t\t\r\n   400\t\t\tfTestViewTab= createTestRunViews();\t\r\n   401\t\t\tJPanel failedPanel= createFailedPanel();\r\n   402\t\t\t\r\n   403\t\t\tfFailureView= createFailureDetailView();\r\n   404\t\t\tJScrollPane tracePane= new JScrollPane(fFailureView.getComponent(), JScrollPane.VERTICAL_SCROLLBAR_ALWAYS, JScrollPane.HORIZONTAL_SCROLLBAR_ALWAYS);\r\n   405\t\r\n   406\t\t\tfStatusLine= createStatusLine();\r\n   407\t\t\tfQuitButton= createQuitButton();\r\n   408\t\t\tfLogo= createLogo();\r\n   409\t\t\t\t\t\t\r\n   410\t\t\tJPanel panel= new JPanel(new GridBagLayout());\r\n   411\t\t\r\n   412\t\t\taddGrid(panel, suiteLabel,\t0, 0, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   413\t\t\taddGrid(panel, fSuiteCombo, \t0, 1, 1, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   414\t\t\taddGrid(panel, browseButton, \t1, 1, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.WEST);\r\n   415\t\t\taddGrid(panel, fRun, \t\t2, 1, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   416\t\r\n   417\t\t\taddGrid(panel, fUseLoadingRunner,  \t0, 2, 3, GridBagConstraints.HORIZONTAL, 1.0, GridBagConstraints.WEST);\r\n   418\t\t\taddGrid(panel, new JSeparator(), \t0, 3, 3, GridBagConstraints.HORIZONTAL, 1.0, GridBagConstraints.WEST);\r\n   419\t\r\n   420\t\t\t\r\n   421\t\t\taddGrid(panel, fProgressIndicator, \t0, 4, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   422\t\t\taddGrid(panel, fLogo, \t\t\t2, 4, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.NORTH);\r\n   423\t\r\n   424\t\t\taddGrid(panel, fCounterPanel,\t 0, 5, 2, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.CENTER);\r\n   425\t\r\n   426\t\t\tJSplitPane splitter= new JSplitPane(JSplitPane.VERTICAL_SPLIT, fTestViewTab, tracePane);\r\n   427\t\t\taddGrid(panel, splitter, \t 0, 6, 2, GridBagConstraints.BOTH, \t\t\t1.0, GridBagConstraints.WEST);\t\t\t\t\r\n   428\t\r\n   429\t\t\taddGrid(panel, failedPanel, \t 2, 6, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.NORTH/*CENTER*/);\r\n   430\t\t\t\r\n   431\t\t\taddGrid(panel, fStatusLine, \t 0, 8, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.CENTER);\r\n   432\t\t\taddGrid(panel, fQuitButton, \t 2, 8, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   433\t\t\t\r\n   434\t\t\tframe.setContentPane(panel);\r\n   435\t\t\tframe.pack();\r\n   436\t\t\tframe.setLocation(200, 200);\r\n   437\t\t\treturn frame;\r\n   438\t\t}\r\n   439\t\r\n   440\t\tprivate void addGrid(JPanel p, Component co, int x, int y, int w, int fill, double wx, int anchor) {\r\n   441\t\t\tGridBagConstraints c= new GridBagConstraints();\r\n   442\t\t\tc.gridx= x; c.gridy= y;\r\n   443\t\t\tc.gridwidth= w;\r\n   444\t\t\tc.anchor= anchor;\r\n   445\t\t\tc.weightx= wx;\r\n   446\t\t\tc.fill= fill;\r\n   447\t\t\tif (fill == GridBagConstraints.BOTH || fill == GridBagConstraints.VERTICAL)\r\n   448\t\t\t\tc.weighty= 1.0;\r\n   449\t\t\tc.insets= new Insets(y == 0 ? GAP : 0, x == 0 ? GAP : 0, GAP, GAP);\r\n   450\t\t\tp.add(co, c);\r\n   451\t\t}\r\n   452\t\r\n   453\t\tprotected String getSuiteText() {\r\n   454\t\t\tif (fSuiteCombo == null)\r\n   455\t\t\t\treturn \"\";\r\n   456\t\t\treturn (String)fSuiteCombo.getEditor().getItem();\r\n   457\t\t}\r\n   458\t\t\r\n   459\t\tpublic ListModel getFailures() {\r\n   460\t\t\treturn fFailures;\r\n   461\t\t}\r\n   462\t\t\r\n   463\t\tpublic void insertUpdate(DocumentEvent event) {\r\n   464\t\t\ttextChanged();\r\n   465\t\t}\r\n   466\t\t\t\r\n   467\t\tpublic void browseTestClasses() {\r\n   468\t\t\tTestCollector collector= createTestCollector();\t\t\r\n   469\t\t\tTestSelector selector= new TestSelector(fFrame, collector);\r\n   470\t\t\tif (selector.isEmpty()) {\r\n   471\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"No Test Cases found.\\nCheck that the configured \\'TestCollector\\' is supported on this platform.\");\r\n   472\t\t\t\treturn;\r\n   473\t\t\t}\r\n   474\t\t\tselector.show();\r\n   475\t\t\tString className= selector.getSelectedItem();\r\n   476\t\t\tif (className != null)\r\n   477\t\t\t\tsetSuite(className);\r\n   478\t\t}\r\n   479\t\r\n   480\t\tTestCollector createTestCollector() {\r\n   481\t\t\tString className= BaseTestRunner.getPreference(TESTCOLLECTOR_KEY);\r\n   482\t\t\tif (className != null) {\t\t\t\r\n   483\t\t\t\tClass collectorClass= null;\r\n   484\t\t\t\ttry {\r\n   485\t\t\t\t\tcollectorClass= Class.forName(className);\r\n   486\t\t\t\t\treturn (TestCollector)collectorClass.newInstance();\r\n   487\t\t\t\t} catch(Exception e) {\r\n   488\t\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"Could not create TestCollector - using default collector\");\r\n   489\t\t\t\t}\r\n   490\t\t\t}\r\n   491\t\t\treturn new SimpleTestCollector();\r\n   492\t\t}\r\n   493\t\t\r\n   494\t\tprivate Image loadFrameIcon() {\r\n   495\t\t\tImageIcon icon= (ImageIcon)getIconResource(BaseTestRunner.class, \"smalllogo.gif\");\r\n   496\t\t\tif (icon != null)\r\n   497\t\t\t\treturn icon.getImage();\r\n   498\t\t\treturn null;\r\n   499\t\t}\r\n   500\t\t\r\n   501\t\tprivate void loadHistory(JComboBox combo) throws IOException {\r\n   502\t\t\tBufferedReader br= new BufferedReader(new FileReader(getSettingsFile()));\r\n   503\t\t\tint itemCount= 0;\r\n   504\t\t\ttry {\r\n   505\t\t\t\tString line;\r\n   506\t\t\t\twhile ((line= br.readLine()) != null) {\r\n   507\t\t\t\t\tcombo.addItem(line);\r\n   508\t\t\t\t\titemCount++;\r\n   509\t\t\t\t}\r\n   510\t\t\t\tif (itemCount > 0)\r\n   511\t\t\t\t\tcombo.setSelectedIndex(0);\r\n   512\t\r\n   513\t\t\t} finally {\r\n   514\t\t\t\tbr.close();\r\n   515\t\t\t}\r\n   516\t\t}\r\n   517\t\t\r\n   518\t\tprivate File getSettingsFile() {\r\n   519\t\t \tString home= System.getProperty(\"user.home\");\r\n   520\t \t\treturn new File(home,\".junitsession\");\r\n   521\t \t}\r\n   522\t\t\r\n   523\t\tprivate void postInfo(final String message) {\r\n   524\t\t\tSwingUtilities.invokeLater(\r\n   525\t\t\t\tnew Runnable() {\r\n   526\t\t\t\t\tpublic void run() {\r\n   527\t\t\t\t\t\tshowInfo(message);\r\n   528\t\t\t\t\t}\r\n   529\t\t\t\t}\r\n   530\t\t\t);\r\n   531\t\t}\r\n   532\t\t\r\n   533\t\tprivate void postStatus(final String status) {\r\n   534\t\t\tSwingUtilities.invokeLater(\r\n   535\t\t\t\tnew Runnable() {\r\n   536\t\t\t\t\tpublic void run() {\r\n   537\t\t\t\t\t\tshowStatus(status);\r\n   538\t\t\t\t\t}\r\n   539\t\t\t\t}\r\n   540\t\t\t);\r\n   541\t\t}\r\n   542\t\t\r\n   543\t\tpublic void removeUpdate(DocumentEvent event) {\r\n   544\t\t\ttextChanged();\r\n   545\t\t}\r\n   546\t\t\r\n   547\t\tprivate void rerun() {\r\n   548\t\t\tTestRunView view= (TestRunView)fTestRunViews.elementAt(fTestViewTab.getSelectedIndex());\r\n   549\t\t\tTest rerunTest= view.getSelectedTest();\r\n   550\t\t\tif (rerunTest != null)\r\n   551\t\t\t\trerunTest(rerunTest);\r\n   552\t\t}\r\n   553\t\t\r\n   554\t\tprivate void rerunTest(Test test) {\r\n   555\t\t\tif (!(test instanceof TestCase)) {\r\n   556\t\t\t\tshowInfo(\"Could not reload \"+ test.toString());\r\n   557\t\t\t\treturn;\r\n   558\t\t\t}\r\n   559\t\t\tTest reloadedTest= null;\r\n   560\t\t\ttry {\r\n   561\t\t\t\tClass reloadedTestClass= getLoader().reload(test.getClass());\r\n   562\t\t\t\tClass[] classArgs= { String.class };\r\n   563\t\t\t\tObject[] args= new Object[]{((TestCase)test).getName()};\r\n   564\t\t\t\tConstructor constructor= reloadedTestClass.getConstructor(classArgs);\