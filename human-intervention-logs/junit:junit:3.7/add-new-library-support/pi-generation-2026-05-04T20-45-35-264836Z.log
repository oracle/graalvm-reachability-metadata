[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_YgDyKlqkQz8YEKiNEsuhe2KT|fc_071b59dec39b2f740169f904b5c72081a0a739f24e3a9d1da0", "toolName": "bash", "content": [{"type": "text", "text": "     1\tpackage junit.swingui;\r\n     2\t\r\n     3\timport junit.framework.*;\r\n     4\timport junit.runner.*;\r\n     5\t\r\n     6\timport java.util.*;\r\n     7\timport java.lang.reflect.*;\r\n     8\timport java.text.NumberFormat;\r\n     9\timport java.net.URL;\r\n    10\timport java.io.*;\r\n    11\t\r\n    12\timport javax.swing.*;\r\n    13\timport javax.swing.event.*;\r\n    14\timport javax.swing.text.*;\r\n    15\timport java.awt.*;\r\n    16\timport java.awt.event.*;\r\n    17\timport java.awt.image.*;\r\n    18\t\r\n    19\t/**\r\n    20\t * A Swing based user interface to run tests.\r\n    21\t * Enter the name of a class which either provides a static\r\n    22\t * suite method or is a subclass of TestCase.\r\n    23\t * <pre>\r\n    24\t * Synopsis: java junit.swingui.TestRunner [-noloading] [TestCase]\r\n    25\t * </pre>\r\n    26\t * TestRunner takes as an optional argument the name of the testcase class to be run.\r\n    27\t */\r\n    28\tpublic class TestRunner extends BaseTestRunner implements TestRunContext {\r\n    29\t\tprotected JFrame fFrame;\r\n    30\t\tprivate Thread fRunner;\r\n    31\t\tprivate TestResult fTestResult;\r\n    32\t\t\r\n    33\t\tprivate JComboBox fSuiteCombo;\r\n    34\t\tprivate ProgressBar fProgressIndicator;\r\n    35\t\tprivate DefaultListModel fFailures;\r\n    36\t\tprivate JLabel fLogo;\r\n    37\t\tprivate CounterPanel fCounterPanel;\r\n    38\t\tprivate JButton fRun;\r\n    39\t\tprivate JButton fQuitButton;\r\n    40\t\tprivate JButton fRerunButton;\r\n    41\t\tprivate StatusLine fStatusLine;\r\n    42\t\tprivate FailureDetailView fFailureView;\r\n    43\t\tprivate JTabbedPane fTestViewTab;\r\n    44\t\tprivate JCheckBox fUseLoadingRunner;\r\n    45\t\tprivate Vector fTestRunViews= new Vector(); // view associated with tab in tabbed pane\r\n    46\t\tprivate static Font PLAIN_FONT= StatusLine.PLAIN_FONT;\r\n    47\t\tprivate static Font BOLD_FONT= StatusLine.BOLD_FONT;\r\n    48\t\tprivate static final int GAP= 4;\r\n    49\t\tprivate static final int HISTORY_LENGTH= 5;\r\n    50\t\r\n    51\t\tprivate static final String TESTCOLLECTOR_KEY= \"TestCollectorClass\";\r\n    52\t\tprivate static final String FAILUREDETAILVIEW_KEY= \"FailureViewClass\";\r\n    53\t\t\t\r\n    54\t\tpublic TestRunner() {\r\n    55\t\t} \r\n    56\t\t\r\n    57\t\tpublic static void main(String[] args) {\r\n    58\t\t\tnew TestRunner().start(args);\r\n    59\t\t}\r\n    60\t\t \r\n    61\t\tpublic static void run(Class test) {\r\n    62\t\t\tString args[]= { test.getName() };\r\n    63\t\t\tmain(args);\r\n    64\t\t}\r\n    65\t\t\r\n    66\t\tpublic void addError(final Test test, final Throwable t) {\r\n    67\t\t\tSwingUtilities.invokeLater(\r\n    68\t\t\t\tnew Runnable() {\r\n    69\t\t\t\t\tpublic void run() {\r\n    70\t\t\t\t\t\tfCounterPanel.setErrorValue(fTestResult.errorCount());\r\n    71\t\t\t\t\t\tappendFailure(\"Error\", test, t);\r\n    72\t\t\t\t\t}\r\n    73\t\t\t\t}\r\n    74\t\t\t);\r\n    75\t\t}\r\n    76\t\t\r\n    77\t\tpublic void addFailure(final Test test, final AssertionFailedError t) {\r\n    78\t\t\tSwingUtilities.invokeLater(\r\n    79\t\t\t\tnew Runnable() {\r\n    80\t\t\t\t\tpublic void run() {\r\n    81\t\t\t\t\t\tfCounterPanel.setFailureValue(fTestResult.failureCount());\r\n    82\t\t\t\t\t\tappendFailure(\"Failure\", test, t);\r\n    83\t\t\t\t\t}\r\n    84\t\t\t\t}\t\t\r\n    85\t\t\t);\r\n    86\t\t}\r\n    87\t\t\r\n    88\t\tpublic void startTest(Test test) {\r\n    89\t\t\tpostInfo(\"Running: \"+test);\r\n    90\t\t}\r\n    91\t\t\r\n    92\t\tpublic void endTest(Test test) {\r\n    93\t\t\tpostEndTest(test);\r\n    94\t\t}\r\n    95\t\r\n    96\t\tprivate void postEndTest(final Test test) {\r\n    97\t\t\tsynchUI();\r\n    98\t\t\tSwingUtilities.invokeLater(\r\n    99\t\t\t\tnew Runnable() {\r\n   100\t\t\t\t\tpublic void run() {\r\n   101\t\t\t\t\t\tif (fTestResult != null) {\r\n   102\t\t\t\t\t\t\tfCounterPanel.setRunValue(fTestResult.runCount());\r\n   103\t\t\t\t\t\t\tfProgressIndicator.step(fTestResult.wasSuccessful());\r\n   104\t\t\t\t\t\t}\r\n   105\t\t\t\t\t}\r\n   106\t\t\t\t}\r\n   107\t\t\t);\r\n   108\t\t}\r\n   109\t\r\n   110\t\tpublic void setSuite(String suiteName) {\r\n   111\t\t\tfSuiteCombo.getEditor().setItem(suiteName);\r\n   112\t\t}\r\n   113\t\r\n   114\t\tprivate void addToHistory(final String suite) {\r\n   115\t\t\tfor (int i= 0; i < fSuiteCombo.getItemCount(); i++) {\r\n   116\t\t\t\tif (suite.equals(fSuiteCombo.getItemAt(i))) {\r\n   117\t\t\t\t\tfSuiteCombo.removeItemAt(i);\r\n   118\t\t\t\t\tfSuiteCombo.insertItemAt(suite, 0);\r\n   119\t\t\t\t\tfSuiteCombo.setSelectedIndex(0);\r\n   120\t\t\t\t\treturn;\r\n   121\t\t\t\t}\r\n   122\t\t\t}\r\n   123\t\t\tfSuiteCombo.insertItemAt(suite, 0);\r\n   124\t\t\tfSuiteCombo.setSelectedIndex(0);\r\n   125\t\t\tpruneHistory();\r\n   126\t\t}\r\n   127\t\t\r\n   128\t\tprivate void pruneHistory() {\r\n   129\t\t\tint historyLength= getPreference(\"maxhistory\", HISTORY_LENGTH);\r\n   130\t\t\tif (historyLength < 1)\r\n   131\t\t\t\thistoryLength= 1;\r\n   132\t\t\tfor (int i= fSuiteCombo.getItemCount()-1; i > historyLength-1; i--) \r\n   133\t\t\t\tfSuiteCombo.removeItemAt(i);\r\n   134\t\t}\r\n   135\t\t\r\n   136\t\tprivate void appendFailure(String kind, Test test, Throwable t) {\r\n   137\t\t\tfFailures.addElement(new TestFailure(test, t));\r\n   138\t\t\tif (fFailures.size() == 1) \r\n   139\t\t\t\trevealFailure(test);\r\n   140\t\t}\r\n   141\t\t\r\n   142\t\tprivate void revealFailure(Test test) {\r\n   143\t\t\tfor (Enumeration e= fTestRunViews.elements(); e.hasMoreElements(); ) {\r\n   144\t\t\t\tTestRunView v= (TestRunView) e.nextElement();\r\n   145\t\t\t\tv.revealFailure(test);\r\n   146\t\t\t}\r\n   147\t\t}\r\n   148\t\t\t\r\n   149\t\tprotected void aboutToStart(final Test testSuite) {\r\n   150\t\t\tfor (Enumeration e= fTestRunViews.elements(); e.hasMoreElements(); ) {\r\n   151\t\t\t\tTestRunView v= (TestRunView) e.nextElement();\r\n   152\t\t\t\tv.aboutToStart(testSuite, fTestResult);\r\n   153\t\t\t}\r\n   154\t\t}\r\n   155\t\t\r\n   156\t\tprotected void runFinished(final Test testSuite) {\r\n   157\t\t\tSwingUtilities.invokeLater(\r\n   158\t\t\t\tnew Runnable() {\r\n   159\t\t\t\t\tpublic void run() {\r\n   160\t\t\t\t\t\tfor (Enumeration e= fTestRunViews.elements(); e.hasMoreElements(); ) {\r\n   161\t\t\t\t\t\t\tTestRunView v= (TestRunView) e.nextElement();\r\n   162\t\t\t\t\t\t\tv.runFinished(testSuite, fTestResult);\r\n   163\t\t\t\t\t\t}\r\n   164\t\t\t\t\t}\r\n   165\t\t\t\t}\r\n   166\t\t\t);\r\n   167\t\t}\r\n   168\t\r\n   169\t\tprotected CounterPanel createCounterPanel() {\r\n   170\t\t\treturn new CounterPanel();\r\n   171\t\t}\r\n   172\t\t\r\n   173\t\tprotected JPanel createFailedPanel() {\r\n   174\t\t\tJPanel failedPanel= new JPanel(new GridLayout(0, 1, 0, 2));\r\n   175\t\t\tfRerunButton= new JButton(\"Run\");\r\n   176\t\t\tfRerunButton.setEnabled(false);\r\n   177\t\t\tfRerunButton.addActionListener(\r\n   178\t\t\t\tnew ActionListener() {\r\n   179\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   180\t\t\t\t\t\trerun();\r\n   181\t\t\t\t\t}\r\n   182\t\t\t\t}\r\n   183\t\t\t);\r\n   184\t\t\tfailedPanel.add(fRerunButton);\r\n   185\t\t\treturn failedPanel;\r\n   186\t\t}\r\n   187\t\t\t\t\r\n   188\t\tprotected FailureDetailView createFailureDetailView() {\r\n   189\t\t\tString className= BaseTestRunner.getPreference(FAILUREDETAILVIEW_KEY);\r\n   190\t\t\tif (className != null) {\t\t\t\r\n   191\t\t\t\tClass viewClass= null;\r\n   192\t\t\t\ttry {\r\n   193\t\t\t\t\tviewClass= Class.forName(className);\r\n   194\t\t\t\t\treturn (FailureDetailView)viewClass.newInstance();\r\n   195\t\t\t\t} catch(Exception e) {\r\n   196\t\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"Could not create Failure DetailView - using default view\");\r\n   197\t\t\t\t}\r\n   198\t\t\t}\r\n   199\t\t\treturn new DefaultFailureDetailView();\r\n   200\t\t}\r\n   201\t\r\n   202\t\t/**\r\n   203\t\t * Creates the JUnit menu. Clients override this\r\n   204\t\t * method to add additional menu items.\r\n   205\t\t */\r\n   206\t\tprotected JMenu createJUnitMenu() {\r\n   207\t\t\tJMenu menu= new JMenu(\"JUnit\");\r\n   208\t\t\tmenu.setMnemonic('J');\r\n   209\t\t\tJMenuItem mi1= new JMenuItem(\"About...\");\r\n   210\t\t\tmi1.addActionListener(\r\n   211\t\t\t    new ActionListener() {\r\n   212\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   213\t\t\t            about();\r\n   214\t\t\t        }\r\n   215\t\t\t    }\r\n   216\t\t\t);\r\n   217\t\t\tmi1.setMnemonic('A');\r\n   218\t\t\tmenu.add(mi1);\r\n   219\t\t\t\r\n   220\t\t\tmenu.addSeparator();\r\n   221\t\t\tJMenuItem mi2= new JMenuItem(\" Exit \");\r\n   222\t\t\tmi2.addActionListener(\r\n   223\t\t\t    new ActionListener() {\r\n   224\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   225\t\t\t            terminate();\r\n   226\t\t\t        }\r\n   227\t\t\t    }\r\n   228\t\t\t);\r\n   229\t\t\tmi2.setMnemonic('x');\r\n   230\t\t\tmenu.add(mi2);\r\n   231\t\r\n   232\t\t\treturn menu;\r\n   233\t\t}\r\n   234\t\t\r\n   235\t\tprotected JFrame createFrame(String title) {\r\n   236\t\t\tJFrame frame= new JFrame(\"JUnit\");\r\n   237\t\t\tImage icon= loadFrameIcon();\t\r\n   238\t\t\tif (icon != null)\r\n   239\t\t\t\tframe.setIconImage(icon);\r\n   240\t\t\tframe.getContentPane().setLayout(new BorderLayout(0, 0));\r\n   241\t\t\t\r\n   242\t\t\tframe.addWindowListener(\r\n   243\t\t\t\tnew WindowAdapter() {\r\n   244\t\t\t\t\tpublic void windowClosing(WindowEvent e) {\r\n   245\t\t\t\t\t\tterminate();\r\n   246\t\t\t\t\t}\r\n   247\t\t\t\t}\r\n   248\t\t\t);\r\n   249\t\t\treturn frame;\r\n   250\t\t}\r\n   251\t\t\r\n   252\t\tprotected JLabel createLogo() {\r\n   253\t\t\tJLabel label;\r\n   254\t\t\tIcon icon= getIconResource(BaseTestRunner.class, \"logo.gif\");\r\n   255\t\t\tif (icon != null) \r\n   256\t\t\t\tlabel= new JLabel(icon);\r\n   257\t\t\telse\r\n   258\t\t\t\tlabel= new JLabel(\"JV\");\r\n   259\t\t\tlabel.setToolTipText(\"JUnit Version \"+Version.id());\r\n   260\t\t\treturn label;\r\n   261\t\t}\r\n   262\t\t\r\n   263\t\tprotected void createMenus(JMenuBar mb) {\r\n   264\t\t\tmb.add(createJUnitMenu());\r\n   265\t\t}\r\n   266\t\t\t\r\n   267\t\tprotected JCheckBox createUseLoaderCheckBox() {\r\n   268\t\t\tboolean useLoader= useReloadingTestSuiteLoader();\r\n   269\t\t\tJCheckBox box= new JCheckBox(\"Reload classes every run\", useLoader);\r\n   270\t\t\tbox.setToolTipText(\"Use a custom class loader to reload the classes for every run\");\r\n   271\t\t\tif (inVAJava())\r\n   272\t\t\t\tbox.setVisible(false);\r\n   273\t\t\treturn box;\r\n   274\t\t}\r\n   275\t\t\r\n   276\t\tprotected JButton createQuitButton() {\r\n   277\t\t\t // spaces required to avoid layout flicker\r\n   278\t\t\t // Exit is shorter than Stop that shows in the same column\r\n   279\t\t\tJButton quit= new JButton(\" Exit \"); \r\n   280\t\t\tquit.addActionListener(\r\n   281\t\t\t\tnew ActionListener() {\r\n   282\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   283\t\t\t\t\t\tterminate();\r\n   284\t\t\t\t\t}\r\n   285\t\t\t\t}\r\n   286\t\t\t);\r\n   287\t\t\treturn quit;\r\n   288\t\t}\r\n   289\t\t\r\n   290\t\tprotected JButton createRunButton() {\r\n   291\t\t\tJButton run= new JButton(\"Run\");\r\n   292\t\t\trun.setEnabled(true);\r\n   293\t\t\trun.addActionListener(\r\n   294\t\t\t\tnew ActionListener() {\r\n   295\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   296\t\t\t\t\t\trunSuite();\r\n   297\t\t\t\t\t}\r\n   298\t\t\t\t}\r\n   299\t\t\t);\r\n   300\t\t\treturn run;\r\n   301\t\t}\r\n   302\t\t\r\n   303\t\tprotected Component createBrowseButton() {\r\n   304\t\t\tJButton browse= new JButton(\"...\");\r\n   305\t\t\tbrowse.setToolTipText(\"Select a Test class\");\r\n   306\t\t\tbrowse.addActionListener(\r\n   307\t\t\t\tnew ActionListener() {\r\n   308\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   309\t\t\t\t\t\tbrowseTestClasses();\r\n   310\t\t\t\t\t}\r\n   311\t\t\t\t}\r\n   312\t\t\t);\r\n   313\t\t\treturn browse;\t\t\r\n   314\t\t}\r\n   315\t\t\r\n   316\t\tprotected StatusLine createStatusLine() {\r\n   317\t\t\treturn new StatusLine(420);\r\n   318\t\t}\r\n   319\t\t\r\n   320\t\tprotected JComboBox createSuiteCombo() {\r\n   321\t\t\tJComboBox combo= new JComboBox();\r\n   322\t\t\tcombo.setEditable(true);\r\n   323\t\t\tcombo.setLightWeightPopupEnabled(false);\r\n   324\t\t\t\r\n   325\t\t\tcombo.getEditor().getEditorComponent().addKeyListener(\r\n   326\t\t\t\tnew KeyAdapter() {\r\n   327\t\t\t\t\tpublic void keyTyped(KeyEvent e) {\r\n   328\t\t\t\t\t\ttextChanged();\r\n   329\t\t\t\t\t\tif (e.getKeyChar() == KeyEvent.VK_ENTER)\r\n   330\t\t\t\t\t\t\trunSuite();\r\n   331\t\t\t\t\t}\r\n   332\t\t\t\t}\r\n   333\t\t\t);\r\n   334\t\t\ttry {\r\n   335\t\t\t\tloadHistory(combo);\r\n   336\t\t\t} catch (IOException e) {\r\n   337\t\t\t\t// fails the first time\r\n   338\t\t\t}\r\n   339\t\t\tcombo.addItemListener(\r\n   340\t\t\t\tnew ItemListener() {\r\n   341\t\t\t\t\tpublic void itemStateChanged(ItemEvent event) {\r\n   342\t\t\t\t\t\tif (event.getStateChange() == ItemEvent.SELECTED) {\r\n   343\t\t\t\t\t\t\ttextChanged();\r\n   344\t\t\t\t\t\t}\r\n   345\t\t\t\t\t}\r\n   346\t\t\t\t}\r\n   347\t\t\t);\r\n   348\t\t\treturn combo;\r\n   349\t\t}\r\n   350\t\t\r\n   351\t\tprotected JTabbedPane createTestRunViews() {\r\n   352\t\t\tJTabbedPane pane= new JTabbedPane(JTabbedPane.BOTTOM);\r\n   353\t\r\n   354\t\t\tFailureRunView lv= new FailureRunView(this);\r\n   355\t\t\tfTestRunViews.addElement(lv);\r\n   356\t\t\tlv.addTab(pane);\r\n   357\t\t\t\r\n   358\t\t\tTestHierarchyRunView tv= new TestHierarchyRunView(this);\r\n   359\t\t\tfTestRunViews.addElement(tv);\r\n   360\t\t\ttv.addTab(pane);\r\n   361\t\t\t\r\n   362\t\t\tpane.addChangeListener(\r\n   363\t\t\t\tnew ChangeListener() {\r\n   364\t\t\t\t\tpublic void stateChanged(ChangeEvent e) {\r\n   365\t\t\t\t\t\ttestViewChanged();\r\n   366\t\t\t\t\t}\r\n   367\t\t\t\t}\r\n   368\t\t\t);\r\n   369\t\t\treturn pane;\r\n   370\t\t}\r\n   371\t\t\r\n   372\t\tpublic void testViewChanged() {\r\n   373\t\t\tTestRunView view= (TestRunView)fTestRunViews.elementAt(fTestViewTab.getSelectedIndex());\r\n   374\t\t\tview.activate();\r\n   375\t\t}\r\n   376\t\t\r\n   377\t\tprotected TestResult createTestResult() {\r\n   378\t\t\treturn new TestResult();\r\n   379\t\t}\r\n   380\t\t\r\n   381\t\tprotected JFrame createUI(String suiteName) {\t\r\n   382\t\t\tJFrame frame= createFrame(\"JUnit\");\t\r\n   383\t\t\tJMenuBar mb= new JMenuBar();\r\n   384\t\t\tcreateMenus(mb);\r\n   385\t\t\tframe.setJMenuBar(mb);\r\n   386\t\t\r\n   387\t\t\tJLabel suiteLabel= new JLabel(\"Test class name:\");\r\n   388\t\t\tfSuiteCombo= createSuiteCombo();\r\n   389\t\t\tfRun= createRunButton();\r\n   390\t\t\tframe.getRootPane().setDefaultButton(fRun);\r\n   391\t\t\tComponent browseButton= createBrowseButton();\r\n   392\t\t\t\r\n   393\t\t\tfUseLoadingRunner= createUseLoaderCheckBox();\r\n   394\t\t\tfProgressIndicator= new ProgressBar();\r\n   395\t\t\tfCounterPanel= createCounterPanel();\r\n   396\t\t\t\r\n   397\t\t\tJLabel failureLabel= new JLabel(\"Errors and Failures:\");\r\n   398\t\t\tfFailures= new DefaultListModel();\r\n   399\t\t\t\r\n   400\t\t\tfTestViewTab= createTestRunViews();\t\r\n   401\t\t\tJPanel failedPanel= createFailedPanel();\r\n   402\t\t\t\r\n   403\t\t\tfFailureView= createFailureDetailView();\r\n   404\t\t\tJScrollPane tracePane= new JScrollPane(fFailureView.getComponent(), JScrollPane.VERTICAL_SCROLLBAR_ALWAYS, JScrollPane.HORIZONTAL_SCROLLBAR_ALWAYS);\r\n   405\t\r\n   406\t\t\tfStatusLine= createStatusLine();\r\n   407\t\t\tfQuitButton= createQuitButton();\r\n   408\t\t\tfLogo= createLogo();\r\n   409\t\t\t\t\t\t\r\n   410\t\t\tJPanel panel= new JPanel(new GridBagLayout());\r\n   411\t\t\r\n   412\t\t\taddGrid(panel, suiteLabel,\t0, 0, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   413\t\t\taddGrid(panel, fSuiteCombo, \t0, 1, 1, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   414\t\t\taddGrid(panel, browseButton, \t1, 1, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.WEST);\r\n   415\t\t\taddGrid(panel, fRun, \t\t2, 1, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   416\t\r\n   417\t\t\taddGrid(panel, fUseLoadingRunner,  \t0, 2, 3, GridBagConstraints.HORIZONTAL, 1.0, GridBagConstraints.WEST);\r\n   418\t\t\taddGrid(panel, new JSeparator(), \t0, 3, 3, GridBagConstraints.HORIZONTAL, 1.0, GridBagConstraints.WEST);\r\n   419\t\r\n   420\t\t\t\r\n   421\t\t\taddGrid(panel, fProgressIndicator, \t0, 4, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   422\t\t\taddGrid(panel, fLogo, \t\t\t2, 4, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.NORTH);\r\n   423\t\r\n   424\t\t\taddGrid(panel, fCounterPanel,\t 0, 5, 2, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.CENTER);\r\n   425\t\r\n   426\t\t\tJSplitPane splitter= new JSplitPane(JSplitPane.VERTICAL_SPLIT, fTestViewTab, tracePane);\r\n   427\t\t\taddGrid(panel, splitter, \t 0, 6, 2, GridBagConstraints.BOTH, \t\t\t1.0, GridBagConstraints.WEST);\t\t\t\t\r\n   428\t\r\n   429\t\t\taddGrid(panel, failedPanel, \t 2, 6, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.NORTH/*CENTER*/);\r\n   430\t\t\t\r\n   431\t\t\taddGrid(panel, fStatusLine, \t 0, 8, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.CENTER);\r\n   432\t\t\taddGrid(panel, fQuitButton, \t 2, 8, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   433\t\t\t\r\n   434\t\t\tframe.setContentPane(panel);\r\n   435\t\t\tframe.pack();\r\n   436\t\t\tframe.setLocation(200, 200);\r\n   437\t\t\treturn frame;\r\n   438\t\t}\r\n   439\t\r\n   440\t\tprivate void addGrid(JPanel p, Component co, int x, int y, int w, int fill, double wx, int anchor) {\r\n   441\t\t\tGridBagConstraints c= new GridBagConstraints();\r\n   442\t\t\tc.gridx= x; c.gridy= y;\r\n   443\t\t\tc.gridwidth= w;\r\n   444\t\t\tc.anchor= anchor;\r\n   445\t\t\tc.weightx= wx;\r\n   446\t\t\tc.fill= fill;\r\n   447\t\t\tif (fill == GridBagConstraints.BOTH || fill == GridBagConstraints.VERTICAL)\r\n   448\t\t\t\tc.weighty= 1.0;\r\n   449\t\t\tc.insets= new Insets(y == 0 ? GAP : 0, x == 0 ? GAP : 0, GAP, GAP);\r\n   450\t\t\tp.add(co, c);\r\n   451\t\t}\r\n   452\t\r\n   453\t\tprotected String getSuiteText() {\r\n   454\t\t\tif (fSuiteCombo == null)\r\n   455\t\t\t\treturn \"\";\r\n   456\t\t\treturn (String)fSuiteCombo.getEditor().getItem();\r\n   457\t\t}\r\n   458\t\t\r\n   459\t\tpublic ListModel getFailures() {\r\n   460\t\t\treturn fFailures;\r\n   461\t\t}\r\n   462\t\t\r\n   463\t\tpublic void insertUpdate(DocumentEvent event) {\r\n   464\t\t\ttextChanged();\r\n   465\t\t}\r\n   466\t\t\t\r\n   467\t\tpublic void browseTestClasses() {\r\n   468\t\t\tTestCollector collector= createTestCollector();\t\t\r\n   469\t\t\tTestSelector selector= new TestSelector(fFrame, collector);\r\n   470\t\t\tif (selector.isEmpty()) {\r\n   471\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"No Test Cases found.\\nCheck that the configured \\'TestCollector\\' is supported on this platform.\");\r\n   472\t\t\t\treturn;\r\n   473\t\t\t}\r\n   474\t\t\tselector.show();\r\n   475\t\t\tString className= selector.getSelectedItem();\r\n   476\t\t\tif (className != null)\r\n   477\t\t\t\tsetSuite(className);\r\n   478\t\t}\r\n   479\t\r\n   480\t\tTestCollector createTestCollector() {\r\n   481\t\t\tString className= BaseTestRunner.getPreference(TESTCOLLECTOR_KEY);\r\n   482\t\t\tif (className != null) {\t\t\t\r\n   483\t\t\t\tClass collectorClass= null;\r\n   484\t\t\t\ttry {\r\n   485\t\t\t\t\tcollectorClass= Class.forName(className);\r\n   486\t\t\t\t\treturn (TestCollector)collectorClass.newInstance();\r\n   487\t\t\t\t} catch(Exception e) {\r\n   488\t\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"Could not create TestCollector - using default collector\");\r\n   489\t\t\t\t}\r\n   490\t\t\t}\r\n   491\t\t\treturn new SimpleTestCollector();\r\n   492\t\t}\r\n   493\t\t\r\n   494\t\tprivate Image loadFrameIcon() {\r\n   495\t\t\tImageIcon icon= (ImageIcon)getIconResource(BaseTestRunner.class, \"smalllogo.gif\");\r\n   496\t\t\tif (icon != null)\r\n   497\t\t\t\treturn icon.getImage();\r\n   498\t\t\treturn null;\r\n   499\t\t}\r\n   500\t\t\r\n   501\t\tprivate void loadHistory(JComboBox combo) throws IOException {\r\n   502\t\t\tBufferedReader br= new BufferedReader(new FileReader(getSettingsFile()));\r\n   503\t\t\tint itemCount= 0;\r\n   504\t\t\ttry {\r\n   505\t\t\t\tString line;\r\n   506\t\t\t\twhile ((line= br.readLine()) != null) {\r\n   507\t\t\t\t\tcombo.addItem(line);\r\n   508\t\t\t\t\titemCount++;\r\n   509\t\t\t\t}\r\n   510\t\t\t\tif (itemCount > 0)\r\n   511\t\t\t\t\tcombo.setSelectedIndex(0);\r\n   512\t\r\n   513\t\t\t} finally {\r\n   514\t\t\t\tbr.close();\r\n   515\t\t\t}\r\n   516\t\t}\r\n   517\t\t\r\n   518\t\tprivate File getSettingsFile() {\r\n   519\t\t \tString home= System.getProperty(\"user.home\");\r\n   520\t \t\treturn new File(home,\".junitsession\");\r\n   521\t \t}\r\n   522\t\t\r\n   523\t\tprivate void postInfo(final String message) {\r\n   524\t\t\tSwingUtilities.invokeLater(\r\n   525\t\t\t\tnew Runnable() {\r\n   526\t\t\t\t\tpublic void run() {\r\n   527\t\t\t\t\t\tshowInfo(message);\r\n   528\t\t\t\t\t}\r\n   529\t\t\t\t}\r\n   530\t\t\t);\r\n   531\t\t}\r\n   532\t\t\r\n   533\t\tprivate void postStatus(final String status) {\r\n   534\t\t\tSwingUtilities.invokeLater(\r\n   535\t\t\t\tnew Runnable() {\r\n   536\t\t\t\t\tpublic void run() {\r\n   537\t\t\t\t\t\tshowStatus(status);\r\n   538\t\t\t\t\t}\r\n   539\t\t\t\t}\r\n   540\t\t\t);\r\n   541\t\t}\r\n   542\t\t\r\n   543\t\tpublic void removeUpdate(DocumentEvent event) {\r\n   544\t\t\ttextChanged();\r\n   545\t\t}\r\n   546\t\t\r\n   547\t\tprivate void rerun() {\r\n   548\t\t\tTestRunView view= (TestRunView)fTestRunViews.elementAt(fTestViewTab.getSelectedIndex());\r\n   549\t\t\tTest rerunTest= view.getSelectedTest();\r\n   550\t\t\tif (rerunTest != null)\r\n   551\t\t\t\trerunTest(rerunTest);\r\n   552\t\t}\r\n   553\t\t\r\n   554\t\tprivate void rerunTest(Test test) {\r\n   555\t\t\tif (!(test instanceof TestCase)) {\r\n   556\t\t\t\tshowInfo(\"Could not reload \"+ test.toString());\r\n   557\t\t\t\treturn;\r\n   558\t\t\t}\r\n   559\t\t\tTest reloadedTest= null;\r\n   560\t\t\ttry {\r\n   561\t\t\t\tClass reloadedTestClass= getLoader().reload(test.getClass());\r\n   562\t\t\t\tClass[] classArgs= { String.class };\r\n   563\t\t\t\tObject[] args= new Object[]{((TestCase)test).getName()};\r\n   564\t\t\t\tConstructor constructor= reloadedTestClass.getConstructor(classArgs);\r\n   565\t\t\t\treloadedTest=(Test)constructor.newInstance(args);\r\n   566\t\t\t} catch(Exception e) {\r\n   567\t\t\t\tshowInfo(\"Could not reload \"+ test.toString());\r\n   568\t\t\t\treturn;\r\n   569\t\t\t}\r\n   570\t\t\tTestResult result= new TestResult();\r\n   571\t\t\treloadedTest.run(result);\r\n   572\t\t\t\r\n   573\t\t\tString message= reloadedTest.toString();\r\n   574\t\t\tif(result.wasSuccessful())\r\n   575\t\t\t\tshowInfo(message+\" was successful\");\r\n   576\t\t\telse if (result.errorCount() == 1) \r\n   577\t\t\t\tshowStatus(message+\" had an error\"); \r\n   578\t\t\telse \r\n   579\t\t\t\tshowStatus(message+\" had a failure\");\r\n   580\t\t}\r\n   581\t\r\n   582\t\tprotected void reset() {\r\n   583\t\t\tfCounterPanel.reset();\r\n   584\t\t\tfProgressIndicator.reset();\r\n   585\t\t\tfRerunButton.setEnabled(false);\r\n   586\t\t\tfFailureView.clear();\r\n   587\t\t\tfFailures.clear();\r\n   588\t\t}\r\n   589\t\t\r\n   590\t\t/**\r\n   591\t\t * runs a suite.\r\n   592\t\t * @deprecated use runSuite() instead\r\n   593\t\t */\r\n   594\t\tpublic void run() {\r\n   595\t\t\trunSuite();\r\n   596\t\t}\r\n   597\t\t\r\n   598\t\tprotected void runFailed(String message) {\r\n   599\t\t\tshowStatus(message);\r\n   600\t\t\tfRun.setText(\"Run\");\r\n   601\t\t\tfRunner= null;\r\n   602\t\t}\r\n   603\t\t\r\n   604\t\tsynchronized public void runSuite() {\r\n   605\t\t\tif (fRunner != null) {\r\n   606\t\t\t\tfTestResult.stop();\r\n   607\t\t\t} else {\r\n   608\t\t\t\tsetLoading(shouldReload());\r\n   609\t\t\t\treset();\r\n   610\t\t\t\tshowInfo(\"Load Test Case...\");\r\n   611\t\t\t\tfinal String suiteName= getSuiteText();\r\n   612\t\t\t\tfinal Test testSuite= getTest(suiteName);\t\t\r\n   613\t\t\t\tif (testSuite != null) {\r\n   614\t\t\t\t\taddToHistory(suiteName);\r\n   615\t\t\t\t\tdoRunTest(testSuite);\r\n   616\t\t\t\t}\r\n   617\t\t\t}\r\n   618\t\t}\r\n   619\t\t\r\n   620\t\tprivate boolean shouldReload() {\r\n   621\t\t\treturn !inVAJava() && fUseLoadingRunner.isSelected();\r\n   622\t\t}\r\n   623\t\t\r\n   624\t\r\n   625\t\tsynchronized protected void runTest(final Test testSuite) {\r\n   626\t\t\tif (fRunner != null) {\r\n   627\t\t\t\tfTestResult.stop();\r\n   628\t\t\t} else {\r\n   629\t\t\t\treset();\t\r\n   630\t\t\t\tif (testSuite != null) {\r\n   631\t\t\t\t\tdoRunTest(testSuite);\r\n   632\t\t\t\t}\r\n   633\t\t\t}\r\n   634\t\t}\r\n   635\t\t\r\n   636\t\tprivate void doRunTest(final Test testSuite) {\r\n   637\t\t\tsetButtonLabel(fRun, \"Stop\");\r\n   638\t\t\tfRunner= new Thread(\"TestRunner-Thread\") {\r\n   639\t\t\t\tpublic void run() {\r\n   640\t\t\t\t\tTestRunner.this.start(testSuite); \r\n   641\t\t\t\t\tpostInfo(\"Running...\");\r\n   642\t\t\t\t\t\r\n   643\t\t\t\t\tlong startTime= System.currentTimeMillis();\r\n   644\t\t\t\t\ttestSuite.run(fTestResult);\r\n   645\t\t\t\t\t\t\r\n   646\t\t\t\t\tif (fTestResult.shouldStop()) {\r\n   647\t\t\t\t\t\tpostStatus(\"Stopped\");\r\n   648\t\t\t\t\t} else {\r\n   649\t\t\t\t\t\tlong endTime= System.currentTimeMillis();\r\n   650\t\t\t\t\t\tlong runTime= endTime-startTime;\r\n   651\t\t\t\t\t\tpostInfo(\"Finished: \" + elapsedTimeAsString(runTime) + \" seconds\");\r\n   652\t\t\t\t\t}\r\n   653\t\t\t\t\trunFinished(testSuite);\r\n   654\t\t\t\t\tsetButtonLabel(fRun, \"Run\");\r\n   655\t\t\t\t\tfRunner= null;\r\n   656\t\t\t\t\tSystem.gc();\r\n   657\t\t\t\t}\r\n   658\t\t\t};\r\n   659\t\t\t// make sure that the test result is created before we start the\r\n   660\t\t\t// test runner thread so that listeners can register for it.\r\n   661\t\t\tfTestResult= createTestResult();\r\n   662\t\t\tfTestResult.addListener(TestRunner.this);\r\n   663\t\t\taboutToStart(testSuite);\r\n   664\t\r\n   665\t\t\tfRunner.start();\r\n   666\t\t}\r\n   667\t\r\n   668\t\tprivate void saveHistory() throws IOException {\r\n   669\t\t\tBufferedWriter bw= new BufferedWriter(new FileWriter(getSettingsFile()));\r\n   670\t\t\ttry {\r\n   671\t\t\t\tfor (int i= 0; i < fSuiteCombo.getItemCount(); i++) {\r\n   672\t\t\t\t\tString testsuite= fSuiteCombo.getItemAt(i).toString();\r\n   673\t\t\t\t\tbw.write(testsuite, 0, testsuite.length());\r\n   674\t\t\t\t\tbw.newLine();\r\n   675\t\t\t\t}\r\n   676\t\t\t} finally {\r\n   677\t\t\t\tbw.close();\r\n   678\t\t\t}\r\n   679\t\t}\r\n   680\t\t\r\n   681\t\tprivate void setButtonLabel(final JButton button, final String label) {\r\n   682\t\t\tSwingUtilities.invokeLater(\r\n   683\t\t\t\tnew Runnable() {\r\n   684\t\t\t\t\tpublic void run() {\r\n   685\t\t\t\t\t\tbutton.setText(label);\r\n   686\t\t\t\t\t}\r\n   687\t\t\t\t}\r\n   688\t\t\t);\r\n   689\t\t}\r\n   690\t\t\r\n   691\t\tprivate void setLabelValue(final JTextField label, final int value) {\r\n   692\t\t\tSwingUtilities.invokeLater(\r\n   693\t\t\t\tnew Runnable() {\r\n   694\t\t\t\t\tpublic void run() {\r\n   695\t\t\t\t\t\tlabel.setText(Integer.toString(value));\r\n   696\t\t\t\t\t}\r\n   697\t\t\t\t}\r\n   698\t\t\t);\r\n   699\t\t}\r\n   700\t\t\t\r\n   701\t\tpublic void handleTestSelected(Test test) {\r\n   702\t\t\tfRerunButton.setEnabled(test != null && (test instanceof TestCase));\r\n   703\t\t\tshowFailureDetail(test);\r\n   704\t\t}\r\n   705\t\r\n   706\t\tprivate void showFailureDetail(Test test) {\r\n   707\t\t\tif (test != null) {\r\n   708\t\t\t\tListModel failures= getFailures();\r\n   709\t\t\t\tfor (int i= 0; i < failures.getSize(); i++) {\r\n   710\t\t\t\t\tTestFailure failure= (TestFailure)failures.getElementAt(i);\r\n   711\t\t\t\t\tif (failure.failedTest() == test) {\r\n   712\t\t\t\t\t\tfFailureView.showFailure(failure);\r\n   713\t\t\t\t\t\treturn;\r\n   714\t\t\t\t\t}\r\n   715\t\t\t\t}\r\n   716\t\t\t}\r\n   717\t\t\tfFailureView.clear();\r\n   718\t\t}\r\n   719\t\t\t\r\n   720\t\tprivate void showInfo(String message) {\r\n   721\t\t\tfStatusLine.showInfo(message);\r\n   722\t\t}\r\n   723\t\t\r\n   724\t\tprivate void showStatus(String status) {\r\n   725\t\t\tfStatusLine.showError(status);\r\n   726\t\t}\r\n   727\t\t\r\n   728\t\t/**\r\n   729\t\t * Starts the TestRunner\r\n   730\t\t */\r\n   731\t\tpublic void start(String[] args) {\t\t\r\n   732\t\t\tString suiteName= processArguments(args);\r\n   733\t\t\tfFrame= createUI(suiteName);\r\n   734\t\t\tfFrame.pack(); \r\n   735\t\t\tfFrame.setVisible(true);\r\n   736\t\r\n   737\t\t\tif (suiteName != null) {\r\n   738\t\t\t\tsetSuite(suiteName);\r\n   739\t\t\t\trunSuite();\r\n   740\t\t\t}\r\n   741\t\t}\r\n   742\t\t\t\r\n   743\t\tprivate void start(final Test test) {\r\n   744\t\t\tSwingUtilities.invokeLater(\r\n   745\t\t\t\tnew Runnable() {\r\n   746\t\t\t\t\tpublic void run() {\r\n   747\t\t\t\t\t\tint total= test.countTestCases();\r\n   748\t\t\t\t\t\tfProgressIndicator.start(total);\r\n   749\t\t\t\t\t\tfCounterPanel.setTotal(total);\r\n   750\t\t\t\t\t}\r\n   751\t\t\t\t}\r\n   752\t\t\t);\r\n   753\t\t}\r\n   754\t\t\r\n   755\t\t/**\r\n   756\t\t * Wait until all the events are processed in the event thread\r\n   757\t\t */\r\n   758\t\tprivate void synchUI() {\r\n   759\t\t\ttry {\r\n   760\t\t\t\tSwingUtilities.invokeAndWait(\r\n   761\t\t\t\t\tnew Runnable() {\r\n   762\t\t\t\t\t\tpublic void run() {}\r\n   763\t\t\t\t\t}\t\t\r\n   764\t\t\t\t);\r\n   765\t\t\t}\r\n   766\t\t\tcatch (Exception e) {\r\n   767\t\t\t}\r\n   768\t\t}\r\n   769\t\t\r\n   770\t\t/**\r\n   771\t\t * Terminates the TestRunner\r\n   772\t\t */\r\n   773\t\tpublic void terminate() {\r\n   774\t\t\tfFrame.dispose();\r\n   775\t\t\ttry {\r\n   776\t\t\t\tsaveHistory();\r\n   777\t\t\t} catch (IOException e) {\r\n   778\t\t\t\tSystem.out.println(\"Couldn't save test run history\");\r\n   779\t\t\t}\r\n   780\t\t\tSystem.exit(0);\r\n   781\t\t}\r\n   782\t\t\r\n   783\t\tpublic void textChanged() {\r\n   784\t\t\tfRun.setEnabled(getSuiteText().length() > 0);\r\n   785\t\t\tclearStatus();\r\n   786\t\t}\r\n   787\t\t\r\n   788\t\tprotected void clearStatus() {\r\n   789\t\t\tfStatusLine.clear();\r\n   790\t\t}\r\n   791\t\t\r\n   792\t\tpublic static Icon getIconResource(Class clazz, String name) {\r\n   793\t\t\tURL url= clazz.getResource(name);\r\n   794\t\t\tif (url == null) {\r\n   795\t\t\t\tSystem.err.println(\"Warning: could not load \\\"\"+name+\"\\\" icon\");\r\n   796\t\t\t\treturn null;\r\n   797\t\t\t} \r\n   798\t\t\treturn new ImageIcon(url);\r\n   799\t\t}\r\n   800\t\t\r\n   801\t\tprivate void about() {\r\n   802\t\t\tAboutDialog about= new AboutDialog(fFrame); \r\n   803\t\t\tabout.show();\r\n   804\t\t}\r\n   805\t\t\r\n   806\t\r\n   807\t}\n"}], "isError": false, "timestamp": 1777927350873}}
[recv] {"type": "message_end", "message": {"role": "toolResult", "toolCallId": "call_YgDyKlqkQz8YEKiNEsuhe2KT|fc_071b59dec39b2f740169f904b5c72081a0a739f24e3a9d1da0", "toolName": "bash", "content": [{"type": "text", "text": "     1\tpackage junit.swingui;\r\n     2\t\r\n     3\timport junit.framework.*;\r\n     4\timport junit.runner.*;\r\n     5\t\r\n     6\timport java.util.*;\r\n     7\timport java.lang.reflect.*;\r\n     8\timport java.text.NumberFormat;\r\n     9\timport java.net.URL;\r\n    10\timport java.io.*;\r\n    11\t\r\n    12\timport javax.swing.*;\r\n    13\timport javax.swing.event.*;\r\n    14\timport javax.swing.text.*;\r\n    15\timport java.awt.*;\r\n    16\timport java.awt.event.*;\r\n    17\timport java.awt.image.*;\r\n    18\t\r\n    19\t/**\r\n    20\t * A Swing based user interface to run tests.\r\n    21\t * Enter the name of a class which either provides a static\r\n    22\t * suite method or is a subclass of TestCase.\r\n    23\t * <pre>\r\n    24\t * Synopsis: java junit.swingui.TestRunner [-noloading] [TestCase]\r\n    25\t * </pre>\r\n    26\t * TestRunner takes as an optional argument the name of the testcase class to be run.\r\n    27\t */\r\n    28\tpublic class TestRunner extends BaseTestRunner implements TestRunContext {\r\n    29\t\tprotected JFrame fFrame;\r\n    30\t\tprivate Thread fRunner;\r\n    31\t\tprivate TestResult fTestResult;\r\n    32\t\t\r\n    33\t\tprivate JComboBox fSuiteCombo;\r\n    34\t\tprivate ProgressBar fProgressIndicator;\r\n    35\t\tprivate DefaultListModel fFailures;\r\n    36\t\tprivate JLabel fLogo;\r\n    37\t\tprivate CounterPanel fCounterPanel;\r\n    38\t\tprivate JButton fRun;\r\n    39\t\tprivate JButton fQuitButton;\r\n    40\t\tprivate JButton fRerunButton;\r\n    41\t\tprivate StatusLine fStatusLine;\r\n    42\t\tprivate FailureDetailView fFailureView;\r\n    43\t\tprivate JTabbedPane fTestViewTab;\r\n    44\t\tprivate JCheckBox fUseLoadingRunner;\r\n    45\t\tprivate Vector fTestRunViews= new Vector(); // view associated with tab in tabbed pane\r\n    46\t\tprivate static Font PLAIN_FONT= StatusLine.PLAIN_FONT;\r\n    47\t\tprivate static Font BOLD_FONT= StatusLine.BOLD_FONT;\r\n    48\t\tprivate static final int GAP= 4;\r\n    49\t\tprivate static final int HISTORY_LENGTH= 5;\r\n    50\t\r\n    51\t\tprivate static final String TESTCOLLECTOR_KEY= \"TestCollectorClass\";\r\n    52\t\tprivate static final String FAILUREDETAILVIEW_KEY= \"FailureViewClass\";\r\n    53\t\t\t\r\n    54\t\tpublic TestRunner() {\r\n    55\t\t} \r\n    56\t\t\r\n    57\t\tpublic static void main(String[] args) {\r\n    58\t\t\tnew TestRunner().start(args);\r\n    59\t\t}\r\n    60\t\t \r\n    61\t\tpublic static void run(Class test) {\r\n    62\t\t\tString args[]= { test.getName() };\r\n    63\t\t\tmain(args);\r\n    64\t\t}\r\n    65\t\t\r\n    66\t\tpublic void addError(final Test test, final Throwable t) {\r\n    67\t\t\tSwingUtilities.invokeLater(\r\n    68\t\t\t\tnew Runnable() {\r\n    69\t\t\t\t\tpublic void run() {\r\n    70\t\t\t\t\t\tfCounterPanel.setErrorValue(fTestResult.errorCount());\r\n    71\t\t\t\t\t\tappendFailure(\"Error\", test, t);\r\n    72\t\t\t\t\t}\r\n    73\t\t\t\t}\r\n    74\t\t\t);\r\n    75\t\t}\r\n    76\t\t\r\n    77\t\tpublic void addFailure(final Test test, final AssertionFailedError t) {\r\n    78\t\t\tSwingUtilities.invokeLater(\r\n    79\t\t\t\tnew Runnable() {\r\n    80\t\t\t\t\tpublic void run() {\r\n    81\t\t\t\t\t\tfCounterPanel.setFailureValue(fTestResult.failureCount());\r\n    82\t\t\t\t\t\tappendFailure(\"Failure\", test, t);\r\n    83\t\t\t\t\t}\r\n    84\t\t\t\t}\t\t\r\n    85\t\t\t);\r\n    86\t\t}\r\n    87\t\t\r\n    88\t\tpublic void startTest(Test test) {\r\n    89\t\t\tpostInfo(\"Running: \"+test);\r\n    90\t\t}\r\n    91\t\t\r\n    92\t\tpublic void endTest(Test test) {\r\n    93\t\t\tpostEndTest(test);\r\n    94\t\t}\r\n    95\t\r\n    96\t\tprivate void postEndTest(final Test test) {\r\n    97\t\t\tsynchUI();\r\n    98\t\t\tSwingUtilities.invokeLater(\r\n    99\t\t\t\tnew Runnable() {\r\n   100\t\t\t\t\tpublic void run() {\r\n   101\t\t\t\t\t\tif (fTestResult != null) {\r\n   102\t\t\t\t\t\t\tfCounterPanel.setRunValue(fTestResult.runCount());\r\n   103\t\t\t\t\t\t\tfProgressIndicator.step(fTestResult.wasSuccessful());\r\n   104\t\t\t\t\t\t}\r\n   105\t\t\t\t\t}\r\n   106\t\t\t\t}\r\n   107\t\t\t);\r\n   108\t\t}\r\n   109\t\r\n   110\t\tpublic void setSuite(String suiteName) {\r\n   111\t\t\tfSuiteCombo.getEditor().setItem(suiteName);\r\n   112\t\t}\r\n   113\t\r\n   114\t\tprivate void addToHistory(final String suite) {\r\n   115\t\t\tfor (int i= 0; i < fSuiteCombo.getItemCount(); i++) {\r\n   116\t\t\t\tif (suite.equals(fSuiteCombo.getItemAt(i))) {\r\n   117\t\t\t\t\tfSuiteCombo.removeItemAt(i);\r\n   118\t\t\t\t\tfSuiteCombo.insertItemAt(suite, 0);\r\n   119\t\t\t\t\tfSuiteCombo.setSelectedIndex(0);\r\n   120\t\t\t\t\treturn;\r\n   121\t\t\t\t}\r\n   122\t\t\t}\r\n   123\t\t\tfSuiteCombo.insertItemAt(suite, 0);\r\n   124\t\t\tfSuiteCombo.setSelectedIndex(0);\r\n   125\t\t\tpruneHistory();\r\n   126\t\t}\r\n   127\t\t\r\n   128\t\tprivate void pruneHistory() {\r\n   129\t\t\tint historyLength= getPreference(\"maxhistory\", HISTORY_LENGTH);\r\n   130\t\t\tif (historyLength < 1)\r\n   131\t\t\t\thistoryLength= 1;\r\n   132\t\t\tfor (int i= fSuiteCombo.getItemCount()-1; i > historyLength-1; i--) \r\n   133\t\t\t\tfSuiteCombo.removeItemAt(i);\r\n   134\t\t}\r\n   135\t\t\r\n   136\t\tprivate void appendFailure(String kind, Test test, Throwable t) {\r\n   137\t\t\tfFailures.addElement(new TestFailure(test, t));\r\n   138\t\t\tif (fFailures.size() == 1) \r\n   139\t\t\t\trevealFailure(test);\r\n   140\t\t}\r\n   141\t\t\r\n   142\t\tprivate void revealFailure(Test test) {\r\n   143\t\t\tfor (Enumeration e= fTestRunViews.elements(); e.hasMoreElements(); ) {\r\n   144\t\t\t\tTestRunView v= (TestRunView) e.nextElement();\r\n   145\t\t\t\tv.revealFailure(test);\r\n   146\t\t\t}\r\n   147\t\t}\r\n   148\t\t\t\r\n   149\t\tprotected void aboutToStart(final Test testSuite) {\r\n   150\t\t\tfor (Enumeration e= fTestRunViews.elements(); e.hasMoreElements(); ) {\r\n   151\t\t\t\tTestRunView v= (TestRunView) e.nextElement();\r\n   152\t\t\t\tv.aboutToStart(testSuite, fTestResult);\r\n   153\t\t\t}\r\n   154\t\t}\r\n   155\t\t\r\n   156\t\tprotected void runFinished(final Test testSuite) {\r\n   157\t\t\tSwingUtilities.invokeLater(\r\n   158\t\t\t\tnew Runnable() {\r\n   159\t\t\t\t\tpublic void run() {\r\n   160\t\t\t\t\t\tfor (Enumeration e= fTestRunViews.elements(); e.hasMoreElements(); ) {\r\n   161\t\t\t\t\t\t\tTestRunView v= (TestRunView) e.nextElement();\r\n   162\t\t\t\t\t\t\tv.runFinished(testSuite, fTestResult);\r\n   163\t\t\t\t\t\t}\r\n   164\t\t\t\t\t}\r\n   165\t\t\t\t}\r\n   166\t\t\t);\r\n   167\t\t}\r\n   168\t\r\n   169\t\tprotected CounterPanel createCounterPanel() {\r\n   170\t\t\treturn new CounterPanel();\r\n   171\t\t}\r\n   172\t\t\r\n   173\t\tprotected JPanel createFailedPanel() {\r\n   174\t\t\tJPanel failedPanel= new JPanel(new GridLayout(0, 1, 0, 2));\r\n   175\t\t\tfRerunButton= new JButton(\"Run\");\r\n   176\t\t\tfRerunButton.setEnabled(false);\r\n   177\t\t\tfRerunButton.addActionListener(\r\n   178\t\t\t\tnew ActionListener() {\r\n   179\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   180\t\t\t\t\t\trerun();\r\n   181\t\t\t\t\t}\r\n   182\t\t\t\t}\r\n   183\t\t\t);\r\n   184\t\t\tfailedPanel.add(fRerunButton);\r\n   185\t\t\treturn failedPanel;\r\n   186\t\t}\r\n   187\t\t\t\t\r\n   188\t\tprotected FailureDetailView createFailureDetailView() {\r\n   189\t\t\tString className= BaseTestRunner.getPreference(FAILUREDETAILVIEW_KEY);\r\n   190\t\t\tif (className != null) {\t\t\t\r\n   191\t\t\t\tClass viewClass= null;\r\n   192\t\t\t\ttry {\r\n   193\t\t\t\t\tviewClass= Class.forName(className);\r\n   194\t\t\t\t\treturn (FailureDetailView)viewClass.newInstance();\r\n   195\t\t\t\t} catch(Exception e) {\r\n   196\t\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"Could not create Failure DetailView - using default view\");\r\n   197\t\t\t\t}\r\n   198\t\t\t}\r\n   199\t\t\treturn new DefaultFailureDetailView();\r\n   200\t\t}\r\n   201\t\r\n   202\t\t/**\r\n   203\t\t * Creates the JUnit menu. Clients override this\r\n   204\t\t * method to add additional menu items.\r\n   205\t\t */\r\n   206\t\tprotected JMenu createJUnitMenu() {\r\n   207\t\t\tJMenu menu= new JMenu(\"JUnit\");\r\n   208\t\t\tmenu.setMnemonic('J');\r\n   209\t\t\tJMenuItem mi1= new JMenuItem(\"About...\");\r\n   210\t\t\tmi1.addActionListener(\r\n   211\t\t\t    new ActionListener() {\r\n   212\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   213\t\t\t            about();\r\n   214\t\t\t        }\r\n   215\t\t\t    }\r\n   216\t\t\t);\r\n   217\t\t\tmi1.setMnemonic('A');\r\n   218\t\t\tmenu.add(mi1);\r\n   219\t\t\t\r\n   220\t\t\tmenu.addSeparator();\r\n   221\t\t\tJMenuItem mi2= new JMenuItem(\" Exit \");\r\n   222\t\t\tmi2.addActionListener(\r\n   223\t\t\t    new ActionListener() {\r\n   224\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   225\t\t\t            terminate();\r\n   226\t\t\t        }\r\n   227\t\t\t    }\r\n   228\t\t\t);\r\n   229\t\t\tmi2.setMnemonic('x');\r\n   230\t\t\tmenu.add(mi2);\r\n   231\t\r\n   232\t\t\treturn menu;\r\n   233\t\t}\r\n   234\t\t\r\n   235\t\tprotected JFrame createFrame(String title) {\r\n   236\t\t\tJFrame frame= new JFrame(\"JUnit\");\r\n   237\t\t\tImage icon= loadFrameIcon();\t\r\n   238\t\t\tif (icon != null)\r\n   239\t\t\t\tframe.setIconImage(icon);\r\n   240\t\t\tframe.getContentPane().setLayout(new BorderLayout(0, 0));\r\n   241\t\t\t\r\n   242\t\t\tframe.addWindowListener(\r\n   243\t\t\t\tnew WindowAdapter() {\r\n   244\t\t\t\t\tpublic void windowClosing(WindowEvent e) {\r\n   245\t\t\t\t\t\tterminate();\r\n   246\t\t\t\t\t}\r\n   247\t\t\t\t}\r\n   248\t\t\t);\r\n   249\t\t\treturn frame;\r\n   250\t\t}\r\n   251\t\t\r\n   252\t\tprotected JLabel createLogo() {\r\n   253\t\t\tJLabel label;\r\n   254\t\t\tIcon icon= getIconResource(BaseTestRunner.class, \"logo.gif\");\r\n   255\t\t\tif (icon != null) \r\n   256\t\t\t\tlabel= new JLabel(icon);\r\n   257\t\t\telse\r\n   258\t\t\t\tlabel= new JLabel(\"JV\");\r\n   259\t\t\tlabel.setToolTipText(\"JUnit Version \"+Version.id());\r\n   260\t\t\treturn label;\r\n   261\t\t}\r\n   262\t\t\r\n   263\t\tprotected void createMenus(JMenuBar mb) {\r\n   264\t\t\tmb.add(createJUnitMenu());\r\n   265\t\t}\r\n   266\t\t\t\r\n   267\t\tprotected JCheckBox createUseLoaderCheckBox() {\r\n   268\t\t\tboolean useLoader= useReloadingTestSuiteLoader();\r\n   269\t\t\tJCheckBox box= new JCheckBox(\"Reload classes every run\", useLoader);\r\n   270\t\t\tbox.setToolTipText(\"Use a custom class loader to reload the classes for every run\");\r\n   271\t\t\tif (inVAJava())\r\n   272\t\t\t\tbox.setVisible(false);\r\n   273\t\t\treturn box;\r\n   274\t\t}\r\n   275\t\t\r\n   276\t\tprotected JButton createQuitButton() {\r\n   277\t\t\t // spaces required to avoid layout flicker\r\n   278\t\t\t // Exit is shorter than Stop that shows in the same column\r\n   279\t\t\tJButton quit= new JButton(\" Exit \"); \r\n   280\t\t\tquit.addActionListener(\r\n   281\t\t\t\tnew ActionListener() {\r\n   282\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   283\t\t\t\t\t\tterminate();\r\n   284\t\t\t\t\t}\r\n   285\t\t\t\t}\r\n   286\t\t\t);\r\n   287\t\t\treturn quit;\r\n   288\t\t}\r\n   289\t\t\r\n   290\t\tprotected JButton createRunButton() {\r\n   291\t\t\tJButton run= new JButton(\"Run\");\r\n   292\t\t\trun.setEnabled(true);\r\n   293\t\t\trun.addActionListener(\r\n   294\t\t\t\tnew ActionListener() {\r\n   295\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   296\t\t\t\t\t\trunSuite();\r\n   297\t\t\t\t\t}\r\n   298\t\t\t\t}\r\n   299\t\t\t);\r\n   300\t\t\treturn run;\r\n   301\t\t}\r\n   302\t\t\r\n   303\t\tprotected Component createBrowseButton() {\r\n   304\t\t\tJButton browse= new JButton(\"...\");\r\n   305\t\t\tbrowse.setToolTipText(\"Select a Test class\");\r\n   306\t\t\tbrowse.addActionListener(\r\n   307\t\t\t\tnew ActionListener() {\r\n   308\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   309\t\t\t\t\t\tbrowseTestClasses();\r\n   310\t\t\t\t\t}\r\n   311\t\t\t\t}\r\n   312\t\t\t);\r\n   313\t\t\treturn browse;\t\t\r\n   314\t\t}\r\n   315\t\t\r\n   316\t\tprotected StatusLine createStatusLine() {\r\n   317\t\t\treturn new StatusLine(420);\r\n   318\t\t}\r\n   319\t\t\r\n   320\t\tprotected JComboBox createSuiteCombo() {\r\n   321\t\t\tJComboBox combo= new JComboBox();\r\n   322\t\t\tcombo.setEditable(true);\r\n   323\t\t\tcombo.setLightWeightPopupEnabled(false);\r\n   324\t\t\t\r\n   325\t\t\tcombo.getEditor().getEditorComponent().addKeyListener(\r\n   326\t\t\t\tnew KeyAdapter() {\r\n   327\t\t\t\t\tpublic void keyTyped(KeyEvent e) {\r\n   328\t\t\t\t\t\ttextChanged();\r\n   329\t\t\t\t\t\tif (e.getKeyChar() == KeyEvent.VK_ENTER)\r\n   330\t\t\t\t\t\t\trunSuite();\r\n   331\t\t\t\t\t}\r\n   332\t\t\t\t}\r\n   333\t\t\t);\r\n   334\t\t\ttry {\r\n   335\t\t\t\tloadHistory(combo);\r\n   336\t\t\t} catch (IOException e) {\r\n   337\t\t\t\t// fails the first time\r\n   338\t\t\t}\r\n   339\t\t\tcombo.addItemListener(\r\n   340\t\t\t\tnew ItemListener() {\r\n   341\t\t\t\t\tpublic void itemStateChanged(ItemEvent event) {\r\n   342\t\t\t\t\t\tif (event.getStateChange() == ItemEvent.SELECTED) {\r\n   343\t\t\t\t\t\t\ttextChanged();\r\n   344\t\t\t\t\t\t}\r\n   345\t\t\t\t\t}\r\n   346\t\t\t\t}\r\n   347\t\t\t);\r\n   348\t\t\treturn combo;\r\n   349\t\t}\r\n   350\t\t\r\n   351\t\tprotected JTabbedPane createTestRunViews() {\r\n   352\t\t\tJTabbedPane pane= new JTabbedPane(JTabbedPane.BOTTOM);\r\n   353\t\r\n   354\t\t\tFailureRunView lv= new FailureRunView(this);\r\n   355\t\t\tfTestRunViews.addElement(lv);\r\n   356\t\t\tlv.addTab(pane);\r\n   357\t\t\t\r\n   358\t\t\tTestHierarchyRunView tv= new TestHierarchyRunView(this);\r\n   359\t\t\tfTestRunViews.addElement(tv);\r\n   360\t\t\ttv.addTab(pane);\r\n   361\t\t\t\r\n   362\t\t\tpane.addChangeListener(\r\n   363\t\t\t\tnew ChangeListener() {\r\n   364\t\t\t\t\tpublic void stateChanged(ChangeEvent e) {\r\n   365\t\t\t\t\t\ttestViewChanged();\r\n   366\t\t\t\t\t}\r\n   367\t\t\t\t}\r\n   368\t\t\t);\r\n   369\t\t\treturn pane;\r\n   370\t\t}\r\n   371\t\t\r\n   372\t\tpublic void testViewChanged() {\r\n   373\t\t\tTestRunView view= (TestRunView)fTestRunViews.elementAt(fTestViewTab.getSelectedIndex());\r\n   374\t\t\tview.activate();\r\n   375\t\t}\r\n   376\t\t\r\n   377\t\tprotected TestResult createTestResult() {\r\n   378\t\t\treturn new TestResult();\r\n   379\t\t}\r\n   380\t\t\r\n   381\t\tprotected JFrame createUI(String suiteName) {\t\r\n   382\t\t\tJFrame frame= createFrame(\"JUnit\");\t\r\n   383\t\t\tJMenuBar mb= new JMenuBar();\r\n   384\t\t\tcreateMenus(mb);\r\n   385\t\t\tframe.setJMenuBar(mb);\r\n   386\t\t\r\n   387\t\t\tJLabel suiteLabel= new JLabel(\"Test class name:\");\r\n   388\t\t\tfSuiteCombo= createSuiteCombo();\r\n   389\t\t\tfRun= createRunButton();\r\n   390\t\t\tframe.getRootPane().setDefaultButton(fRun);\r\n   391\t\t\tComponent browseButton= createBrowseButton();\r\n   392\t\t\t\r\n   393\t\t\tfUseLoadingRunner= createUseLoaderCheckBox();\r\n   394\t\t\tfProgressIndicator= new ProgressBar();\r\n   395\t\t\tfCounterPanel= createCounterPanel();\r\n   396\t\t\t\r\n   397\t\t\tJLabel failureLabel= new JLabel(\"Errors and Failures:\");\r\n   398\t\t\tfFailures= new DefaultListModel();\r\n   399\t\t\t\r\n   400\t\t\tfTestViewTab= createTestRunViews();\t\r\n   401\t\t\tJPanel failedPanel= createFailedPanel();\r\n   402\t\t\t\r\n   403\t\t\tfFailureView= createFailureDetailView();\r\n   404\t\t\tJScrollPane tracePane= new JScrollPane(fFailureView.getComponent(), JScrollPane.VERTICAL_SCROLLBAR_ALWAYS, JScrollPane.HORIZONTAL_SCROLLBAR_ALWAYS);\r\n   405\t\r\n   406\t\t\tfStatusLine= createStatusLine();\r\n   407\t\t\tfQuitButton= createQuitButton();\r\n   408\t\t\tfLogo= createLogo();\r\n   409\t\t\t\t\t\t\r\n   410\t\t\tJPanel panel= new JPanel(new GridBagLayout());\r\n   411\t\t\r\n   412\t\t\taddGrid(panel, suiteLabel,\t0, 0, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   413\t\t\taddGrid(panel, fSuiteCombo, \t0, 1, 1, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   414\t\t\taddGrid(panel, browseButton, \t1, 1, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.WEST);\r\n   415\t\t\taddGrid(panel, fRun, \t\t2, 1, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   416\t\r\n   417\t\t\taddGrid(panel, fUseLoadingRunner,  \t0, 2, 3, GridBagConstraints.HORIZONTAL, 1.0, GridBagConstraints.WEST);\r\n   418\t\t\taddGrid(panel, new JSeparator(), \t0, 3, 3, GridBagConstraints.HORIZONTAL, 1.0, GridBagConstraints.WEST);\r\n   419\t\r\n   420\t\t\t\r\n   421\t\t\taddGrid(panel, fProgressIndicator, \t0, 4, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   422\t\t\taddGrid(panel, fLogo, \t\t\t2, 4, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.NORTH);\r\n   423\t\r\n   424\t\t\taddGrid(panel, fCounterPanel,\t 0, 5, 2, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.CENTER);\r\n   425\t\r\n   426\t\t\tJSplitPane splitter= new JSplitPane(JSplitPane.VERTICAL_SPLIT, fTestViewTab, tracePane);\r\n   427\t\t\taddGrid(panel, splitter, \t 0, 6, 2, GridBagConstraints.BOTH, \t\t\t1.0, GridBagConstraints.WEST);\t\t\t\t\r\n   428\t\r\n   429\t\t\taddGrid(panel, failedPanel, \t 2, 6, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.NORTH/*CENTER*/);\r\n   430\t\t\t\r\n   431\t\t\taddGrid(panel, fStatusLine, \t 0, 8, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.CENTER);\r\n   432\t\t\taddGrid(panel, fQuitButton, \t 2, 8, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   433\t\t\t\r\n   434\t\t\tframe.setContentPane(panel);\r\n   435\t\t\tframe.pack();\r\n   436\t\t\tframe.setLocation(200, 200);\r\n   437\t\t\treturn frame;\r\n   438\t\t}\r\n   439\t\r\n   440\t\tprivate void addGrid(JPanel p, Component co, int x, int y, int w, int fill, double wx, int anchor) {\r\n   441\t\t\tGridBagConstraints c= new GridBagConstraints();\r\n   442\t\t\tc.gridx= x; c.gridy= y;\r\n   443\t\t\tc.gridwidth= w;\r\n   444\t\t\tc.anchor= anchor;\r\n   445\t\t\tc.weightx= wx;\r\n   446\t\t\tc.fill= fill;\r\n   447\t\t\tif (fill == GridBagConstraints.BOTH || fill == GridBagConstraints.VERTICAL)\r\n   448\t\t\t\tc.weighty= 1.0;\r\n   449\t\t\tc.insets= new Insets(y == 0 ? GAP : 0, x == 0 ? GAP : 0, GAP, GAP);\r\n   450\t\t\tp.add(co, c);\r\n   451\t\t}\r\n   452\t\r\n   453\t\tprotected String getSuiteText() {\r\n   454\t\t\tif (fSuiteCombo == null)\r\n   455\t\t\t\treturn \"\";\r\n   456\t\t\treturn (String)fSuiteCombo.getEditor().getItem();\r\n   457\t\t}\r\n   458\t\t\r\n   459\t\tpublic ListModel getFailures() {\r\n   460\t\t\treturn fFailures;\r\n   461\t\t}\r\n   462\t\t\r\n   463\t\tpublic void insertUpdate(DocumentEvent event) {\r\n   464\t\t\ttextChanged();\r\n   465\t\t}\r\n   466\t\t\t\r\n   467\t\tpublic void browseTestClasses() {\r\n   468\t\t\tTestCollector collector= createTestCollector();\t\t\r\n   469\t\t\tTestSelector selector= new TestSelector(fFrame, collector);\r\n   470\t\t\tif (selector.isEmpty()) {\r\n   471\t\t\t\tJOptionPane.showMessageDialog(fFrame, \"No Test Cases found.\\nCheck that the configured \\'TestCollector\\' is supported on this platform.\");\r\n   472\t\t\t\treturn;\r\n   473\t\t\t}\r\n   474\t\t\tselector.show();\r\n   475\t\t\tString className= selector.getSelectedItem();\r\n   476\t\t\tif (className != null)\r\n   477\t\t\t\tsetSuite(className);\r\n   478\t\t}\r\n   479\t\r\n   480\t\tTestCollector createTestCollector() {\r\n   481\t\t\tString className= BaseTestRunner.getPreference(TESTCOLLECTOR_KEY);\r\n   482\t\t\tif (className != null) {\t