     743		private void start(final Test test) {
     744			SwingUtilities.invokeLater(
     745				new Runnable() {
     746					public void run() {
     747						int total= test.countTestCases();
     748						fProgressIndicator.start(total);
     749						fCounterPanel.setTotal(total);
     750					}
     751				}
     752			);
     753		}
