     114		private void addToHistory(final String suite) {
     115			for (int i= 0; i < fSuiteCombo.getItemCount(); i++) {
     116				if (suite.equals(fSuiteCombo.getItemAt(i))) {
     117					fSuiteCombo.removeItemAt(i);
     118					fSuiteCombo.insertItemAt(suite, 0);
     119					fSuiteCombo.setSelectedIndex(0);
     120					return;
     121				}
     122			}
     123			fSuiteCombo.insertItemAt(suite, 0);
     124			fSuiteCombo.setSelectedIndex(0);
     125			pruneHistory();
     126		}
     127		
     128		private void pruneHistory() {
     129			int historyLength= getPreference("maxhistory", HISTORY_LENGTH);
     130			if (historyLength < 1)
     131				historyLength= 1;
     132			for (int i= fSuiteCombo.getItemCount()-1; i > historyLength-1; i--) 
     133				fSuiteCombo.removeItemAt(i);
     134		}
