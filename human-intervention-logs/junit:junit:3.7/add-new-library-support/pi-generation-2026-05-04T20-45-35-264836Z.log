e name of the testcase class to be run.\r\n    27\t */\r\n    28\tpublic class TestRunner extends BaseTestRunner implements TestRunContext {\r\n    29\t\tprotected JFrame fFrame;\r\n    30\t\tprivate Thread fRunner;\r\n    31\t\tprivate TestResult fTestResult;\r\n    32\t\t\r\n    33\t\tprivate JComboBox fSuiteCombo;\r\n    34\t\tprivate ProgressBar fProgressIndicator;\r\n    35\t\tprivate DefaultListModel fFailures;\r\n    36\t\tprivate JLabel fLogo;\r\n    37\t\tprivate CounterPanel fCounterPanel;\r\n    38\t\tprivate JButton fRun;\r\n    39\t\tprivate JButton fQuitButton;\r\n    40\t\tprivate JButton fRerunButton;\r\n    41\t\tprivate StatusLine fStatusLine;\r\n    42\t\tprivate FailureDetailView fFailureView;\r\n    43\t\tprivate JTabbedPane fTestViewTab;\r\n    44\t\tprivate JCheckBox fUseLoadingRunner;\r\n    45\t\tprivate Vector fTestRunViews= new Vector(); // view associated with tab in tabbed pane\r\n    46\t\tprivate static Font PLAIN_FONT= StatusLine.PLAIN_FONT;\r\n    47\t\tprivate static Font BOLD_FONT= StatusLine.BOLD_FONT;\r\n    48\t\tprivate static final int GAP= 4;\r\n    49\t\tprivate static final int HISTORY_LENGTH= 5;\r\n    50\t\r\n    51\t\tprivate static final String TESTCOLLECTOR_KEY= \"TestCollectorClass\";\r\n    52\t\tprivate static final String FAILUREDETAILVIEW_KEY= \"FailureViewClass\";\r\n    53\t\t\t\r\n    54\t\tpublic TestRunner() {\r\n    55\t\t} \r\n    56\t\t\r\n    57\t\tpublic static void main(String[] args) {\r\n    58\t\t\tnew TestRunner().start(args);\r\n    59\t\t}\r\n    60\t\t \r\n    61\t\tpublic static void run(Class test) {\r\n    62\t\t\tString args[]= { test.getName() };\r\n    63\t\t\tmain(args);\r\n    64\t\t}\r\n    65\t\t\r\n    66\t\tpublic void addError(final Test test, final Throwable t) {\r\n    67\t\t\tSwingUtilities.invokeLater(\r\n    68\t\t\t\tnew Runnable() {\r\n    69\t\t\t\t\tpublic void run() {\r\n    70\t\t\t\t\t\tfCounterPanel.setErrorValue(fTestResult.errorCount());\r\n    71\t\t\t\t\t\tappendFailure(\"Error\", test, t);\r\n    72\t\t\t\t\t}\r\n    73\t\t\t\t}\r\n    74\t\t\t);\r\n    75\t\t}\r\n    76\t\t\r\n    77\t\tpublic void addFailure(final Test test, final AssertionFailedError t) {\r\n    78\t\t\tSwingUtilities.invokeLater(\r\n    79\t\t\t\tnew Runnable() {\r\n    80\t\t\t\t\tpublic void run() {\r\n    81\t\t\t\t\t\tfCounterPanel.setFailureValue(fTestResult.failureCount());\r\n    82\t\t\t\t\t\tappendFailure(\"Failure\", test, t);\r\n    83\t\t\t\t\t}\r\n    84\t\t\t\t}\t\t\r\n    85\t\t\t);\r\n    86\t\t}\r\n    87\t\t\r\n    88\t\tpublic void startTest(Test test) {\r\n    89\t\t\tpostInfo(\"Running: \"+test);\r\n    90\t\t}\r\n    91\t\t\r\n    92\t\tpublic void endTest(Test test) {\r\n    93\t\t\tpostEndTest(test);\r\n    94\t\t}\r\n    95\t\r\n    96\t\tprivate void postEndTest(final Test test) {\r\n    97\t\t\tsynchUI();\r\n    98\t\t\tSwingUtilities.invokeLater(\r\n    99\t\t\t\tnew Runnable() {\r\n   100\t\t\t\t\tpublic void run() {\r\n   101\t\t\t\t\t\tif (fTestResult != null) {\r\n   102\t\t\t\t\t\t\tfCounterPanel.setRunValue(fTestResult.runCount());\r\n   103\t\t\t\t\t\t\tfProgressIndicator.step(fTestResult.wasSuccessful());\r\n   104\t\t\t\t\t\t}\r\n   105\t\t\t\t\t}\r\n   106\t\t\t\t}\r\n   107\t\t\t);\r\n   108\t\t}\r\n   109\t\r\n   110\t\tpublic void setSuite(String suiteName) {\r\n   111\t\t\tfSuiteCombo.getEditor().setItem(suiteName);\r\n   112\t\t}\r\n   113\t\r\n   114\t\tprivate void addToHistory(final String suite) {\r\n   115\t\t\tfor (int i= 0; i < fSuiteCombo.getItemCount(); i++) {\r\n   116\t\t\t\tif (suite.equals(fSuiteCombo.getItemAt(i))) {\r\n   117\t\t\t\t\tfSuiteCombo.removeItemAt(i);\r\n   118\t\t\t\t\tfSuiteCombo.insertItemAt(suite, 0);\r\n   119\t\t\t\t\tfSuiteCombo.setSelectedIndex(0);\r\n   120\t\t\t\t\treturn;\r\n   121\t\t\t\t}\r\n   122\t\t\t}\r\n   123\t\t\tfSuiteCombo.insertItemAt(suite, 0);\r\n   124\t\t\tfSuiteCombo.setSelectedIndex(0);\r\n   125\t\t\tpruneHistory();\r\n   126\t\t}\r\n   127\t\t\r\n   128\t\t