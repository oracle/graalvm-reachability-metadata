  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.catchThrowable;
  
  import java.awt.Component;
  import java.awt.HeadlessException;
  import java.io.IOException;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  
  import javax.swing.Icon;
  import javax.swing.JLabel;
  
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import junit.framework.TestCase;
  import junit.framework.TestFailure;
  import junit.runner.BaseTestRunner;
  import junit.runner.FailureDetailView;
  import junit.runner.TestCollector;
  import junit.swingui.TestRunner;
  
  public class TestRunnerTest {
      private String previousUserHome;
  
      @TempDir
      Path temporaryHome;
  
      @AfterEach
      void restoreUserHome() {
          if (previousUserHome != null) {
              System.setProperty("user.home", previousUserHome);
          }
      }
  
      @Test
      void createsConfiguredFailureDetailViewByClassName() throws IOException {
          ExposedTestRunner runner = runnerWithPreferences(
                  "FailureViewClass=" + RecordingFailureDetailView.class.getName());
  
          FailureDetailView view = runner.newFailureDetailView();
  
          assertThat(view).isInstanceOf(RecordingFailureDetailView.class);
          assertThat(view.getComponent()).isInstanceOf(JLabel.class);
      }
  
      @Test
      void createsConfiguredTestCollectorByClassNameWhenBrowsing() throws IOException {
          EmptyTestCollector.createdInstances = 0;
          ExposedTestRunner runner = runnerWithPreferences("TestCollectorClass=" + EmptyTestCollector.class.getName());
  
          Throwable thrown = catchThrowable(runner::browseTestClasses);
  
          assertThat(EmptyTestCollector.createdInstances).isEqualTo(1);
          assertThat(thrown).isInstanceOfAny(HeadlessException.class, NullPointerException.class);
      }
  
      @Test
      void createsLogoFromRunnerResource() throws IOException {
          ExposedTestRunner runner = runnerWithPreferences();
  
          JLabel logo = runner.newLogo();
          Icon icon = TestRunner.getIconResource(BaseTestRunner.class, "logo.gif");
  
          assertThat(logo.getIcon()).isNotNull();
          assertThat(icon).isNotNull();
          assertThat(logo.getToolTipText()).startsWith("JUnit Version ");
      }
  
      @Test
      void rerunReloadsTestCaseThroughStringConstructor() throws Throwable {
          ExposedTestRunner runner = runnerWithPreferences();
          runner.setLoading(false);
          ThrowingConstructorTestCase.constructedNames.clear();
          ThrowingConstructorTestCase.throwFromConstructor = false;
          ThrowingConstructorTestCase original = new ThrowingConstructorTestCase("testNeverRuns");
          ThrowingConstructorTestCase.throwFromConstructor = true;
  
          Method rerunTest = TestRunner.class.getDeclaredMethod("rerunTest", junit.framework.Test.class);
          rerunTest.setAccessible(true);
          Throwable thrown = catchThrowable(() -> rerunTest.invoke(runner, original));
  
          assertThat(thrown).isInstanceOf(InvocationTargetException.class);
          assertThat(((InvocationTargetException) thrown).getCause()).isInstanceOf(NullPointerException.class);
          assertThat(ThrowingConstructorTestCase.constructedNames).containsExactly("testNeverRuns", "testNeverRuns");
      }
  
      private ExposedTestRunner runnerWithPreferences(String... lines) throws IOException {
          previousUserHome = System.getProperty("user.home");
          System.setProperty("user.home", temporaryHome.toString());
          if (lines.length > 0) {
              Files.writeString(temporaryHome.resolve("junit.properties"), String.join(System.lineSeparator(), lines));
          }
          return new ExposedTestRunner();
      }
  
      public static class RecordingFailureDetailView implements FailureDetailView {
          private final JLabel component = new JLabel("failure details");
  
          @Override
          public void clear() {
              component.setText("");
          }
  
          @Override
          public Component getComponent() {
              return component;
          }
  
          @Override
          public void showFailure(TestFailure failure) {
              component.setText(failure.toString());
          }
      }
  
      public static class EmptyTestCollector implements TestCollector {
          static int createdInstances;
  
          public EmptyTestCollector() {
              createdInstances++;
          }
  
          @Override
          public Enumeration collectTests() {
              return Collections.enumeration(Collections.emptyList());
          }
      }
  
      public static class ThrowingConstructorTestCase extends TestCase {
          static final List<String> constructedNames = new ArrayList<>();
          static boolean throwFromConstructor;
  
          public ThrowingConstructorTestCase(String name) {
              super(name);
              constructedNames.add(name);
              if (throwFromConstructor) {
                  throw new IllegalStateException("Constructor invocation reached");
              }
          }
  
          public void testNeverRuns() {
          }
      }
  
      private static class ExposedTestRunner extends TestRunner {
          FailureDetailView newFailureDetailView() {
              return createFailureDetailView();
          }
  
          JLabel newLogo() {
              return createLogo();
          }
      }
  }
