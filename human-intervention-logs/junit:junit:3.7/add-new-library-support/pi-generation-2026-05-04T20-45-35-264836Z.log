     636		private void doRunTest(final Test testSuite) {
     637			setButtonLabel(fRun, "Stop");
     638			fRunner= new Thread("TestRunner-Thread") {
     639				public void run() {
     640					TestRunner.this.start(testSuite); 
     641					postInfo("Running...");
     642					
     643					long startTime= System.currentTimeMillis();
     644					testSuite.run(fTestResult);
     645						
     646					if (fTestResult.shouldStop()) {
     647						postStatus("Stopped");
     648					} else {
     649						long endTime= System.currentTimeMillis();
     650						long runTime= endTime-startTime;
     651						postInfo("Finished: " + elapsedTimeAsString(runTime) + " seconds");
     652					}
     653					runFinished(testSuite);
     654					setButtonLabel(fRun, "Run");
     655					fRunner= null;
     656					System.gc();
     657				}
     658			};
     659			// make sure that the test result is created before we start the
     660			// test runner thread so that listeners can register for it.
     661			fTestResult= createTestResult();
     662			fTestResult.addListener(TestRunner.this);
     663			aboutToStart(testSuite);
     664	
     665			fRunner.start();
     666		}
