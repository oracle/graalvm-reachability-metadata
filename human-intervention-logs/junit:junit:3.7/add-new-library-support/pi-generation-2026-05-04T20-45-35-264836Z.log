     553		
     554		private void rerunTest(Test test) {
     555			if (!(test instanceof TestCase)) {
     556				showInfo("Could not reload "+ test.toString());
     557				return;
     558			}
     559			Test reloadedTest= null;
     560			try {
     561				Class reloadedTestClass= getLoader().reload(test.getClass());
     562				Class[] classArgs= { String.class };
     563				Object[] args= new Object[]{((TestCase)test).getName()};
     564				Constructor constructor= reloadedTestClass.getConstructor(classArgs);
     565				reloadedTest=(Test)constructor.newInstance(args);
     566			} catch(Exception e) {
     567				showInfo("Could not reload "+ test.toString());
     568				return;
     569			}
     570			TestResult result= new TestResult();
     571			reloadedTest.run(result);
     572			
     573			String message= reloadedTest.toString();
     574			if(result.wasSuccessful())
     575				showInfo(message+" was successful");
     576			else if (result.errorCount() == 1) 
     577				showStatus(message+" had an error"); 
     578			else 
     579				showStatus(message+" had a failure");
     580		}
