      public static class MethodFixtureCase {
          private static final List<String> events = new ArrayList<>();
  
          @Before
          public void before() {
              events.clear();
              events.add("before");
          }
  
          @org.junit.Test
          public void testBodyRunsBetweenMethodFixtures() {
              events.add("test");
          }
  
          @After
          public void after() {
              events.add("after");
          }
      }
  }
