lter(params.getArgs());\n        }\n    }\n\n    public static final class MethodNameFilter extends Filter {\n        private final String methodName;\n\n        private MethodNameFilter(final String methodName) {\n            this.methodName = methodName;\n        }\n\n        @Override\n        public boolean shouldRun(final Description description) {\n            if (description.isTest()) {\n                return methodName.equals(description.getMethodName());\n            }\n            for (Description child : description.getChildren()) {\n                if (shouldRun(child)) {\n                    return true;\n                }\n            }\n            return false;\n        }\n\n        @Override\n        public String describe() {\n            return \"method named \" + methodName;\n        }\n    }\n\n    public static final class FilteredCase {\n        @org.junit.Test\n        public void skippedByCommandLineFilter() {\n            FIRST_TEST_RUNS.incrementAndGet();\n        }\n\n        @org.junit.Test\n        public void runsSelectedTest() {\n            SECOND_TEST_RUNS.incrementAndGet();\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class ExitTrappingSecurityManager extends SecurityManager {\n        private int status;\n\n        @Override\n        public void checkPermission(final Permission permission) {\n        }\n\n        @Override\n        public void checkExit(final int status) {\n            this.status = status;\n            throw new ExitTrappedException(status);\n        }\n\n        private int status() {\n            return status;\n        }\n    }\n\n    private static final class ExitTrappedException extends SecurityException {\n        private ExitTrappedException(final int status) {\n            super(\"Trapped System.exit(\" + status + \")\");\n        }\n    }\n}\n"}
