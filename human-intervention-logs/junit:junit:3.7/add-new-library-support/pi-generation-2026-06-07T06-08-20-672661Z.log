perationException unsupportedOperationException) {\n            return false;\n        }\n    }\n\n    private static void resetObservations() {\n        FILTER_FACTORY_CONSTRUCTOR_CALLS.set(0);\n        FILTER_FACTORY_ARGUMENTS.set(null);\n        FIRST_TEST_RUNS.set(0);\n        SECOND_TEST_RUNS.set(0);\n    }\n\n    public static final class RecordingFilterFactory implements FilterFactory {\n        public RecordingFilterFactory() {\n            FILTER_FACTORY_CONSTRUCTOR_CALLS.incrementAndGet();\n        }\n\n        @Override\n        public Filter createFilter(final FilterFactoryParams params) {\n            FILTER_FACTORY_ARGUMENTS.set(params.getArgs());\n            return new MethodNameFilter(params.getArgs());\n        }\n    }\n\n    public static final class MethodNameFilter extends Filter {\n        private final String methodName;\n\n        private MethodNameFilter(final String methodName) {\n            this.methodName = methodName;\n        }\n\n        @Override\n        public boolean shouldRun(final Description description) {\n            if (description.isTest()) {\n                return methodName.equals(description.getMethodName());\n            }\n            for (Description child : description.getChildren()) {\n                if (shouldRun(child)) {\n                    return true;\n                }\n            }\n            return false;\n        }\n\n        @Override\n        public String describe() {\n            return \"method named \" + methodName;\n        }\n    }\n\n    public static final class FilteredCase {\n        @org.junit.Test\n        public void skippedByCommandLineFilter() {\n            FIRST_TEST_RUNS.incrementAndGet();\n        }\n\n        @org.junit.Test\n        public void runsSelectedTest() {\n            SECOND_TEST_RUNS.incrementAndGet();\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class ExitTrappingSecurityManager extends SecurityManager {\n        private int status;\n\n        @Override\n        public void checkPermission(final Permission permission) {\n        }\n\n        @Override\n        public void checkExit(final int status) {\n            this.status = status;\n            throw new ExitTrappedException(status);\n        }\n\n        private int status() {\n            return status;\n        }\n    }\n\n    private static final class ExitTrappedException extends SecurityException {\n        private ExitTrappedException(final int status) {\n            super(\"Trapped System.exit(\" + status + \")\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 538, "output": 1858, "cacheRead": 47616, "cacheWrite": 0, "totalTokens": 50012, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780812400098, "responseId": "resp_0fee0202d2cd3361016a250a70bcb88190a175017619cc94e6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_jrt1DP0S4jd8J9MZedkXJwKK|fc_0fee0202d2cd3361016a250a8333d88190a78bd97a61de7391", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5476 bytes to tests/src/junit/junit/3.7/src/test/java/junit_junit/FilterFactoriesTest.java"}], "isError": false, "timestamp": 1780812430293}]}
