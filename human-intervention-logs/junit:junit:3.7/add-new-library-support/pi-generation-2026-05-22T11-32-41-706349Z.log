[tool-call] delta {"path":"tests/src/junit/junit/3.7/src/test/java/junit/junit/FilterFactoriesTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage junit.junit;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.runner.Description;\nimport org.junit.runner.FilterFactories;\nimport org.junit.runner.FilterFactory;\nimport org.junit.runner.FilterFactoryParams;\nimport org.junit.runner.Request;\nimport org.junit.runner.manipulation.Filter;\nimport org.junit.runner.manipulation.NoTestsRemainException;\nimport org.junit.jupiter.api.Test;\n\npublic class FilterFactoriesTest {\n    @Test\n    void createsFilterFactoryFromClassName() throws Exception {\n        Filter filter = FilterFactories.createFilter(\n                NamePrefixFilterFactory.class.getName(),\n                new FilterFactoryParams(Request.aClass(FilterTarget.class), \"allowed\"));\n\n        Description allowedDescription = Description.createTestDescription(FilterTarget.class, \"allowedTest\");\n        Description rejectedDescription = Description.createTestDescription(FilterTarget.class, \"rejectedTest\");\n\n        assertThat(filter.shouldRun(allowedDescription)).isTrue();\n        assertThat(filter.shouldRun(rejectedDescription)).isFalse();\n        assertThat(filter.describe()).contains(\"allowed\");\n    }\n\n    public static final class NamePrefixFilterFactory implements FilterFactory {\n        public NamePrefixFilterFactory() {\n        }\n\n        @Override\n        public Filter createFilter(FilterFactoryParams params) {\n            String prefix = params.getArgs();\n            return new Filter() {\n                @Override\n                public boolean shouldRun(Description description) {\n                    return description.getMethodName().startsWith(prefix);\n      