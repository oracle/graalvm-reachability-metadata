tories;\nimport org.junit.runner.FilterFactory;\nimport org.junit.runner.FilterFactoryParams;\nimport org.junit.runner.Request;\nimport org.junit.runner.manipulation.Filter;\nimport org.junit.jupiter.api.Test;\n", "newText": "import static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport org.junit.internal.JUnitSystem;\nimport org.junit.runner.Description;\nimport org.junit.runner.FilterFactory;\nimport org.junit.runner.FilterFactoryParams;\nimport org.junit.runner.JUnitCore;\nimport org.junit.runner.Result;\nimport org.junit.runner.manipulation.Filter;\nimport org.junit.jupiter.api.Test;\n"}, {"oldText": "    void createsFilterFactoryFromClassName() throws Exception {\n        Filter filter = FilterFactories.createFilterFromFilterSpec(\n                Request.aClass(FilterTarget.class),\n                NamePrefixFilterFactory.class.getName() + \"=allowed\");\n\n        Description allowedDescription = Description.createTestDescription(FilterTarget.class, \"allowedTest\");\n        Description rejectedDescription = Description.createTestDescription(FilterTarget.class, \"rejectedTest\");\n\n        assertThat(filter.shouldRun(allowedDescription)).isTrue();\n        assertThat(filter.shouldRun(rejectedDescription)).isFalse();\n        assertThat(filter.describe()).contains(\"allowed\");\n    }\n", "newText": "    void commandLineFilterCreatesFilterFactoryFromClassName() {\n        FilterTarget.allowedRuns.set(0);\n        FilterTarget.rejectedRuns.set(0);\n\n        Result result = new JUnitCore().runMain(\n                new CapturingJUnitSystem(),\n                \"--filter=\" + NamePrefixFilterFactory.class.getName() + \"=allowed\",\n                FilterTarget.class.getName());\n\n        assertThat(result.wasSuccessful()).isTrue();\n        assertThat(result.getRunCount()).isEqualTo(1);\n        assertThat(FilterTarget.allowedRuns).hasValue(1);\n        assertThat(FilterTarget.rejectedRuns).hasValue(0);\n    }\n"}, {"oldText": "                public boolean shouldRun(Description description) {\n                    return description.getMethodName().startsWith(prefix);\n                }\n", "newText": "                public boolean shouldRun(Description description) {\n                    if (description.isSuite()) {\n                        return true;\n                    }\n                    String methodName = description.getMethodName();\n                    return methodName != null && methodName.startsWith(prefix);\n                }\n"}, {"oldText": "    public static final class FilterTarget {\n        @org.junit.Test\n        public void allowedTest() {\n        }\n\n        @org.junit.Test\n        public void rejectedTest() {\n        }\n    }\n", "newText": "    public static final class FilterTarget {\n        static final AtomicInteger allowedRuns = new AtomicInteger();\n        static final AtomicInteger rejectedRuns = new AtomicInteger();\n\n        @org.junit.Test\n        public void allowedTest() {\n            allowedRuns.incrementAndGet();\n        }\n\n        @org.junit.Test\n        public void rejectedTest() {\n            rejectedRuns.incrementAndGet();\n        }\n    }\n\n    public static final class CapturingJUnitSystem implements JUnitSystem {\n        private final PrintStream output = new PrintStream(new ByteArrayOutputStream());\n\n        @Override\n        public PrintStream out() {\n            return output;\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 5010, "output": 1873, "cacheRead": 31232, "cacheWrite": 0, "totalTokens": 38115, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779449636095, "responseId": "resp_0500ac25b6889f15016a103f248b908193aed31a3890342b1d"}}
