       1	package junit.runner;
       2	
       3	/**
       4	 * A TestSuite loader that can reload classes.
       5	 */
       6	public class ReloadingTestSuiteLoader implements TestSuiteLoader {
       7		public Class load(String suiteClassName) throws ClassNotFoundException {
       8			TestCaseClassLoader loader= new TestCaseClassLoader();
       9			return loader.loadClass(suiteClassName, true);
      10		}
      11		public Class reload(Class aClass) throws ClassNotFoundException {
      12			TestCaseClassLoader loader= new TestCaseClassLoader();
      13			return loader.loadClass(aClass.getName(), true);
      14		}
      15	}
