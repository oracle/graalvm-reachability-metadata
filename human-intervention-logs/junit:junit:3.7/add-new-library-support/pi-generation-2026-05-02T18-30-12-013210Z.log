enuBar mb = new MenuBar();\r\n   150\t\t\tcreateMenus(mb);\r\n   151\t\t\tframe.setMenuBar(mb);\r\n   152\t\t\t\r\n   153\t\t\t//---- first section\r\n   154\t\t\tLabel suiteLabel= new Label(\"Test class name:\");\r\n   155\t\r\n   156\t\t\tfSuiteField= new TextField(suiteName != null ? suiteName : \"\");\r\n   157\t\t\tfSuiteField.selectAll();\r\n   158\t\t\tfSuiteField.requestFocus();\r\n   159\t\t\tfSuiteField.setFont(PLAIN_FONT);\r\n   160\t\t\tfSuiteField.setColumns(40);\r\n   161\t\t\tfSuiteField.addActionListener(\r\n   162\t\t\t\tnew ActionListener() {\r\n   163\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   164\t\t\t\t\t\trunSuite();\r\n   165\t\t\t\t\t}\r\n   166\t\t\t\t}\r\n   167\t\t\t);\r\n   168\t\t\tfSuiteField.addTextListener(\r\n   169\t\t\t\tnew TextListener() {\r\n   170\t\t\t\t\tpublic void textValueChanged(TextEvent e) {\r\n   171\t\t\t\t\t\tfRun.setEnabled(fSuiteField.getText().length() > 0);\r\n   172\t\t\t\t\t\tfStatusLine.setText(\"\");\r\n   173\t\t\t\t\t}\r\n   174\t\t\t\t}\r\n   175\t\t\t);\r\n   176\t\t\tfRun= new Button(\"Run\");\r\n   177\t\t\tfRun.setEnabled(false);\r\n   178\t\t\tfRun.addActionListener(\r\n   179\t\t\t\tnew ActionListener() {\r\n   180\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   181\t\t\t\t\t\trunSuite();\r\n   182\t\t\t\t\t}\r\n   183\t\t\t\t}\r\n   184\t\t\t);\r\n   185\t\t\tboolean useLoader= useReloadingTestSuiteLoader();\r\n   186\t\t\tfUseLoadingRunner= new Checkbox(\"Reload classes every run\", useLoader);\r\n   187\t\t\tif (inVAJava())\r\n   188\t\t\t\tfUseLoadingRunner.setVisible(false);\r\n   189\t\t\t\t\r\n   190\t\t\t//---- second section\r\n   191\t\t\tfProgressIndicator= new ProgressBar();\t\r\n   192\t\r\n   193\t\t\t//---- third section \r\n   194\t\t\tfNumberOfErrors= new Label(\"0000\", Label.RIGHT);\r\n   195\t\t\tfNumberOfErrors.setText(\"0\");\r\n   196\t\t\tfNumberOfErrors.setFont(PLAIN_FONT);\r\n   197\t\t\r\n   198\t\t\tfNumberOfFailures= new Label(\"0000\", Label.RIGHT);\r\n   199\t\t\tfNumberOfFailures.setText(\"0\");\r\n   200\t\t\tfNumberOfFailures.setFont(PLAIN_FONT);\r\n   201\t\t\r\n   202\t\t\tfNumberOfRuns= new Label(\"0000\", Label.RIGHT);\r\n   203\t\t\tfNumberOfRuns.setText(\"0\");\r\n   204\t\t\tfNumberOfRuns.setFont(PLAIN_FONT);\r\n   205\t\t\r\n   206\t\t\tPanel numbersPanel= new Panel(new FlowLayout());\r\n   207\t\t\tnumbersPanel.add(new Label(\"Runs:\"));\t\t\tnumbersPanel.add(fNumberOfRuns);\r\n   208\t\t\tnumbersPanel.add(new Label(\"   Errors:\"));\t\tnumbersPanel.add(fNumberOfErrors);\r\n   209\t\t\tnumbersPanel.add(new Label(\"   Failures:\"));\tnumbersPanel.add(fNumberOfFailures);\r\n   210\t\r\n   211\t\t\r\n   212\t\t\t//---- fourth section\r\n   213\t\t\tLabel failureLabel= new Label(\"Errors and Failures:\");\r\n   214\t\t\t\r\n   215\t\t\tfFailureList= new List(5);\r\n   216\t\t\tfFailureList.addItemListener(\r\n   217\t\t\t\tnew ItemListener() {\r\n   218\t\t\t\t\tpublic void itemStateChanged(ItemEvent e) {\r\n   219\t\t\t\t\t\tfailureSelected();\r\n   220\t\t\t\t\t}\r\n   221\t\t\t\t}\r\n   222\t\t\t);\r\n   223\t\t\tfRerunButton= new Button(\"Run\");\r\n   224\t\t\tfRerunButton.setEnabled(false);\r\n   225\t\t\tfRerunButton.addActionListener(\r\n   226\t\t\t\tnew ActionListener() {\r\n   227\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   228\t\t\t\t\t\trerun();\r\n   229\t\t\t\t\t}\r\n   230\t\t\t\t}\r\n   231\t\t\t);\r\n   232\t\r\n   233\t\t\tPanel failedPanel= new Panel(new GridLayout(0, 1, 0, 2));\r\n   234\t\t\tfailedPanel.add(fRerunButton);\r\n   235\t\t\t\r\n   236\t\t\tfTraceArea= new TextArea();\r\n   237\t\t\tfTraceArea.setRows(5);\r\n   238\t\t\tfTraceArea.setColumns(60);\r\n   239\t\r\n   240\t\t\t//---- fifth section\r\n   241\t\t\tfStatusLine= new TextField();\r\n   242\t\t\tfStatusLine.setFont(PLAIN_FONT);\r\n   243\t\t\tfStatusLine.setEditable(false);\r\n   244\t\t\tfStatusLine.setForeground(Color.red);\r\n   245\t\r\n   246\t\t\tfQuitButton= new Button(\"Exit\");\r\n   247\t\t\tfQuitButton.addActionListener(\r\n   248\t\t\t\tnew ActionListener() {\r\n   249\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   250\t\t\t\t\t\tSystem.exit(0);\r\n   251\t\t\t\t\t}\r\n   252\t\t\t\t}\r\n   253\t\t\t);\r\n   254\t\t\r\n   255\t\t\t// ---------\r\n   256\t\t\tfLogo= new Logo();\r\n   257\t\t\r\n   258\t\t\t//---- overall layout\r\n   259\t\t\tPanel panel= new Panel(new GridBagLayout());\r\n   260\t\t\r\n   261\t\t\taddGrid(panel, suiteLabel,\t\t 0, 0, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   262\t\t\t\r\n   263\t\t\taddGrid(panel, fSuiteField, \t 0, 1, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   264\t\t\taddGrid(panel, fRun, \t\t\t 2, 1, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   265\t\t\taddGrid(panel, fUseLoadingRunner, 0, 2, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   266\t\t\taddGrid(panel, fProgressIndicator, 0, 3, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   267\t\t\taddGrid(panel, fLogo, \t\t\t 2, 3, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.NORTH);\r\n   268\t\r\n   269\t\t\taddGrid(panel, numbersPanel,\t 0, 4, 2, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.CENTER);\r\n   270\t\r\n   271\t\t\taddGrid(panel, failureLabel, \t 0, 5, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   272\t\t\taddGrid(panel, fFailureList, \t 0, 6, 2, GridBagConstraints.BOTH, \t\t\t1.0, GridBagConstraints.WEST);\r\n   273\t\t\taddGrid(panel, failedPanel, \t 2, 6, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   274\t\t\taddGrid(panel, fTraceArea, \t     0, 7, 2, GridBagConstraints.BOTH, \t\t\t1.0, GridBagConstraints.WEST);\r\n   275\t\t\t\r\n   276\t\t\taddGrid(panel, fStatusLine, \t 0, 8, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.CENTER);\r\n   277\t\t\taddGrid(panel, fQuitButton, \t 2, 8, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   278\t\t\t\r\n   279\t\t\tframe.add(panel, BorderLayout.CENTER);\r\n   280\t\t\tframe.pack();\r\n   281\t\t\treturn frame;\r\n   282\t\t}\r\n   283\t\t\r\n   284\t\tpublic void failureSelected() {\r\n   285\t\t\tfRerunButton.setEnabled(isErrorSelected());\r\n   286\t\t\tshowErrorTrace();\r\n   287\t\t}\r\n   288\t\r\n   289\t\tpublic void endTest(Test test) {\r\n   290\t\t\tsetLabelValue(fNumberOfRuns, fTestResult.runCount());\r\n   291\t\t\tsynchronized(this) {\r\n   292\t\t\t\tfProgressIndicator.step(fTestResult.wasSuccessful());\r\n   293\t\t\t}\r\n   294\t\t}\r\n   295\t\t\t\r\n   296\t\tprivate boolean isErrorSelected() {\r\n   297\t\t\treturn fFailureList.getSelectedIndex() != -1;\r\n   298\t\t}\r\n   299\t\t\r\n   300\t\tprivate Image loadFrameIcon() {\r\n   301\t\t\tToolkit toolkit= Toolkit.getDefaultToolkit();\r\n   302\t\t\ttry {\r\n   303\t\t\t\tjava.net.URL url= BaseTestRunner.class.getResource(\"smalllogo.gif\");\r\n   304\t\t\t\treturn toolkit.createImage((ImageProducer) url.getContent());\r\n   305\t\t\t} catch (Exception ex) {\r\n   306\t\t\t}\r\n   307\t\t\treturn null;\r\n   308\t\t}\r\n   309\t\t\r\n   310\t\tpublic Thread getRunner() {\r\n   311\t\t\treturn fRunner;\r\n   312\t\t}\r\n   313\t\t\r\n   314\t\tpublic static void main(String[] args) {\r\n   315\t\t\tnew TestRunner().start(args);\r\n   316\t\t}\r\n   317\t\t \r\n   318\t\tpublic static void run(Class test) {\r\n   319\t\t\tString args[]= { test.getName() };\t\r\n   320\t\t\tmain(args);\r\n   321\t\t}\r\n   322\t\t\r\n   323\t\tpublic void rerun() {\r\n   324\t\t\tint index= fFailureList.getSelectedIndex();\r\n   325\t\t\tif (index == -1)\r\n   326\t\t\t\treturn;\r\n   327\t\t\r\n   328\t\t\tTest test= (Test)fFailedTests.elementAt(index);\r\n   329\t\t\tif (!(test instanceof TestCase)) {\r\n   330\t\t\t\tshowInfo(\"Could not reload \"+ test.toString());\r\n   331\t\t\t\treturn;\r\n   332\t\t\t}\r\n   333\t\t\tTest reloadedTest= null;\r\n   334\t\t\ttry {\r\n   335\t\t\t\tClass reloadedTestClass= getLoader().reload(test.getClass());\r\n   336\t\t\t\tClass[] classArgs= { String.class };\r\n   337\t\t\t\tConstructor constructor= reloadedTestClass.getConstructor(classArgs);\r\n   338\t\t\t\tObject[] args= new Object[]{((TestCase)test).getName()};\r\n   339\t\t\t\treloadedTest=(Test)constructor.newInstance(args);\r\n   340\t\t\t} catch(Exception e) {\r\n   341\t\t\t\tshowInfo(\"Could not reload \"+ test.toString());\r\n   342\t\t\t\treturn;\r\n   343\t\t\t}\r\n   344\t\t\tTestResult result= new TestResult();\r\n   345\t\t\treloadedTest.run(result);\r\n   346\t\t\t\r\n   347\t\t\tString message= reloadedTest.toString();\r\n   348\t\t\tif(result.wasSuccessful())\r\n   349\t\t\t\tshowInfo(message+\" was successful\");\r\n   350\t\t\telse if (result.errorCount() == 1)\r\n   351\t\t\t\tshowStatus(message+\" had an error\");\r\n   352\t\t\telse\r\n   353\t\t\t\tshowStatus(message+\" had a failure\");\r\n   354\t\t}\r\n   355\t\t\r\n   356\t\tprotected void reset() {\r\n   357\t\t\tsetLabelValue(fNumberOfErrors, 0);\r\n   358\t\t\tsetLabelValue(fNumberOfFailures, 0);\r\n   359\t\t\tsetLabelValue(fNumberOfRuns, 0);\r\n   360\t\t\tfProgressIndicator.reset();\r\n   361\t\t\tfRerunButton.setEnabled(false);\r\n   362\t\t\tfFailureList.removeAll();\r\n   363\t\t\tfExceptions= new Vector(10);\r\n   364\t\t\tfFailedTests= new Vector(10);\r\n   365\t\t\tfTraceArea.setText(\"\");\r\n   366\t\r\n   367\t\t}\r\n   368\t\t/**\r\n   369\t\t * runs a suite.\r\n   370\t\t * @deprecated use runSuite() instead\r\n   371\t\t */\r\n   372\t\tpublic void run() {\r\n   373\t\t\trunSuite();\r\n   374\t\t}\r\n   375\t\t\r\n   376\t\tprotected void runFailed(String message) {\r\n   377\t\t\tshowStatus(message);\r\n   378\t\t\tfRun.setLabel(\"Run\");\r\n   379\t\t\tfRunner= null;\r\n   380\t\t}\r\n   381\t\t\r\n   382\t\tsynchronized public void runSuite() {\r\n   383\t\t\tif (fRunner != null) {\r\n   384\t\t\t\tfTestResult.stop();\r\n   385\t\t\t} else {\r\n   386\t\t\t\tsetLoading(shouldReload());\r\n   387\t\t\t\tfRun.setLabel(\"Stop\");\r\n   388\t\t\t\tshowInfo(\"Initializing...\");\r\n   389\t\t\t\treset();\r\n   390\t\t\t\t\r\n"}], "isError": false, "timestamp": 1777746490421}}
[recv] {"type": "message_end", "message": {"role": "toolResult", "toolCallId": "call_mMynkLTuzDB5ZMu0bmMzi9AC|fc_0890252afdf22a370169f642397f8481938f3351e51246a495", "toolName": "bash", "content": [{"type": "text", "text": "     1\tpackage junit.awtui;\r\n     2\t\r\n     3\timport junit.framework.*;\r\n     4\timport junit.runner.*;\r\n     5\t\r\n     6\timport java.util.Vector;\r\n     7\timport java.lang.reflect.*;\r\n     8\timport java.awt.*;\r\n     9\timport java.awt.event.*;\r\n    10\timport java.awt.image.*;\r\n    11\timport java.io.*;\r\n    12\t \r\n    13\t/**\r\n    14\t * An AWT based user interface to run tests.\r\n    15\t * Enter the name of a class which either provides a static\r\n    16\t * suite method or is a subclass of TestCase.\r\n    17\t * <pre>\r\n    18\t * Synopsis: java junit.awtui.TestRunner [-noloading] [TestCase]\r\n    19\t * </pre>\r\n    20\t * TestRunner takes as an optional argument the name of the testcase class to be run.\r\n    21\t */\r\n    22\t public class TestRunner extends BaseTestRunner {\r\n    23\t\tprotected Frame fFrame;\r\n    24\t\tprotected Vector fExceptions;\r\n    25\t\tprotected Vector fFailedTests;\r\n    26\t\tprotected Thread fRunner;\r\n    27\t\tprotected TestResult fTestResult;\r\n    28\t\t\r\n    29\t\tprotected TextArea fTraceArea;\r\n    30\t\tprotected TextField fSuiteField;\r\n    31\t\tprotected Button fRun;\r\n    32\t\tprotected ProgressBar fProgressIndicator;\r\n    33\t\tprotected List fFailureList;\r\n    34\t\tprotected Logo fLogo;\r\n    35\t\tprotected Label fNumberOfErrors;\r\n    36\t\tprotected Label fNumberOfFailures;\r\n    37\t\tprotected Label fNumberOfRuns;\r\n    38\t\tprotected Button fQuitButton;\r\n    39\t\tprotected Button fRerunButton;\r\n    40\t\tprotected TextField fStatusLine;\r\n    41\t\tprotected Checkbox fUseLoadingRunner;\r\n    42\t\t\r\n    43\t\tprotected static Font PLAIN_FONT= new Font(\"dialog\", Font.PLAIN, 12);\r\n    44\t\tprivate static final int GAP= 4;\r\n    45\t\tprivate static final String SUITE_METHODNAME= \"suite\";\r\n    46\t\t\r\n    47\t\tpublic TestRunner() {\r\n    48\t\t}\r\n    49\t\t \r\n    50\t\tprivate void about() {\r\n    51\t\t\tAboutDialog about= new AboutDialog(fFrame);\r\n    52\t\t\tabout.setModal(true);\r\n    53\t\t\tabout.setLocation(300, 300);\r\n    54\t\t\tabout.setVisible(true);\r\n    55\t\t}\r\n    56\t\t\r\n    57\t\tpublic void addError(Test test, Throwable t) {\r\n    58\t\t\tfNumberOfErrors.setText(Integer.toString(fTestResult.errorCount()));\r\n    59\t\t\tappendFailure(\"Error\", test, t);\r\n    60\t\t}\r\n    61\t\r\n    62\t\tpublic void addFailure(Test test, AssertionFailedError t) {\r\n    63\t\t\tfNumberOfFailures.setText(Integer.toString(fTestResult.failureCount()));\r\n    64\t\t\tappendFailure(\"Failure\", test, t);\r\n    65\t\t}\r\n    66\t\t\r\n    67\t\tprotected void addGrid(Panel p, Component co, int x, int y, int w, int fill, double wx, int anchor) {\r\n    68\t\t\tGridBagConstraints c= new GridBagConstraints();\r\n    69\t\t\tc.gridx= x; c.gridy= y;\r\n    70\t\t\tc.gridwidth= w;\r\n    71\t\t\tc.anchor= anchor;\r\n    72\t\t\tc.weightx= wx;\r\n    73\t\t\tc.fill= fill;\r\n    74\t\t\tif (fill == GridBagConstraints.BOTH || fill == GridBagConstraints.VERTICAL)\r\n    75\t\t\t\tc.weighty= 1.0;\r\n    76\t\t\tc.insets= new Insets(y == 0 ? GAP : 0, x == 0 ? GAP : 0, GAP, GAP);\r\n    77\t\t\tp.add(co, c);\r\n    78\t\t}\r\n    79\t\t\r\n    80\t\tprivate void appendFailure(String kind, Test test, Throwable t) {\r\n    81\t\t\tkind+= \": \" + test;\r\n    82\t\t\tString msg= t.getMessage();\r\n    83\t\t\tif (msg != null) {\r\n    84\t\t\t\tkind+= \":\" + truncate(msg); \r\n    85\t\t\t}\r\n    86\t\t\tfFailureList.add(kind);\r\n    87\t\t\tfExceptions.addElement(t);\r\n    88\t\t\tfFailedTests.addElement(test);\r\n    89\t\t\tif (fFailureList.getItemCount() == 1) {\r\n    90\t\t\t\tfFailureList.select(0);\r\n    91\t\t\t\tfailureSelected();\t\r\n    92\t\t\t}\r\n    93\t\t}\r\n    94\t\t/**\r\n    95\t\t * Creates the JUnit menu. Clients override this\r\n    96\t\t * method to add additional menu items.\r\n    97\t\t */\r\n    98\t\tprotected Menu createJUnitMenu() {\r\n    99\t\t\tMenu menu= new Menu(\"JUnit\");\r\n   100\t\t\tMenuItem mi= new MenuItem(\"About...\");\r\n   101\t\t\tmi.addActionListener(\r\n   102\t\t\t    new ActionListener() {\r\n   103\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   104\t\t\t            about();\r\n   105\t\t\t        }\r\n   106\t\t\t    }\r\n   107\t\t\t);\r\n   108\t\t\tmenu.add(mi);\r\n   109\t\t\t\r\n   110\t\t\tmenu.addSeparator();\r\n   111\t\t\tmi= new MenuItem(\"Exit\");\r\n   112\t\t\tmi.addActionListener(\r\n   113\t\t\t    new ActionListener() {\r\n   114\t\t\t        public void actionPerformed(ActionEvent event) {\r\n   115\t\t\t            System.exit(0);\r\n   116\t\t\t        }\r\n   117\t\t\t    }\r\n   118\t\t\t);\r\n   119\t\t\tmenu.add(mi);\r\n   120\t\t\treturn menu;\r\n   121\t\t}\r\n   122\t\t\r\n   123\t\tprotected void createMenus(MenuBar mb) {\r\n   124\t\t\tmb.add(createJUnitMenu());\r\n   125\t\t}\r\n   126\t\tprotected TestResult createTestResult() {\r\n   127\t\t\treturn new TestResult();\r\n   128\t\t}\r\n   129\t\t\r\n   130\t\tprotected Frame createUI(String suiteName) {\t\r\n   131\t\t\tFrame frame= new Frame(\"JUnit\");\r\n   132\t\t\tImage icon= loadFrameIcon();\t\r\n   133\t\t\tif (icon != null)\r\n   134\t\t\t\tframe.setIconImage(icon);\r\n   135\t\r\n   136\t\t\tframe.setLayout(new BorderLayout(0, 0));\r\n   137\t\t\tframe.setBackground(SystemColor.control);\r\n   138\t\t\tfinal Frame finalFrame= frame;\r\n   139\t\t\t\r\n   140\t\t\tframe.addWindowListener(\r\n   141\t\t\t\tnew WindowAdapter() {\r\n   142\t\t\t\t\tpublic void windowClosing(WindowEvent e) {\r\n   143\t\t\t\t\t\tfinalFrame.dispose();\r\n   144\t\t\t\t\t\tSystem.exit(0);\r\n   145\t\t\t\t\t}\r\n   146\t\t\t\t}\r\n   147\t\t\t); \r\n   148\t\r\n   149\t\t\tMenuBar mb = new MenuBar();\r\n   150\t\t\tcreateMenus(mb);\r\n   151\t\t\tframe.setMenuBar(mb);\r\n   152\t\t\t\r\n   153\t\t\t//---- first section\r\n   154\t\t\tLabel suiteLabel= new Label(\"Test class name:\");\r\n   155\t\r\n   156\t\t\tfSuiteField= new TextField(suiteName != null ? suiteName : \"\");\r\n   157\t\t\tfSuiteField.selectAll();\r\n   158\t\t\tfSuiteField.requestFocus();\r\n   159\t\t\tfSuiteField.setFont(PLAIN_FONT);\r\n   160\t\t\tfSuiteField.setColumns(40);\r\n   161\t\t\tfSuiteField.addActionListener(\r\n   162\t\t\t\tnew ActionListener() {\r\n   163\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   164\t\t\t\t\t\trunSuite();\r\n   165\t\t\t\t\t}\r\n   166\t\t\t\t}\r\n   167\t\t\t);\r\n   168\t\t\tfSuiteField.addTextListener(\r\n   169\t\t\t\tnew TextListener() {\r\n   170\t\t\t\t\tpublic void textValueChanged(TextEvent e) {\r\n   171\t\t\t\t\t\tfRun.setEnabled(fSuiteField.getText().length() > 0);\r\n   172\t\t\t\t\t\tfStatusLine.setText(\"\");\r\n   173\t\t\t\t\t}\r\n   174\t\t\t\t}\r\n   175\t\t\t);\r\n   176\t\t\tfRun= new Button(\"Run\");\r\n   177\t\t\tfRun.setEnabled(false);\r\n   178\t\t\tfRun.addActionListener(\r\n   179\t\t\t\tnew ActionListener() {\r\n   180\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   181\t\t\t\t\t\trunSuite();\r\n   182\t\t\t\t\t}\r\n   183\t\t\t\t}\r\n   184\t\t\t);\r\n   185\t\t\tboolean useLoader= useReloadingTestSuiteLoader();\r\n   186\t\t\tfUseLoadingRunner= new Checkbox(\"Reload classes every run\", useLoader);\r\n   187\t\t\tif (inVAJava())\r\n   188\t\t\t\tfUseLoadingRunner.setVisible(false);\r\n   189\t\t\t\t\r\n   190\t\t\t//---- second section\r\n   191\t\t\tfProgressIndicator= new ProgressBar();\t\r\n   192\t\r\n   193\t\t\t//---- third section \r\n   194\t\t\tfNumberOfErrors= new Label(\"0000\", Label.RIGHT);\r\n   195\t\t\tfNumberOfErrors.setText(\"0\");\r\n   196\t\t\tfNumberOfErrors.setFont(PLAIN_FONT);\r\n   197\t\t\r\n   198\t\t\tfNumberOfFailures= new Label(\"0000\", Label.RIGHT);\r\n   199\t\t\tfNumberOfFailures.setText(\"0\");\r\n   200\t\t\tfNumberOfFailures.setFont(PLAIN_FONT);\r\n   201\t\t\r\n   202\t\t\tfNumberOfRuns= new Label(\"0000\", Label.RIGHT);\r\n   203\t\t\tfNumberOfRuns.setText(\"0\");\r\n   204\t\t\tfNumberOfRuns.setFont(PLAIN_FONT);\r\n   205\t\t\r\n   206\t\t\tPanel numbersPanel= new Panel(new FlowLayout());\r\n   207\t\t\tnumbersPanel.add(new Label(\"Runs:\"));\t\t\tnumbersPanel.add(fNumberOfRuns);\r\n   208\t\t\tnumbersPanel.add(new Label(\"   Errors:\"));\t\tnumbersPanel.add(fNumberOfErrors);\r\n   209\t\t\tnumbersPanel.add(new Label(\"   Failures:\"));\tnumbersPanel.add(fNumberOfFailures);\r\n   210\t\r\n   211\t\t\r\n   212\t\t\t//---- fourth section\r\n   213\t\t\tLabel failureLabel= new Label(\"Errors and Failures:\");\r\n   214\t\t\t\r\n   215\t\t\tfFailureList= new List(5);\r\n   216\t\t\tfFailureList.addItemListener(\r\n   217\t\t\t\tnew ItemListener() {\r\n   218\t\t\t\t\tpublic void itemStateChanged(ItemEvent e) {\r\n   219\t\t\t\t\t\tfailureSelected();\r\n   220\t\t\t\t\t}\r\n   221\t\t\t\t}\r\n   222\t\t\t);\r\n   223\t\t\tfRerunButton= new Button(\"Run\");\r\n   224\t\t\tfRerunButton.setEnabled(false);\r\n   225\t\t\tfRerunButton.addActionListener(\r\n   226\t\t\t\tnew ActionListener() {\r\n   227\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   228\t\t\t\t\t\trerun();\r\n   229\t\t\t\t\t}\r\n   230\t\t\t\t}\r\n   231\t\t\t);\r\n   232\t\r\n   233\t\t\tPanel failedPanel= new Panel(new GridLayout(0, 1, 0, 2));\r\n   234\t\t\tfailedPanel.add(fRerunButton);\r\n   235\t\t\t\r\n   236\t\t\tfTraceArea= new TextArea();\r\n   237\t\t\tfTraceArea.setRows(5);\r\n   238\t\t\tfTraceArea.setColumns(60);\r\n   239\t\r\n   240\t\t\t//---- fifth section\r\n   241\t\t\tfStatusLine= new TextField();\r\n   242\t\t\tfStatusLine.setFont(PLAIN_FONT);\r\n   243\t\t\tfStatusLine.setEditable(false);\r\n   244\t\t\tfStatusLine.setForeground(Color.red);\r\n   245\t\r\n   246\t\t\tfQuitButton= new Button(\"Exit\");\r\n   247\t\t\tfQuitButton.addActionListener(\r\n   248\t\t\t\tnew ActionListener() {\r\n   249\t\t\t\t\tpublic void actionPerformed(ActionEvent e) {\r\n   250\t\t\t\t\t\tSystem.exit(0);\r\n   251\t\t\t\t\t}\r\n   252\t\t\t\t}\r\n   253\t\t\t);\r\n   254\t\t\r\n   255\t\t\t// ---------\r\n   256\t\t\tfLogo= new Logo();\r\n   257\t\t\r\n   258\t\t\t//---- overall layout\r\n   259\t\t\tPanel panel= new Panel(new GridBagLayout());\r\n   260\t\t\r\n   261\t\t\taddGrid(panel, suiteLabel,\t\t 0, 0, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   262\t\t\t\r\n   263\t\t\taddGrid(panel, fSuiteField, \t 0, 1, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   264\t\t\taddGrid(panel, fRun, \t\t\t 2, 1, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   265\t\t\taddGrid(panel, fUseLoadingRunner, 0, 2, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   266\t\t\taddGrid(panel, fProgressIndicator, 0, 3, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   267\t\t\taddGrid(panel, fLogo, \t\t\t 2, 3, 1, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.NORTH);\r\n   268\t\r\n   269\t\t\taddGrid(panel, numbersPanel,\t 0, 4, 2, GridBagConstraints.NONE, \t\t\t0.0, GridBagConstraints.CENTER);\r\n   270\t\r\n   271\t\t\taddGrid(panel, failureLabel, \t 0, 5, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.WEST);\r\n   272\t\t\taddGrid(panel, fFailureList, \t 0, 6, 2, GridBagConstraints.BOTH, \t\t\t1.0, GridBagConstraints.WEST);\r\n   273\t\t\taddGrid(panel, failedPanel, \t 2, 6, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   274\t\t\taddGrid(panel, fTraceArea, \t     0, 7, 2, GridBagConstraints.BOTH, \t\t\t1.0, GridBagConstraints.WEST);\r\n   275\t\t\t\r\n   276\t\t\taddGrid(panel, fStatusLine, \t 0, 8, 2, GridBagConstraints.HORIZONTAL, \t1.0, GridBagConstraints.CENTER);\r\n   277\t\t\taddGrid(panel, fQuitButton, \t 2, 8, 1, GridBagConstraints.HORIZONTAL, \t0.0, GridBagConstraints.CENTER);\r\n   278\t\t\t\r\n   279\t\t\tframe.add(panel, BorderLayout.CENTER);\r\n   280\t\t\tframe.pack();\r\n   281\t\t\treturn frame;\r\n   282\t\t}\r\n   283\t\t\r\n   284\t\tpublic void failureSelected() {\r\n   285\t\t\tfRerunButton.setEnabled(isErrorSelected());\r\n   286\t\t\tshowErrorTrace();\r\n   287\t\t}\r\n   288\t\r\n   289\t\tpublic void endTest(Test test) {\r\n   290\t\t\tsetLabelValue(fNumberOfRuns, fTestResult.runCount());\r\n   291\t\t\tsynchronized(this) {\r\n   292\t\t\t\tfProgressIndicator.step(fTestResult.wasSuccessful());\r\n   293\t\t\t}\r\n   294\t\t}\r\n   295\t\t\t\r\n   296\t\tprivate boolean isErrorSelected() {\r\n   297\t\t\treturn fFailureList.getSelectedIndex() != -1;\r\n   298\t\t}\r\n   299\t\t\r\n   300\t\tprivate Image loadFrameIcon() {\r\n   301\t\t\tToolkit toolkit= Toolkit.getDefaultToolkit();\r\n   302\t\t\ttry {\r\n   303\t\t\t\tjava.net.URL url= BaseTestRunner.class.getResource(\"smalllogo.gif\");\r\n   304\t\t\t\treturn toolkit.createImage((ImageProducer) url.getContent());\r\n   305\t\t\t} catch (Exception ex) {\r\n   306\t\t\t}\r\n   307\t\t\treturn null;\r\n   308\t\t}\r\n   309\t\t\r\n   310\t\tpublic Thread getRunner() {\r\n   311\t\t\treturn fRunner;\r\n   312\t\t}\r\n   313\t\t\r\n   314\t\tpublic static void main(String[] args) {\r\n   315\t\t\tnew TestRunner().start(args);\r\n   316\t\t}\r\n   317\t\t \r\n   318\t\tpublic static void run(Class test) {\r\n   319\t\t\tString args[]= { test.getName() };\t\r\n   320\t\t\tmain(args);\r\n   321\t\t}\r\n   322\t\t\r\n   323\t\tpublic void rerun() {\r\n   324\t\t\tint index= fFailureList.getSelectedIndex();\r\n   325\t\t\tif (index == -1)\r\n   326\t\t\t\treturn;\r\n   327\t\t\r\n   328\t\t\tTest test= (Test)fFailedTests.elementAt(index);\r\n   329\t\t\tif (!(test instanceof TestCase)) {\r\n   330\t\t\t\tshowInfo(\"Could not reload \"+ test.toString());\r\n   331\t\t\t\treturn;\r\n   332\t\t\t}\r\n   333\t\t\tTest reloadedTest= null;\r\n   334\t\t\ttry {\r\n   335\t\t\t\tClass reloadedTestClass= getLoader().reload(test.getClass());\r\n   336\t\t\t\tClass[] classArgs= { String.class };\r\n   337\t\t\t\tConstructor constructor= reloadedTestClass.getConstructor(classArgs);\r\n   338\t\t\t\tObject[] args= new Object[]{((TestCase)test).getName()};\r\n   339\t\t\t\treloadedTest=(Test)constructor.newInstance(args);\r\n   340\t\t\t} catch(Exception e) {\r\n   341\t\t\t\tshowInfo(\"Could not reload \"+ test.toString());\r\n   342\t\t\t\treturn;\r\n   343\t\t\t}\r\n   344\t\t\tTestResult result= new TestResult();\r\n   345\t\t\treloadedTest.run(result);\r\n   346\t\t\t\r\n   347\t\t\tString message= reloadedTest.toString();\r\n   348\t\t\tif(result.wasSuccessful())\r\n   349\t\t\t\tshowInfo(message+\" was successful\");\r\n   350\t\t\telse if (result.errorCount() == 1)\r\n   351\t\t\t\tshowStatus(message+\" had an error\");\r\n   352\t\t\telse\r\n   353\t\t\t\tshowStatus(message+\" had a failure\");\r\n   354\t\t}\r\n   355\t\t\r\n   356\t\tprotected void reset() {\r\n   357\t\t\tsetLabelValue(fNumberOfErrors, 0);\r\n   358\t\t\tsetLabelValue(fNumberOfFailures, 0);\r\n   359\t\t\tsetLabelValue(fNumberOfRuns, 0);\r\n   360\t\t\tfProgressIndicator.reset();\r\n   361\t\t\tfRerunButton.setEnabled(false);\r\n   362\t\t\tfFailureList.removeAll();\r\n   363\t\t\tfExceptions= new Vector(10);\r\n   364\t\t\tfFailedTests= new Vector(10);\r\n   365\t\t\tfTraceArea.setText(\"\");\r\n   366\t\r\n   367\t\t}\r\n   368\t\t/**\r\n   369\t\t * runs a suite.\r\n   370\t\t * @deprecated use runSuite() instead\r\n   371\t\t */\r\n   372\t\tpublic void run() {\r\n   373\t\t\trunSuite();\r\n   374\t\t}\r\n   375\t\t\r\n   376\t\tprotected void runFailed(String message) {\r\n   377\t\t\tshowStatus(message);\r\n   378\t\t\tfRun.setLabel(\"Run\");\r\n   379\t\t\tfRunner= null;\r\n   380\t\t}\r\n   381\t\t\r\n   382\t\tsynchronized public void runSuite() {\r\n   383\t\t\tif (fRunner != null) {\r\n   384\t\t\t\tfTestResult.stop();\r\n   385\t\t\t} else {\r\n   386\t\t\t\tsetLoading(shouldReload());\r\n   387\t\t\t\tfRun.setLabel(\"Stop\");\r\n   388\t\t\t\tshowInfo(\"Initializing...\");\r\n   389\t\t\t\treset();\r\n   390\t\t\t\t\r\n"}], "isError": false, "timestamp": 1777746490421}}
