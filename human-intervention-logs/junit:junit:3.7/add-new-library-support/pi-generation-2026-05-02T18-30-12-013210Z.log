     323		public void rerun() {
     324			int index= fFailureList.getSelectedIndex();
     325			if (index == -1)
     326				return;
     327		
     328			Test test= (Test)fFailedTests.elementAt(index);
     329			if (!(test instanceof TestCase)) {
     330				showInfo("Could not reload "+ test.toString());
     331				return;
     332			}
     333			Test reloadedTest= null;
     334			try {
     335				Class reloadedTestClass= getLoader().reload(test.getClass());
     336				Class[] classArgs= { String.class };
     337				Constructor constructor= reloadedTestClass.getConstructor(classArgs);
     338				Object[] args= new Object[]{((TestCase)test).getName()};
     339				reloadedTest=(Test)constructor.newInstance(args);
     340			} catch(Exception e) {
     341				showInfo("Could not reload "+ test.toString());
     342				return;
     343			}
     344			TestResult result= new TestResult();
     345			reloadedTest.run(result);
     346			
     347			String message= reloadedTest.toString();
     348			if(result.wasSuccessful())
     349				showInfo(message+" was successful");
     350			else if (result.errorCount() == 1)
     351				showStatus(message+" had an error");
     352			else
     353				showStatus(message+" had a failure");
     354		}
