ethodOrder;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport javax.swing.JButton;\nimport javax.swing.JFrame;\nimport javax.swing.JPanel;\nimport javax.swing.SwingUtilities;\nimport javax.swing.Timer;\nimport java.awt.Component;\nimport java.awt.Dialog;\nimport java.awt.Window;\nimport java.io.IOException;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.time.Duration;\nimport java.util.Arrays;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.concurrent.atomic.AtomicBoolean;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.function.BooleanSupplier;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\npublic class JunitSwinguiTestRunnerTest {\n    private static final AtomicBoolean failNextRun = new AtomicBoolean();\n    private static final AtomicInteger constructedCollectors = new AtomicInteger();\n\n    @TempDir\n    Path tempHome;\n\n    @Test\n    @Order(1)\n    void createsConfiguredFailureDetailViewAndLoadsSwingIconResource() throws Exception {\n        ExposedTestRunner runner = newRunnerWithPreferences(\n                \"FailureViewClass=junit.swingui.DefaultFailureDetailView\");\n\n        FailureDetailView view = runner.newFailureDetailView();\n        Component component = view.getComponent();\n\n        assertThat(component).isNotNull();\n        assertThat(view.getClass().getName()).isEqualTo(\"junit.swingui.DefaultFailureDetailView\");\n        assertThat(TestRunner.getIconResource(BaseTestRunner.class, \"logo.gif\")).isNotNull();\n    }\n\n    @Test\n    @Order(3)\n    void createsConfiguredTestCollectorBeforeOpeningBrowserDialog() throws Exception {\n        assertThat(new EmptyTestCollector().collectTests().hasMoreElements()).isFalse();\n        constructedCollectors.set(0);\n        ExposedTestRunner runner = newRunnerWithPreferences(\n                \"TestCollectorClass=\" + EmptyTestCollector.class.getName());\n        Timer dialogCloser = new Timer(50, ignored -> closeShowingDialogs());\n        dialogCloser.setRepeats(true);\n        JFrame frame = createRunnerUi(runner);\n\n        try {\n            dialogCloser.start();\n            runner.browseTestClasses();\n        } finally {\n            dialogCloser.stop();\n            closeShowingDialogs();\n            SwingUtilities.invokeAndWait(frame::dispose);\n        }\n\n        assertThat(constructedCollectors.get()).isGreaterThanOrEqualTo(1);\n    }\n\n    @Test\n    @Order(2)\n    void rerunsSelectedTestCaseThroughSwingRunner() throws Exception {\n        ExposedTestRunner runner = newRunnerWithPreferences();\n        runner.setLoading(false);\n        failNextRun.set(true);\n\n        JFrame frame = createRunnerUi(runner);\n        try {\n            runner.runSingleTest(new RerunnableJunit3TestCase(\"testFailsOnceThenPassesOnRerun\"));\n            waitUntil(() -> runner.rerunButton().isEnabled());\n\n            SwingUtilities.invokeAndWait(() -> runner.rerunButton().doClick());\n            waitUntil(() -> runner.statusText().contains(\"was successful\"));\n\n            assertThat(failNextRun.get()).isFalse();\n            assertThat(runner.statusText()).contains(\"testFailsOnceThenPassesOnRerun\");\n        } finally {\n            SwingUtilities.invokeAndWait(frame::dispose);\n        }\n    }\n\n    private JFrame createRunnerUi(ExposedTestRunner runner) {\n        String previousHome = System.getProperty(\"user.home\");\n        System.setProperty(\"user.home\", tempHome.toString());\n        try {\n            return runner.createRunnerUi();\n        } finally {\n            restoreProperty(\"user.home\", previousHome);\n        }\n    }\n\n    private ExposedTestRunner newRunnerWithPreferences(String... properties) throws IOException {\n        Files.write(\n                tempHome.resolve(\"junit.properties\"),\n                Arrays.asList(properties),\n                StandardCharsets.ISO_8859_1);\n        String previousHome = System.getProperty(\"user.home\");\n        System.setProperty(\"user.home\", tempHome.toString());\n        try {\n            return new ExposedTestRunner();\n        } finally {\n            restoreProperty(\"user.home\", previousHome);\n        }\n    }\n\n    private static void restoreProperty(String name, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, previousValue);\n        }\n    }\n\n    private static void closeShowingDialogs() {\n        for (Window window : Window.getWindows()) {\n            if (window instanceof Dialog && window.isShowing()) {\n                window.dispose();\n            }\n        }\n    }\n\n    private static void waitUntil(BooleanSupplier condition) throws Exception {\n        long deadline = System.nanoTime() + Duration.ofSeconds(5).toNanos();\n        while (System.nanoTime() < deadline) {\n            if (condition.getAsBoolean()) {\n                return;\n            }\n            SwingUtilities.invokeAndWait(() -> {\n            });\n            Thread.sleep(25);\n        }\n        assertThat(condition.getAsBoolean()).isTrue();\n    }\n\n    public static final class EmptyTestCollector implements TestCollector {\n        public EmptyTestCollector() {\n            constructedCollectors.incrementAndGet();\n        }\n\n        @Override\n        public Enumeration collectTests() {\n            return Collections.emptyEnumeration();\n        }\n    }\n\n    public static final class RerunnableJunit3TestCase extends TestCase {\n        public RerunnableJunit3TestCase(String name) {\n            super(name);\n        }\n\n        public void testFailsOnceThenPassesOnRerun() {\n            if (failNextRun.getAndSet(false)) {\n                throw new AssertionFailedError(\"first run fails so the Swing runner can rerun it\");\n            }\n        }\n    }\n\n    private static final class ExposedTestRunner extends TestRunner {\n        private JButton rerunButton;\n        private JFrame frame;\n        private StatusLine statusLine;\n\n        FailureDetailView newFailureDetailView() {\n            return createFailureDetailView();\n        }\n\n        JFrame createRunnerUi() {\n            start(new String[0]);\n            return frame;\n        }\n\n        void runSingleTest(junit.framework.Test test) {\n            runTest(test);\n        }\n\n        JButton rerunButton() {\n            return rerunButton;\n        }\n\n        String statusText() {\n            return statusLine.getText();\n        }\n\n        @Override\n        protected JFrame createUI(String suiteName) {\n            frame = super.createUI(suiteName);\n            return frame;\n        }\n\n        @Override\n        protected JPanel createFailedPanel() {\n            JPanel panel = super.createFailedPanel();\n            rerunButton = (JButton) panel.getComponent(0);\n            return panel;\n        }\n\n        @Override\n        protected StatusLine createStatusLine() {\n            statusLine = super.createStatusLine();\n            return statusLine;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777746466254}, {"role": "toolResult", "toolCallId": "call_YEN8Uux6N7XgWrwtdxnGhAgi|fc_0890252afdf22a370169f6422204888193ae5ce6421c2ef123", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage legacy.junit3;\n\nimport junit.framework.AssertionFailedError;\nimport junit.framework.TestResult;\nimport junit.framework.TestSuite;\nimport junit.runner.BaseTestRunner;\nimport junit.runner.TestCaseClassLoader;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.InputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nclass Junit37MetadataTest {\n\n    @Test\n    void textRunnerBuildsWarningSuiteForLibraryClass() {\n        TestSuite suite = new TestSuite(TestSuite.class);\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        junit.textui.TestRunner runner = new junit.textui.TestRunner(new PrintStream(output));\n\n        TestResult result = runner.doRun(suite, false);\n\n        assertThat(result.runCount()).isEqualTo(1);\n        assertThat(result.failureCount()).isEqualTo(1);\n        assertThat(result.errorCount()).isZero();\n        assertThat(output.toString(StandardCharsets.UTF_8)).contains(\"FAILURES!!!\");\n    }\n\n    @Test\n    void baseRunnerLoadsLibrarySuiteByName() {\n        RecordingBaseTestRunner runner = new RecordingBaseTestRunner();\n        runner.setLoading(false);\n\n        junit.framework.Test loadedTest = runner.getTest(\"junit.framework.TestSuite\");\n\n        assertThat(loadedTest)\n                .as(\"runFailed message: %s\", runner.failedMessage())\n                .isInstanceOf(TestSuite.class);\n        assertThat(runner.failedMessage()).isNull();\n        assertThat(loadedTest.countTestCases()).isEqualTo(1);\n    }\n\n    @Test\n    void testCaseClassLoaderLoadsExcludedPackagesResource() throws Exception {\n        TestCaseClassLoader loader = new TestCaseClassLoader();\n\n        try (InputStream stream = loader.getResourceAsStream(\"junit/runner/excluded.properties\")) {\n            assertThat(stream).isNotNull();\n            assertThat(new String(stream.readAllBytes(), StandardCharsets.ISO_8859_1))\n                    .contains(\"excluded.0=sun.*\")\n                    .contains(\"excluded.5=java.*\");\n        }\n    }\n\n    private static final class RecordingBaseTestRunner extends BaseTestRunner {\n        private String failedMessage;\n\n        @Override\n        public void addError(junit.framework.Test test, Throwable throwable) {\n        }\n\n        @Override\n        public void addFailure(junit.framework.Test test, AssertionFailedError assertionFailedError) {\n        }\n\n        @Override\n        public void endTest(junit.framework.Test test) {\n        }\n\n        @Override\n        protected void runFailed(String message) {\n            failedMessage = message;\n        }\n\n        @Override\n        public void startTest(junit.framework.Test test) {\n        }\n\n        String failedMessage() {\n            return failedMessage;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777746466254}, {"role": "toolResult", "toolCallId": "call_EliBNw18DZFORQP91AuzCaTm|fc_0890252afdf22a370169f6422204908193ab689a6c7a220b00", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\nconfigurations.configureEach {\n    exclude group: \"org.junit.vintage\", module: \"junit-vintage-engine\"\n}\n\ndependencies {\n    testImplementation \"junit:junit:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777746466254}]}
