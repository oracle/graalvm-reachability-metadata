[tool-call] delta {"path":"tests/src/junit/junit/3.7/src/test/java/legacy/junit3/JunitAwtuiTestRunnerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage legacy.junit3;\n\nimport junit.framework.AssertionFailedError;\nimport junit.framework.TestCase;\nimport junit.framework.TestResult;\nimport junit.awtui.TestRunner;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.awt.Frame;\nimport java.nio.file.Path;\nimport java.util.Vector;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JunitAwtuiTestRunnerTest {\n    @TempDir\n    Path tempHome;\n\n    @Test\n    void rerunsSelectedTestCaseThroughAwtRunner() {\n        String previousHome = System.getProperty(\"user.home\");\n        System.setProperty(\"user.home\", tempHome.toString());\n        ExposedAwtTestRunner runner;\n        try {\n            runner = new ExposedAwtTestRunner();\n        } finally {\n            restoreProperty(\"user.home\", previousHome);\n        }\n        runner.setLoading(false);\n\n        Frame frame = runner.createRunnerUi();\n        try {\n            runner.recordFailedTest(new PassingJunit3TestCase(\"testPassesWhenRerun\"));\n\n            assertThat(runner.rerunButtonEnabled()).isTrue();\n\n            runner.rerun();\n\n            assertThat(runner.statusText()).contains(\"testPassesWhenRerun\").contains(\"was successful\");\n        } finally {\n            frame.dispose();\n        }\n    }\n\n    private static void restoreProperty(String name, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, previousValue);\n        }\n    }\n\n    public static final class PassingJunit3TestCase extends TestCase {\n        public PassingJunit3TestCase(String name) {\n            super(name);\n        }\n\n        public void testPassesWhenRerun() {\n            assertTrue(true);\n        }\n    }\n\n    private static final class ExposedAwtTestRunner extends TestRunner {\n        Frame createRunnerUi() {\n            fFrame = createUI(null);\n            fExceptions = new Vector();\n            fFailedTests = new Vector();\n            return fFrame;\n        }\n\n        void recordFailedTest(TestCase testCase) {\n            AssertionFailedError failure = new AssertionFailedError(\"recorded failure for AWT rerun\");\n            fTestResult = new TestResult();\n            fTestResult.addFailure(testCase, failure);\n            addFailure(testCase, failure);\n        }\n\n        boolean rerunButtonEnabled() {\n            return fRerunButton.isEnabled();\n        }\n\n        String statusText() {\n            return fStatusLine.getText();\n        }\n    }\n}\n"}
