      80		private void appendFailure(String kind, Test test, Throwable t) {
      81			kind+= ": " + test;
      82			String msg= t.getMessage();
      83			if (msg != null) {
      84				kind+= ":" + truncate(msg); 
      85			}
      86			fFailureList.add(kind);
      87			fExceptions.addElement(t);
      88			fFailedTests.addElement(test);
      89			if (fFailureList.getItemCount() == 1) {
      90				fFailureList.select(0);
      91				failureSelected();	
      92			}
      93		}
