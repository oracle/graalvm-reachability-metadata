       1	package junit.awtui;
       2	
       3	import junit.framework.*;
       4	import junit.runner.*;
       5	
       6	import java.util.Vector;
       7	import java.lang.reflect.*;
       8	import java.awt.*;
       9	import java.awt.event.*;
      10	import java.awt.image.*;
      11	import java.io.*;
      12	 
      13	/**
      14	 * An AWT based user interface to run tests.
      15	 * Enter the name of a class which either provides a static
      16	 * suite method or is a subclass of TestCase.
      17	 * <pre>
      18	 * Synopsis: java junit.awtui.TestRunner [-noloading] [TestCase]
      19	 * </pre>
      20	 * TestRunner takes as an optional argument the name of the testcase class to be run.
      21	 */
      22	 public class TestRunner extends BaseTestRunner {
      23		protected Frame fFrame;
      24		protected Vector fExceptions;
      25		protected Vector fFailedTests;
      26		protected Thread fRunner;
      27		protected TestResult fTestResult;
      28		
      29		protected TextArea fTraceArea;
      30		protected TextField fSuiteField;
      31		protected Button fRun;
      32		protected ProgressBar fProgressIndicator;
      33		protected List fFailureList;
      34		protected Logo fLogo;
      35		protected Label fNumberOfErrors;
      36		protected Label fNumberOfFailures;
      37		protected Label fNumberOfRuns;
      38		protected Button fQuitButton;
      39		protected Button fRerunButton;
      40		protected TextField fStatusLine;
      41		protected Checkbox fUseLoadingRunner;
      42		
      43		protected static Font PLAIN_FONT= new Font("dialog", Font.PLAIN, 12);
      44		private static final int GAP= 4;
      45		private static final String SUITE_METHODNAME= "suite";
      46		
      47		public TestRunner() {
      48		}
      49		 
      50		private void about() {
      51			AboutDialog about= new AboutDialog(fFrame);
      52			about.setModal(true);
      53			about.setLocation(300, 300);
      54			about.setVisible(true);
      55		}
      56		
      57		public void addError(Test test, Throwable t) {
      58			fNumberOfErrors.setText(Integer.toString(fTestResult.errorCount()));
      59			appendFailure("Error", test, t);
      60		}
      61	
      62		public void addFailure(Test test, AssertionFailedError t) {
      63			fNumberOfFailures.setText(Integer.toString(fTestResult.failureCount()));
      64			appendFailure("Failure", test, t);
      65		}
      66		
      67		protected void addGrid(Panel p, Component co, int x, int y, int w, int fill, double wx, int anchor) {
      68			GridBagConstraints c= new GridBagConstraints();
      69			c.gridx= x; c.gridy= y;
      70			c.gridwidth= w;
      71			c.anchor= anchor;
      72			c.weightx= wx;
      73			c.fill= fill;
      74			if (fill == GridBagConstraints.BOTH || fill == GridBagConstraints.VERTICAL)
      75				c.weighty= 1.0;
      76			c.insets= new Insets(y == 0 ? GAP : 0, x == 0 ? GAP : 0, GAP, GAP);
      77			p.add(co, c);
      78		}
      79		
      80		private void appendFailure(String kind, Test test, Throwable t) {
      81			kind+= ": " + test;
      82			String msg= t.getMessage();
      83			if (msg != null) {
      84				kind+= ":" + truncate(msg); 
      85			}
      86			fFailureList.add(kind);
      87			fExceptions.addElement(t);
      88			fFailedTests.addElement(test);
      89			if (fFailureList.getItemCount() == 1) {
      90				fFailureList.select(0);
      91				failureSelected();	
      92			}
      93		}
      94		/**
      95		 * Creates the JUnit menu. Clients override this
      96		 * method to add additional menu items.
      97		 */
      98		protected Menu createJUnitMenu() {
      99			Menu menu= new Menu("JUnit");
     100			MenuItem mi= new MenuItem("About...");
     101			mi.addActionListener(
     102			    new ActionListener() {
     103			        public void actionPerformed(ActionEvent event) {
     104			            about();
     105			        }
     106			    }
     107			);
     108			menu.add(mi);
     109			
     110			menu.addSeparator();
     111			mi= new MenuItem("Exit");
     112			mi.addActionListener(
     113			    new ActionListener() {
     114			        public void actionPerformed(ActionEvent event) {
     115			            System.exit(0);
     116			        }
