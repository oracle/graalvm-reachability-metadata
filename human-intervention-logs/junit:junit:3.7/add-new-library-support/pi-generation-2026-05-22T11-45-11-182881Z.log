;\n            }\n        }\n\n        public static class SecondNestedTest {\n            @org.junit.Test\n            public void recordsSecondTest() {\n                events.add(\"second\");\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 515, "output": 1156, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 22151, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779450277771, "responseId": "resp_0a842bebc2e65e29016a1041a6304c819da726c0c7f7a66681"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_s1XaNHfJdwPM3kE7KLDIXIKG|fc_0a842bebc2e65e29016a1041b26490819dac729760f29c861a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1632 bytes to tests/src/junit/junit/3.7/src/test/java/junit/junit/EnclosedTest.java"}], "isError": false, "timestamp": 1779450292986}]}
