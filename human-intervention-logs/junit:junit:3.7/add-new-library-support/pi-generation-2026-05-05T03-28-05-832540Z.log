  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Enumeration;
  
  import junit.framework.TestCase;
  import junit.framework.TestSuite;
  import org.junit.jupiter.api.Test;
  
  public class TestSuiteTest {
  
      @Test
      void discoversAndCreatesTestCaseWithStringConstructor() {
          TestSuite suite = new TestSuite(StringConstructorCase.class);
  
          TestCase testCase = onlyTestCaseIn(suite);
  
          assertThat(suite.countTestCases()).isEqualTo(1);
          assertThat(testCase).isInstanceOf(StringConstructorCase.class);
          assertThat(testCase.getName()).isEqualTo("testCreatedWithStringConstructor");
      }
  
      @Test
      void fallsBackToNoArgumentConstructorAndAssignsDiscoveredTestName() {
          TestSuite suite = new TestSuite(NoArgumentConstructorCase.class);
  
          TestCase testCase = onlyTestCaseIn(suite);
  
          assertThat(suite.countTestCases()).isEqualTo(1);
          assertThat(testCase).isInstanceOf(NoArgumentConstructorCase.class);
          assertThat(testCase.getName()).isEqualTo("testCreatedWithNoArgumentConstructor");
      }
  
      private static TestCase onlyTestCaseIn(TestSuite suite) {
          Enumeration<?> tests = suite.tests();
  
          assertThat(tests.hasMoreElements()).isTrue();
          Object test = tests.nextElement();
          assertThat(tests.hasMoreElements()).isFalse();
  
          return (TestCase) test;
      }
  
      public static class StringConstructorCase extends TestCase {
          public StringConstructorCase(String name) {
              super(name);
          }
  
          public void testCreatedWithStringConstructor() {
              assertTrue(true);
          }
      }
  
      public static class NoArgumentConstructorCase extends TestCase {
          public NoArgumentConstructorCase() {
          }
  
          public void testCreatedWithNoArgumentConstructor() {
              assertTrue(true);
          }
