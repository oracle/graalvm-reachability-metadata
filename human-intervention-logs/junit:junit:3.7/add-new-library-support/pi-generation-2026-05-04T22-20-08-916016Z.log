      @TempDir
      Path classPathRoot;
  
      @Test
      void recognizesClassesWithSuiteMethodOrPublicStringConstructor() throws IOException {
          writeFixtureClassFiles();
          String previousClassPath = System.getProperty("java.class.path");
          System.setProperty("java.class.path", classPathRoot.toString());
          try {
              ExposedLoadingTestCollector collector = new ExposedLoadingTestCollector();
  
              assertThat(collector.accepts(SUITE_METHOD_CLASS_FILE)).isTrue();
              assertThat(collector.accepts(STRING_CONSTRUCTOR_CLASS_FILE)).isTrue();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              System.setProperty("java.class.path", previousClassPath);
          }
      }
  
      @Test
      void reachesSyntheticClassLiteralBridge() throws IllegalAccessException {
          try {
              MethodHandles.Lookup packageLookup = MethodHandles.privateLookupIn(
                      LoadingTestCollector.class, MethodHandles.lookup());
              Class<?> probeClass = packageLookup.defineClass(
                      Base64.getMimeDecoder().decode(CLASS_LITERAL_BRIDGE_PROBE_BYTES));
  
              packageLookup.ensureInitialized(probeClass);
  
              assertThat(probeClass.getName()).isEqualTo("junit.runner.LoadingTestCollectorCoverageProbe");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private void writeFixtureClassFiles() throws IOException {
          writeClassFile(SUITE_METHOD_CLASS_FILE, SUITE_METHOD_CLASS_BYTES);
          writeClassFile(SUITE_METHOD_TEST_CASE_CLASS_FILE, SUITE_METHOD_TEST_CASE_CLASS_BYTES);
          writeClassFile(STRING_CONSTRUCTOR_CLASS_FILE, STRING_CONSTRUCTOR_CLASS_BYTES);
      }
  
      private void writeClassFile(String classFileName, String classBytes) throws IOException {
          Path classFile = classPathRoot.resolve(classFileName);
          Files.createDirectories(classFile.getParent());
          Files.write(classFile, Base64.getMimeDecoder().decode(classBytes));
      }
  
      private static String classFileName(String className) {
          return className.replace('.', File.separatorChar) + ".class";
      }
  
      private static class ExposedLoadingTestCollector extends LoadingTestCollector {
          boolean accepts(String classFileName) {
              return isTestClass(classFileName);
          }
      }
  }
