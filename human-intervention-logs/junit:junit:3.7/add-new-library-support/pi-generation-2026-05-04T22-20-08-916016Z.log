.awt.SystemColor;\nimport java.awt.image.BufferedImage;\n\nimport org.junit.jupiter.api.Test;\n\nimport junit.awtui.Logo;\n\npublic class LogoTest {\n\n    @Test\n    void loadsBundledLogoWhenConstructed() {\n        Logo logo = new Logo();\n\n        Dimension size = logo.getSize();\n\n        assertThat(size.width).isGreaterThan(0);\n        assertThat(size.height).isGreaterThan(0);\n    }\n\n    @Test\n    void paintsBackgroundUsingAwtControlColor() {\n        Logo logo = new Logo();\n        BufferedImage target = new BufferedImage(4, 4, BufferedImage.TYPE_INT_RGB);\n        Graphics2D graphics = target.createGraphics();\n        try {\n            logo.setSize(4, 4);\n\n            logo.paintBackground(graphics);\n        } finally {\n            graphics.dispose();\n        }\n\n        assertThat(target.getRGB(0, 0)).isEqualTo(SystemColor.control.getRGB());\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 970, "output": 883, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26429, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777933180282, "responseId": "resp_0d42836eebd4524b0169f91b7cb96481959c0c7a5df6aed401"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZYi7T6wM3fOE12Ui3TlIaFxk|fc_0d42836eebd4524b0169f91b86237c8195bdb315393349b0e4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1203 bytes to tests/src/junit/junit/3.7/src/test/java/junit_junit/LogoTest.java"}], "isError": false, "timestamp": 1777933190990}]}
