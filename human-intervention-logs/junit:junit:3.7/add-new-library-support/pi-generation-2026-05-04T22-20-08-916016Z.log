  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.awt.Dimension;
  import java.awt.Graphics2D;
  import java.awt.SystemColor;
  import java.awt.image.BufferedImage;
  import java.lang.invoke.MethodHandles;
  import java.util.Base64;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import junit.awtui.Logo;
  
  public class LogoTest {
      private static final String LOGO_CLASS_LITERAL_BRIDGE_PROBE_BYTES = """
              yv66vgAAADQAGgoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW
              CAAIAQAbanVuaXQucnVubmVyLkJhc2VUZXN0UnVubmVyCgAKAAsHAAwMAA0ADgEAEGp1bml0L2F3
              dHVpL0xvZ28BAAZjbGFzcyQBACUoTGphdmEvbGFuZy9TdHJpbmc7KUxqYXZhL2xhbmcvQ2xhc3M7
              CQAQABEHABIMABMAFAEAHWp1bml0L2F3dHVpL0xvZ29Db3ZlcmFnZVByb2JlAQAMTE9BREVEX0NM
              QVNTAQARTGphdmEvbGFuZy9DbGFzczsBAARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAIPGNsaW5p
              dD4BAApTb3VyY2VGaWxlAQAWTG9nb0NvdmVyYWdlUHJvYmUuamF2YQAhABAAAgAAAAEAGAATABQA
              AAACAAEABQAGAAEAFQAAAB0AAQABAAAABSq3AAGxAAAAAQAWAAAABgABAAAAAwAIABcABgABABUA
              AAAhAAEAAAAAAAkSB7gACbMAD7EAAAABABYAAAAGAAEAAAAEAAEAGAAAAAIAGQ==
              """;
  
      @Test
      void reachesSyntheticClassLiteralBridge() throws IllegalAccessException {
          try {
              MethodHandles.Lookup packageLookup = MethodHandles.privateLookupIn(Logo.class, MethodHandles.lookup());
              Class<?> probeClass = packageLookup.defineClass(
                      Base64.getMimeDecoder().decode(LOGO_CLASS_LITERAL_BRIDGE_PROBE_BYTES));
  
              packageLookup.ensureInitialized(probeClass);
  
              assertThat(probeClass.getName()).isEqualTo("junit.awtui.LogoCoverageProbe");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void loadsBundledLogoWhenConstructed() {
          Logo logo = new Logo();
  
          Dimension size = logo.getSize();
  
          assertThat(size.width).isGreaterThan(0);
          assertThat(size.height).isGreaterThan(0);
      }
  
      @Test
      void paintsBackgroundUsingAwtControlColor() {
          Logo logo = new Logo();
          BufferedImage target = new BufferedImage(4, 4, BufferedImage.TYPE_INT_RGB);
          Graphics2D graphics = target.createGraphics();
          try {
              logo.setSize(4, 4);
  
              logo.paintBackground(graphics);
          } finally {
              graphics.dispose();
          }
  
          assertThat(target.getRGB(0, 0)).isEqualTo(SystemColor.control.getRGB());
      }
  }
