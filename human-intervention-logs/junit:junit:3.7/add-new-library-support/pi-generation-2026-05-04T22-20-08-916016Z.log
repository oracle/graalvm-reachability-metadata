  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.InputStream;
  import java.net.URL;
  
  import org.junit.jupiter.api.Test;
  
  import junit.runner.TestCaseClassLoader;
  
  public class TestCaseClassLoaderTest {
      private static final String MISSING_RESOURCE = "junit_junit/missing-test-case-class-loader-resource.txt";
  
      @Test
      void delegatesResourceLookupsToSystemClassLoader() {
          TestCaseClassLoader loader = new TestCaseClassLoader("");
  
          URL resource = loader.getResource(MISSING_RESOURCE);
          InputStream resourceStream = loader.getResourceAsStream(MISSING_RESOURCE);
  
          assertThat(resource).isNull();
          assertThat(resourceStream).isNull();
      }
  }
