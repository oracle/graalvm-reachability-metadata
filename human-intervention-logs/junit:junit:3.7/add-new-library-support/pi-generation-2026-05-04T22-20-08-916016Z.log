[tool-call] delta {"path":"tests/src/junit/junit/3.7/src/test/java/junit_junit/LogoTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage junit_junit;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.awt.Dimension;\nimport java.awt.Graphics2D;\nimport java.awt.SystemColor;\nimport java.awt.image.BufferedImage;\n\nimport org.junit.jupiter.api.Test;\n\nimport junit.awtui.Logo;\n\npublic class LogoTest {\n\n    @Test\n    void loadsBundledLogoWhenConstructed() {\n        Logo logo = new Logo();\n\n        Dimension size = logo.getSize();\n\n        assertThat(size.width).isGreaterThan(0);\n        assertThat(size.height).isGreaterThan(0);\n    }\n\n    @Test\n    void paintsBackgroundUsingAwtControlColor() {\n        Logo logo = new Logo();\n        BufferedImage target = new BufferedImage(4, 4, BufferedImage.TYPE_INT_RGB);\n        Graphics2D graphics = target.createGraphics();\n        try {\n            logo.setSize(4, 4);\n\n            logo.paintBackground(graphics);\n        } finally {\n            graphics.dispose();\n        }\n\n        assertThat(target.getRGB(0, 0)).isEqualTo(SystemColor.control.getRGB());\n    }\n}\n"}
