[tool-call] delta {"path":"tests/src/junit/junit/3.7/src/test/java/junit_junit/AnnotatedBuilderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage junit_junit;\n\nimport static org.junit.jupiter.api.Assertions.assertSame;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport org.junit.internal.builders.AnnotatedBuilder;\nimport org.junit.jupiter.api.Test;\nimport org.junit.runner.Description;\nimport org.junit.runner.Runner;\nimport org.junit.runner.notification.RunNotifier;\nimport org.junit.runners.model.RunnerBuilder;\n\npublic class AnnotatedBuilderTest {\n\n    @Test\n    void buildsRunnerUsingClassConstructor() throws Exception {\n        RunnerBuilder suiteBuilder = new EmptyRunnerBuilder();\n        AnnotatedBuilder builder = new AnnotatedBuilder(suiteBuilder);\n\n        Runner runner = builder.buildRunner(ClassConstructorRunner.class, SampleTest.class);\n\n        assertTrue(runner instanceof ClassConstructorRunner);\n        ClassConstructorRunner classConstructorRunner = (ClassConstructorRunner) runner;\n        assertSame(SampleTest.class, classConstructorRunner.testClass);\n    }\n\n    @Test\n    void buildsRunnerUsingClassAndRunnerBuilderConstructor() throws Exception {\n        RunnerBuilder suiteBuilder = new EmptyRunnerBuilder();\n        AnnotatedBuilder builder = new AnnotatedBuilder(suiteBuilder);\n\n        Runner runner = builder.buildRunner(ClassAndBuilderConstructorRunner.class, SampleTest.class);\n\n        assertTrue(runner instanceof ClassAndBuilderConstructorRunner);\n        ClassAndBuilderConstructorRunner classAndBuilderConstructorRunner = (ClassAndBuilderConstructorRunner) runner;\n        assertSame(SampleTest.class, classAndBuilderConstructorRunner.testClass);\n        assertSame(suiteBuilder, classAndBuilderConstructorRunner.suiteBuilder);\n    }\n\n    public static class ClassConstructorRunner extends Runner {\n        private final Class<?> testClass;\n\n        public ClassConstructorRunner(Class<?> testClass) {\n            this.testClass = testClass;\n        }\n\n        @Override\n        public Description getDescription() {\n            return Description.createSuiteDescription(testClass);\n        }\n\n        @Override\n        public void run(RunNotifier notifier) {\n        }\n    }\n\n    public static class ClassAndBuilderConstructorRunner extends Runner {\n        private final Class<?> testClass;\n        private final RunnerBuilder suiteBuilder;\n\n        public ClassAndBuilderConstructorRunner(Class<?> testClass, RunnerBuilder suiteBuilder) {\n            this.testClass = testClass;\n            this.suiteBuilder = suiteBuilder;\n        }\n\n        @Override\n        public Description getDescription() {\n            return Description.createSuiteDescription(testClass);\n        }\n\n        @Override\n        public void run(RunNotifier notifier) {\n        }\n    }\n\n    public static class EmptyRunnerBuilder extends RunnerBuilder {\n        @Override\n        public Runner runnerForClass(Class<?> testClass) {\n            return null;\n        }\n    }\n\n    public static class SampleTest {\n    }\n}\n"}
