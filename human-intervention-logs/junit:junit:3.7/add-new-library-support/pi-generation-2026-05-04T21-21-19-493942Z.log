  	}
  	
  	synchronized public void runSuite() {
  		if (fRunner != null) {
  			fTestResult.stop();
  		} else {
  			setLoading(shouldReload());
  			fRun.setLabel("Stop");
  			showInfo("Initializing...");
  			reset();
  			
  			showInfo("Load Test Case...");
  
  			final Test testSuite= getTest(fSuiteField.getText());
  			if (testSuite != null) {
