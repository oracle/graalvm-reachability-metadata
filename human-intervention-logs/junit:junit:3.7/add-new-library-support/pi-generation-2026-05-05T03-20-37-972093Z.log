       6	
       7	/**
       8	 * A <code>TestSuite</code> is a <code>Composite</code> of Tests.
       9	 * It runs a collection of test cases. Here is an example using
      10	 * the dynamic test definition.
      11	 * <pre>
      12	 * TestSuite suite= new TestSuite();
      13	 * suite.addTest(new MathTest("testAdd"));
      14	 * suite.addTest(new MathTest("testDivideByZero"));
      15	 * </pre>
      16	 * Alternatively, a TestSuite can extract the tests to be run automatically.
      17	 * To do so you pass the class of your TestCase class to the
      18	 * TestSuite constructor.
      19	 * <pre>
      20	 * TestSuite suite= new TestSuite(MathTest.class);
      21	 * </pre>
      22	 * This constructor creates a suite with all the methods
      23	 * starting with "test" that take no arguments.
      24	 *
      25	 * @see Test
      26	 */
      27	public class TestSuite implements Test {
      28	
      29		private Vector fTests= new Vector(10);
      30		private String fName;
      31	
      32	   /**
      33		 * Constructs an empty TestSuite.
      34		 */
      35		public TestSuite() {
      36		}
      37		/**
      38		 * Constructs a TestSuite from the given class. Adds all the methods
      39		 * starting with "test" as test cases to the suite.
      40		 * Parts of this method was written at 2337 meters in the H�ffih�tte,
      41		 * Kanton Uri
      42		 */
      43	
      44		 public TestSuite(final Class theClass) {
      45			fName= theClass.getName();
      46			Constructor constructor= null;
      47			try {	
      48				constructor= getConstructor(theClass);
      49			} catch (NoSuchMethodException e) {
      50				addTest(warning("Class "+theClass.getName()+" has no public constructor TestCase(String name)"));
      51				return;
      52			}
      53	
      54			if (!Modifier.isPublic(theClass.getModifiers())) {
      55				addTest(warning("Class "+theClass.getName()+" is not public"));
      56				return;
      57			}
      58	
      59			Class superClass= theClass;
      60			Vector names= new Vector();
      61			while (Test.class.isAssignableFrom(superClass)) {
      62				Method[] methods= superClass.getDeclaredMethods();
      63				for (int i= 0; i < methods.length; i++) {
      64					addTestMethod(methods[i], names, constructor);
      65				}
      66				superClass= superClass.getSuperclass();
      67			}
      68			if (fTests.size() == 0)
      69				addTest(warning("No tests found in "+theClass.getName()));
      70		}
      71	   	/**
      72		 * Constructs an empty TestSuite.
      73		 */
      74		public TestSuite(String name) {
      75			fName= name;
      76		}
      77		/**
      78		 * Adds a test to the suite.
      79		 */
      80		public void addTest(Test test) {
      81			fTests.addElement(test);
      82		}
      83		
      84		/**
      85		 * Adds the tests from the given class to the suite
      86		 */
      87		public void addTestSuite(Class testClass) {
      88			addTest(new TestSuite(testClass));
      89		}
      90	
      91		private void addTestMethod(Method m, Vector names, Constructor constructor) {
      92			String name= m.getName();
      93			if (names.contains(name)) 
      94				return;
      95			if (isPublicTestMethod(m)) {
      96				names.addElement(name);
      97	
      98				Object[] args= new Object[]{name};
      99				try {
     100					addTest((Test)constructor.newInstance(args));
     101				} catch (InstantiationException e) {
     102					addTest(warning("Cannot instantiate test case: "+name+" ("+exceptionToString(e)+")"));
     103				} catch (InvocationTargetException e) {
     104					addTest(warning("Exception in constructor: "+name+" ("+exceptionToString(e.getTargetException())+")"));
     105				} catch (IllegalAccessException e) {
     106					addTest(warning("Cannot access test case: "+name+" ("+exceptionToString(e)+")"));
     107				}
     108	
     109			} else { // almost a test method
     110				if (isTestMethod(m)) 
     111					addTest(warning("Test method isn't public: "+m.getName()));
     112			}
     113		}
     114		
     115		/**
     116		 * Converts the stack trace into a string
     117		 */
     118		private String exceptionToString(Throwable t) {
     119			StringWriter stringWriter= new StringWriter();
     120			PrintWriter writer= new PrintWriter(stringWriter);
     121			t.printStackTrace(writer);
     122			return stringWriter.toString();
     123			
     124		}
     125		/**
     126		 * Counts the number of test cases that will be run by this test.
     127		 */
     128		public int countTestCases() {
     129			int count= 0;
     130			for (Enumeration e= tests(); e.hasMoreElements(); ) {
     131				Test test= (Test)e.nextElement();
     132				count= count + test.countTestCases();
