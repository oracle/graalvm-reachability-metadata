       1	package junit.runner;
       2	
       3	import junit.framework.*;
       4	import java.lang.reflect.*;
       5	import java.text.NumberFormat;
       6	import java.io.*;
       7	import java.util.*;
       8	
       9	/**
      10	 * Base class for all test runners.
      11	 * This class was born live on stage in Sardinia during XP2000.
      12	 */
      13	public abstract class BaseTestRunner implements TestListener {
      14		public static final String SUITE_METHODNAME= "suite";
      15		
      16		static Properties fPreferences;
      17		static int fgMaxMessageLength= 500;
      18		static boolean fgFilterStack= true;
      19		boolean fLoading= true;
      20		
      21		/**
      22		 * Returns the Test corresponding to the given suite. This is
      23		 * a template method, subclasses override runFailed(), clearStatus().
      24		 */
      25		public Test getTest(String suiteClassName) {
      26			if (suiteClassName.length() <= 0) {
      27				clearStatus();
      28				return null;
      29			}
      30			Class testClass= null;
      31			try {
      32				testClass= loadSuiteClass(suiteClassName);
      33			} catch (ClassNotFoundException e) {
      34				String clazz= e.getMessage();
      35				if (clazz == null) 
      36					clazz= suiteClassName;
      37				runFailed("Class not found \""+clazz+"\"");
      38				return null;
      39			} catch(Exception e) {
      40				runFailed("Error: "+e.toString());
      41				return null;
      42			}
      43			Method suiteMethod= null;
      44			try {
      45				suiteMethod= testClass.getMethod(SUITE_METHODNAME, new Class[0]);
      46		 	} catch(Exception e) {
      47		 		// try to extract a test suite automatically
      48				clearStatus();			
      49				return new TestSuite(testClass);
      50			}
      51			Test test= null;
      52			try {
      53				test= (Test)suiteMethod.invoke(null, new Class[0]); // static method
      54				if (test == null)
      55					return test;
      56			} 
      57			catch (InvocationTargetException e) {
      58				runFailed("Failed to invoke suite():" + e.getTargetException().toString());
      59				return null;
      60			}
      61			catch (IllegalAccessException e) {
      62				runFailed("Failed to invoke suite():" + e.toString());
      63				return null;
      64			}
      65			
      66			clearStatus();
      67			return test;
      68		}
      69		
      70		/**
      71		 * Returns the formatted string of the elapsed time.
      72		 */
      73		public String elapsedTimeAsString(long runTime) {
      74			return NumberFormat.getInstance().format((double)runTime/1000);
      75		}
      76		
      77		/**
      78		 * Processes the command line arguments and
      79		 * returns the name of the suite class to run or null
      80		 */
      81		protected String processArguments(String[] args) {
      82			String suiteName= null;
      83			for (int i= 0; i < args.length; i++) {
      84				if (args[i].equals("-noloading")) {
      85					setLoading(false);
      86				} else if (args[i].equals("-nofilterstack")) {
      87					fgFilterStack= false;
      88				} else if (args[i].equals("-c")) {
      89					if (args.length > i+1)
      90						suiteName= extractClassName(args[i+1]);
      91					else
      92						System.out.println("Missing Test class name");
      93					i++;
      94				} else {
      95					suiteName= args[i];
      96				}
      97			}
      98			return suiteName;		
      99		}
     100	
     101		/**
     102		 * Sets the loading behaviour of the test runner
     103		 */
     104		public void setLoading(boolean enable) {
     105			fLoading= enable;
     106		}
     107		/**
     108		 * Extract the class name from a String in VA/Java style
     109		 */
     110		public String extractClassName(String className) {
     111			if(className.startsWith("Default package for")) 
     112				return className.substring(className.lastIndexOf(".")+1);
     113			return className;
     114		}
     115		
     116		/**
