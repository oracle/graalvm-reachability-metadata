  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  
  import junit.framework.TestCase;
  import junit.framework.TestResult;
  import junit.framework.TestSuite;
  
  public class TestSuiteTest {
  
      @Test
      void createsTestCaseWithStringConstructor() {
          StringConstructorTestCase.executedName = null;
  
          TestSuite suite = new TestSuite(StringConstructorTestCase.class);
          TestResult result = new TestResult();
          suite.run(result);
  
          assertThat(suite.countTestCases()).isEqualTo(1);
          assertThat(result.runCount()).isEqualTo(1);
          assertThat(result.errorCount()).isZero();
          assertThat(result.failureCount()).isZero();
          assertThat(StringConstructorTestCase.executedName).isEqualTo("testRecordsName");
      }
  
      @Test
      void createsTestCaseWithNoArgumentConstructor() {
          NoArgumentConstructorTestCase.executedName = null;
  
          TestSuite suite = new TestSuite(NoArgumentConstructorTestCase.class);
          TestResult result = new TestResult();
          suite.run(result);
  
          assertThat(suite.countTestCases()).isEqualTo(1);
          assertThat(result.runCount()).isEqualTo(1);
          assertThat(result.errorCount()).isZero();
          assertThat(result.failureCount()).isZero();
          assertThat(NoArgumentConstructorTestCase.executedName).isEqualTo("testRecordsName");
      }
  
      public static class StringConstructorTestCase extends TestCase {
          static String executedName;
  
          public StringConstructorTestCase(String name) {
              super(name);
          }
  
          public void testRecordsName() {
              executedName = getName();
          }
      }
  
      public static class NoArgumentConstructorTestCase extends TestCase {
          static String executedName;
  
          public NoArgumentConstructorTestCase() {
              super("constructor-name");
          }
  
          public void testRecordsName() {
              executedName = getName();
          }
      }
  }
