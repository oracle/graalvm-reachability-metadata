ce(Throwable t) { \r\n   208\t\t\tStringWriter stringWriter= new StringWriter();\r\n   209\t\t\tPrintWriter writer= new PrintWriter(stringWriter);\r\n   210\t\t\tt.printStackTrace(writer);\r\n   211\t\t\tStringBuffer buffer= stringWriter.getBuffer();\r\n   212\t\t\tString trace= buffer.toString();\r\n   213\t\t\treturn BaseTestRunner.filterStack(trace);\r\n   214\t\t}\r\n   215\t\r\n   216\t\t/**\r\n   217\t\t * Filters stack frames from internal JUnit classes\r\n   218\t\t */\r\n   219\t\tpublic static String filterStack(String stack) {\r\n   220\t\t\tif (!getPreference(\"filterstack\").equals(\"true\") || fgFilterStack == false)\r\n   221\t\t\t\treturn stack;\r\n   222\t\t\t\t\r\n   223\t\t\tStringWriter sw= new StringWriter();\r\n   224\t\t\tPrintWriter pw= new PrintWriter(sw);\r\n   225\t\t\tStringReader sr= new StringReader(stack);\r\n   226\t\t\tBufferedReader br= new BufferedReader(sr);\r\n   227\t\t\t\r\n   228\t\t\tString line;\r\n   229\t\t\ttry {\t\r\n   230\t\t\t\twhile ((line= br.readLine()) != null) {\r\n   231\t\t\t\t\tif (!filterLine(line))\r\n   232\t\t\t\t\t\tpw.println(line);\r\n   233\t\t\t\t}\r\n   234\t\t\t} catch (Exception IOException) {\r\n   235\t\t\t\treturn stack; // return the stack unfiltered\r\n   236\t\t\t}\r\n   237\t\t\treturn sw.toString();\r\n   238\t\t}\r\n   239\t\t\r\n   240\t\tstatic boolean filterLine(String line) {\r\n   241\t\t\tString[] patterns= new String[] {\r\n   242\t\t\t\t\"junit.framework.TestCase\",\r\n   243\t\t\t\t\"junit.framework.TestResult\",\r\n   244\t\t\t\t\"junit.framework.TestSuite\",\r\n   245\t\t\t\t\"junit.framework.Assert.\", // don't filter AssertionFailure\r\n   246\t\t\t\t\"junit.swingui.TestRunner\",\r\n   247\t\t\t\t\"junit.awtui.TestRunner\",\r\n   248\t\t\t\t\"junit.textui.TestRunner\",\r\n   249\t\t\t\t\"java.lang.reflect.Method.invoke(\"\r\n   250\t\t\t};\r\n   251\t\t\tfor (int i= 0; i < patterns.length; i++) {\r\n   252\t\t\t\tif (line.indexOf(patterns[i]) > 0)\r\n   253\t\t\t\t\treturn true;\r\n   254\t\t\t}\r\n   255\t\t\treturn false;\r\n   256\t\t}\r\n   257\t\r\n   258\t \t{\r\n   259\t \t\tfPreferences= new Properties();\r\n   260\t \t\t//JDK 1.2 feature\r\n   261\t \t\t//fPreferences.setProperty(\"loading\", \"true\");\r\n   262\t \t\tfPreferences.put(\"loading\", \"true\");\r\n   263\t \t\tfPreferences.put(\"filterstack\", \"true\");\r\n   264\t  \t\treadPreferences();\r\n   265\t \t\tfgMaxMessageLength= getPreference(\"maxmessage\", fgMaxMessageLength);\r\n   266\t \t}\r\n   267\t \t\r\n   268\t}\n"}], "isError": false, "timestamp": 1777921812512}}
