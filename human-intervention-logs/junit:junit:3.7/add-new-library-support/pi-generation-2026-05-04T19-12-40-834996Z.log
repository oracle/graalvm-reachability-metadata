 else {\r\n    95\t\t\t\t\tsuiteName= args[i];\r\n    96\t\t\t\t}\r\n    97\t\t\t}\r\n    98\t\t\treturn suiteName;\t\t\r\n    99\t\t}\r\n   100\t\r\n   101\t\t/**\r\n   102\t\t * Sets the loading behaviour of the test runner\r\n   103\t\t */\r\n   104\t\tpublic void setLoading(boolean enable) {\r\n   105\t\t\tfLoading= enable;\r\n   106\t\t}\r\n   107\t\t/**\r\n   108\t\t * Extract the class name from a String in VA/Java style\r\n   109\t\t */\r\n   110\t\tpublic String extractClassName(String className) {\r\n   111\t\t\tif(className.startsWith(\"Default package for\")) \r\n   112\t\t\t\treturn className.substring(className.lastIndexOf(\".\")+1);\r\n   113\t\t\treturn className;\r\n   114\t\t}\r\n   115\t\t\r\n   116\t\t/**\r\n   117\t\t * Truncates a String to the maximum length.\r\n   118\t\t */\r\n   119\t\tpublic static String truncate(String s) {\r\n   120\t\t\tif (fgMaxMessageLength != -1 && s.length() > fgMaxMessageLength)\r\n   121\t\t\t\ts= s.substring(0, fgMaxMessageLength)+\"...\";\r\n   122\t\t\treturn s;\r\n   123\t\t}\r\n   124\t\t\r\n   125\t\t/**\r\n   126\t\t * Override to define how to handle a failed loading of\r\n   127\t\t * a test suite.\r\n   128\t\t */\r\n   129\t\tprotected abstract void runFailed(String message);\r\n   130\t\t\r\n   131\t\t/**\r\n   132\t\t * Returns the loaded Class for a suite name. \r\n   133\t\t */\r\n   134\t\tprotected Class loadSuiteClass(String suiteClassName) throws ClassNotFoundException {\r\n   135\t\t\treturn getLoader().load(suiteClassName);\r\n   136\t\t}\r\n   137\t\t\r\n   138\t\t/**\r\n   139\t\t * Clears the status message.\r\n   140\t\t */\r\n   141\t\tprotected void clearStatus() { // Belongs in the GUI TestRunner class\r\n   142\t\t}\r\n   143\t\t\r\n   144\t\t/**\r\n   145\t\t * Returns the loader to be used.\r\n   146\t\t */\r\n   147\t\tpublic TestSuiteLoader getLoader() {\r\n   148\t\t\tif (useReloadingTestSuiteLoader())\r\n   149\t\t\t\treturn new ReloadingTestSuiteLoader();\r\n   150\t\t\treturn 