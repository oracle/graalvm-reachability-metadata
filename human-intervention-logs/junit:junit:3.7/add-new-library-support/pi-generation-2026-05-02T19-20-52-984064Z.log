     115		/**
     116		 * Converts the stack trace into a string
     117		 */
     118		private String exceptionToString(Throwable t) {
     119			StringWriter stringWriter= new StringWriter();
     120			PrintWriter writer= new PrintWriter(stringWriter);
     121			t.printStackTrace(writer);
     122			return stringWriter.toString();
     123			
     124		}
     125		/**
     126		 * Counts the number of test cases that will be run by this test.
     127		 */
     128		public int countTestCases() {
     129			int count= 0;
     130			for (Enumeration e= tests(); e.hasMoreElements(); ) {
     131				Test test= (Test)e.nextElement();
     132				count= count + test.countTestCases();
     133			}
     134			return count;
     135		}
     136		/**
     137		 * Gets a constructor which takes a single String as
     138		 * its argument.
     139		 */
     140		private Constructor getConstructor(Class theClass) throws NoSuchMethodException {
     141			Class[] args= { String.class };
     142			return theClass.getConstructor(args);
     143		}
     144		
     145		/**
     146		 */
     147		private boolean isPublicTestMethod(Method m) {
     148			return isTestMethod(m) && Modifier.isPublic(m.getModifiers());
     149		 }
     150		/**
     151		 */
     152		private boolean isTestMethod(Method m) {
     153			String name= m.getName();
     154			Class[] parameters= m.getParameterTypes();
     155			Class returnType= m.getReturnType();
     156			return parameters.length == 0 && name.startsWith("test") && returnType.equals(Void.TYPE);
     157		 }
     158		/**
     159		 * Runs the tests and collects their result in a TestResult.
     160		 */
     161		public void run(TestResult result) {
     162			for (Enumeration e= tests(); e.hasMoreElements(); ) {
     163		  		if (result.shouldStop() )
     164		  			break;
     165				Test test= (Test)e.nextElement();
     166				runTest(test, result);
     167			}
     168		}
     169		
     170		public void runTest(Test test, TestResult result) {
     171			test.run(result);
     172		}
