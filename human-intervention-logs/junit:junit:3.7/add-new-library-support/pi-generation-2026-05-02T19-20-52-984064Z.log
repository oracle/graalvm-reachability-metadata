      93			if (names.contains(name)) 
      94				return;
      95			if (isPublicTestMethod(m)) {
      96				names.addElement(name);
      97	
      98				Object[] args= new Object[]{name};
      99				try {
     100					addTest((Test)constructor.newInstance(args));
     101				} catch (InstantiationException e) {
     102					addTest(warning("Cannot instantiate test case: "+name+" ("+exceptionToString(e)+")"));
     103				} catch (InvocationTargetException e) {
     104					addTest(warning("Exception in constructor: "+name+" ("+exceptionToString(e.getTargetException())+")"));
     105				} catch (IllegalAccessException e) {
     106					addTest(warning("Cannot access test case: "+name+" ("+exceptionToString(e)+")"));
     107				}
     108	
     109			} else { // almost a test method
     110				if (isTestMethod(m)) 
     111					addTest(warning("Test method isn't public: "+m.getName()));
     112			}
     113		}
