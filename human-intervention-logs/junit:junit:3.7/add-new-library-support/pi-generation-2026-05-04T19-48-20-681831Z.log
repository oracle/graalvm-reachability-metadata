  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Method;
  import java.util.Collections;
  import java.util.List;
  
  import org.junit.experimental.theories.ParameterSignature;
  import org.junit.experimental.theories.ParameterSupplier;
  import org.junit.experimental.theories.ParametersSuppliedBy;
  import org.junit.experimental.theories.PotentialAssignment;
  import org.junit.experimental.theories.internal.Assignments;
  import org.junit.jupiter.api.Test;
  import org.junit.runners.model.TestClass;
  
  public class AssignmentsTest {
  
      @Test
      void buildsParameterSupplierUsingNoArgumentConstructor() throws Throwable {
          Assignments assignments = assignmentsFor(NoArgumentSupplierFixture.class, "acceptsSuppliedValue");
  
          List<PotentialAssignment> potentialAssignments = assignments.potentialsForNextUnassigned();
  
          assertThat(potentialAssignments).hasSize(1);
          assertThat(potentialAssignments.get(0).getValue()).isEqualTo("no-argument");
      }
  
      @Test
      void buildsParameterSupplierUsingTestClassConstructor() throws Throwable {
          Assignments assignments = assignmentsFor(TestClassConstructorSupplierFixture.class, "acceptsSuppliedValue");
  
          List<PotentialAssignment> potentialAssignments = assignments.potentialsForNextUnassigned();
  
          assertThat(potentialAssignments).hasSize(1);
          assertThat(potentialAssignments.get(0).getValue()).isEqualTo("TestClassConstructorSupplierFixture");
      }
  
      private static Assignments assignmentsFor(Class<?> fixtureClass, String methodName) throws NoSuchMethodException {
          Method method = fixtureClass.getMethod(methodName, String.class);
          return Assignments.allUnassigned(method, new TestClass(fixtureClass));
      }
  
      public static class NoArgumentSupplierFixture {
          public void acceptsSuppliedValue(@ParametersSuppliedBy(NoArgumentSupplier.class) String value) {
          }
      }
  
      public static class TestClassConstructorSupplierFixture {
          public void acceptsSuppliedValue(@ParametersSuppliedBy(TestClassConstructorSupplier.class) String value) {
          }
      }
  
      public static class NoArgumentSupplier extends ParameterSupplier {
  
          public NoArgumentSupplier() {
          }
  
          @Override
          public List<PotentialAssignment> getValueSources(ParameterSignature signature) {
              return Collections.singletonList(PotentialAssignment.forValue("value", "no-argument"));
          }
      }
  
      public static class TestClassConstructorSupplier extends ParameterSupplier {
          private final TestClass testClass;
  
          public TestClassConstructorSupplier(TestClass testClass) {
              this.testClass = testClass;
          }
  
          @Override
          public List<PotentialAssignment> getValueSources(ParameterSignature signature) {
              String fixtureName = testClass.getJavaClass().getSimpleName();
              return Collections.singletonList(PotentialAssignment.forValue("value", fixtureName));
          }
      }
  }
