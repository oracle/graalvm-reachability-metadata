          final String name;
          final int number;
  
          public ConstructorInjectionFixture(String name, int number) {
              this.name = name;
              this.number = number;
          }
  
          @org.junit.Test
          public void acceptsParameters() {
          }
      }
  
      public static class FieldInjectionFixture {
          @Parameter(0)
          public String name;
  
          @Parameter(1)
          public int number;
  
          public FieldInjectionFixture() {
          }
  
          @org.junit.Test
          public void acceptsParameters() {
          }
      }
  }
