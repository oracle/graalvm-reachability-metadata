          assertThat(test).isInstanceOf(FieldInjectionFixture.class);
          FieldInjectionFixture fixture = (FieldInjectionFixture) test;
          assertThat(fixture.name).isEqualTo("bravo");
          assertThat(fixture.number).isEqualTo(42);
      }
  
      private static BlockJUnit4ClassRunnerWithParameters runnerFor(
              Class<?> fixtureClass,
              String name,
              Object... parameters) throws Exception {
          List<Object> parameterList = Arrays.asList(parameters);
          TestWithParameters testWithParameters = new TestWithParameters(
                  name,
                  new TestClass(fixtureClass),
                  parameterList);
          return new BlockJUnit4ClassRunnerWithParameters(testWithParameters);
      }
  
      @RunWith(Parameterized.class)
      public static class ConstructorInjectionFixture {
          final String name;
          final int number;
  
