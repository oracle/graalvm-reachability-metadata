  import org.junit.runners.parameterized.TestWithParameters;
  
  public class BlockJUnit4ClassRunnerWithParametersTest {
  
      @Test
      void createsTestUsingConstructorInjection() throws Exception {
          BlockJUnit4ClassRunnerWithParameters runner = runnerFor(
                  ConstructorInjectionFixture.class,
                  "constructor",
                  "alpha",
                  37);
  
          Object test = runner.createTest();
  
          assertThat(test).isInstanceOf(ConstructorInjectionFixture.class);
          ConstructorInjectionFixture fixture = (ConstructorInjectionFixture) test;
          assertThat(fixture.name).isEqualTo("alpha");
          assertThat(fixture.number).isEqualTo(37);
      }
  
      @Test
