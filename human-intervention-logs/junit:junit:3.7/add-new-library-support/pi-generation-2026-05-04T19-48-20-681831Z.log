  package junit_junit;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Collections;
  import java.util.List;
  
  import org.junit.experimental.theories.DataPoint;
  import org.junit.experimental.theories.ParameterSignature;
  import org.junit.experimental.theories.ParameterSupplier;
  import org.junit.experimental.theories.ParametersSuppliedBy;
  import org.junit.experimental.theories.PotentialAssignment;
  import org.junit.experimental.theories.Theories;
  import org.junit.experimental.theories.Theory;
  import org.junit.jupiter.api.Test;
  import org.junit.runner.Description;
  import org.junit.runners.model.InitializationError;
  
  public class TheoriesTest {
      private static final int SUPPLIED_VALUE = 42;
  
      @Test
      void validatesTheoryDataPointsAndCustomParameterSupplier() throws InitializationError {
          Theories runner = new Theories(TheoryFixture.class);
  
          assertThat(runner.getDescription().getChildren())
                  .extracting(Description::getMethodName)
                  .contains("acceptsStaticDataPoints", "usesCustomParameterSupplier");
      }
  
      public static class TheoryFixture {
          @DataPoint
          public static final String FIELD_DATA_POINT = "field";
  
          @DataPoint
          public static String methodDataPoint() {
              return "method";
          }
  
          @Theory
          public void acceptsStaticDataPoints(String value) {
              assertThat(value).isNotEmpty();
          }
  
          @Theory
          public void usesCustomParameterSupplier(@ParametersSuppliedBy(SingleValueSupplier.class) int value) {
              assertThat(value).isEqualTo(SUPPLIED_VALUE);
          }
      }
  
      public static class SingleValueSupplier extends ParameterSupplier {
  
          public SingleValueSupplier() {
          }
  
          @Override
          public List<PotentialAssignment> getValueSources(ParameterSignature signature) {
              return Collections.singletonList(PotentialAssignment.forValue("supplied", SUPPLIED_VALUE));
          }
      }
  }
