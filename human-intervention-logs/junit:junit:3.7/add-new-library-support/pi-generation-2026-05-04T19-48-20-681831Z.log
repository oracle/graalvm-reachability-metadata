  import java.util.List;
  
  import org.junit.jupiter.api.Test;
  import org.junit.runners.Parameterized.Parameter;
  import org.junit.runners.model.TestClass;
  import org.junit.runners.parameterized.BlockJUnit4ClassRunnerWithParameters;
  import org.junit.runners.parameterized.TestWithParameters;
  
  public class BlockJUnit4ClassRunnerWithParametersTest {
  
      @Test
      void createsTestUsingConstructorInjection() throws Exception {
          BlockJUnit4ClassRunnerWithParameters runner = runnerFor(ConstructorInjectionFixture.class, "constructor", "alpha", 37);
  
          Object test = runner.createTest();
  
          assertThat(test).isInstanceOf(ConstructorInjectionFixture.class);
          ConstructorInjectionFixture fixture = (ConstructorInjectionFixture) test;
          assertThat(fixture.name).isEqualTo("alpha");
          assertThat(fixture.number).isEqualTo(37);
      }
  
      @Test
      void createsTestUsingFieldInjection() throws Exception {
          BlockJUnit4ClassRunnerWithParameters runner = runnerFor(FieldInjectionFixture.class, "field", "bravo", 42);
  
          Object test = runner.createTest();
  
          assertThat(test).isInstanceOf(FieldInjectionFixture.class);
          FieldInjectionFixture fixture = (FieldInjectionFixture) test;
          assertThat(fixture.name).isEqualTo("bravo");
          assertThat(fixture.number).isEqualTo(42);
      }
  
      private static BlockJUnit4ClassRunnerWithParameters runnerFor(Class<?> fixtureClass, String name, Object... parameters)
              throws Exception {
          List<Object> parameterList = Arrays.asList(parameters);
          TestWithParameters testWithParameters = new TestWithParameters(name, new TestClass(fixtureClass), parameterList);
          return new BlockJUnit4ClassRunnerWithParameters(testWithParameters);
      }
  
