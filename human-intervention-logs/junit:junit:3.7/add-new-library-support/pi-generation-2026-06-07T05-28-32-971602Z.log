s.asList(new Object[][] { {\"one\", 1}, {\"two\", 2} });\n        }\n\n        @Test\n        public void receivesConstructorParameters() {\n            assertThat(word.length()).isEqualTo(number + 2);\n        }\n    }\n\n    @RunWith(Parameterized.class)\n    public static class FieldInjectedParametersCase {\n        @Parameter(0)\n        public String word;\n\n        @Parameter(1)\n        public int number;\n\n        @Parameters(name = \"{index}: {0}={1}\")\n        public static Collection<Object[]> parameters() {\n            return Arrays.asList(new Object[][] { {\"three\", 3}, {\"four\", 4} });\n        }\n\n        @Test\n        public void receivesFieldParameters() {\n            assertThat(word.length()).isEqualTo(number + 2);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2743, "output": 1080, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 37103, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780810049596, "responseId": "resp_04a8f9630767cc75016a250142249c8190aaa4c99174ef7f3d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_4KLBDY7GnNetdAssf5r1l9lw|fc_04a8f9630767cc75016a25014bc050819085e834dd21be7da5", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2431 bytes to tests/src/junit/junit/3.7/src/test/java/junit_junit/BlockJUnit4ClassRunnerWithParametersTest.java"}], "isError": false, "timestamp": 1780810065960}]}
