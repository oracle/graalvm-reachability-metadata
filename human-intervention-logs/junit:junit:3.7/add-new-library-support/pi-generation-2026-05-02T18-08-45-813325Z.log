c void waitUntil(BooleanSupplier condition) throws Exception {\n", "newText": "    private static void closeShowingDialogs() {\n        for (Window window : Window.getWindows()) {\n            if (window instanceof Dialog && window.isShowing()) {\n                window.dispose();\n            }\n        }\n    }\n\n    private static void waitUntil(BooleanSupplier condition) throws Exception {\n"}, {"oldText": "    public static final class RerunnableJunit3TestCase extends TestCase {\n", "newText": "    public static final class EmptyTestCollector implements TestCollector {\n        public EmptyTestCollector() {\n            constructedCollectors.incrementAndGet();\n        }\n\n        @Override\n        public Enumeration collectTests() {\n            return Collections.emptyEnumeration();\n        }\n    }\n\n    public static final class RerunnableJunit3TestCase extends TestCase {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2186, "output": 1672, "cacheRead": 49664, "cacheWrite": 0, "totalTokens": 53522, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777745258715, "responseId": "resp_0d2b5657fa412a260169f63d6b4ba08191bfc9bd9e066bc31c"}}
