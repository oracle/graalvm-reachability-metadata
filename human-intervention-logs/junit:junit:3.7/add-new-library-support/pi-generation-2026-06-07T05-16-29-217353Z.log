escription;\n        }\n\n        @Override\n        public void run(RunNotifier notifier) {\n            notifier.fireTestStarted(description);\n            notifier.fireTestFinished(description);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 680, "output": 1637, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 23821, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780809345917, "responseId": "resp_040e9314bd00082d016a24fe8266a0819784a639abf1f170be"}}
