  	}
  	
  	public static Icon getIconResource(Class clazz, String name) {
  		URL url= clazz.getResource(name);
  		if (url == null) {
  			System.err.println("Warning: could not load \""+name+"\" icon");
  			return null;
  		} 
  		return new ImageIcon(url);
  	}
  	
