          public Enumeration<URL> getResources(final String name) {
              byte[] r = resources.get(name);
              return r == null ? emptyEnumeration() : new Enumeration<URL>() {
                  boolean done = false;
  
                  public boolean hasMoreElements() {
                      return !done;
