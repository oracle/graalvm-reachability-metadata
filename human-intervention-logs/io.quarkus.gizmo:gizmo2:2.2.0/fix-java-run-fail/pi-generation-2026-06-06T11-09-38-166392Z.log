                  public URL nextElement() {
                      if (!hasMoreElements()) {
                          throw new NoSuchElementException();
                      }
                      done = true;
                      return newUrl(r, name);
                  }
              };
          }
  
          public URL getResource(final String name) {
              Enumeration<URL> e = getResources(name);
              return e.hasMoreElements() ? e.nextElement() : null;
