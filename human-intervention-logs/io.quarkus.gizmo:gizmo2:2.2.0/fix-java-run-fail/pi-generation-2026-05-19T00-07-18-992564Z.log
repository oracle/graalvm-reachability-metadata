at(constructedDirectly).isInstanceOf(generatedClass);\n\n        InstanceStringFunction instanceGreeting = maker.virtualMethod(generatedClass, \"instanceGreeting\",\n                InstanceStringFunction.class);\n        assertThat(instanceGreeting.apply(constructedDirectly)).isEqualTo(\"instance-result\");\n    }\n\n    private record ArrayClassDesc(ClassDesc componentType) implements ClassDesc {\n        @Override\n        public String descriptorString() {\n            return \"[\" + componentType.descriptorString();\n        }\n\n        @Override\n        public ClassDesc arrayType() {\n            return componentType;\n        }\n\n        @Override\n        public ClassDesc arrayType(int rank) {\n            return rank == 0 ? this : componentType.arrayType(rank - 1);\n        }\n\n        @Override\n        public String displayName() {\n            return componentType.displayName() + \"[]\";\n        }\n\n        @Override\n        public Class<?> resolveConstantDesc(MethodHandles.Lookup lookup) throws ReflectiveOperationException {\n            return componentType.resolveConstantDesc(lookup).arrayType();\n        }\n\n        @Override\n        public Optional<? extends ConstantDesc> describeConstable() {\n            return Optional.of(this);\n        }\n    }\n\n    public interface StringSupplier {\n        String get();\n    }\n\n    public interface ObjectFactory {\n        Object create();\n    }\n\n    public interface InstanceStringFunction {\n        String apply(Object target);\n    }\n}\n"}], "isError": false, "timestamp": 1779149346249}]}
