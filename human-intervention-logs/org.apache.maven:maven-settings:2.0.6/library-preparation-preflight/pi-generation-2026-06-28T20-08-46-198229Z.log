              if ( basedir == null )
              {
                  basedir = System.getProperty( "user.dir" );
              }
  
              basedir = basedir.replaceAll( "\\\\", "/" );
              basedir = basedir.replaceAll( "\\$", "\\\\\\$" );
  
              path = pathPattern.replaceAll( "\\$\\{" + basedirSysProp + "\\}", basedir );
              path = path.replaceAll( "\\\\", "/" );
              path = path.replaceAll( "//", "/" );
  
              return new File( path ).getAbsoluteFile();
