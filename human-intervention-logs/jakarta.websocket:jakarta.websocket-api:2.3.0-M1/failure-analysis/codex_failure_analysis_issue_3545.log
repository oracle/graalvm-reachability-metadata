/org.hamcrest/hamcrest-core/1.3,/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/3545-1a1ff737/metadata/jakarta.websocket/jakarta.websocket-api/2.3.0-M1,/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/3545-1a1ff737/metadata/jakarta.websocket/jakarta.websocket-client-api/2.1.0 \\\n-H:Optimize@user+api=b \\\n-H:+ReportExceptionStackTraces@user \\\n-H:Features@user+api=org.graalvm.junit.platform.JUnitPlatformFeature \\\n'-H:Class@explicit main-class=org.graalvm.junit.platform.NativeImageJUnitLauncher' \\\n-H:ImageBuildID@driver=c95d5ae0-9014-6a8d-8846-7da7058ea3aa \\\n'-H:Features@jar:file:///home/vjovanov/c/g/vj/forge/ce/sdk/mxbuild/linux-amd64/GRAALVM_JAVA25/graalvm-25.1.0-dev+9.1/lib/svm/library-support.jar!/META-INF/native-image/com.oracle.svm/thirdparty/native-image.properties+api=com.oracle.svm.thirdparty.gson.GsonFeature' \\\n'-H:Features@jar:file:///home/vjovanov/c/g/vj/forge/ce/sdk/mxbuild/linux-amd64/GRAALVM_JAVA25/graalvm-25.1.0-dev+9.1/lib/svm/library-support.jar!/META-INF/native-image/com.oracle.svm/polyglot/native-image.properties+api=com.oracle.svm.polyglot.groovy.GroovyIndyInterfaceFeature' \\\n'-H:AddExports@jar:file:///home/vjovanov/c/g/vj/forge/ce/sdk/mxbuild/linux-amd64/GRAALVM_JAVA25/graalvm-25.1.0-dev+9.1/lib/svm/svm-guest.jar!/META-INF/native-image/org.graalvm.nativeimage.guest/native-image.properties+api=java.base/jdk.internal.misc=org.graalvm.nativeimage.guest' \\\n'-H:Features@jar:file:///home/vjovanov/c/g/vj/forge/ce/sdk/mxbuild/linux-amd64/GRAALVM_JAVA25/graalvm-25.1.0-dev+9.1/lib/svm/svm-guest.jar!/META-INF/native-image/org.graalvm.nativeimage.guest/native-image.properties+api=com.oracle.svm.guest.features.jdk.hosted.JavaNetHttpFeature' \\\n'-H:ClassInitialization@jar:file:///home/vjovanov/c/g/vj/forge/ce/sdk/mxbuild/linux-amd64/GRAALVM_JAVA25/graalvm-25.1.0-dev+9.1/lib/svm/svm-guest.jar!/META-INF/native-image/org.graalvm.nativeimage.gue