  package org_hibernate_orm.hibernate_processor;
  
  import java.io.File;
  import java.io.IOException;
  import java.net.URI;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.ArrayList;
  import java.util.List;
  import java.util.Locale;
  import javax.tools.Diagnostic;
  import javax.tools.DiagnosticCollector;
  import javax.tools.JavaCompiler;
  import javax.tools.JavaFileObject;
  import javax.tools.SimpleJavaFileObject;
  import javax.tools.StandardJavaFileManager;
  import javax.tools.ToolProvider;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JpaDescriptorParserTest {
      private static final String CACHE_FILE_NAME = "Hibernate-Static-Metamodel-Generator.tmp";
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void lazyXmlParsingSerializesAndReusesTimestampCache() throws IOException {
          final Path resourceRoot = temporaryDirectory.resolve("resources");
          writeDefaultOrmXml(resourceRoot);
          final Path cacheDirectory = temporaryDirectory.resolve("cache");
          Files.createDirectories(cacheDirectory);
          final Path cacheFile = cacheDirectory.resolve(CACHE_FILE_NAME);
  
          final String originalTemporaryDirectory = System.getProperty("java.io.tmpdir");
          System.setProperty("java.io.tmpdir", cacheDirectory.toString());
          try {
              final CompilationResult firstCompilation = compileWithLazyXmlParsing(resourceRoot, "first");
              assertThat(firstCompilation.successful()).as(firstCompilation.diagnosticText()).isTrue();
              assertThat(cacheFile).isRegularFile();
              assertThat(Files.size(cacheFile)).isPositive();
  
              final CompilationResult secondCompilation = compileWithLazyXmlParsing(resourceRoot, "second");
              assertThat(secondCompilation.successful()).as(secondCompilation.diagnosticText()).isTrue();
          } finally {
              restoreTemporaryDirectoryProperty(originalTemporaryDirectory);
          }
      }
  
      private CompilationResult compileWithLazyXmlParsing(Path resourceRoot, String outputName) throws IOException {
          final JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();
          assertThat(compiler).as("system Java compiler").isNotNull();
  
          final Path classOutput = temporaryDirectory.resolve(outputName).resolve("classes");
          final Path sourceOutput = temporaryDirectory.resolve(outputName).resolve("generated-sources");
          Files.createDirectories(classOutput);
          Files.createDirectories(sourceOutput);
  
          final DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();
          final List<String> options = new ArrayList<>();
          final String classpath = resourceRoot + File.pathSeparator + System.getProperty("java.class.path", "");
          options.add("-proc:only");
          options.add("-processor");
          options.add("org.hibernate.processor.HibernateProcessor");
          options.add("-AlazyXmlParsing=true");
          options.add("-AfullyAnnotationConfigured=false");
          options.add("-classpath");
          options.add(classpath);
          options.add("-processorpath");
          options.add(classpath);
          options.add("-d");
          options.add(classOutput.toString());
          options.add("-s");
          options.add(sourceOutput.toString());
  
          try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(
                  diagnostics, Locale.ROOT, StandardCharsets.UTF_8)) {
              final JavaCompiler.CompilationTask task = compiler.getTask(
                      null, fileManager, diagnostics, options, null, List.of(new SourceFile()));
              final Boolean successful = task.call();
              return new CompilationResult(Boolean.TRUE.equals(successful), diagnosticText(diagnostics));
          }
      }
  
      private static void writeDefaultOrmXml(Path resourceRoot) throws IOException {
          final Path ormXml = resourceRoot.resolve("META-INF").resolve("orm.xml");
          Files.createDirectories(ormXml.getParent());
          Files.writeString(ormXml, """
                  <entity-mappings xmlns="https://jakarta.ee/xml/ns/persistence/orm" version="3.2">
                  </entity-mappings>
                  "", StandardCharsets.UTF_8);
      }
  
      private static void restoreTemporaryDirectoryProperty(String originalTemporaryDirectory) {
          if (originalTemporaryDirectory == null) {
              System.clearProperty("java.io.tmpdir");
          } else {
              System.setProperty("java.io.tmpdir", originalTemporaryDirectory);
          }
      }
  
      private static String diagnosticText(DiagnosticCollector<JavaFileObject> diagnostics) {
          final StringBuilder builder = new StringBuilder();
          for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {
              builder.append(diagnostic.getKind())
                      .append(": ")
                      .append(diagnostic.getMessage(Locale.ROOT))
                      .append(System.lineSeparator());
          }
          return builder.toString();
      }
  
      private record CompilationResult(boolean successful, String diagnosticText) {
      }
  
      private static final class SourceFile extends SimpleJavaFileObject {
          private SourceFile() {
              super(URI.create("string:///example/Book.java"), Kind.SOURCE);
          }
  
          @Override
          public CharSequence getCharContent(boolean ignoreEncodingErrors) {
              return """
                      package example;
  
                      import jakarta.persistence.Entity;
                      import jakarta.persistence.Id;
  
                      @Entity
                      public class Book {
                          @Id
                          Long id;
                      }
                      """;
          }
      }
  }
