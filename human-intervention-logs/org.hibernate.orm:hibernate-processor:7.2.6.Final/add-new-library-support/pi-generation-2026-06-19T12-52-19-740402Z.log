.tmp\";\n    private static final String DEFAULT_ORM_XML_LOCATION = \"/META-INF/orm.xml\";\n\n    @TempDir\n    private Path temporaryDirectory;\n\n    @Test\n    void lazyXmlParsingSerializesAndReusesTimestampCache() throws IOException {\n        final Path cacheDirectory = temporaryDirectory.resolve(\"cache\");\n        Files.createDirectories(cacheDirectory);\n        final Path cacheFile = cacheDirectory.resolve(CACHE_FILE_NAME);\n        writeStaleTimestampCache(cacheFile);\n        final long staleCacheSize = Files.size(cacheFile);\n\n        final String originalTemporaryDirectory = System.getProperty(\"java.io.tmpdir\");\n        System.setProperty(\"java.io.tmpdir\", cacheDirectory.toString());\n        try {\n            parseMappingXmlWithLazyTimestampCache();\n            assertThat(cacheFile).isRegularFile();\n            assertThat(Files.size(cacheFile)).isPositive();\n            assertThat(Files.size(cacheFile)).isNotEqualTo(staleCacheSize);\n\n            parseMappingXmlWithLazyTimestampCache();\n        } finally {\n            restoreTemporaryDirectoryProperty(originalTemporaryDirectory);\n        }\n    }\n\n    private static void writeStaleTimestampCache(Path cacheFile) throws IOException {\n        final FileTimeStampChecker staleTimestampCache = new FileTimeStampChecker();\n        staleTimestampCache.add(DEFAULT_ORM_XML_LOCATION, Long.MIN_VALUE);\n        try (ObjectOutput output = new ObjectOutputStream(new FileOutputStream(cacheFile.toFile()))) {\n            output.writeObject(staleTimestampCache);\n        }\n    }\n\n    private static void parseMappingXmlWithLazyTimestampCache() {\n        final ProcessingEnvironment processingEnvironment = new TimestampCacheProcessingEnvironment();\n        final Context context = new Context(processingEnvironment);\n\n        new JpaDescriptorParser(context).parseMappingXml();\n    }\n\n    private static void restoreTemporaryDirectoryProperty(String originalTemporaryDirectory) {\n        if (originalTemporaryDirectory == null) {\n            System.clearProperty(\"java.io.tmpdir\");\n        } else {\n            System.setProperty(\"java.io.tmpdir\", originalTemporaryDirectory);\n        }\n    }\n\n    private static final class TimestampCacheProcessingEnvironment implements ProcessingEnvironment {\n        @Override\n        public Map<String, String> getOptions() {\n            return Map.of(HibernateProcessor.LAZY_XML_PARSING, \"true\");\n        }\n\n        @Override\n        public Messager getMessager() {\n            return new NoOpMessager();\n        }\n\n        @Override\n        public Filer getFiler() {\n            return new UnavailableFiler();\n        }\n\n        @Override\n        public Elements getElementUtils() {\n            throw new UnsupportedOperationException(\"Element utilities are not used by this test\");\n        }\n\n        @Override\n        public Types getTypeUtils() {\n            throw new UnsupportedOperationException(\"Type utilities are not used by this test\");\n        }\n\n        @Override\n        public SourceVersion getSourceVersion() {\n            return SourceVersion.latestSupported();\n        }\n\n        @Override\n        public Locale getLocale() {\n            return Locale.ROOT;\n        }\n    }\n\n    private static final class NoOpMessager implements Messager {\n        @Override\n        public void printMessage(Diagnostic.Kind kind, CharSequence message) {\n        }\n\n        @Override\n        public void printMessage(Diagnostic.Kind kind, CharSequence message, Element element) {\n        }\n\n        @Override\n        public void printMessage(\n                Diagnostic.Kind kind, CharSequence message, Element element, AnnotationMirror annotation) {\n        }\n\n        @Override\n        public void printMessage(\n                Diagnostic.Kind kind,\n                CharSequence message,\n                Element element,\n                AnnotationMirror annotation,\n                AnnotationValue value) {\n        }\n    }\n\n    private static final class UnavailableFiler implements Filer {\n        @Override\n        public JavaFileObject createSourceFile(CharSequence name, Element... originatingElements) throws IOException {\n            throw new FilerException(\"Source files are not created by this test\");\n        }\n\n        @Override\n        public JavaFileObject createClassFile(CharSequence name, Element... originatingElements) throws IOException {\n            throw new FilerException(\"Class files are not created by this test\");\n        }\n\n        @Override\n        public FileObject createResource(\n                JavaFileManager.Location location,\n                CharSequence packageName,\n                CharSequence relativeName,\n                Element... originatingElements)\n                throws IOException {\n            throw new FilerException(\"Resources are not created by this test\");\n        }\n\n        @Override\n        public FileObject getResource(\n                JavaFileManager.Location location, CharSequence packageName, CharSequence relativeName)\n                throws IOException {\n            throw new IOException(\"No generated resources are available for this test\");\n        }\n    }\n}\n"}
