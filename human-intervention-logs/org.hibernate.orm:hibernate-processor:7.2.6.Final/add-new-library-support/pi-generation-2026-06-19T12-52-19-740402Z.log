  package org_hibernate_orm.hibernate_processor;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.hibernate.processor.validation.Mocker;
  import org.junit.jupiter.api.Test;
  
  import java.util.function.Supplier;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MockerTest {
      @Test
      void createsMockForNullaryType() {
          try {
              final Supplier<NullaryContract> supplier = Mocker.nullary(NullaryContract.class);
              final NullaryContract mock = supplier.get();
  
              assertThat(mock.text()).isEmpty();
              assertThat(mock.enabled()).isFalse();
              assertThat(mock.count()).isZero();
              assertThat(mock.total()).isZero();
              assertThat(mock.numbers()).isEmpty();
              assertThat(mock.names()).isEmpty();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void createsMockForVariadicConstructorType() {
          try {
              final Mocker<VariadicComponent> mocker = Mocker.variadic(VariadicComponent.class);
              final VariadicComponent component = mocker.make("component", 42);
  
              assertThat(component.name()).isEqualTo("component");
              assertThat(component.priority()).isEqualTo(42);
              assertThat(component.generatedText()).isEmpty();
              assertThat(component.generatedFlag()).isFalse();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      public interface NullaryContract {
          String text();
  
          boolean enabled();
  
          int count();
  
          long total();
  
          int[] numbers();
  
          String[] names();
      }
  
      public abstract static class VariadicComponent {
          private final String name;
          private final int priority;
  
          public VariadicComponent(final String name, final int priority) {
              this.name = name;
              this.priority = priority;
          }
  
          public String name() {
              return name;
          }
  
          public int priority() {
              return priority;
          }
  
          public abstract String generatedText();
  
          public abstract boolean generatedFlag();
      }
  }
