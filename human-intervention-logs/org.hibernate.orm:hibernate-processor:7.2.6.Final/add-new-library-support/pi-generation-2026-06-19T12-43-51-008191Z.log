.java. There's also the thought of checking build.gradle for Byte Buddy. I wonder if it's included as a transitive dependency with hibernate-processor. I’ll also look into importing NativeImageSupport to see if it’s available in the testing plugin. Keeping things organized is key!\"}]}"}, {"type": "toolCall", "id": "call_qg0UhoysooF1fhXklsbcNQvc|fc_0cc38e29b32187fb016a3539533c2c8197939ce870c8deb759", "name": "write", "arguments": {"path": "tests/src/org.hibernate.orm/hibernate-processor/7.2.6.Final/src/test/java/org_hibernate_orm/hibernate_processor/MockerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_hibernate_orm.hibernate_processor;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.hibernate.processor.validation.Mocker;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.function.Supplier;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MockerTest {\n    @Test\n    void createsMockForNullaryType() {\n        try {\n            final Supplier<NullaryContract> supplier = Mocker.nullary(NullaryContract.class);\n            final NullaryContract mock = supplier.get();\n\n            assertThat(mock.text()).isEmpty();\n            assertThat(mock.enabled()).isFalse();\n            assertThat(mock.count()).isZero();\n            assertThat(mock.total()).isZero();\n            assertThat(mock.numbers()).isEmpty();\n            assertThat(mock.names()).isEmpty();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void createsMockForVariadicConstructorType() {\n        try {\n            final Mocker<VariadicComponent> mocker = Mocker.variadic(VariadicComponent.class);\n            final VariadicComponent component = mocker.make(\"component\", 42);\n\n            assertThat(component.name()).isEqualTo(\"component\");\n            assertThat(component.priority()).isEqualTo(42);\n            assertThat(component.generatedText()).isEmpty();\n            assertThat(component.generatedFlag()).isFalse();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public interface NullaryContract {\n        String text();\n\n        boolean enabled();\n\n        int count();\n\n        long total();\n\n        int[] numbers();\n\n        String[] names();\n    }\n\n    public abstract static class VariadicComponent {\n        private final String name;\n        private final int priority;\n\n        public VariadicComponent(final String name, final int priority) {\n            this.name = name;\n            this.priority = priority;\n        }\n\n        public String name() {\n            return name;\n        }\n\n        public int priority() {\n            return priority;\n        }\n\n        public abstract String generatedText();\n\n        public abstract boolean generatedFlag();\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.hibernate.orm/hibernate-processor/7.2.6.Final/src/test/java/org_hibernate_orm/hibernate_processor/MockerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_hibernate_orm.hibernate_processor;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.hibernate.processor.validation.Mocker;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.util.function.Supplier;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class MockerTest {\\n    @Test\\n    void createsMockForNullaryT