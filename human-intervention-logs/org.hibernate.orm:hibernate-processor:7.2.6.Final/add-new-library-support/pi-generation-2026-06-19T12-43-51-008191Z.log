mponent component = mocker.make(\"component\", 42);\n\n            assertThat(component.name()).isEqualTo(\"component\");\n            assertThat(component.priority()).isEqualTo(42);\n            assertThat(component.generatedText()).isEmpty();\n            assertThat(component.generatedFlag()).isFalse();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public interface NullaryContract {\n        String text();\n\n        boolean enabled();\n\n        int count();\n\n        long total();\n\n        int[] numbers();\n\n        String[] names();\n    }\n\n    public abstract static class VariadicComponent {\n        private final String name;\n        private final int priority;\n\n        public VariadicComponent(final String name, final int priority) {\n            this.name = name;\n            this.priority = priority;\n        }\n\n        public String name() {\n            return name;\n        }\n\n        public int priority() {\n            return priority;\n        }\n\n        public abstract String generatedText();\n\n        public abstract boolean generatedFlag();\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.hibernate.orm/hibernate-processor/7.2.6.Final/src/test/java/org_hibernate_orm/hibernate_processor/MockerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_hibernate_orm.hibernate_processor;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.hibernate.processor.validation.Mocker;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.util.function.Supplier;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class MockerTest {\\n    @Test\\n    void createsMockForNullaryType