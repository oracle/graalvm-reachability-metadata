              transitions[TestState.OCTETS.ordinal()][UniversalTag.BIT_STRING.getValue()] = new GrammarTransition<>(
                      TestState.OCTETS,
                      TestState.END,
                      UniversalTag.BIT_STRING,
                      new RecordingBitStringAction());
  
