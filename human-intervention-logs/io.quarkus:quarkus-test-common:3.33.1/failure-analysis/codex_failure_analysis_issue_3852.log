nType()).isEqualTo(Class.class);\\n        assertThat(value.getGenericReturnType().getTypeName())\\n                .contains(QuarkusTestResourceLifecycleManager.class.getName());\\n        assertThat(initArgs.getReturnType()).isEqualTo(ResourceArg[].class);\\n        assertThat((ResourceArg[]) initArgs.getDefaultValue()).isEmpty();\\n        assertThat(parallel.getDefaultValue()).isEqualTo(false);\\n        assertThat(restrictToAnnotatedClass.getDefaultValue()).isEqualTo(false);\\n    }\\n\\n    @Test\\n    void withTestResourceDefinesRuntimeRepeatableTypeAnnotationContract() throws NoSuchMethodException {\\n        assertThat(WithTestResource.class.getAnnotation(Retention.class).value()).isEqualTo(RetentionPolicy.RUNTIME);\\n        assertThat(WithTestResource.class.getAnnotation(Target.class).value()).containsExactly(ElementType.TYPE);\\n        assertThat(WithTestResource.class.getAnnotation(Repeatable.class).value()).isEqualTo(WithTestResource.List.class);\\n        assertThat(WithTestResource.List.class.getAnnotation(Retention.class).value()).isEqualTo(RetentionPolicy.RUNTIME);\\n        assertThat(WithTestResource.List.class.getAnnotation(Target.class).value()).containsExactly(ElementType.TYPE);\\n\\n        Method value = WithTestResource.class.getDeclaredMethod(\\\"value\\\");\\n        Method initArgs = WithTestResource.class.getDeclaredMethod(\\\"initArgs\\\");\\n        Method parallel = WithTestResource.class.getDeclaredMethod(\\\"parallel\\\");\\n        Method scope = WithTestResource.class.getDeclaredMethod(\\\"scope\\\");\\n\\n        assertThat(value.getReturnType()).isEqualTo(Class.class);\\n        assertThat(value.getGenericReturnType().getTypeName())\\n                .contains(QuarkusTestResourceLifecycleManager.class.getName());\\n        assertThat(initArgs.getReturnType()).isEqualTo(ResourceArg[].class);\\n        assertThat((ResourceArg[]) initArgs.getDefaultValue()).isEmpty();\\n        assertThat(parallel.getDefaultValue()).isEqualTo(false);\\n        assertThat(scope.getDefaultValue()).isEqualTo(TestResourceScope.MATCHING_RESOURCES);\\n    }\\n\\n    @Test\\n    void resourceArgDefinesNamedRuntimeNestedAnnotationMembers() throws NoSuchMethodException {\\n        assertThat(ResourceArg.class.getAnnotation(Retention.class).value()).isEqualTo(RetentionPolicy.RUNTIME);\\n        assertThat(ResourceArg.class.getAnnotation(Target.class).value()).isEmpty();\\n\\n        assertThat(ResourceArg.class.getDeclaredMethod(\\\"name\\\").getReturnType()).isEqualTo(String.class);\\n        assertThat(ResourceArg.class.getDeclaredMethod(\\\"value\\\").getReturnType()).isEqualTo(String.class);\\n    }\\n\\n    @Test\\n    void httpResourceAnnotationDefinesFieldOnlyUrlConfiguration() throws NoSuchMethodException {\\n        assertThat(TestHTTPResource.class.getAnnotation(Retention.class).value()).isEqualTo(RetentionPolicy.RUNTIME);\\n        assertThat(TestHTTPResource.class.getAnnotation(Target.class).value()).containsExactly(ElementType.FIELD);\\n\\n        Method value = TestHTTPResource.class.getDeclaredMethod(\\\"value\\\");\\n        Method management = TestHTTPResource.class.getDeclaredMethod(\\\"management\\\");\\n        Method tls = TestHTTPResource.class.getDeclaredMethod(\\\"tls\\\");\\n\\n        assertThat(value.getReturnType()).isEqualTo(String.class);\\n        assertThat(value.getDefaultValue()).isEqualTo(\\\"\\\");\\n        assertThat(management.getDefaultValue()).isEqualTo(false);\\n        assertThat(tls.getDefaultValue()).isEqualTo(false);\\n    }\\n\\n    @Test\\n    void httpEndpointAndTransactionAnnotationsExposeTheirSupportedTargets() throws NoSuchMethodException {\\n        assertThat(TestHTTPEndpoint.class.getAnnotation(Retention.class).value()).isEqualTo(RetentionPolicy.RUNTIME);\\n        assertThat(TestHTTPEndpoint.class.getAnnotation(Target.class).value())\\n                .containsExactly(ElementType.METHOD, ElementType.TYPE, ElementType.FIELD);\\n        assertThat(TestHTTPEndpoint.class.getDeclaredMethod(\\\"value\\\").getReturnType()).isEqualTo(Class.class);\\n\\n        assertThat(TestTransaction.class.getAnnotation(Retention.class).value()).isEqualTo(RetentionPolicy.RUNTIME);\\n        assertThat(TestTransaction.class.getAnnotation(Target.class).value())\\n                .containsExactly(ElementType.TYPE, ElementType.METHOD);\\n        assertThat(TestTransaction.class.getAnnotation(InterceptorBinding.class)).isNotNull();\\n    }\\n\\n    @Test\\n    void resourceScopeDeclarationOrderRunsFromNarrowestToWidest() {\\n        assertThat(TestResourceScope.values()).containsExactly(\\n                TestResourceScope.RESTRICTED_TO_CLASS,\\n                TestResourceScope.MATCHING_RESOURCES,\\n                TestResourceScope.GLOBAL);\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 543, \"output\": 2485, \"cacheRead\": 87040, \"cacheWrite\": 0, \"totalTokens\": 90068, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778220792213, \"responseId\": \"resp_03e71391071d95a80169fd7ef97a4081a19bf1bf8f41902ec4\"}}\n36059:[tool-exec] start id=call_gXyHgIH03s54AozJTVilSIna|fc_03e71391071d95a80169fd7f06cfc081a1aaa22c24f988baea name=write args={\"path\": \"tests/src/io.quarkus/quarkus-test-common/3.33.1/src/test/java/io_quarkus/quarkus_test_common/TestResourceAnnotationsTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_quarkus.quarkus_test_common;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.lang.annotation.ElementType;\\nimport java.lang.annotation.Repeatable;\\nimport java.lang.annotation.Retention;\\nimport java.lang.annotation.RetentionPolicy;\\nimport j