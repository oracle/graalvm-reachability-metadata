icationJar);\\n    }\\n\\n    @Test\\n    void findsResourcesDirectoryForGradleClassesDirectory() throws IOException {\\n        Path project = Files.createTempDirectory(\\\"quarkus-path-helper-resources\\\");\\n        try {\\n            Path classes = Files.createDirectories(project.resolve(\\\"build/classes/java/test\\\"));\\n            Path resources = Files.createDirectories(project.resolve(\\\"build/resources/test\\\"));\\n\\n            assertThat(PathTestHelper.getResourcesForClassesDirOrNull(classes, \\\"test\\\")).isEqualTo(resources);\\n            assertThat(PathTestHelper.getResourcesForClassesDirOrNull(classes.resolve(\\\"Example.class\\\"), \\\"test\\\")).isNull();\\n        } finally {\\n            deleteRecursively(project);\\n        }\\n    }\\n\\n    private static void deleteRecursively(Path root) throws IOException {\\n        if (!Files.exists(root)) {\\n            return;\\n        }\\n        try (var paths = Files.walk(root)) {\\n            paths.sorted(Comparator.reverseOrder()).forEach(PathTestHelperTest::deleteIfExists);\\n        }\\n    }\\n\\n    private static void deleteIfExists(Path path) {\\n        try {\\n            Files.deleteIfExists(path);\\n        } catch (IOException e) {\\n            throw new IllegalStateException(\\\"Unable to delete temporary path \\\" + path, e);\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 4958, \"output\": 1565, \"cacheRead\": 46080, \"cacheWrite\": 0, \"totalTokens\": 52603, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778220682453, \"responseId\": \"resp_03e71391071d95a80169fd7e8bc95481a186010313f390e48b\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_6z6CxgUFXVluhc6si0FVGawS|fc_03e71391071d95a80169fd7e95636c81a1be188a799b4ac518\", \"toolName\": \"write\", \"content\": [{\"type\": \"text