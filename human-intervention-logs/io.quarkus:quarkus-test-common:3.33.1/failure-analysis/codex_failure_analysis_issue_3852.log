3\", \"name\": \"write\", \"arguments\": {\"path\": \"tests/src/io.quarkus/quarkus-test-common/3.33.1/src/test/java/io_quarkus/quarkus_test_common/Quarkus_test_commonTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_quarkus.quarkus_test_common;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatIllegalArgumentException;\\n\\nimport java.lang.annotation.ElementType;\\nimport java.lang.annotation.Inherited;\\nimport java.lang.annotation.Retention;\\nimport java.lang.annotation.RetentionPolicy;\\nimport java.lang.annotation.Target;\\nimport java.net.URI;\\nimport java.net.URL;\\nimport java.time.Duration;\\nimport java.util.ArrayList;\\nimport java.util.Collections;\\nimport java.util.HashMap;\\nimport java.util.List;\\nimport java.util.Map;\\nimport java.util.Optional;\\nimport java.util.Set;\\n\\nimport org.eclipse.microprofile.config.Config;\\nimport org.eclipse.microprofile.config.spi.ConfigSource;\\nimport org.junit.jupiter.api.AfterEach;\\nimport org.junit.jupiter.api.Test;\\n\\nimport io.quarkus.test.common.ArtifactLauncher;\\nimport io.quarkus.test.common.DevServicesContext;\\nimport io.quarkus.test.common.ListeningAddress;\\nimport io.quarkus.test.common.QuarkusTestResourceLifecycleManager;\\nimport io.quarkus.test.common.QuarkusTestResourceLifecycleManagerComparator;\\nimport io.quarkus.test.common.RestorableSystemProperties;\\nimport io.quarkus.test.common.TestConfigUtil;\\nimport io.quarkus.test.common.TestResourceManager;\\nimport io.quarkus.test.common.TestResourceScope;\\nimport io.quarkus.test.common.TestStatus;\\nimport io.quarkus.test.common.http.StringTestHTTPResourceProvider;\\nimport io.quarkus.test.common.http.TestHTTPResourceManager;\\nimport io.quarkus.test.common.http.URITestHTTPResourceProvider;\\nimport io.quarkus.test.common.http.URLTestHTTPResourceProvider;\\nimport io.quarkus.test.util.annotations.AnnotationContainer;\\nimport io.quarkus.test.util.annotations.AnnotationUtils;\\nimport io.quarkus.value.registry.ValueRegistry;\\nimport io.quarkus.value.registry.ValueRegistry.RuntimeInfo;\\nimport io.quarkus.value.registry.ValueRegistry.RuntimeKey;\\nimport io.smallrye.config.SmallRyeConfig;\\nimport io.smallrye.config.SmallRyeConfigBuilder;\\n\\npublic class Quarkus_test_commonTest {\\n    private static final String RESTORED_PROPERTY = \\\"quarkus.test.common.restored\\\";\\n    private static final String CLEARED_PROPERTY = \\\"quarkus.test.common.cleared\\\";\\n\\n    @AfterEach\\n    void clearMutableState() {\\n        System.clearProperty(RESTORED_PROPERTY);\\n        System.clearProperty(CLEARED_PROPERTY);\\n        StatefulTestResource.reset();\\n    }\\n\\n    @Test\\n    void argLineValuesSplitWhitespaceAndIgnoreBlankInput() {\\n        assertThat(TestConfigUtil.argLineValues(null)).isEmpty();\\n        assertThat(TestConfigUtil.argLineValues(\\\" \\\\t\\\\n \\\")).isEmpty();\\n        assertThat(TestConfigUtil.argLineValues(\\\" -Dalpha=1   --flag\\\\t-Dbeta=two \\\"))\\n                .containsExactly(\\\"-Dalpha=1\\\", \\\"--flag\\\", \\\"-Dbeta=two\\\");\\n    }\\n\\n    @Test\\n    void runTargetReadsOptionalConfigValue() {\\n        Config config = smallRyeConfig(Map.of(\\\"quarkus.run.target\\\", \\\"native\\\"));\\n        Config emptyConfig = smallRyeConfig(Collections.emptyMap());\\n\\n        assertThat(TestConfigUtil.runTarget(config)).isEqualTo(\\\"native\\\");\\n        assertThat(TestConfigUtil.runTarget(emptyConfig)).isNull();\\n    }\\n\\n    @Test\\n    void restorableSystemPropertiesRestorePreviousValuesAndClearMissingValues() {\\n        System.setProperty(RESTORED_PROPERTY, \\\"before\\\");\\n        System.clearProperty(CLEARED_PROPERTY);\\n\\n        try (RestorableSystemProperties ignored = RestorableSystemProperties.setProperties(\\n                Map.of(RESTORED_PROPERTY, \\\"during\\\", CLEARED_PROPERTY, \\\"created\\\"), CLEARED_PROPERTY)) {\\n            assertThat(System.getProperty(RESTORED_PROPERTY)).isEqualTo(\\\"during\\\");\\n            assertThat(System.getProperty(CLEARED_PROPERTY)).isEqualTo(\\\"created\\\");\\n        }\\n\\n        assertThat(System.getProperty(RESTORED_PROPERTY)).isEqualTo(\\\"before\\\");\\n        assertThat(System.getProperty(CLEARED_PROPERTY)).isNull();\\n    }\\n\\n    @Test\\n    void restorableSystemPropertiesRejectInvalidEntriesBeforeMutatingSystemProperties() {\\n        assertThatIllegalArgumentException()\\n                .isThrownBy(() -> RestorableSystemProperties.setProperties(Collections.singletonMap(\\\"valid\\\", null)))\\n                .withMessageContaining(\\\"Cannot use null value\\\");\\n        assertThatIllegalArgumentException()\\n                .isThrownBy(() -> RestorableSystemProperties.setProperties(Collections.singletonMap(null, \\\"value\\\")))\\n                .withMessageContaining(\\\"Cannot set null key\\\");\\n    }\\n\\n    @Test\\n    void listeningAddressRegistersPortsAndBuildsLocalBaseUri() {\\n        SimpleValueRegistry registry = new SimpleValueRegistry();\\n        SmallRyeConfig config = smallRyeConfig(Map.of(\\\"quarkus.http.host\\\", \\\"0.0.0.0\\\", \\\"quarkus.http.root-path\\\", \\\"api\\\"));\\n\\n        ListeningAddress address = new ListeningAddress(8181, \\\"http\\\");\\n        address.register(registry, config);\\n\\n        assertThat(address.isSsl()).isFalse();\\n        assertThat(registry.get(ListeningAddress.HTTP_PORT)).isEqualTo(8181);\\n        assertThat(registry.get(ListeningAddress.HTTP_TEST_PORT)).isEqualTo(8181);\\n        assertThat(registry.get(ListeningAddress.LOCAL_BASE_URI)).isEqualTo(URI.create(\\\"http://localhost:8181/api/\\\"));\\n    }\\n\\n    @Test\\n    void httpResourceManagerBuildsApplicationAndManagementUrls() {\\n        SimpleValueRegistry registry = new SimpleValueRegistry();\\n        registry.register(ListeningAddress.HTTP_TEST_PORT, 8180);\\n        registry.register(ListeningAddress.HTTPS_TEST_PORT, 8543);\\n        registry.register(RuntimeKey.intKey(\\\"quarkus.management.test-port\\\"), 9191);\\n        SmallRyeConfig config = smallRyeConfig(Map.of(\\n                \\\"quarkus.http.host\\\", \\\"127.0.0.1\\\",\\n                \\\"quarkus.management.host\\\", \\\"management.local\\\",\\n                \\\"quarkus.http.root-path\\\", \\\"root\\\",\\n                \\\"quarkus.servlet.context-path\\\", \\\"/ctx\\\",\\n                \\\"quarkus.management.root-path\\\", \\\"manage\\\"));\\n\\n        assertThat(TestHTTPResourceManager.testUrl(registry, config, \\\"/hello\\\"))\\n                .isEqualTo(\\\"http://127.0.0.1:8180/root/ctx/hello\\\");\\n        assertThat(TestHTTPResourceManager.testUrlSsl(registry, config, \\\"secure\\\"))\\n                .isEqualTo(\\\"https://127.0.0.1:8543/root/ctx/secure\\\");\\n        assertThat(TestHTTPResourceManager.testManagementUrl(registry, config, \\\"health\\\"))\\n                .isEqualTo(\\\"http://management.local:9191/manage/health\\\");\\n        assertThat(TestHTTPResourceManager.testManagementUrlSsl(registry, config, \\\"/metrics\\\"))\\n                .isEqualTo(\\\"https://management.local:9191/manage/metrics\\\");\\n    }\\n\\n    @Test\\n    void httpResourceProvidersConvertTestUriToSupportedTypes() throws Exception {\\n        String uri = \\\"https://localhost:8444/root/path?name=value\\\";\\n\\n        assertThat(new StringTestHTTPResourceProvider().getProvidedType()).isEqualTo(String.class);\\n        assertThat(new StringTestHTTPResourceProvider().provide(uri, null)).isEqualTo(uri);\\n\\n        URITestHTTPResourceProvider uriProvider = new URITestHTTPResourceProvider();\\n        URI providedUri = uriProvider.provide(uri, null);\\n        assertThat(uriProvider.getProvidedType()).isEqualTo(URI.class);\\n        assertThat(providedUri).isEqualTo(new URI(uri));\\n\\n        URLTestHTTPResourceProvider urlProvider = new URLTestHTTPResourceProvider();\\n        URL providedUrl = urlProvider.provide(uri, null);\\n        assertThat(urlProvider.getProvidedType()).isEqualTo(URL.class);\\n        assertThat(providedUrl).isEqualTo(new URI(uri).toURL());\\n    }\\n\\n    @Test\\n    void testResourceManagerInitializesStartsInjectsAndStopsResources() {\\n        TestResourceManager.TestResourceClassEntry entry = new TestResourceManager.TestResourceClassEntry(\\n                StatefulTestResource.class, Map.of(\\\"message\\\", \\\"configured\\\"), null, false,\\n                TestResourceScope.MATCHING_RESOURCES);\\n        Throwable failure = new IllegalStateException(\\\"boom\\\");\\n        TestResourceConsumer consumer = new TestResourceConsumer();\\n\\n        try (TestResourceManager manager = new TestResourceManager(TestResourceConsumer.class, null, List.of(entry), true,\\n                Map.of(\\\"dev.service.url\\\", \\\"localhost\\\"), Optional.of(\\\"test-network\\\"))) {\\n            manager.setTestErrorCause(failure);\\n            manager.init(\\\"profile-name\\\");\\n            Map<String, String> startedProperties = manager.start();\\n            manager.inject(consumer);\\n\\n            assertThat(startedProperties).containsEntry(\\\"resource.message\\\", \\\"configured\\\");\\n            assertThat(manager.getConfigProperties()).containsEntry(\\\"resource.message\\\", \\\"configured\\\");\\n            assertThat(consumer.injectedString).isEqualTo(\\\"injected-value\\\");\\n            assertThat(consumer.context.devServicesProperties()).containsEntry(\\\"dev.service.url\\\", \\\"localhost\\\");\\n            assertThat(consumer.context.containerNetworkId()).contains(\\\"test-network\\\");\\n            assertThat(consumer.contextCapture.context.containerNetworkId()).contains(\\\"test-network\\\");\\n            assertThat(StatefulTestResource.events).containsExactly(\\n                    \\\"context-aware:test-network\\\",\\n                    \\\"context:profile-name:true\\\",\\n                    \\\"init:configured\\\",\\n                    \\\"start:configured\\\",\\n                    \\\"inject-object\\\",\\n                    \\\"inject-test-injector\\\");\\n            assertThat(StatefulTestResource.testErrorCause).isSameAs(failure);\\n        }\\n\\n        assertThat(StatefulTestResource.events).endsWith(\\\"stop\\\");\\n    }\\n\\n    @Test\\n    void testResourceComparisonInfoControlsReloadDecisions() {\\n        TestResourceManager.TestResourceComparisonInfo matching = new TestResourceManager.TestResourceComparisonInfo(\\n                OrderedResource.class.getName(), TestResourceScope.MATCHING_RESOURCES, Map.of(\\\"name\\\", \\\"a\\\"));\\n        TestResourceManager.TestResourceComparisonInfo sameMatching = new TestResourceManager.TestResourceComparisonInfo(\\n                OrderedResource.class.getName(), TestResourceScope.MATCHING_RESOURCES, Map.of(\\\"name\\\", \\\"a\\\"));\\n        TestResourceManager.TestResourceComparisonInfo differentMatching = new TestResourceManager.TestResourceComparisonInfo(\\n                StatefulTestResource.class.getName(), TestResourceScope.MATCHING_RESOURCES, Map.of(\\\"name\\\", \\\"b\\\"));\\n        TestResourceManager.TestResourceComparisonInfo restricted = new TestResourceManager.TestResourceComparisonInfo(\\n                StatefulTestResource.class.getName(), TestResourceScope.RESTRICTED_TO_CLASS, Map.of());\\n\\n        assertThat(TestResourceManager.testResourcesRequireReload(Set.of(), Set.of())).isFalse();\\n        assertThat(TestResourceManager.testResourcesRequireReload(Set.of(matching), Set.of(sameMatching))).isFalse();\\n        assertThat(TestResourceManager.testResourcesRequireReload(Set.of(matching), Set.of(differentMatching))).isTrue();\\n        assertThat(TestResourceManager.testResourcesRequireReload(Set.of(matching), Set.of(restricted))).isTrue();\\n        assertThat(TestResourceManager.getReloadGroupIdentifier(Set.of(matching))).contains(OrderedResource.class.getName());\\n        assertThat(TestResourceManager.getReloadGroupIdentifier(Set.of(restricted)))\\n                .contains(StatefulTestResource.class.getName());\\n    }\\n\\n    @Test\\n    void comparatorOrdersLifecycleManagersByOrderValue() {\\n        List<QuarkusTestResourceLifecycleManager> resources = new ArrayList<>(List.of(\\n                new OrderedResource(20), new OrderedResource(-1), new OrderedResource(7)));\\n\\n        resources.sort(new QuarkusTestResourceLifecycleManagerComparator());\\n\\n        assertThat(resources).extracting(QuarkusTestResourceLifecycleManager::order).containsExactly(-1, 7, 20);\\n    }\\n\\n    @Test\\n    void statusAndLaunchResultExposeTheirValues() {\\n        Throwable failure = new RuntimeException(\\\"failed\\\");\\n        TestStatus failed = new TestStatus(failure);\\n        TestStatus passed = new TestStatus(null);\\n        ArtifactLauncher.LaunchResult result = new ArtifactLauncher.LaunchResult(2, \\\"out\\\".getBytes(), \\\"err\\\".getBytes());\\n\\n        assertThat(failed.isTestFailed()).isTrue();\\n        assertThat(failed.getTestErrorCause()).isSameAs(failure);\\n        assertThat(passed.isTestFailed()).isFalse();\\n        assertThat(passed.getTestErrorCause()).isNull();\\n        assertThat(result.getStatusCode()).isEqualTo(2);\\n        assertThat(result.getOutput()).asString().isEqualTo(\\\"out\\\");\\n        assertThat(result.getStderror()).asString().isEqualTo(\\\"err\\\");\\n    }\\n\\n    @Test\\n    void annotationUtilitiesFindDirectMetaInterfaceAndInheritedAnnotations() {\\n        Optional<AnnotationContainer<Marker>> direct = AnnotationUtils.findAnnotation(DirectlyMarked.class, Marker.class);\\n        Optional<AnnotationContainer<Marker>> meta = AnnotationUtils.findAnnotation(MetaMarked.class, Marker.class);\\n        Optional<AnnotationContainer<Marker>> fromInterface = AnnotationUtils.findAnnotation(InterfaceImplementation.class,\\n                Marker.class);\\n        Optional<AnnotationContainer<Marker>> inherited = AnnotationUtils.findAnnotation(InheritsMarker.class, Marker.class);\\n\\n        assertThat(direct).isPresent();\\n        assertThat(direct.get().getElement()).isEqualTo(DirectlyMarked.class);\\n        assertThat(direct.get().getAnnotation().value()).isEqualTo(\\\"direct\\\");\\n        assertThat(meta).isPresent();\\n        assertThat(meta.get().getElement()).isEqualTo(MetaMarker.class);\\n        assertThat(meta.get().getAnnotation().value()).isEqualTo(\\\"meta\\\");\\n        assertThat(fromInterface).isPresent();\\n        assertThat(fromInterface.get().getElement()).isEqualTo(MarkedInterface.class);\\n        assertThat(inherited).isPresent();\\n        assertThat(inherited.get().getElement()).isEqualTo(BaseWithMarker.class);\\n        assertThat(AnnotationUtils.findAnnotation(Unmarked.class, Marker.class)).isEmpty();\\n    }\\n\\n    private static SmallRyeConfig smallRyeConfig(Map<String, String> values) {\\n        return new SmallRyeConfigBuilder().withSources(new MapConfigSource(values)).build();\\n    }\\n\\n    private static final class MapConfigSource implements ConfigSource {\\n        private final Map<String, String> values;\\n\\n        private MapConfigSource(Map<String, String> values) {\\n            this.values = values;\\n        }\\n\\n        @Override\\n        public Map<String, String> getProperties() {\\n            return values;\\n        }\\n\\n        @Override\\n        public Set<String> getPropertyNames() {\\n            return values.keySet();\\n        }\\n\\n        @Override\\n        public String getValue(String propertyName) {\\n            return values.get(propertyName);\\n        }\\n\\n        @Override\\n        public String getName() {\\n            return \\\"test-map-config-source\\\";\\n        }\\n\\n        @Override\\n        public int getOrdinal() {\\n            return 500;\\n        }\\n    }\\n\\n    private static final class SimpleValueRegistry implements ValueRegistry {\\n        private final Map<RuntimeKey<?>, Object> values = new HashMap<>();\\n        private final Map<String, RuntimeInfo<?>> runtimeInfo = new HashMap<>();\\n\\n        @Override\\n        public <T> void register(RuntimeKey<T> key, T value) {\\n            values.put(key, value);\\n        }\\n\\n        @Override\\n        public <T> void registerInfo(RuntimeKey<T> key, RuntimeInfo<T> info) {\\n            runtimeInfo.put(key.key(), info);\\n        }\\n\\n        @Override\\n        @SuppressWarnings(\\\"unchecked\\\")\\n        public <T> T get(RuntimeKey<T> key) {\\n            return (T) values.get(key);\\n        }\\n\\n        @Override\\n        public <T> T getOrDefault(RuntimeKey<T> key, T defaultValue) {\\n            T value = get(key);\\n            return value != null ? value : defaultValue;\\n        }\\n\\n        @Override\\n        public boolean containsKey(RuntimeKey<T> key) {\\n            return values.containsKey(key);\\n        }\\n\\n        @Override\\n        public RuntimeInfo<?> get(String key) {\\n            return runtimeInfo.get(key);\\n        }\\n    }\\n\\n    public static final class StatefulTestResource\\n            implements QuarkusTestResourceLifecycleManager, DevServicesContext.ContextAware {\\n        private static final List<String> events = new ArrayList<>();\\n        private static Throwable testErrorCause;\\n\\n        private String message;\\n\\n        public StatefulTestResource() {\\n        }\\n\\n        private static void reset() {\\n            events.clear();\\n            testErrorCause = null;\\n        }\\n\\n        @Override\\n        public void setIntegrationTestContext(DevServicesContext context) {\\n            events.add(\\\"context-aware:\\\" + context.containerNetworkId().orElse(\\\"none\\\"));\\n        }\\n\\n        @Override\\n        public void setContext(Context context) {\\n            testErrorCause = context.getTestStatus().getTestErrorCause();\\n            events.add(\\\"context:\\\" + context.testProfile() + \\\":\\\" + context.getTestStatus().isTestFailed());\\n        }\\n\\n        @Override\\n        public void init(Map<String, String> initArgs) {\\n            message = initArgs.get(\\\"message\\\");\\n            events.add(\\\"init:\\\" + message);\\n        }\\n\\n        @Override\\n        public Map<String, String> start() {\\n            events.add(\\\"start:\\\" + message);\\n            return Map.of(\\\"resource.message\\\", message);\\n        }\\n\\n        @Override\\n        public void inject(Object testInstance) {\\n            events.add(\\\"inject-object\\\");\\n        }\\n\\n        @Override\\n        public void inject(TestInjector testInjector) {\\n            events.add(\\\"inject-test-injector\\\");\\n            testInjector.injectIntoFields(\\\"injected-value\\\", new TestInjector.MatchesType(String.class));\\n        }\\n\\n        @Override\\n        public void stop() {\\n            events.add(\\\"stop\\\");\\n        }\\n    }\\n\\n    public static final class OrderedResource implements QuarkusTestResourceLifecycleManager {\\n        private final int order;\\n\\n        public OrderedResource() {\\n            this(0);\\n        }\\n\\n        private OrderedResource(int order) {\\n            this.order = order;\\n        }\\n\\n        @Override\\n        public Map<String, String> start() {\\n            return Collections.emptyMap();\\n        }\\n\\n        @Override\\n        public void stop() {\\n        }\\n\\n        @Override\\n        public int order() {\\n            return order;\\n        }\\n    }\\n\\n    private static final class TestResourceConsumer {\\n        private String injectedString;\\n        private DevServicesContext context;\\n        private final ContextCapture contextCapture = new ContextCapture();\\n    }\\n\\n    private s