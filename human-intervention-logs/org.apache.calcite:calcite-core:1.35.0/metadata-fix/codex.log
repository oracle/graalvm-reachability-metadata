{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,260p' tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ReflectiveSchemaTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_calcite.calcite_core;\n\nimport org.apache.calcite.adapter.java.ReflectiveSchema;\nimport org.apache.calcite.rel.RelReferentialConstraint;\nimport org.apache.calcite.schema.Function;\nimport org.apache.calcite.schema.Table;\nimport org.apache.calcite.schema.TranslatableTable;\nimport org.apache.calcite.util.mapping.IntPair;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Collection;\nimport java.util.List;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectiveSchemaTest {\n\n    @Test\n    void exposesPublicArrayFieldsAsTablesAndAttachesReferentialConstraints() {\n        SampleSchema target = new SampleSchema();\n        ReflectiveSchema schema = new ReflectiveSchema(target);\n\n        Set<String> tableNames = schema.getTableNames();\n\n        assertThat(tableNames).containsExactlyInAnyOrder(\"EMPLOYEES\", \"DEPARTMENTS\");\n        Table employees = schema.getTable(\"EMPLOYEES\");\n        assertThat(employees).isNotNull();\n        assertThat(employees.getStatistic().getReferentialConstraints())\n                .containsExactly(target.EMPLOYEE_DEPARTMENT);\n    }\n\n    @Test\n    void exposesPublicTranslatableTableMethodsAsFunctions() {\n        ReflectiveSchema schema = new ReflectiveSchema(new SampleSchema());\n\n        Collection<Function> functions = schema.getFunctions(\"projectedEmployees\");\n\n        assertThat(schema.getFunctionNames()).contains(\"projectedEmployees\");\n        assertThat(functions)