oBoundMetadata() {\n        BuiltInMetadata.RowCount.Handler handler = new ProxyingMetadataHandlerProvider(\n                new FixedRowCountProvider(123.5))\n                .handler(BuiltInMetadata.RowCount.Handler.class);\n\n        Double rowCount = handler.getRowCount(oneRowRel(), metadataQuery());\n\n        assertThat(rowCount).isEqualTo(123.5);\n    }\n\n    @Test\n    void reportsMissingMetadataHandlerForRelClass() {\n        BuiltInMetadata.RowCount.Handler handler = new ProxyingMetadataHandlerProvider(\n                new MissingRowCountProvider())\n                .handler(BuiltInMetadata.RowCount.Handler.class);\n\n        RelNode rel = oneRowRel();\n        assertThatThrownBy(() -> handler.getRowCount(rel, metadataQuery()))\n                .isInstanceOf(IllegalArgumentException.class)\n                .hasMessageContaining(\"No handler for method\")\n                .hasMessageContaining(rel.getClass().getName());\n    }\n\n    private static RelNode oneRowRel() {\n        JavaTypeFactoryImpl typeFactory = new JavaTypeFactoryImpl();\n        RexBuilder rexBuilder = new RexBuilder(typeFactory);\n        RelOptCluster cluster = RelOptCluster.create(new VolcanoPlanner(), rexBuilder);\n        RelDataType rowType = typeFactory.builder()\n                .add(\"ZERO\", SqlTypeName.INTEGER)\n                .nullable(false)\n                .build();\n        RexLiteral zero = rexBuilder.makeExactLiteral(\n                BigDecimal.ZERO,\n                rowType.getFieldList().get(0).getType());\n        return new LogicalValues(cluster, rowType, ImmutableList.of(ImmutableList.of(zero)));\n    }\n\n    private static RelMetadataQuery metadataQuery() {\n        return new RelMetadataQuery(new EmptyMetadataHandlerProvider());\n    }\n\n    private static final class FixedRowCountProvider extends BaseRowCountProvider {\n        private final double rowCount;\n\n        private FixedRowCountProvider(double rowCount) {\n            this.rowCount = rowCount;\n        }\n\n        @Override\n        public <M extends Metadata> UnboundMetadata<M> apply(\n                Class<? extends RelNode> relClass,\n                Class<? extends M> metadataClass) {\n            if (metadataClass != BuiltInMetadata.RowCount.class) {\n                return null;\n            }\n            return (rel, mq) -> metadataClass.cast(new FixedRowCount(rel, rowCount));\n        }\n    }\n\n    private static final class MissingRowCountProvider extends BaseRowCountProvider {\n        @Override\n        public <M extends Metadata> UnboundMetadata<M> apply(\n                Class<? extends RelNode> relClass,\n                Class<? extends M> metadataClass) {\n            return null;\n        }\n    }\n\n    private abstract static class BaseRowCountProvider implements RelMetadataProvider {\n        @Override\n        public <M extends Metadata> Multimap<Method, MetadataHandler<M>> handlers(MetadataDef<M> def) {\n            return ImmutableListMultimap.of();\n        }\n\n        @Override\n        public List<MetadataHandler<?>> handlers(Class<? extends MetadataHandler<?>> handlerClass) {\n            return List.of();\n        }\n    }\n\n    private static final class EmptyMetadataHandlerProvider implements MetadataHandlerProvider {\n        @Override\n        public <MH extends MetadataHandler<?>> MH handler(Class<MH> handlerClass) {\n            return null;\n        }\n    }\n\n    private static final class FixedRowCount implements BuiltInMetadata.RowCount {\n        private final RelNode rel;\n        private final double rowCount;\n\n        private FixedRowCount(RelNode rel, double rowCount) {\n            this.rel = rel;\n            this.rowCount = rowCount;\n        }\n\n        @Override\n        public RelNode rel() {\n            return rel;\n        }\n\n        @Override\n        public Double getRowCount() {\n            return rowCount;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
