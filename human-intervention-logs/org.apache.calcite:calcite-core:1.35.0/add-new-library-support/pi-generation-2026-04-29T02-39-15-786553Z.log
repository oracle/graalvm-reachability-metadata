          final List<@Nullable Object> valueList = Arrays.asList(values);
          for (Pair<RexNode, @Nullable Object> value : Pair.zip(constExps, valueList)) {
            reducedValues.add(
                rexBuilder.makeLiteral(value.right, value.left.getType(), true));
