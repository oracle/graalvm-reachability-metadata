alcite.schema.TranslatableTable;\nimport org.apache.calcite.util.mapping.IntPair;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Collection;\nimport java.util.List;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectiveSchemaTest {\n\n    @Test\n    void exposesPublicArrayFieldsAsTablesAndAttachesReferentialConstraints() {\n        SampleSchema target = new SampleSchema();\n        ReflectiveSchema schema = new ReflectiveSchema(target);\n\n        Set<String> tableNames = schema.getTableNames();\n\n        assertThat(tableNames).containsExactlyInAnyOrder(\"EMPLOYEES\", \"DEPARTMENTS\");\n        Table employees = schema.getTable(\"EMPLOYEES\");\n        assertThat(employees).isNotNull();\n        assertThat(employees.getStatistic().getReferentialConstraints())\n                .containsExactly(target.EMPLOYEE_DEPARTMENT);\n    }\n\n    @Test\n    void exposesPublicTranslatableTableMethodsAsFunctions() {\n        ReflectiveSchema schema = new ReflectiveSchema(new SampleSchema());\n\n        Collection<Function> functions = schema.getFunctions(\"projectedEmployees\");\n\n        assertThat(schema.getFunctionNames()).contains(\"projectedEmployees\");\n        assertThat(functions).hasSize(1);\n    }\n\n    public static final class SampleSchema {\n        public final Employee[] EMPLOYEES = {\n                new Employee(1, 10, \"Ada\"),\n                new Employee(2, 20, \"Grace\")\n        };\n        public final Department[] DEPARTMENTS = {\n                new Department(10, \"Engineering\"),\n                new Department(20, \"Research\")\n        };\n        public final RelReferentialConstraint EMPLOYEE_DEPARTMENT = new EmployeeDepartmentConstraint();\n\n        public TranslatableTable projectedEmployees() {\n            throw new UnsupportedOperationException(\"The reflective schema only inspects this method's signature\");\n        }\n    }\n\n    public static final class Employee {\n        public final int id;\n        public final int departmentId;\n        public final String name;\n\n        Employee(int id, int departmentId, String name) {\n            this.id = id;\n            this.departmentId = departmentId;\n            this.name = name;\n        }\n    }\n\n    public static final class Department {\n        public final int id;\n        public final String name;\n\n        Department(int id, String name) {\n            this.id = id;\n            this.name = name;\n        }\n    }\n\n    private static final class EmployeeDepartmentConstraint implements RelReferentialConstraint {\n        @Override\n        public List<String> getSourceQualifiedName() {\n            return List.of(\"EMPLOYEES\");\n        }\n\n        @Override\n        public List<String> getTargetQualifiedName() {\n            return List.of(\"DEPARTMENTS\");\n        }\n\n        @Override\n        public List<IntPair> getColumnPairs() {\n            return List.of(IntPair.of(1, 0));\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 628, "output": 875, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 26079, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778076906527, "responseId": "resp_05ab237d40a8087b0169fb4ceb1b04819081338fe8750b09c8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_axfAPDL5FspbOWsrIsvueTMP|fc_05ab237d40a8087b0169fb4cec8cd0819096714b092a38b298", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3365 bytes to tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ReflectiveSchemaTest.java"}], "isError": false, "timestamp": 1778076915185}]}
