de\n        public RelNode toRel(RelOptTable.ToRelContext context, RelOptTable relOptTable) {\n            throw new UnsupportedOperationException(\"Function discovery test only\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777424349308}}
