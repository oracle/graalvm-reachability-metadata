;\n        int configuredLineLength = defaultLineLength == 47 ? 48 : 47;\n        writer.setLineLength(configuredLineLength);\n\n        StringWriter description = new StringWriter();\n        writer.describe(new PrintWriter(description), false);\n\n        assertThat(description.toString())\n                .contains(\"lineLength=\" + configuredLineLength);\n    }\n\n    public static class PropertyAwarePrettyWriter extends SqlPrettyWriter {\n        private String requestedIndentation;\n\n        public PropertyAwarePrettyWriter() {\n            super(SqlPrettyWriter.config());\n        }\n\n        public Void setIndentation(String indentation) {\n            requestedIndentation = indentation;\n            return null;\n        }\n\n        String requestedIndentation() {\n            return requestedIndentation;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 328, "output": 1038, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 19798, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777424375317, "responseId": "resp_076a1025046ca0c70169f157f7cc848194aff2fa5f18bbe104"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tbBsMcTXKAEQrl3j6xEWSouT|fc_076a1025046ca0c70169f1580620608194a2178bdc80cc44f6", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1792 bytes to tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/SqlPrettyWriterInnerBeanTest.java"}], "isError": false, "timestamp": 1777424391732}]}
