ment {\n        public final int id;\n        public final String name;\n\n        Department(int id, String name) {\n            this.id = id;\n            this.name = name;\n        }\n    }\n\n    public static final class TestReferentialConstraint implements RelReferentialConstraint {\n        private final String sourceTable;\n        private final String targetTable;\n\n        TestReferentialConstraint(String sourceTable, String targetTable) {\n            this.sourceTable = sourceTable;\n            this.targetTable = targetTable;\n        }\n\n        @Override\n        public List<String> getSourceQualifiedName() {\n            return List.of(sourceTable);\n        }\n\n        @Override\n        public List<String> getTargetQualifiedName() {\n            return List.of(targetTable);\n        }\n\n        @Override\n        public List<IntPair> getColumnPairs() {\n            return List.of(IntPair.of(1, 0));\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1986, "output": 1070, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 25072, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780827273902, "responseId": "resp_0b555a4489f277d9016a25448a81988194a19828c3389802f3"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_aqEV0pm0IoqkjRe3vP381xXJ|fc_0b555a4489f277d9016a25448e39b88194980b352e461edb39", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3993 bytes to tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ReflectiveSchemaTest.java"}], "isError": false, "timestamp": 1780827287620}]}
