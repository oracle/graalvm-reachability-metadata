  package org_apache_calcite.calcite_core;
  
  import org.apache.calcite.adapter.java.ReflectiveSchema;
  import org.apache.calcite.rel.RelReferentialConstraint;
  import org.apache.calcite.schema.ScannableTable;
  import org.apache.calcite.schema.Table;
  import org.apache.calcite.schema.TranslatableTable;
  import org.apache.calcite.util.mapping.IntPair;
  
  import org.junit.jupiter.api.Test;
  
  import java.util.Arrays;
  import java.util.Collection;
  import java.util.List;
  import java.util.Set;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectiveSchemaTest {
      @Test
      void exposesPublicCollectionFieldsAsTablesAndAppliesConstraints() {
          TestCatalog catalog = new TestCatalog();
          ReflectiveSchema schema = new ReflectiveSchema(catalog);
  
          Set<String> tableNames = schema.getTableNames();
  
          assertThat(tableNames).containsExactlyInAnyOrder("employees", "departments");
          Table employees = schema.getTable("employees");
          assertThat(employees).isInstanceOf(ScannableTable.class);
          assertThat(employees.getStatistic().getReferentialConstraints())
                  .containsExactly(catalog.employeeDepartmentConstraint);
  
          Table departments = schema.getTable("departments");
          assertThat(departments).isInstanceOf(ScannableTable.class);
      }
  
      @Test
      void exposesPublicTranslatableTableMethodsAsFunctions() {
          ReflectiveSchema schema = new ReflectiveSchema(new TestCatalog());
  
          Set<String> functionNames = schema.getFunctionNames();
          Collection<?> functions = schema.getFunctions("activeEmployees");
  
          assertThat(functionNames).contains("activeEmployees");
          assertThat(functions).hasSize(1);
      }
  
      public static final class TestCatalog {
          public final Employee[] employees = {
                  new Employee(1, 10, "Alice"),
                  new Employee(2, 20, "Bob")
          };
          public final List<Department> departments = Arrays.asList(
                  new Department(10, "Sales"),
                  new Department(20, "Engineering"));
          public final RelReferentialConstraint employeeDepartmentConstraint =
                  new TestReferentialConstraint("employees", "departments");
  
          public TranslatableTable activeEmployees() {
              throw new UnsupportedOperationException("Method is only exposed as a table macro");
          }
      }
  
      public static final class Employee {
          public final int id;
          public final int departmentId;
          public final String name;
  
          Employee(int id, int departmentId, String name) {
              this.id = id;
              this.departmentId = departmentId;
              this.name = name;
          }
      }
  
      public static final class Department {
          public final int id;
          public final String name;
  
          Department(int id, String name) {
              this.id = id;
              this.name = name;
          }
      }
  
      public static final class TestReferentialConstraint implements RelReferentialConstraint {
          private final String sourceTable;
          private final String targetTable;
  
          TestReferentialConstraint(String sourceTable, String targetTable) {
              this.sourceTable = sourceTable;
              this.targetTable = targetTable;
          }
  
          @Override
          public List<String> getSourceQualifiedName() {
              return List.of(sourceTable);
          }
  
          @Override
          public List<String> getTargetQualifiedName() {
              return List.of(targetTable);
          }
  
          @Override
          public List<IntPair> getColumnPairs() {
              return List.of(IntPair.of(1, 0));
          }
      }
  }
