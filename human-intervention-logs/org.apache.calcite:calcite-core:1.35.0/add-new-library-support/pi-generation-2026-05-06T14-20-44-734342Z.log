[tool-call] delta {"path":"tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ReflectiveSchemaInnerFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_calcite.calcite_core;\n\nimport org.apache.calcite.adapter.java.ReflectiveSchema;\nimport org.apache.calcite.schema.Schema;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectiveSchemaInnerFactoryTest {\n\n    @Test\n    void createsReflectiveSchemaFromPublicNoArgumentConstructor() {\n        ReflectiveSchema.Factory factory = new ReflectiveSchema.Factory();\n        Map<String, Object> operand = Map.of(\"class\", ConstructorBackedSchema.class.getName());\n\n        Schema schema = factory.create(null, \"constructorSchema\", operand);\n\n        assertThat(schema.getTableNames()).containsExactly(\"ROWS\");\n    }\n\n    @Test\n    void createsReflectiveSchemaFromPublicStaticFactoryMethod() {\n        ReflectiveSchema.Factory factory = new ReflectiveSchema.Factory();\n        Map<String, Object> operand = Map.of(\n                \"class\", StaticMethodBackedSchema.class.getName(),\n                \"staticMethod\", \"create\");\n\n        Schema schema = factory.create(null, \"staticMethodSchema\", operand);\n\n        assertThat(schema.getTableNames()).containsExactly(\"VALUES\");\n    }\n\n    public static final class ConstructorBackedSchema {\n        public final Row[] ROWS = {\n                new Row(1, \"constructor\")\n        };\n\n        public ConstructorBackedSchema() {\n        }\n    }\n\n    public static final class StaticMethodBackedSchema {\n        public final Row[] VALUES = {\n                new Row(2, \"static-method\")\n        };\n\n        private StaticMethodBackedSchema() {\n        }\n\n        public static StaticMethodBackedSchema create() {\n            return new StaticMethodBackedSchema();\n        }\n    }\n\n    public static final class Row {\n        public final int id;\n        public final String label;\n\n        Row(int id, String label) {\n            this.id = id;\n            this.label = label;\n        }\n    }\n}\n"}
