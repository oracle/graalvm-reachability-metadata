      CountAccumulator(AggregateCall call) {
        this.call = call;
        cnt = 0;
      }
  
      @Override public void send(Row row) {
        boolean notNull = true;
        for (Integer i : call.getArgList()) {
          if (row.getObject(i) == null) {
            notNull = false;
