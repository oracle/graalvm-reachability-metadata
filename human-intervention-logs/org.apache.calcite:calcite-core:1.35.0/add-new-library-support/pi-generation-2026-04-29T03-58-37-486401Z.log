    @Override public String getRelTypeName() {
      String cn = getClass().getName();
      int i = cn.length();
      while (--i >= 0) {
        if (cn.charAt(i) == '$' || cn.charAt(i) == '.') {
          return cn.substring(i + 1);
        }
      }
      return cn;
