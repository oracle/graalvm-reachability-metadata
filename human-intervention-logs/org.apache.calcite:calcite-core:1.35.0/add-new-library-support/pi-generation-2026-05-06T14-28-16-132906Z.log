OKSBsyREupcIGLOzDOl-HvyJrf9aoVF3xZb3nz0OIYuC1tPKIqUNGZM7hXwQwBYoj5x8xtLseqx-D4ZhBLAawGBm0QhTkap4xuleEXgMT58MWGJvabPGUp56nYWfoNPTwnacVSIDL21kwv4bELOCZP7COQWPZSWPgrW_ZmPgyqeBsRgqYa2qOrF03xrm7g1Ow-uwU46tO3jHz2Za7vYzd3Q==\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_u0QXMHnJobLyecJSiy9m7pZB|fc_039cc40c4dfe30580169fb4f86e6648196b71fe5284f1494f7", "name": "write", "arguments": {"path": "tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ProxyingMetadataHandlerProviderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_calcite.calcite_core;\n\nimport org.apache.calcite.jdbc.JavaTypeFactoryImpl;\nimport org.apache.calcite.plan.RelOptCluster;\nimport org.apache.calcite.plan.volcano.VolcanoPlanner;\nimport org.apache.calcite.rel.RelNode;\nimport org.apache.calcite.rel.logical.LogicalValues;\nimport org.apache.calcite.rel.metadata.BuiltInMetadata;\nimport org.apache.calcite.rel.metadata.Metadata;\nimport org.apache.calcite.rel.metadata.MetadataDef;\nimport org.apache.calcite.rel.metadata.MetadataHandler;\nimport org.apache.calcite.rel.metadata.ProxyingMetadataHandlerProvider;\nimport org.apache.calcite.rel.metadata.RelMetadataProvider;\nimport org.apache.calcite.rel.metadata.RelMetadataQuery;\nimport org.apache.calcite.rel.metadata.UnboundMetadata;\nimport org.apache.calcite.rex.RexBuilder;\n\nimport com.google.common.collect.ImmutableListMultimap;\nimport com.google.common.collect.Multimap;\n\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class ProxyingMetadataHandlerProviderTest {\n\n    @Test\n    void proxiesHandlerCallsToBoundMetadata() {\n        BuiltInMetadata.RowCount.Handler handler = new ProxyingMetadataHandlerProvider(\n                new FixedRowCountProvider(123.5))\n                .handler(BuiltInMetadata.RowCount.Handler.class);\n\n        Double rowCount = handler.getRowCount(oneRowRel(), RelMetadataQuery.instance());\n\n        assertThat(rowCount).isEqualTo(123.5);\n    }\n\n    @Test\n    void reportsMissingMetadataHandlerForRelClass() {\n        BuiltInMetadata.RowCount.Handler handler = new ProxyingMetadataHandlerProvider(\n                new MissingRowCountProvider())\n                .handler(BuiltInMetadata.RowCount.Handler.class);\n\n        RelNode rel = oneRowRel();\n        assertThatThrownBy(() -> handler.getRowCount(rel, RelMetadataQuery.instance()))\n                .isInstanceOf(IllegalArgumentException.class)\n                .hasMessageContaining(\"No handler for method\")\n                .hasMessageContaining(rel.getClass().getName());\n    }\n\n    private static RelNode oneRowRel() {\n        JavaTypeFactoryImpl typeFactory = new JavaTypeFactoryImpl();\n        RexBuilder rexBuilder = new RexBuilder(typeFactory);\n        RelOptCluster cluster = RelOptCluster.create(new VolcanoPlanner(), rexBuilder);\n        return LogicalValues.createOneRow(cluster);\n    }\n\n    private static final class FixedRowCountProvider extends BaseRowCountProvider {\n        private final double rowCount;\n\n        private FixedRowCountProvider(double rowCount) {\n            this.rowCount = rowCount;\n        }\n\n        @Override\n        public <M extends Metadata> UnboundMetadata<M> apply(\n                Class<? extends RelNode> relClass,\n                Class<? extends M> metadataClass) {\n            if (metadataClass != BuiltInMetadata.RowCount.class) {\n                return null;\n            }\n            return (rel, mq) -> metadataClass.cast(new FixedRowCount(rel, rowCount));\n        }\n    }\n\n    private static final class MissingRowCountProvider extends BaseRowCountProvider {\n        @Override\n        public <M extends Metadata> UnboundMetadata<M> apply(\n                Class<? extends RelNode> relClass,\n                Class<? extends M> metadataClass) {\n            return null;\n        }\n    }\n\n    private abstract static class BaseRowCountProvider implements RelMetadataProvider {\n        @Override\n        public <M extends Metadata> Multimap<Method, MetadataHandler<M>> handlers(MetadataDef<M> def) {\n            return ImmutableListMultimap.of();\n        }\n\n        @Override\n        public List<MetadataHandler<?>> handlers(Class<? extends MetadataHandler<?>> handlerClass) {\n            return List.of();\n        }\n    }\n\n    private static final class FixedRowCount implements BuiltInMetadata.RowCount {\n        private final RelNode rel;\n        private final double rowCount;\n\n        private FixedRowCount(RelNode rel, double rowCount) {\n            this.rel = rel;\n            this.rowCount = rowCount;\n        }\n\n        @Override\n        public RelNode rel() {\n            return rel;\n        }\n\n        @Override\n        public Double getRowCount() {\n            return rowCount;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2081, "output": 2132, "cacheRead": 34304, "cacheWrite": 0, "totalTokens": 38517, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778077560177, "responseId": "resp_039cc40c4dfe30580169fb4f78b5d08196b57b00c476477143"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_u0QXMHnJobLyecJSiy9m7pZB|fc_039cc40c4dfe30580169fb4f86e6648196b71fe5284f1494f7", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4527 bytes to tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ProxyingMetadataHandlerProviderTest.java"}], "isError": false, "timestamp": 1778077581106}]}
