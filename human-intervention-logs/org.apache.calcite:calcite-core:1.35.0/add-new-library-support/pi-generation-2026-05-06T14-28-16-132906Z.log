    RelOptCluster(RelOptPlanner planner, RelDataTypeFactory typeFactory,
        RexBuilder rexBuilder, AtomicInteger nextCorrel,
        Map<String, RelNode> mapCorrelToRel) {
      this.nextCorrel = nextCorrel;
