  package org_apache_calcite.calcite_core;
  
  import org.apache.calcite.adapter.java.ReflectiveSchema;
  import org.apache.calcite.rel.RelReferentialConstraint;
  import org.apache.calcite.schema.Function;
  import org.apache.calcite.schema.Table;
  import org.apache.calcite.schema.TranslatableTable;
  import org.apache.calcite.util.mapping.IntPair;
  import org.junit.jupiter.api.Test;
  
  import java.util.Collection;
  import java.util.List;
  import java.util.Set;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectiveSchemaTest {
  
      @Test
      void exposesPublicArrayFieldsAsTablesAndAttachesReferentialConstraints() {
          SampleSchema target = new SampleSchema();
          ReflectiveSchema schema = new ReflectiveSchema(target);
  
          Set<String> tableNames = schema.getTableNames();
  
          assertThat(tableNames).containsExactlyInAnyOrder("EMPLOYEES", "DEPARTMENTS");
          Table employees = schema.getTable("EMPLOYEES");
          assertThat(employees).isNotNull();
          assertThat(employees.getStatistic().getReferentialConstraints())
                  .containsExactly(target.EMPLOYEE_DEPARTMENT);
      }
  
      @Test
      void exposesPublicTranslatableTableMethodsAsFunctions() {
          ReflectiveSchema schema = new ReflectiveSchema(new SampleSchema());
  
          Collection<Function> functions = schema.getFunctions("projectedEmployees");
  
          assertThat(schema.getFunctionNames()).contains("projectedEmployees");
          assertThat(functions).hasSize(1);
      }
  
      public static final class SampleSchema {
          public final Employee[] EMPLOYEES = {
                  new Employee(1, 10, "Ada"),
                  new Employee(2, 20, "Grace")
          };
          public final Department[] DEPARTMENTS = {
                  new Department(10, "Engineering"),
                  new Department(20, "Research")
          };
          public final RelReferentialConstraint EMPLOYEE_DEPARTMENT = new EmployeeDepartmentConstraint();
  
          public TranslatableTable projectedEmployees() {
              throw new UnsupportedOperationException("The reflective schema only inspects this method's signature");
          }
      }
  
      public static final class Employee {
          public final int id;
          public final int departmentId;
          public final String name;
  
          Employee(int id, int departmentId, String name) {
              this.id = id;
              this.departmentId = departmentId;
              this.name = name;
          }
      }
  
      public static final class Department {
          public final int id;
          public final String name;
  
          Department(int id, String name) {
              this.id = id;
              this.name = name;
          }
      }
  
      private static final class EmployeeDepartmentConstraint implements RelReferentialConstraint {
          @Override
          public List<String> getSourceQualifiedName() {
              return List.of("EMPLOYEES");
          }
  
          @Override
          public List<String> getTargetQualifiedName() {
              return List.of("DEPARTMENTS");
          }
  
          @Override
          public List<IntPair> getColumnPairs() {
              return List.of(IntPair.of(1, 0));
          }
      }
  }
