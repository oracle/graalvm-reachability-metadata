  package org_apache_calcite.calcite_core;
  
  import java.util.AbstractMap;
  import java.util.List;
  import java.util.Map;
  import java.util.Set;
  
  import com.google.common.collect.ImmutableList;
  import org.apache.calcite.jdbc.JavaTypeFactoryImpl;
  import org.apache.calcite.plan.Convention;
  import org.apache.calcite.plan.RelOptCluster;
  import org.apache.calcite.plan.RelOptTable;
  import org.apache.calcite.plan.RelTraitSet;
  import org.apache.calcite.plan.volcano.VolcanoPlanner;
  import org.apache.calcite.rel.RelCollation;
  import org.apache.calcite.rel.RelDistribution;
  import org.apache.calcite.rel.RelDistributions;
  import org.apache.calcite.rel.RelInput;
  import org.apache.calcite.rel.RelNode;
  import org.apache.calcite.rel.core.AggregateCall;
  import org.apache.calcite.rel.externalize.RelJson;
  import org.apache.calcite.rel.logical.LogicalValues;
  import org.apache.calcite.rel.type.RelDataType;
  import org.apache.calcite.rex.RexBuilder;
  import org.apache.calcite.rex.RexLiteral;
  import org.apache.calcite.rex.RexNode;
  import org.apache.calcite.sql.type.SqlTypeName;
  import org.apache.calcite.util.ImmutableBitSet;
  import org.junit.jupiter.api.Test;
  
  import static org.apache.calcite.rel.RelCollations.EMPTY;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RelJsonTest {
  
      @Test
      void createsLogicalValuesFromSerializedInput() {
          RelJson relJson = RelJson.create();
          ValuesRelInputMap input = new ValuesRelInputMap("LogicalValues");
  
          RelNode rel = relJson.create(input);
  
          assertThat(rel).isInstanceOf(LogicalValues.class);
          assertThat(rel.getRowType().getFieldNames()).containsExactly("ZERO");
          assertThat(((LogicalValues) rel).getTuples()).isEmpty();
      }
  
      @Test
      void resolvesFullyQualifiedRelNodeClassName() {
          RelJson relJson = RelJson.create();
  
          Class<?> clazz = relJson.typeNameToClass("org.apache.calcite.rel.logical.LogicalValues");
  
          assertThat(clazz).isEqualTo(LogicalValues.class);
      }
  
      private static final class ValuesRelInputMap extends AbstractMap<String, Object>
              implements RelInput {
  
          private final Map<String, Object> values;
          private final RelOptCluster cluster;
          private final RelDataType rowType;
  
          private ValuesRelInputMap(String relType) {
              this.values = Map.of("type", relType);
              JavaTypeFactoryImpl typeFactory = new JavaTypeFactoryImpl();
              this.cluster = RelOptCluster.create(
                      new VolcanoPlanner(),
                      new RexBuilder(typeFactory));
              this.rowType = typeFactory.builder()
                      .add("ZERO", SqlTypeName.INTEGER)
                      .build();
          }
  
          @Override
          public Set<Entry<String, Object>> entrySet() {
              return values.entrySet();
          }
  
          @Override
          public Object get(Object key) {
              return values.get(key);
          }
  
          @Override
          public Object get(String tag) {
              return values.get(tag);
          }
  
          @Override
          public RelOptCluster getCluster() {
              return cluster;
          }
  
  
