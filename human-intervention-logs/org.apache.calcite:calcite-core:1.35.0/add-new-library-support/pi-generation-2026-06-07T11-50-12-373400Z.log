pache_calcite.calcite_core;\n\nimport java.util.Properties;\n\nimport org.apache.calcite.runtime.Resources;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ResourcesAnonymous1Test {\n\n    @Test\n    void createsMessageInstanceThroughResourceProxy() {\n        SampleResources resources = Resources.create(\n                \"org_apache_calcite.calcite_core.ResourcesAnonymous1Messages\",\n                SampleResources.class);\n\n        Resources.Inst greeting = resources.greeting(\"Calcite\");\n\n        assertThat(greeting.raw()).isEqualTo(\"Hello, {0}\");\n        assertThat(greeting.str()).isEqualTo(\"Hello, Calcite\");\n    }\n\n    @Test\n    void createsPropertyInstanceThroughResourceProxy() {\n        Properties properties = new Properties();\n        properties.setProperty(\"ConfigLimit\", \"42\");\n        SampleResources resources = Resources.create(properties, SampleResources.class);\n\n        Resources.IntProp limit = resources.configLimit();\n\n        assertThat(limit.isSet()).isTrue();\n        assertThat(limit.get()).isEqualTo(42);\n        assertThat(limit.defaultValue()).isEqualTo(7);\n    }\n\n    public interface SampleResources {\n        @Resources.BaseMessage(\"Hello, {0}\")\n        Resources.Inst greeting(String name);\n\n        @Resources.Default(\"7\")\n        Resources.IntProp configLimit();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1322, "output": 1299, "cacheRead": 27648, "cacheWrite": 0, "totalTokens": 30269, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780832880634, "responseId": "resp_0b3d3eb863a9286c016a255a71e1e48197bc5f5b66ec0ba045"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_nGppZEFXZ9I2pJ6rgqOyyJt4|fc_0b3d3eb863a9286c016a255a8726b0819780ee40c4e0b51474", "toolName": "write", "content": [{"type": "text", "text