arsing failures and double-check the return types, specifically ensuring they align with Resources.ExInstWithCause. I'm also thinking about how to manage the generic return types and whether I should reference upstream tests for context. It feels like I'm on the right track!\"}]}"}, {"type": "toolCall", "id": "call_Bu3BpkKjwq5Iig5mASYsVdTv|fc_00a40f04aa01e7b40169f184608b18819da8078711be5f0e55", "name": "write", "arguments": {"path": "tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ResourcesInnerExInstWithCauseTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_calcite.calcite_core;\n\nimport org.apache.calcite.runtime.CalciteContextException;\nimport org.apache.calcite.runtime.CalciteResource;\nimport org.apache.calcite.runtime.Resources;\nimport org.apache.calcite.sql.parser.impl.ParseException;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ResourcesInnerExInstWithCauseTest {\n    @Test\n    public void createsExceptionWithCauseConstructor() {\n        CalciteResource resource = Resources.create(CalciteResource.class);\n        IllegalArgumentException cause = new IllegalArgumentException(\"invalid SQL fragment\");\n\n        CalciteContextException exception = resource.validatorContextPoint(3, 15).ex(cause);\n\n        assertThat(exception)\n                .hasMessage(\"line 3, column 15\")\n                .hasCauseSameInstanceAs(cause);\n        assertThat(exception.getPosLine()).isZero();\n        assertThat(exception.getPosColumn()).isZero();\n    }\n\n    @Test\n    public void createsExceptionWithMessageConstructorThenInitializesCause() {\n        ParserResourceMessages messages = Resources.create(ParserResourceMessages.class);\n        IllegalStateException cause = new IllegalStateException(\"parser stopped\");\n\n        ParseException exception = messages.parseFailed(\"select * from\").ex(cause);\n\n        assertThat(exception)\n                .hasMessage(\"Could not parse select * from\")\n                .hasCauseSameInstanceAs(cause);\n    }\n\n    public interface ParserResourceMessages {\n        @Resources.BaseMessage(\"Could not parse {0}\")\n        Resources.ExInstWithCause<ParseException> parseFailed(String sql);\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ResourcesInnerExInstWithCauseTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_calcite.calcite_core;\\n\\nimport org.apache.calcite.runtime.CalciteContextException;\\nimport org.apache.calcite.runtime.CalciteResource;\\nimport org.apache.calcite.runtime.Resources;\\nimport org.apache.calcite.sql.parser.impl.ParseException;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ResourcesInnerExInstWithCauseTest {\\n    @Test\\n    public void createsExceptionWithCauseConstructor() {\\n        CalciteResource resource = Resources.create(CalciteResource.class);\\n        IllegalArgumentException cause = new IllegalArgumentException(\\\"invalid SQL fragment\\\");\\n\\n        CalciteContextException exception = resource.validatorContextPoint(3, 15).ex(cause);\\n\\n        assertThat(exception)\\n                .hasMessage(\\\"line 3, column 15\\\")\\n                .hasCauseSameInstanceAs(cause);\\n        assertThat(exception.getPosLine()).isZero();\\n        assertThat(exception.getPosColumn()).isZero();\\n    }\\n\\n    @Test\\n    public void createsExceptionWithMessageConstru