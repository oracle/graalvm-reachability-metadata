ithCause<CauseAwareException> causeAwareFailure(String component);\n\n        @Resources.BaseMessage(\"String-only failure for {0}\")\n        Resources.ExInstWithCause<StringOnlyException> stringOnlyFailure(String component);\n    }\n\n    public static class CauseAwareException extends Exception {\n        public CauseAwareException(String message, Throwable cause) {\n            super(message, cause);\n        }\n    }\n\n    public static class StringOnlyException extends Exception {\n        public StringOnlyException(String message) {\n            super(message);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 9299, "output": 943, "cacheRead": 4608, "cacheWrite": 0, "totalTokens": 14850, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777423728729, "responseId": "resp_038f82c6c46643880169f155710ee08191af3d7e8eb8119ef6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_MHoLzTKxFpOU7hzTJBYaLTdr|fc_038f82c6c46643880169f15576b8f88191ba53f61f8a6da8a2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2061 bytes to tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/ResourcesInnerExInstWithCauseTest.java"}], "isError": false, "timestamp": 1777423737547}]}
