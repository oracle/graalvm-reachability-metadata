  package org_apache_calcite.calcite_core;
  
  import java.util.Properties;
  
  import org.apache.calcite.runtime.CalciteResource;
  import org.apache.calcite.runtime.Resources;
  import org.apache.calcite.util.SaffronProperties;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @SuppressWarnings("deprecation")
  public class ResourcesAnonymous1Test {
  
      @Test
      void createsMessageInstanceThroughResourceProxy() {
          CalciteResource resources = Resources.create(CalciteResource.class);
  
          Resources.Inst context = resources.parserContext(3, 4);
  
          assertThat(context.raw()).isEqualTo("line {0,number,#}, column {1,number,#}");
      }
  
      @Test
      void createsPropertyInstanceThroughResourceProxy() {
          Properties properties = new Properties();
          properties.setProperty("saffron.metadata.handler.cache.maximum.size", "42");
          SaffronProperties resources = Resources.create(properties, SaffronProperties.class);
  
          Resources.IntProp maximumSize = resources.metadataHandlerCacheMaximumSize();
  
          assertThat(maximumSize.isSet()).isTrue();
          assertThat(maximumSize.get()).isEqualTo(42);
          assertThat(maximumSize.defaultValue()).isEqualTo(1000);
      }
  }
