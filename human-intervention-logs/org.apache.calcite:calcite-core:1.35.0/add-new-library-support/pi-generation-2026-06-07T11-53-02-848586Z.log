  package org_apache_calcite.calcite_core;
  
  import org.apache.calcite.runtime.Resources;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ResourcesInnerExInstWithCauseTest {
  
      @Test
      void createsExceptionWithCauseConstructor() {
          ResourceMessages resources = Resources.create(ResourceMessages.class);
          IllegalStateException cause = new IllegalStateException("root cause");
  
          ExceptionWithCauseConstructor exception = resources.twoArgumentException("alpha").ex(cause);
  
          assertThat(exception)
                  .hasMessage("two argument alpha")
                  .hasCause(cause);
      }
  
      @Test
      void createsExceptionWithStringConstructorAndInitializesCause() {
          ResourceMessages resources = Resources.create(ResourceMessages.class);
          IllegalArgumentException cause = new IllegalArgumentException("root cause");
  
          Resources.ExInstWithCause<ExceptionWithStringConstructor> instance =
                  resources.stringArgumentException("beta");
          ExceptionWithStringConstructor exception = instance.ex(cause);
  
          assertThat(exception)
                  .hasMessage("string argument beta")
                  .hasCause(cause);
      }
  
      public interface ResourceMessages {
          @Resources.BaseMessage("two argument {0}")
          Resources.ExInstWithCause<ExceptionWithCauseConstructor> twoArgumentException(String value);
  
          @Resources.BaseMessage("string argument {0}")
          Resources.ExInstWithCause<ExceptionWithStringConstructor> stringArgumentException(
                  String value);
      }
  
      public static class ExceptionWithCauseConstructor extends Exception {
          public ExceptionWithCauseConstructor(String message, Throwable cause) {
              super(message, cause);
          }
      }
  
      public static class ExceptionWithStringConstructor extends Exception {
          public ExceptionWithStringConstructor(String message) {
              super(message);
          }
      }
  }
