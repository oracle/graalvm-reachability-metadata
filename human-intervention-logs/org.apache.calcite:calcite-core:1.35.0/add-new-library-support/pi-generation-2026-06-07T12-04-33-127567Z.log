    static boolean classHasPublicZeroArgsConstructor(Class<?> clazz) {
      for (Constructor<?> constructor : clazz.getConstructors()) {
        if (constructor.getParameterCount() == 0
            && Modifier.isPublic(constructor.getModifiers())) {
          return true;
        }
      }
      return false;
    }
  
    /**
