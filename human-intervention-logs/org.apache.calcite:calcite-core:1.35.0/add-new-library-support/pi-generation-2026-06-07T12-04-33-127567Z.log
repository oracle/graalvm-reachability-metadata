  public class RelJsonTest {
  
      @Test
      void createsLogicalValuesFromSerializedInput() {
          RelJson relJson = RelJson.create();
          ValuesRelInputMap input = new ValuesRelInputMap("LogicalValues");
  
          RelNode rel = relJson.create(input);
  
          assertThat(rel).isInstanceOf(LogicalValues.class);
          assertThat(rel.getRowType().getFieldNames()).containsExactly("ZERO");
          assertThat(((LogicalValues) rel).getTuples()).isEmpty();
      }
  
