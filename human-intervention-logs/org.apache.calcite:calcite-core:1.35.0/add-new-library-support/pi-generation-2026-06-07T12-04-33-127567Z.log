      void resolvesFullyQualifiedRelNodeClassName() {
          RelJson relJson = RelJson.create();
  
          Class<?> clazz = relJson.typeNameToClass("org.apache.calcite.rel.logical.LogicalValues");
  
          assertThat(clazz).isEqualTo(LogicalValues.class);
  
