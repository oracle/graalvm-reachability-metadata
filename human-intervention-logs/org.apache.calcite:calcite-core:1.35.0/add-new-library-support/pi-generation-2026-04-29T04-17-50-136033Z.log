apache_calcite/calcite_core/EnumerableInterpretableTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_calcite.calcite_core;\n\nimport org.apache.calcite.DataContexts;\nimport org.apache.calcite.adapter.enumerable.EnumerableInterpretable;\nimport org.apache.calcite.adapter.enumerable.EnumerableRel;\nimport org.apache.calcite.adapter.enumerable.EnumerableValues;\nimport org.apache.calcite.jdbc.JavaTypeFactoryImpl;\nimport org.apache.calcite.linq4j.Enumerator;\nimport org.apache.calcite.plan.RelOptCluster;\nimport org.apache.calcite.plan.volcano.VolcanoPlanner;\nimport org.apache.calcite.rel.type.RelDataType;\nimport org.apache.calcite.rel.type.RelDataTypeField;\nimport org.apache.calcite.rex.RexBuilder;\nimport org.apache.calcite.rex.RexLiteral;\nimport org.apache.calcite.runtime.ArrayBindable;\nimport org.apache.calcite.runtime.Bindable;\nimport org.apache.calcite.sql.type.SqlTypeName;\n\nimport com.google.common.collect.ImmutableList;\n\nimport org.junit.jupiter.api.Test;\n\nimport java.math.BigDecimal;\nimport java.util.Collections;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnumerableInterpretableTest {\n    @Test\n    public void compilesEnumerableValuesToBindableAndReadsRows() {\n        RelOptCluster cluster = cluster();\n        RelDataType rowType = rowType(cluster);\n        EnumerableValues values = EnumerableValues.create(cluster, rowType, rows(cluster, rowType));\n\n        Bindable bindable = EnumerableInterpretable.toBindable(\n            Collections.emptyMap(), null, values, EnumerableRel.Prefer.ARRAY);\n\n        assertThat(bindable).isInstanceOf(ArrayBindable.class);\n        Enumerator<Object[]> enumerator = ((ArrayBindable) bindable).bind(DataContexts.EMPTY).enumerator();\n        try {\n            assertThat(enumerator.moveNext()).isTrue();\n            assertThat(enumerator.current()).containsExactly(1, \"Ada\");\n            assertThat(enumerator.moveNext()).isTrue();\n            assertThat(enumerator.current()).containsExactly(2, \"Grace\");\n            assertThat(enumerator.moveNext()).isFalse();\n        } finally {\n            enumerator.close();\n        }\n    }\n\n    private static RelOptCluster cluster() {\n        JavaTypeFactoryImpl typeFactory = new JavaTypeFactoryImpl();\n        RexBuilder rexBuilder = new RexBuilder(typeFactory);\n        return RelOptCluster.create(new VolcanoPlanner(), rexBuilder);\n    }\n\n    private static RelDataType rowType(RelOptCluster cluster) {\n        return cluster.getTypeFactory().builder()\n            .add(\"ID\", SqlTypeName.INTEGER)\n            .add(\"NAME\", SqlTypeName.VARCHAR)\n            .build();\n    }\n\n    private static ImmutableList<ImmutableList<RexLiteral>> rows(RelOptCluster cluster,\n        RelDataType rowType) {\n        List<RelDataTypeField> fields = rowType.getFieldList();\n        RexBuilder rexBuilder = cluster.getRexBuilder();\n        return ImmutableList.of(\n            row(rexBuilder, fields, 1, \"Ada\"),\n            row(rexBuilder, fields, 2, \"Grace\"));\n    }\n\n    private static ImmutableList<RexLiteral> row(RexBuilder rexBuilder,\n        List<RelDataTypeField> fields, int id, String name) {\n        return ImmutableList.of(\n            rexBuilder.makeExactLiteral(BigDecimal.valueOf(id), fields.get(0).getType()),\n            (RexLiteral) rexBuilder.makeLiteral(name, fields.get(1).getType(), true));\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/EnumerableInterpretableTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_calcite.calcite_core;\\n\\nimport org.apache.calcite.DataContexts;\\nimport org.apache.calcite.adapter.enumerable.EnumerableInterpretable;\\nimport org.apache.calcite.adapter.enumerable.EnumerableRel;\\nimport org.apache.calcite.adapter.enumerable.EnumerableValues;\\nimport org.apache.calcite.jdbc.JavaTypeFactoryImpl;\\nimport org.apache.calcite.linq4j.Enumerator;\\nimport org.apache.calcite.plan.RelOptCluster;\\nimport org.apache.calcite.plan.volcano.VolcanoPlanner;\\nimport org.apache.calcite.rel.type.RelDataType;\\nimport org.apache.calcite.rel.type.RelDataTypeField;\\nimport org.apache.calcite.rex.RexBuilder;\\nimport org.apache.calcite.rex.RexLiteral;\\nimport org.apache.calcite.runtime.ArrayBindable;\\nimport org.apache.calcite.runtime.Bindable;\\nimport org.apache.calcite.sql.type.SqlTypeName;\\n\\nimport com.google.common.collect.ImmutableList;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.math.BigDecimal;\\nimport java.util.Collections;\\nimport java.util.List;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class EnumerableInterpretableTest {\\n    @Test\\n    public void compilesEnumerableValuesToBindableAndReadsRows() {\\n        RelOptCluster cluster = cluster();\\n        RelDataType rowType = rowType(cluster);\\n        EnumerableValues values = EnumerableValues.create(cluster, rowType, rows(cluster, rowType));\\n\\n        Bindable bindable = EnumerableInterpretable.toBindable(\\n            Collections.emptyMap(), null, values, EnumerableRel.Prefer.ARRAY);\\n\\n        assertThat(bindable).isInstanceOf(ArrayBindable.class);\\n        Enumerator<Object[]> enumerator = ((ArrayBindable) bindable).bind(DataContexts.EMPTY).enumerator();\\n        try {\\n            assertThat(enumerator.moveNext()).isTrue();\\n            assertThat(enumerator.current()).containsExactly(1, \\\"Ada\\\");\\n            assertThat(enumerator.moveNext()).isTrue();\\n            assertThat(enumerator.current()).containsExactly(2, \\\"Grace\\\");\\n            assertThat(enumerator.moveNext()).isFalse();\\n        } finally {\\n            enumerator.close();\\n        }\\n    }\\n\\n    private static RelOptCluster cluster() {\\n        JavaTypeFactoryImpl typeFactory = new JavaTypeFactoryImpl();\\n        RexBuilder rexBuilder = new RexBuilder(typeFactory);\\n        return RelOptCluster.create(new VolcanoPlanner(), rexBuilder);\\n    }\\n\\n    private static RelDataType rowType(RelOptCluster cluster) {\\n        return cluster.getTypeFactory().builder()\\n            .add(\\\"ID\\\", SqlTypeName.INTEGER)\\n            .add(\\\"NAME\\\", SqlTypeName.VARCHAR)\\n            .build();\\n    }\\n\\n    private static ImmutableList<ImmutableList<RexLiteral>> rows(RelOptCluster cluster,\\n        RelDataType rowType) {\\n        List<RelDataTypeField> fields = rowType.getFieldList();\\n        RexBuilder rexBuilder = cluster.getRexBuilder();\\n        return ImmutableList.of(\\n            row(rexBuilder, fields, 1, \\\"Ada\\\"),\\n            row(rexBuilder, fields, 2, \\\"Grace\\\"));\\n    }\\n\\n    private static ImmutableList<RexLiteral> row(RexBuilder rexBuilder,\\n        List<RelDataTypeField> fields, int id, String name) {\\n        return ImmutableList.of(\\n            rexBuilder.makeExactLiteral(BigDecimal.valueOf(id), fields.get(0).getType()),\\n            (RexLiteral) rexBuilder.makeLiteral(name, fields.get(1).getType(), true));\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1152, "output": 1310, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 33182, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777436119688, "responseId": "resp_08cfcb35ac859d750169f185d84448819ca0cdfc9d4a49efc6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_HzLLbhx9dsJSJDLXEwjOs07h|fc_08cfcb35ac859d750169f185defa60