     * @return new literal
     */
    public RexLiteral makeApproxLiteral(@Nullable BigDecimal bd, RelDataType type) {
      assert SqlTypeFamily.APPROXIMATE_NUMERIC.getTypeNames().contains(
          type.getSqlTypeName());
      return makeLiteral(bd, type, SqlTypeName.DOUBLE);
    }
  
