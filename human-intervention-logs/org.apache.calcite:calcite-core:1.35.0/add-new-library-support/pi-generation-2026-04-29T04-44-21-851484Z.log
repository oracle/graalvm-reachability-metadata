          .addRuleInstance(CoreRules.AGGREGATE_REDUCE_FUNCTIONS)
          .build();
      final HepPlanner planner = new HepPlanner(hepProgram);
      planner.setRoot(rootRel);
      rootRel = planner.findBestExp();
      return rootRel;
    }
  
