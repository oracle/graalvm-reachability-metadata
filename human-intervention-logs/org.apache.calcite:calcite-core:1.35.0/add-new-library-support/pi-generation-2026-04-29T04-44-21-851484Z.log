     }\n\n        @Override\n        public Enumerable<Object[]> scan(DataContext root) {\n            return Linq4j.asEnumerable(Collections.singletonList(new Object[] {filter}));\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777437711190}]}
