      final Class<?>[] types = method.getParameterTypes();\n      for (int i = 0; i < types.length; i++) {\n        add(types[i], ReflectUtil.getParameterName(method, i),\n            ReflectUtil.isParameterOptional(method, i));\n      }\n      return this;\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1777440408034}]}
