[tool-call] delta {"path":"tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/AggregateNodeInnerUdaAccumulatorFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_calcite.calcite_core;\n\nimport org.apache.calcite.DataContext;\nimport org.apache.calcite.adapter.java.ReflectiveSchema;\nimport org.apache.calcite.jdbc.CalciteConnection;\nimport org.apache.calcite.jdbc.Driver;\nimport org.apache.calcite.runtime.Hook;\nimport org.apache.calcite.schema.FunctionContext;\nimport org.apache.calcite.schema.SchemaPlus;\nimport org.apache.calcite.schema.impl.AggregateFunctionImpl;\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Connection;\nimport java.sql.ResultSet;\nimport java.sql.Statement;\nimport java.util.Properties;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AggregateNodeInnerUdaAccumulatorFactoryTest {\n\n    @Test\n    void bindableAggregateCreatesUserAggregateWithDefaultConstructor() throws Exception {\n        try (Hook.Closeable ignored = Hook.ENABLE_BINDABLE.addThread(Hook.propertyJ(true));\n             Connection connection = new Driver().connect(\"jdbc:calcite:\", new Properties())) {\n            CalciteConnection calciteConnection = connection.unwrap(CalciteConnection.class);\n            SchemaPlus rootSchema = calciteConnection.getRootSchema();\n            rootSchema.add(\"DATA\", new ReflectiveSchema(new DataSchema()));\n            rootSchema.add(\"TRACKING_SUM\", AggregateFunctionImpl.create(TrackingSum.class));\n\n            Object sum = scalar(connection,\n                    \"select TRACKING_SUM(\\\"amount\\\") from \\\"DATA\\\".\\\"entries\\\"\");\n\n            assertThat(sum).isEqualTo(15);\n        }\n    }\n\n    @Test\n    void bindableAggregateCreatesUserAggregateWithFunctionContextConstructor() throws Exception {\n        try (Hook.Closeable ignored = Hook.ENABLE_BINDABLE.addThread(Hook.propertyJ(true));\n             Connection connection = new Driver().connect(\"jdbc:calcite:\", new Properties())) {\n            CalciteConnection calciteConnection = connection.unwrap(CalciteConnection.class);\n            SchemaPlus rootSchema = calciteConnection.getRootSchema();\n            rootSchema.add(\"DATA\", new ReflectiveSchema(new DataSchema()));\n            rootSchema.add(\"CONTEXT_SUM\", AggregateFunctionImpl.create(ContextAwareSum.class));\n\n            Object sum = scalar(connection,\n                    \"select CONTEXT_SUM(\\\"amount\\\") from \\\"DATA\\\".\\\"entries\\\"\");\n\n            assertThat(sum).isEqualTo(18);\n        }\n    }\n\n    private static Object scalar(Connection connection, String sql) throws Exception {\n        try (Statement statement = connection.createStatement();\n             ResultSet resultSet = statement.executeQuery(sql)) {\n            assertThat(resultSet.next()).isTrue();\n            Object value = resultSet.getObject(1);\n            assertThat(resultSet.next()).isFalse();\n            return value;\n        }\n    }\n\n    public static final class DataSchema {\n        public final Entry[] entries = {\n                new Entry(4),\n                new Entry(5),\n                new Entry(6)\n        };\n    }\n\n    public static final class Entry {\n        public final int amount;\n\n        Entry(int amount) {\n            this.amount = amount;\n        }\n    }\n\n    public static final class TrackingSum {\n        public TrackingSum() {\n        }\n\n        public int init() {\n            return 0;\n        }\n\n        public int add(int accumulator, int value) {\n            return accumulator + value;\n        }\n\n        public int result(int accumulator) {\n            return accumulator;\n        }\n    }\n\n    public static final class ContextAwareSum {\n        private final int increment;\n\n        public ContextAwareSum(FunctionContext context) {\n            DataContext dataContext = context.getDataContext();\n            this.increment = dataContext == null ? 1 : 1;\n        }\n\n        public int init() {\n            return 0;\n        }\n\n        public int add(int accumulator, int value) {\n            return accumulator + value + increment;\n        }\n\n        public int result(int accumulator) {\n            return accumulator;\n        }\n    }\n}\n"}
