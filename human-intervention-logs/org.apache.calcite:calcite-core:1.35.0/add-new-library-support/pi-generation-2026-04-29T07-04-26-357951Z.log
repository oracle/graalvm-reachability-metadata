java/org_apache_calcite/calcite_core/RecordEnumeratorCursorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_calcite.calcite_core;\n\nimport org.apache.calcite.avatica.ColumnMetaData;\nimport org.apache.calcite.avatica.util.Cursor;\nimport org.apache.calcite.linq4j.Linq4j;\nimport org.apache.calcite.runtime.RecordEnumeratorCursor;\n\nimport org.junit.jupiter.api.Test;\n\nimport java.sql.Types;\nimport java.util.Calendar;\nimport java.util.Collections;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RecordEnumeratorCursorTest {\n    @Test\n    void readsPublicFieldFromEnumeratorRecord() throws Exception {\n        try (RecordEnumeratorCursor<RecordRow> cursor = new RecordEnumeratorCursor<>(\n                Linq4j.singletonEnumerator(new RecordRow(\"calcite\")), RecordRow.class)) {\n            List<Cursor.Accessor> accessors = cursor.createAccessors(\n                    Collections.singletonList(stringColumn()), Calendar.getInstance(), null);\n\n            assertThat(accessors).hasSize(1);\n            assertThat(cursor.next()).isTrue();\n            assertThat(accessors.get(0).getString()).isEqualTo(\"calcite\");\n            assertThat(accessors.get(0).getObject()).isEqualTo(\"calcite\");\n            assertThat(cursor.next()).isFalse();\n        }\n    }\n\n    private static ColumnMetaData stringColumn() {\n        return ColumnMetaData.dummy(\n                ColumnMetaData.scalar(Types.VARCHAR, \"VARCHAR\", ColumnMetaData.Rep.STRING), true);\n    }\n\n    public static final class RecordRow {\n        public final String name;\n\n        RecordRow(String name) {\n            this.name = name;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/RecordEnumeratorCursorTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_calcite.calcite_core;\\n\\nimport org.apache.calcite.avatica.ColumnMetaData;\\nimport org.apache.calcite.avatica.util.Cursor;\\nimport org.apache.calcite.linq4j.Linq4j;\\nimport org.apache.calcite.runtime.RecordEnumeratorCursor;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.sql.Types;\\nimport java.util.Calendar;\\nimport java.util.Collections;\\nimport java.util.List;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class RecordEnumeratorCursorTest {\\n    @Test\\n    void readsPublicFieldFromEnumeratorRecord() throws Exception {\\n        try (RecordEnumeratorCursor<RecordRow> cursor = new RecordEnumeratorCursor<>(\\n                Linq4j.singletonEnumerator(new RecordRow(\\\"calcite\\\")), RecordRow.class)) {\\n            List<Cursor.Accessor> accessors = cursor.createAccessors(\\n                    Collections.singletonList(stringColumn()), Calendar.getInstance(), null);\\n\\n            assertThat(accessors).hasSize(1);\\n            assertThat(cursor.next()).isTrue();\\n            assertThat(accessors.get(0).getString()).isEqualTo(\\\"calcite\\\");\\n            assertThat(accessors.get(0).getObject()).isEqualTo(\\\"calcite\\\");\\n            assertThat(cursor.next()).isFalse();\\n        }\\n    }\\n\\n    private static ColumnMetaData stringColumn() {\\n        return ColumnMetaData.dummy(\\n                ColumnMetaData.scalar(Types.VARCHAR, \\\"VARCHAR\\\", ColumnMetaData.Rep.STRING), true);\\n    }\\n\\n    public static final class RecordRow {\\n        public final String name;\\n\\n        RecordRow(String name) {\\n            this.name = name;\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-response