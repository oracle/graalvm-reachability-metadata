      RexCastCallBinding(RelDataTypeFactory typeFactory,
          SqlOperator sqlOperator, List<? extends RexNode> operands,
          RelDataType type,
          List<RelCollation> inputCollations) {
        super(typeFactory, sqlOperator, operands, inputCollations);
