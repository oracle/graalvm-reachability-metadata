        RexCall call, @Nullable RexProgram program,
        List<RelCollation> inputCollations) {
      final List<RexNode> operands =
          program != null ? program.expandList(call.getOperands())
              : call.getOperands();
      switch (call.getKind()) {
      case CAST:
