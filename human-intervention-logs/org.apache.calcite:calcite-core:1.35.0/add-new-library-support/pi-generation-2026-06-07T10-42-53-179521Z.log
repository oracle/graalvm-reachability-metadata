  package org_apache_calcite.calcite_core;
  
  import java.lang.reflect.Method;
  import java.util.List;
  
  import com.google.common.collect.ImmutableList;
  import com.google.common.collect.ImmutableMultimap;
  import com.google.common.collect.Multimap;
  import org.apache.calcite.jdbc.JavaTypeFactoryImpl;
  import org.apache.calcite.plan.Convention;
  import org.apache.calcite.plan.RelOptCluster;
  import org.apache.calcite.plan.volcano.VolcanoPlanner;
  import org.apache.calcite.rel.RelNode;
  import org.apache.calcite.rel.logical.LogicalValues;
  import org.apache.calcite.rel.metadata.BuiltInMetadata;
  import org.apache.calcite.rel.metadata.Metadata;
  import org.apache.calcite.rel.metadata.MetadataDef;
  import org.apache.calcite.rel.metadata.MetadataHandler;
  import org.apache.calcite.rel.metadata.ProxyingMetadataHandlerProvider;
  import org.apache.calcite.rel.metadata.RelMetadataProvider;
  import org.apache.calcite.rel.metadata.RelMetadataQuery;
  import org.apache.calcite.rel.metadata.UnboundMetadata;
  import org.apache.calcite.rel.type.RelDataType;
  import org.apache.calcite.rex.RexBuilder;
  import org.apache.calcite.rex.RexLiteral;
  import org.apache.calcite.sql.type.SqlTypeName;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class ProxyingMetadataHandlerProviderTest {
  
      @Test
      void invokesBoundMetadataThroughProxiedHandler() {
          RelNode rel = valuesRel();
          ProxyingMetadataHandlerProvider handlerProvider =
                  new ProxyingMetadataHandlerProvider(new RowCountProvider(123.0));
          RelMetadataQuery mq = new RelMetadataQuery(handlerProvider);
  
          assertThat(mq.getRowCount(rel)).isEqualTo(123.0);
      }
  
      @Test
      void reportsHandlerMethodWhenProviderHasNoMetadataForRel() {
          RelNode rel = valuesRel();
          ProxyingMetadataHandlerProvider handlerProvider =
                  new ProxyingMetadataHandlerProvider(new RowCountProvider(null));
          RelMetadataQuery mq = new RelMetadataQuery(handlerProvider);
  
          assertThatThrownBy(() -> mq.getRowCount(rel))
                  .isInstanceOf(IllegalArgumentException.class)
                  .hasMessageContaining("No handler for method")
                  .hasMessageContaining("LogicalValues");
      }
  
      private static RelNode valuesRel() {
          JavaTypeFactoryImpl typeFactory = new JavaTypeFactoryImpl();
          RelOptCluster cluster = RelOptCluster.create(
                  new VolcanoPlanner(),
                  new RexBuilder(typeFactory));
          RelDataType rowType = typeFactory.builder()
                  .add("ZERO", SqlTypeName.INTEGER)
                  .build();
          return new LogicalValues(
                  cluster,
                  cluster.traitSetOf(Convention.NONE),
                  rowType,
                  ImmutableList.<ImmutableList<RexLiteral>>of());
      }
  
      private static final class RowCountProvider implements RelMetadataProvider {
  
          private final Double rowCount;
  
          private RowCountProvider(Double rowCount) {
              this.rowCount = rowCount;
          }
  
          @Override
          @Deprecated
          @SuppressWarnings("unchecked")
          public <M extends Metadata> UnboundMetadata<M> apply(
                  Class<? extends RelNode> relClass,
                  Class<? extends M> metadataClass) {
              if (rowCount == null || metadataClass != BuiltInMetadata.RowCount.class) {
                  return null;
              }
              return (rel, mq) -> (M) new FixedRowCountMetadata(rel, rowCount);
          }
  
          @Override
          @Deprecated
          public <M extends Metadata> Multimap<Method, MetadataHandler<M>> handlers(
                  MetadataDef<M> def) {
              return ImmutableMultimap.of();
          }
  
          @Override
          public List<MetadataHandler<?>> handlers(
                  Class<? extends MetadataHandler<?>> handlerClass) {
              return List.of();
          }
      }
  
      private static final class FixedRowCountMetadata implements BuiltInMetadata.RowCount {
  
          private final RelNode rel;
          private final Double rowCount;
  
          private FixedRowCountMetadata(RelNode rel, Double rowCount) {
              this.rel = rel;
              this.rowCount = rowCount;
          }
  
          @Override
          public RelNode rel() {
              return rel;
          }
  
          @Override
          public Double getRowCount() {
              return rowCount;
          }
      }
  }
