rn shuttle.visit(this);\n  }\n\n  @Override public RelNode withHints(List<RelHint> hintList) {\n    return new LogicalValues(getCluster(), traitSet, hintList, getRowType(), tuples);\n  }\n}\n"}], "isError": false, "timestamp": 1780828665655}}
