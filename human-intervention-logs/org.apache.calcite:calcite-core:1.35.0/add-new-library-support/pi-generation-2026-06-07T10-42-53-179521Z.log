.calcite.plan.RelOptTable;\nimport org.apache.calcite.plan.RelTraitSet;\nimport org.apache.calcite.plan.volcano.VolcanoPlanner;\nimport org.apache.calcite.rel.RelCollation;\nimport org.apache.calcite.rel.RelDistribution;\nimport org.apache.calcite.rel.RelDistributions;\nimport org.apache.calcite.rel.RelInput;\nimport org.apache.calcite.rel.RelNode;\nimport org.apache.calcite.rel.core.AggregateCall;\nimport org.apache.calcite.rel.externalize.RelJson;\nimport org.apache.calcite.rel.logical.LogicalValues;\nimport org.apache.calcite.rel.type.RelDataType;\nimport org.apache.calcite.rex.RexBuilder;\nimport org.apache.calcite.rex.RexLiteral;\nimport org.apache.calcite.rex.RexNode;\nimport org.apache.calcite.sql.type.SqlTypeName;\nimport org.apache.calcite.util.ImmutableBitSet;\nimport org.junit.jupiter.api.Test;\n\nimport static org.apache.calcite.rel.RelCollations.EMPTY;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RelJsonTest {\n\n    @Test\n    void createsLogicalValuesFromSerializedInput() {\n        RelJson relJson = RelJson.create();\n        ValuesRelInputMap input = new ValuesRelInputMap(\"LogicalValues\");\n\n        RelNode rel = relJson.create(input);\n\n        assertThat(rel).isInstanceOf(LogicalValues.class);\n        assertThat(rel.getRowType().getFieldNames()).containsExactly(\"ZERO\");\n        assertThat(((LogicalValues) rel).getTuples()).isEmpty();\n    }\n\n    @Test\n    void resolvesFullyQualifiedRelNodeClassName() {\n        RelJson relJson = RelJson.create();\n\n        Class<?> clazz = relJson.typeNameToClass(\"org.apache.calcite.rel.logical.LogicalValues\");\n\n        assertThat(clazz).isEqualTo(LogicalValues.class);\n    }\n\n    private static final class ValuesRelInputMap extends AbstractMap<String, Object>\n            implements RelInput {\n\n        private final Map<String, Object> values;\n        private final RelOptCluster cluster;\n        private final RelDataType rowType;\n\n        private ValuesRelInputMap(String relType) {\n            this.values = Map.of(\"type\", relType);\n            JavaTypeFactoryImpl typeFactory = new JavaTypeFactoryImpl();\n            this.cluster = RelOptCluster.create(\n                    new VolcanoPlanner(),\n                    new RexBuilder(typeFactory));\n            this.rowType = typeFactory.builder()\n                    .add(\"ZERO\", SqlTypeName.INTEGER)\n                    .build();\n        }\n\n        @Override\n        public Set<Entry<String, Object>> entrySet() {\n            return values.entrySet();\n        }\n\n        @Override\n        public Object get(Object key) {\n            return values.get(key);\n        }\n\n        @Override\n        public RelOptCluster getCluster() {\n            return cluster;\n        }\n\n        @Override\n        public RelTraitSet getTraitSet() {\n            return cluster.traitSetOf(Convention.NONE);\n        }\n\n        @Override\n        public RelDataType getRowType(String tag) {\n            return rowType;\n        }\n\n        @Override\n        public ImmutableList<ImmutableList<RexLiteral>> getTuples(String tag) {\n            return ImmutableList.of();\n        }\n\n        @Override\n        public RelOptTable getTable(String table) {\n            throw new UnsupportedOperationException(\"Tables are not used by LogicalValues\");\n        }\n\n        @Override\n        public RelNode getInput() {\n            throw new UnsupportedOperationException(\"Inputs are not used by LogicalValues\");\n        }\n\n        @Override\n        public List<RelNode> getInputs() {\n            return List.of();\n        }\n\n        @Override\n        public RexNode getExpression(String tag) {\n            throw new UnsupportedOperationException(\"Expressions are not used by LogicalValues\");\n        }\n\n        @Override\n        public ImmutableBitSet getBitSet(String tag) {\n            throw new UnsupportedOperationException(\"Bit sets are not used by LogicalValues\");\n        }\n\n        @Override\n        public List<ImmutableBitSet> getBitSetList(String tag) {\n            throw new UnsupportedOperationException(\"Bit set lists are not used by LogicalValues\");\n        }\n\n        @Override\n        public List<AggregateCall> getAggregateCalls(String tag) {\n            throw new UnsupportedOperationException(\"Aggregate calls are not used by LogicalValues\");\n        }\n\n        @Override\n        public String getString(String tag) {\n            Object value = values.get(tag);\n            return value instanceof String ? (String) value : null;\n        }\n\n        @Override\n        public float getFloat(String tag) {\n            throw new UnsupportedOperationException(\"Floats are not used by LogicalValues\");\n        }\n\n        @Override\n        public <E extends Enum<E>> E getEnum(String tag, Class<E> enumClass) {\n            throw new UnsupportedOperationException(\"Enums are not used by LogicalValues\");\n        }\n\n        @Override\n        public List<RexNode> getExpressionList(String tag) {\n            throw new UnsupportedOperationException(\"Expression lists are not used by LogicalValues\");\n        }\n\n        @Override\n        public List<String> getStringList(String tag) {\n            throw new UnsupportedOperationException(\"String lists are not used by LogicalValues\");\n        }\n\n        @Override\n        public List<Integer> getIntegerList(String tag) {\n            throw new UnsupportedOperationException(\"Integer lists are not used by LogicalValues\");\n        }\n\n        @Override\n        public List<List<Integer>> getIntegerListList(String tag) {\n            throw new UnsupportedOperationException(\"Integer list lists are not used by LogicalValues\");\n        }\n\n        @Override\n        public RelDataType getRowType(String expressionsTag, String fieldsTag) {\n            throw new UnsupportedOperationException(\"Expression row types are not used by LogicalValues\");\n        }\n\n        @Override\n        public RelCollation getCollation() {\n            return EMPTY;\n        }\n\n        @Override\n        public RelDistribution getDistribution() {\n            return RelDistributions.SINGLETON;\n        }\n\n        @Override\n        public boolean getBoolean(String tag, boolean defaultValue) {\n            return defaultValue;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1519, "output": 3071, "cacheRead": 28672, "cacheWrite": 0, "totalTokens": 33262, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780829092403, "responseId": "resp_0da3f805d897ce7e016a254ba4e59c81969d38f3702dc81c45"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Y3YVl1OwdMEMReJMGuLVxoFr|fc_0da3f805d897ce7e016a254bc5078481969a14a761e1d96268", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6721 bytes to tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/RelJsonTest.java"}], "isError": false, "timestamp": 1780829140202}]}
