5,\n                name,\n                name,\n                null,\n                255,\n                0,\n                null,\n                null,\n                type,\n                true,\n                false,\n                false,\n                String.class.getName());\n    }\n\n    public static class PersonRecord {\n        public final String name;\n\n        PersonRecord(String name) {\n            this.name = name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 696, "output": 843, "cacheRead": 20992, "cacheWrite": 0, "totalTokens": 22531, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777429746981, "responseId": "resp_065ed18bc845e0470169f16cf3706c819f9b913cb853ff5ed4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_PJFUbs5fJGoTlo42aYBjJXzN|fc_065ed18bc845e0470169f16cfadeb0819f8bc18f4ea7c1037e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2193 bytes to tests/src/org.apache.calcite/calcite-core/1.35.0/src/test/java/org_apache_calcite/calcite_core/RecordEnumeratorCursorTest.java"}], "isError": false, "timestamp": 1777429756794}]}
