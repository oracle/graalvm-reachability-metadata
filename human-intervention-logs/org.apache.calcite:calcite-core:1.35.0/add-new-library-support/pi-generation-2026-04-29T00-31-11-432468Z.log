        return mutableRootSchema;
      }
  
      @Override public List<String> getDefaultSchemaPath() {
        final String schemaName;
        try {
          schemaName = connection.getSchema();
        } catch (SQLException e) {
          throw new RuntimeException(e);
        }
        return schemaName == null
