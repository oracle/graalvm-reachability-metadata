      @Override public RelRunner getRelRunner() {
        final RelRunner runner;
        try {
          runner = connection.unwrap(RelRunner.class);
        } catch (SQLException e) {
          throw new RuntimeException(e);
        }
        if (runner == null) {
          throw new UnsupportedOperationException();
        }
        return runner;
      }
  
