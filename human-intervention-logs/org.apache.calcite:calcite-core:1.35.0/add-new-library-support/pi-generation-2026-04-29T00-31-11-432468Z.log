 @Test\n    void interpreterAggregateUsesReflectiveAccumulatorInstancesForStandardAggregates() {\n        RelBuilder builder = newRelBuilder();\n        RelNode aggregate = builder\n                .values(new String[] {\"DEPARTMENT_ID\", \"SCORE\"},\n                        1, 10,\n                        1, 20,\n                        2, 7)\n                .aggregate(builder.groupKey(builder.field(\"DEPARTMENT_ID\")),\n                        builder.sum(false, \"TOTAL_SCORE\", builder.field(\"SCORE\")),\n                        builder.min(\"LOW_SCORE\", builder.field(\"SCORE\")),\n                        builder.max(\"HIGH_SCORE\", builder.field(\"SCORE\")))\n                .build();\n\n        List<Object[]> rows = Interpreters.bindable(aggregate)\n                .bind(DataContexts.EMPTY)\n                .toList();\n\n        assertThat(rows)\n                .extracting(row -> List.of(row[0], row[1], row[2], row[3]))\n                .containsExactlyInAnyOrder(\n                        List.of(1, 30, 10, 20),\n                        List.of(2, 7, 7, 7));\n    }\n\n    private static RelBuilder newRelBuilder() {\n        FrameworkConfig config = Frameworks.newConfigBuilder()\n                .defaultSchema(Frameworks.createRootSchema(true))\n                .build();\n        return RelBuilder.create(config);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 640, "output": 1104, "cacheRead": 58880, "cacheWrite": 0, "totalTokens": 60624, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777422623627, "responseId": "resp_0188b4d1ba5961d90169f1512035988193a9ba1916c84133e2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_202cCyVqXqyfcO0UdEqPmTot|fc_0188b4d1ba5961d90169f15126fcec8193af191138fb048878", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1996 bytes to tests/src/org.apache.calcite/calcite