      // will have the visitee class substituted into it.
      Class<?>[] paramTypes = new Class[1 + additionalParameterTypes.size()];
      int iParam = 1;
      for (Class<?> paramType : additionalParameterTypes) {
        paramTypes[iParam++] = paramType;
