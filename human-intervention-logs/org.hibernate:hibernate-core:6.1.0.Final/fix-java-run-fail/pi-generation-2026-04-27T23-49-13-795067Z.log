  			if ( setter == null ) {
  				setter = setterOrNull( checkClass.getInterfaces(), propertyName, propertyType );
  			}
  			else {
  				ensureAccessibility( setter );
  			}
  
  			checkClass = checkClass.getSuperclass();
  		}
  		return setter; // might be null
  	}
  
