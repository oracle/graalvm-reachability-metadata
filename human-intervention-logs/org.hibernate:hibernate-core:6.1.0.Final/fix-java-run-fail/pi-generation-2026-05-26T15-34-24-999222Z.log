      testImplementation 'com.h2database:h2:2.1.214'
      testImplementation 'javax.validation:validation-api:2.0.1.Final'
      testImplementation 'ch.qos.logback:logback-classic:1.4.5'
      // Added for Hibernate 6 (Jakarta EE 9) API
      testImplementation 'jakarta.persistence:jakarta.persistence-api:3.0.0'
      // Ensure Logger type in AdditionalMetadataTest is available
      testImplementation 'org.jboss.logging:jboss-logging:3.4.3.Final'
