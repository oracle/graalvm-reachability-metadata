  package org_hibernate.hibernate_core;
  
  import org.hibernate.boot.registry.StandardServiceRegistry;
  import org.hibernate.boot.registry.StandardServiceRegistryBuilder;
  import org.hibernate.boot.registry.selector.spi.StrategySelector;
  import org.hibernate.cfg.AvailableSettings;
  import org.hibernate.engine.jdbc.connections.internal.ConnectionProviderInitiator;
  import org.hibernate.engine.jdbc.connections.internal.DatasourceConnectionProviderImpl;
  import org.hibernate.engine.jdbc.connections.internal.UserSuppliedConnectionProviderImpl;
  import org.hibernate.engine.jdbc.connections.spi.ConnectionProvider;
  import org.hibernate.service.spi.ServiceRegistryImplementor;
  import org.h2.jdbcx.JdbcDataSource;
  import org.junit.jupiter.api.Test;
  
  import java.util.HashMap;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConnectionProviderInitiatorTest {
  
      @Test
      public void shouldInstantiateSingleRegisteredConnectionProvider() {
          StandardServiceRegistry serviceRegistry = createServiceRegistry();
          try {
              strategySelector(serviceRegistry).registerStrategyImplementor(
                      ConnectionProvider.class,
                      "single",
                      UserSuppliedConnectionProviderImpl.class
              );
  
              ConnectionProvider connectionProvider = initiate(Map.of(), serviceRegistry);
  
              assertThat(connectionProvider).isInstanceOf(UserSuppliedConnectionProviderImpl.class);
          }
          finally {
              StandardServiceRegistryBuilder.destroy(serviceRegistry);
          }
      }
  
      @Test
      public void shouldInstantiateExplicitConnectionProviderClassAndApplyInjectionData() {
          JdbcDataSource dataSource = new JdbcDataSource();
          dataSource.setURL("jdbc:h2:mem:connection-provider-initiator;DB_CLOSE_DELAY=-1");
  
          Map<String, Object> injectionData = Map.of("dataSource", dataSource);
          Map<String, Object> settings = new HashMap<>();
          settings.put(AvailableSettings.CONNECTION_PROVIDER, DatasourceConnectionProviderImpl.class);
          settings.put(ConnectionProviderInitiator.INJECTION_DATA, injectionData);
  
          StandardServiceRegistry serviceRegistry = createServiceRegistry();
          try {
              ConnectionProvider connectionProvider = initiate(settings, serviceRegistry);
  
              assertThat(connectionProvider).isInstanceOf(DatasourceConnectionProviderImpl.class);
              assertThat(((DatasourceConnectionProviderImpl) connectionProvider).getDataSource()).isSameAs(dataSource);
          }
          finally {
              StandardServiceRegistryBuilder.destroy(serviceRegistry);
          }
      }
  
      @Test
      public void shouldInstantiateRegisteredPoolingConnectionProviders() {
          Map<String, String> strategySettings = new LinkedHashMap<>();
          strategySettings.put(
                  ConnectionProviderInitiator.C3P0_STRATEGY,
                  AvailableSettings.C3P0_CONFIG_PREFIX + ".min_size"
          );
          strategySettings.put(
                  ConnectionProviderInitiator.PROXOOL_STRATEGY,
                  AvailableSettings.PROXOOL_CONFIG_PREFIX + ".pool_alias"
          );
          strategySettings.put(ConnectionProviderInitiator.HIKARI_STRATEGY, "hibernate.hikari.maximumPoolSize");
          strategySettings.put(ConnectionProviderInitiator.VIBUR_STRATEGY, "hibernate.vibur.poolInitialSize");
          strategySettings.put(ConnectionProviderInitiator.AGROAL_STRATEGY, "hibernate.agroal.maxSize");
  
          StandardServiceRegistry serviceRegistry = createServiceRegistry();
          try {
              StrategySelector strategySelector = strategySelector(serviceRegistry);
              for (String strategyName : strategySettings.keySet()) {
                  strategySelector.registerStrategyImplementor(
                          ConnectionProvider.class,
                          strategyName,
                          UserSuppliedConnectionProviderImpl.class
                  );
              }
              strategySelector.registerStrategyImplementor(
                      ConnectionProvider.class,
                      "additional-provider",
                      DatasourceConnectionProviderImpl.class
              );
  
              for (Map.Entry<String, String> strategySetting : strategySettings.entrySet()) {
                  ConnectionProvider connectionProvider = initiate(
                          settings(strategySetting.getValue(), "1"),
                          serviceRegistry
                  );
  
                  assertThat(connectionProvider)
                          .as("provider selected for %s", strategySetting.getKey())
                          .isInstanceOf(UserSuppliedConnectionProviderImpl.class);
              }
          }
          finally {
              StandardServiceRegistryBuilder.destroy(serviceRegistry);
          }
      }
  
      private static StandardServiceRegistry createServiceRegistry() {
          return new StandardServiceRegistryBuilder().build();
      }
  
      private static StrategySelector strategySelector(StandardServiceRegistry serviceRegistry) {
          return serviceRegistry.getService(StrategySelector.class);
      }
  
      private static Map<String, Object> settings(String key, Object value) {
          Map<String, Object> settings = new HashMap<>();
          settings.put(key, value);
          return settings;
      }
  
      private static ConnectionProvider initiate(Map<String, Object> settings, StandardServiceRegistry serviceRegistry) {
          return ConnectionProviderInitiator.INSTANCE.initiateService(
                  settings,
                  (ServiceRegistryImplementor) serviceRegistry
          );
      }
  }
