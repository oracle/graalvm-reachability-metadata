   *
   * @author Steve Ebersole
   */
  public class IntegrationException extends HibernateException {
  	public IntegrationException(String message) {
  		super( message );
  	}
  
  	public IntegrationException(String message, Throwable root) {
  		super( message, root );
  	}
  }
