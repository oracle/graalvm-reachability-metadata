  							catch (Exception e) {
  								throw new AssertionFailure("could not read @DialectOverride annotation", e);
  							}
  							return Stream.of(annotation);
  						}).iterator();
  		while ( annotations.hasNext() ) {
  			Annotation annotation = annotations.next();
