rt org.hibernate.boot.archive.scan.spi.ScanResult;\nimport org.hibernate.boot.archive.scan.spi.Scanner;\nimport org.hibernate.boot.archive.spi.ArchiveDescriptorFactory;\nimport org.hibernate.boot.registry.StandardServiceRegistry;\nimport org.hibernate.boot.registry.StandardServiceRegistryBuilder;\nimport org.hibernate.cfg.AvailableSettings;\nimport org.junit.jupiter.api.Test;\n\nimport java.net.URL;\nimport java.util.Collections;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ScanningCoordinatorTest {\n    private static final ScanResult EMPTY_SCAN_RESULT = EmptyScanResult.INSTANCE;\n\n    @Test\n    public void testCustomScannerClassWithConfiguredArchiveDescriptorFactory() {\n        ArchiveAwareScanner.reset();\n\n        Map<String, Object> settings = scannerSettings(ArchiveAwareScanner.class);\n        settings.put(AvailableSettings.SCANNER_ARCHIVE_INTERPRETER, StandardArchiveDescriptorFactory.INSTANCE);\n\n        buildMetadata(settings);\n\n        assertThat(ArchiveAwareScanner.constructorInvocations).isEqualTo(1);\n        assertThat(ArchiveAwareScanner.scanInvocations).isEqualTo(1);\n        assertThat(ArchiveAwareScanner.archiveDescriptorFactory)\n                .isSameAs(StandardArchiveDescriptorFactory.INSTANCE);\n    }\n\n    @Test\n    public void testCustomScannerClassUsesStandardArchiveDescriptorFactoryByDefault() {\n        ArchiveAwareScanner.reset();\n\n        buildMetadata(scannerSettings(ArchiveAwareScanner.class));\n\n        assertThat(ArchiveAwareScanner.constructorInvocations).isEqualTo(1);\n        assertThat(ArchiveAwareScanner.scanInvocations).isEqualTo(1);\n        assertThat(ArchiveAwareScanner.archiveDescriptorFactory)\n                .isSameAs(StandardArchiveDescriptorFactory.INSTANCE);\n    }\n\n    @Test\n    public void testCustomScannerClassFallsBackToNoArgumentConstructor() {\n        NoArgumentScanner.reset();\n\n        buildMetadata(scannerSettings(NoArgumentScanner.class));\n\n        assertThat(NoArgumentScanner.constructorInvocations).isEqualTo(1);\n        assertThat(NoArgumentScanner.scanInvocations).isEqualTo(1);\n    }\n\n    private static Map<String, Object> scannerSettings(Class<? extends Scanner> scannerClass) {\n        Map<String, Object> settings = new HashMap<>();\n        settings.put(AvailableSettings.DIALECT, \"org.hibernate.dialect.H2Dialect\");\n        settings.put(AvailableSettings.SCANNER, scannerClass);\n        return settings;\n    }\n\n    private static void buildMetadata(Map<String, Object> settings) {\n        StandardServiceRegistry registry = new StandardServiceRegistryBuilder()\n                .applySettings(settings)\n                .build();\n        try {\n            new MetadataSources(registry)\n                    .getMetadataBuilder()\n                    .applyScanEnvironment(EmptyScanEnvironment.INSTANCE)\n                    .build();\n        }\n        finally {\n            StandardServiceRegistryBuilder.destroy(registry);\n        }\n    }\n\n    public static final class ArchiveAwareScanner implements Scanner {\n        static int constructorInvocations;\n        static int scanInvocations;\n        static ArchiveDescriptorFactory archiveDescriptorFactory;\n\n        public ArchiveAwareScanner(ArchiveDescriptorFactory archiveDescriptorFactory) {\n            constructorInvocations++;\n            ArchiveAwareScanner.archiveDescriptorFactory = archiveDescriptorFactory;\n        }\n\n        @Override\n        public ScanResult scan(ScanEnvironment environment, ScanOptions options, ScanParameters params) {\n            scanInvocations++;\n            return EMPTY_SCAN_RESULT;\n        }\n\n        static void reset() {\n            constructorInvocations = 0;\n            scanInvocations = 0;\n            archiveDescriptorFactory = null;\n        }\n    }\n\n    public static final class NoArgumentScanner implements Scanner {\n        static int constructorInvocations;\n        static int scanInvocations;\n\n        public NoArgumentScanner() {\n            constructorInvocations++;\n        }\n\n        @Override\n        public ScanResult scan(ScanEnvironment environment, ScanOptions options, ScanParameters params) {\n            scanInvocations++;\n            return EMPTY_SCAN_RESULT;\n        }\n\n        static void reset() {\n            constructorInvocations = 0;\n            scanInvocations = 0;\n        }\n    }\n\n    private enum EmptyScanResult implements ScanResult {\n        INSTANCE;\n\n        @Override\n        public Set<PackageDescriptor> getLocatedPackages() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Set<ClassDescriptor> getLocatedClasses() {\n            return Collections.emptySet();\n        }\n\n        @Override\n        public Set<MappingFileDescriptor> getLocatedMappingFiles() {\n            return Collections.emptySet();\n        }\n    }\n\n    private enum EmptyScanEnvironment implements ScanEnvironment {\n        INSTANCE;\n\n        @Override\n        public URL getRootUrl() {\n            return null;\n        }\n\n        @Override\n        public List<URL> getNonRootUrls() {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public List<String> getExplicitlyListedClassNames() {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public List<String> getExplicitlyListedMappingFiles() {\n            return Collections.emptyList();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779812239063}]}
