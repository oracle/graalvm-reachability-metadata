  				}
  			}
  
  			count = ois.readInt();
  			if ( LOG.isTraceEnabled() ) {
  				LOG.trace( "Starting deserialization of [" + count + "] proxiesByKey entries" );
  			}
  			for ( int i = 0; i < count; i++ ) {
  				final EntityKey ek = EntityKey.deserialize( ois, sfi );
  				final Object proxy = ois.readObject();
