  				rtn.collectionsByKey.put(
  						CollectionKey.deserialize( ois, session ),
  						(PersistentCollection<?>) ois.readObject()
  				);
  			}
  
  			count = ois.readInt();
  			if ( LOG.isTraceEnabled() ) {
