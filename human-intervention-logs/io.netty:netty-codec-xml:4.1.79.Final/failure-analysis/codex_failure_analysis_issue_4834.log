$/netty-transport-sctp-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-sctp/index.json:9:    \"description\" : \"Netty Transport SCTP provides Netty channel abstractions and implementations for Stream Control Transmission Protocol networking. It includes SCTP message types, client and server channel APIs, NIO/OIO transport implementations, and handlers for SCTP message completion and byte-stream encoding.\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common/$version$/netty-transport-native-unix-common-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:7:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common-tests/$version$/netty-transport-native-unix-common-tests-$version$-sources.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-transport-native-unix-common/$version$/netty-transport-native-unix-common-$version$-javadoc.jar\",\nmetadata/io.netty/netty-transport-native-unix-common/index.json:9:    \"description\" : \"Netty Transport Native Unix Common provides shared JNI-backed Unix utility classes and native support used by Netty's Unix-based transport modules. It supplies common Unix socket address, file descriptor, and native library plumbing that higher-level Netty transports build on for asynchronous network clients and servers.\",\nmetadata/io.netty/netty-resolver/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver/$version$/netty-resolver-$version$-sources.jar\",\nmetadata/io.netty/netty-resolver/index.json:6:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-resolver/index.json:7:    \"test-code-url\" : \"N/A\",\nmetadata/io.netty/netty-resolver/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver/$version$/netty-resolver-$version$-javadoc.jar\",\nmetadata/io.netty/netty-resolver/index.json:9:    \"description\" : \"Netty Resolver provides asynchronous name resolution abstractions used by Netty networking components. It supplies resolver groups and default or no-op InetSocketAddress resolvers that integrate with Netty's Future and EventExecutor APIs.\",\nmetadata/io.netty/netty-resolver/index.json:18:    \"metadata-version\" : \"4.1.79.Final\",\nmetadata/io.netty/netty-resolver/index.json:19:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver/$version$/netty-resolver-$version$-sources.jar\",\nmetadata/io.netty/netty-resolver/index.json:20:    \"repository-url\" : \"https://github.com/netty/netty\",\nmetadata/io.netty/netty-resolver/index.json:21:    \"test-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver/$version$/netty-resolver-$version$-test-sources.jar\",\nmetadata/io.netty/netty-resolver/index.json:22:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver/$version$/netty-resolver-$version$-javadoc.jar\",\nmetadata/io.netty/netty-resolver/index.json:23:    \"description\" : \"Netty Resolver provides the core asynchronous name and address resolution APIs used by Netty network clients and servers. It includes resolver groups, host file parsing, and default InetAddress-based implementations that integrate with Netty's event-driven concurrency model.\",\nmetadata/io.netty/netty-resolver-dns-classes-macos/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/io/netty/netty-resolver-dns-classes-macos/4.1.74.Final/netty-resolver-dns-classes-macos-4.1.74.Final-sources.jar\",\nmetadata/io.netty/netty-resolver-dns-cla