  	 * Return whether to accept GZIP encoding, that is, whether to
  	 * send the HTTP "Accept-Encoding" header with "gzip" as value.
  	 */
  	public boolean isAcceptGzipEncoding() {
  		return this.acceptGzipEncoding;
  	}
  
