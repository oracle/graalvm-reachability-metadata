  				getHeadersMethod = Response.class.getMethod("getHeaders");
  				Class<?> type = classLoader.loadClass("org.eclipse.jetty.http.HttpField");
  				getNameMethod = type.getMethod("getName");
  				getValueMethod = type.getMethod("getValue");
  			}
