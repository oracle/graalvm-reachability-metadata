  									.domain(cookie.getDomain())
  									.path(cookie.getPath())
  									.maxAge(cookie.getMaxAge())
  									.secure(cookie.getSecure())
  									.httpOnly(cookie.isHttpOnly())
  									.sameSite(parseSameSite(header))
  									.build()))
