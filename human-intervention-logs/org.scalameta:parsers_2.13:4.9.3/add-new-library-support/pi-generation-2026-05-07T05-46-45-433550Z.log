[tool-call] delta {"path":"tests/src/org.scalameta/parsers_2.13/4.9.3/src/test/scala/org_scalameta/parsers_2_13/ReificationMacrosTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scalameta.parsers_2_13\n\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Test\n\nimport scala.reflect.runtime.currentMirror\nimport scala.reflect.runtime.universe\nimport scala.tools.reflect.ToolBox\n\nclass ReificationMacrosTest {\n  @Test\n  def expandScalametaQuasiquotesThroughRuntimeCompiler(): Unit = {\n    try {\n      val expandedSyntax: List[String] = compileAndRunQuasiquoteProgram()\n\n      assertEquals(\n        List(\n          \"triple\",\n          \"def triple(n: Int): Int = n * 3\",\n          \"List(1, 2, 3).map(triple)\",\n          \"Either[String, Int]\",\n          \"Some(value)\"\n        ),\n        expandedSyntax\n      )\n    } catch {\n      case error: Error if NativeImageSupport.isUnsupportedFeatureError(error) =>\n    }\n  }\n\n  private def compileAndRunQuasiquoteProgram(): List[String] = {\n    val toolBox: ToolBox[universe.type] = currentMirror.mkToolBox()\n    val source: String =\n      \"\"\"\n        |import scala.meta._\n        |\n        |object RuntimeQuasiquoteProgram {\n        |  def run(): List[String] = {\n        |    val method: Defn.Def = q\"def triple(n: Int): Int = n * 3\"\n        |    val term: Term = q\"List(1, 2, 3).map(triple)\"\n        |    val tpe: Type = t\"Either[String, Int]\"\n        |    val pattern: Pat = p\"Some(value)\"\n        |\n        |    List(method.name.value, method.syntax, term.syntax, tpe.syntax, pattern.syntax)\n        |  }\n        |}\n        |\n        |RuntimeQuasiquoteProgram.run()\n        |\"\"\".stripMargin\n\n    toolBox.compile(toolBox.parse(source)).apply().asInstanceOf[List[String]]\n  }\n}\n"}
