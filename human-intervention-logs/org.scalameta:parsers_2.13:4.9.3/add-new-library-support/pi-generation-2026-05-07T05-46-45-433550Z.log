  package org_scalameta.parsers_2_13
  
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Test
  
  import scala.reflect.runtime.currentMirror
  import scala.reflect.runtime.universe
  import scala.tools.reflect.ToolBox
  
  class ReificationMacrosTest {
    @Test
    def expandScalametaQuasiquotesThroughRuntimeCompiler(): Unit = {
      try {
        val expandedSyntax: List[String] = compileAndRunQuasiquoteProgram()
  
        assertEquals(List("triple", "n", "map:triple", "Either:2", "Some:value"), expandedSyntax)
      } catch {
        case error: Error => verifyUnsupportedNativeImageError(error)
      }
    }
  
    private def verifyUnsupportedNativeImageError(error: Error): Unit = {
      if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
        throw error
      }
    }
  
    private def compileAndRunQuasiquoteProgram(): List[String] = {
      val toolBox: ToolBox[universe.type] = currentMirror.mkToolBox()
      val source: String =
        """
          |import scala.meta._
          |import scala.meta.quasiquotes._
          |
          |object RuntimeQuasiquoteProgram {
          |  def run(): List[String] = {
          |    val method: Defn.Def = q"def triple(n: Int): Int = n * 3"
          |    val term: Term = q"List(1, 2, 3).map(triple)"
          |    val tpe: Type = t"Either[String, Int]"
          |    val pattern: Pat = p"Some(value)"
          |
          |    val termShape: String = term match {
          |      case Term.Apply(Term.Select(_, Term.Name(methodName)), List(Term.Name(argumentName))) =>
          |        methodName + ":" + argumentName
          |      case other => other.productPrefix
          |    }
          |    val typeShape: String = tpe match {
          |      case Type.Apply(Type.Name(name), arguments) => name + ":" + arguments.size
          |      case other => other.productPrefix
          |    }
          |    val patternShape: String = pattern match {
          |      case Pat.Extract(Term.Name(name), List(Pat.Var(Term.Name(value)))) => name + ":" + value
          |      case other => other.productPrefix
          |    }
          |
          |    List(method.name.value, method.paramss.head.head.name.value, termShape, typeShape, patternShape)
          |  }
          |}
          |
          |RuntimeQuasiquoteProgram.run()
          |""".stripMargin
  
      toolBox.compile(toolBox.parse(source)).apply().asInstanceOf[List[String]]
    }
  }
