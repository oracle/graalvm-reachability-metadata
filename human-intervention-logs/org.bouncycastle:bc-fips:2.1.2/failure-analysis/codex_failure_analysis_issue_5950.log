\\n    private static void deleteRecursively(Path path) throws IOException {\\n        IOException failure = null;\\n        try (Stream<Path> paths = Files.walk(path)) {\\n            for (Path currentPath : paths.sorted(Comparator.reverseOrder()).toList()) {\\n                try {\\n                    Files.deleteIfExists(currentPath);\\n                } catch (IOException exception) {\\n                    if (failure == null) {\\n                        failure = exception;\\n                    } else {\\n                        failure.addSuppressed(exception);\\n                    }\\n                }\\n            }\\n        }\\n        if (failure != null) {\\n            throw failure;\\n        }\\n    }\\n\\n    @FunctionalInterface\\n    private interface TestOperation {\\n        void run() throws Exception;\\n    }\\n\\n    private static boolean isNativeImageRuntime() {\\n        return \\\"runtime\\\".equals(System.getProperty(\\\"org.graalvm.nativeimage.imagecode\\\"));\\n    }\\n\\n    private static void assertForcedVariantWithIsolatedLoader() throws Exception {\\n        IsolatedBcFipsLoader loader = new IsolatedBcFipsLoader(NativeLoaderTest.class.getClassLoader());\\n        Class<?> isolatedFipsStatus = loader.loadClass(\\\"org.bouncycastle.crypto.fips.FipsStatus\\\");\\n        Class<?> isolatedFipsNative = loader.loadClass(\\\"org.bouncycastle.crypto.fips.FipsNative\\\");\\n\\n        Method isReady = isolatedFipsStatus.getMethod(\\\"isReady\\\");\\n        assertEquals(Boolean.TRUE, invokeStatic(isReady));\\n\\n        Method getServices = isolatedFipsNative.getMethod(\\\"getServices\\\");\\n        Object nativeServices = invokeStatic(getServices);\\n        Method getVariant = nativeServices.getClass().getMethod(\\\"getVariant\\\");\\n        Method isEnabled = nativeServices.getClass().getMethod(\\\"isEnabled\\\");\\n\\n        assertEquals(TEST_VARIANT, invoke(nativeServices, getVariant));\\n        assertFalse((Boolean)invoke(nativeServices, isEnabled));\\n    }\\n\\n    private static Object invokeStatic(Method method) throws Exception {\\n        return invoke(null, method);\\n    }\\n\\n    private static Object invoke(Object receiver, Method method) throws Exception {\\n        try {\\n            return method.invoke(receiver);\\n        } catch (InvocationTargetException exception) {\\n            Throwable cause = exception.getCause();\\n            if (cause instanceof Error error) {\\n                throw error;\\n            }\\n            if (cause instanceof Exception nestedException) {\\n                throw nestedException;\\n            }\\n            throw exception;\\n        }\\n    }\\n\\n    private static final class IsolatedBcFipsLoader extends ClassLoader {\\n        private static final String ISOLATED_PREFIX = \\\"org.bouncycastle.crypto.fips.\\\";\\n\\n        private final ProtectionDomain protectionDomain;\\n\\n        IsolatedBcFipsLoader(ClassLoader parent) {\\n            super(parent);\\n            Permissions permissions = new Permissions();\\n            permissions.add(new AllPermission());\\n            protectionDomain = new ProtectionDomain(null, permissions, this, null);\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            synchronized (getClassLoadingLock(name)) {\\n                Class<?> loadedClass = findLoadedClass(name);\\n                if (loadedClass == null) {\\n                    loadedClass = loadUncachedClass(name);\\n                }\\n                if (resolve) {\\n                    resolveClass(loadedClass);\\n                }\\n                return loadedClass;\\n            }\\n        }\\n\\n        private Class<?> loadUncachedClass(String name) throws ClassNotFoundException {\\n            if (name.startsWith(ISOLATED_PREFIX)) {\\n                return findClass(name);\\n            }\\n            return super.loadClas