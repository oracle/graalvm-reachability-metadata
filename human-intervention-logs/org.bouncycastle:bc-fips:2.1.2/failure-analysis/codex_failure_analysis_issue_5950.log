ertEquals;\\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.ObjectInputStream;\\nimport java.io.ObjectOutputStream;\\nimport java.math.BigInteger;\\nimport java.security.KeyFactory;\\nimport java.security.KeyPairGenerator;\\nimport java.security.PrivateKey;\\nimport java.security.Provider;\\nimport java.security.PublicKey;\\nimport java.security.SecureRandom;\\nimport java.security.interfaces.XECPublicKey;\\nimport java.security.spec.NamedParameterSpec;\\nimport java.security.spec.X509EncodedKeySpec;\\n\\nimport org.bouncycastle.jcajce.interfaces.XDHPrivateKey;\\nimport org.bouncycastle.jcajce.interfaces.XDHPublicKey;\\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\\nimport org.bouncycastle.jcajce.spec.XDHParameterSpec;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class Prov11XDHPublicKeyTest {\\n    private static final String PUBLIC_KEY_CLASS_NAME =\\n            \\\"org.bouncycastle.jcajce.provider.Prov11XDHPublicKey\\\";\\n    private static final byte[] X25519_BASE_POINT_SUBJECT_PUBLIC_KEY_INFO = new byte[] {\\n        0x30, 0x2a,\\n        0x30, 0x05,\\n        0x06, 0x03, 0x2b, 0x65, 0x6e,\\n        0x03, 0x21, 0x00,\\n        0x09, 0x00, 0x00, 0x00,\\n        0x00, 0x00, 0x00, 0x00,\\n        0x00, 0x00, 0x00, 0x00,\\n        0x00, 0x00, 0x00, 0x00,\\n        0x00, 0x00, 0x00, 0x00,\\n        0x00, 0x00, 0x00, 0x00,\\n        0x00, 0x00, 0x00, 0x00,\\n        0x00, 0x00, 0x00, 0x00\\n    };\\n    private static final byte[] RANDOM_SEED = new byte[] {\\n        0x20, 0x21, 0x22, 0x23,\\n        0x24, 0x25, 0x26, 0x27,\\n        0x28, 0x29, 0x2a, 0x2b,\\n        0x2c, 0x2d, 0x2e, 0x2f\\n    };\\n\\n    @Test\\n    public void serializationRoundTripRestoresX25519PublicKey() throws Exception {\\n        PublicKey publicKey = createX25519PublicKey();\\n        assertEquals(PUBLIC_KEY_CLASS_NAME, publicKey.getClass().getName());\\n        byte[] encodedPublicKey = publicKey.getEncoded();\\n\\n        byte[] serializedKey = serialize(publicKey);\\n        PublicKey restoredPublicKey = assertInstanceOf(PublicKey.class, deserialize(serializedKey));\\n\\n        assertEquals(PUBLIC_KEY_CLASS_NAME, restoredPublicKey.getClass().getName());\\n        assertEquals(\\\"X25519\\\", restoredPublicKey.getAlgorithm());\\n        assertEquals(\\\"X.509\\\", restoredPublicKey.getFormat());\\n        assertArrayEquals(encodedPublicKey, restoredPublicKey.getEncoded());\\n\\n        XECPublicKey xecPublicKey = assertInstanceOf(XECPublicKey.class, restoredPublicKey);\\n        NamedParameterSpec params = assertInstanceOf(NamedParameterSpec.class, xecPublicKey.getParams());\\n        assertEquals(NamedParameterSpec.X25519.getName(), params.getName());\\n        assertEquals(BigInteger.valueOf(9), xecPublicKey.getU());\\n        assertEquals(restoredPublicKey, publicKey);\\n    }\\n\\n    @Test\\n    public void serializationRoundTripRestoresPublicKeyDerivedFromPrivateKey() throws Exception {\\n        PrivateKey privateKey = generateX25519PrivateKey();\\n        XDHPrivateKey xdhPrivateKey = assertInstanceOf(XDHPrivateKey.class, privateKey);\\n        PublicKey publicKey = assertInstanceOf(PublicKey.class, xdhPrivateKey.getPublicKey());\\n        assertEquals(PUBLIC_KEY_CLASS_NAME, publicKey.getClass().getName());\\n        byte[] encodedPublicKey = publicKey.getEncoded();\\n\\n        byte[] serializedKey = serialize(publicKey);\\n        XDHPublicKey restoredPublicKey = assertInstanceOf(XDHPublicKey.class, deserialize(serializedKey));\\n\\n        assertEquals(PUBLIC_KEY_CLASS_NAME, restoredPublicKey.getClass().getName());\\n        assertEquals(\\\"X25519\\\", restoredPublicKey.getAlgorithm());\\n        assertEquals(\\\"X.509\\\", restoredPublicKey.getFormat());\\n        assertArrayEquals(encodedPublicKey, restoredPublicKey.getEncoded());\\n        assertArrayEquals(((XDHPublicKey) publicKey).getPublicData(), restoredPublicKey.getPublicData());\\n    }\\n\\n    private static PublicKey createX25519PublicKey() throws Exception {\\n        KeyFactory keyFactory = KeyFactory.getInstance(\\\"X25519\\\", new BouncyCastleFipsProvider());\\n        return keyFactory.generatePublic(new X509EncodedKeySpec(X25519_BASE_POINT_SUBJECT_PUBLIC_KEY_INFO));\\n    }\\n\\n    private static PrivateKey generateX25519PrivateKey() throws Exception {\\n        Provider provider = new BouncyCastleFipsProvider();\\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\\\"X25519\\\", provider);\\n        keyPairGenerator.initialize(\\n                new XDHParameterSpec(XDHParameterSpec.X25519),\\n                new SecureRandom(RANDOM_SEED));\\n        return keyPairGenerator.generateKeyPair().getPrivate();\\n    }\\n\\n    private static byte[] serialize(Object value) throws Exception {\\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\\n            objectOutputStream.writeObject(value);\\n        }\\n        return output.toByteArray();\\n    }\\n\\n    private static Object deserialize(byte[] serializedValue) throws Exception {\\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {\\n            return objectInputStream.readObject();\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777997883178}]}\n../5950-c17b617c/human-intervention-logs/org.bouncycastle:bc-fips:2.1.2/add-new-library-support/pi-generation-2026-05-05T16-20-31-862509Z.log:1636:     111\t        throws IOException, ClassNotFoundException\n../5950-c17b617c/human-intervention-logs/org.bouncycastle:bc-fips:2.1.2/add-new-library-support/pi-generation-2026-05-05T16-20-31-862509Z.log:1649:     124\t        throws IOException\n../5950-c17b617c/human-intervention-logs/o