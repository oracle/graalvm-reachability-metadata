  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "org.bouncycastle:bc-fips:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.named("test") {
      systemProperty "org.bouncycastle.native.cpu_variant", "java"
  }
  
  tasks.named("nativeTest") {
      runtimeArgs.add("-Dorg.bouncycastle.native.cpu_variant=java")
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add("-Dorg.bouncycastle.native.cpu_variant=java")
              buildArgs.add("--initialize-at-run-time=org.bouncycastle.crypto.fips.FipsStatus")
          }
      }
  
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
