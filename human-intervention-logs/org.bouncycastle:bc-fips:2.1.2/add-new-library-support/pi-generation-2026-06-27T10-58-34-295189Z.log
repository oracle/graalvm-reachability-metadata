  }\n    }\n\n    private static MethodHandle serializationHook(\n            Class<?> keyClass, String methodName, Class<?> parameterType) throws Exception {\n        MethodHandles.Lookup privateLookup = MethodHandles.privateLookupIn(\n                keyClass, MethodHandles.lookup());\n        return privateLookup.findVirtual(\n                keyClass, methodName, MethodType.methodType(void.class, parameterType));\n    }\n\n    private static byte[] serialize(Object value) throws Exception {", "newText": "    private static byte[] serializeWithReplacingPayload(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutput = new ReplacingKeyEncodingObjectOutputStream(output)) {\n            objectOutput.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static PrivateKey deserializePrivateKey(\n            Class<?> privateKeyClass, byte[] serializedValue) throws Exception {\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\n        try (ObjectInputStream objectInput = new ResolvingKeyEncodingObjectInputStream(\n                input, privateKeyClass)) {\n            return assertInstanceOf(PrivateKey.class, objectInput.readObject());\n        }\n    }\n\n    private static byte[] serialize(Object value) throws Exception {"}, {"oldText": "        ResolvingKeyEncodingObjectInputStream(ByteArrayInputStream input) throws IOException {\n            super(input);\n            enableResolveObject(true);\n        }\n\n        @Override\n        public void defaultReadObject() {\n            // `ProvLMSPrivateKey` restores its state through explicit `readObject` calls.\n        }\n\n        @Override\n        protected Object resolveObject(Object object) throws IOException {", "newText": "        private final Class<?> privateKeyClass;\n\n        ResolvingKeyEncodingObjectInputStream(\n                ByteArrayInputStre