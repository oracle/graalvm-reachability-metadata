  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertNull;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import org.bouncycastle.crypto.fips.FipsStatus;
  import org.junit.jupiter.api.Test;
  
  public class FipsStatusAnonymous4Test {
      private static final String BOOTSTRAP_CLASS_RESOURCE = "java/lang/String.class";
  
      @Test
      void bootstrapSourceClassUsesSystemResourceLookup() throws Throwable {
          MethodHandle getMarker = MethodHandles.privateLookupIn(FipsStatus.class, MethodHandles.lookup()).findStatic(
              FipsStatus.class,
              "getMarker",
              MethodType.methodType(String.class, Class.class, String.class));
  
          try {
              String marker = (String)getMarker.invoke(String.class, BOOTSTRAP_CLASS_RESOURCE);
  
              assertNotNull(marker);
              assertTrue(marker.contains(BOOTSTRAP_CLASS_RESOURCE), marker);
          } catch (NullPointerException exception) {
              assertNull(ClassLoader.getSystemResource(BOOTSTRAP_CLASS_RESOURCE));
          }
      }
  }
