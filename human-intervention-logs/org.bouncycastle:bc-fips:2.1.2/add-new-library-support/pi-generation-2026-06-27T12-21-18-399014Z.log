  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.security.AccessController;
  import java.security.PrivilegedAction;
  
  import org.junit.jupiter.api.Test;
  
  public class FipsStatusAnonymous4Test {
      private static final String ACTIVE_CLASS_NAME = "org.bouncycastle.crypto.fips.FipsStatus$4";
      private static final String BOOTSTRAP_CLASS_RESOURCE = "java/lang/String.class";
  
      @Test
      void privilegedActionUsesSystemResourceLookup() throws Throwable {
          Class<?> actionType = Class.forName(ACTIVE_CLASS_NAME);
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(actionType, MethodHandles.lookup());
          MethodHandle constructor = lookup.findConstructor(
              actionType,
              MethodType.methodType(void.class, String.class));
  
          PrivilegedAction<?> action = (PrivilegedAction<?>)constructor.invoke(BOOTSTRAP_CLASS_RESOURCE);
          Object marker = AccessController.doPrivileged(action);
  
          assertNotNull(marker);
          assertTrue(marker.toString().contains(BOOTSTRAP_CLASS_RESOURCE), marker.toString());
      }
  }
