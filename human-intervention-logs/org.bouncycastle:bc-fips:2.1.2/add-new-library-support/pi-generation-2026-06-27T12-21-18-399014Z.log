      static String getMarker(final Class sourceClass, final String markerName)
      {
          ClassLoader loader = sourceClass.getClassLoader();
  
          if (loader != null)
          {
              Object resource = AccessController.doPrivileged(
                  new PrivilegedAction()
                  {
                      public Object run()
                      {
                          try
                          {
                              CodeSource cs =
