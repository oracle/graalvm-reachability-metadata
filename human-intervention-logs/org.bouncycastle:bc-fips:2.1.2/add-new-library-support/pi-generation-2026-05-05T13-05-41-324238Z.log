ecryptCipher.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n        AEADBadTagException exception = assertThrows(\n                AEADBadTagException.class,\n                () -> tamperedDecryptCipher.doFinal(tamperedCiphertext));\n        assertNotNull(exception.getMessage());\n", "newText": "        Provider provider = new BouncyCastleFipsProvider();\n        Security.addProvider(provider);\n        try {\n            Provider.Service gcmService = provider.getService(\"Cipher\", \"GCM\");\n            assertNotNull(gcmService);\n\n            SecretKeySpec key = new SecretKeySpec(KEY_BYTES, \"AES\");\n            GCMParameterSpec parameterSpec = new GCMParameterSpec(128, IV);\n            byte[] plaintext = \"authenticated plaintext\".getBytes(StandardCharsets.UTF_8);\n\n            Cipher encryptCipher = Cipher.getInstance(\"GCM\", BouncyCastleFipsProvider.PROVIDER_NAME);\n            encryptCipher.init(Cipher.ENCRYPT_MODE, key, parameterSpec);\n            byte[] ciphertext = encryptCipher.doFinal(plaintext);\n\n            Cipher decryptCipher = Cipher.getInstance(\"GCM\", BouncyCastleFipsProvider.PROVIDER_NAME);\n            decryptCipher.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n            byte[] decrypted = decryptCipher.doFinal(ciphertext);\n            assertArrayEquals(plaintext, decrypted);\n\n            byte[] tamperedCiphertext = Arrays.copyOf(ciphertext, ciphertext.length);\n            tamperedCiphertext[tamperedCiphertext.length - 1] ^= 0x01;\n\n            Cipher tamperedDecryptCipher = Cipher.getInstance(\"GCM\", BouncyCastleFipsProvider.PROVIDER_NAME);\n            tamperedDecryptCipher.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n            AEADBadTagException exception = assertThrows(\n                    AEADBadTagException.class,\n                    () -> tamperedDecryptCipher.doFinal(tamperedCiphertext));\n            assertInstanceOf(AEADBadTagException.class, exception);\n            assertNotNull(exception.getMessage());\n        } finally {\n            Security.removeProvider(BouncyCastleFipsProvider.PROVIDER_NAME);\n        }\n"}]}
