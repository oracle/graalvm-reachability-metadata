rg.assertj:assertj-core:3.22.0'\n    testCompileOnly 'org.graalvm.sdk:nativeimage:24.2.2'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('--features=' + [\n                'org_bouncycastle.bc_fips.ChaCha20SpecUtilAnonymous1Feature',\n                'org_bouncycastle.bc_fips.GcmSpecUtilAnonymous1Feature',\n                'org_bouncycastle.bc_fips.Prov11XDHPrivateKeyFeature',\n                'org_bouncycastle.bc_fips.Prov11XDHPublicKeyFeature',\n                'org_bouncycastle.bc_fips.Prov15EdDSAPrivateKeyFeature',\n                'org_bouncycastle.bc_fips.Prov15EdDSAPublicKeyFeature'\n            ].join(','))\n            runtimeArgs(\"-D${nativeVariantProperty}=${nativeLoaderTestVariant}\")\n            runtimeArgs(\"-D${osArchProperty}=amd64\")\n            runtimeArgs(\"-D${osNameProperty}=Linux\")\n        }\n    }\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777996734560}, {"role": "toolResult", "toolCallId": "call_1eRy2whjw6wgaTOIZPacgCVm|fc_0550853ffeed4f320169fa13be509881a2a2a51d0e905a7ec0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPairGenerator;\nimport java.security.PrivateKey;\nimport java.security.Provider;\nimport java.security.SecureRandom;\nimport java.security.interfaces.XECPrivateKey;\nimport java.security.spec.NamedParameterSpec;\n\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\nimport org.bouncycastle.jcajce.spec.XDHParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class Prov11XDHPrivateKeyTest {\n    private static final String PRIVATE_KEY_CLASS_NAME =\n            \"org.bouncycastle.jcajce.provider.Prov11XDHPrivateKey\";\n    private static final byte[] RANDOM_SEED = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b,\n        0x0c, 0x0d, 0x0e, 0x0f\n    };\n\n    @Test\n    public void serializationRoundTripRestoresX25519PrivateKey() throws Exception {\n        PrivateKey privateKey = generateX25519PrivateKey();\n        assertEquals(PRIVATE_KEY_CLASS_NAME, privateKey.getClass().getName());\n        byte[] encodedPrivateKey = privateKey.getEncoded();\n\n        byte[] serializedKey = serialize(privateKey);\n        PrivateKey restoredPrivateKey = assertInstanceOf(PrivateKey.class, deserialize(serializedKey));\n\n        assertEquals(PRIVATE_KEY_CLASS_NAME, restoredPrivateKey.getClass().getName());\n        assertEquals(\"X25519\", restoredPrivateKey.getAlgorithm());\n        assertEquals(\"PKCS#8\", restoredPrivateKey.getFormat());\n        assertArrayEquals(encodedPrivateKey, restoredPrivateKey.getEncoded());\n\n        XECPrivateKey xecPrivateKey = assertInstanceOf(XECPrivateKey.class, restoredPrivateKey);\n        NamedParameterSpec params = assertInstanceOf(NamedParameterSpec.class, xecPrivateKey.getParams());\n        assertEquals(NamedParameterSpec.X25519.getName(), params.getName());\n        assertTrue(xecPrivateKey.getScalar().isPresent());\n    }\n\n    private static PrivateKey generateX25519PrivateKey() throws Exception {\n        Provider provider = new BouncyCastleFipsProvider();\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"X25519\", provider);\n        keyPairGenerator.initialize(\n                new XDHParameterSpec(XDHParameterSpec.X25519),\n                new SecureRandom(RANDOM_SEED));\n        return keyPairGenerator.generateKeyPair().getPrivate();\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws Exception {\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {\n            return objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777996734561}, {"role": "toolResult", "toolCallId": "call_wDcQNhsmkjrJVDYUXWpc345G|fc_0550853ffeed4f320169fa13be50a081a2b161c74327ddef4d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyFactory;\nimport java.security.PrivateKey;\nimport java.security.interfaces.EdECPrivateKey;\nimport java.security.spec.EdECPrivateKeySpec;\nimport java.security.spec.NamedParameterSpec;\n\nimport org.bouncycastle.jcajce.interfaces.EdDSAPrivateKey;\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class Prov15EdDSAPrivateKeyTest {\n    private static final String PRIVATE_KEY_CLASS_NAME =\n            \"org.bouncycastle.jcajce.provider.Prov15EdDSAPrivateKey\";\n    private static final byte[] ED25519_PRIVATE_KEY_BYTES = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b,\n        0x0c, 0x0d, 0x0e, 0x0f,\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1a, 0x1b,\n        0x1c, 0x1d, 0x1e, 0x1f\n    };\n\n    @Test\n    public void serializationRoundTripRestoresEd25519PrivateKey() throws Exception {\n        PrivateKey privateKey = generateEd25519PrivateKey();\n        assertEquals(PRIVATE_KEY_CLASS_NAME, privateKey.getClass().getName());\n        EdDSAPrivateKey originalPrivateKey = assertInstanceOf(\n                EdDSAPrivateKey.class,\n                privateKey);\n        byte[] encodedPrivateKey = privateKey.getEncoded();\n\n        byte[] serializedKey = serialize(privateKey);\n        PrivateKey restoredPrivateKey = assertInstanceOf(\n                PrivateKey.class,\n                deserialize(serializedKey));\n\n        assertEquals(PRIVATE_KEY_CLASS_NAME, restoredPrivateKey.getClass().getName());\n        assertEquals(\"Ed25519\", restoredPrivateKey.getAlgorithm());\n        assertEquals(\"PKCS#8\", restoredPrivateKey.getFormat());\n        assertArrayEquals(encodedPrivateKey, restoredPrivateKey.getEncoded());\n\n        EdECPrivateKey edEcPrivateKey = assertInstanceOf(\n                EdECPrivateKey.class,\n                restoredPrivateKey);\n        NamedParameterSpec params = assertInstanceOf(\n                NamedParameterSpec.class,\n                edEcPrivateKey.getParams());\n        assertEquals(NamedParameterSpec.ED25519.getName(), params.getName());\n        assertTrue(edEcPrivateKey.getBytes().isPresent());\n\n        EdDSAPrivateKey edDsaPrivateKey = assertInstanceOf(\n                EdDSAPrivateKey.class,\n                restoredPrivateKey);\n        assertArrayEquals(originalPrivateKey.getPublicData(), edDsaPrivateKey.getPublicData());\n    }\n\n    private static PrivateKey generateEd25519PrivateKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"Ed25519\", new BouncyCastleFipsProvider());\n        return keyFactory.generatePrivate(new EdECPrivateKeySpec(\n                NamedParameterSpec.ED25519,\n                ED25519_PRIVATE_KEY_BYTES));\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws Exception {\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {\n            return objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777996734561}]}
