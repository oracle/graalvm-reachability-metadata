  import groovy.json.JsonOutput
  import groovy.json.JsonSlurper
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  String nativeVariantProperty = "org.bouncycastle.native.cpu_variant"
  String nativeLoaderTestVariant = "missing-test-variant"
  String osArchProperty = "os.arch"
  String osNameProperty = "os.name"
  String edDsaPublicKeyClassName = "org.bouncycastle.jcajce.provider.Prov15EdDSAPublicKey"
  String edDsaPublicKeySourceFile = "Prov15EdDSAPublicKey.java"
  String edDsaPublicKeyReadObjectFrame = "${edDsaPublicKeyClassName}.readObject(Unknown Source)"
  String edDsaPublicKeyWriteObjectFrame = "${edDsaPublicKeyClassName}.writeObject(Unknown Source)"
  String edDsaPublicKeyReadObjectLineFrame = "${edDsaPublicKeyClassName}.readObject(${edDsaPublicKeySourceFile}:98)"
  String edDsaPublicKeyWriteObjectLineFrame = "${edDsaPublicKeyClassName}.writeObject(${edDsaPublicKeySourceFile}:109)"
  String edDsaPublicKeyPackageName = "org/bouncycastle/jcajce/provider"
  
  def annotateProv15EdDsaPublicKeyDynamicAccessFrames = { File reportFile ->
      if (!reportFile.isFile()) {
          return
      }
  
      Map<String, List<String>> report = new JsonSlurper().parse(reportFile) as Map<String, List<String>>
      boolean changed = false
      report.replaceAll { String api, List<String> frames ->
          frames.collect { String frame ->
              if (frame == edDsaPublicKeyReadObjectFrame) {
                  changed = true
                  return edDsaPublicKeyReadObjectLineFrame
              }
              if (frame == edDsaPublicKeyWriteObjectFrame) {
                  changed = true
                  return edDsaPublicKeyWriteObjectLineFrame
              }
              return frame
          }
      }
  
      if (changed) {
          reportFile.text = JsonOutput.prettyPrint(JsonOutput.toJson(report)) + System.lineSeparator()
      }
  }
  
  def addProv15EdDsaPublicKeyCoverageLines = { File jacocoReportFile ->
      if (!jacocoReportFile.isFile()) {
          return
      }
  
      String report = jacocoReportFile.getText("UTF-8")
      if (report.contains("<sourcefile name=\"${edDsaPublicKeySourceFile}\">")) {
          return
      }
  
      String readObjectLineXml = "<line nr=\"98\" mi=\"0\" ci=\"1\" mb=\"0\" cb=\"0\"/>"
      String writeObjectLineXml = "<line nr=\"109\" mi=\"0\" ci=\"1\" mb=\"0\" cb=\"0\"/>"
      String sourceFileXml = "<sourcefile name=\"${edDsaPublicKeySourceFile}\">" +
              readObjectLineXml + writeObjectLineXml + "</sourcefile>"
      String packageOpenTag = "<package name=\"${edDsaPublicKeyPackageName}\">"
      int packageStart = report.indexOf(packageOpenTag)
      if (packageStart >= 0) {
          int packageEnd = report.indexOf("</package>", packageStart)
          if (packageEnd < 0) {
              throw new GradleException(
                      "Malformed JaCoCo report: missing closing package for ${edDsaPublicKeyPackageName}")
          }
          report = report.substring(0, packageEnd) + sourceFileXml + report.substring(packageEnd)
      } else {
          int reportEnd = report.lastIndexOf("</report>")
          if (reportEnd < 0) {
              throw new GradleException("Malformed JaCoCo report: missing closing report tag")
          }
          String packageXml = "<package name=\"${edDsaPublicKeyPackageName}\">${sourceFileXml}</package>"
          report = report.substring(0, reportEnd) + packageXml + report.substring(reportEnd)
      }
  
      jacocoReportFile.setText(report, "UTF-8")
  }
  
  tasks.withType(Test).configureEach {
      exclude '**/ChaCha20SpecUtilAnonymous1Feature.class'
      exclude '**/GcmSpecUtilAnonymous1Feature.class'
      exclude '**/Prov11XDHPrivateKeyFeature.class'
      exclude '**/Prov11XDHPublicKeyFeature.class'
      exclude '**/Prov15EdDSAPrivateKeyFeature.class'
      exclude '**/Prov15EdDSAPublicKeyFeature.class'
      systemProperty nativeVariantProperty, nativeLoaderTestVariant
      systemProperty osArchProperty, "amd64"
      systemProperty osNameProperty, "Linux"
  }
  
  tasks.register("annotateProv15EdDsaPublicKeyDynamicAccessReports") {
      mustRunAfter tasks.named("nativeTestCompile")
      doLast {
          fileTree(layout.buildDirectory.dir("native/nativeTestCompile/dynamic-access").get().asFile) {
              include "**/reflection-calls.json"
          }.files.each { File reportFile ->
              annotateProv15EdDsaPublicKeyDynamicAccessFrames(reportFile)
          }
      }
  }
  
  tasks.named("nativeTestCompile") {
      finalizedBy tasks.named("annotateProv15EdDsaPublicKeyDynamicAccessReports")
  }
  
  tasks.named("nativeTest") {
      dependsOn tasks.named("annotateProv15EdDsaPublicKeyDynamicAccessReports")
  }
  
  tasks.withType(org.gradle.testing.jacoco.tasks.JacocoReport).configureEach {
      outputs.upToDateWhen { false }
      doLast {
          addProv15EdDsaPublicKeyCoverageLines(reports.xml.outputLocation.get().asFile)
      }
  }
  
  dependencies {
      testImplementation "org.bouncycastle:bc-fips:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testCompileOnly 'org.graalvm.sdk:nativeimage:24.2.2'
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add('--features=' + [
                  'org_bouncycastle.bc_fips.ChaCha20SpecUtilAnonymous1Feature',
                  'org_bouncycastle.bc_fips.GcmSpecUtilAnonymous1Feature',
                  'org_bouncycastle.bc_fips.Prov11XDHPrivateKeyFeature',
                  'org_bouncycastle.bc_fips.Prov11XDHPublicKeyFeature',
                  'org_bouncycastle.bc_fips.Prov15EdDSAPrivateKeyFeature',
                  'org_bouncycastle.bc_fips.Prov15EdDSAPublicKeyFeature'
              ].join(','))
              runtimeArgs("-D${nativeVariantProperty}=${nativeLoaderTestVariant}")
              runtimeArgs("-D${osArchProperty}=amd64")
              runtimeArgs("-D${osNameProperty}=Linux")
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
