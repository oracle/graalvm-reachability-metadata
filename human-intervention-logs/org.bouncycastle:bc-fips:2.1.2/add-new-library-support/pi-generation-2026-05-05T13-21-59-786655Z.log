                  String version = BouncyCastleFipsProvider.INFO.substring(BouncyCastleFipsProvider.INFO.lastIndexOf('v') + 1);
  
                  bcFipsLibPath = LoaderUtils.createVersionedTempDir(fixedInstallDirProp, version);
