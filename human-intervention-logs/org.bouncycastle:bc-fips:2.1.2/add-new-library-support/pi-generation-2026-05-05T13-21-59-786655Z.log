}\n\n    private static void assertStatusReadyFromIsolatedLoader() throws Exception {\n        NullCodeSourceBouncyCastleLoader loader = new NullCodeSourceBouncyCastleLoader(\n                FipsStatusTest.class.getClassLoader());\n        Class<?> isolatedFipsStatus = loader.loadClass(\"org.bouncycastle.crypto.fips.FipsStatus\");\n\n        Method isReady = isolatedFipsStatus.getMethod(\"isReady\");\n        assertEquals(Boolean.TRUE, invokeStatic(isReady));\n\n        Method getStatusMessage = isolatedFipsStatus.getMethod(\"getStatusMessage\");\n        assertEquals(FipsStatus.READY, invokeStatic(getStatusMessage));\n\n        Method getModuleHmac = isolatedFipsStatus.getMethod(\"getModuleHMAC\");\n        byte[] hmac = assertInstanceOf(byte[].class, invokeStatic(getModuleHmac));\n        assertEquals(SHA256_HMAC_LENGTH, hmac.length);\n    }\n\n    private static Object invokeStatic(Method method) throws Exception {\n        try {\n            return method.invoke(null);\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause();\n            if (cause instanceof Error error) {\n                throw error;\n            }\n            if (cause instanceof Exception nestedException) {\n                throw nestedException;\n            }\n            throw exception;\n        }\n    }\n\n    private static final class NullCodeSourceBouncyCastleLoader extends ClassLoader {\n        private final ProtectionDomain protectionDomain;\n\n        NullCodeSourceBouncyCastleLoader(ClassLoader parent) {\n            super(parent);\n            Permissions permissions = new Permissions();\n            permissions.add(new AllPermission());\n            protectionDomain = new ProtectionDomain(null, permissions, this, null);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = loadUncachedClass(name);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private Class<?> loadUncachedClass(String name) throws ClassNotFoundException {\n            if (name.startsWith(\"org.bouncycastle.\")) {\n                try {\n                    return findClass(name);\n                } catch (ClassNotFoundException exception) {\n                    return super.loadClass(name, false);\n                }\n            }\n            return super.loadClass(name, false);\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream input = getParent().getResourceAsStream(resourceName)) {\n                if (input == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                byte[] classBytes = input.readAllBytes();\n                return defineClass(name, classBytes, 0, classBytes.length, protectionDomain);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n    }\n}\n"}]}
