[tool-call] delta {"path":"tests/src/org.bouncycastle/bc-fips/2.1.2/src/test/java/org_bouncycastle/bc_fips/ChaCha20SpecUtilAnonymous2Test.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotEquals;\n\nimport java.security.Provider;\nimport java.security.Security;\n\nimport javax.crypto.Cipher;\nimport javax.crypto.SecretKey;\nimport javax.crypto.spec.ChaCha20ParameterSpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\n\npublic class ChaCha20SpecUtilAnonymous2Test {\n    private static final String NATIVE_CPU_VARIANT_PROPERTY = \"org.bouncycastle.native.cpu_variant\";\n\n    @BeforeAll\n    static void useJavaOnlyNativeVariant() {\n        System.setProperty(NATIVE_CPU_VARIANT_PROPERTY, \"java\");\n    }\n\n    @Test\n    void cipherInitWithChaCha20ParameterSpecExtractsNonceAndCounter() throws Exception {\n        byte[] keyBytes = new byte[] {\n            0x00, 0x01, 0x02, 0x03,\n            0x04, 0x05, 0x06, 0x07,\n            0x08, 0x09, 0x0a, 0x0b,\n            0x0c, 0x0d, 0x0e, 0x0f,\n            0x10, 0x11, 0x12, 0x13,\n            0x14, 0x15, 0x16, 0x17,\n            0x18, 0x19, 0x1a, 0x1b,\n            0x1c, 0x1d, 0x1e, 0x1f\n        };\n        byte[] nonce = new byte[] {\n            0x20, 0x21, 0x22, 0x23,\n            0x24, 0x25, 0x26, 0x27,\n            0x28, 0x29, 0x2a, 0x2b\n        };\n        byte[] plaintext = new byte[] {\n            0x30, 0x31, 0x32, 0x33,\n            0x34, 0x35, 0x36, 0x37,\n            0x38, 0x39, 0x3a, 0x3b,\n            0x3c, 0x3d, 0x3e, 0x3f\n        };\n        SecretKey key = new SecretKeySpec(keyBytes, \"CHACHA20\");\n        ChaCha20ParameterSpec parameterSpec = new ChaCha20ParameterSpec(nonce, 7);\n\n        Cipher encryptCipher = Cipher.getInstance(\"CHACHA20\", bouncyCastleFipsProvider());\n        encryptCipher.init(Cipher.ENCRYPT_MODE, key, parameterSpec);\n        byte[] ciphertext = encryptCipher.doFinal(plaintext);\n\n        assertNotEquals(plaintext[0], ciphertext[0]);\n\n        Cipher decryptCipher = Cipher.getInstance(\"CHACHA20\", bouncyCastleFipsProvider());\n        decryptCipher.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n        assertArrayEquals(plaintext, decryptCipher.doFinal(ciphertext));\n    }\n\n    private static Provider bouncyCastleFipsProvider() {\n        Provider provider = Security.getProvider(BouncyCastleFipsProvider.PROVIDER_NAME);\n        if (provider != null) {\n            return provider;\n        }\n        return new BouncyCastleFipsProvider();\n    }\n}\n"}
