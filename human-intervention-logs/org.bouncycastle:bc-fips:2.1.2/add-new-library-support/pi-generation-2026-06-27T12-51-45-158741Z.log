         0x18, 0x19, 0x1a, 0x1b,\n            0x1c, 0x1d, 0x1e, 0x1f\n        };\n        byte[] nonce = new byte[] {\n            0x20, 0x21, 0x22, 0x23,\n            0x24, 0x25, 0x26, 0x27,\n            0x28, 0x29, 0x2a, 0x2b\n        };\n        byte[] plaintext = new byte[] {\n            0x30, 0x31, 0x32, 0x33,\n            0x34, 0x35, 0x36, 0x37,\n            0x38, 0x39, 0x3a, 0x3b,\n            0x3c, 0x3d, 0x3e, 0x3f\n        };\n        SecretKey key = new SecretKeySpec(keyBytes, \"CHACHA20\");\n        ChaCha20ParameterSpec parameterSpec = new ChaCha20ParameterSpec(nonce, 7);\n\n        Cipher encryptCipher = Cipher.getInstance(\"CHACHA20\", bouncyCastleFipsProvider());\n        encryptCipher.init(Cipher.ENCRYPT_MODE, key, parameterSpec);\n        byte[] ciphertext = encryptCipher.doFinal(plaintext);\n\n        assertFalse(Arrays.equals(plaintext, ciphertext));\n\n        Cipher decryptCipher = Cipher.getInstance(\"CHACHA20\", bouncyCastleFipsProvider());\n        decryptCipher.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n        assertArrayEquals(plaintext, decryptCipher.doFinal(ciphertext));\n    }\n\n    private static Provider bouncyCastleFipsProvider() {\n        Provider provider = Security.getProvider(BouncyCastleFipsProvider.PROVIDER_NAME);\n        if (provider != null) {\n            return provider;\n        }\n        return new BouncyCastleFipsProvider();\n    }\n}\n", "newText": "public class ChaCha20SpecUtilAnonymous2Test {\n    private static final String CHACHA20_SPEC_UTIL_CLASS_NAME =\n        \"org.bouncycastle.jcajce.provider.ChaCha20SpecUtil\";\n\n    @Test\n    void extractChaCha20ParametersInvokesSpecAccessors() throws Throwable {\n        byte[] nonce = new byte[] {\n            0x20, 0x21, 0x22, 0x23,\n            0x24, 0x25, 0x26, 0x27,\n            0x28, 0x29, 0x2a, 0x2b\n        };\n        int counter = 7;\n        AlgorithmParameterSpec parameterSpec = new ChaCha20ParameterSpec(nonce, counter);\n        MethodHandle extractChaCha20Parameters = chaCha20SpecUtilLookup().findStatic(\n            chaCha20SpecUtilType(),\n            \"extractChaCha20Parameters\",\n            MethodType.methodType(ASN1Sequence.class, AlgorithmParameterSpec.class));\n\n        Object result = extractChaCha20Parameters.invoke(parameterSpec);\n\n        ASN1Sequence parameters = assertInstanceOf(ASN1Sequence.class, result);\n        assertEquals(2, parameters.size());\n        assertArrayEquals(nonce, ASN1OctetString.getInstance(parameters.getObjectAt(0)).getOctets());\n        assertEquals(counter, ASN1Integer.getInstance(parameters.getObjectAt(1)).getValue().intValue());\n    }\n\n    private static MethodHandles.Lookup chaCha20SpecUtilLookup()\n        throws ClassNotFoundException, IllegalAccessException {\n        return MethodHandles.privateLookupIn(chaCha20SpecUtilType(), MethodHandles.lookup());\n    }\n\n    private static Class<?> chaCha20SpecUtilType() throws ClassNotFoundException {\n        return Class.forName(CHACHA20_SPEC_UTIL_CLASS_NAME);\n    }\n}\n"}]}
