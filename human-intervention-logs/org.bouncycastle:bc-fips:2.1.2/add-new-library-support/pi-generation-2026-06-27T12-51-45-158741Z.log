 0x35, 0x36, 0x37,\n            0x38, 0x39, 0x3a, 0x3b,\n            0x3c, 0x3d, 0x3e, 0x3f\n        };\n        SecretKey key = new SecretKeySpec(keyBytes, \"CHACHA20\");\n        ChaCha20ParameterSpec parameterSpec = new ChaCha20ParameterSpec(nonce, 7);\n\n        Cipher encryptCipher = Cipher.getInstance(\"CHACHA20\", bouncyCastleFipsProvider());\n        encryptCipher.init(Cipher.ENCRYPT_MODE, key, parameterSpec);\n        byte[] ciphertext = encryptCipher.doFinal(plaintext);\n\n        assertNotEquals(plaintext[0], ciphertext[0]);\n\n        Cipher decryptCipher = Cipher.getInstance(\"CHACHA20\", bouncyCastleFipsProvider());\n        decryptCipher.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n        assertArrayEquals(plaintext, decryptCipher.doFinal(ciphertext));\n    }\n\n    private static Provider bouncyCastleFipsProvider() {\n        Provider provider = Security.getProvider(BouncyCastleFipsProvider.PROVIDER_NAME);\n        if (provider != null) {\n            return provider;\n        }\n        return new BouncyCastleFipsProvider();\n    }\n}\n"}
