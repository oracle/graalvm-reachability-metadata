      private static Provider bouncyCastleFipsProvider() {
          Provider provider = Security.getProvider(BouncyCastleFipsProvider.PROVIDER_NAME);
          if (provider != null) {
              return provider;
          }
          return new BouncyCastleFipsProvider();
      }
