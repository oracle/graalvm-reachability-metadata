eterSpec other = (GOST3410DomainParameterSpec)o;\n            \n            return this.parameters.equals(other.parameters);\n        }\n        \n        return false;\n    }\n    \n    public int hashCode()\n    {\n        return this.parameters.hashCode();\n    }\n\n    public int getKeySize()\n    {\n        return parameters.getKeySize();\n    }\n\n    public BigInteger getP()\n    {\n        return parameters.getP();\n    }\n\n    public BigInteger getQ()\n    {\n        return parameters.getQ();\n    }\n\n    public BigInteger getA()\n    {\n        return parameters.getA();\n    }\n}\n"}], "isError": false, "timestamp": 1782556737317}, {"role": "toolResult", "toolCallId": "call_UlyuF2bFNcSoCpv0RRqzs2m9|fc_090969d9f6a19121016a3fa8411fe48197a7c0a2c0a084e64d", "toolName": "read", "content": [{"type": "text", "text": "package org.bouncycastle.jcajce.spec;\n\nimport java.security.spec.AlgorithmParameterSpec;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.crypto.asymmetric.ECDomainParameters;\nimport org.bouncycastle.crypto.asymmetric.GOST3410DomainParameters;\nimport org.bouncycastle.crypto.asymmetric.GOST3410Parameters;\n\n/**\n * ParameterSpec for a GOST 3410-1994/2001/2012 algorithm parameters.\n */\npublic final class GOST3410ParameterSpec<T extends AlgorithmParameterSpec>\n    implements AlgorithmParameterSpec\n{\n    private GOST3410Parameters parameters;\n\n    public GOST3410ParameterSpec(\n        GOST3410Parameters parameters)\n    {\n        this.parameters = parameters;\n    }\n\n    public ASN1ObjectIdentifier getPublicKeyParamSet()\n    {\n        return parameters.getPublicKeyParamSet();\n    }\n\n    public ASN1ObjectIdentifier getDigestParamSet()\n    {\n        return parameters.getDigestParamSet();\n    }\n\n    public ASN1ObjectIdentifier getEncryptionParamSet()\n    {\n        return parameters.getEncryptionParamSet();\n    }\n\n    public T getDomainParametersSpec()\n    {\n        if (parameters.getDomainPara