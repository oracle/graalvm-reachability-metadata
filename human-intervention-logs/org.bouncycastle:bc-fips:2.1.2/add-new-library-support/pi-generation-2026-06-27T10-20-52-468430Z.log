      }
  
      @Override
      public int hashCode()
      {
          checkApprovedOnlyModeStatus();
  
          return hashCode;
      }
  
      private int calculateHashCode()
      {
          int result = getAlgorithm().hashCode();
          result = 31 * result + 3 * Arrays.hashCode(publicData);
          return result;
