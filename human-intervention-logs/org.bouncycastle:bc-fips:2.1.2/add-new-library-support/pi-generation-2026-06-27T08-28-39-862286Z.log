  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "org.bouncycastle:bc-fips:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add("--initialize-at-run-time=org.bouncycastle.crypto.fips.FipsStatus")
              buildArgs.add("--initialize-at-run-time=org.bouncycastle.crypto.fips.NativeLoader")
              buildArgs.add("-H:AdditionalSecurityProviders=org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider")
              buildArgs.add("-H:IncludeResources=native/linux/x86_64/(deps\\.list|probe/libbc-probe\\.so)")
          }
      }
  
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
