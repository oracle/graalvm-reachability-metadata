l byte[] CHACHA20_NONCE = new byte[] {\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27,\n        0x28, 0x29, 0x2a, 0x2b\n    };\n\n    @Test\n    void chacha20InitializationLooksUpParameterSpecAccessorMethods() throws Exception {\n        Provider provider = new BouncyCastleFipsProvider();\n        SecretKey key = new SecretKeySpec(CHACHA20_KEY, \"ChaCha20\");\n        ChaCha20ParameterSpec parameterSpec = new ChaCha20ParameterSpec(CHACHA20_NONCE, 3);\n        byte[] plaintext = \"ClassUtil privileged method lookup\".getBytes(StandardCharsets.UTF_8);\n\n        Cipher encrypt = Cipher.getInstance(\"ChaCha20\", provider);\n        encrypt.init(Cipher.ENCRYPT_MODE, key, parameterSpec);\n        byte[] ciphertext = encrypt.doFinal(plaintext);\n\n        Cipher decrypt = Cipher.getInstance(\"ChaCha20\", provider);\n        decrypt.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n\n        assertArrayEquals(plaintext, decrypt.doFinal(ciphertext));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 539, "output": 1764, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 31999, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782565208918, "responseId": "resp_0d915744893d6926016a3fc9597c848197a71c215567f111b6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_IWIMPotsTYwY2kzTKioi5EPv|fc_0d915744893d6926016a3fc96ced308197b8b5278afc603439", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1966 bytes to tests/src/org.bouncycastle/bc-fips/2.1.2/src/test/java/org_bouncycastle/bc_fips/ClassUtilAnonymous1Test.java"}], "isError": false, "timestamp": 1782565233926}]}
