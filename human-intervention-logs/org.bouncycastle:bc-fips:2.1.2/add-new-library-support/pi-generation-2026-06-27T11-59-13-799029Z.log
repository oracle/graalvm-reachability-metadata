      }
  
      public boolean equals(Object o)
      {
          if (o == this)
          {
              return true;
          }
  
          if (o instanceof ProvEdDSAPrivateKey)
          {
              return this.baseKey.equals(((ProvEdDSAPrivateKey)o).baseKey);
          }
  
          return false;
      }
  
      public int hashCode()
      {
          return baseKey.hashCode();
      }
  
