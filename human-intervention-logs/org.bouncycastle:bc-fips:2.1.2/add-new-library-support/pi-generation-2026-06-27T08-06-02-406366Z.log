o.maven.apache.org/maven2/org/bouncycastle/bc-fips/$version$/bc-fips-$version$-sources.jar\",\n./metadata/org.bouncycastle/bc-fips/index.json:6:    \"repository-url\" : \"bcgit@git.bouncycastle.org:bc-fips-2.1.X-java.git\",\n./metadata/org.bouncycastle/bc-fips/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/bouncycastle/bc-fips/$version$/bc-fips-$version$-javadoc.jar\",\n./metadata/org.bouncycastle/bc-fips/index.json:9:    \"description\" : \"Bouncy Castle bc-fips provides the FIPS-certified Java Cryptography Extension provider and low-level cryptographic APIs from the BC-FJA 2.1 series. It supplies FIPS 140-3 level 1 cryptographic services for JVM applications, including provider implementations and optimized native hardware support where available.\",\n./metadata/org.bouncycastle/bcpkix-jdk15to18/index.json:9:    \"description\" : \"Provides Bouncy Castle Java APIs for PKIX, CMS, PKCS, EAC, TSP, CMP, CRMF, OCSP, and certificate generation. It targets JDK 1.5 through JDK 1.8 and is typically used alongside a JCE/JCA provider such as Bouncy Castle's cryptography provider.\",\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:5:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:17:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:29:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:41:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:53:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:65