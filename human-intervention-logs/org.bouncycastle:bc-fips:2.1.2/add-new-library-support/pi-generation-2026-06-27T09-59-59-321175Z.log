                  domainParameters = ECUtil.convertFromSpec((ECParameterSpec)algorithmParameterSpec);
              }
              else
              {
                  if (algorithmParameterSpec == null)
                  {
                      throw new InvalidParameterSpecException("parameterSpec cannot be null");
