lizationWritesEcPrivateKeyClassDescriptor() throws Exception {\n        PrivateKey privateKey = newEcPrivateKey();\n\n        byte[] serializedPrivateKey = serialize(privateKey);"}, {"oldText": "    void serializationHooksRestoreEcPrivateKeyState() throws Throwable {\n        ECParameterSpec parameterSpec = p256ParameterSpec();\n        PrivateKey privateKey = ecKeyFactory().generatePrivate(\n                new ECPrivateKeySpec(PRIVATE_VALUE, parameterSpec));\n        PrivateKey targetKey = ecKeyFactory().generatePrivate(\n                new ECPrivateKeySpec(PRIVATE_VALUE.add(BigInteger.ONE), parameterSpec));\n        assertNotEquals(\n                assertInstanceOf(ECPrivateKey.class, privateKey).getS(),\n                assertInstanceOf(ECPrivateKey.class, targetKey).getS());\n\n        byte[] hookPayload = writeUsingSerializationHook(privateKey);", "newText": "    void serializationHooksRestoreEcPrivateKeyState() throws Throwable {\n        PrivateKey privateKey = newEcPrivateKey();\n        PrivateKey targetKey = newEcPrivateKey();\n\n        byte[] hookPayload = writeUsingSerializationHook(privateKey);"}, {"oldText": "    private static ECParameterSpec p256ParameterSpec() throws Exception {\n        AlgorithmParameters parameters = AlgorithmParameters.getInstance(\n                \"EC\", bouncyCastleFipsProvider());\n        parameters.init(new ECGenParameterSpec(\"P-256\"));\n        return parameters.getParameterSpec(ECParameterSpec.class);\n    }\n\n    private static KeyFactory ecKeyFactory() throws Exception {", "newText": "    private static PrivateKey newEcPrivateKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\n                \"EC\", bouncyCastleFipsProvider());\n        keyPairGenerator.initialize(new ECGenParameterSpec(\"P-256\"));\n        return keyPairGenerator.generateKeyPair().getPrivate();\n    }\n\n    private static KeyFactory ecKeyFactory() throws Exception {"}]}
