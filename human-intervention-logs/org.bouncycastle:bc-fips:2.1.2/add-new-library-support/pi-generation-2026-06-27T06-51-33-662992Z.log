rovider();\n        SecretKeySpec key = new SecretKeySpec(AES_KEY, \"AES\");\n        byte[] plaintext = \"authenticated plaintext\".getBytes(StandardCharsets.UTF_8);\n        byte[] ciphertext = encrypt(provider, key, plaintext);\n        ciphertext[ciphertext.length - 1] ^= 0x01;\n\n        Cipher decrypt = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        decrypt.init(Cipher.DECRYPT_MODE, key, new GCMParameterSpec(128, GCM_NONCE));\n\n        AEADBadTagException exception = assertThrows(AEADBadTagException.class, () -> decrypt.doFinal(ciphertext));\n        assertInstanceOf(AEADBadTagException.class, exception);\n    }\n\n    @Test\n    void authenticatedEncryptionRoundTripsWithGcmParameterSpec() throws Exception {\n        Provider provider = new BouncyCastleFipsProvider();\n        SecretKeySpec key = new SecretKeySpec(AES_KEY, \"AES\");\n        byte[] plaintext = \"round trip plaintext\".getBytes(StandardCharsets.UTF_8);\n        byte[] ciphertext = encrypt(provider, key, plaintext);\n\n        Cipher decrypt = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        decrypt.init(Cipher.DECRYPT_MODE, key, new GCMParameterSpec(128, GCM_NONCE));\n\n        assertArrayEquals(plaintext, decrypt.doFinal(ciphertext));\n    }\n\n    private static byte[] encrypt(Provider provider, SecretKeySpec key, byte[] plaintext) throws Exception {\n        Cipher encrypt = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        encrypt.init(Cipher.ENCRYPT_MODE, key, new GCMParameterSpec(128, GCM_NONCE));\n        return encrypt.doFinal(plaintext);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2124, "output": 1386, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 35254, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782543045097, "responseId": "resp_0543505c87b61770016a3f72c5904c8197852abe1ba34c3042"}, "toolResults": [{"ro