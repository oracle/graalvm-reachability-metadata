  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertThrows;
  
  import java.nio.charset.StandardCharsets;
  import java.security.AlgorithmParameters;
  import java.security.Provider;
  import java.security.Security;
  
  import javax.crypto.AEADBadTagException;
  import javax.crypto.Cipher;
  import javax.crypto.spec.GCMParameterSpec;
  import javax.crypto.spec.SecretKeySpec;
  
  import org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;
  import org.junit.jupiter.api.Test;
  
  public class ClassUtilTest {
      private static final byte[] AES_KEY = new byte[] {
          0x00, 0x01, 0x02, 0x03,
          0x04, 0x05, 0x06, 0x07,
          0x08, 0x09, 0x0a, 0x0b,
          0x0c, 0x0d, 0x0e, 0x0f
      };
      private static final byte[] GCM_NONCE = new byte[] {
          0x10, 0x11, 0x12, 0x13,
          0x14, 0x15, 0x16, 0x17,
          0x18, 0x19, 0x1a, 0x1b
      };
  
      @Test
      void authenticatedDecryptionFailureUsesAeadBadTagException() throws Exception {
          Provider provider = installProvider();
          SecretKeySpec key = new SecretKeySpec(AES_KEY, "AES");
          byte[] plaintext = "authenticated plaintext".getBytes(StandardCharsets.UTF_8);
          byte[] ciphertext = encrypt(provider, key, plaintext);
          ciphertext[ciphertext.length - 1] ^= 0x01;
  
          Cipher decrypt = newGcmCipher(provider, Cipher.DECRYPT_MODE, key);
  
          assertThrows(AEADBadTagException.class, () -> decrypt.doFinal(ciphertext));
      }
  
      @Test
      void authenticatedDecryptionFailureWithOutputBufferUsesAeadBadTagException() throws Exception {
          Provider provider = installProvider();
          SecretKeySpec key = new SecretKeySpec(AES_KEY, "AES");
          byte[] plaintext = "buffered authenticated plaintext".getBytes(StandardCharsets.UTF_8);
          byte[] ciphertext = encrypt(provider, key, plaintext);
          ciphertext[ciphertext.length - 1] ^= 0x01;
          byte[] output = new byte[plaintext.length];
  
          Cipher decrypt = newGcmCipher(provider, Cipher.DECRYPT_MODE, key);
  
          assertThrows(AEADBadTagException.class, () -> decrypt.doFinal(ciphertext, 0, ciphertext.length, output, 0));
      }
  
      @Test
      void authenticatedEncryptionRoundTripsWithGcmParameterSpec() throws Exception {
          Provider provider = installProvider();
          SecretKeySpec key = new SecretKeySpec(AES_KEY, "AES");
          byte[] plaintext = "round trip plaintext".getBytes(StandardCharsets.UTF_8);
          byte[] ciphertext = encrypt(provider, key, plaintext);
  
          Cipher decrypt = newGcmCipher(provider, Cipher.DECRYPT_MODE, key);
  
          assertArrayEquals(plaintext, decrypt.doFinal(ciphertext));
      }
  
      @Test
      void gcmAlgorithmParametersExposeGcmParameterSpec() throws Exception {
          Provider provider = installProvider();
          SecretKeySpec key = new SecretKeySpec(AES_KEY, "AES");
          Cipher encrypt = newGcmCipher(provider, Cipher.ENCRYPT_MODE, key);
  
          AlgorithmParameters parameters = encrypt.getParameters();
          GCMParameterSpec spec = parameters.getParameterSpec(GCMParameterSpec.class);
  
          assertEquals(128, spec.getTLen());
          assertArrayEquals(GCM_NONCE, spec.getIV());
      }
  
      private static Provider installProvider() {
          Provider provider = Security.getProvider(BouncyCastleFipsProvider.PROVIDER_NAME);
          if (provider == null) {
              Security.addProvider(new BouncyCastleFipsProvider());
              provider = Security.getProvider(BouncyCastleFipsProvider.PROVIDER_NAME);
          }
          assertNotNull(provider);
          return provider;
      }
  
      private static byte[] encrypt(Provider provider, SecretKeySpec key, byte[] plaintext) throws Exception {
          Cipher encrypt = newGcmCipher(provider, Cipher.ENCRYPT_MODE, key);
          return encrypt.doFinal(plaintext);
      }
  
      private static Cipher newGcmCipher(Provider provider, int mode, SecretKeySpec key) throws Exception {
          Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding", provider.getName());
          cipher.init(mode, key, new GCMParameterSpec(128, GCM_NONCE));
          return cipher;
      }
  }
