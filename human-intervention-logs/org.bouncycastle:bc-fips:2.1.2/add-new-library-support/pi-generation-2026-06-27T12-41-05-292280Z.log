      private static void loadClass(String className)
      {
          try
          {
              Class.forName(className);
          }
          catch (ExceptionInInitializerError e)
          {
              if (e.getCause() != null)
              {
                  statusException = e.getCause();
              }
              else
              {
                  statusException = e;
              }
              throw e;
