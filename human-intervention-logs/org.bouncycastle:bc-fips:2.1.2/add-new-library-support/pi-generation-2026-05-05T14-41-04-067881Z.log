  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  import java.io.IOException;
  import java.security.AlgorithmParameters;
  import java.security.Provider;
  import java.security.spec.AlgorithmParameterSpec;
  
  import javax.crypto.spec.GCMParameterSpec;
  
  import org.bouncycastle.asn1.ASN1EncodableVector;
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.DEROctetString;
  import org.bouncycastle.asn1.DERSequence;
  import org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;
  import org.junit.jupiter.api.Test;
  
  public class GcmSpecUtilAnonymous1Test {
      private static final int TAG_LENGTH_BITS = 128;
      private static final int TAG_LENGTH_OCTETS = TAG_LENGTH_BITS / Byte.SIZE;
      private static final byte[] IV = new byte[] {
          0x10, 0x11, 0x12, 0x13,
          0x14, 0x15, 0x16, 0x17,
          0x18, 0x19, 0x1a, 0x1b
      };
  
      @Test
      public void getParameterSpecBuildsJdkGcmParameterSpecFromEncodedGcmParameters() throws Exception {
          Provider provider = new BouncyCastleFipsProvider();
          AlgorithmParameters parameters = AlgorithmParameters.getInstance("GCM", provider);
          parameters.init(encodedGcmParameters());
  
          AlgorithmParameterSpec genericParameterSpec = parameters.getParameterSpec(AlgorithmParameterSpec.class);
          assertNotNull(genericParameterSpec);
  
          GCMParameterSpec parameterSpec = (GCMParameterSpec)genericParameterSpec;
          assertEquals(TAG_LENGTH_BITS, parameterSpec.getTLen());
          assertArrayEquals(IV, parameterSpec.getIV());
      }
  
      private static byte[] encodedGcmParameters() throws IOException {
          ASN1EncodableVector vector = new ASN1EncodableVector(2);
          vector.add(new DEROctetString(IV));
          vector.add(new ASN1Integer(TAG_LENGTH_OCTETS));
  
          return new DERSequence(vector).getEncoded();
      }
  }
