                      Algorithm alg = key.getAlgorithm().equals("Ed448") ? FipsEdEC.Algorithm.Ed448 : FipsEdEC.Algorithm.Ed25519;
                      AsymmetricEdDSAPrivateKey privKey = edPrivateKeyConverter.convertKey(alg, (PrivateKey)key);
