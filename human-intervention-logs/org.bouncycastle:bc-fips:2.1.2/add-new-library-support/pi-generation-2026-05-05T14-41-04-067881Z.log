  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  import java.security.Provider;
  import java.security.spec.X509EncodedKeySpec;
  
  import javax.crypto.SecretKeyFactory;
  import javax.crypto.SecretKeyFactorySpi;
  import javax.crypto.spec.SecretKeySpec;
  
  import org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;
  import org.junit.jupiter.api.Test;
  
  public class BaseSecretKeyFactoryTest {
      private static final byte[] AES_128_KEY = new byte[] {
          0x00, 0x01, 0x02, 0x03,
          0x04, 0x05, 0x06, 0x07,
          0x08, 0x09, 0x0a, 0x0b,
          0x0c, 0x0d, 0x0e, 0x0f
      };
  
      @Test
      public void getKeySpecInstantiatesJdkKeySpecFromValidatedEncodedKey() throws Exception {
          Provider provider = new BouncyCastleFipsProvider();
          Provider.Service service = provider.getService("SecretKeyFactory", "AES");
          assertNotNull(service);
  
          SecretKeyFactorySpi spi = (SecretKeyFactorySpi)service.newInstance(null);
          SecretKeyFactory secretKeyFactory = new DirectSecretKeyFactory(spi, provider, "AES");
          SecretKeySpec secretKey = new SecretKeySpec(AES_128_KEY, "AES");
  
          X509EncodedKeySpec keySpec = (X509EncodedKeySpec)secretKeyFactory.getKeySpec(
                  secretKey,
                  X509EncodedKeySpec.class);
  
          assertNotNull(keySpec);
          assertArrayEquals(AES_128_KEY, keySpec.getEncoded());
          assertEquals("AES", secretKey.getAlgorithm());
      }
  
      private static final class DirectSecretKeyFactory extends SecretKeyFactory {
          DirectSecretKeyFactory(SecretKeyFactorySpi spi, Provider provider, String algorithm) {
              super(spi, provider, algorithm);
          }
      }
  }
