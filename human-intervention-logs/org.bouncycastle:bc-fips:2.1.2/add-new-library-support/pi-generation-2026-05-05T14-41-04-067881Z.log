 "isError": false, "timestamp": 1777992685552}, {"role": "toolResult", "toolCallId": "call_iVBS59Q4EABt29aONsh7ohuC|fc_016d1bfb35594b050169fa03ed4b1c8192bcd07392839f5041", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\nimport static org.junit.jupiter.api.Assertions.assertTrue;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPairGenerator;\nimport java.security.PrivateKey;\nimport java.security.Provider;\nimport java.security.SecureRandom;\nimport java.security.interfaces.XECPrivateKey;\nimport java.security.spec.NamedParameterSpec;\n\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\nimport org.bouncycastle.jcajce.spec.XDHParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class Prov11XDHPrivateKeyTest {\n    private static final String PRIVATE_KEY_CLASS_NAME =\n            \"org.bouncycastle.jcajce.provider.Prov11XDHPrivateKey\";\n    private static final byte[] RANDOM_SEED = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b,\n        0x0c, 0x0d, 0x0e, 0x0f\n    };\n\n    @Test\n    public void serializationRoundTripRestoresX25519PrivateKey() throws Exception {\n        PrivateKey privateKey = generateX25519PrivateKey();\n        assertEquals(PRIVATE_KEY_CLASS_NAME, privateKey.getClass().getName());\n        byte[] encodedPrivateKey = privateKey.getEncoded();\n\n        byte[] serializedKey = serialize(privateKey);\n        PrivateKey restoredPrivateKey = assertInstanceOf(PrivateKey.class, deserialize(serializedKey));\n\n        assertEquals(PRIVATE_KEY_CLASS_NAME, restoredPrivateKey.getClass().getName());\n        assertEquals(\"X25519\", restoredPrivateKey.getAlgorithm());\n        assertEquals(\"PKCS#8\", restoredPrivateKey.getFormat());\n        assertArrayEquals(encodedPrivateKey, restoredPrivateKey.getEncoded());\n\n        XECPrivateKey xecPrivateKey = assertInstanceOf(XECPrivateKey.class, restoredPrivateKey);\n        NamedParameterSpec params = assertInstanceOf(NamedParameterSpec.class, xecPrivateKey.getParams());\n        assertEquals(NamedParameterSpec.X25519.getName(), params.getName());\n        assertTrue(xecPrivateKey.getScalar().isPresent());\n    }\n\n    private static PrivateKey generateX25519PrivateKey() throws Exception {\n        Provider provider = new BouncyCastleFipsProvider();\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"X25519\", provider);\n        keyPairGenerator.initialize(\n                new XDHParameterSpec(XDHParameterSpec.X25519),\n                new SecureRandom(RANDOM_SEED));\n        return keyPairGenerator.generateKeyPair().getPrivate();\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws Exception {\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {\n            return objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777992685553}, {"role": "toolResult", "toolCallId": "call_7jSXjMpRAV1zJu4a