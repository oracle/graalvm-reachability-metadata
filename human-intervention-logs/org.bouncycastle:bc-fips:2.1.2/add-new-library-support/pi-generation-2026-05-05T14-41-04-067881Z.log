erSpec);\n            byte[] decrypted = decryptCipher.doFinal(ciphertext);\n            assertArrayEquals(plaintext, decrypted);\n\n            byte[] tamperedCiphertext = Arrays.copyOf(ciphertext, ciphertext.length);\n            tamperedCiphertext[tamperedCiphertext.length - 1] ^= 0x01;\n\n            Cipher tamperedDecryptCipher = Cipher.getInstance(\"GCM\", BouncyCastleFipsProvider.PROVIDER_NAME);\n            tamperedDecryptCipher.init(Cipher.DECRYPT_MODE, key, parameterSpec);\n            AEADBadTagException exception = assertThrows(\n                    AEADBadTagException.class,\n                    () -> tamperedDecryptCipher.doFinal(tamperedCiphertext));\n            assertNotNull(exception.getMessage());\n        } finally {\n            Security.removeProvider(BouncyCastleFipsProvider.PROVIDER_NAME);\n            restoreProperty(NATIVE_VARIANT_PROPERTY, previousNativeVariant);\n        }\n    }\n\n    private static void restoreProperty(String propertyName, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(propertyName);\n        } else {\n            System.setProperty(propertyName, previousValue);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777992031314}, {"role": "toolResult", "toolCallId": "call_xfgtf2KyWOq07pEPexqrqpZH|fc_016d1bfb35594b050169fa015efd0881928c2fd3ecda0d2d6a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\n\nimport java.security.Provider;\nimport java.security.spec.X509EncodedKeySpec;\n\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.SecretKeyFactorySpi;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BaseSecretKeyFactoryTest {\n    private static final byte[] AES_128_KEY = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b,\n        0x0c, 0x0d, 0x0e, 0x0f\n    };\n\n    @Test\n    public void getKeySpecInstantiatesJdkKeySpecFromValidatedEncodedKey() throws Exception {\n        Provider provider = new BouncyCastleFipsProvider();\n        Provider.Service service = provider.getService(\"SecretKeyFactory\", \"AES\");\n        assertNotNull(service);\n\n        SecretKeyFactorySpi spi = (SecretKeyFactorySpi)service.newInstance(null);\n        SecretKeyFactory secretKeyFactory = new DirectSecretKeyFactory(spi, provider, \"AES\");\n        SecretKeySpec secretKey = new SecretKeySpec(AES_128_KEY, \"AES\");\n\n        X509EncodedKeySpec keySpec = (X509EncodedKeySpec)secretKeyFactory.getKeySpec(\n                secretKey,\n                X509EncodedKeySpec.class);\n\n        assertNotNull(keySpec);\n        assertArrayEquals(AES_128_KEY, keySpec.getEncoded());\n        assertEquals(\"AES\", secretKey.getAlgorithm());\n    }\n\n    private static final class DirectSecretKeyFactory extends SecretKeyFactory {\n        DirectSecretKeyFactory(SecretKeyFactorySpi spi, Provider provider, String algorithm) {\n            super(spi, provider, algorithm);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777992031314}, {"role": "toolResult", "toolCallId": "call_H2ioHbvEr2SaZRBthPTYPvq5|fc_016d1bfb35594b050169fa015efd148192a0ffa67353fdf253", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\n\nimport java.io.IOException;\nimport java.security.AlgorithmParameters;\nimport java.security.Provider;\nimport java.security.spec.AlgorithmParameterSpec;\n\nimport javax.crypto.spec.GCMParameterSpec;\n\nimport org.bouncycastle.asn1.ASN1EncodableVector;\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.DEROctetString;\nimport org.bouncycastle.asn1.DERSequence;\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class GcmSpecUtilAnonymous1Test {\n    private static final int TAG_LENGTH_BITS = 128;\n    private static final int TAG_LENGTH_OCTETS = TAG_LENGTH_BITS / Byte.SIZE;\n    private static final byte[] IV = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1a, 0x1b\n    };\n\n    @Test\n    public void getParameterSpecBuildsJdkGcmParameterSpecFromEncodedGcmParameters() throws Exception {\n        Provider provider = new BouncyCastleFipsProvider();\n        AlgorithmParameters parameters = AlgorithmParameters.getInstance(\"GCM\", provider);\n        parameters.init(encodedGcmParameters());\n\n        AlgorithmParameterSpec genericParameterSpec = parameters.getParameterSpec(AlgorithmParameterSpec.class);\n        assertNotNull(genericParameterSpec);\n\n        GCMParameterSpec parameterSpec = (GCMParameterSpec)genericParameterSpec;\n        assertEquals(TAG_LENGTH_BITS, parameterSpec.getTLen());\n        assertArrayEquals(IV, parameterSpec.getIV());\n    }\n\n    private static byte[] encodedGcmParameters() throws IOException {\n        ASN1EncodableVector vector = new ASN1EncodableVector(2);\n        vector.add(new DEROctetString(IV));\n        vector.add(new ASN1Integer(TAG_LENGTH_OCTETS));\n\n        return new DERSequence(vector).getEncoded();\n    }\n}\n"}], "isError": false, "timestamp": 1777992031314}]}
