er, implement your test\");\n    }\n}\n"}], "isError": false, "timestamp": 1777991140338}, {"role": "toolResult", "toolCallId": "call_eTpE9NpaDcj60UN4opJdV6vF|fc_0d6f61bcd1959db20169f9fde416f08197b349487eb41f8be1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNotNull;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\n\nimport javax.crypto.spec.ChaCha20ParameterSpec;\n\nimport org.bouncycastle.asn1.ASN1Primitive;\nimport org.bouncycastle.asn1.DEROctetString;\nimport org.junit.jupiter.api.Test;\n\npublic class ChaCha20SpecUtilAnonymous1Test {\n    private static final byte[] NONCE = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b\n    };\n\n    @Test\n    public void extractChaCha20SpecBuildsJdkParameterSpecFromAsn1Nonce() throws Exception {\n        assertJdkChaCha20ParameterSpecConstructorIsAvailable();\n\n        ChaCha20ParameterSpec parameterSpec = extractChaCha20Spec(new DEROctetString(NONCE).toASN1Primitive());\n\n        assertNotNull(parameterSpec);\n        assertArrayEquals(NONCE, parameterSpec.getNonce());\n        assertEquals(0, parameterSpec.getCounter());\n    }\n\n    private static void assertJdkChaCha20ParameterSpecConstructorIsAvailable() throws Exception {\n        Constructor<ChaCha20ParameterSpec> constructor = ChaCha20ParameterSpec.class.getConstructor(\n                byte[].class,\n                int.class);\n        ChaCha20ParameterSpec parameterSpec = constructor.newInstance(NONCE, 0);\n\n        assertArrayEquals(NONCE, parameterSpec.getNonce());\n        assertEquals(0, parameterSpec.getCounter());\n    }\n\n    private static ChaCha20ParameterSpec extractChaCha20Spec(ASN1Primitive spec) throws Exception {\n        Class<?> specUtilClass = Class.forName(\"org.bouncycastle.jcajce.provider.ChaCha20SpecUtil\");\n        Method extractMethod = specUtilClass.getDeclaredMethod(\"extractChaCha20Spec\", ASN1Primitive.class);\n        extractMethod.setAccessible(true);\n        try {\n            return (ChaCha20ParameterSpec)extractMethod.invoke(null, spec);\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause();\n            if (cause instanceof Exception nestedException) {\n                throw nestedException;\n            }\n            if (cause instanceof Error error) {\n                throw error;\n            }\n            throw exception;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777991140338}, {"role": "toolResult", "toolCallId": "call_VMwfcIDgviUf4BPHFTT4QYrZ|fc_0d6f61bcd1959db20169f9fde4170081978df22cce7f53d123", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nString nativeVariantProperty = \"org.bouncycastle.native.cpu_variant\"\nString nativeLoaderTestVariant = \"missing-test-variant\"\nString osArchProperty = \"os.arch\"\nString osNameProperty = \"os.name\"\n\ntasks.withType(Test).configureEach {\n    exclude '**/ChaCha20SpecUtilAnonymous1Feature.class'\n    systemProperty nativeVariantProperty, nativeLoaderTestVariant\n    systemProperty osArchProperty, \"amd64\"\n    systemProperty osNameProperty, \"Linux\"\n}\n\ndependen