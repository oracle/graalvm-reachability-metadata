  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  String nativeVariantProperty = "org.bouncycastle.native.cpu_variant"
  String nativeLoaderTestVariant = "missing-test-variant"
  String osArchProperty = "os.arch"
  String osNameProperty = "os.name"
  
  tasks.withType(Test).configureEach {
      exclude '**/ChaCha20SpecUtilAnonymous1Feature.class'
      exclude '**/GcmSpecUtilAnonymous1Feature.class'
      systemProperty nativeVariantProperty, nativeLoaderTestVariant
      systemProperty osArchProperty, "amd64"
      systemProperty osNameProperty, "Linux"
  }
  
  dependencies {
      testImplementation "org.bouncycastle:bc-fips:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testCompileOnly 'org.graalvm.sdk:nativeimage:24.2.2'
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add('--features=org_bouncycastle.bc_fips.ChaCha20SpecUtilAnonymous1Feature,org_bouncycastle.bc_fips.GcmSpecUtilAnonymous1Feature')
              runtimeArgs("-D${nativeVariantProperty}=${nativeLoaderTestVariant}")
              runtimeArgs("-D${osArchProperty}=amd64")
              runtimeArgs("-D${osNameProperty}=Linux")
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
