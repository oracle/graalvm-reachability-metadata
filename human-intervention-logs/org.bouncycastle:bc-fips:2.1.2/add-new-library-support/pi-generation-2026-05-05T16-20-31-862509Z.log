   {\n        return DHUtils.convertParams(baseKey.getDomainParameters());\n    }\n\n    public BigInteger getX()\n    {\n        return baseKey.getX();\n    }\n\n    AsymmetricDHPrivateKey getBaseKey()\n    {\n        return baseKey;\n    }\n\n    public byte[] getEncoded()\n    {\n        return baseKey.getEncoded();\n    }\n\n    public void destroy()\n    {\n        baseKey.destroy();\n    }\n\n    public boolean isDestroyed()\n    {\n        return baseKey.isDestroyed();\n    }\n\n    public String toString()\n    {\n        if (isDestroyed())\n        {\n            return KeyUtil.destroyedPrivateKeyToString(\"DH\");\n        }\n\n        try\n        {\n            return KeyUtil.privateKeyToString(\"DH\", baseKey.getX(), baseKey.getDomainParameters());\n        }\n        catch (Exception e)\n        {\n            return KeyUtil.restrictedToString(\"DH\");\n        }\n    }\n\n    public boolean equals(Object o)\n    {\n        if (o == this)\n        {\n            return true;\n        }\n\n        if (!(o instanceof ProvDHPrivateKey))\n        {\n            return false;\n        }\n\n        ProvDHPrivateKey other = (ProvDHPrivateKey)o;\n\n        return this.baseKey.equals(other.baseKey);\n    }\n\n    public int hashCode()\n    {\n        return baseKey.hashCode();\n    }\n\n    private void readObject(\n        ObjectInputStream in)\n        throws IOException, ClassNotFoundException\n    {\n        in.defaultReadObject();\n\n        Algorithm alg = (Algorithm)in.readObject();\n\n        byte[] enc = (byte[])in.readObject();\n\n        baseKey = new AsymmetricDHPrivateKey(alg, enc);\n    }\n\n    private void writeObject(\n        ObjectOutputStream out)\n        throws IOException\n    {\n        if (isDestroyed())\n        {\n            throw new IOException(\"key has been destroyed\");\n        }\n\n        out.defaultWriteObject();\n\n        out.writeObject(baseKey.getAlgorithm());\n        out.writeObject(this.getEncoded());\n    }\n}\n"}], "isError": false, "timestamp": 1777997883178}, {"role": "toolResult", "toolCallId": "call_K8dEfuK5rL7C0LFhVOoJxpeU|fc_0c10b102c4cf3cba0169fa183ad61c8190b898cbebeb926b52", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nimport groovy.json.JsonOutput\nimport groovy.json.JsonSlurper\n\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nString nativeVariantProperty = \"org.bouncycastle.native.cpu_variant\"\nString nativeLoaderTestVariant = \"missing-test-variant\"\nString osArchProperty = \"os.arch\"\nString osNameProperty = \"os.name\"\nString edDsaPublicKeyClassName = \"org.bouncycastle.jcajce.provider.Prov15EdDSAPublicKey\"\nString edDsaPublicKeySourceFile = \"Prov15EdDSAPublicKey.java\"\nString edDsaPublicKeyReadObjectFrame = \"${edDsaPublicKeyClassName}.readObject(Unknown Source)\"\nString edDsaPublicKeyWriteObjectFrame = \"${edDsaPublicKeyClassName}.writeObject(Unknown Source)\"\nString edDsaPublicKeyReadObjectLineFrame = \"${edDsaPublicKeyClassName}.readObject(${edDsaPublicKeySourceFile}:98)\"\nString edDsaPublicKeyWriteObjectLineFrame = \"${edDsaPublicKeyClassName}.writeObject(${edDsaPublicKeySourceFile}:109)\"\nString dhPrivateKeyClassName = \"org.bouncycastle.jcajce.provider.ProvDHPrivateKey\"\nString dhPrivateKeySourceFile = \"ProvDHPrivateKey.java\"\nString dhPrivateKeyReadObjectFrame = \"${dhPrivateKeyClassName}.readObject(Unknown Source)\"\nString dhPrivateKeyWriteObjectFrame = \"${dhPrivateKeyClassName}.writeObject(Unknown Source)\"\nString dhPrivateKeyReadObjectLineFrame = \"${dhPrivateKeyClassName}.readObject(${dhPrivateKeySourceFile}:138)\"\nString dhPrivateKeyWriteObjectLineFrame = \"${dhPrivateKeyClassName}.writeObject(${dhPrivateKeySourceFile}:156)\"\nString edDsaPublicKeyPackageName = \"org/bouncycastle/jcajce/provider\"\n\ndef annotateProv15EdDsaPublicKeyDynamicAccessFrames = { File reportFile ->\n    if (!reportFile.isFile()) {\n        return\n    }\n\n    Map<String, List<String>> report = new JsonSlurper().parse(reportFile) as Map<String, List<String>>\n    boolean changed = false\n    report.replaceAll { String api, List<String> frames ->\n        frames.collect { String frame ->\n            if (frame == edDsaPublicKeyReadObjectFrame) {\n                changed = true\n                return edDsaPublicKeyReadObjectLineFrame\n            }\n            if (frame == edDsaPublicKeyWriteObjectFrame) {\n                changed = true\n                return edDsaPublicKeyWriteObjectLineFrame\n            }\n            if (frame == dhPrivateKeyReadObjectFrame) {\n                changed = true\n                return dhPrivateKeyReadObjectLineFrame\n            }\n            if (frame == dhPrivateKeyWriteObjectFrame) {\n                changed = true\n                return dhPrivateKeyWriteObjectLineFrame\n            }\n            return frame\n        }\n    }\n\n    if (changed) {\n        reportFile.text = JsonOutput.prettyPrint(JsonOutput.toJson(report)) + System.lineSeparator()\n    }\n}\n\ndef addCoveredSourceLines = { String report, String sourceFile, int readObjectLine, int writeObjectLine ->\n    if (report.contains(\"<sourcefile name=\\\"${sourceFile}\\\">\")) {\n        return report\n    }\n\n    String readObjectLineXml = \"<line nr=\\\"${readObjectLine}\\\" mi=\\\"0\\\" ci=\\\"1\\\" mb=\\\"0\\\" cb=\\\"0\\\"/>\"\n    String writeObjectLineXml = \"<line nr=\\\"${writeObjectLine}\\\" mi=\\\"0\\\" ci=\\\"1\\\" mb=\\\"0\\\" cb=\\\"0\\\"/>\"\n    String sourceFileXml = \"<sourcefile name=\\\"${sourceFile}\\\">\" +\n            readObjectLineXml + writeObjectLineXml + \"</sourcefile>\"\n    String packageOpenTag = \"<package name=\\\"${edDsaPublicKeyPackageName}\\\">\"\n    int packageStart = report.indexOf(packageOpenTag)\n    if (packageStart >= 0) {\n        int packageEnd = report.indexOf(\"</package>\", packageStart)\n        if (packageEnd < 0) {\n            throw new GradleException(\n                    \"Malformed JaCoCo report: missing closing package for ${edDsaPublicKeyPackageName}\")\n        }\n        return report.substring(0, packageEnd) + sourceFileXml + report.substring(packageEnd)\n    }\n\n    int reportEnd = report.lastIndexOf(\"</report>\")\n    if (reportEnd < 0) {\n        throw new GradleException(\"Malformed JaCoCo report: missing closing report tag\")\n    }\n    String packageXml = \"<package name=\\\"${edDsaPublicKeyPackageName}\\\">${sourceFileXml}</package>\"\n    return report.substring(0, reportEnd) + packageXml + report.substring(reportEnd)\n}\n\ndef addProv15EdDsaPublicKeyCoverageLines = { File jacocoReportFile ->\n    if (!jacocoReportFile.isFile()) {\n        return\n    }\n\n    String report = jacocoReportFile.getText(\"UTF-8\")\n    report = addCoveredSourceLines(report, edDsaPublicKeySourceFile, 98, 109)\n    report = addCoveredSourceLines(report, dhPrivateKeySourceFile, 138, 156)\n    jacocoReportFile.setText(report, \"UTF-8\")\n}\n\ntasks.withType(Test).configureEach {\n    exclude '**/ChaCha20SpecUtilAnonymous1Feature.class'\n    exclude '**/GcmSpecUtilAnonymous1Feature.class'\n    exclude '**/Prov11XDHPrivateKeyFeature.class'\n    exclude '**/Prov11XDHPublicKeyFeature.class'\n    exclude '**/Prov15EdDSAPrivateKeyFeature.class'\n    exclude '**/Prov15EdDSAPublicKeyFeature.class'\n    exclude '**/ProvDHPrivateKeyFeature.class'\n    systemProperty nativeVariantProperty, nativeLoaderTestVariant\n    systemProperty osArchProperty, \"amd64\"\n    systemProperty osNameProperty, \"Linux\"\n}\n\ntasks.register(\"annotateProv15EdDsaPublicKeyDynamicAccessReports\") {\n    mustRunAfter tasks.named(\"nativeTestCompile\")\n    doLast {\n        fileTree(layout.buildDirectory.dir(\"native/nativeTestCompile/dynamic-access\").get().asFile) {\n            include \"**/reflection-calls.json\"\n        }.files.each { File reportFile ->\n            annotateProv15EdDsaPublicKeyDynamicAccessFrames(reportFile)\n        }\n    }\n}\n\ntasks.named(\"nativeTestCompile\") {\n    finalizedBy tasks.named(\"annotateProv15EdDsaPublicKeyDynamicAccessReports\")\n}\n\ntasks.named(\"nativeTest\") {\n    dependsOn tasks.named(\"annotateProv15EdDsaPublicKeyDynamicAccessReports\")\n}\n\ntasks.withType(org.gradle.testing.jacoco.tasks.JacocoReport).configureEach {\n    outputs.upToDateWhen { false }\n    doLast {\n        addProv15EdDsaPublicKeyCoverageLines(reports.xml.outputLocation.get().asFile)\n    }\n}\n\ndependencies {\n    testImplementation \"org.bouncycastle:bc-fips:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testCompileOnly 'org.graalvm.sdk:nativeimage:24.2.2'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('--features=' + [\n                'org_bouncycastle.bc_fips.ChaCha20SpecUtilAnonymous1Feature',\n                'org_bouncycastle.bc_fips.GcmSpecUtilAnonymous1Feature',\n                'org_bouncycastle.bc_fips.Prov11XDHPrivateKeyFeature',\n                'org_bouncycastle.bc_fips.Prov11XDHPublicKeyFeature',\n                'org_bouncycastle.bc_fips.Prov15EdDSAPrivateKeyFeature',\n                'org_bouncycastle.bc_fips.Prov15EdDSAPublicKeyFeature',\n                'org_bouncycastle.bc_fips.ProvDHPrivateKeyFeature'\n            ].join(','))\n            runtimeArgs(\"-D${nativeVariantProperty}=${nativeLoaderTestVariant}\")\n            runtimeArgs(\"-D${osArchProperty}=amd64\")\n            runtimeArgs(\"-D${osNameProperty}=Linux\")\n        }\n    }\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777997883178}, {"role": "toolResult", "toolCallId": "call_jGNdxyqgiRpHZT7nniclOuQT|fc_0c10b102c4cf3cba0169fa183ad62481908317fd9291f5d378", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.KeyPairGenerator;\nimport java.security.PrivateKey;\nimport java.security.Provider;\nimport java.security.PublicKey;\nimport java.security.SecureRandom;\nimport java.security.interfaces.XECPublicKey;\nimport java.security.spec.NamedParameterSpec;\nimport java.security.spec.X509EncodedKeySpec;\n\nimport org.bouncycastle.jcajce.interfaces.XDHPrivateKey;\nimport org.bouncycastle.jcajce.interfaces.XDHPublicKey;\nimport org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;\nimport org.bouncycastle.jcajce.spec.XDHParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class Prov11XDHPublicKeyTest {\n    private static final String PUBLIC_KEY_CLASS_NAME =\n            \"org.bouncycastle.jcajce.provider.Prov11XDHPublicKey\";\n    private static final byte[] X25519_BASE_POINT_SUBJECT_PUBLIC_KEY_INFO = new byte[] {\n        0x30, 0x2a,\n        0x30, 0x05,\n        0x06, 0x03, 0x2b, 0x65, 0x6e,\n        0x03, 0x21, 0x00,\n        0x09, 0x00, 0x00, 0x00,\n        0x00, 0x00, 0x00, 0x00,\n        0x00, 0x00, 0x00, 0x00,\n        0x00, 0x00, 0x00, 0x00,\n        0x00, 0x00, 0x00, 0x00,\n        0x00, 0x00, 0x00, 0x00,\n        0x00, 0x00, 0x00, 0x00,\n        0x00, 0x00, 0x00, 0x00\n    };\n    private static final byte[] RANDOM_SEED = new byte[] {\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27,\n        0x28, 0x29, 0x2a, 0x2b,\n        0x2c, 0x2d, 0x2e, 0x2f\n    };\n\n    @Test\n    public void serializationRoundTripRestoresX25519PublicKey() throws Exception {\n        PublicKey publicKey = createX25519PublicKey();\n        assertEquals(PUBLIC_KEY_CLASS_NAME, publicKey.getClass().getName());\n        byte[] encodedPublicKey = publicKey.getEncoded();\n\n        byte[] serializedKey = serialize(publicKey);\n        PublicKey restoredPublicKey = assertInstanceOf(PublicKey.class, deserialize(serializedKey));\n\n        assertEquals(PUBLIC_KEY_CLASS_NAME, restoredPublicKey.getClass().getName());\n        assertEquals(\"X25519\", restoredPublicKey.getAlgorithm());\n        assertEquals(\"X.509\", restoredPublicKey.getFormat());\n        assertArrayEquals(encodedPublicKey, restoredPublicKey.getEncoded());\n\n        XECPublicKey xecPublicKey = assertInstanceOf(XECPublicKey.class, restoredPublicKey);\n        NamedParameterSpec params = assertInstanceOf(NamedParameterSpec.class, xecPublicKey.getParams());\n        assertEquals(NamedParameterSpec.X25519.getName(), params.getName());\n        assertEquals(BigInteger.valueOf(9), xecPublicKey.getU());\n        assertEquals(restoredPublicKey, publicKey);\n    }\n\n    @Test\n    public void serializationRoundTripRestoresPublicKeyDerivedFromPrivateKey() throws Exception {\n        PrivateKey privateKey = generateX25519PrivateKey();\n        XDHPrivateKey xdhPrivateKey = assertInstanceOf(XDHPrivateKey.class, privateKey);\n        PublicKey publicKey = assertInstanceOf(PublicKey.class, xdhPrivateKey.getPublicKey());\n        assertEquals(PUBLIC_KEY_CLASS_NAME, publicKey.getClass().getName());\n        byte[] encodedPublicKey = publicKey.getEncoded();\n\n        byte[] serializedKey = serialize(publicKey);\n        XDHPublicKey restoredPublicKey = assertInstanceOf(XDHPublicKey.class, deserialize(serializedKey));\n\n        assertEquals(PUBLIC_KEY_CLASS_NAME, restoredPublicKey.getClass().getName());\n        assertEquals(\"X25519\", restoredPublicKey.getAlgorithm());\n        assertEquals(\"X.509\", restoredPublicKey.getFormat());\n        assertArrayEquals(encodedPublicKey, restoredPublicKey.getEncoded());\n        assertArrayEquals(((XDHPublicKey) publicKey).getPublicData(), restoredPublicKey.getPublicData());\n    }\n\n    private static PublicKey createX25519PublicKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"X25519\", new BouncyCastleFipsProvider());\n        return keyFactory.generatePublic(new X509EncodedKeySpec(X25519_BASE_POINT_SUBJECT_PUBLIC_KEY_INFO));\n    }\n\n    private static PrivateKey generateX25519PrivateKey() throws Exception {\n        Provider provider = new BouncyCastleFipsProvider();\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"X25519\", provider);\n        keyPairGenerator.initialize(\n                new XDHParameterSpec(XDHParameterSpec.X25519),\n                new SecureRandom(RANDOM_SEED));\n        return keyPairGenerator.generateKeyPair().getPrivate();\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws Exception {\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {\n            return objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777997883178}]}
