      \"org.bouncycastle.jcajce.provider.ProvDHPrivateKey\";\n    private static final BigInteger RFC3526_2048_BIT_MODP_GROUP_PRIME = new BigInteger(\"\"\"\n            FFFFFFFFFFFFFFFFC90FDAA22168C234C4C6628B80DC1CD1\n            29024E088A67CC74020BBEA63B139B22514A08798E3404DD\n            EF9519B3CD3A431B302B0A6DF25F14374FE1356D6D51C245\n            E485B576625E7EC6F44C42E9A637ED6B0BFF5CB6F406B7ED\n            EE386BFB5A899FA5AE9F24117C4B1FE649286651ECE45B3D\n            C2007CB8A163BF0598DA48361C55D39A69163FA8FD24CF5F\n            83655D23DCA3AD961C62F356208552BB9ED529077096966D\n            670C354E4ABC9804F1746C08CA18217C32905E462E36CE3B\n            E39E772C180E86039B2783A2EC07A28FB5C55DF06F4C52C9\n            DE2BCBF6955817183995497CEA956AE515D2261898FA0510\n            15728E5A8AACAA68FFFFFFFFFFFFFFFF\n            \"\"\".replaceAll(\"\\\\s\", \"\"), 16);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(2L);\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"\"\"\n            5A3F931B9C42E7D00B99F5C3A6E1D840\n            8246F0E922178C5B4F612C4BE93D78A1\n            \"\"\".replaceAll(\"\\\\s\", \"\"), 16);\n\n    @Test\n    public void serializationRoundTripRestoresDhPrivateKey() throws Exception {\n        PrivateKey privateKey = generateDhPrivateKey();\n        assertEquals(PRIVATE_KEY_CLASS_NAME, privateKey.getClass().getName());\n        DHPrivateKey originalDhPrivateKey = assertInstanceOf(DHPrivateKey.class, privateKey);\n        byte[] encodedPrivateKey = privateKey.getEncoded();\n\n        byte[] serializedKey = serialize(privateKey);\n        PrivateKey restoredPrivateKey = assertInstanceOf(PrivateKey.class, deserialize(serializedKey));\n\n        assertEquals(PRIVATE_KEY_CLASS_NAME, restoredPrivateKey.getClass().getName());\n        assertEquals(\"DH\", restoredPrivateKey.getAlgorithm());\n        assertEquals(\"PKCS#8\", restoredPrivateKey.getFormat());\n        assertArrayEquals(encodedPrivateKey, restoredPrivateKey.getEncoded());\n        assertEquals(privateKey, restoredPrivateKey);\n\n        DHPrivateKey restoredDhPrivateKey = assertInstanceOf(DHPrivateKey.class, restoredPrivateKey);\n        assertEquals(originalDhPrivateKey.getX(), restoredDhPrivateKey.getX());\n        assertEquals(RFC3526_2048_BIT_MODP_GROUP_PRIME, restoredDhPrivateKey.getParams().getP());\n        assertEquals(GENERATOR, restoredDhPrivateKey.getParams().getG());\n    }\n\n    private static PrivateKey generateDhPrivateKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DH\", new BouncyCastleFipsProvider());\n        return keyFactory.generatePrivate(new DHPrivateKeySpec(\n                PRIVATE_VALUE,\n                RFC3526_2048_BIT_MODP_GROUP_PRIME,\n                GENERATOR));\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws Exception {\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {\n            return objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777997879497}, {"role": "toolResult", "toolCallId": "call_9hc4hOSyHjXNkKB3SoZIViHf|fc_0c10b102c4cf3cba0169fa18370f2c81909bae53a7b00f6fbc", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bc_fips;\n\nimport org.graalvm.nativeimage.hosted.Feature;\nimport org