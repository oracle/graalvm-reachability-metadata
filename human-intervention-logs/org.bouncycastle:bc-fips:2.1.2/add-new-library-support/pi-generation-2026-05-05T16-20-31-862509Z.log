61C62F356208552BB9ED529077096966D\n            670C354E4ABC9804F1746C08CA18217C32905E462E36CE3B\n            E39E772C180E86039B2783A2EC07A28FB5C55DF06F4C52C9\n            DE2BCBF6955817183995497CEA956AE515D2261898FA0510\n            15728E5A8AACAA68FFFFFFFFFFFFFFFF\n            \"\"\".replaceAll(\"\\\\s\", \"\"), 16);\n    private static final BigInteger GENERATOR = BigInteger.valueOf(2L);\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"\"\"\n            5A3F931B9C42E7D00B99F5C3A6E1D840\n            8246F0E922178C5B4F612C4BE93D78A1\n            \"\"\".replaceAll(\"\\\\s\", \"\"), 16);\n    private static final BigInteger PUBLIC_VALUE =\n            GENERATOR.modPow(PRIVATE_VALUE, RFC3526_2048_BIT_MODP_GROUP_PRIME);\n\n    @Test\n    public void serializationRoundTripRestoresDhPublicKey() throws Exception {\n        PublicKey publicKey = generateDhPublicKey();\n        assertEquals(PUBLIC_KEY_CLASS_NAME, publicKey.getClass().getName());\n        DHPublicKey originalDhPublicKey = assertInstanceOf(DHPublicKey.class, publicKey);\n        byte[] encodedPublicKey = publicKey.getEncoded();\n\n        byte[] serializedKey = serialize(publicKey);\n        PublicKey restoredPublicKey = assertInstanceOf(PublicKey.class, deserialize(serializedKey));\n\n        assertEquals(PUBLIC_KEY_CLASS_NAME, restoredPublicKey.getClass().getName());\n        assertEquals(\"DH\", restoredPublicKey.getAlgorithm());\n        assertEquals(\"X.509\", restoredPublicKey.getFormat());\n        assertArrayEquals(encodedPublicKey, restoredPublicKey.getEncoded());\n        assertEquals(publicKey, restoredPublicKey);\n\n        DHPublicKey restoredDhPublicKey = assertInstanceOf(DHPublicKey.class, restoredPublicKey);\n        assertEquals(originalDhPublicKey.getY(), restoredDhPublicKey.getY());\n        assertEquals(PUBLIC_VALUE, restoredDhPublicKey.getY());\n        assertEquals(RFC3526_2048_BIT_MODP_GROUP_PRIME, restoredDhPublicKey.getParams().getP());\n        assertEquals(GENERATOR, restoredDhPublicKey.getParams().getG());\n    }\n\n    private static PublicKey generateDhPublicKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DH\", new BouncyCastleFipsProvider());\n        return keyFactory.generatePublic(new DHPublicKeySpec(\n                PUBLIC_VALUE,\n                RFC3526_2048_BIT_MODP_GROUP_PRIME,\n                GENERATOR));\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws Exception {\n        ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {\n            return objectInputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 871, "output": 1346, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 32425, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777997923160, "responseId": "resp_0c10b102c4cf3cba0169fa1863a90c819081321c3cc71a09e7"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_b56dD062RKqmChP0CaYVfV0Y|fc_0c10b102c4cf3cba0169fa1866119c8190be2f3415a1128821", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4477 bytes to tests/src/org.bouncycastle/bc-fips/2.1.2/src/test/java/org_bouncycastle/bc_fips/ProvDHPublicKeyTest.java"}], "isError": false, "timestamp": 1777997932225}]}
