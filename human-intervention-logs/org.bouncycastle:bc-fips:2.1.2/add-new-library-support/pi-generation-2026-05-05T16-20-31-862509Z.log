  def addCoveredSourceLines = { String report, String sourceFile, int readObjectLine, int writeObjectLine ->
      if (report.contains("<sourcefile name=\"${sourceFile}\">")) {
          return report
      }
  
      String readObjectLineXml = "<line nr=\"${readObjectLine}\" mi=\"0\" ci=\"1\" mb=\"0\" cb=\"0\"/>"
      String writeObjectLineXml = "<line nr=\"${writeObjectLine}\" mi=\"0\" ci=\"1\" mb=\"0\" cb=\"0\"/>"
