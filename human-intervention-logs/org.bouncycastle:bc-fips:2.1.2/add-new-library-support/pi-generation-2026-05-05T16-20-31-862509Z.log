  package org_bouncycastle.bc_fips;
  
  import org.graalvm.nativeimage.hosted.Feature;
  import org.graalvm.nativeimage.hosted.RuntimeReflection;
  import org.graalvm.nativeimage.hosted.RuntimeSerialization;
  
  public class ProvDHPrivateKeyFeature implements Feature {
      private static final String PRIVATE_KEY_CLASS_NAME =
              "org.bouncycastle.jcajce.provider.ProvDHPrivateKey";
      private static final String FIPS_ALGORITHM_CLASS_NAME =
              "org.bouncycastle.crypto.fips.FipsAlgorithm";
  
      @Override
      public void beforeAnalysis(BeforeAnalysisAccess access) {
          Class<?> privateKeyClass = requireClass(access, PRIVATE_KEY_CLASS_NAME);
          Class<?> fipsAlgorithmClass = requireClass(access, FIPS_ALGORITHM_CLASS_NAME);
  
          RuntimeReflection.registerClassLookup(PRIVATE_KEY_CLASS_NAME);
          RuntimeSerialization.registerWithTargetConstructorClass(privateKeyClass, Object.class);
          RuntimeSerialization.registerWithTargetConstructorClass(fipsAlgorithmClass, Object.class);
          RuntimeSerialization.registerIncludingAssociatedClasses(fipsAlgorithmClass);
          RuntimeSerialization.register(String.class);
      }
  
      private static Class<?> requireClass(BeforeAnalysisAccess access, String className) {
          Class<?> foundClass = access.findClassByName(className);
          if (foundClass == null) {
              throw new IllegalStateException(className + " is unavailable");
          }
          return foundClass;
