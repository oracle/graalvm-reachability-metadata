  import java.util.stream.Stream;
  
  import org.bouncycastle.LICENSE;
  import org.bouncycastle.crypto.fips.FipsStatus;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class NativeLoaderTest {
      private static final String BOUNCY_CASTLE_PACKAGE_NAME = "org.bouncycastle.";
      private static final String FIPS_NATIVE_CLASS_NAME = "org.bouncycastle.crypto.fips.FipsNative";
      private static final String FIPS_STATUS_CLASS_NAME = "org.bouncycastle.crypto.fips.FipsStatus";
      private static final String INSTALL_DIR_PROPERTY = "org.bouncycastle.native.loader.install_dir";
      private static final String NATIVE_VARIANT_PROPERTY = "org.bouncycastle.native.cpu_variant";
      private static final String TEST_VARIANT = "missing-test-variant";
  
      @Test
      public void fipsStatusStartupAttemptsNativeResourceLoadingForForcedVariant() throws Exception {
          String previousNativeVariant = System.getProperty(NATIVE_VARIANT_PROPERTY);
          String previousInstallDir = System.getProperty(INSTALL_DIR_PROPERTY);
          Path installRoot = Files.createTempDirectory("bc-fips-native-loader");
          System.setProperty(NATIVE_VARIANT_PROPERTY, TEST_VARIANT);
          System.setProperty(INSTALL_DIR_PROPERTY, installRoot.toString());
          try {
              assertIsolatedStartupAttemptsNativeLoading();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              restoreProperty(NATIVE_VARIANT_PROPERTY, previousNativeVariant);
              restoreProperty(INSTALL_DIR_PROPERTY, previousInstallDir);
              deleteRecursively(installRoot);
          }
      }
  
      private static void assertIsolatedStartupAttemptsNativeLoading() throws Exception {
          IsolatedFipsLoader loader = new IsolatedFipsLoader(NativeLoaderTest.class.getClassLoader());
          Class<?> isolatedFipsStatus = loader.loadClass(FIPS_STATUS_CLASS_NAME);
          Method isReady = isolatedFipsStatus.getMethod("isReady");
          assertEquals(Boolean.TRUE, invokeStatic(isReady));
  
          Class<?> isolatedFipsNative = loader.loadClass(FIPS_NATIVE_CLASS_NAME);
          Method isEnabled = isolatedFipsNative.getMethod("isEnabled");
          assertFalse((Boolean) invokeStatic(isEnabled));
      }
  
      private static Object invokeStatic(Method method) throws Exception {
          try {
              return method.invoke(null);
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause();
              if (cause instanceof Error error) {
                  throw error;
              }
              if (cause instanceof Exception nestedException) {
                  throw nestedException;
              }
              throw exception;
          }
      }
  
      private static void restoreProperty(String propertyName, String previousValue) {
          if (previousValue == null) {
              System.clearProperty(propertyName);
          } else {
              System.setProperty(propertyName, previousValue);
          }
      }
  
      private static void deleteRecursively(Path path) throws IOException {
          IOException failure = null;
          try (Stream<Path> paths = Files.walk(path)) {
              for (Path currentPath : paths.sorted(Comparator.reverseOrder()).toList()) {
                  try {
                      Files.deleteIfExists(currentPath);
                  } catch (IOException exception) {
                      if (failure == null) {
                          failure = exception;
                      } else {
                          failure.addSuppressed(exception);
                      }
                  }
              }
          }
          if (failure != null) {
              throw failure;
          }
      }
  
      private static final class IsolatedFipsLoader extends ClassLoader {
          private static final String NATIVE_RESOURCE_PREFIX = "native/linux/x86_64/";
          private static final String PROBE_RESOURCE = NATIVE_RESOURCE_PREFIX + "probe/libbc-probe.so";
          private static final String DEPS_RESOURCE = NATIVE_RESOURCE_PREFIX + "deps.list";
  
          private final Map<String, byte[]> resources = new HashMap<>();
          private final ProtectionDomain protectionDomain;
  
          IsolatedFipsLoader(ClassLoader parent) {
              super(parent);
              resources.put(PROBE_RESOURCE, "test probe placeholder".getBytes(StandardCharsets.UTF_8));
              resources.put(DEPS_RESOURCE, "# no dependencies for the forced test variant\n".getBytes(StandardCharsets.UTF_8));
              protectionDomain = LICENSE.class.getProtectionDomain();
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      loadedClass = loadUncachedClass(name);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private Class<?> loadUncachedClass(String name) throws ClassNotFoundException {
              if (name.startsWith(BOUNCY_CASTLE_PACKAGE_NAME)) {
                  try {
                      return findClass(name);
                  } catch (ClassNotFoundException exception) {
                      return super.loadClass(name, false);
                  }
              }
              return super.loadClass(name, false);
          }
  
          @Override
          public InputStream getResourceAsStream(String name) {
              byte[] resource = resources.get(name);
              if (resource != null) {
                  return new ByteArrayInputStream(resource);
              }
              return super.getResourceAsStream(name);
          }
  
          @Override
          public URL getResource(String name) {
              byte[] resource = resources.get(name);
              if (resource != null) {
                  return createResourceUrl(name, resource);
              }
              return super.getResource(name);
          }
  
          private URL createResourceUrl(String name, byte[] resource) {
              try {
                  return new URL(null, "memory:" + name, new URLStreamHandler() {
                      @Override
                      protected URLConnection openConnection(URL url) {
                          return new URLConnection(url) {
                              @Override
                              public void connect() {
                              }
  
                              @Override
                              public InputStream getInputStream() {
                                  return new ByteArrayInputStream(resource);
                              }
                          };
                      }
                  });
              } catch (IOException exception) {
                  throw new IllegalStateException(exception);
              }
          }
  
          @Override
          protected Class<?> findClass(String name) throws ClassNotFoundException {
              String resourceName = name.replace('.', '/') + ".class";
              try (InputStream input = getParent().getResourceAsStream(resourceName)) {
                  if (input == null) {
                      throw new ClassNotFoundException(name);
                  }
                  byte[] classBytes = input.readAllBytes();
                  return defineClass(name, classBytes, 0, classBytes.length, protectionDomain);
              } catch (IOException exception) {
                  throw new ClassNotFoundException(name, exception);
              }
          }
      }
  }
