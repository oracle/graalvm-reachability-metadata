  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  
  import java.security.Provider;
  import java.security.spec.KeySpec;
  import java.util.Arrays;
  
  import javax.crypto.SecretKeyFactory;
  import javax.crypto.spec.SecretKeySpec;
  
  import org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;
  import org.junit.jupiter.api.Test;
  
  public class BaseSecretKeyFactoryTest {
      private static final byte[] AES_128_KEY = new byte[] {
          0x00, 0x01, 0x02, 0x03,
          0x04, 0x05, 0x06, 0x07,
          0x08, 0x09, 0x0a, 0x0b,
          0x0c, 0x0d, 0x0e, 0x0f
      };
  
      @Test
      public void getKeySpecInstantiatesCustomKeySpecFromValidatedEncodedKey() throws Exception {
          Provider provider = new BouncyCastleFipsProvider();
          SecretKeyFactory secretKeyFactory = SecretKeyFactory.getInstance("AES", provider);
          SecretKeySpec secretKey = new SecretKeySpec(AES_128_KEY, "AES");
  
          EncodedSecretKeySpec keySpec = (EncodedSecretKeySpec)secretKeyFactory.getKeySpec(
                  secretKey,
                  EncodedSecretKeySpec.class);
  
          assertNotNull(keySpec);
          assertArrayEquals(AES_128_KEY, keySpec.getEncoded());
          assertEquals("AES", secretKey.getAlgorithm());
      }
  
      public static final class EncodedSecretKeySpec implements KeySpec {
          private final byte[] encoded;
  
          public EncodedSecretKeySpec(byte[] encoded) {
              this.encoded = Arrays.copyOf(encoded, encoded.length);
          }
  
          byte[] getEncoded() {
              return Arrays.copyOf(encoded, encoded.length);
          }
      }
  }
