  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertFalse;
  import static org.junit.jupiter.api.Assertions.assertNotNull;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.security.AllPermission;
  import java.security.Permission;
  import java.security.Permissions;
  import java.security.ProtectionDomain;
  
  import org.bouncycastle.LICENSE;
  import org.bouncycastle.crypto.fips.FipsStatus;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class FipsStatusTest {
      private static final String NATIVE_VARIANT_PROPERTY = "org.bouncycastle.native.cpu_variant";
      private static final String TEST_VARIANT = "missing-test-variant";
      private static final int SHA256_HMAC_LENGTH = 32;
  
      @Test
      public void fipsStatusInitializesModuleAndReportsReady() {
          String previousNativeVariant = System.getProperty(NATIVE_VARIANT_PROPERTY);
          System.setProperty(NATIVE_VARIANT_PROPERTY, TEST_VARIANT);
          try {
              String markerName = LICENSE.class.getCanonicalName()
                      .replace(".", "/")
                      .replace("LICENSE", "MARKER");
              assertNotNull(LICENSE.class.getClassLoader().getResource(markerName));
  
              byte[] moduleHmac = FipsStatus.getModuleHMAC();
              assertNotNull(moduleHmac);
              assertEquals(SHA256_HMAC_LENGTH, moduleHmac.length);
  
              assertTrue(FipsStatus.isReady(), FipsStatus::getStatusMessage);
              assertEquals(FipsStatus.READY, FipsStatus.getStatusMessage());
              assertFalse(FipsStatus.isErrorStatus());
          } finally {
              if (previousNativeVariant == null) {
                  System.clearProperty(NATIVE_VARIANT_PROPERTY);
              } else {
                  System.setProperty(NATIVE_VARIANT_PROPERTY, previousNativeVariant);
              }
          }
      }
  
      @Test
      public void fipsStatusFallsBackToMarkerResourceLookupWhenProtectionDomainIsDenied() {
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean installed = installSecurityManager(new DenyProtectionDomainSecurityManager());
          try {
              byte[] hmac = FipsStatus.getModuleHMAC();
              assertNotNull(hmac);
              assertEquals(SHA256_HMAC_LENGTH, hmac.length);
          } finally {
              if (installed) {
                  installSecurityManager(previousSecurityManager);
              }
          }
      }
  
      @Test
      public void isolatedFipsStatusInitializationLoadsSelfTestClassByName() throws Exception {
          String previousNativeVariant = System.getProperty(NATIVE_VARIANT_PROPERTY);
          System.setProperty(NATIVE_VARIANT_PROPERTY, "java");
          try {
              assertIsolatedStatusReachesSelfTestClassLoading();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              if (previousNativeVariant == null) {
                  System.clearProperty(NATIVE_VARIANT_PROPERTY);
              } else {
                  System.setProperty(NATIVE_VARIANT_PROPERTY, previousNativeVariant);
              }
          }
      }
  
      private static void assertIsolatedStatusReachesSelfTestClassLoading() throws Exception {
          NullCodeSourceFipsStatusLoader loader = new NullCodeSourceFipsStatusLoader(
                  FipsStatusTest.class.getClassLoader());
          Class<?> isolatedFipsStatus = loader.loadClass("org.bouncycastle.crypto.fips.FipsStatus");
  
          Method isReady = isolatedFipsStatus.getMethod("isReady");
          try {
              assertEquals(Boolean.TRUE, invokeStatic(isReady));
          } catch (IllegalAccessError error) {
              assertNotNull(error);
          }
      }
  
      private static boolean installSecurityManager(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      private static Object invokeStatic(Method method) throws Exception {
          try {
              return method.invoke(null);
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause();
              if (cause instanceof Error error) {
                  throw error;
              }
              if (cause instanceof Exception nestedException) {
                  throw nestedException;
              }
              throw exception;
          }
      }
  
      private static final class NullCodeSourceFipsStatusLoader extends ClassLoader {
          private static final String FIPS_STATUS_CLASS_NAME = "org.bouncycastle.crypto.fips.FipsStatus";
  
          private final ProtectionDomain protectionDomain;
  
          NullCodeSourceFipsStatusLoader(ClassLoader parent) {
              super(parent);
              Permissions permissions = new Permissions();
              permissions.add(new AllPermission());
              protectionDomain = new ProtectionDomain(null, permissions, this, null);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      loadedClass = loadUncachedClass(name);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private Class<?> loadUncachedClass(String name) throws ClassNotFoundException {
              if (name.equals(FIPS_STATUS_CLASS_NAME) || name.startsWith(FIPS_STATUS_CLASS_NAME + "$")) {
                  return findClass(name);
              }
              return super.loadClass(name, false);
          }
  
          @Override
          protected Class<?> findClass(String name) throws ClassNotFoundException {
              String resourceName = name.replace('.', '/') + ".class";
              try (InputStream input = getParent().getResourceAsStream(resourceName)) {
                  if (input == null) {
                      throw new ClassNotFoundException(name);
                  }
                  byte[] classBytes = input.readAllBytes();
                  return defineClass(name, classBytes, 0, classBytes.length, protectionDomain);
              } catch (IOException exception) {
                  throw new ClassNotFoundException(name, exception);
              }
          }
      }
  
      private static final class DenyProtectionDomainSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              if ("getProtectionDomain".equals(permission.getName())) {
                  throw new SecurityException("exercise FipsStatus marker resource fallback");
              }
          }
      }
  }
