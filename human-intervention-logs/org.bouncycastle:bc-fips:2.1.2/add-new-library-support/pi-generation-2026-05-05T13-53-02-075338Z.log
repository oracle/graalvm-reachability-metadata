rithm());\n    }\n\n    public static final class EncodedSecretKeySpec implements KeySpec {\n        private final byte[] encoded;\n\n        public EncodedSecretKeySpec(byte[] encoded) {\n            this.encoded = Arrays.copyOf(encoded, encoded.length);\n        }\n\n        byte[] getEncoded() {\n            return Arrays.copyOf(encoded, encoded.length);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1569, "output": 1022, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 24095, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777989159640, "responseId": "resp_08abf9286dad3a460169f9f629fc7881a2ac1951a23fcb96dd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_mC3P0QbA7wqoEVKi9WlQsFtn|fc_08abf9286dad3a460169f9f631786881a2811098d0e0809a37", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1880 bytes to tests/src/org.bouncycastle/bc-fips/2.1.2/src/test/java/org_bouncycastle/bc_fips/BaseSecretKeyFactoryTest.java"}], "isError": false, "timestamp": 1777989172832}]}
