  package org_bouncycastle.bc_fips;
  
  import static org.junit.jupiter.api.Assertions.assertArrayEquals;
  import static org.junit.jupiter.api.Assertions.assertEquals;
  import static org.junit.jupiter.api.Assertions.assertInstanceOf;
  import static org.junit.jupiter.api.Assertions.assertTrue;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.KeyFactory;
  import java.security.PrivateKey;
  import java.security.interfaces.EdECPrivateKey;
  import java.security.spec.EdECPrivateKeySpec;
  import java.security.spec.NamedParameterSpec;
  
  import org.bouncycastle.jcajce.interfaces.EdDSAPrivateKey;
  import org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider;
  import org.junit.jupiter.api.Test;
  
  public class Prov15EdDSAPrivateKeyTest {
      private static final String PRIVATE_KEY_CLASS_NAME =
              "org.bouncycastle.jcajce.provider.Prov15EdDSAPrivateKey";
      private static final byte[] ED25519_PRIVATE_KEY_BYTES = new byte[] {
          0x00, 0x01, 0x02, 0x03,
          0x04, 0x05, 0x06, 0x07,
          0x08, 0x09, 0x0a, 0x0b,
          0x0c, 0x0d, 0x0e, 0x0f,
          0x10, 0x11, 0x12, 0x13,
          0x14, 0x15, 0x16, 0x17,
          0x18, 0x19, 0x1a, 0x1b,
          0x1c, 0x1d, 0x1e, 0x1f
      };
  
      @Test
      public void serializationRoundTripRestoresEd25519PrivateKey() throws Exception {
          PrivateKey privateKey = generateEd25519PrivateKey();
          assertEquals(PRIVATE_KEY_CLASS_NAME, privateKey.getClass().getName());
          EdDSAPrivateKey originalPrivateKey = assertInstanceOf(
                  EdDSAPrivateKey.class,
                  privateKey);
          byte[] encodedPrivateKey = privateKey.getEncoded();
  
          byte[] serializedKey = serialize(privateKey);
          PrivateKey restoredPrivateKey = assertInstanceOf(
                  PrivateKey.class,
                  deserialize(serializedKey));
  
          assertEquals(PRIVATE_KEY_CLASS_NAME, restoredPrivateKey.getClass().getName());
          assertEquals("Ed25519", restoredPrivateKey.getAlgorithm());
          assertEquals("PKCS#8", restoredPrivateKey.getFormat());
          assertArrayEquals(encodedPrivateKey, restoredPrivateKey.getEncoded());
  
          EdECPrivateKey edEcPrivateKey = assertInstanceOf(
                  EdECPrivateKey.class,
                  restoredPrivateKey);
          NamedParameterSpec params = assertInstanceOf(
                  NamedParameterSpec.class,
                  edEcPrivateKey.getParams());
          assertEquals(NamedParameterSpec.ED25519.getName(), params.getName());
          assertTrue(edEcPrivateKey.getBytes().isPresent());
  
          EdDSAPrivateKey edDsaPrivateKey = assertInstanceOf(
                  EdDSAPrivateKey.class,
                  restoredPrivateKey);
          assertArrayEquals(originalPrivateKey.getPublicData(), edDsaPrivateKey.getPublicData());
      }
  
      private static PrivateKey generateEd25519PrivateKey() throws Exception {
          KeyFactory keyFactory = KeyFactory.getInstance("Ed25519", new BouncyCastleFipsProvider());
          return keyFactory.generatePrivate(new EdECPrivateKeySpec(
                  NamedParameterSpec.ED25519,
                  ED25519_PRIVATE_KEY_BYTES));
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {
              objectOutputStream.writeObject(value);
          }
          return output.toByteArray();
      }
  
      private static Object deserialize(byte[] serializedValue) throws Exception {
          ByteArrayInputStream input = new ByteArrayInputStream(serializedValue);
          try (ObjectInputStream objectInputStream = new ObjectInputStream(input)) {
              return objectInputStream.readObject();
          }
