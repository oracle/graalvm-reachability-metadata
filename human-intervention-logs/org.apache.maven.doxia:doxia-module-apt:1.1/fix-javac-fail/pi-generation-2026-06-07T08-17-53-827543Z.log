      /** Construct a table row. */
      private void buildRowLine()
      {
          StringBuffer rLine = new StringBuffer();
          rLine.append( TABLE_ROW_START_MARKUP );
  
          for ( int i = 0; i < cellCount; i++ )
          {
              if ( cellJustif != null )
              {
