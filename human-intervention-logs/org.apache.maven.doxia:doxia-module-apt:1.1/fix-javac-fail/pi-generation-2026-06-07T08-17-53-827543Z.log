                  case 2:
                      rLine.append( TABLE_COL_RIGHT_ALIGNED_MARKUP );
                      break;
                  default:
                      rLine.append( TABLE_COL_CENTERED_ALIGNED_MARKUP );
                  }
              }
              else
              {
                  rLine.append( TABLE_COL_CENTERED_ALIGNED_MARKUP );
              }
          }
          rLine.append( EOL );
  
          this.rowLine = rLine.toString();
