              this.id = id;
              this.requestPredicate = new WebOperationRequestPredicate(path, WebEndpointHttpMethod.GET,
                      Collections.emptyList(), List.of(MimeTypeUtils.APPLICATION_JSON_VALUE));
          }
  
          @Override
          public String getId() {
              return this.id;
          }
  
