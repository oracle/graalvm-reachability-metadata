  package com_twitter.chill_2_13
  
  import com.esotericsoftware.kryo.Kryo
  import com.esotericsoftware.kryo.io.{Input, Output}
  import com.twitter.chill.EnumerationSerializer
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class EnumerationSerializerTest {
    @Test
    def serializesAndReadsEnumerationValues(): Unit = {
      val serializer: EnumerationSerializer = new EnumerationSerializer
      val kryo: RecordingEnumerationKryo = new RecordingEnumerationKryo(EnumerationSerializerProbe)
      val output: Output = new Output(16, -1)
  
      serializer.write(kryo, output, EnumerationSerializerProbe.Second)
      val serializedValue: Array[Byte] = output.toBytes
      output.close()
  
      assertThat(kryo.writtenObject).isSameAs(EnumerationSerializerProbe)
  
      val input: Input = new Input(serializedValue)
      val restoredValue: Enumeration#Value = serializer.read(kryo, input, classOf[Enumeration#Value])
      input.close()
  
      assertThat(restoredValue).isSameAs(EnumerationSerializerProbe.Second)
    }
  }
  
  final class RecordingEnumerationKryo(enumToRead: Enumeration) extends Kryo {
    private var lastWrittenObject: AnyRef = _
  
    def writtenObject: AnyRef = lastWrittenObject
  
    override def writeClassAndObject(output: Output, obj: AnyRef): Unit = {
      lastWrittenObject = obj
    }
  
    override def readClassAndObject(input: Input): AnyRef = enumToRead
  }
  
  object EnumerationSerializerProbe extends Enumeration {
    val First: Value = Value("first")
    val Second: Value = Value("second")
  }
