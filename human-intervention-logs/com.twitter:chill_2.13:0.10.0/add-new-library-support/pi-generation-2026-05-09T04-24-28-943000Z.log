    def forClass[T](t: Class[T])(fn: () => T): ObjectInstantiator[T] =
      new ObjectInstantiator[T] {
        override def newInstance(): T =
          try {
            fn()
          } catch {
            case x: Exception =>
              throw new KryoException("Error constructing instance of class: " + t.getName, x)
          }
