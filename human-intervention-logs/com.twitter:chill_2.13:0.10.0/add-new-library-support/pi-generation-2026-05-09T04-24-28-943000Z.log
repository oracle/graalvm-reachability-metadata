  package com_twitter.chill_2_13
  
  import com.twitter.chill.ClosureCleaner
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import scala.jdk.CollectionConverters._
  
  class ClosureCleanerTest {
    @Test
    def cleanRoundTripsSerializableValues(): Unit = {
      val serializableValue: SerializableStringBox = new SerializableStringBox("kept")
  
      val cleanedValue: SerializableStringBox = ClosureCleaner.clean(serializableValue)
  
      assertThat(cleanedValue).isNotSameAs(serializableValue)
      assertThat(cleanedValue.value).isEqualTo("kept")
    }
  
    @Test
    def discoversAndReadsOuterClassChain(): Unit = {
      val outer: OuterState = new OuterState("visible")
      val worker: OuterState#InnerWorker = outer.newWorker()
  
      assertThat(ClosureCleaner.outerFieldOf(worker.getClass).isDefined).isTrue()
      assertThat(ClosureCleaner.outerClassesOf(worker.getClass).asJava).containsExactly(classOf[OuterState])
      assertThat(ClosureCleaner.getOutersOf(worker).map(_._2).asJava).containsExactly(outer)
    }
  
    @Test
    def discoversFieldsReadThroughInnerClassMethods(): Unit = {
      val outer: OuterState = new OuterState("accessed")
      val worker: OuterState#InnerWorker = outer.newWorker()
  
      ClosureCleaner.accessedFieldsOf(worker.getClass)
      val accessedFieldNames: Set[String] = ClosureCleaner.accessedFieldsOf(classOf[OuterState]).map(_.getName)
  
      assertThat(accessedFieldNames.asJava).contains("observed")
    }
  
    @Test
    def cleanRebuildsNonSerializableOuterWithAccessedFieldsOnly(): Unit = {
      val outer: OuterState = new OuterState("copied")
      val worker: OuterState#InnerWorker = outer.newWorker()
  
      val cleanedWorker: OuterState#InnerWorker = ClosureCleaner.clean(worker)
  
      assertThat(cleanedWorker).isSameAs(worker)
      assertThat(cleanedWorker.readObserved()).isEqualTo("copied")
    }
  
    @Test
    def instantiateClassCreatesObjectsWithoutRunningConstructors(): Unit = {
      ConstructorProbe.constructorCalls = 0
  
      val instance: AnyRef = ClosureCleaner.instantiateClass(classOf[ConstructorProbe])
  
      assertThat(instance).isInstanceOf(classOf[ConstructorProbe])
      assertThat(ConstructorProbe.constructorCalls).isZero()
    }
  }
  
  final class SerializableStringBox(val value: String) extends Serializable
  
  final class OuterState(val observed: String) {
    val ignored: NonSerializablePayload = new NonSerializablePayload("ignored")
  
    class InnerWorker {
      def readObserved(): String = observed
    }
  
    def newWorker(): InnerWorker = new InnerWorker
  }
  
  final class NonSerializablePayload(val value: String)
  
  object ConstructorProbe {
    var constructorCalls: Int = 0
  }
  
  final class ConstructorProbe() {
    ConstructorProbe.constructorCalls += 1
  }
