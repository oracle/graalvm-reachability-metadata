  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.objenesis.instantiator.ObjectInstantiator
  
  import scala.util.Try
  
  class InstantiatorsTest {
    @Test
    def normalJavaInstantiatesClassWithPublicNoArgConstructor(): Unit = {
      PublicNoArgInstantiatorProbe.constructorCalls = 0
  
      val instantiator: ObjectInstantiator[PublicNoArgInstantiatorProbe] =
        successfulInstantiator(Instantiators.normalJava(classOf[PublicNoArgInstantiatorProbe]))
      val instance: PublicNoArgInstantiatorProbe = instantiator.newInstance()
  
      assertThat(instance.message).isEqualTo("public")
      assertThat(PublicNoArgInstantiatorProbe.constructorCalls).isEqualTo(1)
    }
  
    @Test
    def normalJavaInstantiatesClassWithPrivateNoArgConstructor(): Unit = {
      PrivateNoArgInstantiatorProbe.constructorCalls = 0
  
      val instantiator: ObjectInstantiator[PrivateNoArgInstantiatorProbe] =
        successfulInstantiator(Instantiators.normalJava(classOf[PrivateNoArgInstantiatorProbe]))
      val instance: PrivateNoArgInstantiatorProbe = instantiator.newInstance()
  
      assertThat(instance.message).isEqualTo("private")
      assertThat(PrivateNoArgInstantiatorProbe.constructorCalls).isEqualTo(1)
    }
  
    private def successfulInstantiator[T](result: Try[ObjectInstantiator[T]]): ObjectInstantiator[T] = {
      assertThat(result.isSuccess).isTrue()
      result.get
    }
  }
  
  object PublicNoArgInstantiatorProbe {
    var constructorCalls: Int = 0
  }
  
  class PublicNoArgInstantiatorProbe {
    PublicNoArgInstantiatorProbe.constructorCalls += 1
  
    val message: String = "public"
  }
  
  object PrivateNoArgInstantiatorProbe {
    var constructorCalls: Int = 0
  }
  
  class PrivateNoArgInstantiatorProbe private () {
    PrivateNoArgInstantiatorProbe.constructorCalls += 1
  
    val message: String = "private"
  }
