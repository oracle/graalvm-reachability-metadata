  package com_twitter.chill_2_13
  
  import com.esotericsoftware.kryo.Kryo
  import com.esotericsoftware.kryo.io.Input
  import com.twitter.chill.{Externalizer, ObjectSerializer}
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class ObjectSerializerTest {
    @Test
    def acceptsScalaSingletonObjects(): Unit = {
      val serializer: ObjectSerializer[AnyRef] = new ObjectSerializer[AnyRef]
  
      val acceptsSingleton: Boolean = serializer.accepts(Externalizer.getClass)
  
      assertThat(acceptsSingleton).isTrue()
    }
  
    @Test
    def readsScalaSingletonFromModuleField(): Unit = {
      val serializer: ObjectSerializer[AnyRef] = new ObjectSerializer[AnyRef]
      val input: Input = new Input(Array.emptyByteArray)
      try {
        val singletonClass: Class[AnyRef] = Externalizer.getClass.asInstanceOf[Class[AnyRef]]
        val restoredObject: AnyRef = serializer.read(new Kryo(), input, singletonClass)
  
        assertThat(restoredObject).isSameAs(Externalizer)
      } finally {
        input.close()
      }
    }
  }
