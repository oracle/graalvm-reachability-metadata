  package com_twitter.chill_2_13
  
  import java.io.{ByteArrayInputStream, ByteArrayOutputStream, ObjectInputStream, ObjectOutputStream}
  
  import com.twitter.chill.Externalizer
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class ExternalizerTest {
    @Test
    def javaWorksProbesSerializablePayloadWithObjectStreams(): Unit = {
      val externalizer: Externalizer[String] = Externalizer("kept")
  
      assertThat(externalizer.javaWorks).isTrue()
      assertThat(externalizer.get).isEqualTo("kept")
    }
  
    @Test
    def externalizableRoundTripUsesJavaSerializationWhenProbeSucceeds(): Unit = {
      val externalizer: Externalizer[String] = Externalizer("round-trip")
  
      val restoredExternalizer: Externalizer[String] = roundTripExternalizer(externalizer)
  
      assertThat(restoredExternalizer.get).isEqualTo("round-trip")
    }
  
    private def roundTripExternalizer[T](externalizer: Externalizer[T]): Externalizer[T] = {
      val outputBytes: ByteArrayOutputStream = new ByteArrayOutputStream()
      val objectOutput: ObjectOutputStream = new ObjectOutputStream(outputBytes)
      try {
        objectOutput.writeObject(externalizer)
      } finally {
        objectOutput.close()
      }
  
      val inputBytes: ByteArrayInputStream = new ByteArrayInputStream(outputBytes.toByteArray)
      val objectInput: ObjectInputStream = new ObjectInputStream(inputBytes)
      try {
        objectInput.readObject().asInstanceOf[Externalizer[T]]
      } finally {
        objectInput.close()
      }
    }
  }
