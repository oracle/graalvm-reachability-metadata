FgXMUIgH1FaOpU8F5FGKUir0|fc_08f9da96dc1f02a20169feb51b1118819fac63636559636df4", "name": "write", "arguments": {"path": "tests/src/com.twitter/chill_2.13/0.10.0/src/test/scala/com_twitter/chill_2_13/ClosureCleanerTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_twitter.chill_2_13\n\nimport com.twitter.chill.ClosureCleaner\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass ClosureCleanerTest {\n  @Test\n  def cleanRoundTripsSerializableValues(): Unit = {\n    val serializableValue: SerializableStringBox = new SerializableStringBox(\"kept\")\n\n    val cleanedValue: SerializableStringBox = ClosureCleaner.clean(serializableValue)\n\n    assertThat(cleanedValue).isNotSameAs(serializableValue)\n    assertThat(cleanedValue.value).isEqualTo(\"kept\")\n  }\n\n  @Test\n  def discoversAndReadsOuterClassChain(): Unit = {\n    val outer: OuterState = new OuterState(\"visible\")\n    val worker: OuterState#InnerWorker = outer.newWorker()\n\n    assertThat(ClosureCleaner.outerFieldOf(worker.getClass)).isPresent\n    assertThat(ClosureCleaner.outerClassesOf(worker.getClass)).containsExactly(classOf[OuterState])\n    assertThat(ClosureCleaner.getOutersOf(worker).map(_._2)).containsExactly(outer)\n  }\n\n  @Test\n  def discoversFieldsReadThroughInnerClassMethods(): Unit = {\n    val outer: OuterState = new OuterState(\"accessed\")\n    val worker: OuterState#InnerWorker = outer.newWorker()\n\n    val accessedFieldNames: Set[String] = ClosureCleaner.accessedFieldsOf(worker.getClass).map(_.getName)\n\n    assertThat(accessedFieldNames.asJava).contains(\"observed\")\n  }\n\n  @Test\n  def cleanRebuildsNonSerializableOuterWithAccessedFieldsOnly(): Unit = {\n    val outer: OuterState = new OuterState(\"copied\")\n    val worker: OuterState#InnerWorker = outer.newWorker()\n\n    val cleanedWorker: OuterState#InnerWorker = ClosureCleaner.clean(worker)\n\n    assertThat(cleanedWorker).isSameAs(worker)\n    assertThat(cleanedWorker.readObserved()).isEqualTo(\"copied\")\n  }\n\n  @Test\n  def instantiateClassCreatesObjectsWithoutRunningConstructors(): Unit = {\n    ConstructorProbe.constructorCalls = 0\n\n    val instance: AnyRef = ClosureCleaner.instantiateClass(classOf[ConstructorProbe])\n\n    assertThat(instance).isInstanceOf(classOf[ConstructorProbe])\n    assertThat(ConstructorProbe.constructorCalls).isZero()\n  }\n}\n\nfinal class SerializableStringBox(val value: String) extends Serializable\n\nfinal class OuterState(val observed: String) {\n  val ignored: NonSerializablePayload = new NonSerializablePayload(\"ignored\")\n\n  class InnerWorker {\n    def readObserved(): String = observed\n  }\n\n  def newWorker(): InnerWorker = new InnerWorker\n}\n\nfinal class NonSerializablePayload(val value: String)\n\nobject ConstructorProbe {\n  var constructorCalls: Int = 0\n}\n\nfinal class ConstructorProbe() {\n  ConstructorProbe.constructorCalls += 1\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 689, "output": 888, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 20009, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778300183884, "responseId": "resp_08f9da96dc1f02a20169feb51871dc819f971e97c7814a63c9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FgXMUIgH1FaOpU8F5FGKUir0|fc_08f9da96dc1f02a20169feb51b1118819fac63636559636df4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2779 bytes to tests/src/com.twitter/chill_2.13/0.10.0/src/test/scala/com_twitter/chill_2_13/ClosureCleanerTest.scala"}], "isError": false, "timestamp": 1778300193967}]}
