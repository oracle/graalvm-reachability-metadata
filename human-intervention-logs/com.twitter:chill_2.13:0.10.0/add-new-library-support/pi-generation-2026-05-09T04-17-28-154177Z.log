      try {
        in.readObject.asInstanceOf[T]
      } finally {
        bis.close()
        in.close()
      }
    }
  
    // Return the $outer field for this class
    def outerFieldOf(c: Class[_]): Option[Field] =
      outerFields
        .getOrElseUpdate(
          c,
          c.getDeclaredFields.find {
            _.getName == OUTER
          }
        )
  
