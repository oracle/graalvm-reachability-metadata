C0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_twitter.chill_2_13\\n\\nimport com.twitter.chill.Instantiators\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\nimport org.objenesis.instantiator.ObjectInstantiator\\n\\nimport scala.util.Try\\n\\nclass InstantiatorsTest {\\n  @Test\\n  def normalJavaInstantiatesClassWithPublicNoArgConstructor(): Unit = {\\n    PublicNoArgInstantiatorProbe.constructorCalls = 0\\n\\n    val instantiator: ObjectInstantiator[PublicNoArgInstantiatorProbe] =\\n      successfulInstantiator(Instantiators.normalJava(classOf[PublicNoArgInstantiatorProbe]))\\n    val instance: PublicNoArgInstantiatorProbe = instantiator.newInstance()\\n\\n    assertThat(instance.message).isEqualTo(\\\"public\\\")\\n    assertThat(PublicNoArgInstantiatorProbe.constructorCalls).isEqualTo(1)\\n  }\\n\\n  @Test\\n  def normalJavaInstantiatesClassWithPrivateNoArgConstructor(): Unit = {\\n    PrivateNoArgInstantiatorProbe.constructorCalls = 0\\n\\n    val instantiator: ObjectInstantiator[PrivateNoArgInstantiatorProbe] =\\n      successfulInstantiator(Instantiators.normalJava(classOf[PrivateNoArgInstantiatorProbe]))\\n    val instance: PrivateNoArgInstantiatorProbe = instantiator.newInstance()\\n\\n    assertThat(instance.message).isEqualTo(\\\"private\\\")\\n    assertThat(PrivateNoArgInstantiatorProbe.constructorCalls).isEqualTo(1)\\n  }\\n\\n  private def successfulInstantiator[T](result: Try[ObjectInstantiator[T]]): ObjectInstantiator[T] = {\\n    assertThat(result.isSuccess).isTrue()\\n    result.get\\n  }\\n}\\n\\nobject PublicNoArgInstantiatorProbe {\\n  var constructorCalls: Int = 0\\n}\\n\\nclass PublicNoArgInstantiatorProbe {\\n  PublicNoArgInstantiatorProbe.constructorCalls += 1\\n\\n  val message: String = \\\"public\\\"\\n}\\n\\nobject PrivateNoArgInstantiatorProbe {\\n  var constructorCalls: Int = 0\\n}\\n\\nclass PrivateNoArgInstantiatorP