       */
      def sendPath(
          content: Path,
          inline: Boolean = true,
          fileName: Path => Option[String] = Option(_).map(_.getFileName.toString),
          onClose: () => Unit = () => ()
      )(implicit ec: ExecutionContext, fileMimeTypes: FileMimeTypes): Result = {
