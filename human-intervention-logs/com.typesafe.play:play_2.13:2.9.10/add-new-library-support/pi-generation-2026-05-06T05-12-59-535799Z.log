  package com_typesafe_play.play_2_13
  
  import java.net.URL
  import java.net.URLConnection
  import java.net.URLStreamHandler
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import play.utils.Resources
  
  class ResourcesTest {
    @Test
    def treatsGraalVmResourceUrlForClasspathFileAsNotADirectory(): Unit = {
      val url: URL = new URL(null, "resource:messages", NoOpUrlStreamHandler)
  
      val isDirectory: Boolean = Resources.isDirectory(getClass.getClassLoader, url)
  
      assertThat(isDirectory).isFalse
    }
  }
  
  object NoOpUrlStreamHandler extends URLStreamHandler {
    override protected def openConnection(url: URL): URLConnection = {
      throw new UnsupportedOperationException("This test only inspects URL metadata")
    }
  }
