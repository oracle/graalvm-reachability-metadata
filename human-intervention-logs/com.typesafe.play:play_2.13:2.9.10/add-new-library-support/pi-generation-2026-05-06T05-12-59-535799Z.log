.isFalse\n  }\n}\n\nobject ResourcesTest {\n  private def resourceUrl(path: String): URL = {\n    new URL(null, s\"resource:$path\", NoOpUrlStreamHandler)\n  }\n\n  private object NoOpUrlStreamHandler extends URLStreamHandler {\n    override protected def openConnection(url: URL): URLConnection = {\n      throw new UnsupportedOperationException(\"This test only inspects URL metadata\")\n    }\n  }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 892, "output": 2412, "cacheRead": 16384, "cacheWrite": 0, "totalTokens": 19688, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778044316847, "responseId": "resp_0817f29c2baf9f6d0169facd9d53dc819db92133db3488aea1"}}
