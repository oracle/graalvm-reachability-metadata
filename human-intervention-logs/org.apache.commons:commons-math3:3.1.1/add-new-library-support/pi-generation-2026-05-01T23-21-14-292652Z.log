      public static RealMatrix createRealIdentityMatrix(int dimension) {
          final RealMatrix m = createRealMatrix(dimension, dimension);
          for (int i = 0; i < dimension; ++i) {
              m.setEntry(i, i, 1.0);
          }
          return m;
