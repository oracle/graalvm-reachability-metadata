          singular = false;
  
          // Loop over columns
          for (int col = 0; col < m; col++) {
  
              T sum = field.getZero();
  
              // upper
              for (int row = 0; row < col; row++) {
                  final T[] luRow = lu[row];
                  sum = luRow[col];
