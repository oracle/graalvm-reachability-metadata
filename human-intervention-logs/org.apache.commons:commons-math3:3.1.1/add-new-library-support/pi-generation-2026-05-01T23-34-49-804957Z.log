      public FieldVector<T> projection(FieldVector<T> v)
          throws DimensionMismatchException, MathArithmeticException {
          checkVectorDimensions(v.getDimension());
          return v.mapMultiply(dotProduct(v).divide(v.dotProduct(v)));
