          int[] dimensionSize = mdcm.getDimensionSizes();
          //if done
          if (subVector.length == dimensionSize.length) {
              Complex[] temp = new Complex[dimensionSize[d]];
              for (int i = 0; i < dimensionSize[d]; i++) {
                  //fft along dimension d
                  subVector[d] = i;
                  temp[i] = mdcm.get(subVector);
              }
  
