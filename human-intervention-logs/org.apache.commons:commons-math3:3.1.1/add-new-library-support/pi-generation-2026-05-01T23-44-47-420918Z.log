              numOfDimensions = 0;
              for (Object lastDimension = multiDimensionalComplexArray;
                   lastDimension instanceof Object[];) {
                  final Object[] array = (Object[]) lastDimension;
                  dimensionSize[numOfDimensions++] = array.length;
                  lastDimension = array[0];
              }
  
