is\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_commons.commons_math3;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.commons.math3.geometry.euclidean.oned.Euclidean1D;\nimport org.apache.commons.math3.geometry.euclidean.oned.IntervalsSet;\nimport org.apache.commons.math3.geometry.euclidean.oned.OrientedPoint;\nimport org.apache.commons.math3.geometry.euclidean.oned.Vector1D;\nimport org.apache.commons.math3.geometry.partitioning.BSPTree;\nimport org.apache.commons.math3.geometry.partitioning.BoundaryAttribute;\nimport org.apache.commons.math3.geometry.partitioning.SubHyperplane;\nimport org.junit.jupiter.api.Test;\n\npublic class AbstractRegionInnerBoundaryBuilderTest {\n    @Test\n    void buildsBoundaryAttributeWhenPlusSideIsOutside() {\n        IntervalsSet region = intervalWithBoundary(Boolean.FALSE, Boolean.TRUE);\n\n        BoundaryAttribute<Euclidean1D> attribute = boundaryAttribute(region);\n\n        assertThat(attribute.getPlusOutside()).isNotNull();\n        assertThat(attribute.getPlusInside()).isNull();\n    }\n\n    @Test\n    void buildsBoundaryAttributeWhenPlusSideIsInside() {\n        IntervalsSet region = intervalWithBoundary(Boolean.TRUE, Boolean.FALSE);\n\n        BoundaryAttribute<Euclidean1D> attribute = boundaryAttribute(region);\n\n        assertThat(attribute.getPlusOutside()).isNull();\n        assertThat(attribute.getPlusInside()).isNotNull();\n    }\n\n    private static IntervalsSet intervalWithBoundary(Boolean plusCellInside, Boolean minusCellInside) {\n        OrientedPoint boundary = new OrientedPoint(Vector1D.ZERO, true);\n        SubHyperplane<Euclidean1D> cut = boundary.wholeHyperplane();\n        BSPTree<Euclidean1D> tree = new BSPTree<Euclidean1D>(\n                cut,\n                new BSPTree<Euclidean1D>(plusCellInside),\n                new BSPTree<Euclidean1D>(minusCellInside),\n                null);\n        return new IntervalsSet(tree);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static BoundaryAttribute<Euclidean1D> boundaryAttribute(IntervalsSet region) {\n        return (BoundaryAttribute<Euclidean1D>) region.getTree(true).getAttribute();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1733, "output": 1021, "cacheRead": 27136, "cacheWrite": 0, "totalTokens": 29890, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777678246737, "responseId": "resp_06dcbe2ee518b8cd0169f537a76b7881a1a69a4c4d044f1fa4"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_UT2bcdeahTgLlwtUWWEg0jDb|fc_06dcbe2ee518b8cd0169f537ad483481a1989a549869083353", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2313 bytes to tests/src/org.apache.commons/commons-math3/3.1.1/src/test/java/org_apache_commons/commons_math3/AbstractRegionInnerBoundaryBuilderTest.java"}], "isError": false, "timestamp": 1777678261498}]}
