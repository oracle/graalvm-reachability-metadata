[tool-call] delta {"path":"tests/src/org.apache.commons/commons-math3/3.1.1/src/test/java/org_apache_commons/commons_math3/AbstractRegionInnerBoundaryBuilderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_commons.commons_math3;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport org.apache.commons.math3.geometry.euclidean.twod.Euclidean2D;\nimport org.apache.commons.math3.geometry.euclidean.twod.PolygonsSet;\nimport org.apache.commons.math3.geometry.partitioning.BSPTree;\nimport org.apache.commons.math3.geometry.partitioning.BSPTreeVisitor;\nimport org.apache.commons.math3.geometry.partitioning.BoundaryAttribute;\nimport org.apache.commons.math3.geometry.partitioning.SubHyperplane;\nimport org.junit.jupiter.api.Test;\n\npublic class AbstractRegionInnerBoundaryBuilderTest {\n    @Test\n    void buildsBoundaryAttributesForBoxRegion() {\n        PolygonsSet rectangle = new PolygonsSet(-1.0, 2.0, -3.0, 4.0);\n\n        List<BoundaryAttribute<Euclidean2D>> attributes = collectBoundaryAttributes(rectangle.getTree(true));\n\n        assertThat(attributes).isNotEmpty();\n        assertThat(attributes).anySatisfy(attribute -> assertThat(attribute.getPlusOutside()).isNotNull());\n        assertThat(attributes).anySatisfy(attribute -> assertThat(attribute.getPlusInside()).isNotNull());\n        assertThat(rectangle.getSize()).isEqualTo(21.0);\n    }\n\n    private static List<BoundaryAttribute<Euclidean2D>> collectBoundaryAttributes(BSPTree<Euclidean2D> tree) {\n        List<BoundaryAttribute<Euclidean2D>> attributes = new ArrayList<BoundaryAttribute<Euclidean2D>>();\n        tree.visit(new BoundaryAttributeCollector(attributes));\n        return attributes;\n    }\n\n    private static final class BoundaryAttributeCollector implements BSPTreeVisitor<Euclidean2D> {\n        private final List<BoundaryAttribute<Euclidean2D>> attributes;\n\n        private BoundaryAttributeCollector(List<BoundaryAttribute<Euclidean2D>> attributes) {\n            this.attributes = attributes;\n        }\n\n        @Override\n        public Order visitOrder(BSPTree<Euclidean2D> node) {\n            return Order.SUB_PLUS_MINUS;\n        }\n\n        @Override\n        public void visitInternalNode(BSPTree<Euclidean2D> node) {\n            BoundaryAttribute<Euclidean2D> attribute = getBoundaryAttribute(node);\n            attributes.add(attribute);\n        }\n\n        @Override\n        public void visitLeafNode(BSPTree<Euclidean2D> node) {\n        }\n\n        @SuppressWarnings(\"unchecked\")\n        private BoundaryAttribute<Euclidean2D> getBoundaryAttribute(BSPTree<Euclidean2D> node) {\n            return (BoundaryAttribute<Euclidean2D>) node.getAttribute();\n        }\n    }\n}\n"}
