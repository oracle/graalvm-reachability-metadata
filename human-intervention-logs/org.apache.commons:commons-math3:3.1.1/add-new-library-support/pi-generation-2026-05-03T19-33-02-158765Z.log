  package org_apache_commons.commons_math3;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.Locale;
  
  import org.apache.commons.math3.exception.util.ExceptionContext;
  import org.apache.commons.math3.exception.util.LocalizedFormats;
  import org.junit.jupiter.api.Test;
  
  public class ExceptionContextTest {
      @Test
      void serializesAndDeserializesMessagesAndContext() throws Exception {
          ExceptionContext context = new ExceptionContext(new IllegalArgumentException("bad input"));
          context.addMessage(LocalizedFormats.DIMENSIONS_MISMATCH_SIMPLE,
                             3,
                             new NonSerializableValue("message argument"));
          context.setValue("serializable", "stored value");
          context.setValue("notSerializable", new NonSerializableValue("context value"));
  
          ExceptionContext restored = roundTrip(context);
  
          assertThat(restored.getThrowable())
              .isInstanceOf(IllegalArgumentException.class)
              .hasMessage("bad input");
          assertThat(restored.getMessage(Locale.US))
              .contains("3")
              .contains("[Object could not be serialized: " + NonSerializableValue.class.getName() + "]");
          assertThat(restored.getKeys()).containsExactlyInAnyOrder("serializable", "notSerializable");
          assertThat(restored.getValue("serializable")).isEqualTo("stored value");
          assertThat(restored.getValue("notSerializable"))
              .isEqualTo("[Object could not be serialized: " + NonSerializableValue.class.getName() + "]");
      }
  
      private static ExceptionContext roundTrip(ExceptionContext context) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(context);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (ExceptionContext) input.readObject();
          }
      }
  
      private static final class NonSerializableValue {
          private final String value;
  
          private NonSerializableValue(String value) {
              this.value = value;
          }
  
          @Override
          public String toString() {
              return value;
          }
      }
  }
