       * @param d Array.
       * @throws NullArgumentException if {@code d} is {@code null}.
       * @see #ArrayFieldVector(FieldElement[])
       */
      public ArrayFieldVector(Field<T> field, T[] d)
              throws NullArgumentException {
          if (d == null) {
