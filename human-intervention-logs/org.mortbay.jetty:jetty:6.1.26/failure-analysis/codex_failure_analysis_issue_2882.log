ortbay.jetty/jetty/6.1.26/src/test/java/org_mortbay_jetty/jetty/XmlConfigurationTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_mortbay_jetty.jetty;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.mortbay.xml.XmlConfiguration;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class XmlConfigurationTest {\\n    @Test\\n    void configuresObjectThroughReflectiveXmlOperations() throws Exception {\\n        System.setProperty(\\\"org.mortbay.xml.XmlParser.Validating\\\", \\\"false\\\");\\n\\n        String beanClass = ConfigurableBean.class.getName();\\n        String constructorTargetClass = ConstructorTarget.class.getName();\\n        String xml = \\\"\\\"\\\"\\\\\\n                <Configure class=\\\"%s\\\" id=\\\"bean\\\">\\n                  <Set name=\\\"name\\\">configured</Set>\\n                  <Set name=\\\"count\\\" type=\\\"Integer\\\">42</Set>\\n                  <Set name=\\\"publicValue\\\">field-value</Set>\\n                  <Set name=\\\"object\\\">object-value</Set>\\n                  <Set name=\\\"converted\\\">converted-value</Set>\\n                  <Set name=\\\"constructedViaNew\\\">\\n                    <New class=\\\"%s\\\">\\n                      <Arg>constructed-via-new</Arg>\\n                    </New>\\n                  </Set>\\n                  <Get name=\\\"child\\\" id=\\\"childFromGetter\\\">\\n                    <Set name=\\\"name\\\">from-getter</Set>\\n                  </Get>\\n                  <Get name=\\\"fieldChild\\\" id=\\\"fieldChild\\\">\\n                    <Set name=\\\"name\\\">from-field-getter</Set>\\n                  </Get>\\n                  <Call name=\\\"createChild\\\" id=\\\"calledChild\\\">\\n                    <Arg>from-call</Arg>\\n                    <Set name=\\\"name\\\">configured-by-call</Set>\\n                  </Call>\\n                </Configure>\\n                \\\"\\\"\\\".formatted(beanClass, constructorTargetClass);\\n\\n        XmlConfiguration configuration = new XmlConfiguration(xml);\\n\\n        Object configured = configuration.configure();\\n\\n        assertThat(configured).isInstanceOf(ConfigurableBean.class);\\n        ConfigurableBean bean = (ConfigurableBean) configured;\\n        assertThat(bean.getName()).isEqualTo(\\\"configured\\\");\\n        assertThat(bean.getCount()).isEqualTo(42);\\n        assertThat(bean.publicValue).isEqualTo(\\\"field-value\\\");\\n        assertThat(bean.getObject()).isEqualTo(\\\"object-value\\\");\\n        assertThat(bean.getConverted().getValue()).isEqualTo(\\\"converted-value\\\");\\n        assertThat(bean.getConstructedViaNew().getValue()).isEqualTo(\\\"constructed-via-new\\\");\\n        assertThat(bean.getChild().getName()).isEqualTo(\\\"from-getter\\\");\\n        assertThat(bean.fieldChild.getName()).isEqualTo(\\\"from-field-getter\\\");\\n        assertThat(bean.getCreatedChild().getName()).isEqualTo(\\\"configured-by-call\\\");\\n        assertThat(configuration.getIdMap())\\n                .containsEntry(\\\"bean\\\", bean)\\n                .containsEntry(\\\"childFromGetter\\\", bean.getChild())\\n                .containsEntry(\\\"fieldChild\\\", bean.fieldChild)\\n                .containsEntry(\\\"calledChild\\\", bean.getCreatedChild());\\n    }\\n\\n    public static class ConfigurableBean {\\n        public String publicValue;\\n        public Child fieldChild = new Child(\\\"field-child\\\");\\n\\n        private String name;\\n        private int count;\\n        private Object object;\\n        private ConstructorTarget converted;\\n        private ConstructorTarget constructedViaNew;\\n        private final Child child = new Child(\\\"child\\\");\\n        private Child createdChild;\\n\\n        public ConfigurableBean() {\\n        }\\n