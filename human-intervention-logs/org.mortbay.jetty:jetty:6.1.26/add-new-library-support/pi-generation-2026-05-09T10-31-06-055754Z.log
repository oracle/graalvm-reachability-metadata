       * @exception Exception
       */
      public Object configure() throws Exception
      {
          Class oClass = nodeClass(_config);
          
          String id = _config.getAttribute("id");
          Object obj = id==null?null:_idMap.get(id);
          
          if (obj==null && oClass !=null)
