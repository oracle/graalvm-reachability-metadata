  package org_mortbay_jetty.jetty;
  
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.EventListener;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.mortbay.jetty.webapp.WebAppContext;
  import org.mortbay.jetty.webapp.WebXmlConfiguration;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class WebXmlConfigurationTest {
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void configuresListenerFromWebXml() throws Exception {
          String previousValidationSetting = System.setProperty("org.mortbay.xml.XmlParser.Validating", "false");
          try {
              WebAppContext context = new WebAppContext();
              context.setClassLoader(ConfiguredListener.class.getClassLoader());
  
              WebXmlConfiguration configuration = new WebXmlConfiguration();
              configuration.setWebAppContext(context);
  
              Path webXml = temporaryDirectory.resolve("web.xml");
              Files.writeString(webXml, """
                      <?xml version="1.0" encoding="UTF-8"?>
                      <web-app>
                        <display-name>configured-webapp</display-name>
                        <context-param>
                          <param-name>configured-param</param-name>
                          <param-value>configured-value</param-value>
                        </context-param>
                        <listener>
                          <listener-class>%s</listener-class>
                        </listener>
                        <welcome-file-list>
                          <welcome-file>index.html</welcome-file>
                        </welcome-file-list>
                      </web-app>
                      """.formatted(ConfiguredListener.class.getName()), StandardCharsets.UTF_8);
  
              configuration.configure(webXml.toUri().toURL().toString());
  
              assertThat(context.getDisplayName()).isEqualTo("configured-webapp");
              assertThat(context.getInitParams()).containsEntry("configured-param", "configured-value");
              assertThat(context.getWelcomeFiles()).containsExactly("index.html");
              assertThat(context.getEventListeners()).hasSize(1);
              assertThat(context.getEventListeners()[0]).isInstanceOf(ConfiguredListener.class);
          } finally {
              if (previousValidationSetting == null) {
                  System.clearProperty("org.mortbay.xml.XmlParser.Validating");
              } else {
                  System.setProperty("org.mortbay.xml.XmlParser.Validating", previousValidationSetting);
              }
          }
      }
  
      public static class ConfiguredListener implements EventListener {
          public ConfiguredListener() {
          }
      }
  }
