 {\n            return name;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public void setObject(Object object) {\n            this.object = object;\n        }\n\n        public Object getObject() {\n            return object;\n        }\n\n        public void setConverted(ConstructorTarget converted) {\n            this.converted = converted;\n        }\n\n        public ConstructorTarget getConverted() {\n            return converted;\n        }\n\n        public void setConstructedViaNew(ConstructorTarget constructedViaNew) {\n            this.constructedViaNew = constructedViaNew;\n        }\n\n        public ConstructorTarget getConstructedViaNew() {\n            return constructedViaNew;\n        }\n\n        public Child getChild() {\n            return child;\n        }\n\n        public Child createChild(String name) {\n            createdChild = new Child(name);\n            return createdChild;\n        }\n\n        public Child getCreatedChild() {\n            return createdChild;\n        }\n    }\n\n    public static class Child {\n        private String name;\n\n        public Child() {\n        }\n\n        public Child(String name) {\n            this.name = name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n\n    public static class ConstructorTarget {\n        private final String value;\n\n        public ConstructorTarget(String value) {\n            this.value = value;\n        }\n\n        public String getValue() {\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778323439937}}
