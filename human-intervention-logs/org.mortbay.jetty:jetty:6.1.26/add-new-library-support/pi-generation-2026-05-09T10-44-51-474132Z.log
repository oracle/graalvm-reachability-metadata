ception {\n        WebAppContext context = new WebAppContext();\n        context.setParentLoaderPriority(true);\n\n        WebAppClassLoader loader = new WebAppClassLoader(getClass().getClassLoader(), context);\n        try {\n            URL resource = loader.getResource(TEST_RESOURCE);\n            Class<?> loadedClass = loader.loadClass(ParentPriorityTarget.class.getName());\n\n            assertThat(resource).isNotNull();\n            assertThat(loadedClass).isSameAs(ParentPriorityTarget.class);\n        } finally {\n            loader.close();\n        }\n    }\n\n    @Test\n    void fallsBackToParentForApplicationResourceAndClass() throws Exception {\n        WebAppContext context = new WebAppContext();\n        context.setParentLoaderPriority(false);\n        context.setSystemClasses(new String[] {\"java.\"});\n        context.setServerClasses(new String[] {\"org.mortbay.jetty.\"});\n\n        WebAppClassLoader loader = new WebAppClassLoader(getClass().getClassLoader(), context);\n        try {\n            URL resource = loader.getResource(TEST_RESOURCE);\n            Class<?> loadedClass = loader.loadClass(ParentFallbackTarget.class.getName());\n\n            assertThat(resource).isNotNull();\n            assertThat(loadedClass).isSameAs(ParentFallbackTarget.class);\n        } finally {\n            loader.close();\n        }\n    }\n\n    public static class ParentPriorityTarget {\n        public ParentPriorityTarget() {\n        }\n    }\n\n    public static class ParentFallbackTarget {\n        public ParentFallbackTarget() {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 564, "output": 1462, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 27114, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778323465495, "responseId": "resp_01a4161401f6a12c0169ff100a0030819c8d4b48f74bc9bed7"}, "toolResults": [{"role": "toolResul