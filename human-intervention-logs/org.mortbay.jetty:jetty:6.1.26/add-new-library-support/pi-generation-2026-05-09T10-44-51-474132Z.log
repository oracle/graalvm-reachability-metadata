e();\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextLoader);\n        }\n    }\n\n    @Test\n    @Order(2)\n    void usesParentFirstWhenParentLoaderPriorityIsEnabled() throws Exception {"}, {"oldText": "    @Test\n    void fallsBackToParentForApplicationResourceAndClass() throws Exception {", "newText": "    @Test\n    @Order(3)\n    void fallsBackToParentForApplicationResourceAndClass() throws Exception {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1358, "output": 1528, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 33094, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778323628434, "responseId": "resp_01a4161401f6a12c0169ff10acf1fc819cb00fd5222bff8f47"}}
