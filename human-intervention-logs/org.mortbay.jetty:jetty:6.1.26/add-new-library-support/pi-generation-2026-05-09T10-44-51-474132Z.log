  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_mortbay_jetty.jetty;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.URL;
  import java.nio.charset.StandardCharsets;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.resource.Resource;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ResourceTest {
      private static final String RESOURCE_DIRECTORY = "org_mortbay_jetty/jetty/resource-test";
  
      @Test
      void findsSystemResourceAfterStrippingLeadingSlash() throws Exception {
          Resource resource = Resource.newSystemResource("/" + RESOURCE_DIRECTORY + "/system-resource.txt");
  
          assertThat(resource).isNotNull();
          assertThat(readContent(resource)).isEqualTo("system resource content\n");
      }
  
      @Test
      void returnsNullWhenSystemResourceIsAbsentAcrossAllLookupStrategies() throws Exception {
          String absentResource = "/" + RESOURCE_DIRECTORY + "/absent-system-resource.txt";
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(ClassLoader.getPlatformClassLoader());
  
              Resource resource = Resource.newSystemResource(absentResource);
  
              assertThat(resource).isNull();
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      @Test
      void findsClasspathResourceWithClassResourceLookup() throws Exception {
          Resource resource = Resource.newClassPathResource("/" + RESOURCE_DIRECTORY + "/classpath-resource.txt");
  
          assertThat(resource).isNotNull();
          assertThat(readContent(resource)).isEqualTo("classpath resource content\n");
      }
  
      @Test
      void fallsBackToSystemClasspathLookupWhenLoaderResourceLookupThrowsClassNotFoundException() {
          ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(new ThrowingResourceClassLoader(originalClassLoader));
  
              Resource resource = Resource.newClassPathResource(RESOURCE_DIRECTORY + "/absent-classpath-resource.txt");
  
              assertThat(resource).isNull();
          } finally {
              Thread.currentThread().setContextClassLoader(originalClassLoader);
          }
      }
  
      private static String readContent(Resource resource) throws IOException {
          try {
              try (InputStream inputStream = resource.getInputStream()) {
                  return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);
              }
          } finally {
              resource.release();
          }
      }
  
      private static final class ThrowingResourceClassLoader extends ClassLoader {
          private ThrowingResourceClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public URL getResource(String name) {
              throwUnchecked(new ClassNotFoundException(name));
              return null;
          }
  
          @SuppressWarnings("unchecked")
          private static <T extends Throwable> void throwUnchecked(Throwable throwable) throws T {
              throw (T) throwable;
          }
      }
  }
