  package org_mortbay_jetty.jetty;
  
  import java.net.URL;
  
  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.TestMethodOrder;
  import org.junit.jupiter.api.MethodOrderer.OrderAnnotation;
  import org.mortbay.jetty.webapp.WebAppClassLoader;
  import org.mortbay.jetty.webapp.WebAppContext;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @TestMethodOrder(OrderAnnotation.class)
  public class WebAppClassLoaderTest {
      private static final String TEST_RESOURCE = "org_mortbay_jetty/jetty/resource-test/classpath-resource.txt";
  
      @Test
      @Order(1)
      void usesWebAppClassLoaderClassLoaderWhenNoParentOrThreadContextLoaderIsAvailable() throws Exception {
          WebAppContext context = new WebAppContext();
          ClassLoader originalContextLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(null);
  
              WebAppClassLoader loader = new WebAppClassLoader(context);
              try {
                  assertThat(loader.getParent()).isSameAs(WebAppClassLoader.class.getClassLoader());
              } finally {
                  loader.close();
              }
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextLoader);
          }
      }
  
      @Test
      @Order(2)
      void usesParentFirstWhenParentLoaderPriorityIsEnabled() throws Exception {
          WebAppContext context = new WebAppContext();
          context.setParentLoaderPriority(true);
  
          WebAppClassLoader loader = new WebAppClassLoader(getClass().getClassLoader(), context);
          try {
              URL resource = loader.getResource(TEST_RESOURCE);
              Class<?> loadedClass = loader.loadClass(ParentPriorityTarget.class.getName());
  
              assertThat(resource).isNotNull();
              assertThat(loadedClass).isSameAs(ParentPriorityTarget.class);
          } finally {
              loader.close();
          }
      }
  
      @Test
      @Order(3)
      void fallsBackToParentForApplicationResourceAndClass() throws Exception {
          WebAppContext context = new WebAppContext();
          context.setParentLoaderPriority(false);
          context.setSystemClasses(new String[] {"java."});
          context.setServerClasses(new String[] {"org.mortbay.jetty."});
  
          WebAppClassLoader loader = new WebAppClassLoader(getClass().getClassLoader(), context);
          try {
              URL resource = loader.getResource(TEST_RESOURCE);
              Class<?> loadedClass = loader.loadClass(ParentFallbackTarget.class.getName());
  
              assertThat(resource).isNotNull();
              assertThat(loadedClass).isSameAs(ParentFallbackTarget.class);
          } finally {
              loader.close();
          }
      }
  
      public static class ParentPriorityTarget {
          public ParentPriorityTarget() {
          }
      }
  
      public static class ParentFallbackTarget {
          public ParentFallbackTarget() {
          }
