  package org_mortbay_jetty.jetty;
  
  import org.junit.jupiter.api.Test;
  import org.mortbay.xml.XmlConfiguration;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class XmlConfigurationTest {
      @Test
      void configuresObjectThroughReflectiveXmlOperations() throws Exception {
          System.setProperty("org.mortbay.xml.XmlParser.Validating", "false");
  
          String beanClass = ConfigurableBean.class.getName();
          String constructorTargetClass = ConstructorTarget.class.getName();
          String xml = """
                  <Configure class="%s" id="bean">
                    <Set name="name">configured</Set>
                    <Set name="count" type="Integer">42</Set>
                    <Set name="publicValue">field-value</Set>
                    <Set name="object">object-value</Set>
                    <Set name="converted">converted-value</Set>
                    <Set name="constructedViaNew">
                      <New class="%s">
                        <Arg>constructed-via-new</Arg>
                      </New>
                    </Set>
                    <Get name="child" id="childFromGetter">
                      <Set name="name">from-getter</Set>
                    </Get>
                    <Get name="fieldChild" id="fieldChild">
                      <Set name="name">from-field-getter</Set>
                    </Get>
                    <Call name="createChild" id="calledChild">
                      <Arg>from-call</Arg>
                      <Set name="name">configured-by-call</Set>
                    </Call>
                  </Configure>
                  """.formatted(beanClass, constructorTargetClass);
  
          XmlConfiguration configuration = new XmlConfiguration(xml);
  
          Object configured = configuration.configure();
  
          assertThat(configured).isInstanceOf(ConfigurableBean.class);
          ConfigurableBean bean = (ConfigurableBean) configured;
          assertThat(bean.getName()).isEqualTo("configured");
          assertThat(bean.getCount()).isEqualTo(42);
          assertThat(bean.publicValue).isEqualTo("field-value");
          assertThat(bean.getObject()).isEqualTo("object-value");
          assertThat(bean.getConverted().getValue()).isEqualTo("converted-value");
          assertThat(bean.getConstructedViaNew().getValue()).isEqualTo("constructed-via-new");
          assertThat(bean.getChild().getName()).isEqualTo("from-getter");
          assertThat(bean.fieldChild.getName()).isEqualTo("from-field-getter");
          assertThat(bean.getCreatedChild().getName()).isEqualTo("configured-by-call");
          assertThat(configuration.getIdMap())
                  .containsEntry("bean", bean)
                  .containsEntry("childFromGetter", bean.getChild())
                  .containsEntry("fieldChild", bean.fieldChild)
                  .containsEntry("calledChild", bean.getCreatedChild());
      }
  
      public static class ConfigurableBean {
          public String publicValue;
          public Child fieldChild = new Child("field-child");
  
          private String name;
          private int count;
          private Object object;
          private ConstructorTarget converted;
          private ConstructorTarget constructedViaNew;
          private final Child child = new Child("child");
          private Child createdChild;
  
          public ConfigurableBean() {
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public String getName() {
              return name;
          }
  
          public void setCount(int count) {
              this.count = count;
          }
  
          public int getCount() {
              return count;
          }
  
          public void setObject(Object object) {
              this.object = object;
          }
  
          public Object getObject() {
              return object;
          }
  
          public void setConverted(ConstructorTarget converted) {
              this.converted = converted;
          }
  
          public ConstructorTarget getConverted() {
              return converted;
          }
  
          public void setConstructedViaNew(ConstructorTarget constructedViaNew) {
              this.constructedViaNew = constructedViaNew;
          }
  
          public ConstructorTarget getConstructedViaNew() {
              return constructedViaNew;
          }
  
          public Child getChild() {
              return child;
          }
  
          public Child createChild(String name) {
              createdChild = new Child(name);
              return createdChild;
          }
  
          public Child getCreatedChild() {
              return createdChild;
          }
      }
  
      public static class Child {
          private String name;
  
          public Child() {
          }
  
          public Child(String name) {
              this.name = name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public String getName() {
              return name;
          }
      }
  
      public static class ConstructorTarget {
          private final String value;
  
          public ConstructorTarget(String value) {
              this.value = value;
          }
  
          public String getValue() {
              return value;
          }
      }
  }
