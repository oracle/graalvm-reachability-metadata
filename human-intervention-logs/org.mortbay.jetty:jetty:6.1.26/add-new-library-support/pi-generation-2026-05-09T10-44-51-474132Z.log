Field(WEB_APP_CLASS_LOADER_CLASS_CACHE);\n        classCache.setAccessible(true);\n        Object originalClassCache = classCache.get(null);\n        try {\n            classCache.set(null, null);\n            Thread.currentThread().setContextClassLoader(null);\n\n            WebAppClassLoader loader = new WebAppClassLoader(context);\n            try {\n                assertThat(loader.getParent()).isNotNull();\n            } finally {\n                loader.close();\n            }\n        } finally {\n            classCache.set(null, originalClassCache);\n            Thread.currentThread().setContextClassLoader(originalContextLoader);\n        }\n    }"}]}
