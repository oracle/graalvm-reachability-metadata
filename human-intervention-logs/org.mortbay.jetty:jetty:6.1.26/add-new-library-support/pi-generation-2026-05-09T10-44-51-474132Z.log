[tool-call] delta {"path":"tests/src/org.mortbay.jetty/jetty/6.1.26/src/test/java/org_mortbay_jetty/jetty/WebAppClassLoaderTest.java","edits":[{"oldText":"import org.junit.jupiter.api.Test;\nimport org.mortbay.jetty.webapp.WebAppClassLoader;","newText":"import org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\nimport org.junit.jupiter.api.MethodOrderer.OrderAnnotation;\nimport org.mortbay.jetty.webapp.WebAppClassLoader;"},{"oldText":"public class WebAppClassLoaderTest {\n    private static final String TEST_RESOURCE = \"org_mortbay_jetty/jetty/resource-test/classpath-resource.txt\";\n\n    @Test\n    void usesParentFirstWhenParentLoaderPriorityIsEnabled() throws Exception {","newText":"@TestMethodOrder(OrderAnnotation.class)\npublic class WebAppClassLoaderTest {\n    private static final String TEST_RESOURCE = \"org_mortbay_jetty/jetty/resource-test/classpath-resource.txt\";\n\n    @Test\n    @Order(1)\n    void usesWebAppClassLoaderClassLoaderWhenNoParentOrThreadContextLoaderIsAvailable() throws Exception {\n        WebAppContext context = new WebAppContext();\n        ClassLoader originalContextLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n\n            WebAppClassLoader loader = new WebAppClassLoader(context);\n            try {\n                assertThat(loader.getParent()).isSameAs(WebAppClassLoader.class.getClassLoader());\n            } finally {\n                loader.close();\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextLoader);\n        }\n    }\n\n    @Test\n    @Order(2)\n    void usesParentFirstWhenParentLoaderPriorityIsEnabled() throws Exception {"},{"oldText":"    @Test\n    void fallsBackToParentForApplicationResourceAndClass() throws Exception {","newText":"    @Test\n    @Order(3)\n    void fallsBackToParentForApplicationResourceAndClass() throws Exception {"}]}
[tool-call] end id=call_2pISwHBgFa7LIIcL9cpgkL93|fc_01a4161401f6a12c0169ff10bce10c819cb4ebc092b3c32735 name=edit args={"path": "tests/src/org.mortbay.jetty/jetty/6.1.26/src/test/java/org_mortbay_jetty/jetty/WebAppClassLoaderTest.java", "edits": [{"oldText": "import org.junit.jupiter.api.Test;\nimport org.mortbay.jetty.webapp.WebAppClassLoader;", "newText": "import org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\nimport org.junit.jupiter.api.MethodOrderer.OrderAnnotation;\nimport org.mortbay.jetty.webapp.WebAppClassLoader;"}, {"oldText": "public class WebAppClassLoaderTest {\n    private static final String TEST_RESOURCE = \"org_mortbay_jetty/jetty/resource-test/classpath-resource.txt\";\n\n    @Test\n    void usesParentFirstWhenParentLoaderPriorityIsEnabled() throws Exception {", "newText": "@TestMethodOrder(OrderAnnotation.class)\npublic class WebAppClassLoaderTest {\n    private static final String TEST_RESOURCE = \"org_mortbay_jetty/jetty/resource-test/classpath-resource.txt\";\n\n    @Test\n    @Order(1)\n    void usesWebAppClassLoaderClassLoaderWhenNoParentOrThreadContextLoaderIsAvailable() throws Exception {\n        WebAppContext context = new WebAppContext();\n        ClassLoader originalContextLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(null);\n\n            WebAppClassLoader loader = new WebAppClassLoader(context);\n            try {\n                assertThat(loader.getParent()).isSameAs(WebAppClassLoader.class.getClassLoader());\n            } finally {\n                loader.close();\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextLoader);\n        }\n    }\n\n    @Test\n    @Order(2)\n    void usesParentFirstWhenParentLoaderPriorityIsEnabled() throws Exception {"}, {"oldText": "    @Test\n    void fallsBackToParentForApplicationResourceAndClas