.isInstanceOf(ConfiguredListener.class);\n        } finally {\n            if (previousValidationSetting == null) {\n                System.clearProperty(\"org.mortbay.xml.XmlParser.Validating\");\n            } else {\n                System.setProperty(\"org.mortbay.xml.XmlParser.Validating\", previousValidationSetting);\n            }\n        }\n    }\n\n    public static class ConfiguredListener implements EventListener {\n        public ConfiguredListener() {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778322905839}]}
