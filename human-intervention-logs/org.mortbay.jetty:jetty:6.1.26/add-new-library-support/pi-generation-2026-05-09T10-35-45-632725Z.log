/src/org.mortbay.jetty/jetty/6.1.26/src/test/java/org_mortbay_jetty/jetty/WebXmlConfigurationTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.EventListener;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.mortbay.jetty.webapp.WebAppContext;\nimport org.mortbay.jetty.webapp.WebXmlConfiguration;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class WebXmlConfigurationTest {\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void configuresListenerFromWebXml() throws Exception {\n        String previousValidationSetting = System.setProperty(\"org.mortbay.xml.XmlParser.Validating\", \"false\");\n        try {\n            WebAppContext context = new WebAppContext();\n            context.setClassLoader(Thread.currentThread().getContextClassLoader());\n\n            WebXmlConfiguration configuration = new WebXmlConfiguration();\n            configuration.setWebAppContext(context);\n\n            Path webXml = temporaryDirectory.resolve(\"web.xml\");\n            Files.writeString(webXml, \"\"\"\n                    <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                    <web-app>\n                      <display-name>configured-webapp</display-name>\n                      <context-param>\n                        <param-name>configured-param</param-name>\n                        <param-value>configured-value</param-value>\n                      </context-param>\n                      <listener>\n                        <listener-class>%s</listener-class>\n                      </listener>\n                      <welcome-file-list>\n                        <welcome-file>index.html</welcome-file>\n                      </welcome-file-list>\n                    </web-app>\n                    \"\"\".formatted(ConfiguredListener.class.getName()));\n\n            configuration.configure(webXml.toUri().toURL().toString());\n\n            assertThat(context.getDisplayName()).isEqualTo(\"configured-webapp\");\n            assertThat(context.getInitParams()).containsEntry(\"configured-param\", \"configured-value\");\n            assertThat(context.getWelcomeFiles()).containsExactly(\"index.html\");\n            assertThat(context.getEventListeners())\n                    .hasSize(1)\n                    .first()\n                    .isInstanceOf(ConfiguredListener.class);\n        } finally {\n            if (previousValidationSetting == null) {\n                System.clearProperty(\"org.mortbay.xml.XmlParser.Validating\");\n            } else {\n                System.setProperty(\"org.mortbay.xml.XmlParser.Validating\", previousValidationSetting);\n            }\n        }\n    }\n\n    public static class ConfiguredListener implements EventListener {\n        public ConfiguredListener() {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 430, "output": 1736, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 44150, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778322861415, "responseId": "resp_010f44f18208fa560169ff0dadf6fc8190999397cd46336833"}}
