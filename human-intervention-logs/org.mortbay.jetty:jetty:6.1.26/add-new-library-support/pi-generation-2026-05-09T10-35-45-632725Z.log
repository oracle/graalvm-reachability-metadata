      public Context(HandlerContainer parent, String contextPath, int options)
      {
          this(parent,contextPath,((options&SESSIONS)!=0)?new SessionHandler():null,((options&SECURITY)!=0)?new SecurityHandler():null,null,null);
      }
      
      /* ------------------------------------------------------------ */
