ot, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mortbay_jetty.jetty;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\n\nimport org.junit.jupiter.api.Test;\nimport org.mortbay.resource.Resource;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ResourceTest {\n    private static final String RESOURCE_DIRECTORY = \"org_mortbay_jetty/jetty/resource-test\";\n\n    @Test\n    void findsSystemResourceAfterStrippingLeadingSlash() throws Exception {\n        Resource resource = Resource.newSystemResource(\"/\" + RESOURCE_DIRECTORY + \"/system-resource.txt\");\n\n        assertThat(resource).isNotNull();\n        assertThat(readContent(resource)).isEqualTo(\"system resource content\\n\");\n    }\n\n    @Test\n    void returnsNullWhenSystemResourceIsAbsentAcrossAllLookupStrategies() throws Exception {\n        String absentResource = \"/\" + RESOURCE_DIRECTORY + \"/absent-system-resource.txt\";\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(ClassLoader.getPlatformClassLoader());\n\n            Resource resource = Resource.newSystemResource(absentResource);\n\n            assertThat(resource).isNull();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    @Test\n    void findsClasspathResourceWithClassResourceLookup() throws Exception {\n        Resource resource = Resource.newClassPathResource(\"/\" + RESOURCE_DIRECTORY + \"/classpath-resource.txt\");\n\n        assertThat(resource).isNotNull();\n        assertThat(readContent(resource)).isEqualTo(\"classpath resource content\\n\");\n    }\n\n    @Test\n    void fallsBackToSystemClasspathLookupWhenLoaderResourceLookupThrowsClassNotFoundException() {\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(new ThrowingResourceClassLoader(originalClassLoader));\n\n            Resource resource = Resource.newClassPathResource(RESOURCE_DIRECTORY + \"/absent-classpath-resource.txt\");\n\n            assertThat(resource).isNull();\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static String readContent(Resource resource) throws IOException {\n        try {\n            try (InputStream inputStream = resource.getInputStream()) {\n                return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\n            }\n        } finally {\n            resource.release();\n        }\n    }\n\n    private static final class ThrowingResourceClassLoader extends ClassLoader {\n        private ThrowingResourceClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public URL getResource(String name) {\n            throwUnchecked(new ClassNotFoundException(name));\n            return null;\n        }\n\n        @SuppressWarnings(\"unchecked\")\n        private static <T extends Throwable> void throwUnchecked(Throwable throwable) throws T {\n            throw (T) throwable;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1294, "output": 1833, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 31287, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778323209944, "responseId": "resp_096a3d118dbc39960169ff0f0a7d4881a38a06c134acba88a7"}}
