  import org.gradle.api.tasks.compile.JavaCompile
  import org.gradle.api.tasks.testing.Test
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "io.airlift:slice:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  def patchedJavaBaseSources = file("src/testPatch/java")
  def patchedJavaBaseClasses = layout.buildDirectory.dir("patched-java-base")
  
  tasks.register("compilePatchedJavaBase", JavaCompile) {
      source = fileTree(patchedJavaBaseSources) {
          include "**/*.java"
      }
      classpath = files()
      destinationDirectory = patchedJavaBaseClasses
      options.compilerArgs.addAll([
          "--patch-module", "java.base=${patchedJavaBaseSources.absolutePath}",
          "--add-exports", "java.base/jdk.internal.foreign=java.base",
          "--add-exports", "java.base/jdk.internal.ref=java.base",
          "--add-exports", "java.base/sun.nio.ch=java.base"
      ])
  }
  
  tasks.withType(Test).configureEach {
      dependsOn tasks.named("compilePatchedJavaBase")
      jvmArgs += [
          "--add-opens=java.base/java.nio=ALL-UNNAMED",
          "--patch-module=java.base=${patchedJavaBaseClasses.get().asFile.absolutePath}"
      ]
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          all {
              buildArgs.addAll([
                  '--add-opens=java.base/java.nio=ALL-UNNAMED'
              ])
          }
      }
  }
