  tests/src/io.airlift/slice/0.36/src/test/java/io_airlift/slice/JvmUtilsTest.java
  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package io_airlift.slice;
  
  import io.airlift.slice.Slice;
  import io.airlift.slice.Slices;
  import org.junit.jupiter.api.Test;
  
  import java.nio.ByteBuffer;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JvmUtilsTest {
      @Test
      void directBufferAccessInitializesJvmUtilsAndRoundTripsDirectMemory() {
          ByteBuffer buffer = ByteBuffer.allocateDirect(8);
          for (int index = 0; index < buffer.capacity(); index++) {
              buffer.put(index, (byte) (index + 1));
          }
          buffer.position(2);
          buffer.limit(6);
  
          try {
              Slice slice = Slices.wrappedBuffer(buffer);
  
              assertThat(slice.length()).isEqualTo(4);
              assertThat(slice.getBase()).isNull();
              assertThat(slice.getAddress()).isPositive();
              assertThat(slice.getByte(0)).isEqualTo((byte) 3);
              assertThat(slice.getByte(3)).isEqualTo((byte) 6);
  
              slice.setByte(1, 99);
              assertThat(buffer.get(3)).isEqualTo((byte) 99);
  
              Slice directSlice = Slices.allocateDirect(5);
              directSlice.setBytes(0, new byte[] {10, 11, 12, 13, 14});
  
              ByteBuffer directBuffer = directSlice.toByteBuffer();
  
              assertThat(directBuffer.isDirect()).isTrue();
              assertThat(directBuffer.remaining()).isEqualTo(5);
              assertThat(directBuffer.get(2)).isEqualTo((byte) 12);
  
              directBuffer.put(3, (byte) 42);
              assertThat(directSlice.getByte(3)).isEqualTo((byte) 42);
          }
          catch (ExceptionInInitializerError error) {
              assertThat(hasMissingLegacyDirectByteBufferConstructor(error))
                      .as("JvmUtils should either initialize or fail only because this JDK removed " +
                              "the legacy DirectByteBuffer constructor")
                      .isTrue();
          }
      }
  
      private static boolean hasMissingLegacyDirectByteBufferConstructor(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof NoSuchMethodException && current.getMessage() != null &&
                      current.getMessage().contains("java.nio.DirectByteBuffer.<init>(long,int,java.lang.Object)")) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  }
