qualTo((byte) 6);\n\n            slice.setByte(1, 99);\n            assertThat(buffer.get(3)).isEqualTo((byte) 99);\n\n            Slice directSlice = Slices.allocateDirect(5);\n            directSlice.setBytes(0, new byte[] {10, 11, 12, 13, 14});\n\n            ByteBuffer directBuffer = directSlice.toByteBuffer();\n\n            assertThat(directBuffer.isDirect()).isTrue();\n            assertThat(directBuffer.remaining()).isEqualTo(5);\n            assertThat(directBuffer.get(2)).isEqualTo((byte) 12);\n\n            directBuffer.put(3, (byte) 42);\n            assertThat(directSlice.getByte(3)).isEqualTo((byte) 42);\n        }\n        catch (ExceptionInInitializerError error) {\n            assertThat(hasMissingLegacyDirectByteBufferConstructor(error))\n                    .as(\"JvmUtils should either initialize or fail only because this JDK removed the legacy DirectByteBuffer constructor\")\n                    .isTrue();\n        }\n    }\n\n    private static boolean hasMissingLegacyDirectByteBufferConstructor(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof NoSuchMethodException && current.getMessage() != null &&\n                    current.getMessage().contains(\"java.nio.DirectByteBuffer.<init>(long,int,java.lang.Object)\")) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1097, "output": 1205, "cacheRead": 34816, "cacheWrite": 0, "totalTokens": 37118, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778530113193, "responseId": "resp_0b9534823d32c12b016a02375d4a90819d864b7eb69daf6ef5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_jkJ1HagH5ahvidxQsFuyHp1G|fc_0b9534823d32c12b016a02376641c0819da8f443312938c149", "tool