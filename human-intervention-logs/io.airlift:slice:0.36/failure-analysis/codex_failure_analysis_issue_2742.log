r;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class JvmUtilsTest {\\n    @Test\\n    void wrappedBufferReadsAndWritesDirectBufferVisibleRegion() {\\n        ByteBuffer buffer = ByteBuffer.allocateDirect(8);\\n        for (int index = 0; index < buffer.capacity(); index++) {\\n            buffer.put(index, (byte) (index + 1));\\n        }\\n        buffer.position(2);\\n        buffer.limit(6);\\n\\n        Slice slice = Slices.wrappedBuffer(buffer);\\n\\n        assertThat(slice.length()).isEqualTo(4);\\n        assertThat(slice.getBase()).isNull();\\n        assertThat(slice.getAddress()).isPositive();\\n        assertThat(slice.getByte(0)).isEqualTo((byte) 3);\\n        assertThat(slice.getByte(3)).isEqualTo((byte) 6);\\n\\n        slice.setByte(1, 99);\\n        assertThat(buffer.get(3)).isEqualTo((byte) 99);\\n    }\\n\\n    @Test\\n    void directSliceProducesByteBufferBackedBySameMemory() {\\n        Slice slice = Slices.allocateDirect(5);\\n        slice.setBytes(0, new byte[] {10, 11, 12, 13, 14});\\n\\n        ByteBuffer buffer = slice.toByteBuffer();\\n\\n        assertThat(buffer.isDirect()).isTrue();\\n        assertThat(buffer.remaining()).isEqualTo(5);\\n        assertThat(buffer.get(2)).isEqualTo((byte) 12);\\n\\n        buffer.put(3, (byte) 42);\\n        assertThat(slice.getByte(3)).isEqualTo((byte) 42);\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778530113190}}\nhuman-intervention-logs/io.airlift:slice:0.36/add-new-library-support/pi-generation-2026-05-11T20-05-14-042553Z.log:2625:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_z9DTvC4BnaMEOPWwJInxZsR4|fc_0b9534823d32c12b016a023740a350819db16630da2ae00bde\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org