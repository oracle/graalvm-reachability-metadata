t;\n\n        ZeroAvailableInputStream(String input) {\n            this.bytes = input.getBytes(StandardCharsets.UTF_8);\n        }\n\n        @Override\n        public int read() {\n            if (offset == bytes.length) {\n                return -1;\n            }\n            int next = bytes[offset] & 0xff;\n            offset++;\n            return next;\n        }\n\n        @Override\n        public int available() {\n            return 0;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
