  package org_apache_pekko.pekko_actor_typed_2_13
  
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  
  import com.typesafe.config.Config
  import com.typesafe.config.ConfigFactory
  import org.apache.pekko.actor.typed.ActorSystem
  import org.apache.pekko.actor.typed.scaladsl.Behaviors
  import org.junit.jupiter.api.Assertions.assertTrue
  import org.junit.jupiter.api.Test
  
  class ExtensionsImplTest {
    @Test
    def loadsJavaStyleExtensionIdFromConfiguration(): Unit = {
      val extensionIdClassName: String = classOf[ExtensionsImplJavaSingletonExtensionId].getName
      val config: Config = ConfigFactory
        .parseString(s"""
          pekko.actor.typed.extensions = ["$extensionIdClassName"]
          pekko.loglevel = "WARNING"
          """)
        .withFallback(ConfigFactory.load())
      val system: ActorSystem[Nothing] = ActorSystem[Nothing](Behaviors.empty, "extensions-impl-java-accessor", config)
  
      try {
        assertTrue(system.hasExtension(ExtensionsImplJavaSingletonExtensionId.getInstance()))
      } finally {
        system.terminate()
        Await.result(system.whenTerminated, 10.seconds)
      }
    }
