  package org_apache_pekko.pekko_actor_typed_2_13;
  
  import org.apache.pekko.actor.typed.ActorSystem;
  import org.apache.pekko.actor.typed.Extension;
  import org.apache.pekko.actor.typed.ExtensionId;
  
  public final class JavaSingletonExtensionId extends ExtensionId<JavaSingletonExtensionId.JavaSingletonExtension> {
      private static final JavaSingletonExtensionId INSTANCE = new JavaSingletonExtensionId();
  
      private JavaSingletonExtensionId() {
      }
  
      public static JavaSingletonExtensionId getInstance() {
          return INSTANCE;
      }
  
      @Override
      public JavaSingletonExtension createExtension(ActorSystem<?> system) {
          return new JavaSingletonExtension(system.name());
      }
  
      public static final class JavaSingletonExtension implements Extension {
          private final String systemName;
  
          private JavaSingletonExtension(String systemName) {
              this.systemName = systemName;
          }
  
          public String systemName() {
              return systemName;
          }
      }
