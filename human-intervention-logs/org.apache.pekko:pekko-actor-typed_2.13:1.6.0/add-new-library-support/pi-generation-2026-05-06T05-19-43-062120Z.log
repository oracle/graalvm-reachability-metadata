  package org_apache_pekko.pekko_actor_typed_2_13
  
  import scala.concurrent.Await
  import scala.concurrent.duration.DurationInt
  
  import com.typesafe.config.ConfigFactory
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  import org.apache.pekko.actor.typed.ActorSystem
  import org.apache.pekko.actor.typed.scaladsl.Behaviors
  
  class ExtensionsImplTest {
    @Test
    def loadsExtensionIdFromJavaSingletonAccessor(): Unit = {
      val config = ConfigFactory
        .parseString(s"""
          pekko.actor.typed.extensions = ["${classOf[JavaSingletonExtensionId].getName}"]
          pekko.coordinated-shutdown.run-by-actor-system-terminate = off
          """)
        .withFallback(ConfigFactory.load())
      val system = ActorSystem[Nothing](Behaviors.empty, "extensions-impl-java-singleton-accessor", config)
  
      try {
        val extensionId = JavaSingletonExtensionId.getInstance()
  
        assertThat(system.hasExtension(extensionId)).isTrue()
        assertThat(system.extension(extensionId).systemName()).isEqualTo(system.name)
      } finally {
        system.terminate()
        Await.result(system.whenTerminated, 10.seconds)
      }
    }
  }
