tj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777834649018}, {"role": "toolResult", "toolCallId": "call_FQvlibXu0ctVdWKL4RjRjedq|fc_0a5e8309bbfeb06e0169f79a98ccd081a3ade0a781dced30c0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.ClickHouseUtils;\nimport com.clickhouse.data.format.tsv.FastByteArrayOutputStream;\nimport java.io.InputStream;\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class ClickHouseUtilsTest {\n    private static final String CLASSPATH_RESOURCE = \"com_clickhouse/clickhouse_data/clickhouse-utils-resource.txt\";\n\n    @Test\n    void createsNoArgumentInstanceByClassName() throws Exception {\n        OutputStream output = ClickHouseUtils.newInstance(\n                FastByteArrayOutputStream.class.getName(),\n                OutputStream.class,\n                ClickHouseUtilsTest.class);\n\n        output.write(\"ok\".getBytes(StandardCharsets.UTF_8));\n\n        assertThat(output).isInstanceOf(FastByteArrayOutputStream.class);\n        assertThat(((FastByteArrayOutputStream) output).toByteArray()).containsExactly((byte) 'o', (byte) 'k');\n    }\n\n    @Test\n    void opensClasspathResourceWhenFileDoesNotExistOnDisk() throws Exception {\n        try (InputStream input = ClickHouseUtils.getFileInputStream(CLASSPATH_RESOURCE)) {\n            assertThat(new String(input.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"resource-loaded\\n\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777834649018}, {"role": "toolResult", "toolCallId": "call_n23goTdNv5cA7tOcOpZD9CnG|fc_0a5e8309bbfeb06e0169f79a98ccd881a38754b1d3f3a51edd", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.value.ClickHouseArrayValue;\nimport com.clickhouse.data.value.ClickHouseIntegerValue;\nimport java.util.UUID;\nimport org.junit.jupiter.api.Test;\n\npublic class ClickHouseArrayValueTest {\n    @Test\n    void createsTypedEmptyArray() {\n        ClickHouseArrayValue<Integer> value = ClickHouseArrayValue.ofEmpty(Integer.class);\n\n        Integer[] values = value.asArray(Integer.class);\n\n        assertThat(values).isEmpty();\n    }\n\n    @Test\n    void convertsArrayToRequestedComponentType() {\n        ClickHouseArrayValue<String> value = ClickHouseArrayValue.of(new String[] {\"one\", \"two\"});\n\n        CharSequence[] values = value.asArray(CharSequence.class);\n\n        assertThat(values).containsExactly(\"one\", \"two\");\n    }\n\n    @Test\n    void resetsNonEmptyArrayToTypedDefaultArray() {\n        ClickHouseArrayValue<String> value = ClickHouseArrayValue.of(new String[] {\"initial\"});\n\n        value.resetToDefault();\n\n        assertThat(value.asArray(String.class)).isEmpty();\n    }\n\n    @Test\n    void updatesUnknownObjectAsSingleElementTypedArray() {\n        UUID uuid = UUID.randomUUID();\n        ClickHouseArrayValue<Object> value = ClickHouseArrayValue.ofEmpty();\n\n        value.updateUnknown(uuid);\n\n        assertThat(value.asArray(UUID.class)).containsExactly(uuid);\n    }\n\n    @Test\n    void adaptsScalarValueToNestedArraySlot() {\n        ClickHouseArrayValue<Number[][]> value = ClickHouseArrayValue.of(new Number[1][][]);\n\n        value.setValue(0, ClickHouseIntegerValue.of(42));\n\n        Number[][][] values = value.getValue();\n        assertThat(values[0]).isInstanceOf(Integer[][].class);\n        assertThat(values[0].length).isEqualTo(1);\n        assertThat(values[0][0]).isNull();\n    }\n}\n"}], "isError": false, "timestamp": 1777834649018}]}
