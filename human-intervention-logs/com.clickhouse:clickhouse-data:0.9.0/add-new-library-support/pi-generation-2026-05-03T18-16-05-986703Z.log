  package com_clickhouse.clickhouse_data;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.clickhouse.data.value.ClickHouseArrayValue;
  import com.clickhouse.data.value.ClickHouseIntegerValue;
  import java.util.UUID;
  import org.junit.jupiter.api.Test;
  
  public class ClickHouseArrayValueTest {
      @Test
      void createsTypedEmptyArray() {
          ClickHouseArrayValue<Integer> value = ClickHouseArrayValue.ofEmpty(Integer.class);
  
          Integer[] values = value.asArray(Integer.class);
  
          assertThat(values).isEmpty();
      }
  
      @Test
      void convertsArrayToRequestedComponentType() {
          ClickHouseArrayValue<String> value = ClickHouseArrayValue.of(new String[] {"one", "two"});
  
          CharSequence[] values = value.asArray(CharSequence.class);
  
          assertThat(values).containsExactly("one", "two");
      }
  
      @Test
      void resetsNonEmptyArrayToTypedDefaultArray() {
          ClickHouseArrayValue<String> value = ClickHouseArrayValue.of(new String[] {"initial"});
  
          value.resetToDefault();
  
          assertThat(value.asArray(String.class)).isEmpty();
      }
  
      @Test
      void updatesUnknownObjectAsSingleElementTypedArray() {
          UUID uuid = UUID.randomUUID();
          ClickHouseArrayValue<Object> value = ClickHouseArrayValue.ofEmpty();
  
          value.updateUnknown(uuid);
  
          assertThat(value.asArray(UUID.class)).containsExactly(uuid);
      }
  
      @Test
      void adaptsScalarValueToNestedArraySlot() {
          ClickHouseArrayValue<Number[][]> value = ClickHouseArrayValue.of(new Number[1][][]);
  
          value.setValue(0, ClickHouseIntegerValue.of(42));
  
          Number[][][] values = value.getValue();
          assertThat(values[0]).isInstanceOf(Integer[][].class);
          assertThat(values[0]).hasSize(1);
          assertThat(values[0][0]).isNull();
      }
  }
