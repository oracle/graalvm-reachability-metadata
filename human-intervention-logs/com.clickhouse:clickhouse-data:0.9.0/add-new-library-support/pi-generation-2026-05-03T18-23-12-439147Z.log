  FallbackAlgorithm.reset();\n\n        ClickHouseCompressionAlgorithm algorithm = withSystemProperty(\n                \"chc_reachability_fallback_lib_detection\",\n                \"true\",\n                () -> ClickHouseCompressionAlgorithm.createInstance(\n                        \"reachability_fallback_lib_detection\",\n                        FailingPreferredAlgorithm.class,\n                        FallbackAlgorithm.class));\n\n        assertThat(algorithm).isInstanceOf(FallbackAlgorithm.class);\n        assertThat(FailingPreferredAlgorithm.createdCount()).isEqualTo(1);\n        assertThat(FallbackAlgorithm.createdCount()).isEqualTo(1);\n    }\n\n    private static ClickHouseCompressionAlgorithm withSystemProperty(String key, String value,\n            AlgorithmFactory factory) {\n        String previousValue = System.getProperty(key);\n        try {\n            System.setProperty(key, value);\n            return factory.create();\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(key);\n            } else {\n                System.setProperty(key, previousValue);\n            }\n        }\n    }\n\n    private interface AlgorithmFactory {\n        ClickHouseCompressionAlgorithm create();\n    }\n\n    public static final class CountingAlgorithm implements ClickHouseCompressionAlgorithm {\n        private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\n\n        public CountingAlgorithm() {\n            CREATED_COUNT.incrementAndGet();\n        }\n\n        static void reset() {\n            CREATED_COUNT.set(0);\n        }\n\n        static int createdCount() {\n            return CREATED_COUNT.get();\n        }\n\n        @Override\n        public ClickHouseCompression getAlgorithm() {\n            return ClickHouseCompression.NONE;\n        }\n    }\n\n    public static final class FailingPreferredAlgorithm implements ClickHouseCompressionAlgorithm {\n        private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\n\n        public FailingPreferredAlgorithm() {\n            CREATED_COUNT.incrementAndGet();\n            throw new IllegalStateException(\"Preferred implementation is intentionally unavailable\");\n        }\n\n        static void reset() {\n            CREATED_COUNT.set(0);\n        }\n\n        static int createdCount() {\n            return CREATED_COUNT.get();\n        }\n\n        @Override\n        public ClickHouseCompression getAlgorithm() {\n            return ClickHouseCompression.NONE;\n        }\n    }\n\n    public static final class FallbackAlgorithm implements ClickHouseCompressionAlgorithm {\n        private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\n\n        public FallbackAlgorithm() {\n            CREATED_COUNT.incrementAndGet();\n        }\n\n        static void reset() {\n            CREATED_COUNT.set(0);\n        }\n\n        static int createdCount() {\n            return CREATED_COUNT.get();\n        }\n\n        @Override\n        public ClickHouseCompression getAlgorithm() {\n            return ClickHouseCompression.NONE;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 656, "output": 1653, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 28933, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777832543998, "responseId": "resp_037f8aadcec91f810169f7926073208195bf757d1af40714dc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Rt5pI1yi81khDRKCtpSzqEkm|fc_037f8aadcec91f810169f79269bf848195934b2dd3424593c9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4492 bytes to tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/ClickHouseCompressionAlgorithmTest.java"}], "isError": false, "timestamp": 1777832560559}]}
