[tool-call] delta {"path":"tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/ClickHouseCompressionAlgorithmTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.ClickHouseCompression;\nimport com.clickhouse.data.ClickHouseCompressionAlgorithm;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class ClickHouseCompressionAlgorithmTest {\n    @Test\n    void createsPreferredAlgorithmWhenDetectionIsEnabled() {\n        CountingAlgorithm.reset();\n        FallbackAlgorithm.reset();\n\n        ClickHouseCompressionAlgorithm algorithm = withSystemProperty(\n                \"chc_reachability_preferred_lib_detection\",\n                \"true\",\n                () -> ClickHouseCompressionAlgorithm.createInstance(\n                        \"reachability_preferred_lib_detection\",\n                        CountingAlgorithm.class,\n                        FallbackAlgorithm.class));\n\n        assertThat(algorithm).isInstanceOf(CountingAlgorithm.class);\n        assertThat(CountingAlgorithm.createdCount()).isEqualTo(1);\n        assertThat(FallbackAlgorithm.createdCount()).isZero();\n    }\n\n    @Test\n    void createsDefaultAlgorithmWhenPreferredConstructorFails() {\n        FailingPreferredAlgorithm.reset();\n        FallbackAlgorithm.reset();\n\n        ClickHouseCompressionAlgorithm algorithm = withSystemProperty(\n                \"chc_reachability_fallback_lib_detection\",\n                \"true\",\n                () -> ClickHouseCompressionAlgorithm.createInstance(\n                        \"reachability_fallback_lib_detection\",\n                        FailingPreferredAlgorithm.class,\n                        FallbackAlgorithm.class));\n\n        assertThat(algorithm).isInstanceOf(FallbackAlgorithm.class);\n        assertThat(FailingPreferredAlgorithm.createdCount()).isEqualTo(1);\n        assertThat(FallbackAlgorithm.createdCount()).isEqualTo(1);\n    }\n\n    private static ClickHouseCompressionAlgorithm withSystemProperty(String key, String value,\n            AlgorithmFactory factory) {\n        String previousValue = System.getProperty(key);\n        try {\n            System.setProperty(key, value);\n            return factory.create();\n        } finally {\n            if (previousValue == null) {\n                System.clearProperty(key);\n            } else {\n                System.setProperty(key, previousValue);\n            }\n        }\n    }\n\n    private interface AlgorithmFactory {\n        ClickHouseCompressionAlgorithm create();\n    }\n\n    public static final class CountingAlgorithm implements ClickHouseCompressionAlgorithm {\n        private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\n\n        public CountingAlgorithm() {\n            CREATED_COUNT.incrementAndGet();\n        }\n\n        static void reset() {\n            CREATED_COUNT.set(0);\n        }\n\n        static int createdCount() {\n            return CREATED_COUNT.get();\n        }\n\n        @Override\n        public ClickHouseCompression getAlgorithm() {\n            return ClickHouseCompression.NONE;\n        }\n    }\n\n    public static final class FailingPreferredAlgorithm implements ClickHouseCompressionAlgorithm {\n        private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\n\n        public FailingPreferredAlgorithm() {\n            CREATED_COUNT.incrementAndGet();\n            throw new IllegalStateException(\"Preferred implementation is intentionally unavailable\");\n        }\n\n        static void reset() {\n            CREATED_COUNT.set(0);\n        }\n\n        static int createdCount() {\n            return CREATED_COUNT.get();\n        }\n\n        @Override\n        public ClickHouseCompression getAlgorithm() {\n            return ClickHouseCompression.NONE;\n        }\n    }\n\n    public static final class FallbackAlgorithm implements ClickHouseCompressionAlgorithm {\n        private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\n\n        public FallbackAlgorithm() {\n            CREATED_COUNT.incrementAndGet();\n        }\n\n        static void reset() {\n            CREATED_COUNT.set(0);\n        }\n\n        static int createdCount() {\n            return CREATED_COUNT.get();\n        }\n\n        @Override\n        public ClickHouseCompression getAlgorithm() {\n            return ClickHouseCompression.NONE;\n        }\n    }\n}\n"}
[tool-call] end id=call_Rt5pI1yi81khDRKCtpSzqEkm|fc_037f8aadcec91f810169f79269bf848195934b2dd3424593c9 name=write args={"path": "tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/ClickHouseCompressionAlgorithmTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.ClickHouseCompression;\nimport com.clickhouse.data.ClickHouseCompressionAlgorithm;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class ClickHouseCompressionAlgorithmTest {\n    @Test\n    void createsPreferredAlgorithmWhenDetectionIsEnabled() {\n        CountingAlgorithm.reset();\n        FallbackAlgorithm.reset();\n\n        ClickHouseCompressionAlgorithm algorithm = withSystemProperty(\n                \"chc_reachability_preferred_lib_detection\",\n                \"true\",\n                () -> ClickHouseCompressionAlgorithm.createInstance(\n                        \"reachability_preferred_lib_detection\",\n                        CountingAlgorithm.class,\n                        FallbackAlgorithm.class));\n\n        assertThat(algorithm).isInstanceOf(CountingAlgorithm.class);\n        assertThat(CountingAlgorithm.createdCount()).isEqualTo(1);\n        assertThat(FallbackAlgorithm.createdCount()).isZero();\n    }\n\n    @Test\n    void createsDefaultAlgorithmWhenPreferredConstructorFails() {\n        FailingPreferredAlgorithm.reset();\n        FallbackAlgorithm.reset();\n\n        ClickHouseCompressionAlgorithm algorithm = withSystemProperty(\n                \"chc_reachability_fallback_lib_detection\",\n                \"true\",\n                () -> ClickHouseCompression