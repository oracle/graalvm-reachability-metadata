[tool-call] delta {"path":"tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/ClickHouseUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.ClickHouseUtils;\nimport com.clickhouse.data.format.tsv.FastByteArrayOutputStream;\nimport java.io.InputStream;\nimport java.io.OutputStream;\nimport java.nio.charset.StandardCharsets;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class ClickHouseUtilsTest {\n    private static final String CLASSPATH_RESOURCE = \"com_clickhouse/clickhouse_data/clickhouse-utils-resource.txt\";\n\n    @Test\n    void createsNoArgumentInstanceByClassName() throws Exception {\n        OutputStream output = ClickHouseUtils.newInstance(\n                FastByteArrayOutputStream.class.getName(),\n                OutputStream.class,\n                ClickHouseUtilsTest.class);\n\n        output.write(\"ok\".getBytes(StandardCharsets.UTF_8));\n\n        assertThat(output).isInstanceOf(FastByteArrayOutputStream.class);\n        assertThat(((FastByteArrayOutputStream) output).toByteArray()).containsExactly('o', 'k');\n    }\n\n    @Test\n    void opensClasspathResourceWhenFileDoesNotExistOnDisk() throws Exception {\n        try (InputStream input = ClickHouseUtils.getFileInputStream(CLASSPATH_RESOURCE)) {\n            assertThat(new String(input.readAllBytes(), StandardCharsets.UTF_8)).isEqualTo(\"resource-loaded\\n\");\n        }\n    }\n}\n"}
