[tool-call] delta {"path":"tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/ClickHouseFormatTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.ClickHouseFormat;\nimport org.junit.jupiter.api.Test;\n\npublic class ClickHouseFormatTest {\n    @Test\n    void initializesOutputOnlyFormatsWithDefaultInputFormats() {\n        assertThat(ClickHouseFormat.MySQLWire.supportsInput()).isFalse();\n        assertThat(ClickHouseFormat.MySQLWire.isBinary()).isTrue();\n        assertThat(ClickHouseFormat.MySQLWire.defaultInputFormat()).isSameAs(ClickHouseFormat.RowBinary);\n\n        assertThat(ClickHouseFormat.Pretty.supportsInput()).isFalse();\n        assertThat(ClickHouseFormat.Pretty.isText()).isTrue();\n        assertThat(ClickHouseFormat.Pretty.defaultInputFormat()).isSameAs(ClickHouseFormat.TabSeparated);\n    }\n\n    @Test\n    void resolvesFormatsFromCommonFileNames() {\n        assertThat(ClickHouseFormat.fromFileName(\"events.json.gz\")).isSameAs(ClickHouseFormat.JSONEachRow);\n        assertThat(ClickHouseFormat.fromFileName(\"events.arrow\")).isSameAs(ClickHouseFormat.Arrow);\n        assertThat(ClickHouseFormat.fromFileName(\"events.unknown\")).isNull();\n    }\n}\n"}
