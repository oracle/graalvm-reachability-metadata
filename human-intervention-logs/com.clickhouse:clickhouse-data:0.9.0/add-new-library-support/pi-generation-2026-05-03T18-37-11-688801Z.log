  package com_clickhouse.clickhouse_data;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.clickhouse.data.ClickHouseCompression;
  import com.clickhouse.data.ClickHouseCompressionAlgorithm;
  import java.util.concurrent.atomic.AtomicInteger;
  import org.junit.jupiter.api.Test;
  
  @SuppressWarnings("deprecation")
  public class ClickHouseCompressionAlgorithmTest {
      @Test
      void createsPreferredAlgorithmWhenDetectionIsEnabled() {
          CountingAlgorithm.reset();
          FallbackAlgorithm.reset();
  
          ClickHouseCompressionAlgorithm algorithm = withSystemProperty(
                  "chc_reachability_preferred_lib_detection",
                  "true",
                  () -> ClickHouseCompressionAlgorithm.createInstance(
                          "reachability_preferred_lib_detection",
                          CountingAlgorithm.class,
                          FallbackAlgorithm.class));
  
          assertThat(algorithm).isInstanceOf(CountingAlgorithm.class);
          assertThat(CountingAlgorithm.createdCount()).isEqualTo(1);
          assertThat(FallbackAlgorithm.createdCount()).isZero();
      }
  
      @Test
      void createsDefaultAlgorithmWhenPreferredConstructorFails() {
          FailingPreferredAlgorithm.reset();
          FallbackAlgorithm.reset();
  
          ClickHouseCompressionAlgorithm algorithm = withSystemProperty(
                  "chc_reachability_fallback_lib_detection",
                  "true",
                  () -> ClickHouseCompressionAlgorithm.createInstance(
                          "reachability_fallback_lib_detection",
                          FailingPreferredAlgorithm.class,
                          FallbackAlgorithm.class));
  
          assertThat(algorithm).isInstanceOf(FallbackAlgorithm.class);
          assertThat(FailingPreferredAlgorithm.createdCount()).isEqualTo(1);
          assertThat(FallbackAlgorithm.createdCount()).isEqualTo(1);
      }
  
      private static ClickHouseCompressionAlgorithm withSystemProperty(String key, String value,
              AlgorithmFactory factory) {
          String previousValue = System.getProperty(key);
          try {
              System.setProperty(key, value);
              return factory.create();
          } finally {
              if (previousValue == null) {
                  System.clearProperty(key);
              } else {
                  System.setProperty(key, previousValue);
              }
          }
      }
  
      private interface AlgorithmFactory {
          ClickHouseCompressionAlgorithm create();
      }
  
      public static final class CountingAlgorithm implements ClickHouseCompressionAlgorithm {
          private static final AtomicInteger CREATED_COUNT = new AtomicInteger();
  
          public CountingAlgorithm() {
              CREATED_COUNT.incrementAndGet();
          }
  
          static void reset() {
              CREATED_COUNT.set(0);
          }
  
          static int createdCount() {
              return CREATED_COUNT.get();
          }
  
          @Override
          public ClickHouseCompression getAlgorithm() {
              return ClickHouseCompression.NONE;
          }
      }
  
      public static final class FailingPreferredAlgorithm implements ClickHouseCompressionAlgorithm {
          private static final AtomicInteger CREATED_COUNT = new AtomicInteger();
  
          public FailingPreferredAlgorithm() {
              CREATED_COUNT.incrementAndGet();
              throw new IllegalStateException("Preferred implementation is intentionally unavailable");
          }
  
          static void reset() {
              CREATED_COUNT.set(0);
          }
  
          static int createdCount() {
              return CREATED_COUNT.get();
          }
  
          @Override
          public ClickHouseCompression getAlgorithm() {
              return ClickHouseCompression.NONE;
          }
      }
  
      public static final class FallbackAlgorithm implements ClickHouseCompressionAlgorithm {
          private static final AtomicInteger CREATED_COUNT = new AtomicInteger();
  
          public FallbackAlgorithm() {
              CREATED_COUNT.incrementAndGet();
          }
  
          static void reset() {
              CREATED_COUNT.set(0);
          }
  
          static int createdCount() {
              return CREATED_COUNT.get();
          }
  
          @Override
          public ClickHouseCompression getAlgorithm() {
              return ClickHouseCompression.NONE;
          }
      }
