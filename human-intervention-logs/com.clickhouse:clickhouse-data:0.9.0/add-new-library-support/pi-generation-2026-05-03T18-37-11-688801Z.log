              for (int i = 0, len = setters.length; i < len; i++) {
                  PropertySetter setter = setters[i];
                  setter.accept(obj, r.getValue(setter.index));
              }
              return obj;
          } catch (Exception e) {
              throw new IllegalArgumentException("Failed to map record to specified class", e);
          }
      }
  }
