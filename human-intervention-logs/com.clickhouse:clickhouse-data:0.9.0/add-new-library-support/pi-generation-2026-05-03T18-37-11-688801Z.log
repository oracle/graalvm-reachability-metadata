[tool-call] delta {"path":"tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/AbstractRecordMapperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.ClickHouseColumn;\nimport com.clickhouse.data.ClickHouseRecord;\nimport com.clickhouse.data.ClickHouseRecordMapper;\nimport com.clickhouse.data.ClickHouseSimpleRecord;\nimport com.clickhouse.data.ClickHouseValue;\nimport com.clickhouse.data.value.ClickHouseIntegerValue;\nimport com.clickhouse.data.value.ClickHouseStringValue;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class AbstractRecordMapperTest {\n    private String name;\n    private int count;\n\n    @Test\n    void mapsRecordToBeanWithDefaultConstructorAndSetters() {\n        List<ClickHouseColumn> columns = List.of(\n                ClickHouseColumn.of(\"name\", \"String\"),\n                ClickHouseColumn.of(\"count\", \"Int32\"));\n        Map<String, Integer> columnIndexes = new LinkedHashMap<>();\n        columnIndexes.put(\"name\", 0);\n        columnIndexes.put(\"count\", 1);\n        ClickHouseRecord record = ClickHouseSimpleRecord.of(columnIndexes, new ClickHouseValue[] {\n                ClickHouseStringValue.of(\"alpha\"),\n                ClickHouseIntegerValue.of(7)\n        });\n\n        ClickHouseRecordMapper mapper = ClickHouseRecordMapper.of(null, columns, AbstractRecordMapperTest.class);\n\n        AbstractRecordMapperTest mapped = mapper.mapTo(record, AbstractRecordMapperTest.class);\n        assertThat(mapped).isNotSameAs(this);\n        assertThat(mapped.name).isEqualTo(\"alpha\");\n        assertThat(mapped.count).isEqualTo(7);\n    }\n\n    public void setName(String name) {\n        this.name = name;\n    }\n\n    public void setCount(int count) {\n        this.count = count;\n    }\n}\n"}
[tool-call] end id=call_1EQRq7rDHhy6X6hRw8lfSgsY|fc_02acab57d86dfa6a0169f795b1deec819eae1aec3f40335e75 name=write args={"path": "tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/AbstractRecordMapperTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_clickhouse.clickhouse_data;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.clickhouse.data.ClickHouseColumn;\nimport com.clickhouse.data.ClickHouseRecord;\nimport com.clickhouse.data.ClickHouseRecordMapper;\nimport com.clickhouse.data.ClickHouseSimpleRecord;\nimport com.clickhouse.data.ClickHouseValue;\nimport com.clickhouse.data.value.ClickHouseIntegerValue;\nimport com.clickhouse.data.value.ClickHouseStringValue;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\n@SuppressWarnings(\"deprecation\")\npublic class AbstractRecordMapperTest {\n    private String name;\n    private int count;\n\n    @Test\n    void mapsRecordToBeanWithDefaultConstructorAndSetters() {\n        List<ClickHouseColumn> columns = List.of(\n                ClickHouseColumn.of(\"name\", \"String\"),\n                ClickHouseColumn.of(\"count\", \"Int32\"));\n        Map<String, Integer> columnIndexes = new LinkedHashMap<>();\n        columnIndexes.put(\"name\", 0);\n        columnIndexes.put(\"count\", 1);\n        ClickHouseRecord record = ClickHouseSimpleRecord.of(columnIndexes, new ClickHouseValue[] {\n                ClickHouseStringValue.of(\"alpha\"),\n                ClickHouseIntegerValue.of(7)\n        });\n\n        ClickHouseRecordMapper mapper = ClickHouseRecordMapper.of(null, columns, AbstractRecordMapperTest.class);\n\n        AbstractRecordMapperTest mapped = mapper.mapTo(record, AbstractRecordMapperTest.class);\n        assertThat(mapped).isNotSameAs(this);\n        assertThat(mapped.name).isEqualTo(\"alpha\");\n        assertThat(mapped.count).isEqualTo(7);\n    }\n\n    public void setName(String name) {\n        this.name = name;\n    }\n\n    public void setCount(int count) {\n        this.count = count;\n    }\n}\n"}
