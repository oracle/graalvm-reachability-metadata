g\"),\n                ClickHouseColumn.of(\"count\", \"Int32\"));\n        Map<String, Integer> columnIndexes = new LinkedHashMap<>();\n        columnIndexes.put(\"name\", 0);\n        columnIndexes.put(\"count\", 1);\n        ClickHouseRecord record = ClickHouseSimpleRecord.of(columnIndexes, new ClickHouseValue[] {\n                ClickHouseStringValue.of(\"alpha\"),\n                ClickHouseIntegerValue.of(7)\n        });\n\n        ClickHouseRecordMapper mapper = ClickHouseRecordMapper.of(null, columns, AbstractRecordMapperTest.class);\n\n        AbstractRecordMapperTest mapped = mapper.mapTo(record, AbstractRecordMapperTest.class);\n        assertThat(mapped).isNotSameAs(this);\n        assertThat(mapped.name).isEqualTo(\"alpha\");\n        assertThat(mapped.count).isEqualTo(7);\n    }\n\n    public void setName(String name) {\n        this.name = name;\n    }\n\n    public void setCount(int count) {\n        this.count = count;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 509, "output": 1115, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 43608, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777833384119, "responseId": "resp_02acab57d86dfa6a0169f795a89118819ea316024602890546"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_1EQRq7rDHhy6X6hRw8lfSgsY|fc_02acab57d86dfa6a0169f795b1deec819eae1aec3f40335e75", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1982 bytes to tests/src/com.clickhouse/clickhouse-data/0.9.0/src/test/java/com_clickhouse/clickhouse_data/AbstractRecordMapperTest.java"}], "isError": false, "timestamp": 1777833396313}]}
