  package jdom.jdom;
  
  import org.jdom.output.Format;
  import org.jdom.output.XMLOutputter;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FormatInnerDefaultEscapeStrategyTest {
      @Test
      void defaultEscapeStrategyUsesCharsetEncoderForNonBuiltInEncodings() {
          Format format = Format.getRawFormat().setEncoding("windows-1252");
          XMLOutputter outputter = new XMLOutputter(format);
  
          String escapedText = outputter.escapeElementEntities("caf␀e9 ␀a9 ␀a3 ␀ae ␀b0 ␀b5 ␀b6 ␀b7 ␀ba ␀bc ␀bd ␀be ␀c6 ␀d8 ␀df ␀e6 ␀f8 \u2603");
  
          assertThat(escapedText).isEqualTo("caf␀e9 ␀a9 ␀a3 ␀ae ␀b0 ␀b5 ␀b6 ␀b7 ␀ba ␀bc ␀bd ␀be ␀c6 ␀d8 ␀df ␀e6 ␀f8 &#x2603;");
