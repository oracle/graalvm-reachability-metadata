../configure > ../logs/configure-log-kaffe 2>&1 && make > ../logs/make-log-kaffe 2>&1
echo "  build result=$?"
rm -rf ../build/*
unset JAVA_HOME

umount /usr/local
mount 10.0.2.1:/mnt/hda3/local /usr/local

for i in \
