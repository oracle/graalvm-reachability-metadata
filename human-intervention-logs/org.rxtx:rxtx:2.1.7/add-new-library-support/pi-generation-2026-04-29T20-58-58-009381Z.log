  package org_rxtx.rxtx;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import gnu.io.CommPortIdentifier;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  import org.graalvm.nativeimage.hosted.Feature;
  import org.graalvm.nativeimage.hosted.Feature.BeforeAnalysisAccess;
  import org.junit.jupiter.api.Test;
  
  public class CommPortIdentifierTest implements Feature {
      private static final List<?> BUILD_TIME_DISCOVERED_IDENTIFIERS = listPortIdentifiers();
  
      @Override
      public void beforeAnalysis(BeforeAnalysisAccess access) {
          listPortIdentifiers();
      }
  
      @Test
      void getPortIdentifiersCreatesDriverAndReturnsEnumeration() {
          assertContainsOnlyCommPortIdentifiers(BUILD_TIME_DISCOVERED_IDENTIFIERS);
          assertContainsOnlyCommPortIdentifiers(listPortIdentifiers());
      }
  
      private static List<?> listPortIdentifiers() {
          Enumeration<?> identifiers = CommPortIdentifier.getPortIdentifiers();
          return Collections.list(identifiers);
      }
  
      private static void assertContainsOnlyCommPortIdentifiers(List<?> discoveredIdentifiers) {
          assertThat(discoveredIdentifiers)
                  .allSatisfy(identifier -> assertThat(identifier).isInstanceOf(CommPortIdentifier.class));
      }
  }
