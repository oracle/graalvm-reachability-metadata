[tool-call] delta {"path":"tests/src/org.rxtx/rxtx/2.1.7/src/test/java/org_rxtx/rxtx/CommPortIdentifierTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_rxtx.rxtx;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport gnu.io.CommPortIdentifier;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class CommPortIdentifierTest {\n    @Test\n    void getPortIdentifiersCreatesDriverAndReturnsEnumeration() {\n        Enumeration<?> identifiers = CommPortIdentifier.getPortIdentifiers();\n        List<?> discoveredIdentifiers = Collections.list(identifiers);\n\n        assertThat(discoveredIdentifiers)\n                .allSatisfy(identifier -> assertThat(identifier).isInstanceOf(CommPortIdentifier.class));\n    }\n}\n"}
