  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  import java.util.Locale
  
  import org.gradle.api.file.Directory
  import org.gradle.api.file.RegularFile
  import org.gradle.api.provider.Provider
  import org.gradle.api.tasks.Exec
  import org.gradle.api.tasks.testing.Test
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  String rxtxNativeLibraryName = System.mapLibraryName("rxtxSerial")
  Provider<Directory> rxtxNativeDirectory = layout.buildDirectory.dir("rxtx-native")
  Provider<RegularFile> rxtxNativeLibrary = rxtxNativeDirectory.map { directory -> directory.file(rxtxNativeLibraryName) }
  RegularFile rxtxNativeStub = layout.projectDirectory.file("src/test/native/rxtxSerialStub.c")
  
  String jniPlatformIncludeDirectory() {
      String osName = System.getProperty("os.name").toLowerCase(Locale.ROOT)
      if (osName.contains("mac")) {
          return "darwin"
      }
      if (osName.contains("win")) {
          return "win32"
      }
      return "linux"
  }
  
  tasks.register("compileRxtxNativeStub", Exec) {
      inputs.file(rxtxNativeStub)
      outputs.file(rxtxNativeLibrary)
  
      doFirst {
          rxtxNativeDirectory.get().asFile.mkdirs()
          String javaHome = System.getProperty("java.home")
          List<String> sharedLibraryFlags = System.getProperty("os.name").toLowerCase(Locale.ROOT).contains("mac")
                  ? ["-dynamiclib", "-fPIC"]
                  : ["-shared", "-fPIC"]
          String cCompiler = System.getenv("CC") ?: "gcc"
          commandLine([cCompiler] + sharedLibraryFlags + [
                  "-I${javaHome}/include",
                  "-I${javaHome}/include/${jniPlatformIncludeDirectory()}",
                  "-o",
                  rxtxNativeLibrary.get().asFile.absolutePath,
                  rxtxNativeStub.asFile.absolutePath
          ])
      }
  }
  
  tasks.withType(Test).configureEach {
      dependsOn(tasks.named("compileRxtxNativeStub"))
      jvmArgs += ["-Djava.library.path=${rxtxNativeDirectory.get().asFile.absolutePath}"]
  }
  
  tasks.matching { task -> task.name in ["nativeTest", "nativeTestCompile"] }.configureEach {
      dependsOn(tasks.named("compileRxtxNativeStub"))
  }
  
  dependencies {
      testImplementation "org.rxtx:rxtx:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      binaries {
          test {
              runtimeArgs("-Djava.library.path=${rxtxNativeDirectory.get().asFile.absolutePath}")
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
