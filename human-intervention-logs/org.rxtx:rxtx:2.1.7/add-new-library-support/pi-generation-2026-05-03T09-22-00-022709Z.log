[tool-call] delta {"path":"tests/src/org.rxtx/rxtx/2.1.7/src/test/java/org_rxtx/rxtx/CommPortIdentifierTest.java","edits":[{"oldText":"    void enumeratesKnownPortsWithRxtxDriver() {\n        Enumeration<?> identifiers = CommPortIdentifier.getPortIdentifiers();\n\n        assertThat(identifiers).isNotNull();\n        assertThat(identifiers.hasMoreElements()).isFalse();\n    }","newText":"    void enumeratesKnownPortsWithRxtxDriver() {\n        clearPortOverrideProperties();\n\n        Enumeration<?> identifiers = CommPortIdentifier.getPortIdentifiers();\n\n        assertThat(identifiers).isNotNull();\n        assertThat(identifiers.hasMoreElements()).isTrue();\n        CommPortIdentifier serialIdentifier = (CommPortIdentifier) identifiers.nextElement();\n        assertThat(serialIdentifier.getName()).isEqualTo(\"rxtx-stub-serial\");\n        assertThat(serialIdentifier.getPortType()).isEqualTo(CommPortIdentifier.PORT_SERIAL);\n        assertThat(identifiers.hasMoreElements()).isTrue();\n        CommPortIdentifier parallelIdentifier = (CommPortIdentifier) identifiers.nextElement();\n        assertThat(parallelIdentifier.getName()).isEqualTo(\"rxtx-stub-parallel\");\n        assertThat(parallelIdentifier.getPortType()).isEqualTo(CommPortIdentifier.PORT_PARALLEL);\n        assertThat(identifiers.hasMoreElements()).isFalse();\n    }\n\n    private static void clearPortOverrideProperties() {\n        System.clearProperty(\"gnu.io.rxtx.SerialPorts\");\n        System.clearProperty(\"gnu.io.SerialPorts\");\n        System.clearProperty(\"gnu.io.rxtx.ParallelPorts\");\n        System.clearProperty(\"gnu.io.ParallelPorts\");\n    }"}]}
