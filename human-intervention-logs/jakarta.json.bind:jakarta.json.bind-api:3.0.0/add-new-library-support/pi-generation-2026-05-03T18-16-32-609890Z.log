[tool-call] delta {"path":"tests/src/jakarta.json.bind/jakarta.json.bind-api/3.0.0/src/test/java/jakarta_json_bind/jakarta_json_bind_api/JsonbConfigTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage jakarta_json_bind.jakarta_json_bind_api;\n\nimport jakarta.json.bind.JsonbConfig;\nimport jakarta.json.bind.adapter.JsonbAdapter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\nimport static org.junit.jupiter.api.Assertions.assertSame;\n\npublic class JsonbConfigTest {\n    @Test\n    public void mergesAdaptersRegisteredInMultipleCalls() throws Exception {\n        JsonbAdapter<String, String> firstAdapter = new PrefixAdapter(\"first:\");\n        JsonbAdapter<String, String> secondAdapter = new PrefixAdapter(\"second:\");\n\n        JsonbConfig config = new JsonbConfig()\n                .withAdapters(firstAdapter)\n                .withAdapters(secondAdapter);\n\n        Object adaptersProperty = config.getProperty(JsonbConfig.ADAPTERS).orElseThrow();\n        assertInstanceOf(JsonbAdapter[].class, adaptersProperty);\n\n        JsonbAdapter[] adapters = (JsonbAdapter[]) adaptersProperty;\n        assertEquals(2, adapters.length);\n        assertSame(firstAdapter, adapters[0]);\n        assertSame(secondAdapter, adapters[1]);\n        assertEquals(\"first:value\", adapters[0].adaptToJson(\"value\"));\n        assertEquals(\"second:value\", adapters[1].adaptToJson(\"value\"));\n    }\n\n    private static final class PrefixAdapter implements JsonbAdapter<String, String> {\n        private final String prefix;\n\n        private PrefixAdapter(String prefix) {\n            this.prefix = prefix;\n        }\n\n        @Override\n        public String adaptToJson(String obj) {\n            return prefix + obj;\n        }\n\n        @Override\n        public String adaptFromJson(String obj) {\n            if (!obj.startsWith(prefix)) {\n                throw new IllegalArgumentException(\"Adapted value does not start with the expected prefix\");\n            }\n            return obj.substring(prefix.length());\n        }\n    }\n}\n"}
