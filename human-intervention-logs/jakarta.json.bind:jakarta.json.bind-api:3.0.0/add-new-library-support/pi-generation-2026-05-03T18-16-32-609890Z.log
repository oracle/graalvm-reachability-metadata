;\n\n        Object adaptersProperty = config.getProperty(JsonbConfig.ADAPTERS).orElseThrow();\n        assertInstanceOf(JsonbAdapter[].class, adaptersProperty);\n\n        JsonbAdapter[] adapters = (JsonbAdapter[]) adaptersProperty;\n        assertEquals(2, adapters.length);\n        assertSame(firstAdapter, adapters[0]);\n        assertSame(secondAdapter, adapters[1]);\n        assertEquals(\"first:value\", adapters[0].adaptToJson(\"value\"));\n        assertEquals(\"second:value\", adapters[1].adaptToJson(\"value\"));\n    }\n\n    private static final class PrefixAdapter implements JsonbAdapter<String, String> {\n        private final String prefix;\n\n        private PrefixAdapter(String prefix) {\n            this.prefix = prefix;\n        }\n\n        @Override\n        public String adaptToJson(String obj) {\n            return prefix + obj;\n        }\n\n        @Override\n        public String adaptFromJson(String obj) {\n            if (!obj.startsWith(prefix)) {\n                throw new IllegalArgumentException(\"Adapted value does not start with the expected prefix\");\n            }\n            return obj.substring(prefix.length());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1319, "output": 1069, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 15188, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777832095676, "responseId": "resp_07a81e80d8666c040169f790a009988196863e52db003f05e9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_kGLSbtpvbJFGd1TXHcFcsa6b|fc_07a81e80d8666c040169f790a6bb5c8196a18e0a46bb0dde93", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2124 bytes to tests/src/jakarta.json.bind/jakarta.json.bind-api/3.0.0/src/test/java/jakarta_json_bind/jakarta_json_bind_api/JsonbConfigTest.java"}], "isError": false, "timestamp": 1777832105988}]}
