age, mdc)\\n   865\\t      with LogEventWithMarker\\n   866\\t  class Warning4(\\n   867\\t      logSource: String,\\n   868\\t      logClass: Class[_],\\n   869\\t      message: Any,\\n   870\\t      override val mdc: MDC,\\n   871\\t      override val marker: LogMarker,\\n   872\\t      override val cause: Throwable)\\n   873\\t      extends Warning2(logSource, logClass, message, mdc)\\n   874\\t      with LogEventWithMarker\\n   875\\t      with LogEventWithCause\\n   876\\t  object Warning {\\n   877\\t    def apply(logSource: String, logClass: Class[_], message: Any, mdc: MDC) =\\n   878\\t      new Warning2(logSource, logClass, message, mdc)\\n   879\\t    def apply(logSource: String, logClass: Class[_], message: Any, mdc: MDC, marker: LogMarker) =\\n   880\\t      new Warning3(logSource, logClass, message, mdc, marker)\\n   881\\t\\n   882\\t    def apply(cause: Throwable, logSource: String, logClass: Class[_], message: Any, mdc: MDC) =\\n   883\\t      new Warning4(logSource, logClass, message, mdc, null, cause)\\n   884\\t    def apply(cause: Throwable, logSource: String, logClass: Class[_], message: Any, mdc: MDC, marker: LogMarker) =\\n   885\\t      new Warning4(logSource, logClass, message, mdc, marker, cause)\\n   886\\t  }\\n   887\\t\\n   888\\t  /**\\n   889\\t   * For INFO Logging\\n   890\\t   */\\n   891\\t  case class Info(logSource: String, logClass: Class[_], message: Any = \\\"\\\") extends LogEvent {\\n   892\\t    override def level = InfoLevel\\n   893\\t  }\\n   894\\t  class Info2(logSource: String, logClass: Class[_], message: Any, override val mdc: MDC)\\n   895\\t      extends Info(logSource, logClass, message)\\n   896\\t  class Info3(\\n   897\\t      logSource: String,\\n   898\\t      logClass: Class[_],\\n   899\\t      message: Any,\\n   900\\t      override val mdc: MDC,\\n   901\\t      override val marker: LogMarker)\\n   902\\t      extends Info2(logSource, logClass, message, mdc)\\n   903\\t      with LogEventWithMarker\\n 