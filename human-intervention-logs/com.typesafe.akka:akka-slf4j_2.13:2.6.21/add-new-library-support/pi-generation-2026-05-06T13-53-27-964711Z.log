[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-slf4j_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_slf4j_2_13/Akka_slf4j_2_13Test.scala","edits":[{"oldText":"import akka.actor.{Actor, ActorRef, ActorSystem, Props}\nimport akka.event.{DummyClassForStringSources, LogMarker, Logging}\n","newText":"import akka.actor.{Actor, ActorRef, ActorSystem, Props}\nimport akka.event.{DiagnosticLoggingAdapter, DummyClassForStringSources, LogMarker, Logging}\n"},{"oldText":"import java.util.concurrent.{CompletableFuture, TimeUnit}\nimport java.util.concurrent.atomic.AtomicInteger\n","newText":"import java.util.concurrent.{CompletableFuture, TimeUnit}\nimport java.util.concurrent.atomic.AtomicInteger\nimport java.util.{HashMap, Map => JMap}\n"},{"oldText":"  @Test\n  def slf4jLoggerAcknowledgesInitialization(): Unit = {\n","newText":"  @Test\n  def diagnosticMarkerLoggingAdapterPublishesMdcAndMarkerProperties(): Unit = {\n    withActorSystem(\"Diagnostic\", \"INFO\") { system: ActorSystem =>\n      val expectedMessage: String = \"diagnostic event reached slf4j\"\n      val result: CompletableFuture[Logging.Info] = new CompletableFuture[Logging.Info]()\n      val probe: ActorRef = system.actorOf(Props(new InfoEventProbe(result, expectedMessage)), \"diagnostic-info-probe\")\n      val subscribed: Boolean = system.eventStream.subscribe(probe, classOf[Logging.Info])\n      val adapter = Logging.withMarker(system, \"diagnostic.source\")\n      val diagnosticAdapter: DiagnosticLoggingAdapter = adapter.asInstanceOf[DiagnosticLoggingAdapter]\n      val mdc: JMap[String, AnyRef] = new HashMap[String, AnyRef]()\n      val markerProperties: JMap[String, Any] = new HashMap[String, Any]()\n\n      mdc.put(\"correlationId\", \"correlation-123\")\n      mdc.put(\"attempt\", Integer.valueOf(3))\n      markerProperties.put(\"operation\", \"checkout\")\n      diagnosticAdapter.setMDC(mdc)\n\n      val marker: LogMarker = LogMarker.create(\"diagnostic-marker\", markerProperties)\n      adapter.info(marker, expectedMessage)\n\n      val event: Logging.Info = result.get(10, TimeUnit.SECONDS)\n      val eventWithMarker: Logging.LogEventWithMarker = event.asInstanceOf[Logging.LogEventWithMarker]\n\n      assertThat(subscribed).isTrue()\n      assertThat(diagnosticAdapter.getMDC.get(\"correlationId\")).isEqualTo(\"correlation-123\")\n      assertThat(event.logSource).isEqualTo(\"diagnostic.source\")\n      assertThat(event.mdc.apply(\"correlationId\")).isEqualTo(\"correlation-123\")\n      assertThat(event.mdc.apply(\"attempt\")).isEqualTo(Integer.valueOf(3))\n      assertThat(eventWithMarker.marker.name).isEqualTo(\"diagnostic-marker\")\n      assertThat(eventWithMarker.marker.properties.apply(\"operation\")).isEqualTo(\"checkout\")\n\n      diagnosticAdapter.clearMDC()\n      assertThat(diagnosticAdapter.getMDC).isEmpty()\n    }\n  }\n\n  @Test\n  def slf4jLoggerAcknowledgesInitialization(): Unit = {\n"},{"oldText":"  private final class ReplyProbe(result: CompletableFuture[AnyRef]) extends Actor {\n    override def receive: Receive = { case message: AnyRef =>\n      result.complete(message)\n      context.stop(self)\n    }\n  }\n","newText":"  private final class ReplyProbe(result: CompletableFuture[AnyRef]) extends Actor {\n    override def receive: Receive = { case message: AnyRef =>\n      result.complete(message)\n      context.stop(self)\n    }\n  }\n\n  private final class InfoEventProbe(result: CompletableFuture[Logging.Info], expectedMessage: String) extends Actor {\n    override def receive: Receive = { case info: Logging.Info if info.message.toString == expectedMessage =>\n      result.complete(info)\n      context.stop(self)\n    }\n  }\n"}]}
[tool-call] end id=call_W4tBSLDlyW8cY8EXdejKhS8a|fc_02fcb0fd65d35ca20169fb47becb448193bb00b1a5fbc0490a name=edit args={"path": "tests/src/com.typesafe.akka/akka-slf4j_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_slf4j_2_13/Akka_slf4j_2_13Test.scala", "edits": [{"oldText": "import akka.actor.{Actor, ActorRef, ActorSystem, Props}\nimport akka.event.{DummyClassForStringSources, LogMarker, Logging}\n", "newText": "import akka.actor.{Actor, ActorRef, ActorSystem, Props}\nimport akka.event.{DiagnosticLoggingAdapter, DummyClassForStringSources, LogMarker, Logging}\n"}, {"oldText": "import java.util.concurrent.{CompletableFuture, TimeUnit}\nimport java.util.concurrent.atomic.AtomicInteger\n", "newText": "import java.util.concurrent.{CompletableFuture, TimeUnit}\nimport java.util.concurrent.atomic.AtomicInteger\nimport java.util.{HashMap, Map => JMap}\n"}, {"oldText": "  @Test\n  def slf4jLoggerAcknowledgesInitialization(): Unit = {\n", "newText": "  @Test\n  def diagnosticMarkerLoggingAdapterPublishesMdcAndMarkerProperties(): Unit = {\n    withActorSystem(\"Diagnostic\", \"INFO\") { system: ActorSystem =>\n      val expectedMessage: String = \"diagnostic event reached slf4j\"\n      val result: CompletableFuture[Logging.Info] = new CompletableFuture[Logging.Info]()\n      val probe: ActorRef = system.actorOf(Props(new InfoEventProbe(result, expectedMessage)), \"diagnostic-info-probe\")\n      val subscribed: Boolean = system.eventStream.subscribe(probe, classOf[Logging.Info])\n      val adapter = Logging.withMarker(system, \"diagnostic.source\")\n      val diagnosticAdapter: DiagnosticLoggingAdapter = adapter.asInstanceOf[DiagnosticLoggingAdapter]\n      val mdc: JMap[String, AnyRef] = new HashMap[String, AnyRef]()\n      val markerProperties: JMap[String, Any] = new HashMap[String, Any]()\n\n      mdc.put(\"correlationId\", \"correlation-123\")\n      mdc.put(\"attempt\", Integer.valueOf(3))\n      markerProperties.put(\"operation\", \"checkout\")\n      diagnosticAdapter.setMDC(mdc)\n\n      val marker: LogMarker = LogMarker.create(\"diagnostic-marker\", markerProperties)\n      adapter.info(marker, expectedMessage)\n\n      val event: Logging.Info = result.get(10, TimeUnit.SECONDS)\n      val eventWithMarker: Logging.LogEventWithMarker = event.asInstanceOf[Logging.LogEventWithMarker]\n\n      assertThat(subscribed).isTrue()\n      assertThat(diagnosticAdapter.getMDC.get(\"correlationId\")).isEqualTo(\"correlation-123\")\n      assertThat(event.logSource).isEqualTo(\"diagnostic.source\")\n      assertThat(event.mdc.apply(\"correlationId\")).isEqualTo(\"correlation-123\")\n      assertThat(event.mdc.apply(\"attempt\")).isEqualTo(Integer.valueOf(3))\n      assertThat(eventWithMarker.marker.name).isEqualTo(\"diagnostic-marker\")\n      assertThat(eventWithMarker.marker.properties.apply(\"operation\")).isEqualTo(\"checkout\")\n\n      diagnosticAdapter.clearMDC()\n      assertThat(diagnosticAdapter.getMDC).isEmpty()\n    }\n  }\n\n  @Test\n  def slf4jLoggerAcknowledgesInitialization(): Unit = {\n"}, {"oldText": "  private final class ReplyProbe(result: CompletableFuture[AnyRef]) extends Actor {\n    override def receive: Receive = { case message: AnyRef =>\n      result.complete(message)\n      context.stop(self)\n    }\n  }\n", "newText": "  private final class ReplyProbe(result: CompletableFuture[AnyRef]) extends Actor {\n    override def receive: Receive = { case message: AnyRef =>\n      result.complete(message)\n      context.stop(self)\n    }\n  }\n\n  private final class InfoEventProbe(result: CompletableFuture[Logging.Info], expectedMessage: String) extends Actor {\n    override def receive: Receive = { case info: Logging.Info if info.message.toString == expectedMessage =>\n      result.complete(info)\n      context.stop(self)\n    }\n  }\n"}]}
