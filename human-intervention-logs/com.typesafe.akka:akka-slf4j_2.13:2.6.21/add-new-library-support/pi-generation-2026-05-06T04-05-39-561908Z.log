       1	/*
       2	 * Copyright (C) 2009-2022 Lightbend Inc. <https://www.lightbend.com>
       3	 */
       4	
       5	package akka.event.slf4j
       6	
       7	import org.slf4j.{ MDC, Marker, MarkerFactory, Logger => SLFLogger, LoggerFactory => SLFLoggerFactory }
       8	
       9	import akka.actor._
      10	import akka.dispatch.RequiresMessageQueue
      11	import akka.event.{ LogMarker, _ }
      12	import akka.event.Logging._
      13	import akka.util.{ unused, Helpers }
      14	
      15	/**
      16	 * Base trait for all classes that wants to be able use the SLF4J logging infrastructure.
      17	 */
      18	trait SLF4JLogging {
      19	  @transient
      20	  lazy val log = Logger(this.getClass.getName)
      21	}
      22	
      23	/**
      24	 * Logger is a factory for obtaining SLF4J-Loggers
      25	 */
      26	object Logger {
      27	
      28	  /**
      29	   * @param logger - which logger
      30	   * @return a Logger that corresponds for the given logger name
      31	   */
      32	  def apply(logger: String): SLFLogger = SLFLoggerFactory.getLogger(logger)
      33	
      34	  /**
      35	   * @param logClass - the class to log for
      36	   * @param logSource - the textual representation of the source of this log stream
      37	   * @return a Logger for the specified parameters
      38	   */
      39	  def apply(logClass: Class[_], logSource: String): SLFLogger = logClass match {
      40	    case c if c == classOf[DummyClassForStringSources] => apply(logSource)
      41	    case _                                             => SLFLoggerFactory.getLogger(logClass)
      42	  }
      43	
      44	  /**
      45	   * Returns the SLF4J Root Logger
      46	   */
      47	  def root: SLFLogger = apply(SLFLogger.ROOT_LOGGER_NAME)
      48	}
      49	
      50	/**
      51	 * SLF4J logger.
      52	 *
      53	 * The thread in which the logging was performed is captured in
      54	 * Mapped Diagnostic Context (MDC) with attribute name "sourceThread".
      55	 */
      56	class Slf4jLogger extends Actor with SLF4JLogging with RequiresMessageQueue[LoggerMessageQueueSemantics] {
      57	
      58	  val mdcThreadAttributeName = "sourceThread"
      59	  val mdcActorSystemAttributeName = "sourceActorSystem"
      60	  val mdcAkkaSourceAttributeName = "akkaSource"
      61	  val mdcAkkaTimestamp = "akkaTimestamp"
      62	  val mdcAkkaAddressAttributeName = "akkaAddress"
      63	  val mdcAkkaUidAttributeName = "akkaUid"
      64	
      65	  private def akkaAddress = context.system.asInstanceOf[ExtendedActorSystem].provider.addressString
      66	  private val akkaUid: String = context.system.asInstanceOf[ExtendedActorSystem].uid.toString
      67	
      68	  def receive = {
      69	
      70	    case event @ Error(cause, logSource, logClass, message) =>
      71	      withMdc(logSource, event) {
      72	        cause match {
      73	          case Error.NoCause | null =>
      74	            Logger(logClass, logSource).error(markerIfPresent(event), if (message != null) message.toString else null)
      75	          case _ =>
      76	            Logger(logClass, logSource).error(
      77	              markerIfPresent(event),
      78	              if (message != null) message.toString else cause.getLocalizedMessage,
      79	              cause)
      80	        }
      81	      }
      82	
      83	    case event @ Warning(logSource, logClass, message) =>
      84	      withMdc(logSource, event) {
      85	        event match {
      86	          case e: LogEventWithCause =>
      87	            Logger(logClass, logSource).warn(
      88	              markerIfPresent(event),
      89	              if (message != null) message.toString else e.cause.getLocalizedMessage,
      90	              e.cause)
      91	          case _ =>
      92	            Logger(logClass, logSource).warn(markerIfPresent(event), if (message != null) message.toString else null)
      93	        }
      94	      }
      95	
      96	    case event @ Info(logSource, logClass, message) =>
      97	      withMdc(logSource, event) {
      98	        Logger(logClass, logSource).info(markerIfPresent(event), "{}", message: Any)
      99	      }
     100	
     101	    case event @ Debug(logSource, logClass, message) =>
     102	      withMdc(logSource, event) {
     103	        Logger(logClass, logSource).debug(markerIfPresent(event), "{}", message: Any)
     104	      }
     105	
     106	    case InitializeLogger(_) =>
     107	      log.info("Slf4jLogger started")
     108	      sender() ! LoggerInitialized
     109	  }
     110	
     111	  @inline
     112	  final def withMdc(logSource: String, logEvent: LogEvent)(logStatement: => Unit): Unit = {
     113	    logEvent match {
     114	      case m: LogEventWithMarker if m.marker ne null =>
     115	        val properties = m.marker.properties
     116	        if (properties.nonEmpty) {
     117	          properties.foreach { case (k, v) => MDC.put(k, String.valueOf(v)) }
     118	        }
     119	      case _ =>
     120	    }
     121	
     122	    MDC.put(mdcAkkaSourceAttributeName, logSource)
     123	    MDC.put(mdcThreadAttributeName, logEvent.thread.getName)
     124	    MDC.put(mdcAkkaTimestamp, formatTimestamp(logEvent.timestamp))
     125	    MDC.put(mdcActorSystemAttributeName, context.system.name)
     126	    MDC.put(mdcAkkaAddressAttributeName, akkaAddress)
     127	    MDC.put(mdcAkkaUidAttributeName, akkaUid)
     128	    logEvent.mdc.foreach { case (k, v) => MDC.put(k, String.valueOf(v)) }
     129	
     130	    try logStatement
     131	    finally {
     132	      MDC.clear()
     133	    }
     134	  }
     135	
     136	  private final def markerIfPresent(event: LogEvent): Marker =
     137	    event match {
     138	      case m: LogEventWithMarker =>
     139	        m.marker match {
     140	          case null                        => null
     141	          case slf4jMarker: Slf4jLogMarker => slf4jMarker.marker
     142	          case marker                      => MarkerFactory.getMarker(marker.name)
     143	        }
     144	      case _ => null
     145	    }
     146	
     147	  /**
     148	   * Override this method to provide a differently formatted timestamp
     149	   * @param timestamp a "currentTimeMillis"-obtained timestamp
     150	   * @return the given timestamp as a UTC String
     151	   */
     152	  protected def formatTimestamp(timestamp: Long): String =
     153	    Helpers.currentTimeMillisToUTCString(timestamp)
     154	
     155	}
     156	
     157	/**
     158	 * [[akka.event.LoggingFilter]] that uses the log level defined in the SLF4J
     159	 * backend configuration (e.g. logback.xml) to filter log events before publishing
     160	 * the log events to the `eventStream`.
     161	 */
     162	class Slf4jLoggingFilter(@unused settings: ActorSystem.Settings, eventStream: EventStream)
     163	    extends LoggingFilterWithMarker {
     164	  def isErrorEnabled(logClass: Class[_], logSource: String) =
     165	    (eventStream.logLevel >= ErrorLevel) && Logger(logClass, logSource).isErrorEnabled
     166	  def isWarningEnabled(logClass: Class[_], logSource: String) =
     167	    (eventStream.logLevel >= WarningLevel) && Logger(logClass, logSource).isWarnEnabled
     168	  def isInfoEnabled(logClass: Class[_], logSource: String) =
     169	    (eventStream.logLevel >= InfoLevel) && Logger(logClass, logSource).isInfoEnabled
     170	  def isDebugEnabled(logClass: Class[_], logSource: String) =
     171	    (eventStream.logLevel >= DebugLevel) && Logger(logClass, logSource).isDebugEnabled
     172	
     173	  private def slf4jMarker(marker: LogMarker) = marker match {
     174	    case null                        => null
     175	    case slf4jMarker: Slf4jLogMarker => slf4jMarker.marker
     176	    case marker                      => MarkerFactory.getMarker(marker.name)
     177	  }
     178	
     179	  override def isErrorEnabled(logClass: Class[_], logSource: String, marker: LogMarker): Boolean =
     180	    (eventStream.logLevel >= ErrorLevel) && Logger(logClass, logSource).isErrorEnabled(slf4jMarker(marker))
