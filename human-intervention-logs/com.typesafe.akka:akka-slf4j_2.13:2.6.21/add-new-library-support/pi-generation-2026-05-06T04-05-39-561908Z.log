      30	 * levels for the initial logging (StandardOutLogger) and the loggers & level
      31	 * for after-init logging, possibly keeping the StandardOutLogger enabled if
      32	 * it is part of the configured loggers. All configured loggers are treated as
      33	 * system services and managed by this trait, i.e. subscribed/unsubscribed in
      34	 * response to changes of LoggingBus.logLevel.
      35	 */
      36	trait LoggingBus extends ActorEventBus {
      37	
      38	  type Event >: Logging.LogEvent
      39	  type Classifier >: Class[_]
      40	
      41	  import Logging._
      42	
      43	  private val guard = new ReentrantGuard
      44	  private var loggers = Seq.empty[ActorRef]
      45	  @volatile private var _logLevel: LogLevel = _
      46	
      47	  /**
      48	   * Query currently set log level. See object Logging for more information.
      49	   */
      50	  def logLevel = _logLevel
      51	
      52	  /**
      53	   * Change log level: default loggers (i.e. from configuration file) are
      54	   * subscribed/unsubscribed as necessary so that they listen to all levels
      55	   * which are at least as severe as the given one. See object Logging for
      56	   * more information.
      57	   *
      58	   * NOTE: if the StandardOutLogger is configured also as normal logger, it
      59	   * will not participate in the automatic management of log level
      60	   * subscriptions!
      61	   */
      62	  def setLogLevel(level: LogLevel): Unit = guard.withGuard {
      63	    val logLvl = _logLevel // saves (2 * AllLogLevel.size - 1) volatile reads (because of the loops below)
      64	    for {
      65	      l <- AllLogLevels
      66	      // subscribe if previously ignored and now requested
      67	      if l > logLvl && l <= level
      68	      log <- loggers
      69	    } subscribe(log, classFor(l))
      70	    for {
      71	      l <- AllLogLevels
      72	      // unsubscribe if previously registered and now ignored
      73	      if l <= logLvl && l > level
      74	      log <- loggers
      75	    } unsubscribe(log, classFor(l))
