[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-slf4j_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_slf4j_2_13/Akka_slf4j_2_13Test.scala","edits":[{"oldText":"import akka.event.slf4j.Slf4jLogging\n","newText":"import org.slf4j.MDC\n"},{"oldText":"  def slf4jLoggingTraitCanBeUsedFromActorLifecycleAndReceive(): Unit = {\n    withActorSystem(\"Slf4jTraitLoggingTest\") { system =>\n      implicit val timeout: Timeout = Timeout(RequestTimeout)\n      val logger = system.actorOf(Props(new Slf4jTraitLoggingActor), \"trait-logger\")\n\n      val result = Await.result(logger ? Slf4jTraitLoggingActor.LogAndReverse(\"bravo\"), RequestTimeout)\n\n      assertThat(result).isEqualTo(Slf4jTraitLoggingActor.Reversed(\"ovarb\"))\n    }\n  }\n\n","newText":"  def systemLoggingAdapterPublishesMessagesToConfiguredSlf4jBackend(): Unit = {\n    withActorSystem(\"Slf4jSystemLoggingTest\") { system =>\n      val logger = akka.event.Logging(system, getClass)\n\n      logger.debug(\"debug message from system logging adapter\")\n      logger.info(\"info message from system logging adapter\")\n      logger.warning(\"warning message from system logging adapter\")\n      logger.error(new RuntimeException(\"adapter failure\"), \"error message from system logging adapter\")\n\n      assertThat(logger.isInfoEnabled).isTrue()\n    }\n  }\n\n"},{"oldText":"    logger.setMDC(Map(\"requestId\" -> \"request-42\", \"component\" -> \"direct-logger\"))\n    try {\n      logger.debug(\"debug message for {}\", \"direct logger\")\n      logger.info(\"info message for {}\", \"direct logger\")\n      logger.warning(\"warning message for {}\", \"direct logger\")\n      logger.error(cause, \"error message with cause\")\n    } finally {\n      logger.clearMDC()\n    }\n","newText":"    MDC.put(\"requestId\", \"request-42\")\n    MDC.put(\"component\", \"direct-logger\")\n    try {\n      logger.debug(\"debug message for {}\", \"direct logger\")\n      logger.info(\"info message for {}\", \"direct logger\")\n      logger.warn(\"warning message for {}\", \"direct logger\")\n      logger.error(\"error message with cause\", cause)\n    } finally {\n      MDC.clear()\n    }\n"},{"oldText":"\n  private object Slf4jTraitLoggingActor {\n    final case class LogAndReverse(payload: String)\n    final case class Reversed(payload: String)\n  }\n\n  private final class Slf4jTraitLoggingActor extends Actor with Slf4jLogging {\n    import Slf4jTraitLoggingActor._\n\n    override def preStart(): Unit = {\n      log.debug(\"starting actor backed by Slf4jLogging trait\")\n    }\n\n    override def receive: Receive = {\n      case LogAndReverse(payload) =>\n        log.info(\"reversing payload {}\", payload)\n        sender() ! Reversed(payload.reverse)\n    }\n  }\n","newText":""}]}
