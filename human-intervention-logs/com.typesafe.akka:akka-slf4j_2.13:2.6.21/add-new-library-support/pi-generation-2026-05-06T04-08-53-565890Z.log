ized =>\n        latch.countDown()\n        context.stop(self)\n    }\n  }\n\n  private final class LogEventCollector(latch: CountDownLatch) extends Actor {\n    override def receive: Receive = {\n      case _: Logging.LogEvent => latch.countDown()\n    }\n  }\n"}]}
