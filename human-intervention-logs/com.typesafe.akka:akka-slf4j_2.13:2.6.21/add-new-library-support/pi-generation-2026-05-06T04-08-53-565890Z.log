r: ActorRef, latch: CountDownLatch) extends Actor {\n    override def preStart(): Unit = {\n      logger ! Logging.InitializeLogger(context.system.eventStream)\n    }\n\n    override def receive: Receive = {\n      case Logging.LoggerInitialized =>\n        latch.countDown()\n        context.stop(self)\n    }\n  }\n\n  private final class LogEventCollector(latch: CountDownLatch) extends Actor {\n    override def receive: Receive = {\n      case _: Logging.LogEvent => latch.countDown()\n    }\n  }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2363, "output": 2885, "cacheRead": 13312, "cacheWrite": 0, "totalTokens": 18560, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778040475794, "responseId": "resp_097f99d3f5d87f960169fabe9c902481a1a8501d2b0ba03512"}}
