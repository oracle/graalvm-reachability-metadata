[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-slf4j_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_slf4j_2_13/Akka_slf4j_2_13Test.scala","edits":[{"oldText":"import akka.actor.{ActorRef, ActorSystem, Props}\n","newText":"import akka.actor.{Actor, ActorRef, ActorSystem, Props}\n"},{"oldText":"import org.slf4j.{Marker, MarkerFactory, MDC}\n","newText":"import org.slf4j.{Marker, MarkerFactory}\n"},{"oldText":"import scala.util.control.NonFatal\n","newText":""},{"oldText":"  @Test\n  def slf4jLoggerPopulatesAndClearsMappedDiagnosticContext(): Unit = {\n    withActorSystem(\"Mdc\", \"INFO\") { system: ActorSystem =>\n      val result: CompletableFuture[MdcProbeResult] = new CompletableFuture[MdcProbeResult]()\n      val markerProperties: java.util.Map[String, AnyRef] = new java.util.HashMap[String, AnyRef]()\n      markerProperties.put(\"operation\", \"settlement\")\n      markerProperties.put(\"batch\", Integer.valueOf(7))\n      val eventMdc: Map[String, AnyRef] = Map(\n        \"requestId\" -> \"request-456\",\n        \"attempt\" -> Integer.valueOf(3)\n      )\n      val probe: ActorRef = system.actorOf(Props(new MdcProbeActor), \"mdc-probe\")\n\n      probe.tell(CaptureMdc(eventMdc, LogMarker.create(\"mdc-marker\", markerProperties), result), ActorRef.noSender)\n\n      val snapshot: MdcProbeResult = result.get(10, TimeUnit.SECONDS)\n      assertThat(snapshot.during(\"akkaSource\")).isEqualTo(\"mdc.source\")\n      assertThat(snapshot.during(\"sourceActorSystem\")).isEqualTo(system.name)\n      assertThat(snapshot.during(\"requestId\")).isEqualTo(\"request-456\")\n      assertThat(snapshot.during(\"attempt\")).isEqualTo(\"3\")\n      assertThat(snapshot.during(\"operation\")).isEqualTo(\"settlement\")\n      assertThat(snapshot.during(\"batch\")).isEqualTo(\"7\")\n      assertThat(snapshot.during(\"sourceThread\")).isNotBlank()\n      assertThat(snapshot.during(\"akkaTimestamp\")).isNotBlank()\n      assertThat(snapshot.during(\"akkaAddress\")).isNotBlank()\n      assertThat(snapshot.during(\"akkaUid\")).isNotBlank()\n      assertThat(snapshot.after.isEmpty).isTrue()\n    }\n  }\n","newText":"  @Test\n  def slf4jLoggerAcknowledgesInitialization(): Unit = {\n    withActorSystem(\"Initialize\", \"INFO\") { system: ActorSystem =>\n      val result: CompletableFuture[AnyRef] = new CompletableFuture[AnyRef]()\n      val probe: ActorRef = system.actorOf(Props(new ReplyProbe(result)), \"logger-initialization-probe\")\n      val logger: ActorRef = system.actorOf(Props(new Slf4jLogger), \"standalone-slf4j-logger\")\n\n      logger.tell(Logging.InitializeLogger(system.eventStream), probe)\n\n      assertThat(result.get(10, TimeUnit.SECONDS)).isSameAs(Logging.LoggerInitialized)\n    }\n  }\n"}]}
