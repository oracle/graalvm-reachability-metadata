  object Akka_slf4j_2_13Test {
    private val nextSystemId: AtomicInteger = new AtomicInteger()
    private val mdcKeys: Seq[String] = Seq(
      "akkaSource",
      "sourceActorSystem",
      "sourceThread",
      "akkaTimestamp",
      "akkaAddress",
      "akkaUid",
      "requestId",
      "attempt",
      "operation",
      "batch"
    )
  
    private final case class CaptureMdc(
        eventMdc: Map[String, AnyRef],
        marker: LogMarker,
        result: CompletableFuture[MdcProbeResult]
    )
  
    private final case class MdcProbeResult(during: Map[String, String], after: Map[String, String])
  
    private final class MdcProbeActor extends Slf4jLogger {
      override def receive: Receive = super.receive.orElse {
        case CaptureMdc(eventMdc, marker, result) =>
          try {
            val event: Logging.Info = Logging.Info(
              "mdc.source",
              classOf[Akka_slf4j_2_13Test],
              "mdc message",
              eventMdc,
              marker
            )
            var during: Map[String, String] = Map.empty
  
            withMdc(event.logSource, event, () => during = currentMdcValues())
  
            result.complete(MdcProbeResult(during, currentMdcValues()))
            ()
          } catch {
            case NonFatal(exception) =>
              result.completeExceptionally(exception)
              ()
          }
      }
    }
  
    private def currentMdcValues(): Map[String, String] =
      mdcKeys.flatMap((key: String) => Option(MDC.get(key)).map((value: String) => key -> value)).toMap
  
    private def configureSimpleLogger(): Unit = {
      System.setProperty("org.slf4j.simpleLogger.defaultLogLevel", "info")
      System.setProperty("org.slf4j.simpleLogger.showDateTime", "false")
      System.setProperty("org.slf4j.simpleLogger.showThreadName", "false")
    }
  
    private def withActorSystem(testName: String, logLevel: String)(body: ActorSystem => Unit): Unit = {
      configureSimpleLogger()
  
      val config = ConfigFactory.parseString(
        s"""
           |akka {
           |  loggers = ["akka.event.slf4j.Slf4jLogger"]
           |  logging-filter = "akka.event.slf4j.Slf4jLoggingFilter"
           |  loglevel = "$logLevel"
           |  stdout-loglevel = "OFF"
           |  log-dead-letters = 0
           |  log-dead-letters-during-shutdown = false
           |}
           |""".stripMargin
      ).withFallback(ConfigFactory.load())
      val systemName: String = s"Slf4j${testName}${nextSystemId.incrementAndGet()}"
      val system: ActorSystem = ActorSystem(systemName, config)
  
      try {
        body(system)
      } finally {
        Await.result(system.terminate(), 10.seconds)
      }
