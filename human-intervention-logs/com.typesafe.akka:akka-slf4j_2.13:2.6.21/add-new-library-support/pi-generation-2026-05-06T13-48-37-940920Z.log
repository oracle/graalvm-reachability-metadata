entMdc: Map[String, AnyRef] = Map(\n        \"requestId\" -> \"request-456\",\n        \"attempt\" -> Integer.valueOf(3)\n      )\n      val probe: ActorRef = system.actorOf(Props(new MdcProbeActor), \"mdc-probe\")\n\n      probe.tell(CaptureMdc(eventMdc, LogMarker.create(\"mdc-marker\", markerProperties), result), ActorRef.noSender)\n\n      val snapshot: MdcProbeResult = result.get(10, TimeUnit.SECONDS)\n      assertThat(snapshot.during.get(\"akkaSource\")).contains(\"mdc.source\")\n      assertThat(snapshot.during.get(\"sourceActorSystem\")).contains(system.name)\n      assertThat(snapshot.during.get(\"requestId\")).contains(\"request-456\")\n      assertThat(snapshot.during.get(\"attempt\")).contains(\"3\")\n      assertThat(snapshot.during.get(\"operation\")).contains(\"settlement\")\n      assertThat(snapshot.during.get(\"batch\")).contains(\"7\")\n      assertThat(snapshot.during.get(\"sourceThread\")).isNotEmpty()\n      assertThat(snapshot.during.get(\"akkaTimestamp\")).isNotEmpty()\n      assertThat(snapshot.during.get(\"akkaAddress\")).isNotEmpty()\n      assertThat(snapshot.during.get(\"akkaUid\")).isNotEmpty()\n      assertThat(snapshot.after.values.flatten).isEmpty()\n    }\n  }\n\n  private final class LoggingComponent extends SLF4JLogging\n"}]}
