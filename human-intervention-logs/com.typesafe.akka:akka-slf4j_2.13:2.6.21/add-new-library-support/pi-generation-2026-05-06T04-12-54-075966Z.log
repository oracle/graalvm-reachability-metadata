gnosticActorLogging\nimport akka.actor.Props\nimport akka.event.Logging.MDC\nimport akka.event.slf4j.{Logger => Slf4jEventLogger, Slf4jLogMarker}\n"}, {"oldText": "  @Test\n  def loggingAdapterAcceptsSlf4jMarkersForMarkedEvents(): Unit = {\n    withActorSystem(\"Slf4jMarkerLoggingTest\") { system =>\n      val logger = akka.event.Logging.withMarker(system, getClass)\n      val slf4jMarker = MarkerFactory.getMarker(\"akka-slf4j-marked-event\")\n      val marker = Slf4jLogMarker(slf4jMarker)\n\n      logger.debug(marker, \"debug message with slf4j marker\")\n      logger.info(marker, \"info message with slf4j marker\")\n      logger.warning(marker, \"warning message with slf4j marker\")\n\n      assertThat(marker.name).isEqualTo(slf4jMarker.getName)\n      assertThat(marker.marker).isSameAs(slf4jMarker)\n    }\n  }\n\n  private def withActorSystem[T](name: String)(body: ActorSystem => T): T = {\n", "newText": "  @Test\n  def loggingAdapterAcceptsSlf4jMarkersForMarkedEvents(): Unit = {\n    withActorSystem(\"Slf4jMarkerLoggingTest\") { system =>\n      val logger = akka.event.Logging.withMarker(system, getClass)\n      val slf4jMarker = MarkerFactory.getMarker(\"akka-slf4j-marked-event\")\n      val marker = Slf4jLogMarker(slf4jMarker)\n\n      logger.debug(marker, \"debug message with slf4j marker\")\n      logger.info(marker, \"info message with slf4j marker\")\n      logger.warning(marker, \"warning message with slf4j marker\")\n\n      assertThat(marker.name).isEqualTo(slf4jMarker.getName)\n      assertThat(marker.marker).isSameAs(slf4jMarker)\n    }\n  }\n\n  @Test\n  def diagnosticActorLoggingPublishesMappedDiagnosticContext(): Unit = {\n    withActorSystem(\"Slf4jDiagnosticActorLoggingTest\") { system =>\n      implicit val timeout: Timeout = Timeout(RequestTimeout)\n      val logger = system.actorOf(Props(new DiagnosticLoggingActor), \"diagnostic-logger\")\n\n      val result = Await.result(\n        logger ? DiagnosticLoggingActor.LogWithContext(\"echo\", \"correlation-7\"),\n        RequestTimeout\n      )\n\n      assertThat(result).isEqualTo(DiagnosticLoggingActor.Ack(\"diagnostic\", \"echo\", \"correlation-7\"))\n    }\n  }\n\n  private def withActorSystem[T](name: String)(body: ActorSystem => T): T = {\n"}, {"oldText": "  private final class EventStreamLoggingActor extends Actor with ActorLogging {\n    import EventStreamLoggingActor._\n\n    override def receive: Receive = {\n      case LogAndAck(payload) =>\n        log.debug(\"debugging payload {}\", payload)\n        log.info(\"processed payload {}\", payload)\n        sender() ! Ack(\"event-stream\", payload)\n      case LogFailureAndAck(payload) =>\n        log.error(new IllegalStateException(\"simulated failure\"), s\"failed payload $payload\")\n        sender() ! Ack(\"failure\", payload)\n    }\n  }\n", "newText": "  private final class EventStreamLoggingActor extends Actor with ActorLogging {\n    import EventStreamLoggingActor._\n\n    override def receive: Receive = {\n      case LogAndAck(payload) =>\n        log.debug(\"debugging payload {}\", payload)\n        log.info(\"processed payload {}\", payload)\n        sender() ! Ack(\"event-stream\", payload)\n      case LogFailureAndAck(payload) =>\n        log.error(new IllegalStateException(\"simulated failure\"), s\"failed payload $payload\")\n        sender() ! Ack(\"failure\", payload)\n    }\n  }\n\n  private object DiagnosticLoggingActor {\n    final case class LogWithContext(payload: String, correlationId: String)\n    final case class Ack(source: String, payload: String, correlationId: String)\n  }\n\n  private final class DiagnosticLoggingActor extends Actor with DiagnosticActorLogging {\n    import DiagnosticLoggingActor._\n\n    override def mdc(currentMessage: Any): MDC = currentMessage match {\n      case LogWithContext(_, correlationId) =>\n        Map(\"correlationId\" -> correlationId, \"component\" -> \"diagnostic-actor\")\n      case _ =>\n        Map.empty\n    }\n\n    override def receive: Receive = {\n      case LogWithContext(payload, correlationId) =>\n        log.info(\"diagnostic payload {}\", payload)\n        sender() ! Ack(\"diagnostic\", payload, correlationId)\n    }\n  }\n"}]}, "partialJson": "{\"path\":\"tests/src/com.typesafe.akka/akka-slf4j_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_slf4j_2_13/Akka_slf4j_2_13Test.scala\",\"edits\":[{\"oldText\":\"import akka.actor.ActorLogging\\nimport akka.actor.ActorSystem\\nimport akka.actor.Props\\nimport akka.event.slf4j.{Logger => Slf4jEventLogger, Slf4jLogMarker}\\n\",\"newText\":\"import akka.actor.ActorLogging\\nimport akka.actor.ActorSystem\\nimport akka.actor.DiagnosticActorLogging\\nimport akka.actor.Props\\nimport akka.event.Logging.MDC\\nimport akka.event.slf4j.{Logger => Slf4jEventLogger, Slf4jLogMarker}\\n\"},{\"oldText\":\"  @Test\\n  def loggingAdapterAcceptsSlf4jMarkersForMarkedEvents(): Unit = {\\n    withActorSystem(\\\"Slf4jMarkerLoggingTest\\\") { system =>\\n      val logger = akka.event.Logging.withMarker(system, getClass)\\n      val slf4jMarker = MarkerFactory.getMarker(\\\"akka-slf4j-marked-event\\\")\\n      val marker = Slf4jLogMarker(slf4jMarker)\\n\\n      logger.debug(marker, \\\"debug message with slf4j marker\\\")\\n      logger.info(marker, \\\"info message with slf4j marker\\\")\\n      logger.warning(marker, \\\"warning message with slf4j marker\\\")\\n\\n      assertThat(marker.name).isEqualTo(slf4jMarker.getName)\\n      assertThat(marker.marker).isSameAs(slf4jMarker)\\n    }\\n  }\\n\\n  private def withActorSystem[T](name: String)(body: ActorSystem => T): T = {\\n\",\"newText\":\"  @Test\\n  def loggingAdapterAcceptsSlf4jMarkersForMarkedEvents(): Unit = {\\n    withActorSystem(\\\"Slf4jMarkerLoggingTest\\\") { system =>\\n      val logger = akka.event.Logging.withMarker(system, getClass)\\n      val slf4jMarker = MarkerFactory.getMarker(\\\"akka-slf4j-marked-event\\\")\\n      val marker = Slf4jLogMarker(slf4jMarker)\\n\\n      logger.debug(marker, \\\"debug message with slf4j marker\\\")\\n      logger.info(marker, \\\"info message with slf4j marker\\\")\\n      logger.warning(marker, \\\"warning message with slf4j marker\\\")\\n\\n      assertThat(marker.name).isEqualTo(slf4jMarker.getName)\\n      assertThat(marker.marker).isSameAs(slf4jMarker)\\n    }\\n  }\\n\\n  @Test\\n  def diagnosticActorLoggingPublishesMappedDiagnosticContext(): Unit = {\\n    withActorSystem(\\\"Slf4jDiagnosticActorLoggingTest\\\") { system =>\\n      implicit val timeout: Timeout = Timeout(RequestTimeout)\\n      val logger = system.actorOf(Props(new DiagnosticLoggingActor), \\\"diagnostic-logger\\\")\\n\\n      val result = Await.result(\\n        logger ? DiagnosticLoggingActor.LogWithContext(\\\"echo\\\", \\\"correlation-7\\\"),\\n        RequestTimeout\\n      )\\n\\n      assertThat(result).isEqualTo(DiagnosticLoggingActor.Ack(\\\"diagnostic\\\", \\\"echo\\\", \\\"correlation-7\\\"))\\n    }\\n  }\\n\\n  private def withActorSystem[T](name: String)(body: ActorSystem => T): T = {\\n\"},{\"oldText\":\"  private final class EventStreamLoggingActor extends Actor with ActorLogging {\\n    import EventStreamLoggingActor._\\n\\n    override def receive: Receive = {\\n      case LogAndAck(payload) =>\\n        log.debug(\\\"debugging payload {}\\\", payload)\\n        log.info(\\\"processed payload {}\\\", payload)\\n        sender() ! Ack(\\\"event-stream\\\", payload)\\n      case LogFailureAndAck(payload) =>\\n        log.error(new IllegalStateException(\\\"simulated failure\\\"), s\\\"failed payload $payload\\\")\\n        sender() ! Ack(\\\"failure\\\", payload)\\n    }\\n  }\\n\",\"newText\":\"  private final class EventStreamLoggingActor extends Actor with ActorLogging {\\n    import EventStreamLoggingActor._\\n\\n    override def receive: Receive = {\\n      case LogAndAck(payload) =>\\n        log.debug(\\\"debugging payload {}\\\", payload)\\n        log.info(\\\"processed payload {}\\\", payload)\\n        sender() ! Ack(\\\