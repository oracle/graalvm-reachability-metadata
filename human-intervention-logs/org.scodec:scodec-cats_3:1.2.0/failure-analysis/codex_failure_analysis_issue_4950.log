le extractLibraryTestParams -Pcoordinates=<group:artifact[:version]>\\n   823\\ttasks.register(\\\"extractLibraryTestParams\\\", DefaultTask) { task ->\\n   824\\t    task.setDescription(\\\"Extracts TEST_PATH, LATEST_VERSION and TEST_COORDINATES for given coordinates (group:artifact[:version]). Writes them into GITHUB_ENV.\\\")\\n   825\\t    task.setGroup(METADATA_GROUP)\\n   826\\t    task.doFirst {\\n   827\\t        if (!project.hasProperty(\\\"coordinates\\\")) {\\n   828\\t            throw new GradleException(\\\"Missing 'coordinates' property! Rerun Gradle with -Pcoordinates=<group:artifact[:version]>\\\")\\n   829\\t        }\\n   830\\t        def coordsStr = project.findProperty(\\\"coordinates\\\").toString()\\n   831\\t        def parts = coordsStr.split(\\\":\\\")\\n   832\\t        if (parts.length < 2) {\\n   833\\t            throw new GradleException(\\\"Invalid 'coordinates' value; expected group:artifact or group:artifact:version, got: ${coordsStr}\\\")\\n   834\\t        }\\n   835\\t        String lib = parts[0] + \\\":\\\" + parts[1]\\n   836\\t\\n   837\\t        String libPath = lib.replace(\\\":\\\", \\\"/\\\")\\n   838\\t        File indexFile = project.file(\\\"metadata/${libPath}/index.json\\\")\\n   839\\t\\n   840\\t        Map latestEntry = null\\n   841\\t        if (indexFile.exists()) {\\n   842\\t            def entries = new JsonSlurper().parse(indexFile) as List<Map>\\n   843\\t            latestEntry = entries.find { e -> Boolean.TRUE.equals(e[\\\"latest\\\"]) }\\n   844\\t            if (latestEntry == null && !entries.isEmpty()) {\\n   845\\t                latestEntry = entries.max { e -> VersionNumber.parse((e[\\\"metadata-version\\\"] ?: \\\"\\\").toString()) }\\n   846\\t            }\\n   847\\t        }\\n   848\\t\\n   849\\t        String latestVersion = null\\n   850\\t        String testVersionFolder = null\\n   851\\t\\n   852\\t        if (latestEntry != null) {\\n   853\\t            latestVersion = (latestEntry[\\\"metadata-version\\\"] ?: \\\"\\\").toString()\\n   854\\t            def tv = latestEntry[\\\"test-version\\\"]\\n   855\\t            testVersionFolder = (tv != null && tv.toString().trim()) ? tv.toString() : latestVersion\\n   856\\t        } else {\\n   857\\t            if (!indexFile.exists()) {\\n   858\\t                throw new GradleException(\\\"Missing index.json at ${indexFile}. Cannot determine latest metadata version.\\\")\\n   859\\t            }\\n   860\\t            def entries = new JsonSlurper().parse(indexFile) as List<Map>\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_22\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"nl -ba tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle | sed -n '880,980p'\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_22\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"nl -ba tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle | sed -n '880,980p'\\\"\",\"aggregated_output\":\"   880\\t\\n   881\\t        String testPath = \\\"${libPath}/${testVersionFolder}\\\"\\n   882\\t        // Use the latest metadata version for compatibility verification.\\n   883\\t        String testCoordinates = \\\"${lib}:${latestVersion}\\\"\\n   884\\t\\n   885\\t        writeGithubEnv(\\\"LATEST_VERSION\\\", latestVersion)\\n   886\\t        writeGithubEnv(\\\"TEST_PATH\\\", testPath)\\n   887\\t        writeGithubEnv(\\\"TEST_COORDINATES\\\", testCoordinates)\\n   888\\t    }\\n   889\\t}\\n   890\\t\\n   891\\t// gradle generateAffectedSpringTestMatrix -PbaseCommit=<base> -PnewCommit=<head> -PspringAotBranch=<branch> -PspringAotPath=/path/to/spring-aot-smoke-tests\\n   892\\t//\\n   893\\t// Generates a GitHub Actions matrix for 'spring-aot-smoke-tests' impacted by metadata changes:\\n   894\\t// 1. Identifies changed Group:Artifacts via git diff between commits.\\n   895\\t// 2. Runs an impact scan on the spring-aot-smoke-tests repo to find projects transitively depending on those GAs.\\n   896\\t// 3. Resolves the Java version for each project, favoring build.gradle overrides over ci.json defaults.\\n   897\\t// 4. Emits a JSON matrix to trigger parallel test execution in GitHub Actions.\\n   898\\ttasks.register(\\\"generateAffectedSpringTestMatrix\\\") { task ->\\n   899\\t    task.setDescription(\\\"Computes GA changes from git diff, scans Spring AOT for impacted tests, and emits a ready-to-use GitHub Actions matrix.\\\")\\n   900\\t    task.setGroup(METADATA_GROUP)\\n   901\\t\\n   902\\t    doLast {\\n   903\\t        if (!project.hasProperty(\\\"baseCommit\\\")) {\\n   904\\t            throw new GradleException(\\\"Missing 'baseCommit' property! Rerun Gradle with -PbaseCommit=<commit-hash>\\\")\\n   905\\t        }\\n   906\\t        if (!project.hasProperty(\\\"springAotBranch\\\")) {\\n   907\\t            throw new GradleException(\\\"Missing 'springAotBranch' property! Rerun Gradle with -PspringAotBranch=<branch>\\\")\\n   908\\t        }\\n   909\\t        if (!project.hasProperty(\\\"springAotPath\\\")) {\\n   910\\t            throw new GradleException(\\\"Missing 'springAotPath' property! Rerun Gradle with -PspringAotPath=<spring-aot-smoke-tests-path>\\\")\\n   911\\t        }\\n   912\\t\\n   913\\t        // Resolve Spring AOT dir\\n   914\\t        def springDir = project.file(project.findProperty(\\\"springAotPath\\\").toString())\\n   915\\t        if (!springDir.exists()) {\\n   916\\t            throw new GradleException(\\\"Spring AOT path does not exist: ${springDir.absolutePath}\\\")\\n   917\\t        }\\n   918\\t\\n   919\\t        // Resolve default Java and OS for this branch from ci.json\\n   920\\t        def springAotCfg = springAotMatrixConfig()\\n   921\\t        def javaBranchMapping = (springAotCfg[\\\"java-branch-mapping\\\