  .map(this::indexPathToCoordinate)\\n   205\\t                .filter(Objects::nonNull)\\n   206\\t                .distinct()\\n   207\\t                .collect(Collectors.toList());\\n   208\\t    }\\n   209\\t\\n   210\\t    /**\\n   211\\t     * Returns changed artifact coordinates paired with only newly added tested-versions from artifact-level index.json diffs.\\n   212\\t     */\\n   213\\t    @SuppressWarnings(\\\"unchecked\\\")\\n   214\\t    public List<Map<String, Object>> diffIndexTestedVersions(String baseCommit, String newCommit) {\\n   215\\t        return diffFiles(baseCommit, newCommit, \\\"ACMRT\\\").stream()\\n   216\\t                .map(path -> repoRoot().relativize(path).toString().replace('\\\\\\\\', '/'))\\n   217\\t                .map(relativePath -> diffIndexTestedVersionsEntry(baseCommit, newCommit, relativePath))\\n   218\\t                .filter(Objects::nonNull)\\n   219\\t                .collect(Collectors.toList());\\n   220\\t    }\\n   221\\t\\n   222\\t    private List<Path> diffFiles(String baseCommit, String newCommit, String diffFilter) {\\n   223\\t        ByteArrayOutputStream baos = new ByteArrayOutputStream();\\n   224\\t        getExecOperations().exec(spec -> {\\n   225\\t            spec.setStandardOutput(baos);\\n   226\\t            spec.commandLine(\\\"git\\\", \\\"diff\\\", \\\"--name-only\\\", \\\"--diff-filter=\\\" + diffFilter, baseCommit, newCommit);\\n   227\\t        });\\n   228\\t\\n   229\\t        return Arrays.stream(baos.toString(StandardCharsets.UTF_8).split(\\\"\\\\\\\\r?\\\\\\\\n\\\"))\\n   230\\t                .filter(line -> !line.isBlank())\\n   231\\t                .map(line -> repoRoot().resolve(line))\\n   232\\t                .collect(Collectors.toList());\\n   233\\t    }\\n   234\\t\\n   235\\t    /**\\n   236\\t     * Maps an artifact-level metadata index.json file path to its corresponding coordinate string.\\n   237\\t     *\\n   238\\t     * @return the coordinate string (G:A), or null if not a match\\n   239\\t     */\\n   240\\t    private String indexPathToCoordinate(String path) {\\n   241\\t        Pattern pattern = Pattern.compile(\\\"(?:metadata|tests/src)/([^/]+)/([^/]+)(?:/([^/]+))?/index\\\\\\\\.json\\\");\\n   242\\t        Matcher matcher = pattern.matcher(path);\\n   243\\t\\n   244\\t        if (matcher.matches()) {\\n   245\\t            String group = matcher.group(1);\\n   246\\t            String artifact = matcher.group(2);\\n   247\\t            String version = matcher.group(3);\\n   248\\t\\n   249\\t            return (version != null)\\n   250\\t                    ? String.format(\\\"%s:%s:%s\\\", group, artifact, version)\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n56:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_28\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"nl -ba tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle | sed -n '430,590p'\\\"\",\"aggregated_output\":\"   430\\t    List<String> nativeImageModes = nativeImageModesForMatrix()\\n   431\\t    NativeImageConfigUtils.expandMatrixEntries(\\n   432\\t            entries,\\n   433\\t            defaults[\\\"version\\\"],\\n   434\\t            defaults[\\\"os\\\"],\\n   435\\t            nativeImageModes,\\n   436\\t            NativeImageConfigUtils.javaVersionsByMode(loadCi(), defaults[\\\"version\\\"], nativeImageModes)\\n   437\\t    )\\n   438\\t}\\n   439\\t\\n   440\\tMap<String, Object> springAotMatrixConfig() {\\n   441\\t    def ci = loadCi()\\n   442\\t    def sec = ci[\\\"generateAffectedSpringTestMatrix\\\"]\\n   443\\t    if (sec == null) throw new GradleException(\\\"Missing 'generateAffectedSpringTestMatrix' in ci.json\\\")\\n   444\\t    [\\n   445\\t            \\\"java-branch-mapping\\\": (sec[\\\"java-branch-mapping\\\"] as Map<String, String>),\\n   446\\t            \\\"os\\\": sec[\\\"os\\\"]\\n   447\\t    ]\\n   448\\t}\\n   449\\t\\n   450\\tList<Map<String, Object>> expandNewLibraryVersionCompatibilityMatrix(List<Map<String, Object>> libraries) {\\n   451\\t    int versionsPerJob = versionsPerJobFor(\\\"generateNewLibraryVersionCompatibilityMatrix\\\")\\n   452\\t    int maxLibraries = maxLibrariesFor(\\\"generateNewLibraryVersionCompatibilityMatrix\\\")\\n   453\\t    expandMatrixEntries(libraries.take(maxLibraries).collect { Map<String, Object> library ->\\n   454\\t        [\\n   455\\t                \\\"name\\\"    : library[\\\"name\\\"],\\n   456\\t                \\\"versions\\\": (library[\\\"versions\\\"] as List<?>)\\n   457\\t                        .collect { it.toString() }\\n   458\\t                        .take(versionsPerJob)\\n   459\\t        ]\\n   460\\t    }, \\\"generateNewLibraryVersionCompatibilityMatrix\\\")\\n   461\\t}\\n   462\\t\\n   463\\tList<Map<String, Object>> expandChangedTestedVersionsMatrix(List<Map<String, Object>> entries) {\\n   464\\t    List<Map<String, Object>> include = []\\n   465\\t    entries.each { Map<String, Object> entry ->\\n   466\\t        List<Map<String, Object>> matrixEntries = entry.containsKey(\\\"entries\\\")\\n   467\\t                ? (entry[\\\"entries\\\"] as List<Map<String, Object>>)\\n   468\\t                : [entry]\\n   469\\t        include.addAll(expandMatrixEntries(matrixEntries.collect { Map<String, Object> matrixEntry ->\\n   470\\t            [\\n   471\\t                    \\\"coordinates\\\": matrixEntry[\\\"coordinates\\\"],\\n   472\\t                    \\\"versions\\\"   : matrixEntry[\\\"versions\\\"]\\n   473\\t            ]\\n   474\\t        }, \\\"generateChangedTestedVersionsMatrix\\\"))\\n   475\\t    }\\n   476\\t    include\\n   477\\t}\\n   478\\t\\n   479\\tList<Map<String, Object>> flattenChangedTestedVersionEntries(List<Map<String, Object>> entries) {\\n   480\\t    List<Map<String, Object>> flattened = []\\n   481\\t    entries.each { Map<String, Object> entry ->\\n   482\\t        if (entry.containsKey(\\\"entries\\\")) {\\n   483\\t 