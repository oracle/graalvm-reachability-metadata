atrix' in ci.json\\\")\\n   444\\t    [\\n   445\\t            \\\"java-branch-mapping\\\": (sec[\\\"java-branch-mapping\\\"] as Map<String, String>),\\n   446\\t            \\\"os\\\": sec[\\\"os\\\"]\\n   447\\t    ]\\n   448\\t}\\n   449\\t\\n   450\\tList<Map<String, Object>> expandNewLibraryVersionCompatibilityMatrix(List<Map<String, Object>> libraries) {\\n   451\\t    int versionsPerJob = versionsPerJobFor(\\\"generateNewLibraryVersionCompatibilityMatrix\\\")\\n   452\\t    int maxLibraries = maxLibrariesFor(\\\"generateNewLibraryVersionCompatibilityMatrix\\\")\\n   453\\t    expandMatrixEntries(libraries.take(maxLibraries).collect { Map<String, Object> library ->\\n   454\\t        [\\n   455\\t                \\\"name\\\"    : library[\\\"name\\\"],\\n   456\\t                \\\"versions\\\": (library[\\\"versions\\\"] as List<?>)\\n   457\\t                        .collect { it.toString() }\\n   458\\t                        .take(versionsPerJob)\\n   459\\t        ]\\n   460\\t    }, \\\"generateNewLibraryVersionCompatibilityMatrix\\\")\\n   461\\t}\\n   462\\t\\n   463\\tList<Map<String, Object>> expandChangedTestedVersionsMatrix(List<Map<String, Object>> entries) {\\n   464\\t    List<Map<String, Object>> include = []\\n   465\\t    entries.each { Map<String, Object> entry ->\\n   466\\t        List<Map<String, Object>> matrixEntries = entry.containsKey(\\\"entries\\\")\\n   467\\t                ? (entry[\\\"entries\\\"] as List<Map<String, Object>>)\\n   468\\t                : [entry]\\n   469\\t        include.addAll(expandMatrixEntries(matrixEntries.collect { Map<String, Object> matrixEntry ->\\n   470\\t            [\\n   471\\t                    \\\"coordinates\\\": matrixEntry[\\\"coordinates\\\"],\\n   472\\t                    \\\"versions\\\"   : matrixEntry[\\\"versions\\\"]\\n   473\\t            ]\\n   474\\t        }, \\\"generateChangedTestedVersionsMatrix\\\"))\\n   475\\t    }\\n   476\\t    include\\n   477\\t}\\n   478\\t\\n   479\\tList<Map<String, Object>> flattenChangedTestedVersionEntries(List<Map<String, Object>> entries) {\\n   480\\t    List<Map<String, Object>> flattened = []\\n   481\\t    entries.each { Map<String, Object> entry ->\\n   482\\t        if (entry.containsKey(\\\"entries\\\")) {\\n   483\\t            flattened.addAll(entry[\\\"entries\\\"] as List<Map<String, Object>>)\\n   484\\t        } else {\\n   485\\t            flattened.add(entry)\\n   486\\t        }\\n   487\\t    }\\n   488\\t    flattened\\n   489\\t}\\n   490\\t\\n   491\\tList<Map<String, Object>> changedMetadataTestEntries(\\n   492\\t        String base,\\n   493\\t        String head,\\n   494\\t        int versionsPerJob,\\n   495\\t        List<String> changedCoordinates\\n   496\\t) {\\n   497\\t    List<Map<String, Object>> addedVersionEntries = flattenChangedTestedVersionEntries(tck.diffIndexTestedVersions(base, head))\\n   498\\t    List<Map<String, Object>> entries = []\\n   499\\t    entries.addAll(addedVersionEntries.collect { Map<String, Object> entry ->\\n   500\\t        [\\n   501\\t                \\\"coordinates\\\": entry[\\\"coordinates\\\"],\\n   502\\t                \\\"versions\\\"   : entry[\\\"versions\\\"],\\n   503\\t                \\\"batch\\\"      : \\\"added\\\"\\n   504\\t        ]\\n   505\\t    })\\n   506\\t    entries.addAll(changedCoordinates.collectMany { coordinate -> tck.testedVersionBatches(coordinate, versionsPerJob) })\\n   507\\t    entries\\n   508\\t}\\n   509\\t\\n   510\\t// gradle generateMatrixMatchingCoordinates -Pcoordinates=<maven-coordinates>\\n   511\\tProvider<Task> generateMatrixMatchingCoordinates = tasks.register(\\\"generateMatrixMatchingCoordinates\\\", DefaultTask) { task ->\\n   512\\t    task.setDescription(\\\"Returns matrix definition populated with all matching coordinates\\\")\\n   513\\t    task.setGroup(METADATA_GROUP)\\n   514\\t    task.doFirst {\\n   515\\t        def matrix = [\\n   516\\t                \\\"coordinates\\\": matchingCoordinates\\n   517\\t        ]\\n   518\\t        matrix.putAll(matrixDefaultsFor(\\\"generateMatrixMatchingCoordinates\\\"))\\n   519\\t        writeGithubOutput(\\\"matrix\\\", JsonOutput.toJson(matrix))\\n   520\\t    }\\n   521\\t}\\n   522\\t\\n   523\\t// gradle generateMatrixBatchedCoordinates [-Pbatches=<n>]\\n   524\\tProvider<Task> generateMatrixBatchedCoordinates = tasks.register(\\\"generateMatrixBatchedCoordinates\\\", DefaultTask) { task ->\\n   525\\t    task.setDescription(\\\"Returns matrix definition populated with fractional batch coordinates (k/n)\\\")\\n   526\\t    task.setGroup(METADATA_GROUP)\\n   527\\t    task.doFirst {\\n   528\\t        int batches = project.hasProperty(\\\"batches\\\") ? Integer.parseInt(project.findProperty(\\\"batches\\\").toString()) : 16\\n   529\\t        if (batches <= 0) {\\n   530\\t            throw new GradleException(\\\"Invalid 'batches' value: ${batches}\\\")\\n   531\\t        }\\n   532\\t        def matrix = [\\n   533\\t                \\\"include\\\": expandMatrixEntries(\\n   534\\t                        (1..batches).collect { i -> [\\\"coordinates\\\": \\\"${i}/${batches}\\\"] },\\n   535\\t                        \\\"generateMatrixBatchedCoordinates\\\"\\n   536\\t                )\\n   537\\t        ]\\n   538\\t        writeGithubOutput(\\\"matrix\\\", JsonOutput.toJson(matrix))\\n   539\\t    }\\n   540\\t}\\n   541\\t\\n   542\\t// gradle generateChangedCoordinatesMatrix -PbaseCommit=<base-commit> -PnewCommit=<new-commit>\\n   543\\tProvider<Task> generateChangedCoordinatesMatrix = tasks.register(\\\"generateChangedCoordinatesMatrix\\\", DefaultTask) { task ->\\n   544\\t    task.setDescription(\\\"Returns matrix definition populated with coordinates of changed libraries\\\")\\n   545\\t    task.setGroup(METADATA_GROUP)\\n   546\\t    task.doFirst {\\n   547\\t        if (!project.hasProperty(\\\"baseCommit\\\")) {\\n   548\\t            throw new GradleException(\\\"Missing 'baseCommit' property! Rerun Gradle with '-PbaseCommit=<commit-hash>'\\\")\\n   549\\t        }\\n   550\\t\\n   551\\t        boolean noneFound = diffCoordinates.isEmpty()\\n   552\\t        def matrix = [\\n   553\\t                \\\"include\\\": noneFound\\n   554\\t                        ? []\\n   555\\t                        : expandMatrixEntries(\\n   556\\t                                diffCoordinates.collect { coordinate -> [\\\"coordinates\\\": coordinate] },\\n   557\\t                                \\\"generateChangedCoordinatesMatrix\\\"\\n   558\\t                        )\\n   559\\t        ]\\n   560\\t        if (noneFound) {\\n   561\\t            println \\\"No changed coordinates were found!\\\"\\n   562\\t        }\\n   563\\t\\n   564\\t\\n   565\\t        writeGithubOutput(\\\"matrix\\\", JsonOutput.toJson(matrix))\\n   566\\t        writeGithubOutput(\\\"none-found\\\", noneFound.toString())\\n   567\\t    }\\n   568\\t}\\n   569\\t\\n   570\\t// gradle generateChangedTestedVersionsMatrix -PbaseCommit=<base-commit> -PnewCommit=<new-commit>\\n   571\\tProvider<Task> generateChangedTestedVersionsMatrix = tasks.register(\\\"generateChangedTestedVersionsMatrix\\\", DefaultTask) { task ->\\n   572\\t    task.setDescription(\\\"Returns matrix definition populated with artifact coordinates and newly added tested versions from changed metadata index files\\\")\\n   573\\t    task.setGroup(METADATA_GROUP)\\n   574\\t    task.doFirst {\\n   575\\t        if (!project.hasProperty(\\\"baseCommit\\\")) {\\n   576\\t            throw new GradleException(\\\"Missing 'baseCommit' property! Rerun Gradle with '-PbaseCommit=<commit-hash>'\\\")\\n   577\\t        }\\n   578\\t\\n   579\\t        String base = project.property(\\\"baseCommit\\\")\\n   580\\t        String head = project.findProperty(\\\"newCommit\\\") ?: \\\"HEAD\\\"\\n   581\\t        List<Map<String, Object>> changedIndexEntries = tck.diffIndexTestedVersions(base, head)\\n   582\\t\\n   583\\t        boolean noneFound = changedIndexEntries.isEmpty()\\n   584\\t        List<Map<String, Object>> include = noneFound ? [] : expandChangedTestedVersionsMatrix(changedIndexEntries)\\n   585\\t        def matrix = [include: include]\\n   586\\t        if (noneFound) {\\n   587\\t            println \\\"No changed metadata index tested-version additions were found!\\\"\\n   588\\t        }\\n   589\\t\\n   590\\t        writeGithubOutput(\\\"matrix\\\", JsonOutput.toJson(matrix))\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nhuman-intervention-logs/org.scodec:scodec-cats_3:1.2.0/local-ci-fixup/changed-metadata-matrix-2026-05-07T12-47-58-687209Z.log:60:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_30\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"nl -ba tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java | sed -n '250,380p'\\\"\",\"aggregated_output\":\"   250\\t                    ? String.format(\\\"%s:%s:%s\\\", group, artifact, version)\\n   251\\t                    : String.format(\\\"%s:%s\\\", group, artifact);\\n   252\\t        }\\n   253\\t        return null;\\n   254\\t    }\\n   255\\t\\n   256\\t    @SuppressWarnings(\\\"unchecked\\\")\\n   257\\t    private Map<String, Object> diffIndexTestedVersionsEntry(String baseCommit, String newCommit, String relativePath) {\\n   258\\t        String coordinates = indexPathToCoordinate(relativePath);\\n   259\\t        if (coordinates == null) {\\n   260\\t            return null;\\n   261\\t        }\\n   262\\t\\n   263\\t        List<Map<String, ?>> baseEntries = readJsonListFromCommit(baseCommit, relativePath);\\n   264\\t        List<Map<String, ?>> headEntries = readJsonListFromCommit(newCommit, relativePath);\\n   265\\t\\n   266\\t        Map<String, Set<String>> baseByMetadataVersion = testedVersionsByMetadataVersion(baseEntries);\\n   267\\t        Map<String, Set<String>> headByMetadataVersion = testedVersionsByMetadataVersion(headEntries);