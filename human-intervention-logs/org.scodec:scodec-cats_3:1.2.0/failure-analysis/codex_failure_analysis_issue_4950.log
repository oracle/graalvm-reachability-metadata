 loadMatchingIndices(String groupId, String artifactId) {\\n   545\\t        Map<Path, List<Map<String, ?>>> indices = new HashMap<>();\\n   546\\t        for (String directory : getMatchingMetadataDirs(groupId, artifactId)) {\\n   547\\t            Path fullDir = metadataRoot().resolve(directory);\\n   548\\t            Path indexFile = fullDir.resolve(\\\"index.json\\\");\\n   549\\t\\n   550\\t            @SuppressWarnings(\\\"unchecked\\\")\\n   551\\t            List<Map<String, ?>> metadataIndex = (List<Map<String, ?>>) extractJsonFile(indexFile);\\n   552\\t            if (metadataIndex != null) {\\n   553\\t                indices.put(fullDir, metadataIndex);\\n   554\\t            }\\n   555\\t        }\\n   556\\t        return indices;\\n   557\\t    }\\n   558\\t\\n   559\\t    /**\\n   560\\t     * Returns a list of metadata files in a given directory.\\n   561\\t     *\\n   562\\t     * @return list of json files contained in it\\n   563\\t     */\\n   564\\t    public List<String> getMetadataFileList(Path directory) throws IOException {\\n   565\\t        try (Stream<Path> paths = Files.walk(directory)) {\\n   566\\t            return paths\\n   567\\t                    .filter(Files::isRegularFile)\\n   568\\t                    .map(p -> p.getFileName().toString())\\n   569\\t                    .filter(name -> name.endsWith(\\\".json\\\"))\\n   570\\t                    .collect(Collectors.toList());\\n   571\\t        }\\n   572\\t    }\\n   573\\t}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_20\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"nl -ba tests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle | sed -n '250,320p'\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_20\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"nl -ba tests/tck-build