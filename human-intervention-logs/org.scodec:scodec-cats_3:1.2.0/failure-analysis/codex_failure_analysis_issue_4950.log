intln \\\"No changed metadata index tested-version additions were found!\\\"\\n   588\\t        }\\n   589\\t\\n   590\\t        writeGithubOutput(\\\"matrix\\\", JsonOutput.toJson(matrix))\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n58:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_29\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n \\\\\\\"getMetadataDir\\\\\\\\(|metadataDirTo|testDirTo|pathToCoordinate|coordinate.*path\\\\\\\" tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java -S\\\"\",\"aggregated_output\":\"185:            Path metadataDir = getMetadataDir(c);\\n395:    public Path getMetadataDir(String coordinates) {\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n60:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_30\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"nl -ba tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java | sed -n '250,380p'\\\"\",\"aggregated_output\":\"   250\\t                    ? String.format(\\\"%s:%s:%s\\\", group, artifact, version)\\n   251\\t                    : String.format(\\\"%s:%s\\\", group, artifact);\\n   252\\t        }\\n   253\\t        return null;\\n   254\\t    }\\n   255\\t\\n   256\\t    @SuppressWarnings(\\\"unchecked\\\")\\n   257\\t    private Map<String, Object> diffIndexTestedVersionsEntry(String baseCommit, String newCommit, String relativePath) {\\n   258\\t        String coordinates = indexPathToCoordinate(relativePath);\\n   259\\t        if (coordinates == null) {\\n   260\\t            return null;\\n   261\\t        }\\n   262\\t\\n   263\\t        List<Map<String, ?>> baseEntries = readJsonListFromCommit(baseCommit, relativePath);\\n   264\\t        List<Map<String, ?>> headEntries = readJsonListFromCommit(newCommit, relativePath);\\n   265\\t\\n   266\\t        Map<String, Set<String>> baseByMetadataVersion = testedVersionsByMetadataVersion(baseEntries);\\n   267\\t        Map<String, Set<String>> headByMetadataVersion = testedVersionsByMetadataVersion(headEntries);\\n   268\\t\\n   269\\t        List<Map<String, Object>> changedMetadataVersions = new ArrayList<>();\\n   270\\t        for (Map.Entry<String, Set<String>> headEntry : headByMetadataVersion.entrySet()) {\\n   271\\t            String metadataVersion = headEntry.getKey();\\n   272\\t            Set<String> baseVersions = baseByMetadataVersion.getOrDefault(metadataVersion, Collections.emptySet());\\n   273\\t            List<String> addedVersions = headEntry.getValue().stream()\\n   274\\t                    .filter(testedVersion -> !baseVersions.contains(testedVersion))\\n   275\\t                    .toList();\\n   276\\t            if (!addedVersions.isEmpty()) {\\n   277\\t                changedMetadataVersions.add(Map.of(\\n   278\\t                        \\\"coordinates\\\", coordinates + \\\":\\\" + metadataVersion,\\n   279\\t                        \\\"versions\\\", addedVersions\\n   280\\t                ));\\n   281\\t            }\\n   282\\t        }\\n   283\\t\\n   284\\t        if (changedMetadataVersions.isEmpty()) {\\n   285\\t            return null;\\n   286\\t        }\\n   287\\t\\n   288\\t        if (changedMetadataVersions.size() == 1) {\\n   289\\t            return changedMetadataVersions.get(0);\\n   290\\t        }\\n   291\\t\\n   292\\t        return Map.of(\\n   293\\t                \\\"entries\\\", changedMetadataVersions\\n   294\\t        );\\n   295\\t    }\\n   296\\t\\n   297\\t    @SuppressWarnings(\\\"unchecked\\\")\\n   298\\t    private List<Map<String, ?>> readJsonListFromCommit(String commit, String relativePath) {\\n   299\\t        ByteArrayOutputStream stdout = new ByteArrayOutputStream();\\n   300\\t        ByteArrayOutputStream stderr = new ByteArrayOutputStream();\\n   301\\t        var result = getExecOperations().exec(spec -> {\\n   302\\t            spec.setIgnoreExitValue(true);\\n   303\\t            spec.setStandardOutput(stdout);\\n   304\\t            spec.setErrorOutput(stderr);\\n   305\\t            spec.commandLine(\\\"git\\\", \\\"show\\\", commit + \\\":\\\" + relativePath);\\n   306\\t        });\\n   307\\t        if (result.getExitValue() != 0) {\\n   308\\t            return Collections.emptyList();\\n   309\\t        }\\n   310\\t        String json = stdout.toString(StandardCharsets.UTF_8);\\n   311\\t        if (json == null || json.isBlank()) {\\n   312\\t            return Collections.emptyList();\\n   313\\t        }\\n   314\\t        Object parsed = parseTextJson(json);\\n   315\\t        if (parsed instanceof List<?> list) {\\n   316\\t            return list.stream()\\n   317\\t                    .filter(Map.class::isInstance)\\n   318\\t                    .map(entry -> (Map<String, ?>) entry)\\n   319\\t                    .collect(Collectors.toList());\\n   320\\t        }\\n   321\\t        return Collections.emptyList();\\n   322\\t    }\\n   323\\t\\n   324\\t    @SuppressWarnings(\\\"unchecked\\\")\\n   325\\t    private Map<String, Set<String>> testedVersionsByMetadataVersion(List<Map<String, ?>> entries) {\\n   326\\t        Map<String, Set<String>> testedVersions = new LinkedHashMap<>();\\n   327\\t        for (Map<String, ?> entry : entries) {\\n   328\\t            if (entry == null) {\\n   329\\t                continue;\\n   330\\t            }\\n   331\\t            Object metadataVersion = entry.get(\\\"metadata-version\\\");\\n   332\\t            Object testedVersionsRaw = entry.get(\\\"tested-versions\\\");\\n   333\\t            if (!(metadataVersion instanceof String metadataVersionString) || !(testedVersionsRaw instanceof List<?> versions)) {\\n   334\\t                continue;\\n   335\\t            }\\n   336\\t            testedVersions.put(\\n   337\\t                    metadataVersionString,\\n   338\\t                    versions.stream()\\n   339\\t                            .map(Object::toString)\\n   340\\t     