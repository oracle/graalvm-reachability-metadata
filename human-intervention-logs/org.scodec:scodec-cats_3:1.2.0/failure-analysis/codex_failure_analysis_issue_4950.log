dle with -PbaseCommit=<commit-hash>\\\")\\n   905\\t        }\\n   906\\t        if (!project.hasProperty(\\\"springAotBranch\\\")) {\\n   907\\t            throw new GradleException(\\\"Missing 'springAotBranch' property! Rerun Gradle with -PspringAotBranch=<branch>\\\")\\n   908\\t        }\\n   909\\t        if (!project.hasProperty(\\\"springAotPath\\\")) {\\n   910\\t            throw new GradleException(\\\"Missing 'springAotPath' property! Rerun Gradle with -PspringAotPath=<spring-aot-smoke-tests-path>\\\")\\n   911\\t        }\\n   912\\t\\n   913\\t        // Resolve Spring AOT dir\\n   914\\t        def springDir = project.file(project.findProperty(\\\"springAotPath\\\").toString())\\n   915\\t        if (!springDir.exists()) {\\n   916\\t            throw new GradleException(\\\"Spring AOT path does not exist: ${springDir.absolutePath}\\\")\\n   917\\t        }\\n   918\\t\\n   919\\t        // Resolve default Java and OS for this branch from ci.json\\n   920\\t        def springAotCfg = springAotMatrixConfig()\\n   921\\t        def javaBranchMapping = (springAotCfg[\\\"java-branch-mapping\\\"] as Map<String, String>)\\n   922\\t        def branch = project.findProperty(\\\"springAotBranch\\\").toString()\\n   923\\t        String defaultJavaStr = javaBranchMapping.get(branch)\\n   924\\t        if (defaultJavaStr == null || defaultJavaStr.trim().isEmpty()) {\\n   925\\t            throw new GradleException(\\\"Unknown springAotBranch '${branch}' in ci.json mapping\\\")\\n   926\\t        }\\n   927\\t        Integer defaultJava = Integer.parseInt(defaultJavaStr)\\n   928\\t\\n   929\\t        // Compute versionless GA targets from diffCoordinates\\n   930\\t        boolean noneFound = diffCoordinates.isEmpty()\\n   931\\t        List<String> versionless = []\\n   932\\t        if (!noneFound) {\\n   933\\t            versionless = diffCoordinates.collect { c ->\\n   934\\t                def parts = c.split(\\\":\\\", 3)\\n   935\\t                \\\"${parts[0]}:${parts[1]}\\\"\\n   936\\t            }.unique()\\n   937\\t            noneFound = versionless.isEmpty()\\n   938\\t        }\\n   939\\t\\n   940\\t        if (noneFound) {\\n   941\\t            writeGithubOutput(\\\"impacted_tests\\\", \\\"\\\")\\n   942\\t            writeGithubOutput(\\\"matrix\\\", JsonOutput.toJson([include: []]))\\n   943\\t            writeGithubOutput(\\\"none-found\\\", \\\"true\\\")\\n   944\\t            return\\n   945\\t        }\\n   946\\t\\n   947\\t        // Init script within this repo (corrected path)\\n   948\\t        File initScript = project.file(\\\"tests/tck-build-logic/scripts/spring-aot-impact-scan.gradle\\\")\\n   949\\t        if (!initScript.exists()) {\\n   950\\t            throw new GradleException(\\\"Missing init script: ${initScript.absolutePath}\\\")\\n   951\\t        }\\n   952\\t\\n   953\\t        // Execute impact scan in Spring AOT repo\\n   954\\t        ByteArrayOutputStream stdout = new ByteArrayOutputStream()\\n   955\\t        def execOps = project.services.get(ExecOperations)\\n   956\\t        execOps.exec {\\n   957\\t            workingDir = springDir\\n   958\\t            executable = \\\"${springDir.absolutePath}/gradlew\\\"\\n   959\\t            args = [\\n   960\\t                    \\\"-I\\\", initScript.absolutePath,\\n   961\\t                    \\\"-PimpactCoordinatesList=${versionless.join(',')}\\\",\\n   962\\t                    \\\"__internalImpactScan\\\",\\n   963\\t                    \\\"-q\\\",\\n   964\\t                    \\\"--no-daemon\\\",\\n   965\\t                    \\\"--console=plain\\\",\\n   966\\t                    \\\"--warning-mode=none\\\"\\n   967\\t            ]\\n   968\\t            standardOutput = stdout\\n   969\\t            errorOutput = stdout\\n   970\\t            ignoreExitValue = true\\n   971\\t        }\\n   972\\t\\n   973\\t        // Parse impact results\\n   974\\t        List<String> results = stdout.toString().split(\\\"\