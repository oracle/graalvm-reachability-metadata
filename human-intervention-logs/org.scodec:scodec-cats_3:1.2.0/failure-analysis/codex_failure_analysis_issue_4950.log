ow: avoid resolving `getTestDir` unless test files actually changed, and treat unrelated metadata-only entries with no tests as irrelevant to the diff result instead of a hard configuration failure. I’m pairing that with a regression test that sets up a temp git repo containing exactly that kind of unrelated metadata-only library.\"}}\n90:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_48\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'git diff -- tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java tests/tck-build-logic/src/test/java/org/graalvm/internal/tck/harness/TckExtensionTests.java'\",\"aggregated_output\":\"diff --git i/tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java w/tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java\\nindex e865a0308d..66ffe81473 100644\\n--- i/tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java\\n+++ w/tests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/TckExtension.java\\n@@ -186,8 +186,15 @@ public abstract class TckExtension {\\n             if (changedMetadataFiles.stream().anyMatch(f -> f.startsWith(metadataDir))) {\\n                 return true;\\n             }\\n-            Path testDir = getTestDir(c);\\n-            return changedTestFiles.stream().anyMatch(f -> f.startsWith(testDir));\\n+            if (changedTestFiles.isEmpty()) {\\n+                return false;\\n+            }\\n+            try {\\n+                Path testDir = getTestDir(c);\\n+                return changedTestFiles.stream().anyMatch(f -> f.startsWith(testDir));\\n+            } catch (RuntimeException ignored) {\\n+                return false;\\n+            }\\n         }).distinct().collect(Collectors.toCollection(ArrayList::new));\\n \\n         return changedCoordinates;\\ndiff --git i/tests/tck-build-logic/src/test/java/org/graalvm/internal/tck/harne