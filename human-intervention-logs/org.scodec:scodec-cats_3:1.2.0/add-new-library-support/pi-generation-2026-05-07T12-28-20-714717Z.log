        def decode(bits: BitVector): Attempt[DecodeResult[A]] = Attempt.failure(e)
      }
  
      def handleErrorWith[A](fa: Decoder[A])(f: Err => Decoder[A]): Decoder[A] = new Decoder[A] {
        def decode(bits: BitVector): Attempt[DecodeResult[A]] =
