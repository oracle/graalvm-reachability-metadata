eam().anyMatch(f -> f.startsWith(metadataDir))) {\n   187\t                return true;\n   188\t            }\n   189\t            Path testDir = getTestDir(c);\n   190\t            return changedTestFiles.stream().anyMatch(f -> f.startsWith(testDir));\n   191\t        }).distinct().collect(Collectors.toCollection(ArrayList::new));\n   192\t\n   193\t        return changedCoordinates;\n   194\t    }\n   195\t\n   196\t    /**\n   197\t     * Returns a list of changed artifact coordinates based on artifact-level index.json files modified between baseCommit and newCommit.\n   198\t     *\n   199\t     * @return List of coordinates (e.g., \"org.flywaydb:flyway-core\" or \"org.example:library\")\n   200\t     */\n   201\t    public List<String> diffIndexCoordinates(String baseCommit, String newCommit) {\n   202\t        return diffFiles(baseCommit, newCommit, \"ACMRT\").stream()\n   203\t                .map(path -> repoRoot().relativize(path).toString().replace('\\\\', '/'))\n   204\t                .map(this::indexPathToCoordinate)\n   205\t                .filter(Objects::nonNull)\n   206\t                .distinct()\n   207\t                .collect(Collectors.toList());\n   208\t    }\n   209\t\n   210\t    /**\n   211\t     * Returns changed artifact coordinates paired with only newly added tested-versions from artifact-level index.json diffs.\n   212\t     */\n   213\t    @SuppressWarnings(\"unchecked\")\n   214\t    public List<Map<String, Object>> diffIndexTestedVersions(String baseCommit, String newCommit) {\n   215\t        return diffFiles(baseCommit, newCommit, \"ACMRT\").stream()\n   216\t                .map(path -> repoRoot().relativize(path).toString().replace('\\\\', '/'))\n   217\t                .map(relativePath -> diffIndexTestedVersionsEntry(baseCommit, newCommit, relativePath))\n   218\t                .filter(Objects::nonNull)\n   219\t                .collect(Collectors.toList());\n   220\t    }\n   221\t\n   222\t    private List<Path> diffFiles(String baseCommit, String newCommit, String diffFilter) {\n   223\t        ByteArrayOutputStream baos = new ByteArrayOutputStream();\n   224\t        getExecOperations().exec(spec -> {\n   225\t            spec.setStandardOutput(baos);\n   226\t            spec.commandLine(\"git\", \"diff\", \"--name-only\", \"--diff-filter=\" + diffFilter, baseCommit, newCommit);\n   227\t        });\n   228\t\n   229\t        return Arrays.stream(baos.toString(StandardCharsets.UTF_8).split(\"\\\\r?\\\\n\"))\n   230\t                .filter(line -> !line.isBlank())\n   231\t                .map(line -> repoRoot().resolve(line))\n   232\t                .collect(Collectors.toList());\n   233\t    }\n   234\t\n   235\t    /**\n   236\t     * Maps an artifact-level metadata index.json file path to its corresponding coordinate string.\n   237\t     *\n   238\t     * @return the coordinate string (G:A), or null if not a match\n   239\t     */\n   240\t    private String indexPathToCoordinate(String path) {\n   241\t        Pattern pattern = Pattern.compile(\"(?:metadata|tests/src)/([^/]+)/([^/]+)(?:/([^/]+))?/index\\\\.json\");\n   242\t        Matcher matcher = pattern.matcher(path);\n   243\t\n   244\t        if (matcher.matches()) {\n   245\t            String group = matcher.group(1);\n   246\t            String artifact = matcher.group(2);\n   247\t            String version = matcher.group(3);\n   248\t\n   249\t            return (version != null)\n   250\t                    ? String.format(\"%s:%s:%s\", group, artifact, version)\n","exit_code":0,"status":"completed"}}
