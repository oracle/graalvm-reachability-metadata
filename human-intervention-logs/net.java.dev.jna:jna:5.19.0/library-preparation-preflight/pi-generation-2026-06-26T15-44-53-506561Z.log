rnal process execution.\",\nmetadata/org.jline/jline-terminal-jni/index.json:46:    \"description\" : \"JLine JNI Terminal provides the JLine terminal provider implementation that uses JLine's JNI native library for low-level terminal and pseudoterminal access. It plugs into the JLine terminal API to support native console operations across supported platforms without relying on JNA or external process execution.\",\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:5:        \"typeReached\": \"org.jline.terminal.impl.jna.linux.LinuxNativePty\"\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:9:          \"org.jline.terminal.impl.jna.linux.CLibrary\"\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:15:        \"typeReached\": \"org.jline.terminal.impl.jna.linux.LinuxNativePty$UtilLibrary\"\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:19:          \"org.jline.terminal.impl.jna.linux.LinuxNativePty$UtilLibrary\"\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:25:        \"typeReached\": \"org.jline.terminal.impl.jna.linux.CLibrary$termios\"\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:27:      \"type\": \"org.jline.terminal.impl.jna.linux.CLibrary$termios\",\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:32:        \"typeReached\": \"org.jline.terminal.impl.jna.linux.CLibrary$winsize\"\nmetadata/org.jline/jline-terminal-jna/3.20.0/reachability-metadata.json:34:      \"type\": \"org.jline.terminal.impl.jna.linux.CLibrary$winsize\",\nmetadata/org.jline/jline-terminal-jna/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/jline/jline-terminal-jna/$version$/jline-terminal-jna-$version$-sources.jar\",\nmetadata/org.jline/jline-terminal-jna/index.json:7:    \"test-code-url\" : \"https://github.com/jline/jline3/tree/jline-parent-$version$/terminal-jna/src/test\",\nmetadata/org.jline/jline-terminal-jna/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/jline/jline-terminal-jna/$version$/jline-terminal-jna-$version$-javadoc.jar\",\nmetadata/org.jline/jline-terminal-jna/index.json:9:    \"description\" : \"This module adds a JNA-backed terminal provider for JLine. It uses native platform APIs to manage terminals and pseudoterminals on supported operating systems.\",\nmetadata/org.jline/jline-terminal-jna/index.json:17:      \"org.jline.terminal.impl.jna\"\nmetadata/org.jline/jline-reader/3.22.0/reachability-metadata.json:33:      \"glob\": \"META-INF/services/org/jline/terminal/provider/jna\"\nmetadata/com.github.ajalt.mordant/mordant-jvm/index.json:5:    \"replacement\": \"com.github.ajalt.mordant:mordant-core-jvm:3.0.2 plus com.github.ajalt.mordant:mordant-jvm-jna-jvm:3.0.2, com.github.ajalt.mordant:mordant-jvm-ffm-jvm:3.0.2, and com.github.ajalt.mordant:mordant-jvm-graal-ffi-jvm:3.0.2\"\ntests/src/org.jline/jline-terminal-jna/3.20.0/build.gradle:14:    testImplementation \"org.jline:jline-terminal-jna:$libraryVersion\"\ntests/src/org.jline/jline-terminal-jna/3.20.0/settings.gradle:20:rootProject.name = 'org.jline.jline-terminal-jna_tests'\ntests/src/org.jline/jline-terminal-jna/3.20.0/src/test/java/org/graalvm/jline/JnaNativePtyTest.java:9:import com.sun.jna.Platform;\ntests/src/org.jline/jline-terminal-jna/3.20.0/src/test/java/org/graalvm/jline/JnaNativePtyTest.java:12:import org.jline.terminal.impl.jna.JnaNativePty;\ntests/src/org.jline/jline-terminal-jna/3.20.0/user-code-filter.json:7:      \"includeClasses\" : \"org.jline.terminal.impl.jna.**\"\ntests/src/org.jetbrains.kotlin/kotlin-daemon-embeddable/2.3.20/build.gradle:25:                \"jline-terminal-jna\",\ntests/src/io.nats/jnats/2.16.11/build.gradle:14:    testImplementation \"io.nats:jnats:$libraryVersion\"\ntests/src/io.nats/jnats/2.16.11/settings.gradle:20:rootProject.name = 'io.nats.jnats_tests'\ntests/src/io.nats/jnats/2.16.11/src/test/java/io_