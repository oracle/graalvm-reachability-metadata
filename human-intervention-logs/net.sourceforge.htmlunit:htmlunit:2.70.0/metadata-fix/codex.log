n() throws Exception {\n        ActiveXObjectImpl activeXObject = new ActiveXObjectImpl(\"Scripting.Dictionary\");\n\n        Object functionObject = activeXObject.get(\"open\", null);\n        assertThat(functionObject).isInstanceOf(Function.class);\n\n        Object result = ((Function) functionObject).call(null, null, null, new Object[] {\"document.html\"});\n\n        ActiveXComponent component = ActiveXComponent.getLastInstance();\n        assertThat(component.getLastCallName()).isEqualTo(\"open\");\n        assertThat(component.getLastCallArguments()).containsExactly(\"document.html\");\n        assertThat(result).isInstanceOf(ActiveXObjectImpl.class);\n    }\n}\n","exit_code":0,"status":"completed"}}
