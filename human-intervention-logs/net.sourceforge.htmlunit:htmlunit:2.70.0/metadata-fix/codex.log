{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/net.sourceforge.htmlunit/htmlunit/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit/AbstractJavaScriptConfigurationTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit;\n\nimport java.util.List;\nimport java.util.Map;\n\nimport com.gargoylesoftware.htmlunit.BrowserVersion;\nimport com.gargoylesoftware.htmlunit.javascript.configuration.AbstractJavaScriptConfiguration;\nimport com.gargoylesoftware.htmlunit.javascript.configuration.ClassConfiguration;\nimport com.gargoylesoftware.htmlunit.javascript.host.css.CSSRule;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.w3c.dom.css.CSSRule.STYLE_RULE;\n\npublic class AbstractJavaScriptConfigurationTest {\n\n    @Test\n    void buildsConfigurationFromAnnotatedHostClassMembers() {\n        ClassConfiguration configuration = AbstractJavaScriptConfiguration.getClassConfiguration(\n                CSSRule.class, BrowserVersion.CHROME);\n\n        assertThat(configuration).isNotNull();\n        assertThat(configuration.getClassName()).isEqualTo(\"CSSRule\");\n        assertThat(configuration.getJsConstructor()).isNotNull();\n\n        Map<String, ClassConfiguration.PropertyInfo> properties = configuration.getPropertyMap();\n        assertThat(properties).containsKeys(\"cssText\", \"parentRule\", \"parentStyleSheet\", \"type\");\n        assertThat(properties.get(\"cssText\").getWriteMethod()).isNotNull();\n\n        List<ClassConfiguration.ConstantInfo> constants = configuration.getConstants();\n        assertThat(constants)\n                .extracting(ClassConfiguration.ConstantInfo::getName)\n                .contains(\"STYLE_RULE\", \"IMPORT_RULE\", \"SUPPORTS_RULE\");\n        assertThat(constants)\n                .filteredOn(constant -> \"STYLE_RULE\".equals(constant.getName()))\n                .singleElement()\n                .extracting(ClassConfiguration.ConstantInfo::getValue)\n                .isEqualTo(STYLE_RULE);\n    }\n}\n","exit_code":0,"status":"completed"}}
