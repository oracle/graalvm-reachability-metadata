  import net.sourceforge.htmlunit.corejs.javascript.Scriptable;
  
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ScriptableWrapperTest {
  
      @Test
      void wrapsNodeListPropertiesAndIndexedAccess() {
          final Context context = Context.enter();
          try {
              final Scriptable scope = context.initStandardObjects();
              final TestNodeList nodes = new TestNodeList(3);
  
              final ScriptableWrapper wrapper = new ScriptableWrapper(scope, nodes, NodeList.class);
  
              assertThat(wrapper.getClassName()).isEqualTo("NodeList");
              assertThat(wrapper.getDefaultValue(String.class)).isEqualTo("[object NodeList]");
              assertThat(wrapper.has("length", wrapper)).isTrue();
              assertThat(((Number) wrapper.get("length", wrapper)).intValue()).isEqualTo(3);
              assertThat(wrapper.get(1, wrapper)).isNull();
              assertThat(nodes.getLastRequestedIndex()).isEqualTo(1);
          }
          finally {
              Context.exit();
          }
      }
  
      @Test
      void wrapsNamedNodeMapNameLookupFallback() {
          final Context context = Context.enter();
          try {
              final Scriptable scope = context.initStandardObjects();
              final TestNamedNodeMap attributes = new TestNamedNodeMap(2);
  
              final ScriptableWrapper wrapper = new ScriptableWrapper(scope, attributes, NamedNodeMap.class);
  
              assertThat(wrapper.getClassName()).isEqualTo("NamedNodeMap");
              assertThat(((Number) wrapper.get("length", wrapper)).intValue()).isEqualTo(2);
              Object missingAttribute = wrapper.get("data-test", wrapper);
              assertThat(missingAttribute).isNotNull();
              assertThat(attributes.getLastRequestedName()).isEqualTo("data-test");
          }
          finally {
              Context.exit();
          }
      }
  
      public static final class TestNodeList implements NodeList {
          private final int length;
          private int lastRequestedIndex = -1;
  
          TestNodeList(final int length) {
              this.length = length;
          }
  
          @Override
          public Node item(final int index) {
              lastRequestedIndex = index;
              return null;
          }
  
          @Override
          public int getLength() {
              return length;
          }
  
          int getLastRequestedIndex() {
              return lastRequestedIndex;
          }
      }
  
      public static final class TestNamedNodeMap implements NamedNodeMap {
          private final int length;
          private String lastRequestedName;
  
          TestNamedNodeMap(final int length) {
              this.length = length;
          }
  
