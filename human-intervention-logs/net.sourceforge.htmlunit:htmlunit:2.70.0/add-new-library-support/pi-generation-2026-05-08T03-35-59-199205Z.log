[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit/SvgElementFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit;\n\nimport com.gargoylesoftware.htmlunit.BrowserVersion;\nimport com.gargoylesoftware.htmlunit.WebClient;\nimport com.gargoylesoftware.htmlunit.html.DomElement;\nimport com.gargoylesoftware.htmlunit.html.HtmlPage;\nimport com.gargoylesoftware.htmlunit.svg.SvgElementFactory;\nimport com.gargoylesoftware.htmlunit.svg.SvgRect;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SvgElementFactoryTest {\n    private static final String SVG_NAMESPACE = \"http://www.w3.org/2000/svg\";\n\n    @Test\n    void createsSupportedSvgElementWithNamespaceAndPrefix() throws Exception {\n        try (WebClient webClient = new WebClient(BrowserVersion.CHROME)) {\n            webClient.getOptions().setJavaScriptEnabled(false);\n            HtmlPage page = webClient.loadHtmlCodeIntoCurrentWindow(\"<!doctype html><html><body></body></html>\");\n            SvgElementFactory factory = new SvgElementFactory();\n\n            assertThat(factory.isSupported(\"rect\")).isTrue();\n\n            DomElement rect = factory.createElementNS(page, SVG_NAMESPACE, \"svg:rect\", null);\n\n            assertThat(rect).isInstanceOf(SvgRect.class);\n            assertThat(rect.getNamespaceURI()).isEqualTo(SVG_NAMESPACE);\n            assertThat(rect.getLocalName()).isEqualTo(\"rect\");\n            assertThat(rect.getPrefix()).isEqualTo(\"svg\");\n            assertThat(rect.getTagName()).isEqualTo(\"svg:rect\");\n        }\n    }\n}\n"}
