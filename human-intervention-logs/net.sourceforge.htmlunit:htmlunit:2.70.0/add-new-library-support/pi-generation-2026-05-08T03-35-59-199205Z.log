utes, NamedNodeMap.class);\n\n            assertThat(wrapper.getClassName()).isEqualTo(\"NamedNodeMap\");\n            assertThat(((Number) wrapper.get(\"length\", wrapper)).intValue()).isEqualTo(2);\n            Object missingAttribute = wrapper.get(\"data-test\", wrapper);\n            assertThat(missingAttribute).isNotNull();\n            assertThat(attributes.getLastRequestedName()).isEqualTo(\"data-test\");\n        }\n        finally {\n            Context.exit();\n        }\n    }\n\n    public static final class TestNodeList implements NodeList {\n        private final int length;\n        private int lastRequestedIndex = -1;\n\n        TestNodeList(final int length) {\n            this.length = length;\n        }\n\n        @Override\n        public Node item(final int index) {\n            lastRequestedIndex = index;\n            return null;\n        }\n\n        @Override\n        public int getLength() {\n            return length;\n        }\n\n        int getLastRequestedIndex() {\n            return lastRequestedIndex;\n        }\n    }\n\n    public static final class TestNamedNodeMap implements NamedNodeMap {\n        private final int length;\n        private String lastRequestedName;\n\n        TestNamedNodeMap(final int length) {\n            this.length = length;\n        }\n\n        @Override\n        public Node getNamedItem(final String name) {\n            lastRequestedName = name;\n            return null;\n        }\n\n        @Override\n        public Node setNamedItem(final Node arg) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node removeNamedItem(final String name) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node item(final int index) {\n            return null;\n        }\n\n        @Override\n        public int getLength() {\n            return length;\n        }\n\n        @Override\n        public Node getNamedItemNS(final String namespaceURI, final String localName) {\n            return null;\n        }\n\n        @Override\n        public Node setNamedItemNS(final Node arg) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node removeNamedItemNS(final String namespaceURI, final String localName) {\n            throw new UnsupportedOperationException();\n        }\n\n        String getLastRequestedName() {\n            return lastRequestedName;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778211243767}, {"role": "toolResult", "toolCallId": "call_RqQaWk1MYPDNtmeV6aSQsliz|fc_0d82648ec0303b540169fd59ab8cf481a1b090efad5f1b9e2a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport com.gargoylesoftware.htmlunit.DefaultCredentialsProvider;\n\nimport org.apache.http.auth.AuthScope;\nimport org.apache.http.auth.Credentials;\nimport org.apache.http.auth.UsernamePasswordCredentials;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultCredentialsProviderInnerAuthScopeProxyTest {\n\n    @Test\n    void serializesCredentialsProviderWithAuthScopeProxy() throws Exception {\n        DefaultCredentialsProvider provider = new DefaultCredentialsProvider();\n        AuthScope authScope = new AuthScope(\"example.test\", 8080, \"members\", \"basic\");\n        provider.setCredentials(authScope, new UsernamePasswordCredentials(\"alice\", \"secret\"));\n\n        byte[] serializedProvider = serialize(provider);\n        DefaultCredentialsProvider deserializedProvider = deserialize(serializedProvider);\n\n        Credentials credentials = deserializedProvider.getCredentials(authScope);\n        assertThat(credentials).isNotNull();\n        assertThat(credentials.getUserPrincipal().getName()).isEqualTo(\"alice\");\n        assertThat(credentials.getPassword()).isEqualTo(\"secret\");\n    }\n\n    private static byte[] serialize(final DefaultCredentialsProvider provider) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            stream.writeObject(provider);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static DefaultCredentialsProvider deserialize(final byte[] serializedProvider) throws Exception {\n        try (ObjectInputStream stream = new ObjectInputStream(new ByteArrayInputStream(serializedProvider))) {\n            return (DefaultCredentialsProvider) stream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778211243768}]}
