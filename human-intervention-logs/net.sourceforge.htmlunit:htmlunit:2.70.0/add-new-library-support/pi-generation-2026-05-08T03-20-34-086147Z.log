[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit/ActiveXObjectImplTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit;\n\nimport com.gargoylesoftware.htmlunit.javascript.host.ActiveXObjectImpl;\nimport com.jacob.activeX.ActiveXComponent;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Function;\n\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ActiveXObjectImplTest {\n\n    @BeforeEach\n    void setUp() {\n        ActiveXComponent.reset();\n    }\n\n    @Test\n    void constructsActiveXComponentAndWrapsDispatchProperty() throws Exception {\n        ActiveXObjectImpl activeXObject = new ActiveXObjectImpl(\"Scripting.Dictionary\");\n\n        ActiveXComponent component = ActiveXComponent.getLastInstance();\n        assertThat(component).isNotNull();\n        assertThat(component.getActiveXName()).isEqualTo(\"Scripting.Dictionary\");\n\n        Object dispatchProperty = activeXObject.get(\"dispatchProperty\", null);\n        assertThat(dispatchProperty).isInstanceOf(ActiveXObjectImpl.class);\n    }\n\n    @Test\n    void writesPropertyThroughJacobSetPropertyMethod() throws Exception {\n        ActiveXObjectImpl activeXObject = new ActiveXObjectImpl(\"Scripting.Dictionary\");\n\n        activeXObject.put(\"title\", null, \"HtmlUnit\");\n\n        ActiveXComponent component = ActiveXComponent.getLastInstance();\n        assertThat(component.getPropertyValue(\"title\")).isEqualTo(\"HtmlUnit\");\n    }\n\n    @Test\n    void missingPropertyIsExposedAsDispatchFunction() throws Exception {\n        ActiveXObjectImpl activeXObject = new ActiveXObjectImpl(\"Scripting.Dictionary\");\n\n        Object functionObject = activeXObject.get(\"open\", null);\n        assertThat(functionObject).isInstanceOf(Function.class);\n\n        Object result = ((Function) functionObject).call(null, null, null, new Object[] {\"document.html\"});\n\n        ActiveXComponent component = ActiveXComponent.getLastInstance();\n        assertThat(component.getLastCallName()).isEqualTo(\"open\");\n        assertThat(component.getLastCallArguments()).containsExactly(\"document.html\");\n        assertThat(result).isInstanceOf(ActiveXObjectImpl.class);\n    }\n}\n"}
