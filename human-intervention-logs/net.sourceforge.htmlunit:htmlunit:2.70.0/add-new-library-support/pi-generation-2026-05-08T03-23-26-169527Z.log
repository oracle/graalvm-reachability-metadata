[tool-call] delta {"path":"tests/src/net.sourceforge.htmlunit/htmlunit/2.70.0/src/test/java/net_sourceforge_htmlunit/htmlunit/DefaultCredentialsProviderInnerAuthScopeProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport com.gargoylesoftware.htmlunit.DefaultCredentialsProvider;\n\nimport org.apache.http.auth.AuthScope;\nimport org.apache.http.auth.Credentials;\nimport org.apache.http.auth.UsernamePasswordCredentials;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DefaultCredentialsProviderInnerAuthScopeProxyTest {\n\n    @Test\n    void serializesCredentialsProviderWithAuthScopeProxy() throws Exception {\n        DefaultCredentialsProvider provider = new DefaultCredentialsProvider();\n        AuthScope authScope = new AuthScope(\"example.test\", 8080, \"members\", \"basic\");\n        provider.setCredentials(authScope, new UsernamePasswordCredentials(\"alice\", \"secret\"));\n\n        byte[] serializedProvider = serialize(provider);\n        DefaultCredentialsProvider deserializedProvider = deserialize(serializedProvider);\n\n        Credentials credentials = deserializedProvider.getCredentials(authScope);\n        assertThat(credentials).isNotNull();\n        assertThat(credentials.getUserPrincipal().getName()).isEqualTo(\"alice\");\n        assertThat(credentials.getPassword()).isEqualTo(\"secret\");\n    }\n\n    private static byte[] serialize(final DefaultCredentialsProvider provider) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {\n            stream.writeObject(provider);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static DefaultCredentialsProvider deserialize(final byte[] serializedProvider) throws Exception {\n        try (ObjectInputStream stream = new ObjectInputStream(new ByteArrayInputStream(serializedProvider))) {\n            return (DefaultCredentialsProvider) stream.readObject();\n        }\n    }\n}\n"}
