  package net_sourceforge_htmlunit.htmlunit;
  
  import com.gargoylesoftware.htmlunit.javascript.host.ActiveXObjectImpl;
  import com.jacob.activeX.ActiveXComponent;
  
  import net.sourceforge.htmlunit.corejs.javascript.Function;
  
  import org.junit.jupiter.api.BeforeEach;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ActiveXObjectImplTest {
  
      @BeforeEach
      void setUp() {
          ActiveXComponent.reset();
      }
  
      @Test
      void constructsActiveXComponentAndWrapsDispatchProperty() throws Exception {
          ActiveXObjectImpl activeXObject = new ActiveXObjectImpl("Scripting.Dictionary");
  
          ActiveXComponent component = ActiveXComponent.getLastInstance();
          assertThat(component).isNotNull();
          assertThat(component.getActiveXName()).isEqualTo("Scripting.Dictionary");
  
          Object dispatchProperty = activeXObject.get("dispatchProperty", null);
          assertThat(dispatchProperty).isInstanceOf(ActiveXObjectImpl.class);
      }
  
      @Test
      void writesPropertyThroughJacobSetPropertyMethod() throws Exception {
          ActiveXObjectImpl activeXObject = new ActiveXObjectImpl("Scripting.Dictionary");
  
          activeXObject.put("title", null, "HtmlUnit");
  
          ActiveXComponent component = ActiveXComponent.getLastInstance();
          assertThat(component.getPropertyValue("title")).isEqualTo("HtmlUnit");
      }
  
      @Test
      void missingPropertyIsExposedAsDispatchFunction() throws Exception {
          ActiveXObjectImpl activeXObject = new ActiveXObjectImpl("Scripting.Dictionary");
  
          Object functionObject = activeXObject.get("open", null);
          assertThat(functionObject).isInstanceOf(Function.class);
  
          Object result = ((Function) functionObject).call(null, null, null, new Object[] {"document.html"});
  
          ActiveXComponent component = ActiveXComponent.getLastInstance();
          assertThat(component.getLastCallName()).isEqualTo("open");
          assertThat(component.getLastCallArguments()).containsExactly("document.html");
          assertThat(result).isInstanceOf(ActiveXObjectImpl.class);
      }
  }
