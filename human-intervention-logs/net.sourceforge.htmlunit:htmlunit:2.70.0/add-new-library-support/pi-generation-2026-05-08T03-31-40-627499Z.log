  /**
   * An abstract container for all the JavaScript configuration information.
   *
   * @author <a href="mailto:mbowler@GargoyleSoftware.com">Mike Bowler</a>
   * @author Chris Erskine
   * @author Ahmed Ashour
   * @author Ronald Brill
