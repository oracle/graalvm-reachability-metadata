0d35a6b4bc", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage net_sourceforge_htmlunit.htmlunit;\n\nimport org.w3c.dom.NamedNodeMap;\nimport org.w3c.dom.Node;\nimport org.w3c.dom.NodeList;\n\nimport com.gargoylesoftware.htmlunit.javascript.ScriptableWrapper;\n\nimport net.sourceforge.htmlunit.corejs.javascript.Context;\nimport net.sourceforge.htmlunit.corejs.javascript.Scriptable;\n\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ScriptableWrapperTest {\n\n    @Test\n    void wrapsNodeListPropertiesAndIndexedAccess() {\n        final Context context = Context.enter();\n        try {\n            final Scriptable scope = context.initStandardObjects();\n            final TestNodeList nodes = new TestNodeList(3);\n\n            final ScriptableWrapper wrapper = new ScriptableWrapper(scope, nodes, NodeList.class);\n\n            assertThat(wrapper.getClassName()).isEqualTo(\"NodeList\");\n            assertThat(wrapper.getDefaultValue(String.class)).isEqualTo(\"[object NodeList]\");\n            assertThat(wrapper.has(\"length\", wrapper)).isTrue();\n            assertThat(((Number) wrapper.get(\"length\", wrapper)).intValue()).isEqualTo(3);\n            assertThat(wrapper.get(1, wrapper)).isNull();\n            assertThat(nodes.getLastRequestedIndex()).isEqualTo(1);\n        }\n        finally {\n            Context.exit();\n        }\n    }\n\n    @Test\n    void wrapsNamedNodeMapNameLookupFallback() {\n        final Context context = Context.enter();\n        try {\n            final Scriptable scope = context.initStandardObjects();\n            final TestNamedNodeMap attributes = new TestNamedNodeMap(2);\n\n            final ScriptableWrapper wrapper = new ScriptableWrapper(scope, attributes, NamedNodeMap.class);\n\n            assertThat(wrapper.getClassName()).isEqualTo(\"NamedNodeMap\");\n            assertThat(((Number) wrapper.get(\"length\", wrapper)).intValue()).isEqualTo(2);\n            Object missingAttribute = wrapper.get(\"data-test\", wrapper);\n            assertThat(missingAttribute).isNotNull();\n            assertThat(attributes.getLastRequestedName()).isEqualTo(\"data-test\");\n        }\n        finally {\n            Context.exit();\n        }\n    }\n\n    public static final class TestNodeList implements NodeList {\n        private final int length;\n        private int lastRequestedIndex = -1;\n\n        TestNodeList(final int length) {\n            this.length = length;\n        }\n\n        @Override\n        public Node item(final int index) {\n            lastRequestedIndex = index;\n            return null;\n        }\n\n        @Override\n        public int getLength() {\n            return length;\n        }\n\n        int getLastRequestedIndex() {\n            return lastRequestedIndex;\n        }\n    }\n\n    public static final class TestNamedNodeMap implements NamedNodeMap {\n        private final int length;\n        private String lastRequestedName;\n\n        TestNamedNodeMap(final int length) {\n            this.length = length;\n        }\n\n        @Override\n        public Node getNamedItem(final String name) {\n            lastRequestedName = name;\n            return null;\n        }\n\n        @Override\n        public Node setNamedItem(final Node arg) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node removeNamedItem(final String name) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node item(final int index) {\n            return null;\n        }\n\n        @Override\n        public int getLength() {\n            return length;\n        }\n\n        @Override\n        public Node getNamedItemNS(final String namespaceURI, final String localName) {\n            return null;\n        }\n\n        @Override\n        public Node setNamedItemNS(final Node arg) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node removeNamedItemNS(final String namespaceURI, final String localName) {\n            throw new UnsupportedOperationException();\n        }\n\n        String getLastRequestedName() {\n            return lastRequestedName;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778211028211}, {"role": "toolResult", "toolCallId": "call_fvtpC4xm4NZgJI3uq0IeUTEJ|fc_0307595ef87bff110169fd58d401d0819dafd4aa00b85347da", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"net.sourceforge.htmlunit:htmlunit:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778211028211}]}
