          method_ = clazz.getMethod(methodName, parameterTypes);
          jsTypeTags_ = new int[parameterTypes.length];
          int i = 0;
          for (final Class<?> klass : parameterTypes) {
              jsTypeTags_[i++] = FunctionObject.getTypeTag(klass);
          }
      }
  
