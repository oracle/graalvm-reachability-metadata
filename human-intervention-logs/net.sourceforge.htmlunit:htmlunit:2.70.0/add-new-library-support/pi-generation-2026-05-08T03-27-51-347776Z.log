      NamedAttrNodeMapImpl(final DomElement domNode, final boolean caseSensitive) {
          super();
          if (domNode == null) {
              throw new IllegalArgumentException("Provided domNode can't be null.");
          }
          domNode_ = domNode;
          caseSensitive_ = caseSensitive;
