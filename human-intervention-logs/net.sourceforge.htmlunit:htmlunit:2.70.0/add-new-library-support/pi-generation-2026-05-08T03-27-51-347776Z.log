alue(\"title\")).isEqualTo(\"HtmlUnit\");\n    }\n\n    @Test\n    void missingPropertyIsExposedAsDispatchFunction() throws Exception {\n        ActiveXObjectImpl activeXObject = new ActiveXObjectImpl(\"Scripting.Dictionary\");\n\n        Object functionObject = activeXObject.get(\"open\", null);\n        assertThat(functionObject).isInstanceOf(Function.class);\n\n        Object result = ((Function) functionObject).call(null, null, null, new Object[] {\"document.html\"});\n\n        ActiveXComponent component = ActiveXComponent.getLastInstance();\n        assertThat(component.getLastCallName()).isEqualTo(\"open\");\n        assertThat(component.getLastCallArguments()).containsExactly(\"document.html\");\n        assertThat(result).isInstanceOf(ActiveXObjectImpl.class);\n    }\n}\n"}], "isError": false, "timestamp": 1778210749175}, {"role": "toolResult", "toolCallId": "call_t6uu1NGhNBpr4W6PwR1WFPSj|fc_08e84a1683925a610169fd57bcca84819f88db77a58c15e6fe", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"net.sourceforge.htmlunit:htmlunit:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778210749176}]}
