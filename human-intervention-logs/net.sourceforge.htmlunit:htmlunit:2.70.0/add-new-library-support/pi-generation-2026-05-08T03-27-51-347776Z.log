  package net_sourceforge_htmlunit.htmlunit;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import com.gargoylesoftware.htmlunit.DefaultCredentialsProvider;
  
  import org.apache.http.auth.AuthScope;
  import org.apache.http.auth.Credentials;
  import org.apache.http.auth.UsernamePasswordCredentials;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DefaultCredentialsProviderInnerAuthScopeProxyTest {
  
      @Test
      void serializesCredentialsProviderWithAuthScopeProxy() throws Exception {
          DefaultCredentialsProvider provider = new DefaultCredentialsProvider();
          AuthScope authScope = new AuthScope("example.test", 8080, "members", "basic");
          provider.setCredentials(authScope, new UsernamePasswordCredentials("alice", "secret"));
  
          byte[] serializedProvider = serialize(provider);
          DefaultCredentialsProvider deserializedProvider = deserialize(serializedProvider);
  
          Credentials credentials = deserializedProvider.getCredentials(authScope);
          assertThat(credentials).isNotNull();
          assertThat(credentials.getUserPrincipal().getName()).isEqualTo("alice");
          assertThat(credentials.getPassword()).isEqualTo("secret");
      }
  
      private static byte[] serialize(final DefaultCredentialsProvider provider) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream stream = new ObjectOutputStream(bytes)) {
              stream.writeObject(provider);
          }
          return bytes.toByteArray();
      }
  
      private static DefaultCredentialsProvider deserialize(final byte[] serializedProvider) throws Exception {
          try (ObjectInputStream stream = new ObjectInputStream(new ByteArrayInputStream(serializedProvider))) {
              return (DefaultCredentialsProvider) stream.readObject();
          }
      }
  }
