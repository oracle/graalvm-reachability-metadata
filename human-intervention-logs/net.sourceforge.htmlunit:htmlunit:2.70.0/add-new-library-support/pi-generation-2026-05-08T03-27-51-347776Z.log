NamedNodeMap(2);\n\n            final ScriptableWrapper wrapper = new ScriptableWrapper(scope, attributes, NamedNodeMap.class);\n\n            assertThat(wrapper.getClassName()).isEqualTo(\"NamedNodeMap\");\n            assertThat(((Number) wrapper.get(\"length\", wrapper)).intValue()).isEqualTo(2);\n            assertThat(wrapper.get(\"data-test\", wrapper)).isSameAs(Scriptable.NOT_FOUND);\n            assertThat(attributes.getLastRequestedName()).isEqualTo(\"data-test\");\n        }\n        finally {\n            Context.exit();\n        }\n    }\n\n    public static final class TestNodeList implements NodeList {\n        private final int length;\n        private int lastRequestedIndex = -1;\n\n        TestNodeList(final int length) {\n            this.length = length;\n        }\n\n        @Override\n        public Node item(final int index) {\n            lastRequestedIndex = index;\n            return null;\n        }\n\n        @Override\n        public int getLength() {\n            return length;\n        }\n\n        int getLastRequestedIndex() {\n            return lastRequestedIndex;\n        }\n    }\n\n    public static final class TestNamedNodeMap implements NamedNodeMap {\n        private final int length;\n        private String lastRequestedName;\n\n        TestNamedNodeMap(final int length) {\n            this.length = length;\n        }\n\n        @Override\n        public Node getNamedItem(final String name) {\n            lastRequestedName = name;\n            return null;\n        }\n\n        @Override\n        public Node setNamedItem(final Node arg) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node removeNamedItem(final String name) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node item(final int index) {\n            return null;\n        }\n\n        @Override\n        public int getLength() {\n            return length;\n        }\n\n        @Override\n        public Node getNamedItemNS(final String namespaceURI, final String localName) {\n            return null;\n        }\n\n        @Override\n        public Node setNamedItemNS(final Node arg) {\n            throw new UnsupportedOperationException();\n        }\n\n        @Override\n        public Node removeNamedItemNS(final String namespaceURI, final String localName) {\n            throw new UnsupportedOperationException();\n        }\n\n        String getLastRequestedName() {\n            return lastRequestedName;\n        }\n    }\n}\n"}
