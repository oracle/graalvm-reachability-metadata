Context(Files.createTempDirectory('groovy-servlet-json-binding'))\n        TestHttpServletRequest request = new TestHttpServletRequest(context, new TestHttpSession(context))\n        TestHttpServletResponse response = new TestHttpServletResponse()\n        ServletBinding binding = new ServletBinding(request, response, context)\n\n        def json = binding.getVariable('json')\n        json {\n            message 'hello'\n            tags(['servlet', 'json'])\n            nested {\n                enabled true\n            }\n        }\n        (binding.getVariable('out') as PrintWriter).flush()\n\n        Map payload = new JsonSlurper().parseText(response.body) as Map\n        assertThat(payload).containsEntry('message', 'hello')\n        assertThat(payload['tags']).containsExactly('servlet', 'json')\n        assertThat(payload['nested']).isEqualTo([enabled: true])\n        assertThatThrownBy { (binding.getVariable('sout') as ServletOutputStream).write(33) }\n                .isInstanceOf(IllegalStateException)\n    }\n\n    @Test\n    void servletCategoryProvidesGroovyAttributeAccessForServletScopes() {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 785, "output": 1152, "cacheRead": 19456, "cacheWrite": 0, "totalTokens": 21393, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778402001261, "responseId": "resp_05939b2dc7712d17016a0042d24fc08193a9330e3cb48587dc"}}
