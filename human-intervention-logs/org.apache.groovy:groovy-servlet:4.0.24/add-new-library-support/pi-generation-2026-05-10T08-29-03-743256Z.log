          }
  
          //
          // flush the response buffer.
          //
          response.flushBuffer();
  
          if (verbose) {
              log("Template \"" + name + "\" request responded. [create/get=" + getMillis + " ms, make=" + makeMillis + " ms]");
          }
      }
