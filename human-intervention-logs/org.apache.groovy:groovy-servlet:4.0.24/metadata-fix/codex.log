est\n   142\t    void templateServletRendersTemplatesWithRequestHeadersParametersAndCustomVariables() {\n   143\t        try {\n   144\t            Path root = Files.createTempDirectory('groovy-template-servlet')\n   145\t            Files.writeString(root.resolve('hello.tpl'), 'Hello ${params.name}; ${headers[\"X-Test\"]}; ${extra}', StandardCharsets.UTF_8)\n   146\t            TestServletContext context = new TestServletContext(root)\n   147\t            TestTemplateServlet servlet = new TestTemplateServlet()\n   148\t            servlet.init(new TestServletConfig(context, [\n   149\t                    'generated.by': 'false',\n   150\t                    'encoding'    : 'UTF-8'\n   151\t            ]))\n   152\t            TestHttpServletRequest request = new TestHttpServletRequest(context, new TestHttpSession(context))\n   153\t            request.servletPath = '/hello.tpl'\n   154\t            request.parameters.put('name', ['Grace'] as String[])\n   155\t            request.headers.put('X-Test', ['header'])\n   156\t            TestHttpServletResponse response = new TestHttpServletResponse()\n   157\t\n   158\t            servlet.service(request, response)\n   159\t\n   160\t            assertThat(response.status).isEqualTo(HttpServletResponse.SC_OK)\n   161\t            assertThat(response.contentType).isEqualTo('text/html; charset=UTF-8')\n   162\t            assertThat(response.body).isEqualTo('Hello Grace; header; from-setVariables')\n   163\t        } catch (Error error) {\n   164\t            rethrowIfNotNativeImageDynamicClassLoadingError(error)\n   165\t        }\n   166\t    }\n   167\t\n   168\t    @Test\n   169\t    void templateServletAppliesResourceNamePatternBeforeLoadingTemplate() {\n   170\t        try {\n   171\t            Path root = Files.createTempDirectory('groovy-template-resource-pattern')\n   172\t            Files.writeString(root.resolve('resolved.tpl'), 'Mapped template', StandardCharsets.UTF_8)\n   173\t            TestServletCont