xt, session)\n   208\t            request.servletPath = '/hello.groovy'\n   209\t            request.parameters.put('name', ['Linus'] as String[])\n   210\t            request.headers.put('X-Test', ['header'])\n   211\t            TestHttpServletResponse response = new TestHttpServletResponse()\n   212\t\n   213\t            servlet.service(request, response)\n   214\t\n   215\t            assertThat(response.contentType).isEqualTo('text/html; charset=UTF-8')\n   216\t            assertThat(response.getHeader('X-Script')).isEqualTo('ran')\n   217\t            assertThat(response.body).isEqualTo('Hello Linus header')\n   218\t            assertThat(context.getAttribute('scriptAttribute')).isEqualTo('stored-in-context')\n   219\t            assertThat(session.getAttribute('visited')).isEqualTo('Linus')\n   220\t        } catch (Error error) {\n   221\t            rethrowIfNotNativeImageDynamicClassLoadingError(error)\n   222\t        }\n   223\t    }\n   224\t\n   225\t    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n   226\t        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n   227\t            throw error\n   228\t        }\n   229\t    }\n   230\t}\n   231\t\n   232\tclass TestTemplateServlet extends TemplateServlet {\n   233\t    @Override\n   234\t    protected void setVariables(ServletBinding binding) {\n   235\t        binding.setVariable('extra', 'from-setVariables')\n   236\t    }\n   237\t}\n   238\t\n   239\tclass TestServletConfig implements ServletConfig {\n   240\t    final ServletContext servletContext\n","exit_code":0,"status":"completed"}}
