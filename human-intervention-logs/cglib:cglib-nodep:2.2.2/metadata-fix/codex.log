rn_value=(0, \"/tmp/codex.log\", False),\n        ) as codex_mock:\n            result = ntv.verify_native_test_passes(\n                reachability_repo_path=self.repo,\n                coordinate=\"g:a:1.0\",\n                output_dir=self.output_dir,\n","exit_code":0,"status":"completed"}}
