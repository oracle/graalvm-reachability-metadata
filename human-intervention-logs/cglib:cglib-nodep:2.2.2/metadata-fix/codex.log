ssAfterPublicInitialization() throws Throwable {\n        try {\n            MethodHandle classLookup = syntheticClassLookup();\n\n            Class<?> resolvedClass = invokeSyntheticClassLookup(\n                    classLookup,\n                    \"net.sf.cglib.proxy.Mixin\"\n            );\n\n            assertThat(resolvedClass.getName()).isEqualTo(\"net.sf.cglib.proxy.Mixin\");\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @Order(3)\n    void discoversInterfacesImplementedByDelegates() {\n        try {\n            Class<?>[] classes = Mixin.getClasses(new Object[] {new GreeterAndCounter()});\n\n            assertThat(classes).containsExactlyInAnyOrder(Greeter.class, Counter.class);\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    @Order(4)\n    void initializesGeneratorSourceWithMixinClassName() {\n        try {\n            Mixin.Generator generator = new Mixin.Generator();\n\n            assertThatThrownBy(() -> generator.setStyle(-1))\n                    .isInstanceOf(IllegalArgumentException.class)\n                    .hasMessage(\"Unknown mixin style: -1\");\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        }\n    }\n\n    private static MethodHandle syntheticClassLookup()\n            throws NoSuchMethodException, IllegalAccessException {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                Mixin.class,\n                MethodHandles.lookup()\n        );\n        return lookup.findStatic(\n                Mixin.class,\n                \"class$\",\n                MethodType.methodType(Class.class, String.class)\n        );\n    }\n\n    private static Class<?> invokeSyntheticClassLookup(MethodHandle classLookup, String className)\n            throws Throwable {\n        return (Class<?>) classLookup.invokeExact(className);\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            if (current instanceof NoClassDefFoundError error\n                    && \"Could not initialize class net.sf.cglib.proxy.Mixin\"\n                            .equals(error.getMessage())) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface Greeter {\n        String greet(String name);\n    }\n\n    public interface Counter {\n        int count();\n    }\n\n    private static final class GreeterDelegate implements Greeter {\n        @Override\n        public String greet(String name) {\n            return \"Hello, \" + name;\n        }\n    }\n\n    private static final class CounterDelegate implements Counter {\n        @Override\n        public int count() {\n            return 2;\n        }\n    }\n\n    private static final class GreeterAndCounter implements Greeter, Counter {\n        @Override\n        public String greet(String name) {\n            return \"Hello, \" + name;\n        }\n\n        @Override\n        public int count() {\n            return 2;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
