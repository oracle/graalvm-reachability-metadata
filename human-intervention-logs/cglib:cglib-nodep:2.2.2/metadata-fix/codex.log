eSyntheticClassLookup(MethodHandle classLookup, String className)\n            throws Throwable {\n        return (Class<?>) classLookup.invokeExact(className);\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            if (current instanceof NoClassDefFoundError error\n                    && \"Could not initialize class net.sf.cglib.proxy.Mixin\"\n                            .equals(error.getMessage())) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface Greeter {\n        String greet(String name);\n    }\n\n    public interface Counter {\n        int count();\n    }\n\n    private static final class GreeterDelegate implements Greeter {\n        @Override\n        public String greet(String name) {\n            return \"Hello, \" + name;\n        }\n    }\n\n    private static final class CounterDelegate implements Counter {\n        @Override\n        public int count() {\n            return 2;\n        }\n    }\n\n    private static final class GreeterAndCounter implements Greeter, Counter {\n        @Override\n        public String greet(String name) {\n            return \"Hello, \" + name;\n        }\n\n        @Override\n        public int count() {\n            return 2;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
