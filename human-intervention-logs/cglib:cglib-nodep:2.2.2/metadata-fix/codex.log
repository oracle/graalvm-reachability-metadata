ignature.class,\n                new Class[] {String.class, String.class},\n                new Object[] {\"generated\", \"()V\"});\n\n        assertThat(signature.getName()).isEqualTo(\"generated\");\n        assertThat(signature.getDescriptor()).isEqualTo(\"()V\");\n    }\n\n    @Test\n    void findsDeclaredMethodsAcrossClassHierarchy() throws NoSuchMethodException {\n        Method inherited = ReflectUtils.findDeclaredMethod(\n                Enhancer.class, \"setUseCache\", new Class[] {Boolean.TYPE});\n\n        assertThat(inherited.getName()).isEqualTo(\"setUseCache\");\n        assertThat(inherited.getDeclaringClass().getName())\n                .isEqualTo(\"net.sf.cglib.core.AbstractClassGenerator\");\n    }\n\n    @Test\n    void collectsDeclaredMethodsFromClassHierarchyAndInterfaces() {\n        List methods = ReflectUtils.addAllMethods(Enhancer.class, new ArrayList());\n\n        assertThat(methods)\n                .extracting(\"name\")\n                .contains(\"setSuperclass\", \"setUseCache\", \"getClassLoader\");\n    }\n\n    @Test\n    void locatesSingleMethodOnInterface() {\n        Method evaluate = ReflectUtils.findInterfaceMethod(Predicate.class);\n\n        assertThat(evaluate.getName()).isEqualTo(\"evaluate\");\n        assertThat(evaluate.getDeclaringClass()).isEqualTo(Predicate.class);\n    }\n\n    @Test\n    void definesGeneratedClassThroughConfiguredClassLoader() throws Exception {\n        byte[] bytecode = generatedClassBytecode();\n        ClassLoader loader = new ClassLoader(ReflectUtilsTest.class.getClassLoader()) { };\n\n        try {\n            Class<?> generated = ReflectUtils.defineClass(GENERATED_CLASS_NAME, bytecode, loader);\n\n            assertThat(generated.getName()).isEqualTo(GENERATED_CLASS_NAME);\n            assertThat(generated.getClassLoader()).isSameAs(loader);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static byte[] generatedClassBytecode() {\n        ClassWriter writer = new ClassWriter(0);\n        writer.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                GENERATED_INTERNAL_NAME,\n                null,\n                \"java/lang/Object\",\n                null);\n        writeDefaultConstructor(writer);\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static void writeDefaultConstructor(ClassWriter writer) {\n        MethodVisitor constructor = writer.visitMethod(\n                Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n    }\n}\n","exit_code":0,"status":"completed"}}
