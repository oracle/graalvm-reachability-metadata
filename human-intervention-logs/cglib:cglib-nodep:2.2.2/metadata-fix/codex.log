sformed.getDeclaredConstructor().newInstance();\n            DynamicDelegate delegate = DynamicDelegate.class.cast(instance);\n\n            assertThat(transformed.getInterfaces()).contains(DynamicDelegate.class);\n            assertThat(delegate.describe(\"subject\")).isEqualTo(\"delegate:subject\");\n            assertThat(delegate.getTarget()).isSameAs(instance);\n        } catch (InvocationTargetException exception) {\n            if (findUnsupportedFeatureError(exception) == null) {\n                throw exception;\n            }\n        } catch (RuntimeException exception) {\n            if (findUnsupportedFeatureError(exception) == null) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static ClassTransformer newDelegateTransformer() {\n        return new AddDelegateTransformer(new Class[] {DynamicDelegate.class}, DelegateImpl.class);\n    }\n\n    private static byte[] generatedClassBytecode() {\n        ClassWriter writer = new ClassWriter(0);\n        writer.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                GENERATED_INTERNAL_NAME,\n                null,\n                \"java/lang/Object\",\n                null);\n        writeDefaultConstructor(writer);\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static void writeDefaultConstructor(ClassWriter writer) {\n        MethodVisitor constructor = writer.visitMethod(\n                Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface DynamicDelegate {\n        String describe(String value);\n\n        Object getTarget();\n    }\n\n    public static class DelegateImpl implements DynamicDelegate {\n        private final Object target;\n\n        public DelegateImpl(Object target) {\n            this.target = target;\n        }\n\n        @Override\n        public String describe(String value) {\n            return \"delegate:\" + value;\n        }\n\n        @Override\n        public Object getTarget() {\n            return target;\n        }\n    }\n\n    private static class GeneratedClassPathLoader extends ClassLoader {\n        GeneratedClassPathLoader() {\n            super(AddDelegateTransformerTest.class.getClassLoader());\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if ((GENERATED_INTERNAL_NAME + \".class\").equals(name)) {\n                return new ByteArrayInputStream(generatedClassBytecode());\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n}\n\n---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.util.Locale;\n\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.Factory;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnhancerTest {\n    @Test\n    void createsEnhancedSubclassWithMethodInterceptor() {\n        try {\n            Enhancer enhancer = new Enhancer();\n            enhancer.setUseCache(false);\n            enhancer.setSuperclass(GreetingService.class);\n            enhancer.setCallback((MethodInterceptor) (object, method, arguments, proxy) -> {\n                Object result = proxy.invokeSuper(object, arguments);\n                if (result instanceof String) {\n                    return ((String) result).toUpperCase(Locale.ROOT);\n                }\n                return result;\n            });\n\n            GreetingService service = (GreetingService) enhancer.create();\n\n            assertThat(service).isInstanceOf(Factory.class);\n            assertThat(service.greet(\"cglib\")).isEqualTo(\"HELLO CGLIB\");\n        } catch (RuntimeException exception) {\n            if (findUnsupportedFeatureError(exception) == null) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n}\n\n---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\n\nimport net.sf.cglib.asm.ClassWriter;\nimport net.sf.cglib.asm.MethodVisitor;\nimport net.sf.cglib.asm.Opcodes;\nimport net.sf.cglib.transform.AbstractClassLoader;\nimport net.sf.cglib.transform.ClassFilter;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AbstractClassLoaderTest {\n    private static final String GENERATED_CLASS_NAME = \"cglib.cglib_nodep.AbstractClassLoaderGenerated\";\n    private static final String GENERATED_INTERNAL_NAME = \"cglib/cglib_nodep/AbstractClassLoaderGenerated\";\n\n    @Test\n    void delegatesRejectedClassesToParentLoader() throws ClassNotFoundException {\n        RecordingClassLoader loader = new RecordingClassLoader(\n                AbstractClassLoaderTest.class.getClassLoader(), name -> false);\n\n        Class loaded = loader.loadClass(String.class.getName());\n\n        assertThat(loaded).isSameAs(String.class);\n        assertThat(loader.postProcessedClass).isNull();\n    }\n\n    @Test\n    void loadsAcceptedClassBytesFromClassPathLoader() throws ClassNotFoundException {\n        RecordingClassLoader loader = new RecordingClassLoader(\n                new GeneratedClassPathLoader(), GENERATED_CLASS_NAME::equals);\n\n        try {\n            Class loaded = loader.loadClass(GENERATED_CLASS_NAME);\n            Class loadedAgain = loader.loadClass(GENERATED_CLASS_NAME);\n\n            assertThat(loaded.getName()).isEqualTo(GENERATED_CLASS_NAME);\n            assertThat(loaded.getClassLoader()).isSameAs(loader);\n            assertThat(loadedAgain).isSameAs(loaded);\n            assertThat(loader.postProcessedClass).isSameAs(loaded);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static byte[] generatedClassBytecode() {\n        ClassWriter writer = new ClassWriter(0);\n        writer.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                GENERATED_INTERNAL_NAME,\n                null,\n                \"java/lang/Object\",\n                null);\n        writeDefaultConstructor(writer);\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static void writeDefaultConstructor(ClassWriter writer) {\n        MethodVisitor constructor = writer.visitMethod(\n                Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n    }\n\n    private static class RecordingClassLoader extends AbstractClassLoader {\n        private Class postProcessedClass;\n\n        RecordingClassLoader(ClassLoader classPath, ClassFilter filter) {\n            super(AbstractClassLoaderTest.class.getClassLoader(), classPath, filter);\n        }\n\n        @Override\n        protected void postProcess(Class loadedClass) {\n            postProcessedClass = loadedClass;\n        }\n    }\n\n    private static class GeneratedClassPathLoader extends ClassLoader {\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if ((GENERATED_INTERNAL_NAME + \".class\").equals(name)) {\n                return new ByteArrayInputStream(generatedClassBytecode());\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
