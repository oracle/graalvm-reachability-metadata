da\\\");\\n        source.setAge(37);\\n        source.setActive(true);\\n        source.setScore(99);\\n        TargetAccount target = new TargetAccount();\\n        target.setName(\\\"unchanged\\\");\\n        target.setScore(7);\\n\\n        BeanCopier copier = BeanCopier.create(SourceAccount.class, TargetAccount.class, false);\\n        copier.copy(source, target, null);\\n\\n        assertThat(target.getName()).isEqualTo(\\\"Ada\\\");\\n        assertThat(target.getAge()).isEqualTo(37);\\n        assertThat(target.isActive()).isTrue();\\n        assertThat(target.getScore()).isEqualTo(99);\\n        assertThat(target.getTargetOnly()).isEqualTo(\\\"kept\\\");\\n    }\\n\\n    @Test\\n    @Order(4)\\n    void appliesConverterForMatchingPropertiesWithDifferentTypes() {\\n        SourceForm source = new SourceForm();\\n        source.setName(\\\"Grace\\\");\\n        source.setAge(\\\"42\\\");\\n        source.setEnabled(\\\"yes\\\");\\n        TargetForm target = new TargetForm();\\n        RecordingConverter converter = new RecordingConverter();\\n\\n        BeanCopier copier = BeanCopier.create(SourceForm.class, TargetForm.class, true);\\n        copier.copy(source, target, converter);\\n\\n        assertThat(target.getName()).isEqualTo(\\\"Grace\\\");\\n        assertThat(target.getAge()).isEqualTo(42);\\n        assertThat(target.isEnabled()).isTrue();\\n        assertThat(converter.getSetterNames()).contains(\\\"setName\\\", \\\"setAge\\\", \\\"setEnabled\\\");\\n    }\\n\\n    public static class SourceAccount {\\n        private String name;\\n        private int age;\\n        private boolean active;\\n        private Integer score;\\n\\n        public String getName() {\\n            return name;\\n        }\\n\\n        public void setName(String name) {\\n            this.name = name;\\n        }\\n\\n        public int getAge() {\\n            return age;\\n        }\\n\\n        public void setAge(int age) {\\n            this.age = age;\\n        }\\n\\n        public boolean isActive() {\\n            return active;\\n        }\\n\\n        public void setActive(boolean active) {\\n            this.active = active;\\n        }\\n\\n        public Integer getScore() {\\n            return score;\\n        }\\n\\n        public void setScore(Integer score) {\\n            this.score = score;\\n        }\\n    }\\n\\n    public static class TargetAccount {\\n        private String name;\\n        private int age;\\n        private boolean active;\\n        private Number score;\\n        private String targetOnly = \\\"kept\\\";\\n\\n        public String getName() {\\n            return name;\\n        }\\n\\n        public void setName(String name) {\\n            this.name = name;\\n        }\\n\\n        public int getAge() {\\n            return age;\\n        }\\n\\n        public void setAge(int age) {\\n            this.age = age;\\n        }\\n\\n        public boolean isActive() {\\n            return active;\\n        }\\n\\n        public void setActive(boolean active) {\\n            this.active = active;\\n        }\\n\\n        public Number getScore() {\\n            return score;\\n        }\\n\\n        public void setScore(Number score) {\\n            this.score = score;\\n        }\\n\\n        public String getTargetOnly() {\\n            return targetOnly;\\n        }\\n\\n        public void setTargetOnly(String targetOnly) {\\n            this.targetOnly = targetOnly;\\n        }\\n    }\\n\\n    public static class SourceForm {\\n        private String name;\\n        private String age;\\n        private String enabled;\\n\\n        public String getName() {\\n            return name;\\n        }\\n\\n        public void setName(String name) {\\n            this.name = name;\\n        }\\n\\n        public String getAge() {\\n            return age;\\n        }\\n\\n        public void setAge(String age) {\\n            this.age = age;\\n        }\\n\\n        public String getEnabled()