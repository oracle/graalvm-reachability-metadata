ort org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\npublic class AbstractClassLoaderTest {\\n    private static final String MISSING_CLASS_NAME = \\\"cglib.cglib_nodep.generated.MissingType\\\";\\n\\n    @Test\\n    void delegatesRejectedClassNamesToParentLoader() throws Exception {\\n        RecordingClassPath classPath = new RecordingClassPath();\\n        AbstractClassLoader loader = new TestClassLoader(\\n                AbstractClassLoaderTest.class.getClassLoader(),\\n                classPath,\\n                new ClassFilter() {\\n                    @Override\\n                    public boolean accept(String className) {\\n                        return false;\\n                    }\\n                });\\n\\n        Class<?> loadedClass = loader.loadClass(\\\"java.lang.String\\\");\\n\\n        assertThat(loadedClass).isSameAs(String.class);\\n        assertThat(classPath.requestedResources()).isEmpty();\\n    }\\n\\n    @Test\\n    void asksConfiguredClassPathForAcceptedClassBytes() {\\n        RecordingClassPath classPath = new RecordingClassPath();\\n        AbstractClassLoader loader = new TestClassLoader(\\n                AbstractClassLoaderTest.class.getClassLoader(),\\n                classPath,\\n                new ClassFilter() {\\n                    @Override\\n                    public boolean accept(String className) {\\n                        return className.equals(MISSING_CLASS_NAME);\\n                    }\\n                });\\n\\n        assertThatThrownBy(() -> loader.loadClass(MISSING_CLASS_NAME))\\n                .isInstanceOf(ClassNotFoundException.class)\\n                .hasMessage(MISSING_CLASS_NAME);\\n        assertThat(classPath.requestedResources())\\n                .containsExactly(\\\"cglib/cglib_nodep/generated/MissingType.class\\\");\\n    }\\n\\n    private static final class TestClassLoader exte