_INTERNAL_NAME = \\\"cglib/cglib_nodep/ReflectUtilsGenerated\\\";\\n\\n    @Test\\n    void findsConstructorsAndMethodsFromDescriptorStrings() {\\n        Constructor<?> stringConstructor = ReflectUtils.findConstructor(\\\"String(char[])\\\");\\n        Method substring = ReflectUtils.findMethod(\\\"java.lang.String.substring(int)\\\");\\n\\n        assertThat(stringConstructor.getDeclaringClass()).isEqualTo(String.class);\\n        assertThat(stringConstructor.getParameterTypes()).containsExactly(char[].class);\\n        assertThat(substring.getName()).isEqualTo(\\\"substring\\\");\\n        assertThat(substring.getParameterTypes()).containsExactly(int.class);\\n    }\\n\\n    @Test\\n    void invokesPrivateConstructorSelectedByParameterTypes() {\\n        Constructed constructed = (Constructed) ReflectUtils.newInstance(\\n                Constructed.class,\\n                new Class[] {String.class},\\n                new Object[] {\\\"created\\\"});\\n\\n        assertThat(constructed.getValue()).isEqualTo(\\\"created\\\");\\n    }\\n\\n    @Test\\n    void findsDeclaredMethodsAcrossClassHierarchy() throws NoSuchMethodException {\\n        Method inherited = ReflectUtils.findDeclaredMethod(\\n                ChildMethods.class, \\\"inheritedMessage\\\", new Class[0]);\\n\\n        assertThat(inherited.getName()).isEqualTo(\\\"inheritedMessage\\\");\\n        assertThat(inherited.getDeclaringClass()).isEqualTo(ParentMethods.class);\\n    }\\n\\n    @Test\\n    void collectsDeclaredMethodsFromClassHierarchyAndInterfaces() {\\n        List methods = ReflectUtils.addAllMethods(ChildMethods.class, new ArrayList());\\n\\n        assertThat(methods)\\n                .extracting(\\\"name\\\")\\n                .contains(\\\"childMessage\\\", \\\"inheritedMessage\\\", \\\"interfaceMessage\\\");\\n    }\\n\\n    @Test\\n    void locatesSingleFactoryMethodOnInterface() {\\n        Method newInstance = ReflectUtils.findNewInstance(SingleFactory.class);\\n\\n        assertThat(newInstance.getName()).isEqualTo(\\\"newInstance\\\");\\n        assertThat(newInstance.getDeclaringClass()).isEqualTo(SingleFactory.class);\\n    }\\n\\n    @Test\\n    void definesGeneratedClassThroughConfiguredClassLoader() throws Exception {\\n        byte[] bytecode = generatedClassBytecode();\\n        ClassLoader loader = new ClassLoader(ReflectUtilsTest.class.getClassLoader()) { };\\n\\n        try {\\n            Class<?> generated = ReflectUtils.defineClass(GENERATED_CLASS_NAME, bytecode, loader);\\n\\n            assertThat(generated.getName()).isEqualTo(GENERATED_CLASS_NAME);\\n            assertThat(generated.getClassLoader()).isSameAs(loader);\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    private static byte[] generatedClassBytecode() {\\n        ClassWriter writer = new ClassWriter(0);\\n        writer.visit(\\n                Opcodes.V1_6,\\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\\n                GENERATED_INTERNAL_NAME,\\n                null,\\n                \\\"java/lang/Object\\\",\\n                null);\\n        writeDefaultConstructor(writer);\\n        writer.visitEnd();\\n        return writer.toByteArray();\\n    }\\n\\n    private static void writeDefaultConstructor(ClassWriter writer) {\\n        MethodVisitor constructor = writer.visitMethod(\\n                Opcodes.ACC_PUBLIC, \\\"<init>\\\", \\\"()V\\\", null, null);\\n        constructor.visitCode();\\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \\\"java/lang/Object\\\", \\\"<init>\\\", \\\"()V\\\");\\n        constructor.visitInsn(Opcodes.RETURN);\\n        constructor.visitMaxs(1, 1);\\n        constructor.visitEnd();\\n    }\\n\\n    private static final class Constructed {\\n        private final String value;\\n\\n        private Constructed(String 