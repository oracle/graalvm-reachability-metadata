lkBeanTest {\\n+    private static final String[] GETTERS = {\\n+        \\\"getName\\\",\\n+        \\\"getAge\\\",\\n+        \\\"isActive\\\",\\n+        \\\"getScore\\\",\\n+        \\\"getCode\\\"\\n+    };\\n+    private static final String[] SETTERS = {\\n+        \\\"setName\\\",\\n+        \\\"setAge\\\",\\n+        \\\"setActive\\\",\\n+        \\\"setScore\\\",\\n+        \\\"setCode\\\"\\n+    };\\n+    private static final Class[] TYPES = {\\n+        String.class,\\n+        Integer.TYPE,\\n+        Boolean.TYPE,\\n+        Long.class,\\n+        Character.TYPE\\n+    };\\n+\\n+    @Test\\n+    @Order(1)\\n+    void initializesPublicGenerator() {\\n+        BulkBean.Generator generator = new BulkBean.Generator();\\n+\\n+        assertThat(generator).isNotNull();\\n+    }\\n+\\n+    @Test\\n+    @Order(2)\\n+    void createsBulkAccessorThroughConfiguredGenerator() {\\n+        BulkBean.Generator generator = new BulkBean.Generator();\\n+        generator.setTarget(RecordBean.class);\\n+        generator.setGetters(GETTERS);\\n+        generator.setSetters(SETTERS);\\n+        generator.setTypes(TYPES);\\n+\\n+        BulkBean bulkBean = generator.create();\\n+\\n+        assertThat(bulkBean.getGetters()).containsExactly(GETTERS);\\n+        assertThat(bulkBean.getSetters()).containsExactly(SETTERS);\\n+        assertThat(bulkBean.getPropertyTypes()).containsExactly(TYPES);\\n+    }\\n+\\n+    @Test\\n+    @Order(3)\\n+    void readsAndWritesBeanPropertiesInBulk() {\\n+        BulkBean bulkBean = BulkBean.create(RecordBean.class, GETTERS, SETTERS, TYPES);\\n+        RecordBean bean = new RecordBean();\\n+        Object[] values = {\\\"Ada\\\", 37, true, 99L, 'G'};\\n+\\n+        bulkBean.setPropertyValues(bean, values);\\n+        Object[] actualValues = bulkBean.getPropertyValues(bean);\\n+\\n+        assertThat(actualValues).containsExactly(values);\\n+        assertThat(bean.getName()).isEqualTo(\\\"Ada\\\");\\n+        assertThat(bean.getAge()).isEqua