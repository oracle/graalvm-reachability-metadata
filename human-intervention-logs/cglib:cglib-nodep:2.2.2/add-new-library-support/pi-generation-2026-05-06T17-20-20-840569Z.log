[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/EnhancerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.core.CodeGenerationException;\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.FixedValue;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnhancerTest {\n\n    @Test\n    void createsEnhancedInterfaceImplementationAndInstallsCallbacks() {\n        try {\n            GreetingService proxy = createGreetingService(\"generated greeting\");\n\n            assertThat(proxy.greet()).isEqualTo(\"generated greeting\");\n            assertThat(Enhancer.isEnhanced(proxy.getClass())).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static GreetingService createGreetingService(String greeting) {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(GreetingService.class);\n        enhancer.setCallback((FixedValue) () -> greeting);\n        return (GreetingService) enhancer.create();\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface GreetingService {\n        String greet();\n    }\n}\n"}
