nternal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MethodDelegateTest {\n\n    @Test\n    void comparesDelegatesByTargetIdentityAndMethodSignature() {\n        Object target = new Object();\n        Object otherTarget = new Object();\n\n        try {\n            InspectableMethodDelegate first = new InspectableMethodDelegate(target, \"format(Ljava/lang/String;)Ljava/lang/String;\");\n            InspectableMethodDelegate same = new InspectableMethodDelegate(target, \"format(Ljava/lang/String;)Ljava/lang/String;\");\n            InspectableMethodDelegate differentTarget = new InspectableMethodDelegate(\n                    otherTarget,\n                    \"format(Ljava/lang/String;)Ljava/lang/String;\"\n            );\n            InspectableMethodDelegate differentMethod = new InspectableMethodDelegate(target, \"format(I)Ljava/lang/String;\");\n\n            assertThat(first.getTarget()).isSameAs(target);\n            assertThat(first).isEqualTo(same);\n            assertThat(first.hashCode()).isEqualTo(same.hashCode());\n            assertThat(first).isNotEqualTo(differentTarget);\n            assertThat(first).isNotEqualTo(differentMethod);\n\n            MethodDelegate rebound = first.newInstance(otherTarget);\n            assertThat(rebound.getTarget()).isSameAs(otherTarget);\n            assertThat(rebound).isEqualTo(differentTarget);\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    private static final class InspectableMethodDelegate extends MethodDelegate {\n        InspectableMethodDelegate(Object target, String eqMethod) {\n            this.target = target;\n            this.eqMethod = eqMethod;\n        }\n\n        @Override\n        public MethodDelegate newInstance(Object target) {\n            return new InspectableMethodDelegate(target, eqMethod);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 823, "output": 1872, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 22663, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778099830091, "responseId": "resp_0802ed8f142e61a40169fba6774a7c8192aec936a32d5d14b3"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ISsGcVgSVDI4B9K0AL6RBIlm|fc_0802ed8f142e61a40169fba68935388192b1c0ecbd747d5a76", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2645 bytes to tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/MethodDelegateTest.java"}], "isError": false, "timestamp": 1778099852840}]}
