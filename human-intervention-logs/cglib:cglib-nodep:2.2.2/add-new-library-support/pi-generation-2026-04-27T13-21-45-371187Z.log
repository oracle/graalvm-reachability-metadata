  diff --git c/tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/InterfaceMakerTest.java i/tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/InterfaceMakerTest.java
  new file mode 100644
  index 0000000000..616182c724
  --- /dev/null
  +++ i/tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/InterfaceMakerTest.java
  @@ -0,0 +1,55 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package cglib.cglib_nodep;
  +
  +import java.io.IOException;
  +import java.lang.reflect.Method;
  +import java.util.Arrays;
  +import java.util.List;
  +import java.util.stream.Collectors;
  +
  +import net.sf.cglib.proxy.InterfaceMaker;
  +import org.junit.jupiter.api.Test;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +public class InterfaceMakerTest {
  +    @Test
  +    void createsInterfaceFromPublicClassMethods() throws Exception {
  +        InterfaceMaker maker = new InterfaceMaker();
  +        maker.add(ExampleOperations.class);
  +
  +        Class<?> generatedInterface = maker.create();
  +
  +        List<Method> generatedMethods = Arrays.stream(generatedInterface.getMethods())
  +                .filter(method -> method.getDeclaringClass().equals(generatedInterface))
  +                .collect(Collectors.toList());
  +
  +        assertThat(generatedInterface.isInterface()).isTrue();
  +        assertThat(generatedMethods)
  +                .extracting(Method::getName)
