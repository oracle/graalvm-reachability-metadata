  package cglib.cglib_nodep;
  
  import java.lang.reflect.Method;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import net.sf.cglib.proxy.InvocationHandler;
  import net.sf.cglib.proxy.Proxy;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProxyTest {
      @Test
      void createsInterfaceProxyAndDispatchesMapMethodsThroughHandler() {
          MapBackedInvocationHandler handler = new MapBackedInvocationHandler();
  
          Map<?, ?> proxy = (Map<?, ?>) Proxy.newProxyInstance(
                  ProxyTest.class.getClassLoader(),
                  new Class[] { Map.class },
                  handler);
  
          assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();
          assertThat(Proxy.getInvocationHandler(proxy)).isSameAs(handler);
  
          @SuppressWarnings("unchecked")
          Map<String, String> typedProxy = (Map<String, String>) proxy;
          assertThat(typedProxy.put("language", "Java")).isNull();
          assertThat(typedProxy.get("language")).isEqualTo("Java");
          assertThat(typedProxy.containsKey("language")).isTrue();
          assertThat(typedProxy.remove("language")).isEqualTo("Java");
          assertThat(typedProxy.isEmpty()).isTrue();
      }
  
      private static final class MapBackedInvocationHandler implements InvocationHandler {
          private final Map<Object, Object> entries = new LinkedHashMap<>();
  
          @Override
          public Object invoke(Object proxy, Method method, Object[] args) {
              String methodName = method.getName();
              if ("put".equals(methodName)) {
                  return entries.put(args[0], args[1]);
              }
              if ("get".equals(methodName)) {
                  return entries.get(args[0]);
              }
              if ("containsKey".equals(methodName)) {
                  return entries.containsKey(args[0]);
              }
              if ("remove".equals(methodName)) {
                  return entries.remove(args[0]);
              }
              if ("isEmpty".equals(methodName)) {
                  return entries.isEmpty();
              }
              if ("equals".equals(methodName)) {
                  return proxy == args[0];
              }
              if ("hashCode".equals(methodName)) {
                  return System.identityHashCode(proxy);
              }
              if ("toString".equals(methodName)) {
                  return "MapBackedProxy" + entries;
              }
              throw new UnsupportedOperationException(methodName);
          }
      }
  }
