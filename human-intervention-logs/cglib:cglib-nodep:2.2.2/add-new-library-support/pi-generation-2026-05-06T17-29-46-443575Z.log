[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.core.CodeGenerationException;\nimport net.sf.cglib.proxy.InvocationHandler;\nimport net.sf.cglib.proxy.Proxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProxyTest {\n\n    @Test\n    void createsProxyInstanceWithInvocationHandlerConstructor() {\n        InvocationHandler handler = new DispatchingInvocationHandler();\n\n        try {\n            Object proxy = Proxy.newProxyInstance(\n                    ProxyTest.class.getClassLoader(),\n                    new Class<?>[] {GreetingService.class, Adder.class},\n                    handler\n            );\n\n            assertThat(proxy).isInstanceOf(GreetingService.class);\n            assertThat(proxy).isInstanceOf(Adder.class);\n            assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();\n            assertThat(Proxy.getInvocationHandler(proxy)).isSameAs(handler);\n            assertThat(((GreetingService) proxy).greet(\"GraalVM\")).isEqualTo(\"Hello, GraalVM\");\n            assertThat(((Adder) proxy).add(19, 23)).isEqualTo(42);\n            assertThat(proxy.toString()).isEqualTo(\"cglib proxy\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface GreetingService {\n        String greet(String name);\n    }\n\n    public interface Adder {\n        int add(int left, int right);\n    }\n\n    private static final class DispatchingInvocationHandler implements InvocationHandler {\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] arguments) {\n            String methodName = method.getName();\n            if (\"greet\".equals(methodName)) {\n                return \"Hello, \" + arguments[0];\n            }\n            if (\"add\".equals(methodName)) {\n                return (Integer) arguments[0] + (Integer) arguments[1];\n            }\n            if (\"toString\".equals(methodName)) {\n                return \"cglib proxy\";\n            }\n            throw new AssertionError(\"Unexpected method invocation: \" + method);\n        }\n    }\n}\n"}
