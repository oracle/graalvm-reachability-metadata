    } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface GreetingService {\n        String greet(String name);\n    }\n\n    public interface Adder {\n        int add(int left, int right);\n    }\n\n    private static final class DispatchingInvocationHandler implements InvocationHandler {\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] arguments) {\n            String methodName = method.getName();\n            if (\"greet\".equals(methodName)) {\n                return \"Hello, \" + arguments[0];\n            }\n            if (\"add\".equals(methodName)) {\n                return (Integer) arguments[0] + (Integer) arguments[1];\n            }\n            if (\"toString\".equals(methodName)) {\n                return \"cglib proxy\";\n            }\n            throw new AssertionError(\"Unexpected method invocation: \" + method);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 952, "output": 1184, "cacheRead": 14336, "cacheWrite": 0, "totalTokens": 16472, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778088550912, "responseId": "resp_0e7f454e05ab282b0169fb7a6766f48193a1a1b242c365f2b8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_SKk2JRTLhO1KSPLYalnlxxdp|fc_0e7f454e05ab282b0169fb7a6e03b48193a96d3bb2bb99c7b8", "