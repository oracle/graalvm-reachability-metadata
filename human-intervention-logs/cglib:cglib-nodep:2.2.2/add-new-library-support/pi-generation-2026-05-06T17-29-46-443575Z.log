  package cglib.cglib_nodep;
  
  import java.io.ByteArrayInputStream;
  import java.io.InputStream;
  
  import net.sf.cglib.asm.ClassWriter;
  import net.sf.cglib.asm.MethodVisitor;
  import net.sf.cglib.asm.Opcodes;
  import net.sf.cglib.transform.AbstractClassLoader;
  import net.sf.cglib.transform.ClassFilter;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AbstractClassLoaderTest {
  
      @Test
      void delegatesRejectedClassesToParentLoader() throws Exception {
          TransformingLoader loader = new TransformingLoader(
                  getClass().getClassLoader(),
                  getClass().getClassLoader(),
                  className -> false
          );
  
          Class<?> loadedClass = loader.loadClass(String.class.getName());
  
          assertThat(loadedClass).isSameAs(String.class);
      }
  
      @Test
      void loadsAcceptedClassBytesFromClassPathLoaderAndCachesDefinedClass() throws Exception {
          String className = "cglib.cglib_nodep.AbstractClassLoaderGenerated";
          ByteArrayClassPath classPath = new ByteArrayClassPath(
                  getClass().getClassLoader(),
                  className,
                  createMinimalClassBytes(className)
          );
          TransformingLoader loader = new TransformingLoader(
                  getClass().getClassLoader(),
                  classPath,
                  className::equals
          );
  
          try {
              Class<?> loadedClass = loader.loadClass(className);
              Class<?> loadedAgain = loader.loadClass(className);
  
              assertThat(loadedClass.getName()).isEqualTo(className);
              assertThat(loadedClass.getClassLoader()).isSameAs(loader);
              assertThat(loadedAgain).isSameAs(loadedClass);
              assertThat(classPath.requestedResources()).isEqualTo(1);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static byte[] createMinimalClassBytes(String className) {
          String internalName = className.replace('.', '/');
          ClassWriter writer = new ClassWriter(0);
          writer.visit(
                  Opcodes.V1_7,
                  Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,
                  internalName,
                  null,
                  "java/lang/Object",
                  null
          );
  
          MethodVisitor constructor = writer.visitMethod(Opcodes.ACC_PUBLIC, "<init>", "()V", null, null);
          constructor.visitCode();
          constructor.visitVarInsn(Opcodes.ALOAD, 0);
          constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, "java/lang/Object", "<init>", "()V");
          constructor.visitInsn(Opcodes.RETURN);
          constructor.visitMaxs(1, 1);
          constructor.visitEnd();
          writer.visitEnd();
          return writer.toByteArray();
      }
  
      private static final class TransformingLoader extends AbstractClassLoader {
          private TransformingLoader(ClassLoader parent, ClassLoader classPath, ClassFilter filter) {
              super(parent, classPath, filter);
          }
      }
  
      private static final class ByteArrayClassPath extends ClassLoader {
          private final String resourceName;
          private final byte[] classBytes;
          private int requestedResources;
  
          private ByteArrayClassPath(ClassLoader parent, String className, byte[] classBytes) {
              super(parent);
              this.resourceName = className.replace('.', '/') + ".class";
              this.classBytes = classBytes.clone();
          }
  
          @Override
          public InputStream getResourceAsStream(String name) {
              if (!resourceName.equals(name)) {
                  return super.getResourceAsStream(name);
              }
              requestedResources++;
              return new ByteArrayInputStream(classBytes);
          }
  
          private int requestedResources() {
              return requestedResources;
          }
      }
  }
