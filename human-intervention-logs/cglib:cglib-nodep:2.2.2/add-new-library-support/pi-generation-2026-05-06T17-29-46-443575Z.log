n        PrivateValue value = (PrivateValue) ReflectUtils.newInstance(\n                PrivateValue.class,\n                new Class<?>[] {String.class},\n                new Object[] {\"created\"}\n        );\n\n        assertThat(value.text()).isEqualTo(\"created\");\n    }\n\n    @Test\n    void findsDeclaredMethodsThroughHierarchyAndCollectsMethods() throws Exception {\n        Method inheritedMethod = ReflectUtils.findDeclaredMethod(\n                ChildValue.class,\n                \"inheritedSecret\",\n                new Class<?>[0]\n        );\n        assertThat(inheritedMethod.getDeclaringClass()).isEqualTo(ParentValue.class);\n\n        List<Method> methods = ReflectUtils.addAllMethods(ChildValue.class, new ArrayList<Method>());\n        assertThat(methods)\n                .extracting(Method::getName)\n                .contains(\"childMethod\", \"inheritedSecret\");\n    }\n\n    @Test\n    void findsSingleInterfaceFactoryMethod() {\n        Method method = ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);\n\n        assertThat(method.getName()).isEqualTo(\"newInstance\");\n        assertThat(method.getParameterTypes()).isEmpty();\n    }\n\n    @Test\n    void definesClassBytesWithRequestedLoader() throws Exception {\n        String className = \"cglib.cglib_nodep.GeneratedByReflectUtils\";\n        byte[] classBytes = createMinimalClassBytes(className);\n        ChildOnlyClassLoader loader = new ChildOnlyClassLoader(ReflectUtilsTest.class.getClassLoader());\n\n        try {\n            Class<?> definedClass = ReflectUtils.defineClass(className, classBytes, loader);\n\n            assertThat(definedClass.getName()).isEqualTo(className);\n            assertThat(definedClass.getClassLoader()).isSameAs(loader);\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause();\n            if (!(cause instanceof Error error) || !NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static byte[] createMinimalClassBytes(String className) {\n        String internalName = className.replace('.', '/');\n        ClassWriter writer = new ClassWriter(0);\n        writer.visit(\n                Opcodes.V1_7,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                internalName,\n                null,\n                \"java/lang/Object\",\n                null\n        );\n\n        MethodVisitor constructor = writer.visitMethod(Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    public interface SingleMethodFactory {\n        Object newInstance();\n    }\n\n    public static class ParentValue {\n        private String inheritedSecret() {\n            return \"parent\";\n        }\n    }\n\n    public static class ChildValue extends ParentValue {\n        public String childMethod() {\n            return \"child\";\n        }\n    }\n\n    public static class PrivateValue {\n        private final String text;\n\n        private PrivateValue(String text) {\n            this.text = text;\n        }\n\n        public String text() {\n            return text;\n        }\n    }\n\n    private static final class ChildOnlyClassLoader extends ClassLoader {\n        private ChildOnlyClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778088542987}, {"role": "toolResult", "toolCallId": "call_YEXMtm9iB9Rdt58iF1mxL2XF|fc_0e7f454e05ab282b0169fb7a5ea0bc8193bb4d9403525856ec", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\n\nimport net.sf.cglib.asm.ClassWriter;\nimport net.sf.cglib.asm.MethodVisitor;\nimport net.sf.cglib.asm.Opcodes;\nimport net.sf.cglib.transform.AbstractClassLoader;\nimport net.sf.cglib.transform.ClassFilter;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AbstractClassLoaderTest {\n\n    @Test\n    void delegatesRejectedClassesToParentLoader() throws Exception {\n        TransformingLoader loader = new TransformingLoader(\n                getClass().getClassLoader(),\n                getClass().getClassLoader(),\n                className -> false\n        );\n\n        Class<?> loadedClass = loader.loadClass(String.class.getName());\n\n        assertThat(loadedClass).isSameAs(String.class);\n    }\n\n    @Test\n    void loadsAcceptedClassBytesFromClassPathLoaderAndCachesDefinedClass() throws Exception {\n        String className = \"cglib.cglib_nodep.AbstractClassLoaderGenerated\";\n        ByteArrayClassPath classPath = new ByteArrayClassPath(\n                getClass().getClassLoader(),\n                className,\n                createMinimalClassBytes(className)\n        );\n        TransformingLoader loader = new TransformingLoader(\n                getClass().getClassLoader(),\n                classPath,\n                className::equals\n        );\n\n        try {\n            Class<?> loadedClass = loader.loadClass(className);\n            Class<?> loadedAgain = loader.loadClass(className);\n\n            assertThat(loadedClass.getName()).isEqualTo(className);\n            assertThat(loadedClass.getClassLoader()).isSameAs(loader);\n            assertThat(loadedAgain).isSameAs(loadedClass);\n            assertThat(classPath.requestedResources()).isEqualTo(1);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static byte[] createMinimalClassBytes(String className) {\n        String internalName = className.replace('.', '/');\n        ClassWriter writer = new ClassWriter(0);\n        writer.visit(\n                Opcodes.V1_7,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                internalName,\n                null,\n                \"java/lang/Object\",\n                null\n        );\n\n        MethodVisitor constructor = writer.visitMethod(Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static final class TransformingLoader extends AbstractClassLoader {\n        private TransformingLoader(ClassLoader parent, ClassLoader classPath, ClassFilter filter) {\n            super(parent, classPath, filter);\n        }\n    }\n\n    private static final class ByteArrayClassPath extends ClassLoader {\n        private final String resourceName;\n        private final byte[] classBytes;\n        private int requestedResources;\n\n        private ByteArrayClassPath(ClassLoader parent, String className, byte[] classBytes) {\n            super(parent);\n            this.resourceName = className.replace('.', '/') + \".class\";\n            this.classBytes = classBytes.clone();\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (!resourceName.equals(name)) {\n                return super.getResourceAsStream(name);\n            }\n            requestedResources++;\n            return new ByteArrayInputStream(classBytes);\n        }\n\n        private int requestedResources() {\n            return requestedResources;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778088542987}]}
