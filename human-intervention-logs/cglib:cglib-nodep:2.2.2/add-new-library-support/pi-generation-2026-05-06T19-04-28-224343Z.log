  package cglib.cglib_nodep;
  
  import java.beans.IntrospectionException;
  import java.beans.Introspector;
  import java.beans.PropertyDescriptor;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import net.sf.cglib.beans.BeanGenerator;
  import net.sf.cglib.core.CodeGenerationException;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatIllegalArgumentException;
  
  public class BeanGeneratorTest {
  
      @Test
      void createsGeneratedBeanWithConfiguredProperties() throws Exception {
          try {
              BeanGenerator generator = new BeanGenerator();
              generator.setSuperclass(BaseBean.class);
              generator.addProperty("score", Integer.TYPE);
  
              Map<String, Class<?>> additionalProperties = new LinkedHashMap<>();
              additionalProperties.put("nickname", String.class);
              BeanGenerator.addProperties(generator, additionalProperties);
  
              assertThatIllegalArgumentException()
                      .isThrownBy(() -> generator.addProperty("score", Integer.TYPE))
                      .withMessageContaining("Duplicate property name");
  
              Object bean = generator.create();
  
              assertThat(bean).isInstanceOf(BaseBean.class);
              assertThat(propertyTypes(bean.getClass()))
                      .containsEntry("name", String.class)
                      .containsEntry("score", Integer.TYPE)
                      .containsEntry("nickname", String.class);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static Map<String, Class<?>> propertyTypes(Class<?> beanClass)
              throws IntrospectionException {
          Map<String, Class<?>> propertyTypes = new LinkedHashMap<>();
          PropertyDescriptor[] descriptors = Introspector.getBeanInfo(beanClass)
                  .getPropertyDescriptors();
          for (PropertyDescriptor descriptor : descriptors) {
              if (!"class".equals(descriptor.getName())) {
                  propertyTypes.put(descriptor.getName(), descriptor.getPropertyType());
              }
          }
          return propertyTypes;
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public static class BaseBean {
          private String name;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
      }
  }
