2/src/test/java/cglib/cglib_nodep/BeanMapTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.beans.BeanMap;\nimport net.sf.cglib.core.CodeGenerationException;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BeanMapTest {\n\n    @Test\n    void createsMapBackedByBeanProperties() throws Exception {\n        runWithNativeImageUnsupportedFeatureCheck(() -> {\n            MappedBean bean = new MappedBean();\n            bean.setFoo(\"initial\");\n            bean.setQuud(7);\n\n            BeanMap beanMap = BeanMap.create(bean);\n\n            assertThat(beanMap.getBean()).isSameAs(bean);\n            assertThat(beanMap.keySet())\n                    .contains(\"foo\", \"bar\", \"baz\", \"quud\", \"quick\", \"quip\")\n                    .doesNotContain(\"class\");\n            assertThat(beanMap.get(\"foo\")).isEqualTo(\"initial\");\n            assertThat(beanMap.put(\"foo\", \"updated\")).isEqualTo(\"initial\");\n            assertThat(bean.getFoo()).isEqualTo(\"updated\");\n            assertThat(beanMap.put(\"quud\", 13)).isEqualTo(7);\n            assertThat(bean.getQuud()).isEqualTo(13);\n            assertThat(beanMap.get(\"bar\")).isEqualTo(\"read-only\");\n            assertThat(beanMap.get(\"baz\")).isNull();\n            assertThat(beanMap.containsKey(\"quick\")).isTrue();\n            assertThat(beanMap.containsValue(\"updated\")).isTrue();\n            assertThat(beanMap.getPropertyType(\"foo\")).isEqualTo(String.class);\n            assertThat(beanMap.getPropertyType(\"quud\")).isEqualTo(Integer.TYPE);\n            assertThat(beanMap.getPropertyType(\"missing\")).isNull();\n            assertThat(beanMap.entrySet()).hasSize(beanMap.size());\n            assertThat(beanMap.values()).contains(\"updated\", \"read-only\", 13, 42);\n            assertThat(beanMap.toString()).contains(\"foo=updated\");\n        });\n    }\n\n    @Test\n    void generatorCreatesReusableMapWithoutInitialBeanAndHonorsGetterRequirement()\n            throws Exception {\n        runWithNativeImageUnsupportedFeatureCheck(() -> {\n            BeanMap.Generator generator = new BeanMap.Generator();\n            generator.setBeanClass(MappedBean.class);\n            generator.setRequire(BeanMap.REQUIRE_GETTER);\n\n            BeanMap beanMap = generator.create();\n            MappedBean firstBean = new MappedBean();\n            MappedBean secondBean = new MappedBean();\n\n            assertThat(beanMap.getBean()).isNull();\n            assertThat(beanMap.keySet())\n                    .contains(\"foo\", \"bar\", \"quud\", \"quick\")\n                    .doesNotContain(\"baz\", \"quip\");\n            assertThat(beanMap.put(firstBean, \"foo\", \"first\")).isNull();\n            assertThat(beanMap.get(firstBean, \"foo\")).isEqualTo(\"first\");\n            assertThat(firstBean.getFoo()).isEqualTo(\"first\");\n\n            BeanMap reboundMap = beanMap.newInstance(secondBean);\n            reboundMap.put(\"foo\", \"second\");\n            assertThat(secondBean.getFoo()).isEqualTo(\"second\");\n            assertThat(beanMap.get(firstBean, \"foo\")).isEqualTo(\"first\");\n        });\n    }\n\n    private static void runWithNativeImageUnsupportedFeatureCheck(ThrowingRunnable runnable)\n            throws Exception {\n        try {\n            runnable.run();\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    public static class MappedBean {\n        private String foo;\n        private String baz;\n        private int quud;\n        private int quip;\n\n        public String getFoo() {\n            return foo;\n        }\n\n        public void setFoo(String foo) {\n            this.foo = foo;\n        }\n\n        public String getBar() {\n            return \"read-only\";\n        }\n\n        public void setBaz(String baz) {\n            this.baz = baz;\n        }\n\n        public int getQuud() {\n            return quud;\n        }\n\n        public void setQuud(int quud) {\n            this.quud = quud;\n        }\n\n        public int getQuick() {\n            return 42;\n        }\n\n        public void setQuip(int quip) {\n            this.quip = quip;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1561, "output": 2356, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 36685, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778094220478, "responseId": "resp_06103cc0d4d340690169fb908df5e8819694f67da80ae2baea"}}
