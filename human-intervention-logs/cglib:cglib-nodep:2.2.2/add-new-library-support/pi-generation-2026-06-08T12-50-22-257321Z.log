ult).toUpperCase(Locale.ROOT);\n            }\n            return result;\n        });\n\n        try {\n            GreetingService service = (GreetingService) enhancer.create();\n\n            assertThat(service).isInstanceOf(Factory.class);\n            assertThat(service.greet(\"cglib\")).isEqualTo(\"HELLO CGLIB\");\n        } catch (RuntimeException exception) {\n            Error unsupportedFeatureError = findUnsupportedFeatureError(exception);\n            if (unsupportedFeatureError == null) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 4351, "output": 1072, "cacheRead": 35840, "cacheWrite": 0, "totalTokens": 41263, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780923181810, "responseId": "resp_076e7844004622a7016a26bb2e88808190a4618707472021d6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_XCsJAgpiQ4omjYMus9hskv8p|fc_076e7844004622a7016a26bb3e1c008190a7c58636ce088e5e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2206 bytes to tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/EnhancerTest.java"}], "isError": false, "timestamp": 1