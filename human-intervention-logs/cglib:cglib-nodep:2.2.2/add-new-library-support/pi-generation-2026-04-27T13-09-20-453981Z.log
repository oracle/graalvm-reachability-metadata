"path": "tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/EnhancerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Callback;\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatCode;\n\npublic class EnhancerTest {\n    @Test\n    void createsEnhancedSubclassAndDispatchesThroughMethodInterceptor() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(GreetingService.class);\n        enhancer.setCallback(new PrefixingInterceptor(\"proxied\"));\n\n        GreetingService service = (GreetingService) enhancer.create();\n\n        assertThat(Enhancer.isEnhanced(service.getClass())).isTrue();\n        assertThat(service.greet(\"Ada\")).isEqualTo(\"proxied Ada\");\n        assertThat(service.describe()).isEqualTo(\"service\");\n    }\n\n    @Test\n    void createsEnhancedInstanceWithConstructorArguments() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(ConstructedGreetingService.class);\n        enhancer.setCallback(new PrefixingInterceptor(\"native\"));\n\n        ConstructedGreetingService service = (ConstructedGreetingService) enhancer.create(\n                new Class[] { String.class },\n                new Object[] { \"original\" });\n\n        assertThat(service.greet(\"Bob\")).isEqualTo(\"native Bob\");\n        assertThat(service.describe()).isEqualTo(\"original\");\n    }\n\n    @Test\n    void createsReusableEnhancedClassAndRegistersStaticCallbacks() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(GreetingService.class);\n        enhancer.setCallbackType(MethodInterceptor.class);\n\n        Class<?> enhancedType = enhancer.createClass();\n\n        assertThat(Enhancer.isEnhanced(enhancedType)).isTrue();\n        assertThatCode(() -> Enhancer.registerStaticCallbacks(\n                enhancedType,\n                new Callback[] { new PrefixingInterceptor(\"static\") })).doesNotThrowAnyException();\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n\n        public String describe() {\n            return \"service\";\n        }\n    }\n\n    public static class ConstructedGreetingService {\n        private final String description;\n\n        public ConstructedGreetingService(String description) {\n            this.description = description;\n        }\n\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n\n        public String describe() {\n            return description;\n        }\n    }\n\n    private static final class PrefixingInterceptor implements MethodInterceptor {\n        private final String prefix;\n\n        private PrefixingInterceptor(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public Object intercept(Object object, Method method, Object[] arguments, MethodProxy methodProxy) throws Throwable {\n            if (\"greet\".equals(method.getName())) {\n                return prefix + \" \" + arguments[0];\n            }\n            return methodProxy.invokeSuper(object, arguments);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2614, "output": 1776, "cacheRead": 46592, "cacheWrite": 0, "totalTokens": 50982, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777295284047, "responseId": "resp_006f35700f21a5690169ef5fb4a