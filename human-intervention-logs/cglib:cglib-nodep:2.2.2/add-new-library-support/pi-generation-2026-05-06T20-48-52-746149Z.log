  package cglib.cglib_nodep;
  
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.CodeSource;
  
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.reflect.MethodDelegate;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodDelegateTest {
  
      @Test
      void initializesMethodDelegateInIsolatedClassLoader() throws Exception {
          CodeSource codeSource = MethodDelegate.class.getProtectionDomain().getCodeSource();
          URL libraryLocation = codeSource.getLocation();
  
          try (URLClassLoader loader = new URLClassLoader(new URL[] {libraryLocation}, null)) {
              Class<?> loadedClass = Class.forName("net.sf.cglib.reflect.MethodDelegate", true, loader);
  
              assertThat(loadedClass.getName()).isEqualTo("net.sf.cglib.reflect.MethodDelegate");
              assertThat(loadedClass.getClassLoader()).isSameAs(loader);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          }
      }
  
      @Test
      void createsDelegateForStaticMethodWithMatchingInterfaceSignature() {
          try {
              WordLength delegate = (WordLength) MethodDelegate.createStatic(
                      StaticWords.class,
                      "lengthOf",
                      WordLength.class
              );
  
              assertThat(delegate.length("cglib")).isEqualTo(5);
              assertThat(((MethodDelegate) delegate).getTarget()).isNull();
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      @Test
      void comparesDelegatesByTargetIdentityAndMethodSignature() {
          Object target = new Object();
          Object otherTarget = new Object();
          String stringMethod = "format(Ljava/lang/String;)Ljava/lang/String;";
  
          try {
              InspectableMethodDelegate first = new InspectableMethodDelegate(target, stringMethod);
              InspectableMethodDelegate same = new InspectableMethodDelegate(target, stringMethod);
              InspectableMethodDelegate differentTarget = new InspectableMethodDelegate(otherTarget, stringMethod);
              InspectableMethodDelegate differentMethod = new InspectableMethodDelegate(
                      target,
                      "format(I)Ljava/lang/String;"
              );
  
              assertThat(first.getTarget()).isSameAs(target);
              assertThat(first).isEqualTo(same);
              assertThat(first.hashCode()).isEqualTo(same.hashCode());
              assertThat(first).isNotEqualTo(differentTarget);
              assertThat(first).isNotEqualTo(differentMethod);
  
              MethodDelegate rebound = first.newInstance(otherTarget);
              assertThat(rebound.getTarget()).isSameAs(otherTarget);
              assertThat(rebound).isEqualTo(differentTarget);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public interface WordLength {
          int length(String value);
      }
  
      public static final class StaticWords {
          private StaticWords() {
          }
  
          public static int lengthOf(String value) {
              return value.length();
          }
      }
  
      private static final class InspectableMethodDelegate extends MethodDelegate {
          InspectableMethodDelegate(Object target, String eqMethod) {
              this.target = target;
              this.eqMethod = eqMethod;
          }
  
          @Override
          public MethodDelegate newInstance(Object target) {
              return new InspectableMethodDelegate(target, eqMethod);
          }
      }
  }
