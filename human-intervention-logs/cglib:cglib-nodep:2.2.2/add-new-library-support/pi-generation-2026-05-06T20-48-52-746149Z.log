[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/MulticastDelegateTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport net.sf.cglib.core.CodeGenerationException;\nimport net.sf.cglib.reflect.MulticastDelegate;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MulticastDelegateTest {\n\n    @Test\n    void initializesGeneratorAndCreatesMulticastDelegateForSingleMethodInterface() {\n        try {\n            MulticastDelegate.Generator generator = new MulticastDelegate.Generator();\n            generator.setInterface(Listener.class);\n\n            MulticastDelegate delegate = generator.create();\n            RecordingListener first = new RecordingListener();\n            RecordingListener second = new RecordingListener();\n            Listener multicaster = (Listener) delegate.add(first).add(second);\n\n            multicaster.onMessage(\"cglib\");\n\n            assertThat(first.messages()).containsExactly(\"cglib\");\n            assertThat(second.messages()).containsExactly(\"cglib\");\n            assertThat(((MulticastDelegate) multicaster).getTargets()).containsExactly(first, second);\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface Listener {\n        void onMessage(String message);\n    }\n\n    public static final class RecordingListener implements Listener {\n        private final List<String> messages = new ArrayList<>();\n\n        @Override\n        public void onMessage(String message) {\n            messages.add(message);\n        }\n\n        List<String> messages() {\n            return messages;\n        }\n    }\n}\n"}
