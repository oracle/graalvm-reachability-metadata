  package cglib.cglib_nodep;
  
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.reflect.ConstructorDelegate;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConstructorDelegateTest {
  
      @Test
      void createsDelegateForMatchingConstructorSignature() {
          try {
              MessageFactory factory = (MessageFactory) ConstructorDelegate.create(
                      Message.class,
                      MessageFactory.class
              );
  
              Message message = factory.newInstance("hello", 7);
  
              assertThat(message.text()).isEqualTo("hello");
              assertThat(message.priority()).isEqualTo(7);
              assertThat(factory).isInstanceOf(ConstructorDelegate.class);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public interface MessageFactory {
          Message newInstance(String text, int priority);
      }
  
      public static final class Message {
          private final String text;
          private final int priority;
  
          public Message(String text, int priority) {
              this.text = text;
              this.priority = priority;
          }
  
          String text() {
              return text;
          }
  
          int priority() {
              return priority;
          }
      }
  }
