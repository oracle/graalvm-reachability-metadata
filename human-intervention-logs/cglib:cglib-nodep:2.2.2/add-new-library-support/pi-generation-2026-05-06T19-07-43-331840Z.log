nerator.create();\n            MappedBean firstBean = new MappedBean();\n            MappedBean secondBean = new MappedBean();\n\n            assertThat(beanMap.getBean()).isNull();\n            assertThat(beanMap.keySet())\n                    .contains(\"foo\", \"bar\", \"quud\", \"quick\")\n                    .doesNotContain(\"baz\", \"quip\");\n            assertThat(beanMap.put(firstBean, \"foo\", \"first\")).isNull();\n            assertThat(beanMap.get(firstBean, \"foo\")).isEqualTo(\"first\");\n            assertThat(firstBean.getFoo()).isEqualTo(\"first\");\n\n            BeanMap reboundMap = beanMap.newInstance(secondBean);\n            reboundMap.put(\"foo\", \"second\");\n            assertThat(secondBean.getFoo()).isEqualTo(\"second\");\n            assertThat(beanMap.get(firstBean, \"foo\")).isEqualTo(\"first\");\n        });\n    }\n\n    private static void runWithNativeImageUnsupportedFeatureCheck(ThrowingRunnable runnable)\n            throws Exception {\n        try {\n            runnable.run();\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    public static class MappedBean {\n        private String foo;\n        private String baz;\n        private int quud;\n        private int quip;\n\n        public String getFoo() {\n            return foo;\n        }\n\n        public void setFoo(String foo) {\n            this.foo = foo;\n        }\n\n        public String getBar() {\n            return \"read-only\";\n        }\n\n        public void setBaz(String baz) {\n            this.baz = baz;\n        }\n\n        public int getQuud() {\n            return quud;\n        }\n\n        public void setQuud(int quud) {\n            this.quud = quud;\n        }\n\n        public int getQuick() {\n            return 42;\n        }\n\n        public void setQuip(int quip) {\n            this.quip = quip;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778094416076}]}
