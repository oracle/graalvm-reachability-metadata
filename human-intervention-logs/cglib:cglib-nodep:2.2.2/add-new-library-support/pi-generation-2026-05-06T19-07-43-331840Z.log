s BulkBeanTest {\n    private static final String[] GETTERS = {\n            \"getName\",\n            \"getScore\",\n            \"isEnabled\"\n    };\n\n    private static final String[] SETTERS = {\n            \"setName\",\n            \"setScore\",\n            \"setEnabled\"\n    };\n\n    private static final Class<?>[] TYPES = {\n            String.class,\n            Integer.TYPE,\n            Boolean.TYPE\n    };\n\n    @Test\n    void createsBulkAccessorForBeanProperties() throws Exception {\n        runWithNativeImageUnsupportedFeatureCheck(() -> {\n            BulkBean bulkBean = BulkBean.create(SampleBean.class, GETTERS, SETTERS, TYPES);\n            SampleBean bean = new SampleBean();\n            Object[] propertyValues = {\n                    \"Ada\",\n                    Integer.valueOf(42),\n                    Boolean.TRUE\n            };\n\n            bulkBean.setPropertyValues(bean, propertyValues);\n\n            assertThat(bean.getName()).isEqualTo(\"Ada\");\n            assertThat(bean.getScore()).isEqualTo(42);\n            assertThat(bean.isEnabled()).isTrue();\n            assertThat(bulkBean.getGetters()).containsExactly(GETTERS);\n            assertThat(bulkBean.getSetters()).containsExactly(SETTERS);\n            assertThat(bulkBean.getPropertyTypes()).containsExactly(TYPES);\n            assertThat(bulkBean.getPropertyValues(bean)).containsExactly(propertyValues);\n\n            Object[] reusableValues = new Object[TYPES.length];\n            bulkBean.getPropertyValues(bean, reusableValues);\n            assertThat(reusableValues).containsExactly(propertyValues);\n        });\n    }\n\n    private static void runWithNativeImageUnsupportedFeatureCheck(ThrowingRunnable runnable)\n            throws Exception {\n        try {\n            runnable.run();\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    public static class SampleBean {\n        private String name;\n        private int score;\n        private boolean enabled;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getScore() {\n            return score;\n        }\n\n        public void setScore(int score) {\n            this.score = score;\n        }\n\n        public boolean isEnabled() {\n            return enabled;\n        }\n\n        public void setEnabled(boolean enabled) {\n            this.enabled = enabled;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2257, "output": 1769, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 32186, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778094431901, "responseId": "resp_04b96e3b35f0c8390169fb916093988194a43a202b190b2212"}}
