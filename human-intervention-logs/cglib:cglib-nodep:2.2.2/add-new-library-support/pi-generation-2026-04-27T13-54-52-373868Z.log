C0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.beans.BeanGenerator;\nimport net.sf.cglib.beans.BeanMap;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BeanGeneratorTest {\n    @Test\n    void createsBeanClassForConfiguredProperties() {\n        BeanGenerator generator = new BeanGenerator();\n        generator.addProperty(\"name\", String.class);\n        generator.addProperty(\"score\", int.class);\n\n        Object generatedType = generator.createClass();\n\n        assertThat(generatedType).isInstanceOf(Class.class);\n        assertThat((Class<?>) generatedType).isNotFinal();\n    }\n\n    @Test\n    void createsBeanInstanceWithReadableAndWritableGeneratedProperties() {\n        BeanGenerator generator = new BeanGenerator();\n        generator.addProperty(\"name\", String.class);\n        generator.addProperty(\"score\", int.class);\n        generator.addProperty(\"active\", boolean.class);\n\n        Object bean = generator.create();\n        BeanMap properties = BeanMap.create(bean);\n        properties.put(\"name\", \"Ada\");\n        properties.put(\"score\", 42);\n        properties.put(\"active\", true);\n\n        assertThat(properties.keySet()).contains(\"name\", \"score\", \"active\");\n        assertThat(properties.get(\"name\")).isEqualTo(\"Ada\");\n        assertThat(properties.get(\"score\")).isEqualTo(42);\n        assertThat(properties.get(\"active\")).isEqualTo(true);\n    }\n\n    @Test\n    void addsPropertiesFromExistingBeanTypeAndExtendsSuperclass() {\n        BeanGenerator generator = new BeanGenerator();\n        generator.setSuperclass(BaseRecord.class);\n        BeanGenerator.addProperties(generator, TemplateProperties.class);\n\n        Object bean = generator.create();\n        BeanMap properties = BeanMap.create(bean);\n        properties.put(\"code\", \"generated\");\n        properties.put(\"enabled\", true);\n\n        assertThat(bean).isInstanceOf(BaseRecord.class);\n        BaseRecord record = (BaseRecord) bean;\n        record.setId(7L);\n        assertThat(record.getId()).isEqualTo(7L);\n        assertThat(properties.get(\"code\")).isEqualTo(\"generated\");\n        assertThat(properties.get(\"enabled\")).isEqualTo(true);\n    }\n\n    public static class BaseRecord {\n        private Long id;\n\n        public Long getId() {\n            return id;\n        }\n\n        public void setId(Long id) {\n            this.id = id;\n        }\n    }\n\n    public static class TemplateProperties {\n        private String code;\n        private boolean enabled;\n\n        public String getCode() {\n            return code;\n        }\n\n        public void setCode(String code) {\n            this.code = code;\n        }\n\n        public boolean isEnabled() {\n            return enabled;\n        }\n\n        public void setEnabled(boolean enabled) {\n            this.enabled = enabled;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 932, "output": 1301, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 23737, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777298045244, "responseId": "resp_0879ac1071ae547e0169ef6a7db6708195b046a29ef6684124"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_97Z6Oe6JFR883DYkpKhdpyP7|fc_0879ac1071ae547e0169ef6a8a6bd48195ae3f7dfd4734485f", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3024 bytes to tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/BeanGeneratorTest.java"}], "isError": false, "timestamp": 1777298060743}]}
