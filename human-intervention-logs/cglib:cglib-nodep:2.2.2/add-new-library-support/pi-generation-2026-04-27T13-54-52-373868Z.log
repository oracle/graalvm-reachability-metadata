  package cglib.cglib_nodep;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import net.sf.cglib.beans.BeanCopier;
  import net.sf.cglib.core.Converter;
  import org.junit.jupiter.api.MethodOrderer;
  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.TestMethodOrder;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @TestMethodOrder(MethodOrderer.OrderAnnotation.class)
  public class BeanCopierTest {
      @Test
      @Order(1)
      void initializesPublicGenerator() {
          BeanCopier.Generator generator = new BeanCopier.Generator();
  
          assertThat(generator).isNotNull();
      }
  
      @Test
      @Order(2)
      void createsCopierThroughConfiguredGenerator() {
          SourceAccount source = new SourceAccount();
          source.setName("Katherine");
          TargetAccount target = new TargetAccount();
          BeanCopier.Generator generator = new BeanCopier.Generator();
          generator.setSource(SourceAccount.class);
          generator.setTarget(TargetAccount.class);
          generator.setUseConverter(false);
  
          BeanCopier copier = generator.create();
          copier.copy(source, target, null);
  
          assertThat(target.getName()).isEqualTo("Katherine");
      }
  
      @Test
      @Order(3)
      void copiesCompatibleBeanPropertiesWithoutConverter() {
          SourceAccount source = new SourceAccount();
          source.setName("Ada");
          source.setAge(37);
          source.setActive(true);
          source.setScore(99);
          TargetAccount target = new TargetAccount();
          target.setName("unchanged");
          target.setScore(7);
  
          BeanCopier copier = BeanCopier.create(SourceAccount.class, TargetAccount.class, false);
          copier.copy(source, target, null);
  
          assertThat(target.getName()).isEqualTo("Ada");
          assertThat(target.getAge()).isEqualTo(37);
          assertThat(target.isActive()).isTrue();
          assertThat(target.getScore()).isEqualTo(99);
          assertThat(target.getTargetOnly()).isEqualTo("kept");
      }
  
      @Test
      @Order(4)
      void appliesConverterForMatchingPropertiesWithDifferentTypes() {
          SourceForm source = new SourceForm();
          source.setName("Grace");
          source.setAge("42");
          source.setEnabled("yes");
          TargetForm target = new TargetForm();
          RecordingConverter converter = new RecordingConverter();
  
          BeanCopier copier = BeanCopier.create(SourceForm.class, TargetForm.class, true);
          copier.copy(source, target, converter);
  
          assertThat(target.getName()).isEqualTo("Grace");
          assertThat(target.getAge()).isEqualTo(42);
          assertThat(target.isEnabled()).isTrue();
          assertThat(converter.getSetterNames()).contains("setName", "setAge", "setEnabled");
      }
  
      public static class SourceAccount {
          private String name;
          private int age;
          private boolean active;
          private Integer score;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getAge() {
              return age;
          }
  
          public void setAge(int age) {
              this.age = age;
          }
  
          public boolean isActive() {
              return active;
          }
  
          public void setActive(boolean active) {
              this.active = active;
          }
  
          public Integer getScore() {
              return score;
          }
  
          public void setScore(Integer score) {
              this.score = score;
          }
      }
  
      public static class TargetAccount {
          private String name;
          private int age;
          private boolean active;
          private Number score;
          private String targetOnly = "kept";
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getAge() {
              return age;
          }
  
          public void setAge(int age) {
              this.age = age;
          }
  
          public boolean isActive() {
              return active;
          }
  
          public void setActive(boolean active) {
              this.active = active;
          }
  
          public Number getScore() {
              return score;
          }
  
          public void setScore(Number score) {
              this.score = score;
          }
  
          public String getTargetOnly() {
              return targetOnly;
          }
  
          public void setTargetOnly(String targetOnly) {
              this.targetOnly = targetOnly;
          }
      }
  
      public static class SourceForm {
          private String name;
          private String age;
          private String enabled;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public String getAge() {
              return age;
          }
  
          public void setAge(String age) {
              this.age = age;
          }
  
          public String getEnabled() {
              return enabled;
          }
  
          public void setEnabled(String enabled) {
              this.enabled = enabled;
          }
      }
  
      public static class TargetForm {
          private String name;
          private int age;
          private boolean enabled;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getAge() {
              return age;
          }
  
          public void setAge(int age) {
              this.age = age;
          }
  
          public boolean isEnabled() {
              return enabled;
          }
  
          public void setEnabled(boolean enabled) {
              this.enabled = enabled;
          }
      }
  
      private static final class RecordingConverter implements Converter {
          private final List<String> setterNames = new ArrayList<>();
  
          @Override
          public Object convert(Object value, Class target, Object context) {
  
