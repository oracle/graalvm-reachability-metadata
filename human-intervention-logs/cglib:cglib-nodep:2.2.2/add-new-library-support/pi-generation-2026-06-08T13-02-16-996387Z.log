      }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface DynamicDelegate {\n        String describe(String value);\n\n        Object getTarget();\n    }\n\n    public static class DelegateImpl implements DynamicDelegate {\n        private final Object target;\n\n        public DelegateImpl(Object target) {\n            this.target = target;\n        }\n\n        @Override\n        public String describe(String value) {\n            return \"delegate:\" + value;\n        }\n\n        @Override\n        public Object getTarget() {\n            return target;\n        }\n    }\n\n    private static class GeneratedClassPathLoader extends ClassLoader {\n        GeneratedClassPathLoader() {\n            super(AddDelegateTransformerTest.class.getClassLoader());\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if ((GENERATED_INTERNAL_NAME + \".class\").equals(name)) {\n                return new ByteArrayInputStream(generatedClassBytecode());\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n}\n"}
