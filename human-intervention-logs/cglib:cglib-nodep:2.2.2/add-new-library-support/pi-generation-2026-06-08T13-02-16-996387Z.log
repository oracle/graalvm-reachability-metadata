  package cglib.cglib_nodep;
  
  import java.util.Locale;
  
  import net.sf.cglib.proxy.Enhancer;
  import net.sf.cglib.proxy.Factory;
  import net.sf.cglib.proxy.MethodInterceptor;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class EnhancerTest {
      @Test
      void createsEnhancedSubclassWithMethodInterceptor() {
          try {
              Enhancer enhancer = new Enhancer();
              enhancer.setUseCache(false);
              enhancer.setSuperclass(GreetingService.class);
              enhancer.setCallback((MethodInterceptor) (object, method, arguments, proxy) -> {
                  Object result = proxy.invokeSuper(object, arguments);
                  if (result instanceof String) {
                      return ((String) result).toUpperCase(Locale.ROOT);
                  }
                  return result;
              });
  
              GreetingService service = (GreetingService) enhancer.create();
  
              assertThat(service).isInstanceOf(Factory.class);
              assertThat(service.greet("cglib")).isEqualTo("HELLO CGLIB");
          } catch (RuntimeException exception) {
              if (findUnsupportedFeatureError(exception) == null) {
                  throw exception;
              }
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public static class GreetingService {
          public String greet(String name) {
              return "Hello " + name;
          }
      }
  }
