egateImplementation() throws Exception {\n        TransformingClassLoader loader = new TransformingClassLoader(\n                new GeneratedClassPathLoader(),\n                GENERATED_CLASS_NAME::equals,\n                AddDelegateTransformerTest::newDelegateTransformer);\n\n        try {\n            Class<?> transformed = loader.loadClass(GENERATED_CLASS_NAME);\n            Object instance = transformed.getDeclaredConstructor().newInstance();\n            DynamicDelegate delegate = DynamicDelegate.class.cast(instance);\n\n            assertThat(transformed.getInterfaces()).contains(DynamicDelegate.class);\n            assertThat(delegate.describe(\"subject\")).isEqualTo(\"delegate:subject\");\n            assertThat(delegate.getTarget()).isSameAs(instance);\n        } catch (InvocationTargetException exception) {\n            if (findUnsupportedFeatureError(exception) == null) {\n                throw exception;\n            }\n        } catch (RuntimeException exception) {\n            if (findUnsupportedFeatureError(exception) == null) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static ClassTransformer newDelegateTransformer() {\n        return new AddDelegateTransformer(new Class[] {DynamicDelegate.class}, DelegateImpl.class);\n    }\n\n    private static byte[] generatedClassBytecode() {\n        ClassWriter writer = new ClassWriter(0);\n        writer.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                GENERATED_INTERNAL_NAME,\n                null,\n                \"java/lang/Object\",\n                null);\n        writeDefaultConstructor(writer);\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static void writeDefaultConstructor(ClassWriter writer) {\n        MethodVisitor constructor = writer.visitMethod(\n                Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface DynamicDelegate {\n        String describe(String value);\n\n        Object getTarget();\n    }\n\n    public static class DelegateImpl implements DynamicDelegate {\n        private final Object target;\n\n        public DelegateImpl(Object target) {\n            this.target = target;\n        }\n\n        @Override\n        public String describe(String value) {\n            return \"delegate:\" + value;\n        }\n\n        @Override\n        public Object getTarget() {\n            return target;\n        }\n    }\n\n    private static class GeneratedClassPathLoader extends ClassLoader {\n        GeneratedClassPathLoader() {\n            super(AddDelegateTransformerTest.class.getClassLoader());\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if ((GENERATED_INTERNAL_NAME + \".class\").equals(name)) {\n                return new ByteArrayInputStream(generatedClassBytecode());\n            }\n            return super.getResourceAsStream(name);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input