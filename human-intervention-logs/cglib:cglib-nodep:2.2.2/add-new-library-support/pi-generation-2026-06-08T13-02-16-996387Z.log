  package cglib.cglib_nodep;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.util.ArrayList;
  import java.util.List;
  
  import net.sf.cglib.asm.ClassWriter;
  import net.sf.cglib.asm.MethodVisitor;
  import net.sf.cglib.asm.Opcodes;
  import net.sf.cglib.core.Predicate;
  import net.sf.cglib.core.ReflectUtils;
  import net.sf.cglib.core.Signature;
  import net.sf.cglib.proxy.Enhancer;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectUtilsTest {
      private static final String GENERATED_CLASS_NAME = "cglib.cglib_nodep.ReflectUtilsGenerated";
      private static final String GENERATED_INTERNAL_NAME = "cglib/cglib_nodep/ReflectUtilsGenerated";
  
      @Test
      void findsConstructorsAndMethodsFromDescriptorStrings() {
          Constructor<?> stringConstructor = ReflectUtils.findConstructor("String(char[])");
          Method substring = ReflectUtils.findMethod("java.lang.String.substring(int)");
  
          assertThat(stringConstructor.getDeclaringClass()).isEqualTo(String.class);
          assertThat(stringConstructor.getParameterTypes()).containsExactly(char[].class);
          assertThat(substring.getName()).isEqualTo("substring");
          assertThat(substring.getParameterTypes()).containsExactly(int.class);
      }
  
      @Test
      void invokesConstructorSelectedByParameterTypes() {
          Signature signature = (Signature) ReflectUtils.newInstance(
                  Signature.class,
                  new Class[] {String.class, String.class},
                  new Object[] {"generated", "()V"});
  
          assertThat(signature.getName()).isEqualTo("generated");
          assertThat(signature.getDescriptor()).isEqualTo("()V");
      }
  
      @Test
      void findsDeclaredMethodsAcrossClassHierarchy() throws NoSuchMethodException {
          Method inherited = ReflectUtils.findDeclaredMethod(
                  Enhancer.class, "setUseCache", new Class[] {Boolean.TYPE});
  
          assertThat(inherited.getName()).isEqualTo("setUseCache");
          assertThat(inherited.getDeclaringClass().getName())
                  .isEqualTo("net.sf.cglib.core.AbstractClassGenerator");
      }
  
      @Test
      void collectsDeclaredMethodsFromClassHierarchyAndInterfaces() {
          List methods = ReflectUtils.addAllMethods(Enhancer.class, new ArrayList());
  
          assertThat(methods)
                  .extracting("name")
                  .contains("setSuperclass", "setUseCache", "getClassLoader");
      }
  
      @Test
      void locatesSingleMethodOnInterface() {
          Method evaluate = ReflectUtils.findInterfaceMethod(Predicate.class);
  
          assertThat(evaluate.getName()).isEqualTo("evaluate");
          assertThat(evaluate.getDeclaringClass()).isEqualTo(Predicate.class);
      }
  
      @Test
      void definesGeneratedClassThroughConfiguredClassLoader() throws Exception {
          byte[] bytecode = generatedClassBytecode();
          ClassLoader loader = new ClassLoader(ReflectUtilsTest.class.getClassLoader()) { };
  
          try {
              Class<?> generated = ReflectUtils.defineClass(GENERATED_CLASS_NAME, bytecode, loader);
  
              assertThat(generated.getName()).isEqualTo(GENERATED_CLASS_NAME);
              assertThat(generated.getClassLoader()).isSameAs(loader);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static byte[] generatedClassBytecode() {
          ClassWriter writer = new ClassWriter(0);
          writer.visit(
                  Opcodes.V1_6,
                  Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,
                  GENERATED_INTERNAL_NAME,
                  null,
                  "java/lang/Object",
                  null);
          writeDefaultConstructor(writer);
          writer.visitEnd();
          return writer.toByteArray();
      }
  
      private static void writeDefaultConstructor(ClassWriter writer) {
          MethodVisitor constructor = writer.visitMethod(
                  Opcodes.ACC_PUBLIC, "<init>", "()V", null, null);
          constructor.visitCode();
          constructor.visitVarInsn(Opcodes.ALOAD, 0);
          constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, "java/lang/Object", "<init>", "()V");
          constructor.visitInsn(Opcodes.RETURN);
          constructor.visitMaxs(1, 1);
          constructor.visitEnd();
      }
  }
