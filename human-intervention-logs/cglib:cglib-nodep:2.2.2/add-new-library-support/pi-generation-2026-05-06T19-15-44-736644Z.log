  package cglib.cglib_nodep;
  
  import net.sf.cglib.beans.ImmutableBean;
  import net.sf.cglib.core.CodeGenerationException;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatIllegalStateException;
  
  public class ImmutableBeanTest {
  
      @Test
      void createsReadOnlyViewThatDelegatesGettersToOriginalBean() throws Exception {
          runWithNativeImageUnsupportedFeatureCheck(() -> {
              MutablePerson original = new MutablePerson();
              original.setName("Ada");
              original.setAge(36);
  
              MutablePerson immutablePerson = (MutablePerson) ImmutableBean.create(original);
  
              assertThat(immutablePerson).isNotSameAs(original);
              assertThat(immutablePerson.getName()).isEqualTo("Ada");
              assertThat(immutablePerson.getAge()).isEqualTo(36);
  
              assertThatIllegalStateException()
                      .isThrownBy(() -> immutablePerson.setName("Grace"))
                      .withMessage("Bean is immutable");
              assertThatIllegalStateException()
                      .isThrownBy(() -> immutablePerson.setAge(37))
                      .withMessage("Bean is immutable");
  
              original.setName("Grace");
              original.setAge(37);
              assertThat(immutablePerson.getName()).isEqualTo("Grace");
              assertThat(immutablePerson.getAge()).isEqualTo(37);
          });
      }
  
      private static void runWithNativeImageUnsupportedFeatureCheck(ThrowingRunnable runnable)
              throws Exception {
          try {
              runnable.run();
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      public static class MutablePerson {
          private String name;
          private int age;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getAge() {
              return age;
          }
  
          public void setAge(int age) {
              this.age = age;
          }
      }
  }
