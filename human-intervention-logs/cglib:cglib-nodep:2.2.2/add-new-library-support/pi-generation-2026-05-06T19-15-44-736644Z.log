  package cglib.cglib_nodep;
  
  import net.sf.cglib.beans.BeanMap;
  import net.sf.cglib.core.CodeGenerationException;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanMapTest {
  
      @Test
      void createsMapBackedByBeanProperties() throws Exception {
          runWithNativeImageUnsupportedFeatureCheck(() -> {
              MappedBean bean = new MappedBean();
              bean.setFoo("initial");
              bean.setQuud(7);
  
              BeanMap beanMap = BeanMap.create(bean);
  
              assertThat(beanMap.getBean()).isSameAs(bean);
              assertThat(beanMap.keySet())
                      .contains("foo", "bar", "baz", "quud", "quick", "quip")
                      .doesNotContain("class");
              assertThat(beanMap.get("foo")).isEqualTo("initial");
              assertThat(beanMap.put("foo", "updated")).isEqualTo("initial");
              assertThat(bean.getFoo()).isEqualTo("updated");
              assertThat(beanMap.put("quud", 13)).isEqualTo(7);
              assertThat(bean.getQuud()).isEqualTo(13);
              assertThat(beanMap.get("bar")).isEqualTo("read-only");
              assertThat(beanMap.get("baz")).isNull();
              assertThat(beanMap.containsKey("quick")).isTrue();
              assertThat(beanMap.containsValue("updated")).isTrue();
              assertThat(beanMap.getPropertyType("foo")).isEqualTo(String.class);
              assertThat(beanMap.getPropertyType("quud")).isEqualTo(Integer.TYPE);
              assertThat(beanMap.getPropertyType("missing")).isNull();
              assertThat(beanMap.entrySet()).hasSize(beanMap.size());
              assertThat(beanMap.values()).contains("updated", "read-only", 13, 42);
              assertThat(beanMap.toString()).contains("foo=updated");
          });
      }
  
      @Test
      void generatorCreatesReusableMapWithoutInitialBeanAndHonorsGetterRequirement()
              throws Exception {
          runWithNativeImageUnsupportedFeatureCheck(() -> {
              BeanMap.Generator generator = new BeanMap.Generator();
              generator.setBeanClass(MappedBean.class);
              generator.setRequire(BeanMap.REQUIRE_GETTER);
  
              BeanMap beanMap = generator.create();
              MappedBean firstBean = new MappedBean();
              MappedBean secondBean = new MappedBean();
  
              assertThat(beanMap.getBean()).isNull();
              assertThat(beanMap.keySet())
                      .contains("foo", "bar", "quud", "quick")
                      .doesNotContain("baz", "quip");
              assertThat(beanMap.put(firstBean, "foo", "first")).isNull();
              assertThat(beanMap.get(firstBean, "foo")).isEqualTo("first");
              assertThat(firstBean.getFoo()).isEqualTo("first");
  
              BeanMap reboundMap = beanMap.newInstance(secondBean);
              reboundMap.put("foo", "second");
              assertThat(secondBean.getFoo()).isEqualTo("second");
              assertThat(beanMap.get(firstBean, "foo")).isEqualTo("first");
          });
      }
  
      private static void runWithNativeImageUnsupportedFeatureCheck(ThrowingRunnable runnable)
              throws Exception {
          try {
              runnable.run();
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run() throws Exception;
      }
  
      public static class MappedBean {
          private String foo;
          private String baz;
          private int quud;
          private int quip;
  
          public String getFoo() {
              return foo;
          }
  
          public void setFoo(String foo) {
              this.foo = foo;
          }
  
          public String getBar() {
              return "read-only";
          }
  
          public void setBaz(String baz) {
              this.baz = baz;
          }
  
          public int getQuud() {
              return quud;
          }
  
          public void setQuud(int quud) {
              this.quud = quud;
          }
  
          public int getQuick() {
              return 42;
          }
  
          public void setQuip(int quip) {
              this.quip = quip;
          }
