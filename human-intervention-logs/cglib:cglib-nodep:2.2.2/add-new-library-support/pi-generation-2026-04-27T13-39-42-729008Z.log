[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ClassWriterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.asm.ClassReader;\nimport net.sf.cglib.asm.ClassWriter;\nimport net.sf.cglib.asm.Label;\nimport net.sf.cglib.asm.MethodVisitor;\nimport net.sf.cglib.asm.Opcodes;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassWriterTest {\n    private static final String GENERATED_CLASS_NAME = \"cglib.cglib_nodep.generated.ClassWriterFrameMergeType\";\n\n    @Test\n    void computesFramesForBranchesWithCommonApplicationSuperClass() {\n        byte[] bytecode = generateClassWithMergedSubclassFrames();\n        ClassReader reader = new ClassReader(bytecode);\n\n        assertThat(bytecode).isNotEmpty();\n        assertThat(reader.getClassName()).isEqualTo(GENERATED_CLASS_NAME.replace('.', '/'));\n        assertThat(reader.getSuperName()).isEqualTo(internalName(Object.class));\n    }\n\n    private static byte[] generateClassWithMergedSubclassFrames() {\n        ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        writer.visit(\n                Opcodes.V1_6,\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,\n                GENERATED_CLASS_NAME.replace('.', '/'),\n                null,\n                internalName(Object.class),\n                null);\n\n        writeDefaultConstructor(writer);\n        writeChooserMethod(writer);\n\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n\n    private static void writeDefaultConstructor(ClassWriter writer) {\n        MethodVisitor constructor = writer.visitMethod(Opcodes.ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visi