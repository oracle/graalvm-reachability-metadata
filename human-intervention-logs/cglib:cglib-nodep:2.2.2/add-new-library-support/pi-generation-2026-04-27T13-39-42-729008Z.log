ructor.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName(Object.class), \"<init>\", \"()V\");\n        constructor.visitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(0, 0);\n        constructor.visitEnd();\n    }\n\n    private static void writeChooserMethod(ClassWriter writer) {\n        MethodVisitor chooser = writer.visitMethod(\n                Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,\n                \"chooseAnimal\",\n                \"(Z)\" + descriptor(Animal.class),\n                null,\n                null);\n        Label catBranch = new Label();\n        Label returnBranch = new Label();\n\n        chooser.visitCode();\n        chooser.visitVarInsn(Opcodes.ILOAD, 0);\n        chooser.visitJumpInsn(Opcodes.IFEQ, catBranch);\n        chooser.visitTypeInsn(Opcodes.NEW, internalName(Dog.class));\n        chooser.visitInsn(Opcodes.DUP);\n        chooser.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName(Dog.class), \"<init>\", \"()V\");\n        chooser.visitVarInsn(Opcodes.ASTORE, 1);\n        chooser.visitJumpInsn(Opcodes.GOTO, returnBranch);\n\n        chooser.visitLabel(catBranch);\n        chooser.visitTypeInsn(Opcodes.NEW, internalName(Cat.class));\n        chooser.visitInsn(Opcodes.DUP);\n        chooser.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName(Cat.class), \"<init>\", \"()V\");\n        chooser.visitVarInsn(Opcodes.ASTORE, 1);\n\n        chooser.visitLabel(returnBranch);\n        chooser.visitVarInsn(Opcodes.ALOAD, 1);\n        chooser.visitInsn(Opcodes.ARETURN);\n        chooser.visitMaxs(0, 0);\n        chooser.visitEnd();\n    }\n\n    private static String descriptor(Class<?> type) {\n        return \"L\" + internalName(type) + \";\";\n    }\n\n    private static String internalName(Class<?> type) {\n        return type.getName().replace('.', '/');\n    }\n\n    public abstract static class Animal {\n    }\n\n    public static class Dog extends Animal {\n    }\n\n    public static class Cat extends Animal {\n    }\n}\n"}}], 