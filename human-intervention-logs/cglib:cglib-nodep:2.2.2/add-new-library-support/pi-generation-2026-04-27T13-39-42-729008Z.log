  package cglib.cglib_nodep;
  
  import net.sf.cglib.asm.ClassReader;
  import net.sf.cglib.asm.ClassWriter;
  import net.sf.cglib.asm.Label;
  import net.sf.cglib.asm.MethodVisitor;
  import net.sf.cglib.asm.Opcodes;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassWriterTest {
      private static final String GENERATED_CLASS_NAME = "cglib.cglib_nodep.generated.ClassWriterFrameMergeType";
  
      @Test
      void computesFramesForBranchesWithCommonApplicationSuperClass() {
          byte[] bytecode = generateClassWithMergedSubclassFrames();
          ClassReader reader = new ClassReader(bytecode);
  
          assertThat(bytecode).isNotEmpty();
          assertThat(reader.getClassName()).isEqualTo(GENERATED_CLASS_NAME.replace('.', '/'));
          assertThat(reader.getSuperName()).isEqualTo(internalName(Object.class));
      }
  
      private static byte[] generateClassWithMergedSubclassFrames() {
          ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_FRAMES);
          writer.visit(
                  Opcodes.V1_6,
                  Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,
                  GENERATED_CLASS_NAME.replace('.', '/'),
                  null,
                  internalName(Object.class),
                  null);
  
          writeDefaultConstructor(writer);
          writeChooserMethod(writer);
  
          writer.visitEnd();
          return writer.toByteArray();
      }
  
      private static void writeDefaultConstructor(ClassWriter writer) {
          MethodVisitor constructor = writer.visitMethod(Opcodes.ACC_PUBLIC, "<init>", "()V", null, null);
          constructor.visitCode();
          constructor.visitVarInsn(Opcodes.ALOAD, 0);
          constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName(Object.class), "<init>", "()V");
          constructor.visitInsn(Opcodes.RETURN);
          constructor.visitMaxs(0, 0);
          constructor.visitEnd();
      }
  
      private static void writeChooserMethod(ClassWriter writer) {
          MethodVisitor chooser = writer.visitMethod(
                  Opcodes.ACC_PUBLIC | Opcodes.ACC_STATIC,
                  "chooseAnimal",
                  "(Z)" + descriptor(Animal.class),
                  null,
                  null);
          Label catBranch = new Label();
          Label returnBranch = new Label();
  
          chooser.visitCode();
          chooser.visitVarInsn(Opcodes.ILOAD, 0);
          chooser.visitJumpInsn(Opcodes.IFEQ, catBranch);
          chooser.visitTypeInsn(Opcodes.NEW, internalName(Dog.class));
          chooser.visitInsn(Opcodes.DUP);
          chooser.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName(Dog.class), "<init>", "()V");
          chooser.visitVarInsn(Opcodes.ASTORE, 1);
          chooser.visitJumpInsn(Opcodes.GOTO, returnBranch);
  
          chooser.visitLabel(catBranch);
          chooser.visitTypeInsn(Opcodes.NEW, internalName(Cat.class));
          chooser.visitInsn(Opcodes.DUP);
          chooser.visitMethodInsn(Opcodes.INVOKESPECIAL, internalName(Cat.class), "<init>", "()V");
          chooser.visitVarInsn(Opcodes.ASTORE, 1);
  
          chooser.visitLabel(returnBranch);
          chooser.visitVarInsn(Opcodes.ALOAD, 1);
          chooser.visitInsn(Opcodes.ARETURN);
          chooser.visitMaxs(0, 0);
          chooser.visitEnd();
      }
  
      private static String descriptor(Class<?> type) {
          return "L" + internalName(type) + ";";
      }
  
      private static String internalName(Class<?> type) {
          return type.getName().replace('.', '/');
      }
  
      public abstract static class Animal {
      }
  
      public static class Dog extends Animal {
      }
  
      public static class Cat extends Animal {
      }
  }
