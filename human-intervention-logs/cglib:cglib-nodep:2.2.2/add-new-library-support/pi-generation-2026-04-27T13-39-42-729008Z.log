[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ClassWriterTest.java","edits":[{"oldText":"import net.sf.cglib.asm.ClassReader;\nimport net.sf.cglib.asm.ClassWriter;\n","newText":"import net.sf.cglib.asm.ClassAdapter;\nimport net.sf.cglib.asm.ClassReader;\nimport net.sf.cglib.asm.ClassWriter;\n"},{"oldText":"import net.sf.cglib.asm.MethodVisitor;\nimport net.sf.cglib.asm.Opcodes;\n","newText":"import net.sf.cglib.asm.MethodVisitor;\nimport net.sf.cglib.asm.Opcodes;\nimport net.sf.cglib.core.ClassEmitter;\nimport net.sf.cglib.transform.AbstractClassTransformer;\n"},{"oldText":"    void computesCommonSuperclassForApplicationTypes() {\n        InspectingClassWriter writer = new InspectingClassWriter();\n\n        assertThat(writer.commonSuperClass(Dog.class, Cat.class)).isEqualTo(internalName(Animal.class));\n        assertThat(writer.commonSuperClass(Animal.class, Dog.class)).isEqualTo(internalName(Animal.class));\n    }\n","newText":"    void computesCommonSuperclassForLibraryTypes() {\n        InspectingClassWriter writer = new InspectingClassWriter();\n\n        assertThat(writer.commonSuperClass(ClassEmitter.class, AbstractClassTransformer.class))\n                .isEqualTo(internalName(ClassAdapter.class));\n        assertThat(writer.commonSuperClass(ClassAdapter.class, ClassEmitter.class))\n                .isEqualTo(internalName(ClassAdapter.class));\n    }\n"}]}
