  package cglib.cglib_nodep;
  
  import java.io.IOException;
  
  import net.sf.cglib.asm.ClassReader;
  import net.sf.cglib.proxy.Enhancer;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassReaderTest {
      @Test
      void readsClassBytesFromSystemResource() throws IOException {
          ClassReader reader = new ClassReader(Enhancer.class.getName());
  
          assertThat(reader.getClassName()).isEqualTo(Enhancer.class.getName().replace('.', '/'));
      }
  }
