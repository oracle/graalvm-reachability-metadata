  package cglib.cglib_nodep;
  
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.util.ArrayList;
  import java.util.List;
  
  import net.sf.cglib.core.ReflectUtils;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectUtilsTest {
  
      @Test
      void resolvesConstructorsMethodsAndDescriptorTypes() {
          Constructor<?> stringConstructor = ReflectUtils.findConstructor("java.lang.String(byte[])");
          assertThat(stringConstructor.getDeclaringClass()).isEqualTo(String.class);
  
          Method substring = ReflectUtils.findMethod("String.substring(int, int)");
          assertThat(substring.getName()).isEqualTo("substring");
          assertThat(substring.getParameterTypes()).containsExactly(int.class, int.class);
  
          Method arrayToString = ReflectUtils.findMethod("java.util.Arrays.toString(int[])");
          assertThat(arrayToString.getParameterTypes()).containsExactly(int[].class);
      }
  
      @Test
      void createsInstancesWithDeclaredConstructors() {
          PrivateValue value = (PrivateValue) ReflectUtils.newInstance(
                  PrivateValue.class,
                  new Class<?>[] {String.class},
                  new Object[] {"created"}
          );
  
          assertThat(value.text()).isEqualTo("created");
      }
  
      @Test
      void findsDeclaredMethodsThroughHierarchyAndCollectsMethods() throws Exception {
          Method inheritedMethod = ReflectUtils.findDeclaredMethod(
                  ChildValue.class,
                  "inheritedSecret",
                  new Class<?>[0]
          );
          assertThat(inheritedMethod.getDeclaringClass()).isEqualTo(ParentValue.class);
  
          List<Method> methods = ReflectUtils.addAllMethods(ChildValue.class, new ArrayList<Method>());
          assertThat(methods)
                  .extracting(Method::getName)
                  .contains("childMethod", "inheritedSecret");
      }
  
      @Test
      void findsSingleInterfaceFactoryMethod() {
          Method method = ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);
  
          assertThat(method.getName()).isEqualTo("newInstance");
          assertThat(method.getParameterTypes()).isEmpty();
      }
  
      @Test
      void definesClassBytesWithRequestedLoader() throws Exception {
          String className = DefinedByReflectUtils.class.getName();
          byte[] classBytes = readClassBytes(DefinedByReflectUtils.class);
          ChildOnlyClassLoader loader = new ChildOnlyClassLoader(ReflectUtilsTest.class.getClassLoader());
  
          try {
              Class<?> definedClass = ReflectUtils.defineClass(className, classBytes, loader);
  
              assertThat(definedClass.getName()).isEqualTo(className);
              assertThat(definedClass.getClassLoader()).isSameAs(loader);
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause();
              if (!(cause instanceof Error error) || !NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static byte[] readClassBytes(Class<?> type) throws IOException {
          String resourceName = type.getName().replace('.', '/') + ".class";
          InputStream inputStream = ReflectUtilsTest.class.getClassLoader().getResourceAsStream(resourceName);
          assertThat(inputStream).as("class resource %s", resourceName).isNotNull();
          try (InputStream input = inputStream; ByteArrayOutputStream output = new ByteArrayOutputStream()) {
              byte[] buffer = new byte[4096];
              int read;
              while ((read = input.read(buffer)) != -1) {
                  output.write(buffer, 0, read);
              }
              return output.toByteArray();
          }
      }
  
      public interface SingleMethodFactory {
          Object newInstance();
      }
  
      public static class ParentValue {
          private String inheritedSecret() {
              return "parent";
          }
      }
  
      public static class ChildValue extends ParentValue {
          public String childMethod() {
              return "child";
          }
      }
  
      public static class PrivateValue {
          private final String text;
  
          private PrivateValue(String text) {
              this.text = text;
          }
  
          public String text() {
              return text;
          }
      }
  
      public static class DefinedByReflectUtils {
      }
  
      private static final class ChildOnlyClassLoader extends ClassLoader {
          private ChildOnlyClassLoader(ClassLoader parent) {
              super(parent);
          }
      }
  }
