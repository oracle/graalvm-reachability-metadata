  package cglib.cglib_nodep;
  
  import net.sf.cglib.asm.ClassWriter;
  import net.sf.cglib.asm.Label;
  import net.sf.cglib.asm.MethodVisitor;
  import org.junit.jupiter.api.Test;
  
  import static net.sf.cglib.asm.Opcodes.ACC_PUBLIC;
  import static net.sf.cglib.asm.Opcodes.ACC_SUPER;
  import static net.sf.cglib.asm.Opcodes.ACC_STATIC;
  import static net.sf.cglib.asm.Opcodes.ALOAD;
  import static net.sf.cglib.asm.Opcodes.ARETURN;
  import static net.sf.cglib.asm.Opcodes.DUP;
  import static net.sf.cglib.asm.Opcodes.GOTO;
  import static net.sf.cglib.asm.Opcodes.IFEQ;
  import static net.sf.cglib.asm.Opcodes.ILOAD;
  import static net.sf.cglib.asm.Opcodes.INVOKESPECIAL;
  import static net.sf.cglib.asm.Opcodes.NEW;
  import static net.sf.cglib.asm.Opcodes.RETURN;
  import static net.sf.cglib.asm.Opcodes.V1_6;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassWriterTest {
  
      @Test
      void resolvesCommonSuperclassForApplicationClasses() {
          ExposingClassWriter writer = new ExposingClassWriter();
  
          String commonSuperClass = writer.commonSuperClass(
                  internalName(ClassWriterFirstSibling.class),
                  internalName(ClassWriterSecondSibling.class));
  
          assertThat(commonSuperClass).isEqualTo(internalName(ClassWriterBaseSibling.class));
      }
  
      @Test
      void computesFramesForBranchMergingApplicationClasses() {
          ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_FRAMES);
          writer.visit(V1_6, ACC_PUBLIC | ACC_SUPER, "cglib/cglib_nodep/GeneratedFrameMergeSample", null,
                  "java/lang/Object", null);
          writeConstructor(writer);
          writeBranchingFactory(writer);
          writer.visitEnd();
  
          byte[] classFile = writer.toByteArray();
  
          assertThat(classFile).isNotEmpty();
      }
  
      private static void writeConstructor(ClassWriter writer) {
          MethodVisitor constructor = writer.visitMethod(ACC_PUBLIC, "<init>", "()V", null, null);
          constructor.visitCode();
          constructor.visitVarInsn(ALOAD, 0);
          constructor.visitMethodInsn(INVOKESPECIAL, "java/lang/Object", "<init>", "()V");
          constructor.visitInsn(RETURN);
          constructor.visitMaxs(0, 0);
          constructor.visitEnd();
      }
  
      private static void writeBranchingFactory(ClassWriter writer) {
          MethodVisitor method = writer.visitMethod(ACC_PUBLIC | ACC_STATIC, "create",
                  "(Z)L" + internalName(ClassWriterBaseSibling.class) + ";", null, null);
          Label createSecondSibling = new Label();
          Label returnSibling = new Label();
  
          method.visitCode();
          method.visitVarInsn(ILOAD, 0);
          method.visitJumpInsn(IFEQ, createSecondSibling);
          method.visitTypeInsn(NEW, internalName(ClassWriterFirstSibling.class));
          method.visitInsn(DUP);
          method.visitMethodInsn(INVOKESPECIAL, internalName(ClassWriterFirstSibling.class), "<init>", "()V");
          method.visitJumpInsn(GOTO, returnSibling);
          method.visitLabel(createSecondSibling);
          method.visitTypeInsn(NEW, internalName(ClassWriterSecondSibling.class));
  
