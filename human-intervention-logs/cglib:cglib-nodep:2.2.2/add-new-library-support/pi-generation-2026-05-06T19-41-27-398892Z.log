[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/CallbackInfoTest.java","edits":[{"oldText":"import net.sf.cglib.proxy.ProxyRefDispatcher;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThatCode;\n","newText":"import net.sf.cglib.proxy.ProxyRefDispatcher;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"    void acceptsEveryBuiltInCallbackType() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(CallbackTarget.class);\n        enhancer.setCallbackFilter(new RotatingCallbackFilter());\n\n        assertThatCode(() -> enhancer.setCallbackTypes(new Class[] {\n                NoOp.class,\n                MethodInterceptor.class,\n                InvocationHandler.class,\n                LazyLoader.class,\n                Dispatcher.class,\n                FixedValue.class,\n                ProxyRefDispatcher.class,\n        })).doesNotThrowAnyException();\n    }\n","newText":"    void acceptsEveryBuiltInCallbackType() {\n        try {\n            configureEnhancerWithEveryBuiltInCallbackType();\n        } catch (Error error) {\n            if (!isUnsupportedNativeFailure(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void configureEnhancerWithEveryBuiltInCallbackType() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(CallbackTarget.class);\n        enhancer.setCallbackFilter(new RotatingCallbackFilter());\n        enhancer.setCallbackTypes(new Class[] {\n                NoOp.class,\n                MethodInterceptor.class,\n                InvocationHandler.class,\n                LazyLoader.class,\n                Dispatcher.class,\n                FixedValue.class,\n                ProxyRefDispatcher.class,\n        });\n    }\n\n    private static boolean isUnsupportedNativeFailure(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            if (current instanceof NoClassDefFoundError\n                    && \"Could not initialize class net.sf.cglib.proxy.Enhancer\".equals(current.getMessage())) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n"}]}
