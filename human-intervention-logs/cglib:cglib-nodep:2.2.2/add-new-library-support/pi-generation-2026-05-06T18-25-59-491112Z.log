  package cglib.cglib_nodep;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import net.sf.cglib.beans.BeanCopier;
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.core.Converter;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.MethodOrderer;
  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.TestMethodOrder;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @TestMethodOrder(MethodOrderer.OrderAnnotation.class)
  public class BeanCopierTest {
  
      @Test
      @Order(1)
      void initializesBeanCopierThroughSubclassContract() {
          try {
              SourceBean source = new SourceBean();
              source.setName("Grace");
              source.setCount(7);
              TargetBean target = new TargetBean();
  
              BeanCopier copier = new RecordingBeanCopier();
              copier.copy(source, target, null);
  
              assertThat(target.getName()).isEqualTo("Grace");
              assertThat(target.getCount()).isEqualTo(7);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(2)
      void syntheticClassLookupResolvesBeanCopierKey() throws Throwable {
          MethodHandle classLookup = syntheticClassLookup();
  
          Class<?> resolvedClass = invokeSyntheticClassLookup(
                  classLookup,
                  "net.sf.cglib.beans.BeanCopier$BeanCopierKey"
          );
  
          assertThat(resolvedClass.getName())
                  .isEqualTo("net.sf.cglib.beans.BeanCopier$BeanCopierKey");
      }
  
      @Test
      @Order(3)
      void copiesMatchingBeanPropertiesWithAndWithoutConverter() {
          SourceBean source = new SourceBean();
          source.setName("Ada");
          source.setCount(41);
  
          try {
              TargetBean directTarget = new TargetBean();
              BeanCopier directCopier = BeanCopier.create(SourceBean.class, TargetBean.class, false);
              directCopier.copy(source, directTarget, null);
  
              assertThat(directTarget.getName()).isEqualTo("Ada");
              assertThat(directTarget.getCount()).isEqualTo(41);
  
              TargetBean convertedTarget = new TargetBean();
              BeanCopier convertingCopier = BeanCopier.create(
                      SourceBean.class,
                      TargetBean.class,
                      true
              );
              convertingCopier.copy(source, convertedTarget, new IncrementingConverter());
  
              assertThat(convertedTarget.getName()).isEqualTo("Ada");
              assertThat(convertedTarget.getCount()).isEqualTo(42);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static MethodHandle syntheticClassLookup()
              throws NoSuchMethodException, IllegalAccessException {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                  BeanCopier.class,
                  MethodHandles.lookup()
          );
          return lookup.findStatic(
                  BeanCopier.class,
                  "class$",
                  MethodType.methodType(Class.class, String.class)
          );
      }
  
      private static Class<?> invokeSyntheticClassLookup(MethodHandle classLookup, String className)
              throws Throwable {
          return (Class<?>) classLookup.invokeExact(className);
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public static class SourceBean {
          private String name;
          private int count;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getCount() {
              return count;
          }
  
          public void setCount(int count) {
              this.count = count;
          }
      }
  
      public static class TargetBean {
          private String name;
          private int count;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getCount() {
              return count;
          }
  
          public void setCount(int count) {
              this.count = count;
          }
      }
  
      private static final class RecordingBeanCopier extends BeanCopier {
          @Override
          public void copy(Object from, Object to, Converter converter) {
              SourceBean source = (SourceBean) from;
              TargetBean target = (TargetBean) to;
              target.setName(source.getName());
              target.setCount(source.getCount());
          }
      }
  
      private static final class IncrementingConverter implements Converter {
          @Override
          public Object convert(Object value, Class target, Object context) {
              if (target.equals(Integer.TYPE)) {
                  return Integer.valueOf(((Number) value).intValue() + 1);
              }
              return value;
          }
      }
  }
