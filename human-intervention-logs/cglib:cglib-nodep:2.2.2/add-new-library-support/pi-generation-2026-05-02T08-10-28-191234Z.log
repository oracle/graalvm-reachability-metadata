w SampleValue(\"beta\") });\n\n            assertThat(key).isEqualTo(matchingKey);\n            assertThat(key).hasSameHashCodeAs(matchingKey);\n            assertThat(key).isNotEqualTo(differentKey);\n        } catch (Error error) {\n            if (!isUnsupportedNativeImageDynamicClassLoading(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static boolean isUnsupportedNativeImageDynamicClassLoading(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error && NativeImageSupport.isUnsupportedFeatureError((Error) current)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class SampleValue {\n        private final String value;\n\n        public SampleValue(String value) {\n            this.value = value;\n        }\n\n        public String value() {\n            return value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1234, "output": 1016, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 23754, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777709412547, "responseId": "resp_02526f08426fa5360169f5b164fffc819cacfa679342b3a733"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZFjn3ZFMpT7WwYsF1vZ69qDw|fc_02526f08426fa5360169f5b16db7cc819c87a16ec44b59bb1a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1864 bytes to tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ClassesKeyTest.java"}], "isError": false, "timestamp": 1777709424079}]}
