[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/AbstractClassGeneratorTest.java","edits":[{"oldText":"import java.util.ArrayList;\nimport java.util.List;\n\nimport net.sf.cglib.core.AbstractClassGenerator;\n","newText":"import net.sf.cglib.core.AbstractClassGenerator;\n"},{"oldText":"    private static final String GENERATED_CLASS_NAME = \"cglib.cglib_nodep.AttemptLoadGeneratedClass\";\n\n    @Test\n    void attemptsToLoadGeneratedClassNameBeforeFallingBackToGeneration() {\n        RecordingClassLoader classLoader = new RecordingClassLoader(\n                AbstractClassGeneratorTest.class.getClassLoader());\n        TestClassGenerator generator = new TestClassGenerator(classLoader);\n        generator.setAttemptLoad(true);\n\n        assertThatThrownBy(() -> generator.createWithKey(\"attempt-load-key\"))\n                .isInstanceOf(GenerationStoppedException.class);\n\n        assertThat(classLoader.loadedClassNames).containsExactly(GENERATED_CLASS_NAME);\n    }\n\n    private static final class TestClassGenerator extends AbstractClassGenerator {\n        private static final Source SOURCE = new Source(TestClassGenerator.class.getName());\n\n        private final ClassLoader defaultClassLoader;\n\n        private TestClassGenerator(ClassLoader classLoader) {\n            super(SOURCE);\n            this.defaultClassLoader = classLoader;\n            setClassLoader(classLoader);\n            setNamingPolicy((prefix, source, key, names) -> GENERATED_CLASS_NAME);\n            setStrategy(new StoppingGeneratorStrategy());\n        }\n","newText":"    private static final String EXISTING_CLASS_NAME = String.class.getName();\n\n    @Test\n    void attemptsToLoadClassNameBeforeGeneratingBytecode() {\n        TestClassGenerator generator = new TestClassGenerator(\n                AbstractClassGeneratorTest.class.getClassLoader());\n        generator.setAttemptLoad(true);\n\n        Object created = generator.createWithKey(\"attempt-load-key\");\n\n        assertThat(created).isSameAs(String.class);\n    }\n\n    private static final class TestClassGenerator extends AbstractClassGenerator {\n        private static final Source SOURCE = new Source(TestClassGenerator.class.getName());\n\n        private final ClassLoader defaultClassLoader;\n\n        private TestClassGenerator(ClassLoader classLoader) {\n            super(SOURCE);\n            this.defaultClassLoader = classLoader;\n            setClassLoader(classLoader);\n            setNamingPolicy((prefix, source, key, names) -> EXISTING_CLASS_NAME);\n            setStrategy(new StoppingGeneratorStrategy());\n        }\n"},{"oldText":"    private static final class RecordingClassLoader extends ClassLoader {\n        private final List<String> loadedClassNames = new ArrayList<>();\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (GENERATED_CLASS_NAME.equals(name)) {\n                loadedClassNames.add(name);\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n    }\n\n    private static final class GenerationStoppedException extends RuntimeException {\n    }\n","newText":"    private static final class GenerationStoppedException extends RuntimeException {\n    }\n"}]}
