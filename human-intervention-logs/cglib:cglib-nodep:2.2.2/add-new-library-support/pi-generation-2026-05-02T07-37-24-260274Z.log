          ParsedJacocoReport parsedJacocoReport = parseJacocoReport(jacocoReport);
          return versionStats(
                  coordinate,
                  LibraryStatsModels.DynamicAccessStatsValue.notAvailable(),
                  parsedJacocoReport
          );
      }
  
