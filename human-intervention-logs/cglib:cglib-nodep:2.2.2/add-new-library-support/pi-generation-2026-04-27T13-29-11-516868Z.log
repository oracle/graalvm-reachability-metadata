  package cglib.cglib_nodep;
  
  import java.util.Arrays;
  
  import net.sf.cglib.asm.ClassReader;
  import net.sf.cglib.asm.ClassWriter;
  import net.sf.cglib.asm.Opcodes;
  import net.sf.cglib.asm.Type;
  import net.sf.cglib.transform.impl.AddDelegateTransformer;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AddDelegateTransformerTest {
      private static final String GENERATED_CLASS_NAME = "cglib.cglib_nodep.generated.AddDelegateTarget";
  
      @Test
      void addsDelegateInterfaceMethodsToGeneratedClassBytecode() {
          ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);
          AddDelegateTransformer transformer = new AddDelegateTransformer(
                  new Class[] { DelegatedOperations.class },
                  DelegateImplementation.class);
  
          transformer.setTarget(writer);
          transformer.begin_class(
                  Opcodes.V1_5,
                  Opcodes.ACC_PUBLIC,
                  GENERATED_CLASS_NAME,
                  Type.getType(Object.class),
                  new Type[0],
                  null);
          transformer.end_class();
  
          ClassReader generatedClass = new ClassReader(writer.toByteArray());
          assertThat(generatedClass.getClassName()).isEqualTo(GENERATED_CLASS_NAME.replace('.', '/'));
          assertThat(Arrays.asList(generatedClass.getInterfaces()))
                  .contains(Type.getInternalName(DelegatedOperations.class));
      }
  
      public interface DelegatedOperations {
          Object owner();
  
          String describe(String name);
      }
  
      public static class DelegateImplementation implements DelegatedOperations {
          private final Object owner;
  
          public DelegateImplementation(Object owner) {
              this.owner = owner;
          }
  
          @Override
          public Object owner() {
              return owner;
          }
  
          @Override
          public String describe(String name) {
              return "delegate for " + name;
          }
      }
  }
