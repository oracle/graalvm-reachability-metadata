[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.proxy.InvocationHandler;\nimport net.sf.cglib.proxy.Proxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProxyTest {\n    @Test\n    void createsProxyInstanceAndDispatchesInterfaceCallsToInvocationHandler() {\n        InvocationHandler handler = (proxy, method, arguments) -> {\n            if (method.getName().equals(\"echo\")) {\n                return \"handled \" + arguments[0];\n            }\n            if (method.getName().equals(\"answer\")) {\n                return 42;\n            }\n            return method.getName();\n        };\n\n        try {\n            Object proxy = Proxy.newProxyInstance(\n                    ProxyTest.class.getClassLoader(),\n                    new Class[] {EchoService.class},\n                    handler);\n\n            EchoService service = (EchoService) proxy;\n            assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();\n            assertThat(Proxy.getInvocationHandler(proxy)).isSameAs(handler);\n            assertThat(service.echo(\"cglib\")).isEqualTo(\"handled cglib\");\n            assertThat(service.answer()).isEqualTo(42);\n        } catch (RuntimeException exception) {\n            if (findUnsupportedFeatureError(exception) == null) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface EchoService {\n        String echo(String value);\n\n        int answer();\n    }\n}\n"}
