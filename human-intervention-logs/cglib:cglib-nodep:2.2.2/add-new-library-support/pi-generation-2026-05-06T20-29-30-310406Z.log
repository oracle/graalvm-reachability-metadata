  package cglib.cglib_nodep;
  
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.proxy.Enhancer;
  import net.sf.cglib.proxy.FixedValue;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class EnhancerTest {
  
      @Test
      void createsEnhancedInterfaceImplementationAndInstallsCallbacks() {
          try {
              GreetingService proxy = createGreetingService("generated greeting");
  
              assertThat(proxy.greet()).isEqualTo("generated greeting");
              assertThat(Enhancer.isEnhanced(proxy.getClass())).isTrue();
          } catch (Error error) {
              if (!isUnsupportedNativeFailure(error)) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static GreetingService createGreetingService(String greeting) {
          Enhancer enhancer = new Enhancer();
          enhancer.setSuperclass(GreetingService.class);
          enhancer.setCallback((FixedValue) () -> greeting);
          return (GreetingService) enhancer.create();
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      private static boolean isUnsupportedNativeFailure(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              if (current instanceof NoClassDefFoundError
                      && "Could not initialize class net.sf.cglib.proxy.Enhancer".equals(current.getMessage())) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public interface GreetingService {
          String greet();
      }
