  package cglib.cglib_nodep;
  
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.reflect.MethodDelegate;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodDelegateInnerGeneratorTest {
  
      @Test
      void createsDelegateForInstanceMethodWithMatchingInterfaceSignature() {
          GreetingTarget target = new GreetingTarget("Hello");
  
          try {
              GreetingOperation delegate = (GreetingOperation) MethodDelegate.create(
                      target,
                      "formatGreeting",
                      GreetingOperation.class
              );
  
              assertThat(delegate.greet("Ada")).isEqualTo("Hello, Ada");
              assertThat(((MethodDelegate) delegate).getTarget()).isSameAs(target);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public interface GreetingOperation {
          String greet(String name);
      }
  
      public static class GreetingTarget {
          private final String prefix;
  
          GreetingTarget(String prefix) {
              this.prefix = prefix;
          }
  
          public String formatGreeting(String name) {
              return prefix + ", " + name;
          }
      }
  }
