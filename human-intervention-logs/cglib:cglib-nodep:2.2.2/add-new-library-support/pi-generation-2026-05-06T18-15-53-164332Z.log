[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ClassWriterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.asm.ClassWriter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassWriterTest {\n\n    @Test\n    void resolvesCommonSuperclassForApplicationClasses() {\n        ExposingClassWriter writer = new ExposingClassWriter();\n\n        String commonSuperClass = writer.commonSuperClass(\n                internalName(ClassWriterFirstSibling.class),\n                internalName(ClassWriterSecondSibling.class));\n\n        assertThat(commonSuperClass).isEqualTo(internalName(ClassWriterBaseSibling.class));\n    }\n\n    private static String internalName(Class<?> type) {\n        return type.getName().replace('.', '/');\n    }\n\n    private static final class ExposingClassWriter extends ClassWriter {\n        private ExposingClassWriter() {\n            super(0);\n        }\n\n        private String commonSuperClass(String leftType, String rightType) {\n            return super.getCommonSuperClass(leftType, rightType);\n        }\n    }\n}\n\nclass ClassWriterBaseSibling {\n}\n\nfinal class ClassWriterFirstSibling extends ClassWriterBaseSibling {\n}\n\nfinal class ClassWriterSecondSibling extends ClassWriterBaseSibling {\n}\n"}
