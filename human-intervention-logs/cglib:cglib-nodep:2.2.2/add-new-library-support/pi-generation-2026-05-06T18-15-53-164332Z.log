[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ClassWriterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.asm.ClassWriter;\nimport net.sf.cglib.asm.Label;\nimport net.sf.cglib.asm.MethodVisitor;\nimport org.junit.jupiter.api.Test;\n\nimport static net.sf.cglib.asm.Opcodes.ACC_PUBLIC;\nimport static net.sf.cglib.asm.Opcodes.ACC_SUPER;\nimport static net.sf.cglib.asm.Opcodes.ACC_STATIC;\nimport static net.sf.cglib.asm.Opcodes.ALOAD;\nimport static net.sf.cglib.asm.Opcodes.ARETURN;\nimport static net.sf.cglib.asm.Opcodes.DUP;\nimport static net.sf.cglib.asm.Opcodes.GOTO;\nimport static net.sf.cglib.asm.Opcodes.IFEQ;\nimport static net.sf.cglib.asm.Opcodes.ILOAD;\nimport static net.sf.cglib.asm.Opcodes.INVOKESPECIAL;\nimport static net.sf.cglib.asm.Opcodes.NEW;\nimport static net.sf.cglib.asm.Opcodes.RETURN;\nimport static net.sf.cglib.asm.Opcodes.V1_6;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassWriterTest {\n\n    @Test\n    void resolvesCommonSuperclassForApplicationClasses() {\n        ExposingClassWriter writer = new ExposingClassWriter();\n\n        String commonSuperClass = writer.commonSuperClass(\n                internalName(ClassWriterFirstSibling.class),\n                internalName(ClassWriterSecondSibling.class));\n\n        assertThat(commonSuperClass).isEqualTo(internalName(ClassWriterBaseSibling.class));\n    }\n\n    @Test\n    void computesFramesForBranchMergingApplicationClasses() {\n        ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_FRAMES);\n        writer.visit(V1_6, ACC_PUBLIC | ACC_SUPER, \"cglib/cglib_nodep/GeneratedFrameMergeSample\", null,\n                \"java/lang/Object\", null);\n        writeConstructor(writer);\n        writeBranchingFactory(writer);\n        writer.visitEnd();\n\n        byte[] classFile = writer.toByteArray();\n\n        assertThat(classFile).isNotEmpty();\n    }\n\n    private static void writeConstructor(ClassWriter writer) {\n        MethodVisitor constructor = writer.visitMethod(ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(ALOAD, 0);\n        constructor.visitMethodInsn(INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(RETURN);\n        constructor.visitMaxs(0, 0);\n        constructor.visitEnd();\n    }\n\n    private static void writeBranchingFactory(ClassWriter writer) {\n        MethodVisitor method = writer.visitMethod(ACC_PUBLIC | ACC_STATIC, \"create\",\n                \"(Z)L\" + internalName(ClassWriterBaseSibling.class) + \";\", null, null);\n        Label createSecondSibling = new Label();\n        Label returnSibling = new Label();\n\n        method.visitCode();\n        method.visitVarInsn(ILOAD, 0);\n        method.visitJumpInsn(IFEQ, createSecondSibling);\n        method.visitTypeInsn(NEW, internalName(ClassWriterFirstSibling.class));\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, internalName(ClassWriterFirstSibling.class), \"<init>\", \"()V\");\n        method.visitJumpInsn(GOTO, returnSibling);\n        method.visitLabel(createSecondSibling);\n        method.visitTypeInsn(NEW, internalName(ClassWriterSecondSibling.class));\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, internalName(ClassWriterSecondSibling.class), \"<init>\", \"()V\");\n        method.visitLabel(returnSibling);\n        method.visitInsn(ARETURN);\n        method.visitMaxs(0, 0);\n        method.visitEnd();\n    }\n\n    private static String internalName(Class<?> type) {\n        return type.getName().replace('.', '/');\n    }\n\n    private static final class ExposingClassWriter extends ClassWriter {\n        private ExposingClassWriter() {\n            super(0);\n        }\n\n        private String commonSuperClass(String leftType, String rightType) {\n            return super.getCommonSuperClass(leftType, rightType);\n        }\n    }\n}\n\nclass ClassWriterBaseSibling {\n}\n\nfinal class ClassWriterFirstSibling extends ClassWriterBaseSibling {\n}\n\nfinal class ClassWriterSecondSibling extends ClassWriterBaseSibling {\n}\n"}
