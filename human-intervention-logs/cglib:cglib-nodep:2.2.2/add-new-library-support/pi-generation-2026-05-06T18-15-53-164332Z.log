[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/ClassWriterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.asm.ClassWriter;\nimport net.sf.cglib.asm.Label;\nimport net.sf.cglib.asm.MethodVisitor;\nimport org.junit.jupiter.api.Test;\n\nimport static net.sf.cglib.asm.Opcodes.ACC_PUBLIC;\nimport static net.sf.cglib.asm.Opcodes.ACC_SUPER;\nimport static net.sf.cglib.asm.Opcodes.ACC_STATIC;\nimport static net.sf.cglib.asm.Opcodes.ALOAD;\nimport static net.sf.cglib.asm.Opcodes.ARETURN;\nimport static net.sf.cglib.asm.Opcodes.DUP;\nimport static net.sf.cglib.asm.Opcodes.GOTO;\nimport static net.sf.cglib.asm.Opcodes.IFEQ;\nimport static net.sf.cglib.asm.Opcodes.ILOAD;\nimport static net.sf.cglib.asm.Opcodes.INVOKESPECIAL;\nimport static net.sf.cglib.asm.Opcodes.RETURN;\nimport static net.sf.cglib.asm.Opcodes.V1_6;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassWriterTest {\n\n    @Test\n    void computesCommonSuperclassWhileGeneratingStackMapFrames() {\n        ObservingClassWriter writer = new ObservingClassWriter(ClassWriter.COMPUTE_FRAMES);\n        writer.visit(V1_6, ACC_PUBLIC | ACC_SUPER, \"cglib/cglib_nodep/GeneratedFrameSample\", null,\n                \"java/lang/Object\", null);\n        writeConstructor(writer);\n        writeFactoryMethod(writer);\n        writer.visitEnd();\n\n        byte[] classFile = writer.toByteArray();\n\n        assertThat(classFile).isNotEmpty();\n        assertThat(writer.commonSuperClassCalls).isGreaterThanOrEqualTo(1);\n        assertThat(writer.lastCommonSuperClass).isEqualTo(\"java/util/AbstractList\");\n    }\n\n    private static void writeConstructor(ClassWriter writer) {\n        MethodVisitor constructor = writer.visitMethod(ACC_PUBLIC, \"<init>\", \"()V\", null, null);\n        constructor.visitCode();\n        constructor.visitVarInsn(ALOAD, 0);\n        constructor.visitMethodInsn(INVOKESPECIAL, \"java/lang/Object\", \"<init>\", \"()V\");\n        constructor.visitInsn(RETURN);\n        constructor.visitMaxs(0, 0);\n        constructor.visitEnd();\n    }\n\n    private static void writeFactoryMethod(ClassWriter writer) {\n        MethodVisitor method = writer.visitMethod(ACC_PUBLIC | ACC_STATIC, \"createList\",\n                \"(Z)Ljava/util/AbstractList;\", null, null);\n        Label createLinkedList = new Label();\n        Label returnList = new Label();\n\n        method.visitCode();\n        method.visitVarInsn(ILOAD, 0);\n        method.visitJumpInsn(IFEQ, createLinkedList);\n        method.visitTypeInsn(net.sf.cglib.asm.Opcodes.NEW, \"java/util/ArrayList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/ArrayList\", \"<init>\", \"()V\");\n        method.visitJumpInsn(GOTO, returnList);\n        method.visitLabel(createLinkedList);\n        method.visitTypeInsn(net.sf.cglib.asm.Opcodes.NEW, \"java/util/LinkedList\");\n        method.visitInsn(DUP);\n        method.visitMethodInsn(INVOKESPECIAL, \"java/util/LinkedList\", \"<init>\", \"()V\");\n        method.visitLabel(returnList);\n        method.visitInsn(ARETURN);\n        method.visitMaxs(0, 0);\n        method.visitEnd();\n    }\n\n    private static final class ObservingClassWriter extends ClassWriter {\n        private int commonSuperClassCalls;\n        private String lastCommonSuperClass;\n\n        private ObservingClassWriter(int flags) {\n            super(flags);\n        }\n\n        @Override\n        protected String getCommonSuperClass(String leftType, String rightType) {\n            commonSuperClassCalls++;\n            lastCommonSuperClass = super.getCommonSuperClass(leftType, rightType);\n            return lastCommonSuperClass;\n        }\n    }\n}\n"}
