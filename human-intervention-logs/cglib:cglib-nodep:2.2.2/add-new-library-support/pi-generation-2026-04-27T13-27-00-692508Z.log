[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/MethodDelegateInnerGeneratorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.reflect.MethodDelegate;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MethodDelegateInnerGeneratorTest {\n    @Test\n    void createsInstanceDelegateForMatchingTargetMethodSignature() {\n        TextOperations target = new TextOperations(\"metadata-forge\");\n\n        RangeOperation delegate = (RangeOperation) MethodDelegate.create(target, \"slice\", RangeOperation.class);\n\n        assertThat(delegate.apply(0, 8)).isEqualTo(\"metadata\");\n        assertThat(((MethodDelegate) delegate).getTarget()).isSameAs(target);\n    }\n\n    @Test\n    void createsStaticDelegateForMatchingTargetMethodSignature() {\n        BinaryOperation delegate = (BinaryOperation) MethodDelegate.createStatic(\n                MathOperations.class,\n                \"multiply\",\n                BinaryOperation.class);\n\n        assertThat(delegate.apply(6, 7)).isEqualTo(42);\n    }\n\n    public interface RangeOperation {\n        String apply(int start, int end);\n    }\n\n    public interface BinaryOperation {\n        int apply(int left, int right);\n    }\n\n    public static class TextOperations {\n        private final String text;\n\n        public TextOperations(String text) {\n            this.text = text;\n        }\n\n        public String slice(int start, int end) {\n            return text.substring(start, end);\n        }\n    }\n\n    public static class MathOperations {\n        public static int multiply(int left, int right) {\n            return left * right;\n        }\n    }\n}\n"}
