  package cglib.cglib_nodep;
  
  import net.sf.cglib.core.AbstractClassGenerator;
  import net.sf.cglib.core.ClassGenerator;
  import net.sf.cglib.core.GeneratorStrategy;
  import net.sf.cglib.asm.ClassVisitor;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AbstractClassGeneratorTest {
  
      private static final String EXISTING_CLASS_NAME = String.class.getName();
  
      @Test
      void attemptsToLoadClassNameBeforeGeneratingBytecode() {
          TestClassGenerator generator = new TestClassGenerator(
                  AbstractClassGeneratorTest.class.getClassLoader());
          generator.setAttemptLoad(true);
  
          Object created = generator.createWithKey("attempt-load-key");
  
          assertThat(created).isSameAs(String.class);
      }
  
      private static final class TestClassGenerator extends AbstractClassGenerator {
          private static final Source SOURCE = new Source(TestClassGenerator.class.getName());
  
          private final ClassLoader defaultClassLoader;
  
          private TestClassGenerator(ClassLoader classLoader) {
              super(SOURCE);
              this.defaultClassLoader = classLoader;
              setClassLoader(classLoader);
              setUseCache(false);
              setNamingPolicy((prefix, source, key, names) -> EXISTING_CLASS_NAME);
              setStrategy(new StoppingGeneratorStrategy());
          }
  
          private Object createWithKey(Object key) {
              return create(key);
          }
  
          @Override
          public void generateClass(ClassVisitor visitor) {
          }
  
          @Override
          protected ClassLoader getDefaultClassLoader() {
              return defaultClassLoader;
          }
  
          @Override
          protected Object firstInstance(Class type) {
              return type;
          }
  
          @Override
          protected Object nextInstance(Object instance) {
              return instance;
          }
      }
  
      private static final class StoppingGeneratorStrategy implements GeneratorStrategy {
          @Override
          public byte[] generate(ClassGenerator classGenerator) {
              throw new GenerationStoppedException();
          }
      }
  
      private static final class GenerationStoppedException extends RuntimeException {
      }
  }
