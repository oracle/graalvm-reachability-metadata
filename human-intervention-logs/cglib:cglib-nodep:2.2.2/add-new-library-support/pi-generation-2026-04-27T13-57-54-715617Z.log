  new file mode 100644
  index 0000000000..a0c8fc49e6
  --- /dev/null
  +++ i/tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/BulkBeanTest.java
  @@ -0,0 +1,155 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package cglib.cglib_nodep;
  +
  +import net.sf.cglib.beans.BulkBean;
  +import net.sf.cglib.beans.BulkBeanException;
  +import org.junit.jupiter.api.MethodOrderer;
  +import org.junit.jupiter.api.Order;
  +import org.junit.jupiter.api.Test;
  +import org.junit.jupiter.api.TestMethodOrder;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +import static org.assertj.core.api.Assertions.assertThatThrownBy;
  +
  +@TestMethodOrder(MethodOrderer.OrderAnnotation.class)
  +public class BulkBeanTest {
  +    private static final String[] GETTERS = {
  +        "getName",
  +        "getAge",
  +        "isActive",
  +        "getScore",
  +        "getCode"
  +    };
  +    private static final String[] SETTERS = {
  +        "setName",
  +        "setAge",
  +        "setActive",
  +        "setScore",
  +        "setCode"
  +    };
  +    private static final Class[] TYPES = {
  +        String.class,
  +        Integer.TYPE,
  +        Boolean.TYPE,
  +        Long.class,
  +        Character.TYPE
  +    };
  +
  +    @Test
  +    @Order(1)
  +    void initializesPublicGenerator() {
  +        BulkBean.Generator generator = new BulkBean.Generator();
  +
  +        assertThat(generator).isNotNull();
  +    }
  +
  +    @Test
  +    @Order(2)
  +    void createsBulkAccessorThroughConfiguredGenerator() {
  +        BulkBean.Generator generator = new BulkBean.Generator();
  +        generator.setTarget(RecordBean.class);
  +        generator.setGetters(GETTERS);
  +        generator.setSetters(SETTERS);
  +        generator.setTypes(TYPES);
  +
  +        BulkBean bulkBean = generator.create();
  +
  +        assertThat(bulkBean.getGetters()).containsExactly(GETTERS);
  +        assertThat(bulkBean.getSetters()).containsExactly(SETTERS);
  +        assertThat(bulkBean.getPropertyTypes()).containsExactly(TYPES);
  +    }
  +
  +    @Test
  +    @Order(3)
  +    void readsAndWritesBeanPropertiesInBulk() {
  +        BulkBean bulkBean = BulkBean.create(RecordBean.class, GETTERS, SETTERS, TYPES);
  +        RecordBean bean = new RecordBean();
  +        Object[] values = {"Ada", 37, true, 99L, 'G'};
  +
  +        bulkBean.setPropertyValues(bean, values);
  +        Object[] actualValues = bulkBean.getPropertyValues(bean);
  +
  +        assertThat(actualValues).containsExactly(values);
  +        assertThat(bean.getName()).isEqualTo("Ada");
  +        assertThat(bean.getAge()).isEqualTo(37);
  +        assertThat(bean.isActive()).isTrue();
  +        assertThat(bean.getScore()).isEqualTo(99L);
  +        assertThat(bean.getCode()).isEqualTo('G');
  +    }
  +
  +    @Test
  +    @Order(4)
  +    void reportsAccessorValidationFailuresWithPropertyIndex() {
  +        Class[] mismatchedTypes = TYPES.clone();
  +        mismatchedTypes[1] = Long.TYPE;
  +
  +        assertThatThrownBy(() -> BulkBean.create(RecordBean.class, GETTERS, SETTERS, mismatchedTypes))
  +            .isInstanceOf(BulkBeanException.class)
  +            .satisfies(throwable -> assertThat(((BulkBeanException) throwable).getIndex()).isEqualTo(1));
  +    }
  +
  +    @Test
  +    @Order(5)
  +    void reportsSetterFailuresWithPropertyIndex() {
  +        BulkBean bulkBean = BulkBean.create(RecordBean.class, GETTERS, SETTERS, TYPES);
  +        RecordBean bean = new RecordBean();
  +        Object[] values = {"Grace", 42, true, new Object(), 'H'};
  +
  +        assertThatThrownBy(() -> bulkBean.setPropertyValues(bean, values))
  +            .isInstanceOf(BulkBeanException.class)
  +            .satisfies(throwable -> assertThat(((BulkBeanException) throwable).getIndex()).isEqualTo(3));
  +    }
  +
  +    public static class RecordBean {
  +        private String name;
  +        private int age;
  +        private boolean active;
  +        private Long score;
  +        private char code;
  +
  +        public String getName() {
  +            return name;
  +        }
  +
  +        public void setName(String name) {
  +            this.name = name;
  +        }
  +
  +        public int getAge() {
  +            return age;
  +        }
  +
  +        public void setAge(int age) {
  +            this.age = age;
  +        }
  +
  +        public boolean isActive() {
  +            return active;
  +        }
  +
  +        public void setActive(boolean active) {
  +            this.active = active;
  +        }
  +
  +        public Long getScore() {
  +            return score;
  +        }
  +
  +        public void setScore(Long score) {
  +            this.score = score;
  +        }
  +
  +        public char getCode() {
  +            return code;
  +        }
  +
  +        public void setCode(char code) {
  +            this.code = code;
  +        }
  +    }
  +}
