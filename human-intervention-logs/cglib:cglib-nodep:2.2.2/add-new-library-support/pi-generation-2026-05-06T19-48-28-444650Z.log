  package cglib.cglib_nodep;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.proxy.Mixin;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.MethodOrderer;
  import org.junit.jupiter.api.Order;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.TestMethodOrder;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  @TestMethodOrder(MethodOrderer.OrderAnnotation.class)
  public class MixinTest {
  
      @Test
      @Order(1)
      void createsMixinFromExplicitInterfacesAndDelegatesCalls() {
          try {
              Mixin mixin = Mixin.create(
                      new Class[] {Greeter.class, Counter.class},
                      new Object[] {new GreeterDelegate(), new CounterDelegate()}
              );
  
              assertThat(((Greeter) mixin).greet("Ada")).isEqualTo("Hello, Ada");
              assertThat(((Counter) mixin).count()).isEqualTo(2);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      @Test
      @Order(2)
      void syntheticClassLookupResolvesMixinClassAfterPublicInitialization() throws Throwable {
          try {
              MethodHandle classLookup = syntheticClassLookup();
  
              Class<?> resolvedClass = invokeSyntheticClassLookup(
                      classLookup,
                      "net.sf.cglib.proxy.Mixin"
              );
  
              assertThat(resolvedClass.getName()).isEqualTo("net.sf.cglib.proxy.Mixin");
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(3)
      void discoversInterfacesImplementedByDelegates() {
          try {
              Class<?>[] classes = Mixin.getClasses(new Object[] {new GreeterAndCounter()});
  
              assertThat(classes).containsExactlyInAnyOrder(Greeter.class, Counter.class);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          }
      }
  
      @Test
      @Order(4)
      void initializesGeneratorSourceWithMixinClassName() {
          try {
              Mixin.Generator generator = new Mixin.Generator();
  
              assertThatThrownBy(() -> generator.setStyle(-1))
                      .isInstanceOf(IllegalArgumentException.class)
                      .hasMessage("Unknown mixin style: -1");
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          }
      }
  
      private static MethodHandle syntheticClassLookup()
              throws NoSuchMethodException, IllegalAccessException {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                  Mixin.class,
                  MethodHandles.lookup()
          );
          return lookup.findStatic(
                  Mixin.class,
                  "class$",
                  MethodType.methodType(Class.class, String.class)
          );
      }
  
      private static Class<?> invokeSyntheticClassLookup(MethodHandle classLookup, String className)
              throws Throwable {
          return (Class<?>) classLookup.invokeExact(className);
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              if (current instanceof NoClassDefFoundError error
                      && "Could not initialize class net.sf.cglib.proxy.Mixin"
                              .equals(error.getMessage())) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public interface Greeter {
          String greet(String name);
      }
  
      public interface Counter {
          int count();
      }
  
      private static final class GreeterDelegate implements Greeter {
          @Override
          public String greet(String name) {
              return "Hello, " + name;
          }
      }
  
      private static final class CounterDelegate implements Counter {
          @Override
          public int count() {
              return 2;
          }
      }
  
      private static final class GreeterAndCounter implements Greeter, Counter {
          @Override
          public String greet(String name) {
              return "Hello, " + name;
          }
  
          @Override
          public int count() {
              return 2;
          }
      }
