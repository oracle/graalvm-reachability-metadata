ding(error)) {\n                throw error;\n            }\n        } catch (RuntimeException exception) {\n            if (!isUnsupportedNativeImageDynamicClassLoading(exception)) {\n                throw exception;\n            }\n        }\n    }\n\n    @Test\n    void createsStableKeysFromMethodSignatures() throws NoSuchMethodException {\n"}]}
