          CodeEmitter e = super.begin_method(Constants.ACC_PUBLIC, sig, exceptions);
          e.load_this();
          e.getfield(DELEGATE);
          e.load_args();
          e.invoke_virtual(delegateType, sig);
          e.return_value();
          e.end_method();
      }
  }
  
  
  
