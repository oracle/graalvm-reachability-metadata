  package cglib.cglib_nodep;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.util.ArrayList;
  import java.util.List;
  
  import net.sf.cglib.asm.ClassWriter;
  import net.sf.cglib.asm.MethodVisitor;
  import net.sf.cglib.asm.Opcodes;
  import net.sf.cglib.core.ClassEmitter;
  import net.sf.cglib.core.ReflectUtils;
  import net.sf.cglib.proxy.FixedValue;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectUtilsTest {
      private static final String GENERATED_CLASS_NAME = "cglib.cglib_nodep.generated.ReflectUtilsGeneratedType";
  
      @Test
      void resolvesConstructorsAndMethodsFromHumanReadableDescriptors() {
          Constructor<?> constructor = ReflectUtils.findConstructor("String(byte[])");
          assertThat(constructor.getDeclaringClass()).isEqualTo(String.class);
          assertThat(constructor.getParameterTypes()).containsExactly(byte[].class);
  
          Method packageResolvedMethod = ReflectUtils.findMethod("String.substring(int)");
          assertThat(packageResolvedMethod.getDeclaringClass()).isEqualTo(String.class);
          assertThat(packageResolvedMethod.getName()).isEqualTo("substring");
          assertThat(packageResolvedMethod.getParameterTypes()).containsExactly(int.class);
  
          Method fullyQualifiedMethod = ReflectUtils.findMethod("java.lang.String.trim()");
          assertThat(fullyQualifiedMethod.getDeclaringClass()).isEqualTo(String.class);
          assertThat(fullyQualifiedMethod.getName()).isEqualTo("trim");
      }
  
      @Test
      void createsInstancesThroughDeclaredConstructors() {
          Object instance = ReflectUtils.newInstance(ClassEmitter.class);
  
          assertThat(instance).isInstanceOf(ClassEmitter.class);
      }
  
      @Test
      void findsDeclaredMethodsAndCollectsMethodsAcrossTypeHierarchy() throws Exception {
          Method declaredMethod = ReflectUtils.findDeclaredMethod(ClassEmitter.class, "getClassInfo", new Class[0]);
          assertThat(declaredMethod.getDeclaringClass()).isEqualTo(ClassEmitter.class);
  
          List<Method> methods = ReflectUtils.addAllMethods(ClassEmitter.class, new ArrayList<Method>());
          assertThat(methods)
                  .extracting("name")
                  .contains("getClassInfo", "visit", "toString");
      }
  
      @Test
      void findsTheSingleInterfaceMethod() {
          Method method = ReflectUtils.findInterfaceMethod(FixedValue.class);
  
          assertThat(method.getName()).isEqualTo("loadObject");
          assertThat(method.getParameterTypes()).isEmpty();
      }
  
      @Test
      void definesGeneratedClassesWithTheSuppliedClassLoader() throws Exception {
          byte[] bytecode = generateEmptyClass(GENERATED_CLASS_NAME);
  
          Class<?> generatedClass = ReflectUtils.defineClass(
                  GENERATED_CLASS_NAME,
                  bytecode,
                  ReflectUtilsTest.class.getClassLoader());
  
          assertThat(generatedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);
          assertThat(generatedClass.getClassLoader()).isEqualTo(ReflectUtilsTest.class.getClassLoader());
      }
  
      private static byte[] generateEmptyClass(String className) {
          String internalName = className.replace('.', '/');
          ClassWriter writer = new ClassWriter(0);
          writer.visit(
                  Opcodes.V1_5,
                  Opcodes.ACC_PUBLIC | Opcodes.ACC_SUPER,
                  internalName,
                  null,
                  "java/lang/Object",
                  null);
  
          MethodVisitor constructor = writer.visitMethod(Opcodes.ACC_PUBLIC, "<init>", "()V", null, null);
          constructor.visitCode();
          constructor.visitVarInsn(Opcodes.ALOAD, 0);
          constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, "java/lang/Object", "<init>", "()V");
          constructor.visitInsn(Opcodes.RETURN);
          constructor.visitMaxs(1, 1);
          constructor.visitEnd();
  
          writer.visitEnd();
          return writer.toByteArray();
      }
  }
