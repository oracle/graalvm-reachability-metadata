ath,\n                new ClassFilter() {\n                    @Override\n                    public boolean accept(String className) {\n                        return className.equals(MISSING_CLASS_NAME);\n                    }\n                });\n\n        assertThatThrownBy(() -> loader.loadClass(MISSING_CLASS_NAME))\n                .isInstanceOf(ClassNotFoundException.class)\n                .hasMessage(MISSING_CLASS_NAME);\n        assertThat(classPath.requestedResources())\n                .containsExactly(\"cglib/cglib_nodep/generated/MissingType.class\");\n    }\n\n    private static final class TestClassLoader extends AbstractClassLoader {\n        private TestClassLoader(ClassLoader parent, ClassLoader classPath, ClassFilter filter) {\n            super(parent, classPath, filter);\n        }\n    }\n\n    private static final class RecordingClassPath extends ClassLoader {\n        private final List<String> requestedResources = new ArrayList<String>();\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            requestedResources.add(name);\n            return null;\n        }\n\n        private List<String> requestedResources() {\n            return Collections.unmodifiableList(requestedResources);\n        }\n    }\n}\n"}
