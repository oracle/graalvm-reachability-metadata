ing source, Object key, Predicate names) {\n            return className;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof FixedNamingPolicy)) {\n                return false;\n            }\n            FixedNamingPolicy that = (FixedNamingPolicy) other;\n            return className.equals(that.className);\n        }\n\n        @Override\n        public int hashCode() {\n            return className.hashCode();\n        }\n    }\n\n    private static class RecordingClassLoader extends ClassLoader {\n        private final List<String> loadedClassNames = new ArrayList<String>();\n\n        RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            loadedClassNames.add(name);\n            return super.loadClass(name);\n        }\n\n        List<String> loadedClassNames() {\n            return Collections.unmodifiableList(loadedClassNames);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 986, "output": 1219, "cacheRead": 37376, "cacheWrite": 0, "totalTokens": 39581, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777709266115, "responseId": "resp_05cf71fb6fd1f2e00169f5b0d29550819fb71c4bd9cdf087af"}}
