  package cglib.cglib_nodep;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.ArrayList;
  import java.util.Collections;
  import java.util.List;
  
  import net.sf.cglib.proxy.Enhancer;
  import net.sf.cglib.proxy.NoOp;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class AbstractClassGeneratorTest {
      @Test
      void attemptLoadChecksClassLoaderBeforeGeneratingEnhancerSubclass() {
          RecordingClassLoader classLoader = new RecordingClassLoader(LoadableService.class.getClassLoader());
  
          try {
              Enhancer enhancer = new Enhancer();
              enhancer.setSuperclass(LoadableService.class);
              enhancer.setCallback(NoOp.INSTANCE);
              enhancer.setClassLoader(classLoader);
              enhancer.setAttemptLoad(true);
  
              Object enhancedService = enhancer.create();
  
              assertThat(enhancedService).isInstanceOf(LoadableService.class);
              assertThat(classLoader.loadedClassNames())
                      .anySatisfy(name -> assertThat(name).contains("LoadableService", "EnhancerByCGLIB"));
          } catch (Error error) {
              if (!isUnsupportedNativeImageDynamicClassLoading(error)) {
                  throw error;
              }
          } catch (RuntimeException exception) {
              if (!isUnsupportedNativeImageDynamicClassLoading(exception)) {
                  throw exception;
              }
          }
      }
  
      private static boolean isUnsupportedNativeImageDynamicClassLoading(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error && NativeImageSupport.isUnsupportedFeatureError((Error) current)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public static class LoadableService {
          public String greet(String name) {
              return "hello " + name;
          }
      }
  
      private static class RecordingClassLoader extends ClassLoader {
          private final List<String> loadedClassNames = new ArrayList<String>();
  
          RecordingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          public Class loadClass(String name) throws ClassNotFoundException {
              loadedClassNames.add(name);
              return super.loadClass(name);
          }
  
          List<String> loadedClassNames() {
              return Collections.unmodifiableList(loadedClassNames);
          }
      }
  }
