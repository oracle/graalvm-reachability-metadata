  package cglib.cglib_nodep;
  
  import java.io.IOException;
  import java.io.InputStream;
  
  import net.sf.cglib.asm.ClassReader;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassReaderTest {
  
      @Test
      void readsClassBytesUsingSystemResourceLookup() throws IOException {
          String className = "cglib.cglib_nodep.classreader.Fixture";
          String resourceName = "cglib/cglib_nodep/classreader/Fixture.class";
  
          try (InputStream fixture = ClassLoader.getSystemResourceAsStream(resourceName)) {
              assertThat(fixture).isNotNull();
          }
  
          ClassReader reader = new ClassReader(className);
  
          assertThat(reader.getClassName()).isEqualTo("cglib/cglib_nodep/classreader/Fixture");
          assertThat(reader.getSuperName()).isEqualTo("java/lang/Object");
      }
  }
