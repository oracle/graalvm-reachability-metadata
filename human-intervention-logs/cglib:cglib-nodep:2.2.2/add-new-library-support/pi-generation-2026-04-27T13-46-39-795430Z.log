[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/BeanCopierTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport net.sf.cglib.beans.BeanCopier;\nimport net.sf.cglib.core.Converter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BeanCopierTest {\n    @Test\n    void copiesCompatibleBeanPropertiesWithoutConverter() {\n        SourceAccount source = new SourceAccount();\n        source.setName(\"Ada\");\n        source.setAge(37);\n        source.setActive(true);\n        source.setScore(99);\n        TargetAccount target = new TargetAccount();\n        target.setName(\"unchanged\");\n        target.setScore(7);\n\n        BeanCopier copier = BeanCopier.create(SourceAccount.class, TargetAccount.class, false);\n        copier.copy(source, target, null);\n\n        assertThat(target.getName()).isEqualTo(\"Ada\");\n        assertThat(target.getAge()).isEqualTo(37);\n        assertThat(target.isActive()).isTrue();\n        assertThat(target.getScore()).isEqualTo(99);\n        assertThat(target.getTargetOnly()).isEqualTo(\"kept\");\n    }\n\n    @Test\n    void appliesConverterForMatchingPropertiesWithDifferentTypes() {\n        SourceForm source = new SourceForm();\n        source.setName(\"Grace\");\n        source.setAge(\"42\");\n        source.setEnabled(\"yes\");\n        TargetForm target = new TargetForm();\n        RecordingConverter converter = new RecordingConverter();\n\n        BeanCopier copier = BeanCopier.create(SourceForm.class, TargetForm.class, true);\n        copier.copy(source, target, converter);\n\n        assertThat(target.getName()).isEqualTo(\"Grace\");\n        assertThat(target.getAge()).isEqualTo(42);\n        assertThat(target.isEnabled()).isTrue();\n        assertThat(converter.getSetterNames()).contains(\"setName\", \"setAge\", \"setEnabled\");\n    }\n\n    public static class SourceAccount {\n        private String name;\n        private int age;\n        private boolean active;\n        private Integer score;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getAge() {\n            return age;\n        }\n\n        public void setAge(int age) {\n            this.age = age;\n        }\n\n        public boolean isActive() {\n            return active;\n        }\n\n        public void setActive(boolean active) {\n            this.active = active;\n        }\n\n        public Integer getScore() {\n            return score;\n        }\n\n        public void setScore(Integer score) {\n            this.score = score;\n        }\n    }\n\n    public static class TargetAccount {\n        private String name;\n        private int age;\n        private boolean active;\n        private Number score;\n        private String targetOnly = \"kept\";\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getAge() {\n            return age;\n        }\n\n        public void setAge(int age) {\n            this.age = age;\n        }\n\n        public boolean isActive() {\n            return active;\n        }\n\n        public void setActive(boolean active) {\n            this.active = active;\n        }\n\n        public Number getScore() {\n            return score;\n        }\n\n        public void setScore(Number score) {\n            this.score = score;\n        }\n\n        public String getTargetOnly() {\n            return targetOnly;\n        }\n\n        public void setTargetOnly(String targetOnly) {\n            this.targetOnly = targetOnly;\n        }\n    }\n\n    public static class SourceForm {\n        private String name;\n        private String age;\n        private String enabled;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public String getAge() {\n            return age;\n        }\n\n        public void setAge(String age) {\n            this.age = age;\n        }\n\n        public String getEnabled() {\n            return enabled;\n        }\n\n        public void setEnabled(String enabled) {\n            this.enabled = enabled;\n        }\n    }\n\n    public static class TargetForm {\n        private String name;\n        private int age;\n        private boolean enabled;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getAge() {\n            return age;\n        }\n\n        public void setAge(int age) {\n            this.age = age;\n        }\n\n        public boolean isEnabled() {\n            return enabled;\n        }\n\n        public void setEnabled(boolean enabled) {\n            this.enabled = enabled;\n        }\n    }\n\n    private static final class RecordingConverter implements Converter {\n        private final List<String> setterNames = new ArrayList<>();\n\n        @Override\n        public Object convert(Object value, Class target, Object context) {\n            setterNames.add((String) context);\n            if (target.equals(Integer.TYPE)) {\n                return Integer.valueOf((String) value);\n            }\n            if (target.equals(Boolean.TYPE)) {\n                return Boolean.valueOf(\"yes\".equals(value));\n            }\n            return value;\n        }\n\n        private List<String> getSetterNames() {\n            return setterNames;\n        }\n    }\n}\n"}
