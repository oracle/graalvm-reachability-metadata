  package cglib.cglib_nodep;
  
  import java.lang.reflect.Method;
  import java.util.Arrays;
  import java.util.Set;
  
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.core.MethodWrapper;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodWrapperTest {
  
      @Test
      void createsStableKeysForEquivalentMethodSignatures() throws NoSuchMethodException {
          try {
              Method greetMethod = SampleService.class.getMethod("greet", String.class);
              Method equivalentGreetMethod = AlternateService.class.getMethod("greet", String.class);
              Method lengthMethod = SampleService.class.getMethod("length", String.class);
  
              Object greetKey = MethodWrapper.create(greetMethod);
              Object equivalentGreetKey = MethodWrapper.create(equivalentGreetMethod);
              Object lengthKey = MethodWrapper.create(lengthMethod);
  
              assertThat(greetKey).isEqualTo(equivalentGreetKey);
              assertThat(greetKey.hashCode()).isEqualTo(equivalentGreetKey.hashCode());
              assertThat(greetKey).isNotEqualTo(lengthKey);
  
              Set<Object> keys = createMethodKeySet(greetMethod, equivalentGreetMethod, lengthMethod);
              assertThat(keys).containsExactlyInAnyOrder(greetKey, lengthKey);
          } catch (Error error) {
              if (findUnsupportedFeatureError(error) == null) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              if (findUnsupportedFeatureError(exception) == null) {
                  throw exception;
              }
          }
      }
  
      @SuppressWarnings("unchecked")
      private static Set<Object> createMethodKeySet(Method... methods) {
          return MethodWrapper.createSet(Arrays.asList(methods));
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public static class SampleService {
          public String greet(String name) {
              return "Hello " + name;
          }
  
          public int length(String value) {
              return value.length();
          }
      }
  
      public static class AlternateService {
          public String greet(String name) {
              return "Hi " + name;
          }
      }
  }
