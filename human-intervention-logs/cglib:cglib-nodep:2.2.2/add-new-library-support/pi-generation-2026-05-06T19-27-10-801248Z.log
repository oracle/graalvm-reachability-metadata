  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodProxyTest {
  
      @Test
      void findsMethodProxyGeneratedForInterceptedMethod() throws Throwable {
          try {
              GreetingTarget target = createInterceptedGreetingTarget();
  
              assertThat(target.greet("Ada")).isEqualTo("intercepted hello Ada");
  
              Signature signature = TypeUtils.parseSignature("String greet(String)");
              MethodProxy methodProxy = MethodProxy.find(target.getClass(), signature);
  
              assertThat(methodProxy).isNotNull();
              assertThat(methodProxy.getSignature()).isEqualTo(signature);
              assertThat(methodProxy.invokeSuper(target, new Object[] {"Grace"})).isEqualTo("hello Grace");
          } catch (Error error) {
              if (!isUnsupportedNativeFailure(error)) {
                  throw error;
