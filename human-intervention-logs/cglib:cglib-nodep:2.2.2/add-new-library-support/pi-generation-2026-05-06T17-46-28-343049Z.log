[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/InterfaceMakerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.io.IOException;\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.core.CodeGenerationException;\nimport net.sf.cglib.proxy.InterfaceMaker;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InterfaceMakerTest {\n\n    @Test\n    void createsInterfaceFromPublicMethodsOnClass() throws Exception {\n        InterfaceMaker maker = new InterfaceMaker();\n        maker.add(SampleOperations.class);\n\n        try {\n            Class<?> generatedInterface = maker.create();\n\n            assertThat(generatedInterface.isInterface()).isTrue();\n            assertThat(generatedInterface.getMethods()).extracting(Method::getName)\n                    .contains(\"describe\", \"combine\");\n            assertThat(generatedInterface.getMethod(\"describe\", String.class).getExceptionTypes())\n                    .containsExactly(IOException.class);\n            assertThat(generatedInterface.getMethod(\"combine\", int.class, int.class).getReturnType())\n                    .isEqualTo(int.class);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public static class SampleOperations {\n        public String describe(String value) throws IOException {\n            return \"value: \" + value;\n        }\n\n        public int combine(int left, int right) {\n            return left + right;\n        }\n    }\n}\n"}
[tool-call] end id=call_bPkqr7E8mVtRAPTqIOWe9aVU|fc_012fc9f2860bd5f60169fb7e51c8d481a298cf9b58dd17766d name=write args={"path": "tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/InterfaceMakerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport java.io.IOException;\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.core.CodeGenerationException;\nimport net.sf.cglib.proxy.InterfaceMaker;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InterfaceMakerTest {\n\n    @Test\n    void createsInterfaceFromPublicMethodsOnClass() throws Exception {\n        InterfaceMaker maker = new InterfaceMaker();\n        maker.add(SampleOperations.class);\n\n        try {\n            Class<?> generatedInterface = maker.create();\n\n            assertThat(generatedInterface.isInterface()).isTrue();\n            assertThat(generatedInterface.getMethods()).extracting(Method::getName)\n                    .contains(\"describe\", \"combine\");\n            assertThat(generatedInterface.getMethod(\"describe\", String.class).getExceptionTypes())\n                    .containsExactly(IOException.class);\n            assertThat(generatedInterface.getMethod(\"combine\", int.class, int.class).getReturnType())\n                    .isEqualTo(int.class);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public static class SampleOperations {\n        public String describe(String value) throws IOException {\n            return \"value: \" + value;\n        }\n\n        public int combine(int left, int right) {\n            return left + right;\n        }\n    }\n}\n"}
