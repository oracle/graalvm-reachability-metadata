  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProxyTest {
  
      @Test
      void createsProxyInstanceWithInvocationHandlerConstructor() {
          InvocationHandler handler = new DispatchingInvocationHandler();
  
          try {
              Object proxy = Proxy.newProxyInstance(
                      ProxyTest.class.getClassLoader(),
                      new Class<?>[] {GreetingService.class, Adder.class},
                      handler
              );
  
              assertThat(proxy).isInstanceOf(GreetingService.class);
              assertThat(proxy).isInstanceOf(Adder.class);
              assertThat(Proxy.isProxyClass(proxy.getClass())).isTrue();
              assertThat(Proxy.getInvocationHandler(proxy)).isSameAs(handler);
              assertThat(((GreetingService) proxy).greet("GraalVM")).isEqualTo("Hello, GraalVM");
              assertThat(((Adder) proxy).add(19, 23)).isEqualTo(42);
              assertThat(proxy.toString()).isEqualTo("cglib proxy");
          } catch (Error error) {
              if (!isUnsupportedNativeFailure(error)) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      private static boolean isUnsupportedNativeFailure(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              if (current instanceof NoClassDefFoundError
                      && "Could not initialize class net.sf.cglib.proxy.Enhancer".equals(current.getMessage())) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
