  package cglib.cglib_nodep;
  
  import java.io.IOException;
  import java.lang.reflect.Method;
  
  import net.sf.cglib.core.CodeGenerationException;
  import net.sf.cglib.proxy.InterfaceMaker;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InterfaceMakerTest {
  
      @Test
      void createsInterfaceFromPublicMethodsOnClass() throws Exception {
          InterfaceMaker maker = new InterfaceMaker();
          maker.add(SampleOperations.class);
  
          try {
              Class<?> generatedInterface = maker.create();
  
              assertThat(generatedInterface.isInterface()).isTrue();
              assertThat(generatedInterface.getMethods()).extracting(Method::getName)
                      .contains("describe", "combine");
              assertThat(generatedInterface.getMethod("describe", String.class).getExceptionTypes())
                      .containsExactly(IOException.class);
              assertThat(generatedInterface.getMethod("combine", int.class, int.class).getReturnType())
                      .isEqualTo(int.class);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (CodeGenerationException exception) {
              Error error = findUnsupportedFeatureError(exception);
              if (error == null) {
                  throw exception;
              }
          }
      }
  
      private static Error findUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return error;
              }
              current = current.getCause();
          }
          return null;
      }
  
      public static class SampleOperations {
          public String describe(String value) throws IOException {
              return "value: " + value;
          }
  
          public int combine(int left, int right) {
              return left + right;
          }
      }
  }
