Support;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MixinEverythingEmitterTest {\n\n    @Test\n    void createsEverythingStyleMixinFromConcreteDelegates() {\n        try {\n            Mixin.Generator generator = new Mixin.Generator();\n            generator.setStyle(Mixin.STYLE_EVERYTHING);\n            generator.setDelegates(new Object[] {new NameDelegate(), new AgeDelegate()});\n\n            Mixin mixin = generator.create();\n\n            assertThat(mixin).isInstanceOf(Named.class);\n            assertThat(((Named) mixin).name()).isEqualTo(\"Ada\");\n        } catch (Error error) {\n            if (findUnsupportedFeatureError(error) == null) {\n                throw error;\n            }\n        } catch (CodeGenerationException exception) {\n            Error error = findUnsupportedFeatureError(exception);\n            if (error == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return error;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    public interface Named {\n        String name();\n    }\n\n    public static class NameDelegate implements Named {\n        @Override\n        public String name() {\n            return \"Ada\";\n        }\n\n        public String getDescription() {\n            return \"primary delegate\";\n        }\n    }\n\n    public static class AgeDelegate {\n        public int getAge() {\n            return 37;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 763, "output": 583, "cacheRead": 26112, "cacheWrite": 0, "totalTokens