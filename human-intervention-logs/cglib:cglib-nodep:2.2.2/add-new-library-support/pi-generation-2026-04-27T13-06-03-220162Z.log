isitInsn(Opcodes.RETURN);\n        constructor.visitMaxs(1, 1);\n        constructor.visitEnd();\n\n        writer.visitEnd();\n        return writer.toByteArray();\n    }\n}\n"}], "isError": false, "timestamp": 1777295125609}}
