[tool-call] delta {"path":"tests/src/cglib/cglib-nodep/2.2.2/src/test/java/cglib/cglib_nodep/AddDelegateTransformerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib_nodep;\n\nimport net.sf.cglib.transform.ClassFilter;\nimport net.sf.cglib.transform.ClassTransformer;\nimport net.sf.cglib.transform.ClassTransformerFactory;\nimport net.sf.cglib.transform.TransformingClassLoader;\nimport net.sf.cglib.transform.impl.AddDelegateTransformer;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AddDelegateTransformerTest {\n    @Test\n    void addsDelegateInterfaceMethodsToTransformedClass() throws Exception {\n        Class<?> transformedClass = loadWithDelegateTransformer(PlainTarget.class);\n        Object transformedInstance = transformedClass.getConstructor().newInstance();\n\n        assertThat(transformedInstance).isInstanceOf(DelegatedOperations.class);\n\n        DelegatedOperations operations = (DelegatedOperations) transformedInstance;\n        assertThat(operations.owner()).isSameAs(transformedInstance);\n        assertThat(operations.describe(\"Ada\")).isEqualTo(\"delegate for Ada\");\n    }\n\n    private static Class<?> loadWithDelegateTransformer(Class<?> targetClass) throws ClassNotFoundException {\n        ClassFilter targetOnlyFilter = new ClassFilter() {\n            @Override\n            public boolean accept(String name) {\n                return targetClass.getName().equals(name);\n            }\n        };\n        ClassTransformerFactory transformerFactory = new ClassTransformerFactory() {\n            @Override\n            public ClassTransformer newInstance() {\n                return new AddDelegateTransformer(\n                        new Class[] { DelegatedOperations.class },\n                        DelegateImplementation.class);\n            }\n        };\n        TransformingClassLoader loader = new TransformingClassLoader(\n                AddDelegateTransformerTest.class.getClassLoader(),\n                targetOnlyFilter,\n                transformerFactory);\n        return loader.loadClass(targetClass.getName());\n    }\n\n    public interface DelegatedOperations {\n        Object owner();\n\n        String describe(String name);\n    }\n\n    public static class DelegateImplementation implements DelegatedOperations {\n        private final Object owner;\n\n        public DelegateImplementation(Object owner) {\n            this.owner = owner;\n        }\n\n        @Override\n        public Object owner() {\n            return owner;\n        }\n\n        @Override\n        public String describe(String name) {\n            return \"delegate for \" + name;\n        }\n    }\n\n    public static class PlainTarget {\n        public PlainTarget() {\n        }\n    }\n}\n"}
