  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package cglib.cglib_nodep;
  
  import java.lang.reflect.Method;
  
  import net.sf.cglib.proxy.Callback;
  import net.sf.cglib.proxy.Enhancer;
  import net.sf.cglib.proxy.MethodInterceptor;
  import net.sf.cglib.proxy.MethodProxy;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class EnhancerTest {
      @Test
      void createsEnhancedSubclassAndDispatchesThroughMethodInterceptor() {
          Enhancer enhancer = new Enhancer();
          enhancer.setSuperclass(GreetingService.class);
          enhancer.setCallback(new PrefixingInterceptor("proxied"));
  
          GreetingService service = (GreetingService) enhancer.create();
  
          assertThat(Enhancer.isEnhanced(service.getClass())).isTrue();
          assertThat(service.greet("Ada")).isEqualTo("proxied Ada");
          assertThat(service.describe()).isEqualTo("service");
      }
  
      @Test
      void createsEnhancedInstanceWithConstructorArguments() {
          Enhancer enhancer = new Enhancer();
          enhancer.setSuperclass(ConstructedGreetingService.class);
          enhancer.setCallback(new PrefixingInterceptor("native"));
  
          ConstructedGreetingService service = (ConstructedGreetingService) enhancer.create(
                  new Class[] { String.class },
                  new Object[] { "original" });
  
          assertThat(service.greet("Bob")).isEqualTo("native Bob");
          assertThat(service.describe()).isEqualTo("original");
      }
  
      @Test
      void createsReusableEnhancedClassAndRegistersStaticCallbacks() {
          Enhancer enhancer = new Enhancer();
          enhancer.setSuperclass(GreetingService.class);
          enhancer.setCallbackType(MethodInterceptor.class);
  
          Class<?> enhancedType = enhancer.createClass();
  
          assertThat(Enhancer.isEnhanced(enhancedType)).isTrue();
          Enhancer.registerStaticCallbacks(enhancedType, new Callback[] { new PrefixingInterceptor("static") });
      }
  
      public static class GreetingService {
          public String greet(String name) {
              return "hello " + name;
          }
  
          public String describe() {
              return "service";
          }
      }
  
      public static class ConstructedGreetingService {
          private final String description;
  
          public ConstructedGreetingService(String description) {
              this.description = description;
          }
  
          public String greet(String name) {
              return "hello " + name;
          }
  
          public String describe() {
              return description;
          }
      }
  
      private static final class PrefixingInterceptor implements MethodInterceptor {
          private final String prefix;
  
          private PrefixingInterceptor(String prefix) {
              this.prefix = prefix;
          }
  
          @Override
          public Object intercept(
                  Object object,
                  Method method,
                  Object[] arguments,
                  MethodProxy methodProxy) throws Throwable {
              if ("greet".equals(method.getName())) {
                  return prefix + " " + arguments[0];
              }
              return methodProxy.invokeSuper(object, arguments);
          }
      }
