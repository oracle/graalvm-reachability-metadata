  package cglib.cglib_nodep;
  
  import net.sf.cglib.asm.ClassReader;
  import net.sf.cglib.asm.ClassWriter;
  import net.sf.cglib.asm.Opcodes;
  import net.sf.cglib.asm.Type;
  import net.sf.cglib.transform.impl.AddDelegateTransformer;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AddDelegateTransformerTest {
  
      @Test
      void addsDelegateInterfaceAndMethodsToGeneratedClass() {
          AddDelegateTransformer transformer = new AddDelegateTransformer(
                  new Class[] {DelegateContract.class},
                  DelegateImplementation.class
          );
          ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);
          transformer.setTarget(writer);
  
          transformer.begin_class(
                  Opcodes.V1_7,
                  Opcodes.ACC_PUBLIC,
                  "cglib.cglib_nodep.AddDelegateGenerated",
                  Type.getType(Object.class),
                  new Type[0],
                  "AddDelegateGenerated.java"
          );
          transformer.end_class();
  
          ClassReader reader = new ClassReader(writer.toByteArray());
          assertThat(reader.getClassName()).isEqualTo("cglib/cglib_nodep/AddDelegateGenerated");
          assertThat(reader.getInterfaces()).contains("cglib/cglib_nodep/AddDelegateTransformerTest$DelegateContract");
      }
  
      public interface DelegateContract {
          String greet(String name);
  
          Object target();
      }
  
      public static class DelegateImplementation implements DelegateContract {
          private final Object target;
  
          public DelegateImplementation(Object target) {
              this.target = target;
          }
  
          @Override
          public String greet(String name) {
              return "Hello, " + name;
          }
  
          @Override
          public Object target() {
              return target;
          }
      }
  }
