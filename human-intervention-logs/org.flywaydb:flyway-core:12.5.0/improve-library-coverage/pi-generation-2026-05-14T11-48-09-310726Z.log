  package flyway;
  
  import java.util.List;
  
  import org.flywaydb.core.internal.configuration.ConfigUtils;
  import org.flywaydb.core.internal.configuration.models.FlywayModel;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConfigUtilsTest {
  
      @Test
      void suggestsNamespaceForUnknownConfigurationExtensionField() {
          final List<String> possibleConfigurations = ConfigUtils.getPossibleFlywayConfigurations(
                  "root",
                  FlywayModel.defaults(),
                  "flyway.");
  
          assertThat(possibleConfigurations).contains("integration.root");
      }
  }
