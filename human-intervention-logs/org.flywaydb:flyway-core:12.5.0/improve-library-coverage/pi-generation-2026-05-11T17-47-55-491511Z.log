[tool-call] delta {"path":"tests/src/org.flywaydb/flyway-core/11.14.1/src/test/java/flyway/ClassPathScannerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage flyway;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.flywaydb.core.api.Location;\nimport org.flywaydb.core.api.callback.Callback;\nimport org.flywaydb.core.api.resource.LoadableResource;\nimport org.flywaydb.core.internal.scanner.LocationScannerCache;\nimport org.flywaydb.core.internal.scanner.ResourceNameCache;\nimport org.flywaydb.core.internal.scanner.classpath.ClassPathScanner;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassPathScannerTest {\n    private static final String LOCATION = \"db/migration\";\n    private static final String MIGRATION = LOCATION + \"/V1__scanner_test.sql\";\n\n    @TempDir\n    Path classPathRoot;\n\n    @Test\n    void scansResourcesFromClassLoaderLocationEnumeration() throws IOException {\n        Path migrationDirectory = classPathRoot.resolve(\"db\").resolve(\"migration\");\n        Files.createDirectories(migrationDirectory);\n        Files.writeString(migrationDirectory.resolve(\"V1__scanner_test.sql\"), \"select 1;\", StandardCharsets.UTF_8);\n\n        ClassLoader classLoader = new FixedLocationClassLoader(classPathRoot);\n        ClassPathScanner<Callback> scanner = new ClassPathScanner<>(\n                Callback.class,\n                classLoader,\n                StandardCharsets.UTF_8,\n                new Location(\"classpath:\" + LOCATION),\n                new ResourceNameCache(),\n                new LocationScannerCache(),\n                true,\n                false);\n\n        List<String> resourcePaths = scanner.scanForResources().stream()\n                .map(LoadableResource::getAbsolutePath)\n                .toList();\n\n        assertThat(resourcePaths).containsExactly(MIGRATION);\n    }\n\n    private static final class FixedLocationClassLoader extends ClassLoader {\n        private final Path classPathRoot;\n\n        private FixedLocationClassLoader(Path classPathRoot) {\n            this.classPathRoot = classPathRoot;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            Path resource = resolveResource(name);\n            if (!Files.exists(resource)) {\n                return Collections.emptyEnumeration();\n            }\n            return Collections.enumeration(List.of(toScannerUrl(resource)));\n        }\n\n        private Path resolveResource(String name) {\n            Path resource = classPathRoot;\n            for (String part : name.split(\"/\")) {\n                resource = resource.resolve(part);\n            }\n            return resource;\n        }\n\n        private URL toScannerUrl(Path resource) throws IOException {\n            String url = resource.toUri().toURL().toExternalForm();\n            if (Files.isDirectory(resource) && url.endsWith(\"/\")) {\n                return new URL(url.substring(0, url.length() - 1));\n            }\n            return new URL(url);\n        }\n    }\n}\n"}
