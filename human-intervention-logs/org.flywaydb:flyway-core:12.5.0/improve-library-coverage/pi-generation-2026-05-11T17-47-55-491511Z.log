     285	                        + ")"
     286	                        + " On WebSphere an empty file named flyway.location must be present on the classpath location for WebSphere to find it!");
     287	                }
     288	                while (urls.hasMoreElements()) {
     289	                    final URL url = urls.nextElement();
     290	                    locationUrls.add(new URL(UrlUtils.decodeURL(url.toExternalForm()).replace("/flyway.location", "")));
