  package flyway;
  
  import java.io.IOException;
  import java.net.URL;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collections;
  import java.util.Enumeration;
  import javax.sql.DataSource;
  
  import org.flywaydb.core.Flyway;
  import org.flywaydb.core.api.configuration.Configuration;
  import org.flywaydb.core.api.configuration.FluentConfiguration;
  import org.flywaydb.core.api.output.MigrateResult;
  import org.h2.jdbcx.JdbcDataSource;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassPathScannerTest {
      private static final String LOCATION = "db/migration";
      private static final String MIGRATION = LOCATION + "/V1__scanner_test.sql";
  
      @TempDir
      Path classPathRoot;
  
      @Test
      void scansResourcesFromClassLoaderLocationEnumeration() throws IOException {
          Path migrationDirectory = classPathRoot.resolve("db").resolve("migration");
          Files.createDirectories(migrationDirectory);
          Files.writeString(migrationDirectory.resolve("V1__scanner_test.sql"), """
                  create table scanner_test (
                      id int primary key
                  );
                  """, StandardCharsets.UTF_8);
  
          ClassLoader classLoader = new FixedLocationClassLoader(classPathRoot, getClass().getClassLoader());
          Configuration configuration = new FluentConfiguration(classLoader)
                  .dataSource(getDataSource())
                  .encoding(StandardCharsets.UTF_8)
                  .locations("classpath:" + LOCATION);
  
          MigrateResult result = new Flyway(configuration).migrate();
  
          assertThat(result.success).isTrue();
          assertThat(result.migrationsExecuted).isEqualTo(1);
      }
  
      private DataSource getDataSource() {
          JdbcDataSource dataSource = new JdbcDataSource();
          dataSource.setUrl("jdbc:h2:mem:class-path-scanner;DB_CLOSE_DELAY=-1");
          dataSource.setUser("user");
          dataSource.setPassword("password");
          return dataSource;
      }
  
      private static final class FixedLocationClassLoader extends ClassLoader {
          private final Path classPathRoot;
  
          private FixedLocationClassLoader(Path classPathRoot) {
              this.classPathRoot = classPathRoot;
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              Path resource = resolveResource(name);
              if (!Files.exists(resource)) {
                  return Collections.emptyEnumeration();
              }
              return Collections.enumeration(List.of(toScannerUrl(resource)));
          }
  
          private Path resolveResource(String name) {
              Path resource = classPathRoot;
              for (String part : name.split("/")) {
                  resource = resource.resolve(part);
              }
              return resource;
          }
  
          private URL toScannerUrl(Path resource) throws IOException {
              String url = resource.toUri().toURL().toExternalForm();
              if (Files.isDirectory(resource) && url.endsWith("/")) {
                  return new URL(url.substring(0, url.length() - 1));
              }
              return new URL(url);
          }
      }
  }
