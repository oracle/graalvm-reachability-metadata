            <sourceFileIncludes>
              <sourceFileInclude>**/core/Flyway.java</sourceFileInclude>
              <sourceFileInclude>**/core/api/**/*.java</sourceFileInclude>
            </sourceFileIncludes>
          </configuration>
        </plugin>
      </plugins>
    </reporting>
