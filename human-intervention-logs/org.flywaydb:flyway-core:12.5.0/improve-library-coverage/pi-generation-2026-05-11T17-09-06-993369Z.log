                  Field field = Arrays.stream(declaredFields)
                      .filter(f -> f.getName().equals(path[0]))
                      .findFirst()
                      .orElse(null);
                  try {
                      currentConfigExtension = field.getType().getDeclaredConstructor().newInstance();
