        node
          .asInstanceOf[I[Any]]
          .map { (e: Any) =>
            e match {
              case optElem: Option[_] =>
                optElem.map(elem => delegate.fromResult(elem.asInstanceOf[delegate.marshaller.Node]))
              case elem =>
                delegate.fromResult(elem.asInstanceOf[delegate.marshaller.Node])
            }
          }
          .asInstanceOf[I[T]]
