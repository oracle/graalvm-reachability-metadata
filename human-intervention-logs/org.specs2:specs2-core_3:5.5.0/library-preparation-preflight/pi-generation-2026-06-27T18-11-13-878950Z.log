foreach(db.createUser) db.listAllUsers.map(_.name).toSet === Set("me", "you") // create a database before running anything def beforeSpec = createDatabase(databaseUrl) // remove all data before running an example def before = cleanDatabase(databaseUrl) Previous Next $("#navigation").load("https://etorreborre.github.io/specs2/website/SPECS2-5.9.1/nav.html"); 
  
