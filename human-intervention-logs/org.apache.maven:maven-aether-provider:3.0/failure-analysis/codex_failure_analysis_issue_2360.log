eResolver;\\nimport org.sonatype.aether.impl.VersionResolver;\\nimport org.sonatype.aether.installation.InstallRequest;\\nimport org.sonatype.aether.metadata.Metadata;\\nimport org.sonatype.aether.repository.RemoteRepository;\\nimport org.sonatype.aether.resolution.MetadataRequest;\\nimport org.sonatype.aether.resolution.MetadataResult;\\nimport org.sonatype.aether.resolution.VersionRangeRequest;\\nimport org.sonatype.aether.resolution.VersionRangeResult;\\nimport org.sonatype.aether.resolution.VersionRequest;\\nimport org.sonatype.aether.resolution.VersionResult;\\nimport org.sonatype.aether.util.artifact.DefaultArtifact;\\nimport org.sonatype.aether.version.Version;\\n\\npublic class Maven_aether_providerTest {\\n    private static final String GROUP_ID = \\\"org.example\\\";\\n    private static final String ARTIFACT_ID = \\\"demo\\\";\\n    private static final String CONTEXT = \\\"test-context\\\";\\n\\n    @TempDir\\n    Path tempDir;\\n\\n    @Test\\n    void mavenRepositorySystemSessionExposesInheritedRepositorySettings() {\\n        MavenRepositorySystemSession session = new MavenRepositorySystemSession();\\n\\n        session.setOffline(true)\\n                .setChecksumPolicy(\\\"fail\\\")\\n                .setUpdatePolicy(\\\"always\\\")\\n                .setSystemProperty(\\\"java.version\\\", \\\"test-jdk\\\")\\n                .setUserProperty(\\\"profile\\\", \\\"native\\\")\\n                .setConfigProperty(\\\"maven.metadata.legacy\\\", Boolean.TRUE);\\n\\n        assertThat(session.isOffline()).isTrue();\\n        assertThat(session.getChecksumPolicy()).isEqualTo(\\\"fail\\\");\\n        assertThat(session.getUpdatePolicy()).isEqualTo(\\\"always\\\");\\n        assertThat(session.getSystemProperties()).containsEntry(\\\"java.version\\\", \\\"test-jdk\\\");\\n        assertThat(session.getUserProperties()).containsEntry(\\\"profile\\\", \\\"native\\\");\\n        assertThat(session.getConfigProperties()).containsEntry(\\\"maven.metadata.legacy\\\", Boolean.TRUE);\\n    }\\n\\n    @Test\\n    void defaultServiceLocatorProvidesMavenAetherServices() {\\n        DefaultServiceLocator locator = new DefaultServiceLocator();\\n        RecordingMetadataResolver metadataResolver = new RecordingMetadataResolver(Map.of());\\n        locator.setServices(MetadataResolver.class, metadataResolver);\\n\\n        assertThat(locator.getService(VersionResolver.class)).isInstanceOf(DefaultVersionResolver.class);\\n        assertThat(locator.getService(VersionRangeResolver.class)).isInstanceOf(DefaultVersionRangeResolver.class);\\n        assertThat(locator.getService(ArtifactDescriptorReader.class)).isNotNull();\\n\\n        List<MetadataGeneratorFactory> factories = locator.getServices(MetadataGeneratorFactory.class);\\n        assertThat(factories).hasSize(2);\\n        assertThat(factories).extracting(MetadataGeneratorFactory::getPriority).containsExactlyInAnyOrder(10, 5);\\n    }\\n\\n    @Test\\n    void versionRangeResolverReadsMetadataAndFiltersSortedVersions() throws Exception {\\n        Path metadataFile = writeMetadata(\\\"\\\"\\\"\\n                <metadata>\\n                  <groupId>org.example</groupId>\\n                  <artifactId>demo</artifactId>\\n                  <versioning>\\n                    <versions>\\n                      <version>0.9</version>\\n                      <version>1.0</version>\\n                      <version>1.1</version>\\n                      <version>2.0</version>\\n                    </versions>\\n                    <lastUpdated>20200101000000</lastUpdated>\\n                  </versioning>\\n                </metadata>\\n                \\\"\\\"\\\");\\n        RecordingMetadataResolver metadataResolver = new RecordingMetadataResolver(Map.of(ARTIFACT_ID, metadataFile));\\n        DefaultVersionRangeResolver resolver = new DefaultVersionRangeResolver().setMetadataResolver(metadataResolver);\\n        Artifact artifact = new DefaultArtifact(GROUP_ID + ':' + ARTIFACT_ID + \\\":[1.0,2.0)\\\");\\n        RemoteRepository central = new RemoteRepository(\\\"central\\\", \\\"default\\\", \\\"file:///unused-repository\\\");\\n        VersionRangeRequest request = new VersionRangeRequest(artifact, List.of(central), CONTEXT);\\n\\n        VersionRangeResult result = resolver.resolveVersionRange(new MavenRepositorySystemSession(), request);\\n\\n        assertThat(result.getVersions()).extracting(Version::toString).containsExactly(\\\"1.0\\\", \\\"1.1\\\");\\n        assertThat(result.getRepository(result.getVersions().get(0))).isNotNull();\\n        assertThat(result.getVersionConstraint().containsVersion(result.getVersions().get(1))).isTrue();\\n        assertThat(metadataResolver.getRequests()).hasSize(2);\\n        assertThat(metadataResolver.getRequests().get(0).getRepository()).isNull();\\n        assertThat(metadataResolver.getRequests().get(1).getRepository()).isSameAs(central);\\n        assertThat(metadataResolver.getRequests().get(1).isDeleteLocalCopyIfMissing()).isTrue();\\n    }\\n\\n    @Test\\n    void versionResolverHandlesReleaseLatestAndTimestampedSnapshots() throws Exception {\\n        Path metadataFile = writeMetadata(\\\"\\\"\\\"\\n                <metadata>\\n                  <groupId>org.example</groupId>\\n                  <artifactId>demo</artifactId>\\n                  <version>2.0-SNAPSHOT</version>\\n                  <versioning>\\n                    <latest>2.0-SNAPSHOT</latest>\\n                    <release>1.1</release>\\n                    <snapshot>\\n                      <timestamp>20200101.010203</timestamp>\\n                      <buildNumber>7</buildNumber>\\n                    </snapshot>\\n                    <snapshotVersions>\\n                      <snapshotVersion>\\n                        <extension>jar</extension>\\n                        <value>2.0-20200101.010203-7</value>\\n                        <updated>20200101010203</updated>\\n                      </snapshotVersion>\\n                    </snapshotVersions>\\n                    <lastUpdated>20200101010203</lastUpdated>\\n                  </versioning>\\n                </metadata>\\n                \\\"\\\"\\\");\\n        RecordingMetadataResolver metadataResolver = new RecordingMetadataResolver(Map.of(ARTIFACT_ID, metadataFile));\\n        DefaultVersionResolver resolver = new DefaultVersionResolver().setMetadataResolver(metadataResolver);\\n        MavenRepositorySystemSession session = new MavenRepositorySystemSession();\\n        RemoteRepository releases = new RemoteRepository(\\\"releases\\\", \\\"default\\\", \\\"file:///releases\\\");\\n\\n        VersionResult release = resolver.resolveVersion(session, versionRequest(\\\"RELEASE\\\", releases));\\n        VersionResult latest = resolver.resolveVersion(session, versionRequest(\\\"LATEST\\\", releases));\\n        VersionResult snapshot = resolver.resolveVersion(session, versionRequest(\\\"2.0-SNAPSHOT\\\", releases));\\n\\n        assertThat(release.getVersion()).isEqualTo(\\\"1.1\\\");\\n        assertThat(release.getRepository()).isSameAs(releases);\\n        assertThat(latest.getVersion()).isEqualTo(\\\"2.0-20200101.010203-7\\\");\\n        assertThat(snapshot.getVersion()).isEqualTo(\\\"2.0-20200101.010203-7\\\");\\n        assertThat(metadataResolver.getRequests()).hasSizeGreaterThanOrEqualTo(6);\\n        assertThat(metadataResolver.getRequests())\\n                .anySatisfy(request -> assertThat(request.isFavorLocalRepository()).isTrue());\\n    }\\n\\n    @Test\\n    void metadataGeneratorFactoriesCreateVersionAndSnapshotMetadataThroughPublicInterfaces() {\\n        MavenRepositorySystemSession session = new MavenRepositorySystemSession();\\n        Artifact release = new DefaultArtifact(GROUP_ID, ARTIFACT_ID, \\\"jar\\\", \\\"1.0\\\");\\n        Artifact snapshot = new DefaultArtifact(GROUP_ID, ARTIFACT_ID, \\\"jar\\\", \\\"1.1-SNAPSHOT\\\");\\n        List<Artifact> artifacts = List.of(release, snapshot);\\n\\n        VersionsMetadataGeneratorFactory versionsFactory = new VersionsMetadataGeneratorFactory();\\n        MetadataGenerator versionsGenerator = versionsFactory.newInstance(session, new InstallRequest());\\n        Collection<? extends Metadata> versionMetadata = versionsGenerator.finish(artifacts);\\n\\n        assertThat(versionsFactory.getPriority()).isEqualTo(5);\\n        assertThat(versionsGenerator.prepare(artifacts)).isEmpty();\\n        assertThat(versionsGenerator.transformArtifact(release)).isSameAs(release);\\n        assertThat(versionMetadata).hasSize(1);\\n        Metadata versions = versionMetadata.iterator().next();\\n        assertThat(versions.getGroupId()).isEqualTo(GROUP_ID);\\n        assertThat(versions.getArtifactId()).isEqualTo(ARTIFACT_ID);\\n        assertThat(versions.getType()).isEqualTo(\\\"maven-metadata.xml\\\");\\n\\n        SnapshotMetadataGeneratorFactory snapshotFactory = new SnapshotMetadataGeneratorFactory();\\n        MetadataGenerator localSnapshots = snapshotFactory.newInstance(session, new InstallRequest());\\n        assertThat(snapshotFactory.getPriority()).isEqualTo(10);\\n        assertThat(localSnapshots.prepare(artifacts)).isEmpty();\\n        assertThat(localSnapshots.finish(artifacts)).singleElement().satisfies(metadata -> {\\n            assertThat(metadata.getGroupId()).isEqualTo(GROUP_ID);\\n            assertThat(metadata.getArtifactId()).isEqualTo(ARTIFACT_ID);\\n            assertThat(metadata.getVersion()).isEqualTo(\\\"1.1-SNAPSHOT\\\");\\n        });\\n\\n        MetadataGenerator remoteSnapshots = snapshotFactory.newInstance(session, new DeployRequest());\\n        Collection<? extends Metadata> remoteMetadata = remoteSnapshots.prepare(artifacts);\\n        Artifact transformedSnapshot = remoteSnapshots.transformArtifact(snapshot);\\n\\n        assertThat(remoteMetadata).hasSize(1);\\n        assertThat(transformedSnapshot.getVersion()).startsWith(\\\"1.1-\\\").doesNotEndWith(\\\"SNAPSHOT\\\");\\n        assertThat(remoteSnapshots.transformArtifact(release)).isSameAs(release);\\n        assertThat(remoteSnapshots.finish(artifacts)).isEmpty();\\n    }\\n\\n    private VersionRequest versionRequest(String version, RemoteRepository repository) {\\n        Artifact artifact = new DefaultArtifact(GROUP_ID, ARTIFACT_ID, \\\"jar\\\", version);\\n        return new VersionRequest(artifact, List.of(repository), CONTEXT);\\n    }\\n\\n    private Path writeMetadata(String content) throws IOException {\\n        Path file = tempDir.resolve(\\\"maven-metadata-\\\" + System.nanoTime() + \\\".xml\\\");\\n        Files.writeString(file, content, StandardCharsets.UTF_8);\\n        return file;\\n    }\\n\\n    private static final class RecordingMetadataResolver implements MetadataResolver {\\n        private final Map<String, Path> metadataFilesByArtifactId;\\n        private final List<MetadataRequest> requests = new ArrayList<>();\\n\\n        RecordingMetadataResolver(Map<String, Path> metadataFilesByArtifactId) {\\n            this.metadataFilesByArtifactId = new LinkedHashMap<>(metadataFilesByArtifactId);\\n        }\\n\\n        @Override\\n        public List<MetadataResult> resolveMetadata(\\n                RepositorySystemSession session, Collection<? extends MetadataRequest> requests) {\\n            List<MetadataResult> results = new ArrayList<>();\\n            for (MetadataRequest request : requests) {\\n                this.requests.add(request);\\n                MetadataResult result = new MetadataResult(request);\\n                Metadata requestedMetadata = request.getMetadata();\\n                Path metadataFile = metadataFilesByArtifactId.get(requestedMetadata.getArtifactId());\\n                if (metadataFile != null) {\\n                    result.setMetadata(requestedMetadata.setFile(metadataFile.toFile()));\\n                }\\n                results.add(result);\\n            }\\n            return results;\\n        }\\n\\n        List<MetadataRequest> getRequests() {\\n            return requests;\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1516, \"output\": 3173, \"cacheRead\": 53760, \"cacheWrite\": 0, \"totalTokens\": 58449, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1778610568381, \"responseId\": \"resp_05e88d989e283b95016a03718a1740819587fd2415a9176e8c\"}}\n22575:[tool-exec] start id=call_bc3IV66TEpk1r4et5SJkmVoM|fc_05e88d989e283b95016a03718ec8b081958207215273f85a9c name=write args={\"path\": \"tests/src/org.apache.maven/maven-aether-provider/3.0/src/test/java/org_apache_maven/maven_aether_provider/Maven_aether_providerTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_maven.maven_aether_provider;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.IOException;\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.util.ArrayList;\\nimport java.util.Collection;\\nimport java.util.LinkedHashMap;\\nimport java.util.List;\\nimport java.util.Map;\\n\\nimport org.apache.maven.repository.internal.DefaultServiceLocator;\\nimport org.apache.maven.repository.internal.DefaultVersionRangeResolver;\\nimport org.apache.maven.repository.internal.DefaultVersionResolver;\\nimport org.apache.maven.repository.internal.MavenRepositorySystemSession;\\nimport org.apache.maven.repository.internal.SnapshotMetadataGeneratorFactory;\\nimport org.apache.maven.repository.internal.VersionsMetadataGeneratorFactory;\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\nimport org.sonatype.aether.RepositorySystemSession;\\