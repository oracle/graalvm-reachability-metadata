           </formset>\\n                </form-validation>\\n                \\\"\\\"\\\";\\n\\n        ValidatorResources resources;\\n        try (InputStream input = new ByteArrayInputStream(validationXml.getBytes(StandardCharsets.UTF_8))) {\\n            resources = new ValidatorResources(input);\\n        }\\n\\n        ValidatorAction action = resources.getValidatorAction(\\\"isbn\\\");\\n        assertThat(action).isNotNull();\\n        assertThat(action.getMethod()).isEqualTo(\\\"isValid\\\");\\n        assertThat(action.getJavascript()).contains(\\\"validateIsbn\\\");\\n\\n        Form form = resources.getForm(Locale.getDefault(), \\\"bookForm\\\");\\n        assertThat(form).isNotNull();\\n        Field field = form.getField(\\\"title\\\");\\n        assertThat(field).isNotNull();\\n        assertThat(field.getDepends()).isEqualTo(\\\"isbn\\\");\\n    }\\n}\\n\"}\nhuman-intervention-logs/commons-validator:commons-validator:1.6/add-new-library-support/pi-generation-2026-05-08T12-42-06-808086Z.log:1883:[tool-call] end id=call_9IKbaT0qvN8dd6X7J46orfAr|fc_0f4d8bc919cb01360169fdda014f4c8190b50e0f5572a07674 name=write args={\"path\": \"tests/src/commons-validator/commons-validator/1.6/src/test/java/commons_validator/commons_validator/ValidatorResourcesTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage commons_validator.commons_validator;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.InputStream;\\nimport java.nio.charset.StandardCharsets;\\nimport java.util.Locale;\\n\\nimport org.apache.commons.validator.Field;\\nimport org.apache.commons.validator.Form;\\nimport org.apache.commons.validator.ValidatorAction;\\nimport org.apache.commons.validator.ValidatorResources;\\nimport org.junit.jupite