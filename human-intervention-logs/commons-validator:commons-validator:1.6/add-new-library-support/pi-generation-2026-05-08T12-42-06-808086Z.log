[tool-call] delta {"path":"tests/src/commons-validator/commons-validator/1.6/src/test/java/commons_validator/commons_validator/ValidatorResourcesTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_validator.commons_validator;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Locale;\n\nimport org.apache.commons.validator.Field;\nimport org.apache.commons.validator.Form;\nimport org.apache.commons.validator.ValidatorAction;\nimport org.apache.commons.validator.ValidatorResources;\nimport org.junit.jupiter.api.Test;\n\npublic class ValidatorResourcesTest {\n    @Test\n    void parsesValidationXmlUsingBundledDigesterRulesAndRegisteredDtdResources() throws Exception {\n        String validationXml = \"\"\"\n                <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n                <!DOCTYPE form-validation PUBLIC\n                    \"-//Apache Software Foundation//DTD Commons Validator Rules Configuration 1.4.0//EN\"\n                    \"http://commons.apache.org/dtds/validator_1_4_0.dtd\">\n                <form-validation>\n                  <global>\n                    <validator name=\"isbn\"\n                               classname=\"org.apache.commons.validator.routines.ISBNValidator\"\n                               method=\"isValid\"\n                               methodParams=\"java.lang.String\"\n                               msg=\"errors.isbn\">\n                      <javascript>function validateIsbn(form) { return true; }</javascript>\n                    </validator>\n                    <constant>\n                      <constant-name>bookTitleLabel</constant-name>\n                      <constant-value>Book title</constant-value>\n                    </constant>\n                  </global>\n                  <formset>\n                    <form name=\"bookForm\">\n                      <field property=\"title\" depends=\"isbn\">\n                        <arg key=\"${bookTitleLabel}\" resource=\"false\"/>\n                      </field>\n                    </form>\n                  </formset>\n                </form-validation>\n                \"\"\";\n\n        ValidatorResources resources;\n        try (InputStream input = new ByteArrayInputStream(validationXml.getBytes(StandardCharsets.UTF_8))) {\n            resources = new ValidatorResources(input);\n        }\n\n        ValidatorAction action = resources.getValidatorAction(\"isbn\");\n        assertThat(action).isNotNull();\n        assertThat(action.getMethod()).isEqualTo(\"isValid\");\n        assertThat(action.getJavascript()).contains(\"validateIsbn\");\n\n        Form form = resources.getForm(Locale.getDefault(), \"bookForm\");\n        assertThat(form).isNotNull();\n        Field field = form.getField(\"title\");\n        assertThat(field).isNotNull();\n        assertThat(field.getDepends()).isEqualTo(\"isbn\");\n    }\n}\n"}
