bn(form) { return true; }</javascript>\n                    </validator>\n                    <constant>\n                      <constant-name>bookTitleLabel</constant-name>\n                      <constant-value>Book title</constant-value>\n                    </constant>\n                  </global>\n                  <formset>\n                    <form name=\"bookForm\">\n                      <field property=\"title\" depends=\"isbn\">\n                        <arg key=\"${bookTitleLabel}\" resource=\"false\"/>\n                      </field>\n                    </form>\n                  </formset>\n                </form-validation>\n                \"\"\";\n\n        ValidatorResources resources;\n        try (InputStream input = new ByteArrayInputStream(validationXml.getBytes(StandardCharsets.UTF_8))) {\n            resources = new ValidatorResources(input);\n        }\n\n        ValidatorAction action = resources.getValidatorAction(\"isbn\");\n        assertThat(action).isNotNull();\n        assertThat(action.getMethod()).isEqualTo(\"isValid\");\n        assertThat(action.getJavascript()).contains(\"validateIsbn\");\n\n        Form form = resources.getForm(Locale.getDefault(), \"bookForm\");\n        assertThat(form).isNotNull();\n        Field field = form.getField(\"title\");\n        assertThat(field).isNotNull();\n        assertThat(field.getDepends()).isEqualTo(\"isbn\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1316, "output": 976, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25332, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778244089931, "responseId": "resp_0f4d8bc919cb01360169fdd9fa817c8190aae6bf7b5ff4d698"}}
