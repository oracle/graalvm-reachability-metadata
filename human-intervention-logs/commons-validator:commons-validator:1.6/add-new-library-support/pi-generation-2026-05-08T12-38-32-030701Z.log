  package commons_validator.commons_validator;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.apache.commons.validator.Field;
  import org.apache.commons.validator.Form;
  import org.apache.commons.validator.FormSet;
  import org.apache.commons.validator.Validator;
  import org.apache.commons.validator.ValidatorAction;
  import org.apache.commons.validator.ValidatorResult;
  import org.apache.commons.validator.ValidatorResources;
  import org.apache.commons.validator.ValidatorResults;
  import org.junit.jupiter.api.Test;
  
  public class ValidatorActionTest {
      @Test
      void validateInvokesInstanceValidationMethodLoadedByName() throws Exception {
          ValidatorAction action = new ValidatorAction();
          action.setName("isbn");
          action.setClassname("org.apache.commons.validator.routines.ISBNValidator");
          action.setMethod("isValid");
          action.setMethodParams(String.class.getName());
          action.setJsFunction("validator-action.javascript.from-classloader");
  
          ValidatorResources resources = new ValidatorResources();
          resources.addValidatorAction(action);
          resources.addFormSet(formSetWithSingleFieldDependingOn(action));
          resources.process();
  
          Validator validator = new Validator(resources, "bookForm");
          validator.setParameter(String.class.getName(), "0-306-40615-2");
  
          ValidatorResults results = validator.validate();
  
          ValidatorResult isbnResult = results.getValidatorResult("isbn");
          assertThat(isbnResult).isNotNull();
          assertThat(isbnResult.isValid("isbn")).isTrue();
          assertThat(isbnResult.getResult("isbn")).isEqualTo(Boolean.TRUE);
          assertThat(action.getJavascript()).contains("fromClassLoaderValidatorActionJavascript");
      }
  
      @Test
      void loadsClassRelativeJavascriptWhenClassLoaderResourceIsAbsent() {
          ValidatorAction action = new ValidatorAction();
          action.setName("classRelativeJavascript");
          action.setJsFunction("/validator-action-class-relative.js");
  
          ValidatorResources resources = new ValidatorResources();
          resources.addValidatorAction(action);
  
          assertThat(action.getJavascript()).contains("classRelativeValidatorActionJavascript");
      }
  
      private static FormSet formSetWithSingleFieldDependingOn(ValidatorAction action) {
          Field field = new Field();
          field.setProperty("isbn");
          field.setDepends(action.getName());
  
          Form form = new Form();
          form.setName("bookForm");
          form.addField(field);
  
          FormSet formSet = new FormSet();
          formSet.addForm(form);
          return formSet;
      }
  }
