      assertThat(isbnResult.isValid(\"isbn\")).isTrue();\n        assertThat(isbnResult.getResult(\"isbn\")).isEqualTo(Boolean.TRUE);\n        assertThat(action.getJavascript()).contains(\"fromClassLoaderValidatorActionJavascript\");\n    }\n\n    @Test\n    void loadsClassRelativeJavascriptWhenClassLoaderResourceIsAbsent() {\n        ValidatorAction action = new ValidatorAction();\n        action.setName(\"classRelativeJavascript\");\n        action.setJsFunction(\"/validator-action-class-relative\");\n\n        ValidatorResources resources = new ValidatorResources();\n        resources.addValidatorAction(action);\n\n        assertThat(action.getJavascript()).contains(\"classRelativeValidatorActionJavascript\");\n    }\n\n    private static FormSet formSetWithSingleFieldDependingOn(ValidatorAction action) {\n        Field field = new Field();\n        field.setProperty(\"isbn\");\n        field.setDepends(action.getName());\n\n        Form form = new Form();\n        form.setName(\"bookForm\");\n        form.addField(field);\n\n        FormSet formSet = new FormSet();\n        formSet.addForm(form);\n        return formSet;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3554, "output": 1214, "cacheRead": 53248, "cacheWrite": 0, "totalTokens": 58016, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778243816109, "responseId": "resp_0a6c7c6c22d4b9d60169fdd8e93540819f9df066268625b05d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_07AwJI6AOewCBJ5RihTS4nCs|fc_0a6c7c6c22d4b9d60169fdd8f69ef0819fab0e410572496ab2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2848 bytes to tests/src/commons-validator/commons-validator/1.6/src/test/java/commons_validator/commons_validator/ValidatorActionTest.java"}], "isError": false, "timestamp": 1778243834983}]}
