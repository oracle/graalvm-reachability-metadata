       9	import static org.assertj.core.api.Assertions.assertThat;
      10	import static org.junit.jupiter.api.Assertions.assertThrows;
      11	
      12	import java.io.ByteArrayInputStream;
      13	import java.io.IOException;
      14	import java.io.InputStream;
      15	import java.nio.charset.StandardCharsets;
      16	import java.util.ServiceLoader;
      17	import java.util.concurrent.Callable;
      18	
      19	import org.graalvm.internal.tck.NativeImageSupport;
      20	import org.jdom.adapters.XML4JDOMAdapter;
      21	import org.junit.jupiter.api.Test;
      22	import org.junit.jupiter.api.function.Executable;
      23	import org.w3c.dom.Document;
      24	import org.w3c.dom.Element;
      25	
      26	public class XML4JDOMAdapterTest {
      27	    private static final String ISOLATED_CALLABLE_CLASS_NAME =
      28	            XML4JDOMAdapterTest.class.getName() + "$IsolatedXml4jDomAdapterCallable";
      29	    private static final String JDOM_PACKAGE = "org.jdom.";
      30	    private static final String XERCES_PARSER_PACKAGE = "org.apache.xerces.parsers.";
      31	
      32	    @Test
      33	    void parsesValidatingDocumentThroughXml4jParserReflection() throws Exception {
      34	        XML4JDOMAdapter adapter = new XML4JDOMAdapter();
      35	        String xml = """
      36	                <catalog>
      37	                    <entry sku="xml4j">XML4J</entry>
      38	                </catalog>
      39	                """;
      40	
      41	        Document document = parse(adapter, xml, true);
      42	
      43	        Element root = document.getDocumentElement();
      44	        Element entry = (Element) root.getElementsByTagName("entry").item(0);
      45	        assertThat(root.getTagName()).isEqualTo("catalog");
      46	        assertThat(entry.getAttribute("sku")).isEqualTo("xml4j");
      47	        assertThat(entry.getTextContent()).isEqualTo("XML4J");
      48	    }
      49	
      50	    @Test
      51	    void parsesDocumentThroughXml4jAdapterLoadedInIsolatedClassLoader() throws Exception {
      52	        IsolatedClassLoader classLoader = new IsolatedClassLoader(XML4JDOMAdapterTest.class.getClassLoader());
      53	
      54	        try {
      55	            Callable<?> action = ServiceLoader.load(Callable.class, classLoader).stream()
      56	                    .filter(provider -> provider.type().getName().equals(ISOLATED_CALLABLE_CLASS_NAME))
      57	                    .map(ServiceLoader.Provider::get)
      58	                    .findFirst()
      59	                    .orElseThrow(() -> new AssertionError("Expected isolated XML4J DOM adapter callable provider"));
      60	
      61	            assertThat(action.call()).isEqualTo("isolated-xml4j");
      62	        } catch (Error error) {
      63	            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
      64	                throw error;
      65	            }
      66	        }
      67	    }
      68	
      69	    @Test
      70	    void reportsSaxParseFailuresFromXml4jParserReflection() {
      71	        XML4JDOMAdapter adapter = new XML4JDOMAdapter();
      72	        Executable parseMalformedXml = () -> parse(adapter, "<root><broken></root>", false);
      73	
      74	        IOException exception = assertThrows(IOException.class, parseMalformedXml);
      75	        assertThat(exception.getMessage()).contains("Error on line");
      76	    }
      77	
      78	    public static final class IsolatedXml4jDomAdapterCallable implements Callable<String> {
      79	        @Override
      80	        public String call() throws Exception {
      81	            XML4JDOMAdapter adapter = new XML4JDOMAdapter();
      82	            byte[] xmlBytes = "<root id=\"isolated-xml4j\" />".getBytes(StandardCharsets.UTF_8);
      83	            Document document;
      84	            try (InputStream inputStream = new ByteArrayInputStream(xmlBytes)) {
      85	                document = adapter.getDocument(inputStream, false);
      86	            }
      87	
      88	            return document.getDocumentElement().getAttribute("id");
      89	        }
      90	    }
      91	
      92	    private static Document parse(XML4JDOMAdapter adapter, String xml, boolean validate) throws IOException {
      93	        byte[] xmlBytes = xml.getBytes(StandardCharsets.UTF_8);
      94	        try (InputStream inputStream = new ByteArrayInputStream(xmlBytes)) {
      95	            return adapter.getDocument(inputStream, validate);
      96	        }
      97	    }
      98	
      99	    private static final class IsolatedClassLoader extends ClassLoader {
     100	        private IsolatedClassLoader(ClassLoader parent) {
     101	            super(parent);
     102	        }
     103	
     104	        @Override
     105	        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
     106	            synchronized (getClassLoadingLock(name)) {
     107	                Class<?> loadedClass = findLoadedClass(name);
     108	                if (loadedClass == null) {
     109	                    loadedClass = loadUnresolvedClass(name);
     110	                }
     111	                if (resolve) {
     112	                    resolveClass(loadedClass);
     113	                }
     114	                return loadedClass;
     115	            }
     116	        }
     117	
     118	        private Class<?> loadUnresolvedClass(String name) throws ClassNotFoundException {
     119	            if (!isChildFirst(name)) {
     120	                return super.loadClass(name, false);
     121	            }
     122	
     123	            try {
     124	                return findClass(name);
     125	            } catch (ClassNotFoundException ignored) {
     126	                return super.loadClass(name, false);
     127	            }
     128	        }
     129	
     130	        @Override
     131	        protected Class<?> findClass(String name) throws ClassNotFoundException {
     132	            String resourceName = name.replace('.', '/') + ".class";
     133	
     134	            try (InputStream inputStream = getParent().getResourceAsStream(resourceName)) {
     135	                if (inputStream == null) {
     136	                    throw new ClassNotFoundException(name);
     137	                }
     138	                byte[] classBytes = inputStream.readAllBytes();
     139	                return defineClass(name, classBytes, 0, classBytes.length);
     140	            } catch (IOException exception) {
     141	                throw new ClassNotFoundException(name, exception);
     142	            }
     143	        }
     144	
     145	        private boolean isChildFirst(String className) {
     146	            return className.startsWith(JDOM_PACKAGE)
     147	                    || className.startsWith(XERCES_PARSER_PACKAGE)
     148	                    || className.equals(ISOLATED_CALLABLE_CLASS_NAME);
     149	        }
     150	    }
     151	}
