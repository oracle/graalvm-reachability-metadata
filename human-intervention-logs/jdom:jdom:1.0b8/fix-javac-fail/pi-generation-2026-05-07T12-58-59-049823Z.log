      public static Namespace getNamespace(String prefix, String uri) {
          // Sanity checking
          if ((prefix == null) || (prefix.trim().equals(""))) {
              prefix = "";
          }
          if ((uri == null) || (uri.trim().equals(""))) {
              uri = "";
