              parser = XMLReaderFactory.createXMLReader(DEFAULT_SAX_DRIVER);
              // System.out.println("using default " + DEFAULT_SAX_DRIVER);
              saxDriverClass = parser.getClass().getName();
          }
  
          return parser;
      }
  
