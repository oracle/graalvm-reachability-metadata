  public class AbstractDOMAdapterTest {
      @Test
      void setInternalSubsetInvokesParserSpecificDocumentTypeMutator() {
          TestDOMAdapter adapter = new TestDOMAdapter();
          MutableDocumentType documentType = new MutableDocumentType(
                  "article", "-//example//DTD Article//EN", "article.dtd");
  
          adapter.applyInternalSubset(documentType, "<!ELEMENT article (#PCDATA)>");
  
          assertThat(documentType.getInternalSubset()).isEqualTo("<!ELEMENT article (#PCDATA)>");
      }
  
      @Test
      void createDocumentWithDocTypeUsesMutableDomDocumentType() throws Exception {
          MutableDOMImplementation domImplementation = new MutableDOMImplementation();
          TestDOMAdapter adapter = new TestDOMAdapter(new MinimalDocument(domImplementation, null));
          DocType docType = new DocType("article", "-//example//DTD Article//EN", "article.dtd");
          docType.setInternalSubset("<!ELEMENT article (#PCDATA)>");
  
          Document document = adapter.createDocument(docType);
  
          assertThat(document.getDoctype().getName()).isEqualTo("article");
          assertThat(document.getDoctype().getPublicId()).isEqualTo("-//example//DTD Article//EN");
          assertThat(document.getDoctype().getSystemId()).isEqualTo("article.dtd");
          assertThat(document.getDoctype().getInternalSubset()).isEqualTo("<!ELEMENT article (#PCDATA)>");
      }
  
