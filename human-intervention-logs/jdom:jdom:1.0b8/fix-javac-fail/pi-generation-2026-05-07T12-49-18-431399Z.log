ter adapter = new TestDOMAdapter(new MinimalDocument(domImplementation, null));\n        DocType docType = new DocType(\"article\", \"-//example//DTD Article//EN\", \"article.dtd\");\n        docType.setInternalSubset(\"<!ELEMENT article (#PCDATA)>\");\n\n        Document document = adapter.createDocument(docType);\n\n        assertThat(document.getDoctype().getName()).isEqualTo(\"article\");\n        assertThat(document.getDoctype().getPublicId()).isEqualTo(\"-//example//DTD Article//EN\");\n        assertThat(document.getDoctype().getSystemId()).isEqualTo(\"article.dtd\");\n        assertThat(document.getDoctype().getInternalSubset()).isEqualTo(\"<!ELEMENT article (#PCDATA)>\");\n    }\n\n    public static class TestDOMAdapter extends AbstractDOMAdapter {\n        private final Document document;\n\n        public TestDOMAdapter() {\n            this(null);\n        }\n\n        public TestDOMAdapter(Document document) {\n            this.document = document;\n        }\n\n        public void applyInternalSubset(DocumentType documentType, String internalSubset) {\n            setInternalSubset(documentType, internalSubset);\n        }\n\n        @Override\n        public Document getDocument(InputStream inputStream, boolean validate) throws IOException, JDOMException {\n            throw new UnsupportedOperationException(\"Parsing is not needed for this test\");\n        }\n\n        @Override\n        public Document createDocument() throws JDOMException {\n            if (document == null) {\n                throw new UnsupportedOperationException(\"Document creation is not needed for this test\");\n            }\n            return document;\n        }\n    }\n"}]}
