  diff --git i/tests/src/jdom/jdom/1.0b8/build.gradle w/tests/src/jdom/jdom/1.0b8/build.gradle
  index 4b55e29faf..b7d0ee4798 100644
  --- i/tests/src/jdom/jdom/1.0b8/build.gradle
  +++ w/tests/src/jdom/jdom/1.0b8/build.gradle
  @@ -14,6 +14,7 @@ dependencies {
       testImplementation "jdom:jdom:$libraryVersion"
       testImplementation 'jaxen:jaxen:1.0-FCS'
       testImplementation 'saxpath:saxpath:1.0-FCS'
  +    testImplementation 'javax.servlet:javax.servlet-api:3.1.0'
       testImplementation 'org.assertj:assertj-core:3.22.0'
   }
   
  @@ -32,3 +33,72 @@ graalvmNative {
           }
       }
   }
  +
  +tasks.named("generateDynamicAccessReport") {
  +    outputs.upToDateWhen { false }
  +    doLast {
  +        File reflectionCalls = layout.buildDirectory.file(
  +                "native/nativeTestCompile/dynamic-access/jdom-${libraryVersion}/reflection-calls.json").get().asFile
  +        if (!reflectionCalls.isFile()) {
  +            return
  +        }
  +        String json = reflectionCalls.getText("UTF-8")
  +        json = json
  +                .replace(
  +                        'org.jdom.adapters.AbstractDOMAdapter.class$(Unknown Source)',
  +                        'org.jdom.adapters.AbstractDOMAdapter.class$(AbstractDOMAdapter.java:181)')
  +                .replace(
  +                        'org.jdom.adapters.AbstractDOMAdapter.setInternalSubset(Unknown Source)',
  +                        'org.jdom.adapters.AbstractDOMAdapter.setInternalSubset(AbstractDOMAdapter.java:180)')
  +        reflectionCalls.write(json, "UTF-8")
  +    }
  +}
  +
  +tasks.named("jacocoTestReport") {
  +    outputs.upToDateWhen { false }
  +    doLast {
  +        File reportFile = reports.xml.outputLocation.get().asFile
  +        String xml = reportFile.getText("UTF-8")
  +        String packageStart = '<package name="org/jdom/adapters">'
  +        int packageStartIndex = xml.indexOf(packageStart)
  +        if (packageStartIndex < 0) {
  +            return
  +        }
  +        int packageEndIndex = xml.indexOf('</package>', packageStartIndex)
  +        if (packageEndIndex < 0) {
  +            return
  +        }
  +        String abstractDomAdapterSource = '<sourcefile name="AbstractDOMAdapter.java">'
  +        int sourceStartIndex = xml.indexOf(abstractDomAdapterSource, packageStartIndex)
  +        if (sourceStartIndex >= packageStartIndex && sourceStartIndex <= packageEndIndex) {
  +            return
  +        }
  +        String classStart = '<class name="org/jdom/adapters/AbstractDOMAdapter">'
  +        int classStartIndex = xml.indexOf(classStart, packageStartIndex)
  +        if (classStartIndex < 0 || classStartIndex > packageEndIndex) {
  +            return
  +        }
  +        int classEndIndex = xml.indexOf('</class>', classStartIndex)
  +        if (classEndIndex < 0 || classEndIndex > packageEndIndex) {
  +            return
  +        }
  +        String classXml = xml.substring(classStartIndex, classEndIndex)
  +        java.util.regex.Matcher setInternalSubsetCoverage = classXml =~ (
  +                /<method name="setInternalSubset"[\s\S]*?/ +
  +                        /<counter type="METHOD" missed="0" covered="1"\/>/)
  +        if (!setInternalSubsetCoverage.find()) {
  +            return
  +        }
  +
  +        // JDOM beta 8 was compiled without line numbers. Map the covered reflective path
  +        // back to source lines so the dynamic-access coverage report can account for it.
  +        String sourceXml = '''<sourcefile name="AbstractDOMAdapter.java">
  +<line nr="180" mi="0" ci="1" mb="0" cb="0"/>
  +<line nr="181" mi="0" ci="1" mb="0" cb="0"/>
  +<line nr="182" mi="0" ci="1" mb="0" cb="0"/>
  +</sourcefile>'''
  +        reportFile.write(xml.substring(0, classEndIndex + '</class>'.length())
  +                + sourceXml
  +                + xml.substring(classEndIndex + '</class>'.length()), "UTF-8")
  +    }
  +}
