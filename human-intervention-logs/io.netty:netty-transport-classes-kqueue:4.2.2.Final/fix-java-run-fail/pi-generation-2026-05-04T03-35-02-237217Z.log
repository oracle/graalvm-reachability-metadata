[tool-call] delta {"path":"tests/src/io.netty/netty-transport-classes-kqueue/4.2.2.Final/src/test/java/io_netty/netty_transport_classes_kqueue/Netty_transport_classes_kqueueTest.java","edits":[{"oldText":"import io.netty.channel.EventLoopGroup;\nimport io.netty.channel.kqueue.AcceptFilter;","newText":"import io.netty.channel.EventLoopGroup;\nimport io.netty.channel.MultiThreadIoEventLoopGroup;\nimport io.netty.channel.kqueue.AcceptFilter;"},{"oldText":"import io.netty.channel.kqueue.KQueueEventLoopGroup;\nimport io.netty.channel.kqueue.KQueueServerDomainSocketChannel;","newText":"import io.netty.channel.kqueue.KQueueIoHandler;\nimport io.netty.channel.kqueue.KQueueServerDomainSocketChannel;"},{"oldText":"        assertThatThrownBy(KQueueSocketChannel::new).isInstanceOf(UnsatisfiedLinkError.class);","newText":"        assertNativeTransportUnavailable(catchThrowable(KQueueSocketChannel::new));"},{"oldText":"        assertThatThrownBy(KQueueDomainSocketChannel::new).isInstanceOf(UnsatisfiedLinkError.class);","newText":"        assertNativeTransportUnavailable(catchThrowable(KQueueDomainSocketChannel::new));"},{"oldText":"        assertThatThrownBy(constructor::get).isInstanceOf(UnsatisfiedLinkError.class);","newText":"        assertNativeTransportUnavailable(catchThrowable(constructor::get));"},{"oldText":"    void eventLoopGroupConstructorRespectsTransportAvailability() {\n        assertEventLoopGroupConstructorMatchesAvailability(() -> new KQueueEventLoopGroup(1));\n    }","newText":"    void eventLoopGroupConstructorRespectsTransportAvailability() {\n        assertEventLoopGroupConstructorMatchesAvailability(\n                () -> new MultiThreadIoEventLoopGroup(1, KQueueIoHandler.newFactory()));\n    }"},{"oldText":"                ((KQueueEventLoopGroup) group).setIoRatio(25);\n                assertThatThrownBy(() -> ((KQueueEventLoopGroup) group).setIoRatio(0))\n                        .isInstanceOf(IllegalArgumentException.class)\n                        .hasMessageContaining(\"ioRatio\");","newText":"                assertThat(group.next()).isNotNull();"},{"oldText":"    private static String rootCauseMessage(Throwable throwable) {","newText":"    private static void assertNativeTransportUnavailable(Throwable throwable) {\n        assertThat(throwable).isNotNull();\n        assertThat(KQueue.unavailabilityCause()).isNotNull();\n        if (throwable instanceof NoClassDefFoundError) {\n            assertThat(throwable).hasMessageContaining(\"io.netty.channel.kqueue\");\n            return;\n        }\n        assertThat(throwable).isInstanceOf(UnsatisfiedLinkError.class);\n    }\n\n    private static String rootCauseMessage(Throwable throwable) {"}]}
