                      buf.internalNioBuffer(buf.readerIndex(), buf.readableBytes()) : buf.nioBuffer();
              int localFlushedAmount = socket.write(nioBuf, nioBuf.position(), nioBuf.limit());
              if (localFlushedAmount > 0) {
