ror.class);", "newText": "        assertNativeTransportUnavailable(catchThrowable(KQueueDomainSocketChannel::new));"}, {"oldText": "        assertThatThrownBy(constructor::get).isInstanceOf(UnsatisfiedLinkError.class);", "newText": "        assertNativeTransportUnavailable(catchThrowable(constructor::get));"}, {"oldText": "    void eventLoopGroupConstructorRespectsTransportAvailability() {\n        assertEventLoopGroupConstructorMatchesAvailability(() -> new KQueueEventLoopGroup(1));\n    }", "newText": "    void eventLoopGroupConstructorRespectsTransportAvailability() {\n        assertEventLoopGroupConstructorMatchesAvailability(\n                () -> new MultiThreadIoEventLoopGroup(1, KQueueIoHandler.newFactory()));\n    }"}, {"oldText": "                ((KQueueEventLoopGroup) group).setIoRatio(25);\n                assertThatThrownBy(() -> ((KQueueEventLoopGroup) group).setIoRatio(0))\n                        .isInstanceOf(IllegalArgumentException.class)\n                        .hasMessageContaining(\"ioRatio\");", "newText": "                assertThat(group.next()).isNotNull();"}, {"oldText": "    private static String rootCauseMessage(Throwable throwable) {", "newText": "    private static void assertNativeTransportUnavailable(Throwable throwable) {\n        assertThat(throwable).isNotNull();\n        assertThat(KQueue.unavailabilityCause()).isNotNull();\n        if (throwable instanceof NoClassDefFoundError) {\n            assertThat(throwable).hasMessageContaining(\"io.netty.channel.kqueue\");\n            return;\n        }\n        assertThat(throwable).isInstanceOf(UnsatisfiedLinkError.class);\n    }\n\n    private static String rootCauseMessage(Throwable throwable) {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 615, "output": 1425, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 33784, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp"