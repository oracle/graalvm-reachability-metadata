eatedByDefaultConstructor = true;\\n        }\\n    }\\n\\n    public static class PostConstructedResource {\\n        private final boolean created;\\n        private boolean ready;\\n\\n        public PostConstructedResource() {\\n            this.created = true;\\n        }\\n\\n        public void markReady() {\\n            this.ready = true;\\n        }\\n    }\\n\\n    public static class ParameterConstructedResource {\\n        private final String message;\\n\\n        public ParameterConstructedResource(String message) {\\n            this.message = message;\\n        }\\n    }\\n\\n    private static class FixedInjectable implements Injectable<String> {\\n        private final String value;\\n\\n        FixedInjectable(String value) {\\n            this.value = value;\\n        }\\n\\n        @Override\\n        public String getValue() {\\n            return value;\\n        }\\n    }\\n\\n    private static class FixedInjectableProviderContext implements ServerInjectableProviderContext {\\n        private final List<Injectable> constructorInjectables;\\n\\n        FixedInjectableProviderContext(Injectable... constructorInjectables) {\\n            this.constructorInjectables = new ArrayList<Injectable>();\\n            Collections.addAll(this.constructorInjectables, constructorInjectables);\\n        }\\n\\n        @Override\\n        public boolean isParameterTypeRegistered(Parameter parameter) {\\n            return false;\\n        }\\n\\n        @Override\\n        public Injectable getInjectable(Parameter parameter, ComponentScope scope) {\\n            return null;\\n        }\\n\\n        @Override\\n        public Injectable getInjectable(AccessibleObject accessibleObject, Parameter parameter, ComponentScope scope) {\\n            return null;\\n        }\\n\\n        @Override\\n        public InjectableScopePair getInjectableiWithScope(Parameter parameter, ComponentScope scope) {\\n            return null;\\n        }\\n\\n        @Override\\n