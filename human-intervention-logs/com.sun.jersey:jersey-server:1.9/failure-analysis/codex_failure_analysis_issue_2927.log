or.\\n     * \\n     * @param ipc the injectable provider context to obtain injectables.\\n     * @param s the scope under which injection will be performed.\\n     * @param resource the abstract resource model.\\n     */\\n    public ResourceComponentInjector(ServerInjectableProviderContext ipc, ComponentScope s, AbstractResource resource) {\\n        // processFields(ipc, s, resource.getResourceClass());\\n        processFields(ipc, s, resource.getFields());\\n        processSetters(ipc, s, resource.getSetterMethods());\\n    }\\n\\n    /**\\n     * Ascertain if there are any injectable artifacts to be injected.\\n     *\\n     * @return true if there are any injectable artifacts to be injected.\\n     */\\n    public boolean hasInjectableArtifacts() {\\n        return singletonFields.length > 0 || perRequestFields.length > 0 ||\\n                singletonSetters.length > 0 || perRequestSetters.length > 0;\\n    }\\n\\n    private void processFields(ServerInjectableProviderContext ipc, ComponentScope s,\\n            List<AbstractField> fields) {\\n        Map<Field, Injectable<?>> singletons = new HashMap<Field, Injectable<?>>();\\n        Map<Field, Injectable<?>> perRequest = new HashMap<Field, Injectable<?>>();\\n        \\n        for (AbstractField af : fields) {\\n            Parameter p = af.getParameters().get(0);\\n\\n            InjectableScopePair isp = ipc.getInjectableiWithScope(af.getField(), p, s);\\n            if (isp != null) {\\n                configureField(af.getField());\\n                if (s == ComponentScope.PerRequest && isp.cs != ComponentScope.Singleton) {\\n                    perRequest.put(af.getField(), isp.i);\\n                } else {\\n                    singletons.put(af.getField(), isp.i);\\n                }\\n            } else if (ipc.isParameterTypeRegistered(p)) {\\n                // Missing dependency\\n                Errors.missingDependency(af.getField());\\n            }\\n        }\\n        \\n        int size = singletons.entrySet().size();\\n        singletonFields = new Field[size];\\n        singletonFieldValues = new Object[size];        \\n        int i = 0;\\n        for (Map.Entry<Field, Injectable<?>> e : singletons.entrySet()) {\\n            singletonFields[i] = e.getKey();\\n            singletonFieldValues[i++] = e.getValue().getValue();\\n        }\\n        \\n        size = perRequest.entrySet().size();\\n        perRequestFields = new Field[size];\\n        perRequestFieldInjectables = new AbstractHttpContextInjectable<?>[size];\\n        i = 0;\\n        for (Map.Entry<Field, Injectable<?>> e : perRequest.entrySet()) {\\n            perRequestFields[i] = e.getKey();\\n            perRequestFieldInjectables[i++] = AbstractHttpContextInjectable.transform(e.getValue());\\n        }        \\n    }\\n    \\n    private void configureField(final Field f) {\\n        if (!f.isAccessible()) {\\n            AccessController.doPrivileged(new PrivilegedAction<Object>() {\\n                @Override\\n                public Object run() {\\n                    f.setAccessible(true);\\n                    return null;\\n                }\\n            });\\n        }\\n    }\\n    \\n    private void processSetters(ServerInjectableProviderContext ipc, ComponentScope s,\\n            List<AbstractSetterMethod> setterMethods) {\\n        Map<Method, Injectable<?>> singletons = new HashMap<Method, Injectable<?>>();\\n        Map<Method, Injectable<?>> perRequest = new HashMap<Method, Injectable<?>>();\\n        \\n        int methodIndex = 0;\\n        for (AbstractSetterMethod sm : setterMethods) {\\n            Parameter p = sm.getParameters().get(0);\\n\\n            InjectableScopePair isp = ipc.getInjectableiWithScope(sm.getMethod(), p, s);\\n            if (isp != null) {\\n                if (s == ComponentScope.PerRequest && isp.cs != ComponentScope.Singleton) {\\n                    perRequest.put(sm.getMethod(), isp.i);\\n                } else {\\n                    singletons.put(sm.getMethod(), isp.i);\\n                }\\n            } else if (ipc.isParameterTypeRegistered(p)) {\\n                // Missing dependency\\n                Errors.missingDependency(sm.getMethod(), methodIndex);\\n            }\\n            methodIndex++;\\n        }\\n                \\n        int size = singletons.entrySet().size();\\n        singletonSetters = new Method[size];\\n        singletonSetterValues = new Object[size];        \\n        int i = 0;\\n        for (Map.Entry<Method, Injectable<?>> e : singletons.entrySet()) {\\n            singletonSetters[i] = e.getKey();\\n            singletonSetterValues[i++] = e.getValue().getValue();\\n        }\\n        \\n        size = perRequest.entrySet().size();\\n        perRequestSetters = new Method[size];\\n        perRequestSetterInjectables = new AbstractHttpContextInjectable<?>[size];\\n        i = 0;\\n        for (Map.Entry<Method, Injectable<?>> e : perRequest.entrySet()) {\\n            perRequestSetters[i] = e.getKey();\\n            perRequestSetterInjectables[i++] = AbstractHttpContextInjectable.transform(e.getValue());\\n        }        \\n    }\\n    \\n    /**\\n     * Inject onto an instance of a resource class.\\n     * \\n     * @param c the HTTP context, may be set to null if not available for the\\n     *        current scope.\\n     * @param o the resource.\\n     */\\n    public void inject(HttpContext c, Object o) {\\n        int i = 0;\\n        for (Field f : singletonFields) {\\n            try {\\n                f.set(o, singletonFieldValues[i++]);\\n            } catch (IllegalAccessException ex) {\\n                throw new ContainerException(ex);\\n            }\\n        }\\n        \\n        i = 0;\\n        for (Field f : perRequestFields) {\\n            try {\\n                f.set(o, perRequestFieldInjectables[i++].getValue(c));\\n            } catch (IllegalAccessException ex) {\\n                throw new ContainerException(ex);\\n            }\\n        }\\n        \\n        i = 0;\\n        for (Method m : singletonSetters) {\\n            try {\\n                m.invoke(o, singletonSetterValues[i++]);\\n            } catch (Exception ex) {\\n                throw new ContainerException(ex);\\n            }\\n        }\\n        \\n        i = 0;\\n        for (Method m : perRequestSetters) {\\n            try {\\n                m.invoke(o, perRequestSetterInjectables[i++].getValue(c));\\n            } catch (Exception ex) {\\n                throw new ContainerException(ex);\\n            }\\n        }\\n    }\\n}\"}], \"isError\": false, \"timestamp\": 1778310164671}]}\nhuman-intervention-logs/com.sun.jersey:jersey-server:1.9/add-new-library-support/pi-generation-2026-05-09T07-03-51-247992Z.log:1637:[tool-call] end id=call_zQ9wQzYHMr9tJHY6XhcZWnS1|fc_061b2f1e85eb0edd0169fedc399400819d8cf1cee7bc561f97 name=write args={\"path\": \"tests/src/com.sun.jersey/jersey-server/1.9/src/test/java/com_sun_jersey/jersey_server/ResourceComponentInjectorTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_sun_jersey.jersey_server;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport com.sun.jersey.api.model.AbstractField;\\nimport com.sun.jersey.api.model.AbstractResource;\\nimport com.sun.jersey.api.model.AbstractSetterMethod;\\nimport com.sun.jersey.api.model.Parameter;\\nimport com.sun.jersey.api.model.Parameter.Source;\\nimport com.sun.jersey.core.spi.component.ComponentContext;\\nimport com.sun.jersey.core.spi.component.ComponentScope;\\nimport com.sun.jersey.server.impl.inject.ServerInjectableProviderContext;\\nimport com.sun.jersey.server.spi.component.ResourceComponentInjector;\\nimport com.sun.jersey.spi.inject.Injectable;\\nimport com.sun.jersey.spi.inject.InjectableProviderContext.InjectableScopePair;\\nimport java.lang.annotation.Annotation;\\nimport java.lang.reflect.AccessibleObject;\\nimport java.lang.reflect.Field;\\nimport java.lang.reflect.Method;\\nimport java.util.Collections;\\nimport java.util.HashMap;\\nimport java.util.List;\\nimport java.util.Map;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class ResourceComponentInjectorTest {\\n    @Test\\n    void injectsSingletonAndPerRequestFieldsAndSetters() throws Exception {\\n        AbstractResource resourceModel = resourceModelWithFieldsAndSetters();\\n        ResourceComponentInjector injector = new ResourceComponentInjector(\\n                new NamedInjectableProviderContext()\\n                        .register(\\\"singleton-field\\\", \\\"singleton field value\\\", ComponentScope.Singleton)\\n                        .register(\\\"per-request-field\\\", \\\"per request field value\\\", ComponentScope.PerRequest)\\n                        .register(\\\"singleton-setter\\\", \\\"singleton setter value\\\", ComponentScope.Singleton)\\n                        .register(\\\"per-request-setter\\\", \\\"per request setter value\\\", ComponentScope.PerRequest),\\n                ComponentScope.PerRequest,\\n                resourceModel);\\n        InjectableResource resource = new InjectableResource();\\n\\n        injector.inject(null, resource);\\n\\n        assertThat(injector.hasInjectableArtifacts()).isTrue();\\n        assertThat(resource.singletonField).isEqualTo(\\\"singleton field value\\\");\\n        assertThat(resource.perRequestField).isEqualTo(\\\"per request field value\\\");\\n        assertThat(resource.singletonSetterValue).isEqualTo(\\\"singleton setter value\\\");\\n        assertThat(resource.perRequestSetterValue).isEqualTo(\\\"per request setter value\\\");\\n    }\\n\\n    private AbstractResource resourceModelWithFieldsAndSetters() throws Exception {\\n        AbstractResource resourceModel = new AbstractResource(InjectableResource.class);\\n        resourceModel.getFields().add(abstractField(\\\"singletonField\\\", \\\"singleton-field\\\"));\\n        resourceModel.getFields().add(abstractField(\\\"perRequestField\\\", \\\"per-request-field\\\"));\\n        resourceModel.getSetterMethods().add(abstractSetter(resourceModel, \\\"setSingletonSetterValue\\\", \\\"singleton-setter\\\"));\\n        resourceModel.getSetterMethods().add(abstractSetter(resourceModel, \\\"setPerRequestSetterValue\\\", \\\"per-request-setter\\\"));\\n        return resourceModel;\\n    }\\n\\n    private AbstractField abstractField(String fieldName, String parameterName) throws Exception {\\n        Field field = InjectableResource.class.getDeclaredField(fieldName);\\n        AbstractField abstractField = new AbstractField(field);\\n        abstractField.getParameters().add(parameter(parameterName));\\n        return abstractField;\\n    }\\n\\n    private AbstractSetterMethod abstractSetter(\\n            AbstractResource resourceModel,\\n            String methodName,\\n            String parameterName) throws Exception {\\n        Method method = InjectableResource.class.getMethod(methodName, String.class);\\n        AbstractSetterMethod setter = new AbstractSetterMethod(resourceModel, method, new Annotation[0]);\\n        setter.getParameters().add(parameter(parameterName));\\n        return setter;\\n    }\\n\\n    private Parameter parameter(String name) {\\n        return new Parameter(new Annotation[0], null, Source.UNKNOWN, name, String.class, String.class);\\n    }\\n\\n    public static class InjectableResource {\\n        private String singletonField;\\n        private String perRequestField;\\n        private String singletonSetterValue;\\n        private String perRequestSetterValue;\\n\\n        public void setSingletonSetterValue(String singletonSetterValue) {\\n            this.singletonSetterValue = singletonSetterValue;\\n        }\\n\\n        public void setPerRequestSetterValue(String perRequestSetterValue) {\\n            this.perRequestSetterValue = perRequestSetterValue;\\n        }\\n    }\\n\\n    private static class FixedInjectable implements Injectable<String> {\\n        private final String value;\\n\\n        FixedInjectable(String value) {\\n            this.value = value;\\n        }\\n\\n        @Override\\n        public String getValue() {\\n            return value;\\n        }\\n    }\\n\\n    private static class NamedInjectableProviderContext implements ServerInjectableProviderContext {\\n        private final Map<String, InjectableScopePair> injectables = new HashMap<String, InjectableScopePair>();\\n\\n        NamedInjectableProviderContext register(String parameterName, String value, ComponentScope scope) {\\n            injectables.put(parameterName, new InjectableScopePair(new FixedInjectable(value), scope));\\n            return this;\\n        }\\n\\n        @Override\\n        public boolean isParameterTypeRegistered(Parameter parameter) {\\n            return false;\\n        }\\n\\n        @Override\\n        public Injectable getInjectable(Parameter parameter, ComponentScope scope) {\\n            return null;\\n        }\\n\\n        @Override\\n        public Injectable getInjectable(AccessibleObject accessibleObject, Parameter parameter, ComponentScope scope) {\\n            return null;\\n        }\\n\\n        @Override\\n        public InjectableScopePair getInjectableiWithScope(Parameter parameter, ComponentScope scope) {\\n            return null;\\n        }\\n\\n        @Override\\n        public InjectableScopePair getInjectableiWithScope(\\n                AccessibleObject accessibleObject,\\n                Parameter parameter,\\n                ComponentScope scope) {\\n            return injectables.get(parameter.getSourceName());\\n        }\\n\\n        @Override\\n        public List<Injectable> getInjectable(List<Parameter> parameters, ComponentScope scope) {\\n            return Collections.emptyList();\\n        }\\n\\n        @Override\\n        public List<Injectable> getInjectable(\\n                AccessibleObject accessibleObject,\\n                List<Parameter> parameters,\\n                ComponentScope scope) {\\n            return Collections.emptyList();\\n        }\\n\\n        @Override\\n        public boolean isAnnotationRegistered(\\n                Class<? extends Annotation> annotationType,\\n                Class<?> parameterType) {\\n            return false;\\n        }\\n\\n        @Override\\n        public boolean isInjectableProviderRegistered(\\n                Class<? extends Annotation> annotationType,\\n                Class<?> parameterType,\\n                ComponentScope scope) {\\n            return false;\\n        }\\n\\n        @Override\\n        public <A extends Annotation, C> Injectable getInjectable(\\n                Class<? extends Annotation> annotationType,\\n                ComponentContext componentContext,\\n                A annotation,\\n                C context,\\n                ComponentScope scope) {\\n            return null;\\n        }\\n\\n        @Override\\n        public <A extends Annotation, C> Injectable getInjectable(\\n                Class<? extends Annotation> annotationType,\\n                ComponentContext componentContext,\\n                A annotation,\\n                C context,\\n                List<ComponentScope> scopes) {\\n            return null;\\n        }\\n\\n        @Override\\n        public <A extends Annotation, C> InjectableScopePair getInjectableWithScope(\\n                Class<? extends Annotation> annotationType,\\n                ComponentContext componentContext,\\n                A annotation,\\n                C context,\\n                List<ComponentScope> scopes) {\\n            return null;\\n        }\\n    }\\n}\\n\"}\nhuman-intervention-logs/com.sun.jersey:jersey-server:1.9/add-new-library-support/pi-generation-2026-05-09T07-03-51-247992Z.log:1638:[recv] {\"type\": \"me