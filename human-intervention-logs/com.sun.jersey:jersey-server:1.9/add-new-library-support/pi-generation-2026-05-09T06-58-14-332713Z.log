ope) {\n            return null;\n        }\n\n        @Override\n        public InjectableScopePair getInjectableiWithScope(\n                AccessibleObject accessibleObject,\n                Parameter parameter,\n                ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public List<Injectable> getInjectable(List<Parameter> parameters, ComponentScope scope) {\n            return constructorInjectables;\n        }\n\n        @Override\n        public List<Injectable> getInjectable(\n                AccessibleObject accessibleObject,\n                List<Parameter> parameters,\n                ComponentScope scope) {\n            return constructorInjectables;\n        }\n\n        @Override\n        public boolean isAnnotationRegistered(\n                Class<? extends Annotation> annotationType,\n                Class<?> parameterType) {\n            return false;\n        }\n\n        @Override\n        public boolean isInjectableProviderRegistered(\n                Class<? extends Annotation> annotationType,\n                Class<?> parameterType,\n                ComponentScope scope) {\n            return false;\n        }\n\n        @Override\n        public <A extends Annotation, C> Injectable getInjectable(\n                Class<? extends Annotation> annotationType,\n                ComponentContext componentContext,\n                A annotation,\n                C context,\n                ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public <A extends Annotation, C> Injectable getInjectable(\n                Class<? extends Annotation> annotationType,\n                ComponentContext componentContext,\n                A annotation,\n                C context,\n                List<ComponentScope> scopes) {\n            return null;\n        }\n\n        @Override\n        public <A extends Annotation, C> InjectableScopePair getInjectableWithScope(\n                Class<? extends Annotation> annotationType,\n                ComponentContext componentContext,\n                A annotation,\n                C context,\n                List<ComponentScope> scopes) {\n            return null;\n        }\n    }\n}\n"}
