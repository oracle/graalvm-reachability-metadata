[tool-call] delta {"path":"tests/src/com.sun.jersey/jersey-server/1.9/src/test/java/com_sun_jersey/jersey_server/ResourceComponentConstructorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_sun_jersey.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.jersey.api.core.HttpContext;\nimport com.sun.jersey.api.model.AbstractResource;\nimport com.sun.jersey.api.model.AbstractResourceConstructor;\nimport com.sun.jersey.api.model.Parameter;\nimport com.sun.jersey.api.model.Parameter.Source;\nimport com.sun.jersey.core.spi.component.ComponentContext;\nimport com.sun.jersey.core.spi.component.ComponentScope;\nimport com.sun.jersey.server.impl.inject.ServerInjectableProviderContext;\nimport com.sun.jersey.server.spi.component.ResourceComponentConstructor;\nimport com.sun.jersey.spi.inject.Injectable;\nimport com.sun.jersey.spi.inject.InjectableProviderContext.InjectableScopePair;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.AccessibleObject;\nimport java.util.ArrayList;\nimport java.util.Collections;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class ResourceComponentConstructorTest {\n    @Test\n    void constructsResourceUsingResourceClassDefaultConstructor() throws Exception {\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(),\n                ComponentScope.PerRequest,\n                new AbstractResource(DefaultConstructedResource.class));\n\n        DefaultConstructedResource resource = (DefaultConstructedResource) constructor.construct(null);\n\n        assertThat(resource.createdByDefaultConstructor).isTrue();\n    }\n\n    @Test\n    void constructsResourceUsingModeledNoArgumentConstructorAndRunsPostConstructMethod() throws Exception {\n        AbstractResource resourceModel = new AbstractResource(PostConstructedResource.class);\n        resourceModel.getConstructors().add(new AbstractResourceConstructor(\n                PostConstructedResource.class.getConstructor()));\n        resourceModel.getPostConstructMethods().add(PostConstructedResource.class.getMethod(\"markReady\"));\n\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(),\n                ComponentScope.PerRequest,\n                resourceModel);\n\n        PostConstructedResource resource = (PostConstructedResource) constructor.construct(null);\n\n        assertThat(resource.created).isTrue();\n        assertThat(resource.ready).isTrue();\n    }\n\n    @Test\n    void constructsResourceUsingInjectedConstructorParameter() throws Exception {\n        AbstractResourceConstructor abstractConstructor = new AbstractResourceConstructor(\n                ParameterConstructedResource.class.getConstructor(String.class));\n        abstractConstructor.getParameters().add(new Parameter(\n                new Annotation[0],\n                null,\n                Source.UNKNOWN,\n                \"message\",\n                String.class,\n                String.class));\n        AbstractResource resourceModel = new AbstractResource(ParameterConstructedResource.class);\n        resourceModel.getConstructors().add(abstractConstructor);\n\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(new FixedInjectable(\"injected value\")),\n                ComponentScope.PerRequest,\n                resourceModel);\n\n        ParameterConstructedResource resource = (ParameterConstructedResource) constructor.construct(null);\n\n        assertThat(resource.message).isEqualTo(\"injected value\");\n    }\n\n    public static class DefaultConstructedResourc