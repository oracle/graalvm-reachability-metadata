onstructor;\nimport com.sun.jersey.spi.inject.Injectable;\nimport com.sun.jersey.spi.inject.InjectableProviderContext.InjectableScopePair;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.AccessibleObject;\nimport java.util.ArrayList;\nimport java.util.Collections;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class ResourceComponentConstructorTest {\n    @Test\n    void constructsResourceUsingResourceClassDefaultConstructor() throws Exception {\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(),\n                ComponentScope.PerRequest,\n                new AbstractResource(DefaultConstructedResource.class));\n\n        DefaultConstructedResource resource = (DefaultConstructedResource) constructor.construct(null);\n\n        assertThat(resource.createdByDefaultConstructor).isTrue();\n    }\n\n    @Test\n    void constructsResourceUsingModeledNoArgumentConstructorAndRunsPostConstructMethod() throws Exception {\n        AbstractResource resourceModel = new AbstractResource(PostConstructedResource.class);\n        resourceModel.getConstructors().add(new AbstractResourceConstructor(\n                PostConstructedResource.class.getConstructor()));\n        resourceModel.getPostConstructMethods().add(PostConstructedResource.class.getMethod(\"markReady\"));\n\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(),\n                ComponentScope.PerRequest,\n                resourceModel);\n\n        PostConstructedResource resource = (PostConstructedResource) constructor.construct(null);\n\n        assertThat(resource.created).isTrue();\n        assertThat(resource.ready).isTrue();\n    }\n\n    @Test\n    void constructsResourceUsingInjectedConstructorParameter() throws Exception {\n        AbstractResourceConstructor abstractConstructor = new AbstractResourceConstructor(\n                ParameterConstructedResource.class.getConstructor(String.class));\n        abstractConstructor.getParameters().add(new Parameter(\n                new Annotation[0],\n                null,\n                Source.UNKNOWN,\n                \"message\",\n                String.class,\n                String.class));\n        AbstractResource resourceModel = new AbstractResource(ParameterConstructedResource.class);\n        resourceModel.getConstructors().add(abstractConstructor);\n\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(new FixedInjectable(\"injected value\")),\n                ComponentScope.PerRequest,\n                resourceModel);\n\n        ParameterConstructedResource resource = (ParameterConstructedResource) constructor.construct(null);\n\n        assertThat(resource.message).isEqualTo(\"injected value\");\n    }\n\n    public static class DefaultConstructedResource {\n        private final boolean createdByDefaultConstructor;\n\n        public DefaultConstructedResource() {\n            this.createdByDefaultConstructor = true;\n        }\n    }\n\n    public static class PostConstructedResource {\n        private final boolean created;\n        private boolean ready;\n\n        public PostConstructedResource() {\n            this.created = true;\n        }\n\n        public void markReady() {\n            this.ready = true;\n        }\n    }\n\n    public static class ParameterConstructedResource {\n        private final String message;\n\n        public ParameterConstructedResource(String message) {\n            this.message = message;\n        }\n    }\n\n    private static class FixedInjectable implements Injectable<String> {\n        private final String value;\n\n        FixedInjectable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getValue() {\n            return value;\n        }\n    }\n\n    private static class FixedInjectableProviderContext implements ServerInjectableProviderContext {\n        private final List<Injectable> constructorInjectables;\n\n        FixedInjectableProviderContext(Injectable... constructorInjectables) {\n            this.constructorInjectables = new ArrayList<Injectable>();\n            Collections.addAll(this.constructorInjectables, constructorInjectables);\n        }\n\n        @Override\n        public boolean isParameterTypeRegistered(Parameter parameter) {\n            return false;\n        }\n\n        @Override\n        public Injectable getInjectable(Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public Injectable getInjectable(AccessibleObject accessibleObject, Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public InjectableScopePair getInjectableiWithScope(Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public InjectableScopePair getInjectableiWithScope(\n                AccessibleObject accessibleObject,\n                Parameter parameter,\n                ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public List<Injectable> getInjectable(List<Parameter> parameters, ComponentScope scope) {\n            return constructorInjectables;\n        }\n\n        @Override\n        public List<Injectable> getInjectable(\n                AccessibleObject accessibleObject,\n                List<Parameter> parameters,\n                ComponentScope scope) {\n            return constructorInjectables;\n        }\n\n        @Override\n        public boolean isAnnotationRegistered(\n                Class<? extends Annotation> annotationType,\n                Class<?> parameterType) {\n            return false;\n        }\n\n        @Override\n        public boolean isInjectableProviderRegistered(\n                Class<? extends Annotation> annotationType,\n                Class<?> parameterType,\n                ComponentScope scope) {\n            return false;\n        }\n\n        @Override\n        public <A extends Annotation, C> Injectable getInjectable(\n                Class<? extends Annotation> annotationType,\n                ComponentContext componentContext,\n                A annotation,\n                C context,\n                ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public <A extends Annotation, C> Injectable getInjectable(\n                Class<? extends Annotation> annotationType,\n                ComponentContext componentContext,\n                A annotation,\n                C context,\n                List<ComponentScope> scopes) {\n            return null;\n        }\n\n        @Override\n        public <A extends Annotation, C> InjectableScopePair getInjectableWithScope(\n                Class<? extends Annotation> annotationType,\n                ComponentContext componentContext,\n                A annotation,\n                C context,\n                List<ComponentScope> scopes) {\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1539, "output": 2144, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 24163, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778309829486, "responseId": "resp_0468e23c4760039b0169fedac62ef88197b7bd0cba9e6f0f14"}}
