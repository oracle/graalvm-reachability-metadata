string\")\n                .prop(\"qualifiedName\", \"converted-name\")\n                .prop(\"resourceStream\", RESOURCE_NAME)\n                .prop(\"classpathFile\", \"classpath:/\" + RESOURCE_NAME)\n                .prop(\"plainFile\", \"target/generated-wadl.xml\")\n                .build();\n\n        WadlGenerator wadlGenerator = wadlGeneratorConfig.createWadlGenerator();\n\n        assertThat(wadlGenerator).isInstanceOf(PropertyCapturingWadlGenerator.class);\n        assertThat(PropertyCapturingWadlGenerator.configuredValues).hasSize(1);\n        PropertyValues values = PropertyCapturingWadlGenerator.configuredValues.get(0);\n        assertThat(values.exactValue).isEqualTo(\"direct-string\");\n        assertThat(values.qualifiedName).isEqualTo(new QName(\"converted-name\"));\n        assertThat(values.resourceText).contains(\"loaded from the test classpath\");\n        assertThat(values.classpathFile).isFile().hasName(RESOURCE_NAME);\n        assertThat(values.plainFile).isEqualTo(new File(\"target/generated-wadl.xml\"));\n        assertThat(values.delegate).isNotNull();\n    }\n\n    public static class PropertyCapturingWadlGenerator implements WadlGenerator {\n        private static final List<PropertyValues> configuredValues = new ArrayList<PropertyValues>();\n\n        private WadlGenerator delegate;\n        private String exactValue;\n        private QName qualifiedName;\n        private InputStream resourceStream;\n        private File classpathFile;\n        private File plainFile;\n\n        public PropertyCapturingWadlGenerator() {\n        }\n\n        public void setExactValue(String exactValue) {\n            this.exactValue = exactValue;\n        }\n\n        public void setQualifiedName(QName qualifiedName) {\n            this.qualifiedName = qualifiedName;\n        }\n\n        public void setResourceStream(InputStream resourceStream) {\n            this.resourceStream = resourceStream;\n        }\n\n        public void setClasspathFile(File classpathFile) {\n            this.classpathFile = classpathFile;\n        }\n\n        public void setPlainFile(File plainFile) {\n            this.plainFile = plainFile;\n        }\n\n        @Override\n        public void setWadlGeneratorDelegate(WadlGenerator delegate) {\n            this.delegate = delegate;\n        }\n\n        @Override\n        public void init() throws Exception {\n            if (delegate != null) {\n                delegate.init();\n            }\n            configuredValues.add(new PropertyValues(\n                    delegate,\n                    exactValue,\n                    qualifiedName,\n                    readResourceStream(),\n                    classpathFile,\n                    plainFile));\n        }\n\n        private String readResourceStream() throws IOException {\n            byte[] bytes = new byte[resourceStream.available()];\n            int readBytes = resourceStream.read(bytes);\n            return new String(bytes, 0, readBytes, StandardCharsets.UTF_8);\n        }\n\n        @Override\n        public String getRequiredJaxbContextPath() {\n            return delegate.getRequiredJaxbContextPath();\n        }\n\n        @Override\n        public Application createApplication() {\n            return delegate.createApplication();\n        }\n\n        @Override\n        public Resources createResources() {\n            return delegate.createResources();\n        }\n\n        @Override\n        public Resource createResource(AbstractResource resource, String path) {\n            return delegate.createResource(resource, path);\n        }\n\n        @Override\n        public com.sun.research.ws.wadl.Method createMethod(\n                AbstractResource resource,\n                AbstractResourceMethod method) {\n            return delegate.createMethod(resource, method);\n        }\n\n        @Override\n        public Request createRequest(AbstractResource resource, AbstractResourceMethod method) {\n            return delegate.createRequest(resource, method);\n        }\n\n        @Override\n        public Representation createRequestRepresentation(\n                AbstractResource resource,\n                AbstractResourceMethod method,\n                MediaType mediaType) {\n            return delegate.createRequestRepresentation(resource, method, mediaType);\n        }\n\n        @Override\n        public Response createResponse(AbstractResource resource, AbstractResourceMethod method) {\n            return delegate.createResponse(resource, method);\n        }\n\n        @Override\n        public Param createParam(AbstractResource resource, AbstractMethod method, Parameter parameter) {\n            return delegate.createParam(resource, method, parameter);\n        }\n\n        @Override\n        public ExternalGrammarDefinition createExternalGrammar() {\n            return delegate.createExternalGrammar();\n        }\n\n        @Override\n        public void attachTypes(ApplicationDescription description) {\n            delegate.attachTypes(description);\n        }\n    }\n\n    private static class PropertyValues {\n        private final WadlGenerator delegate;\n        private final String exactValue;\n        private final QName qualifiedName;\n        private final String resourceText;\n        private final File classpathFile;\n        private final File plainFile;\n\n        PropertyValues(\n                WadlGenerator delegate,\n                String exactValue,\n                QName qualifiedName,\n                String resourceText,\n                File classpathFile,\n                File plainFile) {\n            this.delegate = delegate;\n            this.exactValue = exactValue;\n            this.qualifiedName = qualifiedName;\n            this.resourceText = resourceText;\n            this.classpathFile = classpathFile;\n            this.plainFile = plainFile;\n        }\n    }\n}\n"}
