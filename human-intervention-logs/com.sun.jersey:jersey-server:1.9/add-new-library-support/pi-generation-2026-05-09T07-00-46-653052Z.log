rt static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.jersey.api.model.AbstractResource;\nimport com.sun.jersey.api.model.AbstractResourceConstructor;\nimport com.sun.jersey.api.model.Parameter;\nimport com.sun.jersey.api.model.Parameter.Source;\nimport com.sun.jersey.core.spi.component.ComponentContext;\nimport com.sun.jersey.core.spi.component.ComponentScope;\nimport com.sun.jersey.server.impl.inject.ServerInjectableProviderContext;\nimport com.sun.jersey.server.spi.component.ResourceComponentConstructor;\nimport com.sun.jersey.spi.inject.Injectable;\nimport com.sun.jersey.spi.inject.InjectableProviderContext.InjectableScopePair;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.AccessibleObject;\nimport java.util.ArrayList;\nimport java.util.Collections;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\npublic class ResourceComponentConstructorTest {\n    @Test\n    void constructsResourceUsingResourceClassDefaultConstructor() throws Exception {\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(),\n                ComponentScope.PerRequest,\n                new AbstractResource(DefaultConstructedResource.class));\n\n        DefaultConstructedResource resource = (DefaultConstructedResource) constructor.construct(null);\n\n        assertThat(resource.createdByDefaultConstructor).isTrue();\n    }\n\n    @Test\n    void constructsResourceUsingModeledNoArgumentConstructorAndRunsPostConstructMethod() throws Exception {\n        AbstractResource resourceModel = new AbstractResource(PostConstructedResource.class);\n        resourceModel.getConstructors().add(new AbstractResourceConstructor(\n                PostConstructedResource.class.getConstructor()));\n        resourceModel.getPostConstructMethods().add(PostConstructedResource.class.getMethod(\"markReady\"));\n\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(),\n                ComponentScope.PerRequest,\n                resourceModel);\n\n        PostConstructedResource resource = (PostConstructedResource) constructor.construct(null);\n\n        assertThat(resource.created).isTrue();\n        assertThat(resource.ready).isTrue();\n    }\n\n    @Test\n    void constructsResourceUsingInjectedConstructorParameter() throws Exception {\n        AbstractResourceConstructor abstractConstructor = new AbstractResourceConstructor(\n                ParameterConstructedResource.class.getConstructor(String.class));\n        abstractConstructor.getParameters().add(new Parameter(\n                new Annotation[0],\n                null,\n                Source.UNKNOWN,\n                \"message\",\n                String.class,\n                String.class));\n        AbstractResource resourceModel = new AbstractResource(ParameterConstructedResource.class);\n        resourceModel.getConstructors().add(abstractConstructor);\n\n        ResourceComponentConstructor constructor = new ResourceComponentConstructor(\n                new FixedInjectableProviderContext(new FixedInjectable(\"injected value\")),\n                ComponentScope.PerRequest,\n                resourceModel);\n\n        ParameterConstructedResource resource = (ParameterConstructedResource) constructor.construct(null);\n\n        assertThat(resource.message).isEqualTo(\"injected value\");\n    }\n\n    public static class DefaultConstructedResource {\n        private final boolean createdByDefaultConstructor;\n\n        public DefaultConstructedResource() {\n            this.createdByDefaultConstructor = true;\n        }\n    }\n\n    public static class PostConstructedResource {\n        private final boolean created;\n        private boolean ready;\n\n        public PostConstructedResource() {\n            this.created = true;\n        }\n\n        public void markReady() {\n            this.ready = true;\n        }\n    }\n\n    public static class ParameterConstructedResource {\n        private final String message;\n\n        public ParameterConstructedResource(String message) {\n            this.message = message;\n        }\n    }\n\n    private static class FixedInjectable implements Injectable<String> {\n        private final String value;\n\n        FixedInjectable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getValue() {\n            return value;\n        }\n    }\n\n    private static class FixedInjectableProviderContext implements ServerInjectableProviderContext {\n        private final List<Injectable> constructorInjectables;\n\n        FixedInjectableProviderContext(Injectable... constructorInjectables) {\n            this.constructorInjectables = new ArrayList<Injectable>();\n            Collections.addAll(this.constructorInjectables, constructorInjectables);\n        }\n\n        @Override\n        public boolean isParameterTypeRegistered(Parameter parameter) {\n            return false;\n        }\n\n        @Override\n        public Injectable getInjectable(Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public Injectable getInjectable(AccessibleObject accessibleObject, Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public InjectableScopePair getInjectableiWithScope(Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public InjectableScopePair getInjectableiWithScope(\n                AccessibleObject accessibleObject,\n                Parameter parameter,\n                ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public List<Injectable> getInjectable(List<Parameter> parameters, ComponentScope scope) {\n            return constructorInjectables;\n   