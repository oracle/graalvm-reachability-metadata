          processParameters(
                  concreteClass, declaringClass,
                  parametrized,
                  ((null != ctor.getAnnotation(Encoded.class)) || isEncoded),
                  parameterTypes,
                  genericParameterTypes,
                  ctor.getParameterAnnotations());
