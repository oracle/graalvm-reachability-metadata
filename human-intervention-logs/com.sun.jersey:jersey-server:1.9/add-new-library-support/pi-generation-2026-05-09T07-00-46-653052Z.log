  public class WadlGeneratorLoaderTest {
      private static final String RESOURCE_NAME = "wadl-generator-loader-resource.txt";
  
      @BeforeEach
      void resetConfiguredValues() {
          PropertyCapturingWadlGenerator.configuredValues.clear();
      }
  
      @Test
      void createsConfiguredGeneratorUsingSupportedPropertyConversions() {
          WadlGeneratorConfig wadlGeneratorConfig = WadlGeneratorConfig
                  .generator(PropertyCapturingWadlGenerator.class)
                  .prop("exactValue", "direct-string")
                  .prop("qualifiedName", "converted-name")
                  .prop("resourceStream", RESOURCE_NAME)
                  .prop("plainFile", "target/generated-wadl.xml")
                  .build();
  
          WadlGenerator wadlGenerator = wadlGeneratorConfig.createWadlGenerator();
  
          assertThat(wadlGenerator).isInstanceOf(PropertyCapturingWadlGenerator.class);
          assertThat(PropertyCapturingWadlGenerator.configuredValues).hasSize(1);
          PropertyValues values = PropertyCapturingWadlGenerator.configuredValues.get(0);
          assertThat(values.exactValue).isEqualTo("direct-string");
          assertThat(values.qualifiedName).isEqualTo(new QName("converted-name"));
          assertThat(values.resourceText).contains("loaded from the test classpath");
          assertThat(values.plainFile).isEqualTo(new File("target/generated-wadl.xml"));
          assertThat(values.delegate).isNotNull();
      }
  
      @Test
      void createsConfiguredGeneratorUsingClasspathFileProperty() {
          WadlGeneratorConfig wadlGeneratorConfig = WadlGeneratorConfig
                  .generator(PropertyCapturingWadlGenerator.class)
                  .prop("classpathFile", "classpath:/" + RESOURCE_NAME)
                  .build();
  
          RuntimeException classpathFileException = null;
          try {
              wadlGeneratorConfig.createWadlGenerator();
          } catch (RuntimeException e) {
              classpathFileException = e;
          }
  
          if (classpathFileException == null) {
              assertThat(PropertyCapturingWadlGenerator.configuredValues).hasSize(1);
              PropertyValues values = PropertyCapturingWadlGenerator.configuredValues.get(0);
              assertThat(values.classpathFile).isFile().hasName(RESOURCE_NAME);
          } else {
              assertThat(rootCause(classpathFileException)).isInstanceOf(IllegalArgumentException.class);
          }
      }
  
      private static Throwable rootCause(Throwable throwable) {
          Throwable result = throwable;
          while (result.getCause() != null) {
              result = result.getCause();
          }
          return result;
      }
  
      public static class PropertyCapturingWadlGenerator implements WadlGenerator {
          private static final List<PropertyValues> configuredValues = new ArrayList<PropertyValues>();
  
          private WadlGenerator delegate;
          private String exactValue;
          private QName qualifiedName;
          private InputStream resourceStream;
          private File classpathFile;
          private File plainFile;
  
          public PropertyCapturingWadlGenerator() {
          }
  
          public void setExactValue(String exactValue) {
              this.exactValue = exactValue;
          }
  
          public void setQualifiedName(QName qualifiedName) {
              this.qualifiedName = qualifiedName;
          }
  
          public void setResourceStream(InputStream resourceStream) {
              this.resourceStream = resourceStream;
          }
  
          public void setClasspathFile(File classpathFile) {
              this.classpathFile = classpathFile;
          }
  
          public void setPlainFile(File plainFile) {
              this.plainFile = plainFile;
          }
  
          @Override
          public void setWadlGeneratorDelegate(WadlGenerator delegate) {
              this.delegate = delegate;
          }
  
          @Override
          public void init() throws Exception {
              if (delegate != null) {
                  delegate.init();
              }
              configuredValues.add(new PropertyValues(
                      delegate,
                      exactValue,
                      qualifiedName,
                      readResourceStream(),
                      classpathFile,
                      plainFile));
          }
  
          private String readResourceStream() throws IOException {
              if (resourceStream == null) {
                  return null;
              }
              byte[] bytes = new byte[resourceStream.available()];
              int readBytes = resourceStream.read(bytes);
              return new String(bytes, 0, readBytes, StandardCharsets.UTF_8);
          }
  
          @Override
          public String getRequiredJaxbContextPath() {
              return delegate.getRequiredJaxbContextPath();
          }
  
          @Override
          public Application createApplication() {
              return delegate.createApplication();
          }
  
          @Override
          public Resources createResources() {
              return delegate.createResources();
          }
  
          @Override
          public Resource createResource(AbstractResource resource, String path) {
              return delegate.createResource(resource, path);
          }
  
          @Override
          public Method createMethod(
                  AbstractResource resource,
                  AbstractResourceMethod method) {
              return delegate.createMethod(resource, method);
          }
  
          @Override
          public Request createRequest(AbstractResource resource, AbstractResourceMethod method) {
              return delegate.createRequest(resource, method);
          }
  
          @Override
          public Representation createRequestRepresentation(
                  AbstractResource resource,
                  AbstractResourceMethod method,
                  MediaType mediaType) {
              return delegate.createRequestRepresentation(resource, method, mediaType);
          }
  
          @Override
          public Response createResponse(AbstractResource resource, AbstractResourceMethod method) {
              return delegate.createResponse(resource, method);
          }
  
          @Override
          public Param createParam(AbstractResource resource, AbstractMethod method, Parameter parameter) {
              return delegate.createParam(resource, method, parameter);
          }
  
          @Override
          public ExternalGrammarDefinition createExternalGrammar() {
              return delegate.createExternalGrammar();
          }
  
          @Override
          public void attachTypes(ApplicationDescription description) {
              delegate.attachTypes(description);
          }
      }
  
      private static class PropertyValues {
          private final WadlGenerator delegate;
          private final String exactValue;
          private final QName qualifiedName;
          private final String resourceText;
          private final File classpathFile;
          private final File plainFile;
  
          PropertyValues(
                  WadlGenerator delegate,
                  String exactValue,
                  QName qualifiedName,
                  String resourceText,
                  File classpathFile,
                  File plainFile) {
              this.delegate = delegate;
              this.exactValue = exactValue;
              this.qualifiedName = qualifiedName;
              this.resourceText = resourceText;
              this.classpathFile = classpathFile;
              this.plainFile = plainFile;
          }
      }
  }
