  package com.sun.jersey.server.impl.modelapi.annotation;
  
  import com.sun.jersey.core.reflection.AnnotatedMethod;
  import com.sun.jersey.core.reflection.MethodList;
  import com.sun.jersey.core.header.MediaTypes;
