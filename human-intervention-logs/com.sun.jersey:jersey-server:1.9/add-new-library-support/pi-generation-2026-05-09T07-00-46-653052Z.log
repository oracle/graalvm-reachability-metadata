[tool-call] delta {"path":"tests/src/com.sun.jersey/jersey-server/1.9/src/test/java/com_sun_jersey/jersey_server/IntrospectionModellerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_sun_jersey.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.jersey.api.model.AbstractField;\nimport com.sun.jersey.api.model.AbstractResource;\nimport com.sun.jersey.api.model.AbstractResourceConstructor;\nimport com.sun.jersey.api.model.Parameter;\nimport com.sun.jersey.api.model.Parameter.Source;\nimport com.sun.jersey.server.impl.modelapi.annotation.IntrospectionModeller;\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\nimport javax.ws.rs.Path;\nimport org.junit.jupiter.api.Test;\n\npublic class IntrospectionModellerTest {\n    @Test\n    void modelsPublicConstructorsAndUnknownAnnotatedFields() {\n        AbstractResource resource = IntrospectionModeller.createResource(IntrospectedRootResource.class);\n\n        assertThat(resource.isRootResource()).isTrue();\n        assertThat(resource.getPath().getValue()).isEqualTo(\"introspected\");\n        assertThat(resource.getConstructors())\n                .hasSize(2)\n                .anySatisfy(this::assertDefaultConstructor)\n                .anySatisfy(this::assertUnknownAnnotatedConstructorParameter);\n        assertThat(resource.getFields())\n                .singleElement()\n                .satisfies(this::assertUnknownAnnotatedField);\n    }\n\n    private void assertDefaultConstructor(AbstractResourceConstructor constructor) {\n        assertThat(constructor.getParameters()).isEmpty();\n    }\n\n    private void assertUnknownAnnotatedConstructorParameter(AbstractResourceConstructor constructor) {\n        if (constructor.getParameters().isEmpty()) {\n            return;\n        }\n\n        assertThat(constructor.getParameters())\n                .singleElement()\n                .satisfies(parameter -> assertUnknownParameter(parameter, \"constructor-value\"));\n    }\n\n    private void assertUnknownAnnotatedField(AbstractField field) {\n        assertThat(field.getParameters())\n                .singleElement()\n                .satisfies(parameter -> assertUnknownParameter(parameter, \"field-value\"));\n    }\n\n    private void assertUnknownParameter(Parameter parameter, String expectedName) {\n        assertThat(parameter.getSource()).isEqualTo(Source.UNKNOWN);\n        assertThat(parameter.getSourceName()).isEqualTo(expectedName);\n        assertThat(parameter.getParameterClass()).isEqualTo(String.class);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface TestParam {\n        String value();\n    }\n\n    @Path(\"introspected\")\n    public static class IntrospectedRootResource {\n        @TestParam(\"field-value\")\n        private String field;\n\n        public IntrospectedRootResource() {\n        }\n\n        public IntrospectedRootResource(@TestParam(\"constructor-value\") String value) {\n            this.field = value;\n        }\n    }\n}\n"}
