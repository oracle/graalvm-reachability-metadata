[tool-call] delta {"path":"tests/src/com.sun.jersey/jersey-server/1.9/src/test/java/com_sun_jersey/jersey_server/ResourceComponentInjectorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_sun_jersey.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.jersey.api.model.AbstractField;\nimport com.sun.jersey.api.model.AbstractResource;\nimport com.sun.jersey.api.model.AbstractSetterMethod;\nimport com.sun.jersey.api.model.Parameter;\nimport com.sun.jersey.api.model.Parameter.Source;\nimport com.sun.jersey.core.spi.component.ComponentContext;\nimport com.sun.jersey.core.spi.component.ComponentScope;\nimport com.sun.jersey.server.impl.inject.ServerInjectableProviderContext;\nimport com.sun.jersey.server.spi.component.ResourceComponentInjector;\nimport com.sun.jersey.spi.inject.Injectable;\nimport com.sun.jersey.spi.inject.InjectableProviderContext.InjectableScopePair;\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.AccessibleObject;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.util.Collections;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\npublic class ResourceComponentInjectorTest {\n    @Test\n    void injectsSingletonAndPerRequestFieldsAndSetters() throws Exception {\n        AbstractResource resourceModel = resourceModelWithFieldsAndSetters();\n        ResourceComponentInjector injector = new ResourceComponentInjector(\n                new NamedInjectableProviderContext()\n                        .register(\"singleton-field\", \"singleton field value\", ComponentScope.Singleton)\n                        .register(\"per-request-field\", \"per request field value\", ComponentScope.PerRequest)\n                        .register(\"singleton-setter\", \"singleton setter value\", ComponentScope.Singleton)\n                        .register(\"per-request-setter\", \"per request setter value\", ComponentScope.PerRequest),\n                ComponentScope.PerRequest,\n                resourceModel);\n        InjectableResource resource = new InjectableResource();\n\n        injector.inject(null, resource);\n\n        assertThat(injector.hasInjectableArtifacts()).isTrue();\n        assertThat(resource.singletonField).isEqualTo(\"singleton field value\");\n        assertThat(resource.perRequestField).isEqualTo(\"per request field value\");\n        assertThat(resource.singletonSetterValue).isEqualTo(\"singleton setter value\");\n        assertThat(resource.perRequestSetterValue).isEqualTo(\"per request setter value\");\n    }\n\n    private AbstractResource resourceModelWithFieldsAndSetters() throws Exception {\n        AbstractResource resourceModel = new AbstractResource(InjectableResource.class);\n        resourceModel.getFields().add(abstractField(\"singletonField\", \"singleton-field\"));\n        resourceModel.getFields().add(abstractField(\"perRequestField\", \"per-request-field\"));\n        resourceModel.getSetterMethods().add(abstractSetter(resourceModel, \"setSingletonSetterValue\", \"singleton-setter\"));\n        resourceModel.getSetterMethods().add(abstractSetter(resourceModel, \"setPerRequestSetterValue\", \"per-request-setter\"));\n        return resourceModel;\n    }\n\n    private AbstractField abstractField(String fieldName, String parameterName) throws Exception {\n        Field field = InjectableResource.class.getDeclaredField(fieldName);\n        AbstractField abstractField = new AbstractField(field);\n        abstractField.getParameters().add(parameter(parameterName));\n        return abstractField;\n    }\n\n    private AbstractSetterMethod abstractSetter(\n            AbstractResource resourceModel,\n            String methodName,\n            String parameterName) throws Exception {\n        Method method = InjectableResource.class.getMethod(methodName, String.class);\n        AbstractSetterMethod setter = new AbstractSetterMethod(resourceModel, method, new Annotation[0]);\n        setter.getParameters().add(parameter(parameterName));\n        return setter;\n    }\n\n    private Parameter parameter(String name) {\n        return new Parameter(new Annotation[0], null, Source.UNKNOWN, name, String.class, String.class);\n    }\n\n    public static class InjectableResource {\n        private String singletonField;\n        private String perRequestField;\n        private String singletonSetterValue;\n        private String perRequestSetterValue;\n\n        public void setSingletonSetterValue(String singletonSetterValue) {\n            this.singletonSetterValue = singletonSetterValue;\n        }\n\n        public void setPerRequestSetterValue(String perRequestSetterValue) {\n            this.perRequestSetterValue = perRequestSetterValue;\n        }\n    }\n\n    private static class FixedInjectable implements Injectable<String> {\n        private final String value;\n\n        FixedInjectable(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String getValue() {\n            return value;\n        }\n    }\n\n    private static class NamedInjectableProviderContext implements ServerInjectableProviderContext {\n        private final Map<String, InjectableScopePair> injectables = new HashMap<String, InjectableScopePair>();\n\n        NamedInjectableProviderContext register(String parameterName, String value, ComponentScope scope) {\n            injectables.put(parameterName, new InjectableScopePair(new FixedInjectable(value), scope));\n            return this;\n        }\n\n        @Override\n        public boolean isParameterTypeRegistered(Parameter parameter) {\n            return false;\n        }\n\n        @Override\n        public Injectable getInjectable(Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public Injectable getInjectable(AccessibleObject accessibleObject, Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public InjectableScopePair getInjectableiWithScope(Parameter parameter, ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public InjectableScopePair getInjectableiWithScope(\n                AccessibleObject accessibleObject,\n                Parameter parameter,\n                ComponentScope scope) {\n            return injectables.get(parameter.getSourceName());\n        }\n\n        @Override\n        public List<Injectable> getInjectable(List<Parameter> parameters, ComponentScope scope) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public List<Injectable> getInjectable(\n                AccessibleObject accessibleObject,\n                List<Parameter> parameters,\n                ComponentScope scope) {\n            return Collections.emptyList();\n        }\n\n        @Override\n        public boolean isAnnotationRegistered(\n                Class<? extends Annotation> annotationType,\n                Class<?> parameterType) {\n            return false;\n        }\n\n        @Override\n        public boolean isInjectableProviderRegistered(\n                Class<? extends Annotation> annotationType,\n                Class<?> parameterType,\n                ComponentScope scope) {\n            return false;\n        }\n\n        @Override\n        public <A extends Annotation, C> Injectable getInjectable(\n                Class<? extends Annotation> annotationType,\n                ComponentContext componentContext,\n                A annotation,\n                C context,\n                ComponentScope scope) {\n            return null;\n        }\n\n        @Override\n        public <A extends Annotation, C> Injec