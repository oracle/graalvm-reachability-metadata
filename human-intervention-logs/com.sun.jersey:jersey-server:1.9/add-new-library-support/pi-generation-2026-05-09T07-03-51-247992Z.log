  package com_sun_jersey.jersey_server;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.jersey.api.model.AbstractField;
  import com.sun.jersey.api.model.AbstractResource;
  import com.sun.jersey.api.model.AbstractResourceConstructor;
  import com.sun.jersey.api.model.Parameter;
  import com.sun.jersey.api.model.Parameter.Source;
  import com.sun.jersey.server.impl.modelapi.annotation.IntrospectionModeller;
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  import javax.ws.rs.Path;
  import org.junit.jupiter.api.Test;
  
  public class IntrospectionModellerTest {
      @Test
      void modelsPublicConstructorsAndUnknownAnnotatedFields() {
          AbstractResource resource = IntrospectionModeller.createResource(IntrospectedRootResource.class);
  
          assertThat(resource.isRootResource()).isTrue();
          assertThat(resource.getPath().getValue()).isEqualTo("introspected");
          assertThat(resource.getConstructors()).hasSize(2);
          assertDefaultConstructorCount(resource);
          assertUnknownAnnotatedConstructorParameter(resource);
          assertThat(resource.getFields())
                  .singleElement()
                  .satisfies(this::assertUnknownAnnotatedField);
      }
  
      private void assertDefaultConstructorCount(AbstractResource resource) {
          long defaultConstructors = resource.getConstructors().stream()
                  .filter(constructor -> constructor.getParameters().isEmpty())
                  .count();
  
          assertThat(defaultConstructors).isEqualTo(1);
      }
  
      private void assertUnknownAnnotatedConstructorParameter(AbstractResource resource) {
          AbstractResourceConstructor constructor = resource.getConstructors().stream()
                  .filter(resourceConstructor -> !resourceConstructor.getParameters().isEmpty())
                  .findFirst()
                  .orElseThrow(AssertionError::new);
  
          assertThat(constructor.getParameters())
                  .singleElement()
                  .satisfies(parameter -> assertUnknownParameter(parameter, "constructor-value"));
      }
  
      private void assertUnknownAnnotatedField(AbstractField field) {
          assertThat(field.getParameters())
                  .singleElement()
                  .satisfies(parameter -> assertUnknownParameter(parameter, "field-value"));
      }
  
      private void assertUnknownParameter(Parameter parameter, String expectedName) {
          assertThat(parameter.getSource()).isEqualTo(Source.UNKNOWN);
          assertThat(parameter.getSourceName()).isEqualTo(expectedName);
          assertThat(parameter.getParameterClass()).isEqualTo(String.class);
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface TestParam {
          String value();
      }
  
      @Path("introspected")
      public static class IntrospectedRootResource {
          @TestParam("field-value")
          private String field;
  
          public IntrospectedRootResource() {
          }
  
          public IntrospectedRootResource(@TestParam("constructor-value") String value) {
              this.field = value;
          }
      }
  }
