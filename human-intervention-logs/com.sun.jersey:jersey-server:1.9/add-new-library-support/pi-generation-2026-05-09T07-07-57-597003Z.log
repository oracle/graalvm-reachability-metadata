eMethod;\nimport com.sun.jersey.api.model.Parameter;\nimport com.sun.jersey.api.wadl.config.WadlGeneratorConfig;\nimport com.sun.jersey.server.wadl.ApplicationDescription;\nimport com.sun.jersey.server.wadl.WadlGenerator;\nimport com.sun.jersey.server.wadl.WadlGenerator.ExternalGrammarDefinition;\nimport com.sun.research.ws.wadl.Application;\nimport com.sun.research.ws.wadl.Method;\nimport com.sun.research.ws.wadl.Param;\nimport com.sun.research.ws.wadl.Representation;\nimport com.sun.research.ws.wadl.Request;\nimport com.sun.research.ws.wadl.Resource;\nimport com.sun.research.ws.wadl.Resources;\nimport com.sun.research.ws.wadl.Response;\nimport java.io.File;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.ArrayList;\nimport java.util.List;\nimport javax.ws.rs.core.MediaType;\nimport javax.xml.namespace.QName;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class WadlGeneratorLoaderTest {\n    private static final String RESOURCE_NAME = \"wadl-generator-loader-resource.txt\";\n\n    @BeforeEach\n    void resetConfiguredValues() {\n        PropertyCapturingWadlGenerator.configuredValues.clear();\n    }\n\n    @Test\n    void createsConfiguredGeneratorUsingSupportedPropertyConversions() {\n        WadlGeneratorConfig wadlGeneratorConfig = WadlGeneratorConfig\n                .generator(PropertyCapturingWadlGenerator.class)\n                .prop(\"exactValue\", \"direct-string\")\n                .prop(\"qualifiedName\", \"converted-name\")\n                .prop(\"resourceStream\", RESOURCE_NAME)\n                .prop(\"plainFile\", \"target/generated-wadl.xml\")\n                .build();\n\n        WadlGenerator wadlGenerator = wadlGeneratorConfig.createWadlGenerator();\n\n        assertThat(wadlGenerator).isInstanceOf(PropertyCapturingWadlGenerator.class);\n        assertThat(PropertyCapturingWadlGenerator.configuredValues).hasSize(1);\n        PropertyValues values = PropertyCapturingWadlGenerator.configuredValues.get(0);\n        assertThat(values.exactValue).isEqualTo(\"direct-string\");\n        assertThat(values.qualifiedName).isEqualTo(new QName(\"converted-name\"));\n        assertThat(values.resourceText).contains(\"loaded from the test classpath\");\n        assertThat(values.plainFile).isEqualTo(new File(\"target/generated-wadl.xml\"));\n        assertThat(values.delegate).isNotNull();\n    }\n\n    @Test\n    void createsConfiguredGeneratorUsingClasspathFileProperty() {\n        WadlGeneratorConfig wadlGeneratorConfig = WadlGeneratorConfig\n                .generator(PropertyCapturingWadlGenerator.class)\n                .prop(\"classpathFile\", \"classpath:/\" + RESOURCE_NAME)\n                .build();\n\n        RuntimeException classpathFileException = null;\n        try {\n            wadlGeneratorConfig.createWadlGenerator();\n        } catch (RuntimeException e) {\n            classpathFileException = e;\n        }\n\n        if (classpathFileException == null) {\n            assertThat(PropertyCapturingWadlGenerator.configuredValues).hasSize(1);\n            PropertyValues values = PropertyCapturingWadlGenerator.configuredValues.get(0);\n            assertThat(values.classpathFile).isFile().hasName(RESOURCE_NAME);\n        } else {\n            assertThat(rootCause(classpathFileException)).isInstanceOf(IllegalArgumentException.class);\n        }\n    }\n\n    private static Throwable rootCause(Throwable throwable) {\n        Throwable result = throwable;\n        while (result.getCause() != null) {\n            result = result.getCause();\n        }\n        return result;\n    }\n\n    public static class PropertyCapturingWadlGenerator implements WadlGenerator {\n        private static final List<PropertyValues> configuredValues = new ArrayList<PropertyValues>();\n\n        private WadlGenerator delegate;\n        private String exactValue;\n        private QName qualifiedName;\n        private 