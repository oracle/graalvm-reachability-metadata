[tool-call] delta {"path":"tests/src/com.sun.jersey/jersey-server/1.9/src/test/java/com_sun_jersey/jersey_server/ContainerFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_sun_jersey.jersey_server;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport com.sun.jersey.api.container.ContainerFactory;\nimport com_sun_jersey.jersey_server.container_factory_support.WebResources;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class ContainerFactoryTest {\n    private static final String RESOURCE_CONFIG_PACKAGE = WebResources.class.getPackage().getName();\n\n    @BeforeEach\n    void resetResourceConfigState() {\n        WebResources.resetInstantiationCount();\n    }\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void loadsAndInstantiatesPackageWebResourcesConfiguration() {\n        assertThatThrownBy(() -> ContainerFactory.createContainer(Object.class, RESOURCE_CONFIG_PACKAGE))\n                .isInstanceOf(IllegalArgumentException.class)\n                .hasMessageContaining(\"No container provider supports the type\");\n\n        assertThat(WebResources.instantiationCount()).isEqualTo(1);\n    }\n}\n"}
