ionId].getName\\n+    val config: Config = ConfigFactory\\n+      .parseString(s\\\"\\\"\\\"\\n+          |akka.actor.typed.library-extensions = [\\\"$extensionIdClassName\\\"]\\n+          |\\\"\\\"\\\".stripMargin)\\n+      .withFallback(ConfigFactory.load())\\n+    val system: ActorSystem[Nothing] = ActorSystem[Nothing](Behaviors.empty, systemName, config)\\n+\\n+    try {\\n+      val extensionId: JavaSingletonExtensionId = JavaSingletonExtensionId.getInstance()\\n+      val extension: JavaSingletonExtensionId.LoadedExtension = system.extension(extensionId)\\n+\\n+      assertThat(system.hasExtension(extensionId)).isTrue\\n+      assertThat(extension.actorSystemName()).isEqualTo(systemName)\\n+      assertThat(JavaSingletonExtensionId.createdCount()).isEqualTo(1)\\n+    } finally {\\n+      system.terminate()\\n+      Await.result(system.whenTerminated, 10.seconds)\\n+    }\\n+  }\\n+}\\ndiff --git 1/tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/java/com_typesafe_akka/akka_actor_typed_2_13/JavaSingletonExtensionId.java 2/tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/java/com_typesafe_akka/akka_actor_typed_2_13/JavaSingletonExtensionId.java\\nnew file mode 100644\\nindex 0000000000..9d06cfd0ee\\n--- /dev/null\\n+++ 2/tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/java/com_typesafe_akka/akka_actor_typed_2_13/JavaSingletonExtensionId.java\\n@@ -0,0 +1,55 @@\\n+/*\\n+ * Copyright and related rights waived via CC0\\n+ *\\n+ * You should have received a copy of the CC0 legalcode along with this\\n+ * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n+ */\\n+package com_typesafe_akka.akka_actor_typed_2_13;\\n+\\n+import java.util.concurrent.atomic.AtomicInteger;\\n+\\n+import akka.actor.typed.ActorSystem;\\n+import akka.actor.typed.Extension;\\n+import akka.actor.typed.ExtensionId;\\n+\\n+public final class JavaSingletonExtensionId extends ExtensionId<JavaSingletonExtensionId.LoadedExtension> {\\n+    private static final JavaSingletonExtensionId INSTANCE = new JavaSingletonExtensionId();\\n+    private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\\n+\\n+    private JavaSingletonExtensionId() {\\n+    }\\n+\\n+    public static JavaSingletonExtensionId getInstance() {\\n+        return INSTANCE;\\n+    }\\n+\\n+    public static LoadedExtension get(final ActorSystem<?> system) {\\n+        return INSTANCE.apply(system);\\n+    }\\n+\\n+    public static int createdCount() {\\n+        return CREATED_COUNT.get();\\n+    }\\n+\\n+    public static void resetCreatedCount() {\\n+        CREATED_COUNT.set(0);\\n+    }\\n+\\n+    @Override\\n+    public LoadedExtension createExtension(final ActorSystem<?> system) {\\n+        CREATED_COUNT.incrementAndGet();\\n+        return new LoadedExtension(system.name());\\n+    }\\n+\\n+    public static final class LoadedExtension implements Extension {\\n+        private final String actorSystemName;\\n+\\n+        private LoadedExtension(final String actorSystemName) {\\n+            this.actorSystemName = actorSystemName;\\n+        }\\n+\\n+        public String actorSystemName() {\\n+            return actorSystemName;\\n+        }\\n+    }\\n+}\\n\"}], \"isError\": false, \"timestamp\": 1778042644337}]}\n[recv] {\"type\": \"turn_start\"}\n[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"assistant\", \"content\": [], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"totalTokens\": 0, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"stop\", \"timestamp\": 1778042644343}}\n[assistant-event] thinking_start\n[thinking] **Considering JavaSingleton and Scala compatibility**\n[thinking] \n[thinking] I need to understand how to implement `getInstance` in `JavaSingletonExtensionId`. There’s some uncertainty regarding S