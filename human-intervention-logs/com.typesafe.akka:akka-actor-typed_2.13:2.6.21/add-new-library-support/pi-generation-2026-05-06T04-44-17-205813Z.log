[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/java/com_typesafe_akka/akka_actor_typed_2_13/JavaSingletonExtensionId.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_typed_2_13;\n\nimport akka.actor.typed.ActorSystem;\nimport akka.actor.typed.Extension;\nimport akka.actor.typed.ExtensionId;\n\nimport java.util.concurrent.atomic.AtomicInteger;\n\npublic final class JavaSingletonExtensionId extends ExtensionId<JavaSingletonExtensionId.LoadedExtension> {\n    private static final JavaSingletonExtensionId INSTANCE = new JavaSingletonExtensionId();\n    private static final AtomicInteger CREATED_COUNT = new AtomicInteger();\n\n    private JavaSingletonExtensionId() {\n    }\n\n    public static JavaSingletonExtensionId getInstance() {\n        return INSTANCE;\n    }\n\n    public static LoadedExtension get(final ActorSystem<?> system) {\n        return INSTANCE.apply(system);\n    }\n\n    public static int createdCount() {\n        return CREATED_COUNT.get();\n    }\n\n    public static void resetCreatedCount() {\n        CREATED_COUNT.set(0);\n    }\n\n    @Override\n    public LoadedExtension createExtension(final ActorSystem<?> system) {\n        CREATED_COUNT.incrementAndGet();\n        return new LoadedExtension(system.name());\n    }\n\n    public static final class LoadedExtension implements Extension {\n        private final String actorSystemName;\n\n        private LoadedExtension(final String actorSystemName) {\n            this.actorSystemName = actorSystemName;\n        }\n\n        public String actorSystemName() {\n            return actorSystemName;\n        }\n    }\n}\n"}
