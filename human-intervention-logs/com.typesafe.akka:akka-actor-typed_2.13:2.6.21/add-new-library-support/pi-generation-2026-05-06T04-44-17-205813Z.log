  +package com_typesafe_akka.akka_actor_typed_2_13
  +
  +import scala.concurrent.Await
  +import scala.concurrent.duration.DurationInt
  +
  +import akka.actor.typed.ActorSystem
  +import akka.actor.typed.scaladsl.Behaviors
  +import com.typesafe.config.Config
  +import com.typesafe.config.ConfigFactory
  +import org.assertj.core.api.Assertions.assertThat
  +import org.junit.jupiter.api.Test
  +
  +class ExtensionsImplTest {
  +  @Test
  +  def loadExtensionsUsesJavaSingletonAccessor(): Unit = {
  +    JavaSingletonExtensionId.resetCreatedCount()
  +    val systemName: String = s"extensions-impl-test-${System.nanoTime()}"
  +    val extensionIdClassName: String = classOf[JavaSingletonExtensionId].getName
  +    val config: Config = ConfigFactory
  +      .parseString(s"""
  +          |akka.actor.typed.library-extensions = ["$extensionIdClassName"]
  +          |""".stripMargin)
  +      .withFallback(ConfigFactory.load())
  +    val system: ActorSystem[Nothing] = ActorSystem[Nothing](Behaviors.empty, systemName, config)
  +
  +    try {
  +      val extensionId: JavaSingletonExtensionId = JavaSingletonExtensionId.getInstance()
  +      val extension: JavaSingletonExtensionId.LoadedExtension = system.extension(extensionId)
  +
  +      assertThat(system.hasExtension(extensionId)).isTrue
  +      assertThat(extension.actorSystemName()).isEqualTo(systemName)
  +      assertThat(JavaSingletonExtensionId.createdCount()).isEqualTo(1)
  +    } finally {
  +      system.terminate()
  +      Await.result(system.whenTerminated, 10.seconds)
  +    }
  +  }
  +}
