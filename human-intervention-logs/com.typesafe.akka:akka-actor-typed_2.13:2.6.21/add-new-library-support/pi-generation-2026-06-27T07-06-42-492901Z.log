 = ActorSystem(Behaviors.ignore[String], systemName, config)\n+\n+    try {\n+      val extensionId: ExtensionsImplJavaExtensionId = ExtensionsImplJavaExtensionId.getInstance()\n+      assertThat(system.hasExtension(extensionId)).isTrue()\n+\n+      val extension: ExtensionsImplJavaExtensionId.TestExtension = system.extension(extensionId)\n+      assertThat(extension.systemName()).isEqualTo(systemName)\n+      assertThat(ExtensionsImplJavaExtensionId.get(system)).isSameAs(extension)\n+    } finally {\n+      system.terminate()\n+      Await.result(system.whenTerminated, 10.seconds)\n+    }\n+  }\n+}\ndiff --git 1/tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_actor_typed_2_13/ExtensionsImplJavaExtensionId.java 2/tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_actor_typed_2_13/ExtensionsImplJavaExtensionId.java\nnew file mode 100644\nindex 0000000000..a98ec2d2cd\n--- /dev/null\n+++ 2/tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_actor_typed_2_13/ExtensionsImplJavaExtensionId.java\n@@ -0,0 +1,43 @@\n+/*\n+ * Copyright and related rights waived via CC0\n+ *\n+ * You should have received a copy of the CC0 legalcode along with this\n+ * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n+ */\n+package com_typesafe_akka.akka_actor_typed_2_13;\n+\n+import akka.actor.typed.ActorSystem;\n+import akka.actor.typed.Extension;\n+import akka.actor.typed.ExtensionId;\n+\n+public final class ExtensionsImplJavaExtensionId extends ExtensionId<ExtensionsImplJavaExtensionId.TestExtension> {\n+    private static final ExtensionsImplJavaExtensionId INSTANCE = new ExtensionsImplJavaExtensionId();\n+\n+    private ExtensionsImplJavaExtensionId() {\n+    }\n+\n+    public static ExtensionsImplJavaExtensionId getInstance() {\n+        return INSTANCE;\n+    }\n+\n+    public static TestExtension get(ActorSystem<?> system) {\n+        return INSTANCE.apply(system);\n+    }\n+\n+    @Override\n+    public TestExtension createExtension(ActorSystem<?> system) {\n+        return new TestExtension(system.name());\n+    }\n+\n+    public static final class TestExtension implements Extension {\n+        private final String systemName;\n+\n+        private TestExtension(String systemName) {\n+            this.systemName = systemName;\n+        }\n+\n+        public String systemName() {\n+            return systemName;\n+        }\n+    }\n+}\n"}], "isError": false, "timestamp": 1782543961216}]}
