[tool-call] delta {"path":"tests/src/com.typesafe.akka/akka-actor-typed_2.13/2.6.21/src/test/scala/com_typesafe_akka/akka_actor_typed_2_13/ExtensionsImplTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_typesafe_akka.akka_actor_typed_2_13\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nimport akka.actor.typed.ActorSystem\nimport akka.actor.typed.scaladsl.Behaviors\nimport com.typesafe.config.ConfigFactory\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nclass ExtensionsImplTest {\n  @Test\n  def loadConfiguredJavaExtensionThroughSingletonAccessor(): Unit = {\n    val extensionIdClassName: String = classOf[ExtensionsImplJavaExtensionId].getName\n    val systemName: String = \"extensions-impl-test\"\n    val config = ConfigFactory\n      .parseString(s\"\"\"akka.actor.typed.extensions = [\"$extensionIdClassName\"]\"\"\")\n      .withFallback(ConfigFactory.load())\n    val system: ActorSystem[String] = ActorSystem(Behaviors.ignore[String], systemName, config)\n\n    try {\n      val extensionId: ExtensionsImplJavaExtensionId = ExtensionsImplJavaExtensionId.getInstance()\n      assertThat(system.hasExtension(extensionId)).isTrue()\n\n      val extension: ExtensionsImplJavaExtensionId.TestExtension = system.extension(extensionId)\n      assertThat(extension.systemName()).isEqualTo(systemName)\n      assertThat(ExtensionsImplJavaExtensionId.get(system)).isSameAs(extension)\n    } finally {\n      system.terminate()\n      Await.result(system.whenTerminated, 10.seconds)\n    }\n  }\n}\n"}
