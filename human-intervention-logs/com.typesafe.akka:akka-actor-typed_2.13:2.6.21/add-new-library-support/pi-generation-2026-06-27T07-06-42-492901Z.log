  object ActorSystem {
  
    /**
     * Scala API: Create an ActorSystem
     */
    def apply[T](guardianBehavior: Behavior[T], name: String): ActorSystem[T] =
      createInternal(name, guardianBehavior, Props.empty, ActorSystemSetup.create(BootstrapSetup()))
  
    /**
