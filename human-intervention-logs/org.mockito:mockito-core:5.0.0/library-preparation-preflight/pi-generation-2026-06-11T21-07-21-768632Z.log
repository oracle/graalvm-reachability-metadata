[assistant] {
[assistant]   "action": "advisory_preparation",
[assistant]   "summary": "Mockito 5.0.0 depends only on transitive Byte Buddy/Objenesis artifacts and needs no extra Maven dependency or Docker service, but native-image-relevant tests need Mockito configured away from its Mockito 5 default inline mock maker before reliable meaningful coverage is reachable.",
[assistant]   "deterministic_setup": [],
[assistant]   "agent_guidance": "Configure Mockito tests with `src/test/resources/mockito-extensions/org.mockito.plugins.MockMaker` containing `mock-maker-proxy` or `org.mockito.internal.creation.proxy.ProxyMockMaker`, and focus coverage on interface mocks, stubbing, verification, argument captors, answers, sessions, and related core APIs that work with proxy-based mocks. Avoid relying on default inline/static/construction/final-class mocking for native-image coverage; Mockito 5.0.0 defaults to the inline Byte Buddy mock maker, which uses Java-agent/instrumentation machinery unsuitable as the baseline for GraalVM native-image tests.",
[assistant]   "risks": [
[assistant]     "ProxyMockMaker can only mock interfaces, so tests that try to increase coverage through class, final, static, or construction mocking may fail or be non-portable in native image.",
[assistant]     "The existing test setup already uses ProxyMockMaker; generation should preserve or recreate that resource rather than adding extra dependencies.",
[assistant]     "Local Gradle and Native Image verification remain authoritative because some Byte Buddy/agent paths may still be discovered if tests accidentally use Mockito features that require inline or subclass mock makers."
[assistant]   ]
[assistant] }
[assistant-event] text_end
