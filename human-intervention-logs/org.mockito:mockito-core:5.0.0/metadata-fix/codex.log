{"type":"item.completed","item":{"id":"item_178","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/PluginLoaderTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.plugins.MockResolver;\nimport org.mockito.plugins.MockitoLogger;\nimport org.mockito.plugins.PluginSwitch;\n\nimport java.io.IOException;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.net.URL;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class PluginLoaderTest {\n    private static final String PLUGIN_LOADER_TYPE =\n            \"org.mockito.internal.configuration.plugins.PluginLoader\";\n\n    @Test\n    void loadPluginCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Throwable {\n        Object pluginLoader = newPluginLoader();\n\n        MockitoLogger logger =\n                withFailingMockitoExtensionLookup(\n                        () -> (MockitoLogger) loadPlugin(pluginLoader, MockitoLogger.class));\n\n        assertThatThrownBy(() -> logger.log(\"message\"))\n                .isInstanceOf(IllegalStateException.class)\n                .hasMessageContaining(\"Could not initialize plugin\")\n                .hasMessageContaining(\"org.mockito.plugins.MockitoLogger\");\n    }\n\n    @Test\n    void loadPluginsCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Throwable {\n        Object pluginLoader = newPluginLoader();\n\n        List<MockResolver> resolvers =\n                withFailingMockitoExtensionLookup(\n                        () -> loadPlugins(pluginLoader, MockResolver.class));\n\n        assertThat(resolvers).hasSize(1);\n        assertThatThrownBy(() -> resolvers.get(0).resolve(new Object()))\n                .isInstanceOf(IllegalStateException.class)\n                .hasMessageContaining(\"Could not initialize plugin\")\n                .hasMessageContaining(\"org.mockito.plugins.MockResolver\");\n    }\n\n    private static Object newPluginLoader() throws Throwable {\n        Class<?> pluginLoaderType = Class.forName(PLUGIN_LOADER_TYPE);\n        MethodHandles.Lookup lookup =\n                MethodHandles.privateLookupIn(pluginLoaderType, MethodHandles.lookup());\n        MethodHandle constructor =\n                lookup.findConstructor(\n                        pluginLoaderType, MethodType.methodType(void.class, PluginSwitch.class));\n        return constructor.invoke(new EnabledPluginSwitch());\n    }\n\n    private static Object loadPlugin(Object pluginLoader, Class<?> pluginType) throws Throwable {\n        MethodHandle loadPlugin = pluginLoaderMethod(\"loadPlugin\", Object.class);\n        return loadPlugin.invoke(pluginLoader, pluginType);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> List<T> loadPlugins(Object pluginLoader, Class<T> pluginType)\n            throws Throwable {\n        MethodHandle loadPlugins = pluginLoaderMethod(\"loadPlugins\", List.class);\n        return (List<T>) loadPlugins.invoke(pluginLoader, pluginType);\n    }\n\n    private static MethodHandle pluginLoaderMethod(String name, Class<?> returnType)\n            throws ReflectiveOperationException {\n        Class<?> pluginLoaderType = Class.forName(PLUGIN_LOADER_TYPE);\n        MethodHandles.Lookup lookup =\n                MethodHandles.privateLookupIn(pluginLoaderType, MethodHandles.lookup());\n        return lookup.findVirtual(\n                pluginLoaderType, name, MethodType.methodType(returnType, Class.class));\n    }\n\n    private static <T> T withFailingMockitoExtensionLookup(ThrowingSupplier<T> action)\n            throws Throwable {\n        Thread thread = Thread.currentThread();\n        ClassLoader originalLoader = thread.getContextClassLoader();\n        try {\n            thread.setContextClassLoader(\n                    new FailingMockitoExtensionResourceLoader(originalLoader));\n            return action.get();\n        } finally {\n            thread.setContextClassLoader(originalLoader);\n        }\n    }\n\n    private interface ThrowingSupplier<T> {\n        T get() throws Throwable;\n    }\n\n    private static final class EnabledPluginSwitch implements PluginSwitch {\n        @Override\n        public boolean isEnabled(String pluginClassName) {\n            return true;\n        }\n    }\n\n    private static final class FailingMockitoExtensionResourceLoader extends ClassLoader {\n        private FailingMockitoExtensionResourceLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (name.startsWith(\"mockito-extensions/\")) {\n                throw new IOException(\"Deliberate resource lookup failure for \" + name);\n            }\n            return super.getResources(name);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
