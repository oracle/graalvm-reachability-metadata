{"type":"item.completed","item":{"id":"item_181","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ByteBuddyCrossClassLoaderSerializationSupportInnerCrossClassLoaderSerializationProxyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockMakers;\nimport org.mockito.Mockito;\nimport org.mockito.exceptions.base.MockitoSerializationIssue;\nimport org.mockito.mock.SerializableMode;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteBuddyCrossClassLoaderSerializationSupportInnerCrossClassLoaderSerializationProxyTest {\n    private static final String PROXY_CLASS_NAME =\n            \"org.mockito.internal.creation.bytebuddy.ByteBuddyCrossClassLoaderSerializationSupport\"\n                    + \"$CrossClassLoaderSerializationProxy\";\n    private static final long PROXY_SERIAL_VERSION_UID = -7600267929109286514L;\n\n    @Test\n    void serializesSubclassMockThroughCrossClassLoaderProxy() throws Exception {\n        runAllowingUnsupportedFeature(\n                () -> {\n                    GreetingService mock =\n                            Mockito.mock(\n                                    GreetingService.class,\n                                    Mockito.withSettings()\n                                            .mockMaker(MockMakers.SUBCLASS)\n                                            .serializable(SerializableMode.ACROSS_CLASSLOADERS));\n                    Mockito.when(mock.greet(\"Ada\")).thenReturn(\"Hello Ada\");\n\n                    byte[] serialized = serialize(mock);\n\n                    try {\n                        GreetingService deserialized = (GreetingService) deserialize(serialized);\n                        assertThat(deserialized.greet(\"Ada\")).isEqualTo(\"Hello Ada\");\n                    } catch (MockitoSerializationIssue issue) {\n                        assertThat(issue)\n                                .hasMessageContaining(\n                                        \"Byte Buddy-generated mock cannot be deserialized \"\n                                                + \"into a non-Byte Buddy generated mock class\");\n                    }\n                });\n    }\n\n    @Test\n    void readResolveReturnsObjectFromProxyPayload() throws Exception {\n        // Handcraft the proxy stream so the nested payload can resolve without a\n        // Byte Buddy mock maker.\n        byte[] proxyStream = serializedProxyStream(serialize(\"resolved payload\"));\n\n        assertThat(deserialize(proxyStream)).isEqualTo(\"resolved payload\");\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serializedProxyStream(byte[] serializedMock) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (DataOutputStream outputStream = new DataOutputStream(bytes)) {\n            outputStream.writeShort(0xACED);\n            outputStream.writeShort(5);\n            outputStream.writeByte(0x73);\n            outputStream.writeByte(0x72);\n            outputStream.writeUTF(PROXY_CLASS_NAME);\n            outputStream.writeLong(PROXY_SERIAL_VERSION_UID);\n            outputStream.writeByte(0x02);\n            outputStream.writeShort(3);\n            writeObjectField(outputStream, \"extraInterfaces\", \"Ljava/util/Set;\");\n            writeObjectField(outputStream, \"serializedMock\", \"[B\");\n            writeObjectField(outputStream, \"typeToMock\", \"Ljava/lang/Class;\");\n            outputStream.writeByte(0x78);\n            outputStream.writeByte(0x70);\n            outputStream.writeByte(0x70);\n            writeSerializedContent(outputStream, serializedMock);\n            outputStream.writeByte(0x70);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static void writeObjectField(\n            DataOutputStream outputStream, String name, String descriptor) throws IOException {\n        outputStream.writeByte(descriptor.charAt(0));\n        outputStream.writeUTF(name);\n        outputStream.writeByte(0x74);\n        outputStream.writeUTF(descriptor);\n    }\n\n    private static void writeSerializedContent(DataOutputStream outputStream, Object value)\n            throws IOException {\n        byte[] serialized = serialize(value);\n        outputStream.write(serialized, 4, serialized.length - 4);\n    }\n\n    @SuppressWarnings(\"BanSerializableRead\")\n    private static Object deserialize(byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream =\n                new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return inputStream.readObject();\n        }\n    }\n\n    private static void runAllowingUnsupportedFeature(ThrowingRunnable action) throws Exception {\n        try {\n            action.run();\n        } catch (RuntimeException exception) {\n            if (!hasUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    public static class GreetingService implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
