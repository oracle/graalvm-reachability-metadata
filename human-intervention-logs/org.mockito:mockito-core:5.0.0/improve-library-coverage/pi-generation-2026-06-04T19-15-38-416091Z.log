tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InlineDelegateByteBuddyMockMakerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockMakers;\nimport org.mockito.MockedConstruction;\nimport org.mockito.Mockito;\n\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.withSettings;\n\npublic class InlineDelegateByteBuddyMockMakerTest {\n    static {\n        System.setProperty(\"net.bytebuddy.experimental\", \"true\");\n    }\n\n    @Test\n    void inlineMockMakerCreatesFinalClassMockUsingConstructors() throws Exception {\n        exerciseInlineMockito(\n                () -> {\n                    final FinalGreetingService service =\n                            Mockito.mock(\n                                    FinalGreetingService.class,\n                                    withSettings().mockMaker(MockMakers.INLINE));\n\n                    Mockito.when(service.greeting(\"Mockito\")).thenReturn(\"Hello Mockito\");\n\n                    assertThat(Mockito.mockingDetails(service).isMock()).isTrue();\n                    assertThat(service.getClass()).isEqualTo(FinalGreetingService.class);\n                    assertThat(service.greeting(\"Mockito\")).isEqualTo(\"Hello Mockito\");\n                });\n    }\n\n    @Test\n    void inlineMockMakerMocksConstructionThroughPublicApi() throws Exception {\n        exerciseInlineMockito(\n                () -> {\n                    final AtomicReference<MockedConstruction.Context> constructionContext =\n                            new AtomicReference<>();\n                    try (MockedConstruction<ConstructedGreetingService> mockedConstruction =\n                            Mockito.mockConstruction(\n                                    ConstructedGreetingService.class,\n                                    withSettings().mockMaker(MockMakers.INLINE),\n                                    (mock, context) -> {\n                                        constructionContext.set(context);\n                                        Mockito.when(mock.greeting()).thenReturn(\"constructed mock\");\n                                    })) {\n                        final ConstructedGreetingService service =\n                                new ConstructedGreetingService(\"real\", 7);\n\n                        assertThat(service.greeting()).isEqualTo(\"constructed mock\");\n                        assertThat(mockedConstruction.constructed()).containsExactly(service);\n                    }\n\n                    final MockedConstruction.Context context = constructionContext.get();\n                    assertThat(context).isNotNull();\n                    assertThat(context.arguments()).containsExactly(\"real\", 7);\n                    assertThat(context.constructor().getParameterTypes())\n                            .containsExactly(String.class, int.class);\n                });\n    }\n\n    private static void exerciseInlineMockito(ThrowingRunnable exercise) throws Exception {\n        try {\n            exercise.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (Exception exception) {\n            final Error unsupportedFeatureError = findUnsupportedFeatureError(exception);\n            if (unsupportedFeatureError == null) {\n                throw exception;\n            }\n        }\n    }\n\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) current)) {\n                return (Error) current;\n            }\n            current = current.getCause();\n        }\n        return null;\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run() throws Exception;\n    }\n\n    public static final class FinalGreetingService {\n        private final String prefix;\n\n        public FinalGreetingService(\n                String prefix, int retryCount, boolean enabled, Object dependency) {\n            this.prefix = prefix + retryCount + enabled + dependency;\n        }\n\n        public final String greeting(String name) {\n            return prefix + name;\n        }\n    }\n\n    public static class ConstructedGreetingService {\n        private final String prefix;\n        private final int retryCount;\n\n        public ConstructedGreetingService(String prefix, int retryCount) {\n            this.prefix = prefix;\n            this.retryCount = retryCount;\n        }\n\n        public String greeting() {\n            return prefix + retryCount;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InlineDelegateByteBuddyMockMakerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_mockito.mockito_core;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.mockito.MockMakers;\\nimport org.mockito.MockedConstruction;\\nimport org.mockito.Mockito;\\n\\nimport java.util.concurrent.atomic.AtomicReference;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.mockito.Mockito.withSettings;\\n\\npublic class InlineDelegateByteBuddyMockMakerTest {\\n    static {\\n        System.setProperty(\\\"net.bytebuddy.experimental\\\", \\\"true\\\");\\n    }\\n\\n    @Test\\n    void inlineMockMakerCreatesFinalClassMockUsingConstructors() throws Exception {\\n        exerciseInlineMockito(\\n                () -> {\\n                    final FinalGreetingService service =\\n                            Mockito.mock(\\n                                    FinalGreetingService.class,\\n                                    withSettings().mockMaker(MockMakers.INLINE));\\n\\n                    Mockito.when(service.greeting(\\\"Mockito\\\")).thenReturn(\\\"Hello Mockito\\\");\\n\\n                    assertThat(Mockito.mockingDetails(service).isMock()).isTrue();\\n                    assertThat(service.getClass()).isEqualTo(FinalGreetingService.class);\\n                    assertThat(service.greeting(\\\"Mockito\\\")).isEqualTo(\\\"Hello Mockito\\\");\\n                });\\n    }\\n\\n    @Test\\n    void inlineMockMakerMocksConstructionThroughPublicApi() throws Exception {\\n        exerciseInlineMockito(\\n                () -> {\\n                    final AtomicReference<MockedConstruction.Context> constructionContext =\\n                            new AtomicReference<>();\\n                    try (MockedConstruction<ConstructedGreetingService> mockedConstruction =\\n                            Mockito.mockConstruction(\\n                                    ConstructedGreetingService.class,\\n                                    withSettings().mockMaker(MockMakers.INLINE),\\n                                    (mock, context) -> {\\n                                        constructionContext.set(context);\\n                                        Mockito.when(mock.greeting()).thenReturn(\\\"constructed mock\\\");\\n                                    })) {\\n                        final ConstructedGreetingService service =\\n                                new ConstructedGreetingService(\\\"real\\\", 7);\\n\\n                        assertThat(service.greeting()).isEqualTo(\\\"constructed mock\\\");\\n                        assertThat(mockedConstruction.constructed()).containsExactly(service);\\n                    }\\n\\n                    final MockedConstruction.Context context = constructionContext.get();\\n                    assertThat(context).isNotNull();\\n                    assertThat(context.arguments()).containsExactly(\\\"real\\\", 7);\\n                    assertThat(context.constructor().getParameterTypes())\\n                            .containsExactly(String.class, int.class);\\n                });\\n    }\\n\\n    private static void exerciseInlineMockito(ThrowingRunnable exercise) throws Exception {\\n        try {\\n            exercise.run();\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        } catch (Exception exception) {\\n            final Error unsupportedFeatureError = findUnsupportedFeatureError(exception);\\n            if (unsupportedFeatureError == null) {\\n                throw exception;\\n            }\\n        }\\n    }\\n\\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\\n        Throwable current = throwable;\\n        while (current != null) {\\n            if (current instanceof Error\\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) current)) {\\n                return (Error) current;\\n            }\\n            current = current.getCause();\\n        }\\n        return null;\\n    }\\n\\n    @FunctionalInterface\\n    private interface ThrowingRunnable {\\n        void run() throws Exception;\\n    }\\n\\n    public static final class FinalGreetingService {\\n        private final String prefix;\\n\\n        public FinalGreetingService(\\n                String prefix, int retryCount, boolean enabled, Ob