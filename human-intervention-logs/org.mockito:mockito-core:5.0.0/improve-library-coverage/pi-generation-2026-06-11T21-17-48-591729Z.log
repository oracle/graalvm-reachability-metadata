              assureOpen(module, packageName);
              MethodHandle handle =
                      ((MethodHandles.Lookup)
                                      DISPATCHER.invokeWithArguments(
                                              privateLookupIn,
                                              method.getDeclaringClass(),
                                              DISPATCHER.getLookup()))
                              .unreflect(method);
