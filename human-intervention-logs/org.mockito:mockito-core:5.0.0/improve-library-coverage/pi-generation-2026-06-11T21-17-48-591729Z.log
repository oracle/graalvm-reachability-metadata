[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java","edits":[{"oldText":"import org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InstrumentationMemberAccessorTest {\n","newText":"import org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.plugins.MemberAccessor;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InstrumentationMemberAccessorTest {\n"},{"oldText":"    @Test\n    void annotationsInstantiateClassAndInjectInterfaceMocksThroughSetters() throws Exception {\n        try (AutoCloseable mocks = MockitoAnnotations.openMocks(this)) {\n            Mockito.when(greetingGateway.greetingFor(\"Mockito\")).thenReturn(\"Hello Mockito\");\n\n            String greeting = controller.greet(\"Mockito\");\n\n            assertThat(greeting).isEqualTo(\"constructed:Hello Mockito\");\n            assertThat(controller.greetingGateway()).isSameAs(greetingGateway);\n            assertThat(controller.auditGateway()).isSameAs(auditGateway);\n            Mockito.verify(auditGateway).record(\"Mockito\");\n        }\n    }\n}\n","newText":"    @Test\n    void annotationsInstantiateClassAndInjectInterfaceMocksThroughSetters() throws Exception {\n        try (AutoCloseable mocks = MockitoAnnotations.openMocks(this)) {\n            Mockito.when(greetingGateway.greetingFor(\"Mockito\")).thenReturn(\"Hello Mockito\");\n\n            String greeting = controller.greet(\"Mockito\");\n\n            assertThat(greeting).isEqualTo(\"constructed:Hello Mockito\");\n            assertThat(controller.greetingGateway()).isSameAs(greetingGateway);\n            assertThat(controller.auditGateway()).isSameAs(auditGateway);\n            Mockito.verify(auditGateway).record(\"Mockito\");\n        }\n    }\n\n    @Test\n    void defaultMemberAccessorCreatesInstancesAndAccessesMembers() throws Exception {\n        MemberAccessor accessor =\n                Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        Constructor<MemberAccessorSample> constructor =\n                MemberAccessorSample.class.getDeclaredConstructor(String.class);\n        Field message = MemberAccessorSample.class.getDeclaredField(\"message\");\n        Method format = MemberAccessorSample.class.getDeclaredMethod(\"format\", String.class);\n\n        MemberAccessorSample sample = (MemberAccessorSample) accessor.newInstance(constructor, \"initial\");\n        assertThat(accessor.get(message, sample)).isEqualTo(\"initial\");\n\n        accessor.set(message, sample, \"updated\");\n\n        assertThat(accessor.invoke(format, sample, \"value\")).isEqualTo(\"value=updated\");\n        assertThat(accessor.get(message, sample)).isEqualTo(\"updated\");\n    }\n}\n"}]}
