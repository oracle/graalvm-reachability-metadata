          WRAPPERS.put(byte.class, Byte.class);
          WRAPPERS.put(short.class, Short.class);
          WRAPPERS.put(char.class, Character.class);
          WRAPPERS.put(int.class, Integer.class);
          WRAPPERS.put(long.class, Long.class);
