[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java","edits":[{"oldText":"import java.lang.reflect.Method;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.plugins.MemberAccessor;\n","newText":"import java.lang.reflect.Method;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.internal.MockedConstructionImpl;\nimport org.mockito.plugins.MemberAccessor;\nimport org.mockito.plugins.MockMaker;\n"},{"oldText":"    void defaultMemberAccessorCreatesInstancesAndAccessesMembers() throws Exception {\n        MemberAccessor accessor =\n                Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        Constructor<MemberAccessorSample> constructor =\n                MemberAccessorSample.class.getDeclaredConstructor(String.class);\n        Field message = MemberAccessorSample.class.getDeclaredField(\"message\");\n        Method format = MemberAccessorSample.class.getDeclaredMethod(\"format\", String.class);\n\n        MemberAccessorSample sample =\n                (MemberAccessorSample) accessor.newInstance(constructor, \"initial\");\n        assertThat(accessor.get(message, sample)).isEqualTo(\"initial\");\n\n        accessor.set(message, sample, \"updated\");\n\n        assertThat(accessor.invoke(format, sample, \"value\")).isEqualTo(\"value=updated\");\n        assertThat(accessor.get(message, sample)).isEqualTo(\"updated\");\n    }\n","newText":"    void defaultMemberAccessorCreatesInstancesAndAccessesMembers() throws Exception {\n        MemberAccessor accessor =\n                Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        MockMaker.ConstructionMockControl<Object> control = Mockito.mock(MockMaker.ConstructionMockControl.class);\n        Constructor<MockedConstructionImpl> constructor =\n                MockedConstructionImpl.class.getDeclaredConstructor(MockMaker.ConstructionMockControl.class);\n        Field closed = MockedConstructionImpl.class.getDeclaredField(\"closed\");\n        Method isClosed = MockedConstructionImpl.class.getDeclaredMethod(\"isClosed\");\n\n        MockedConstructionImpl construction =\n                (MockedConstructionImpl) accessor.newInstance(constructor, control);\n        assertThat(accessor.get(closed, construction)).isEqualTo(false);\n\n        accessor.set(closed, construction, true);\n\n        assertThat(accessor.invoke(isClosed, construction)).isEqualTo(true);\n        assertThat(accessor.get(closed, construction)).isEqualTo(true);\n    }\n"},{"oldText":"}\n\nclass MemberAccessorSample {\n    private String message;\n\n    private MemberAccessorSample(String message) {\n        this.message = message;\n    }\n\n    private String format(String prefix) {\n        return prefix + \"=\" + message;\n    }\n}\n","newText":"}\n"}]}
[tool-call] end id=call_SLqLwHGDVXw8B0c4FkrmY0xo|fc_060af8cf4e902a4c016a2b287ee3108193bd160fcce3452706 name=edit args={"path": "tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java", "edits": [{"oldText": "import java.lang.reflect.Method;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.plugins.MemberAccessor;\n", "newText": "import java.lang.reflect.Method;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.internal.MockedConstructionImpl;\nimport org.mockito.plugins.MemberAccessor;\nimport org.mockito.plugins.MockMaker;\n"}, {"oldText": "    void defaultMemberAccessorCreatesInstancesAndAccessesMembers() throws Exception {\n        MemberAccessor accessor =\n                Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        Constructor<MemberAccessorSample> constructor =\n                MemberAccessorSample.class.getDeclaredConstructor(String.class);\n        Field message = MemberAccessorSample.class.getDeclaredField(\"message\");\n        Method format = MemberAccessorSample.class.getDeclaredMethod(\"format\", String.class);\n\n        MemberAccessorSample sample =\n                (MemberAccessorSample) accessor.newInstance(constructor, \"initial\");\n        assertThat(accessor.get(message, sample)).isEqualTo(\"initial\");\n\n        accessor.set(message, sample, \"updated\");\n\n        assertThat(accessor.invoke(format, sample, \"value\")).isEqualTo(\"value=updated\");\n        assertThat(accessor.get(message, sample)).isEqualTo(\"updated\");\n    }\n", "newText": "    void defaultMemberAccessorCreatesInstancesAndAccessesMembers() throws Exception {\n        MemberAccessor accessor =\n                Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        MockMaker.ConstructionMockControl<Object> control = Mockito.mock(MockMaker.ConstructionMockControl.class);\n        Constructor<MockedConstructionImpl> constructor =\n                MockedConstructionImpl.class.getDeclaredConstructor(MockMaker.ConstructionMockControl.class);\n        Field closed = MockedConstructionImpl.class.getDeclaredField(\"closed\");\n        Method isClosed = MockedConstructionImpl.class.getDeclaredMethod(\"isClosed\");\n\n        MockedConstructionImpl construction =\n                (MockedConstructionImpl) accessor.newInstance(constructor, control);\n        assertThat(accessor.get(closed, construction)).isEqualTo(false);\n\n        accessor.set(closed, construction, true);\n\n        assertThat(accessor.invoke(isClosed, construction)).isEqualTo(true);\n        assertThat(accessor.get(closed, construction)).isEqualTo(true);\n    }\n"}, {"oldText": "}\n\nclass MemberAccessorSample {\n    private String message;\n\n    private MemberAccessorSample(String message) {\n        this.message = message;\n    }\n\n    private String format(String prefix) {\n        return prefix + \"=\" + message;\n    }\n}\n", "newText": "}\n"}]}
