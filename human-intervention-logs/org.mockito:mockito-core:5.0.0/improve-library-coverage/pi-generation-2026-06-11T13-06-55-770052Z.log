  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.AdditionalAnswers;
  import org.mockito.ArgumentCaptor;
  import org.mockito.InjectMocks;
  import org.mockito.Mock;
  import org.mockito.MockitoAnnotations;
  import org.mockito.Spy;
  
  public class InstrumentationMemberAccessorTest {
      @Test
      void initializesSpyWithPrivateConstructor() throws Exception {
          SpyFixture fixture = new SpyFixture();
  
          try (AutoCloseable mocks = MockitoAnnotations.openMocks(fixture)) {
              assertThat(fixture.counter.increment()).isEqualTo(8);
              verify(fixture.counter).increment();
          }
      }
  
      @Test
      void delegatesCallsThroughMemberAccessor() {
          GreetingContract greeting =
                  mock(
                          GreetingContract.class,
                          AdditionalAnswers.delegatesTo(new GreetingDelegate()));
  
          assertThat(greeting.greet("Ada")).isEqualTo("Hello Ada");
          verify(greeting).greet("Ada");
      }
  
      @Test
      void initializesInjectMocksFieldAndInjectsConcreteClassMocks() throws Exception {
          InjectionFixture fixture = new InjectionFixture();
  
          try (AutoCloseable mocks = MockitoAnnotations.openMocks(fixture)) {
              when(fixture.repository.findName("42")).thenReturn("Ada");
              when(fixture.auditTrail.record("Ada"))
                      .thenAnswer(invocation -> "recorded " + invocation.getArgument(0));
  
              assertThat(fixture.service.greet("42")).isEqualTo("Hello Ada");
              assertThat(fixture.service.audit("Ada")).isEqualTo("recorded Ada");
  
              verify(fixture.repository).findName("42");
              ArgumentCaptor<String> capturedName = ArgumentCaptor.forClass(String.class);
              verify(fixture.auditTrail).record(capturedName.capture());
              assertThat(capturedName.getValue()).isEqualTo("Ada");
          }
      }
  
      public static class SpyFixture {
          @Spy
          PrivateConstructorCounter counter;
      }
  
      public static class PrivateConstructorCounter {
          private int value;
  
          private PrivateConstructorCounter() {
              value = 7;
          }
  
          public int increment() {
              return ++value;
          }
      }
  
      public interface GreetingContract {
          String greet(String name);
      }
  
      public static class GreetingDelegate {
          public String greet(String name) {
              return "Hello " + name;
          }
      }
  
      public static class InjectionFixture {
          @Mock
          Repository repository;
  
          @Mock
          AuditTrail auditTrail;
  
          @InjectMocks
          GreetingService service;
      }
  
      public static class GreetingService {
          private Repository repository;
          private AuditTrail auditTrail;
  
          public GreetingService() {}
  
          public void setRepository(Repository repository) {
              this.repository = repository;
          }
  
          public String greet(String id) {
              return "Hello " + repository.findName(id);
          }
  
          public String audit(String name) {
              return auditTrail.record(name);
          }
      }
  
      public static class Repository {
          public String findName(String id) {
              return "real " + id;
          }
      }
  
      public static class AuditTrail {
          public String record(String name) {
              return "real " + name;
          }
      }
  }
