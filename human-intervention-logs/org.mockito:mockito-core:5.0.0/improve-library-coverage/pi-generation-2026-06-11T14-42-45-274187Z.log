[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org/mockito/internal/configuration/plugins/PluginLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.mockito.internal.configuration.plugins;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.lang.reflect.Proxy;\nimport java.util.Collections;\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\n\npublic class PluginLoaderTest {\n    @Test\n    void createsFailingProxyWhenSinglePluginInitializationFails() {\n        RuntimeException initializationFailure = new RuntimeException(\"single plugin failed\");\n        PluginLoader loader = new PluginLoader(new DefaultMockitoPlugins(), failingInitializer(initializationFailure));\n\n        SinglePlugin plugin = loader.loadPlugin(SinglePlugin.class);\n\n        assertThat(Proxy.isProxyClass(plugin.getClass())).isTrue();\n        assertThatThrownBy(plugin::name)\n                .isInstanceOf(IllegalStateException.class)\n                .hasMessageContaining(\"Could not initialize plugin\")\n                .hasCauseSameInstanceAs(initializationFailure);\n    }\n\n    @Test\n    void createsFailingProxyWhenMultiplePluginInitializationFails() {\n        RuntimeException initializationFailure = new RuntimeException(\"multiple plugins failed\");\n        PluginLoader loader = new PluginLoader(new DefaultMockitoPlugins(), failingInitializer(initializationFailure));\n\n        List<MultiplePlugin> plugins = loader.loadPlugins(MultiplePlugin.class);\n\n        assertThat(plugins).hasSize(1);\n        MultiplePlugin plugin = plugins.get(0);\n        assertThat(Proxy.isProxyClass(plugin.getClass())).isTrue();\n        assertThatThrownBy(plugin::name)\n                .isInstanceOf(IllegalStateException.class)\n                .hasMessageContaining(\"Could not initialize plugin\")\n                .hasCauseSameInstanceAs(initializationFailure);\n    }\n\n    private static PluginInitializer failingInitializer(RuntimeException initializationFailure) {\n        return new PluginInitializer(pluginClassName -> true, Collections.emptySet()) {\n            @Override\n            public <T> T loadImpl(Class<T> service) {\n                throw initializationFailure;\n            }\n\n            @Override\n            public <T> List<T> loadImpls(Class<T> service) {\n                throw initializationFailure;\n            }\n        };\n    }\n\n    public interface SinglePlugin {\n        String name();\n    }\n\n    public interface MultiplePlugin {\n        String name();\n    }\n}\n"}
[tool-call] end id=call_JsUIq77HnuniJYu6Nxx0Oo0I|fc_0dda82a1f13cf035016a2ac944e0b88195a22ea3d7af01119f name=write args={"path": "tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org/mockito/internal/configuration/plugins/PluginLoaderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.mockito.internal.configuration.plugins;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.lang.reflect.Proxy;\nimport java.util.Collections;\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\n\npublic class PluginLoaderTest {\n    @Test\n    void createsFailingProxyWhenSinglePluginInitializationFails() {\n        RuntimeException initializationFailure = new RuntimeException(\"single plugin failed\");\n        PluginLoader loader = new PluginLoader(new DefaultMockitoPlugins(), failingInitializer(initializationFailure));\n\n        SinglePlugin plugin = loader.loadPlugin(SinglePlugin.class);\n\n        assertThat(Proxy.isProxyClass(plugin.getClass())).isTrue();\n        assertThatThrownBy(plugin::name)\n                .isInstanceOf(IllegalStateException.class)\n                .hasMessageContaining(\"Could not initialize plugin\")\n                .hasCauseSameInstanceAs(initializationFailure);\n    }\n\n    @Test\n    void createsFailingProxyWhenMultiplePluginInitializationFails() {\n        RuntimeException initializationFailure = new RuntimeException(\"multiple plugins failed\");\n        PluginLoader loader = new PluginLoader(new DefaultMockitoPlugins(), failingInitializer(initializationFailure));\n\n        List<MultiplePlugin> plugins = loader.loadPlugins(MultiplePlugin.class);\n\n        assertThat(plugins).hasSize(1);\n        MultiplePlugin plugin = plugins.get(0);\n        assertThat(Proxy.isProxyClass(plugin.getClass())).isTrue();\n        assertThatThrownBy(plugin::name)\n                .isInstanceOf(IllegalStateException.class)\n                .hasMessageContaining(\"Could not initialize plugin\")\n                .hasCauseSameInstanceAs(initializationFailure);\n    }\n\n    private static PluginInitializer failingInitializer(RuntimeException initializationFailure) {\n        return new PluginInitializer(pluginClassName -> true, Collections.emptySet()) {\n            @Override\n            public <T> T loadImpl(Class<T> service) {\n                throw initializationFailure;\n            }\n\n            @Override\n            public <T> List<T> loadImpls(Class<T> service) {\n                throw initializationFailure;\n            }\n        };\n    }\n\n    public interface SinglePlugin {\n        String name();\n    }\n\n    public interface MultiplePlugin {\n        String name();\n    }\n}\n"}
