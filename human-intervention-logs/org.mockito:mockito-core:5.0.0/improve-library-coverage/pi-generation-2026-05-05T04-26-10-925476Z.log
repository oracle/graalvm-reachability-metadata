atureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static FileSystemProvider findJarFileSystemProvider() {","newText":"    @Test\n    void subclassMockMakerLooksUpInjectionBaseWithChildContextLoader() throws Exception {\n        Thread thread = Thread.currentThread();\n        ClassLoader originalLoader = thread.getContextClassLoader();\n        try {\n            ClassLoader childLoader = new ChildContextLoader(originalLoader);\n            thread.setContextClassLoader(childLoader);\n            Class<?> directBufferType =\n                    ClassLoader.getSystemClassLoader().loadClass(DIRECT_BUFFER_TYPE);\n\n            Object mock =\n                    Mockito.mock(\n                            directBufferType,\n                            withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureError(exception)) {\n                return;\n            }\n            assertThat(rootCause(exception))\n                    .hasMessageContaining(\n                            \"Cannot adjust module graph for modules in the bootstrap loader\");\n        } catch (RuntimeException exception) {\n            if (!hasUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!hasUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            thread.setContextClassLoader(originalLoader);\n        }\n    }\n\n    private static FileSystemProvider findJarFileSystemProvider() {"},{"oldText":"    @SuppressWarnings(\"unchecked\")\n    private static Class<FileSystemProvider> fileSystemProviderType(FileSystemProvider provider) {\n        return (Class<FileSystemProvider>) provider.getClass();\n    }\n\n}","newText":"    @SuppressWarnings(\"unchecked\")\n    private static Class<FileSystemProvider> fileSystemProviderType(FileSystemProvider provider) {\n        return (Class<FileSystemProvider>) provider.getClass();\n    }\n\n    private static class ChildContextLoader extends ClassLoader {\n        ChildContextLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n}"}]}
