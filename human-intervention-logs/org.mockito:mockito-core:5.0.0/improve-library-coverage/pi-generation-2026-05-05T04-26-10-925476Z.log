s().mockMaker(MockMakers.SUBCLASS));\n            Mockito.when(mock.getScheme()).thenReturn(\"mock-jar\");\n\n            assertThat(mock.getScheme()).isEqualTo(\"mock-jar\");\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureError(exception)) {\n                return;\n            }\n            Throwable rootCause = rootCause(exception);\n            assertThat(rootCause)\n                    .isInstanceOf(IllegalAccessError.class)\n                    .hasMessageContaining(\"does not read\");\n        } catch (RuntimeException exception) {\n            if (!hasUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n        } catch (Error error) {\n            if (!hasUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void subclassMockMakerLooksUpInjectionBaseForCrossClassLoaderSerializableMock() {\n        try {\n            FileSystemProvider provider = findJarFileSystemProvider();\n            Class<FileSystemProvider> providerType = fileSystemProviderType(provider);\n\n            FileSystemProvider mock =\n                    Mockito.mock(\n                            providerType,\n                            withSettings()\n                                    .mockMaker(MockMakers.SUBCLASS)\n                                    .serializable(SerializableMode.ACROSS_CLASSLOADERS));\n\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureError(exception)) {\n                return;\n            }\n            assertThat(rootCause(exception))\n                    .hasMessageContainingAnyOf(\n                            \"does not read\",\n                            \"Cannot adjust module graph\",\n                            \"Cannot inject already loaded