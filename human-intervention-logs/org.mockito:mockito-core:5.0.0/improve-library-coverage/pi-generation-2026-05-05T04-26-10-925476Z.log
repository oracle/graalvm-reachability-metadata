  package org_mockito.mockito_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.MockMakers;
  import org.mockito.Mockito;
  import org.mockito.exceptions.base.MockitoException;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.nio.file.spi.FileSystemProvider;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.withSettings;
  
  public class ModuleHandlerInnerModuleSystemFoundTest {
      private static final String DIRECT_BUFFER_TYPE = "sun.nio.ch.DirectBuffer";
  
      @Test
      void subclassMockMakerAdjustsModuleGraphForNonExportedJdkZipfsProvider() {
          try {
              FileSystemProvider provider = findJarFileSystemProvider();
              Class<FileSystemProvider> providerType = fileSystemProviderType(provider);
  
              FileSystemProvider mock =
                      Mockito.mock(providerType, withSettings().mockMaker(MockMakers.SUBCLASS));
              Mockito.when(mock.getScheme()).thenReturn("mock-jar");
  
              assertThat(mock.getScheme()).isEqualTo("mock-jar");
              assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();
          } catch (MockitoException exception) {
              if (hasUnsupportedFeatureError(exception)) {
                  return;
              }
              Throwable rootCause = rootCause(exception);
              assertThat(rootCause)
                      .isInstanceOf(IllegalAccessError.class)
                      .hasMessageContaining("does not read");
          } catch (RuntimeException exception) {
              if (!hasUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!hasUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void subclassMockMakerLooksUpInjectionBaseInGeneratedClassLoader() throws Exception {
          try {
              IsolatedTargetLoader loader = new IsolatedTargetLoader();
              Class<?> targetType = loader.loadClass(CrossLoaderTarget.class.getName());
              Class<?> directBufferType = ClassLoader.getSystemClassLoader().loadClass(DIRECT_BUFFER_TYPE);
  
              Object mock =
                      Mockito.mock(
                              targetType,
                              withSettings()
                                      .mockMaker(MockMakers.SUBCLASS)
                                      .extraInterfaces(directBufferType));
  
              assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();
              assertThat(directBufferType.isInstance(mock)).isTrue();
          } catch (MockitoException exception) {
              Throwable rootCause = rootCause(exception);
              if (rootCause instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return;
              }
              assertThat(exception)
                      .hasMessageContaining("Cannot adjust module graph for modules in the bootstrap loader");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static FileSystemProvider findJarFileSystemProvider() {
          return FileSystemProvider.installedProviders().stream()
                  .filter(provider -> "jar".equalsIgnoreCase(provider.getScheme()))
                  .findFirst()
                  .orElseThrow(
                          () ->
                                  new IllegalStateException(
                                          "JDK zip file-system provider is unavailable"));
      }
  
      private static Throwable rootCause(Throwable throwable) {
          Throwable current = throwable;
          while (current.getCause() != null) {
              current = current.getCause();
          }
          return current;
      }
  
      private static boolean hasUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      @SuppressWarnings("unchecked")
      private static Class<FileSystemProvider> fileSystemProviderType(FileSystemProvider provider) {
          return (Class<FileSystemProvider>) provider.getClass();
      }
  
      public static class CrossLoaderTarget {
          public String describe() {
              return "target";
          }
      }
  
      private static class IsolatedTargetLoader extends ClassLoader {
          IsolatedTargetLoader() {
              super(null);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (!name.equals(CrossLoaderTarget.class.getName())) {
                  return super.loadClass(name, resolve);
              }
              Class<?> loaded = findLoadedClass(name);
              if (loaded == null) {
                  loaded = findClass(name);
              }
              if (resolve) {
                  resolveClass(loaded);
              }
              return loaded;
          }
  
          @Override
          protected Class<?> findClass(String name) throws ClassNotFoundException {
              String resourceName = name.replace('.', '/') + ".class";
              try (InputStream inputStream = ClassLoader.getSystemResourceAsStream(resourceName)) {
                  if (inputStream == null) {
                      throw new ClassNotFoundException(name);
                  }
                  byte[] bytes = inputStream.readAllBytes();
                  return defineClass(name, bytes, 0, bytes.length);
              } catch (IOException exception) {
                  throw new ClassNotFoundException(name, exception);
              }
          }
      }
  }
