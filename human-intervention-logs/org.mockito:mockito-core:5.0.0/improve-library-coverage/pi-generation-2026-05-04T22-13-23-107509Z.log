  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.ArgumentMatcher;
  import org.mockito.Mockito;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  import static org.mockito.ArgumentMatchers.argThat;
  import static org.mockito.Mockito.verify;
  
  public class MatcherToStringTest {
      @Test
      void describesCustomMatcherWithoutExplicitToString() {
          DynamicAccessService service = Mockito.mock(DynamicAccessService.class);
  
          service.accept("actual");
  
          assertThatThrownBy(() -> verify(service).accept(argThat(new NeedsSpecialValue())))
                  .hasMessageContaining("needs special value");
      }
  
      private static class NeedsSpecialValue implements ArgumentMatcher<String> {
          @Override
          public boolean matches(String argument) {
              return "special".equals(argument);
          }
      }
  }
