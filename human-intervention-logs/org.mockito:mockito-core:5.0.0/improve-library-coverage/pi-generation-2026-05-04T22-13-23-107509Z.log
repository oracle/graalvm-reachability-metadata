*/\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.internal.invocation.SerializableMethod;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SerializableMethodTest {\n    @Test\n    void resolvesJavaMethodAfterDeserialization() throws Exception {\n        Method method = DynamicAccessService.class.getDeclaredMethod(\"echo\", String.class);\n        SerializableMethod serializableMethod = new SerializableMethod(method);\n\n        SerializableMethod restored = roundTrip(serializableMethod);\n\n        assertThat(restored.getJavaMethod().getName()).isEqualTo(\"echo\");\n    }\n\n    private static SerializableMethod roundTrip(SerializableMethod method) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(method);\n        }\n        try (ObjectInputStream inputStream =\n                new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (SerializableMethod) inputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 922, "output": 437, "cacheRead": 83456, "cacheWrite": 0, "totalTokens": 84815, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777932600963, "responseId": "resp_0c55635ec3f778d50169f9193a3818819ea7ff38a73b279bcd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_g1qsz0ke2AtWhFVpaWpZ4muv|fc_0c55635ec3f778d50169f9193e2650819e8c5ccb3ba630e653", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1525 bytes to tests/src/org.mockito