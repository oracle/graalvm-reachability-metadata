s/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.Spy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.verify;\nimport static org.mockito.Mockito.when;\n\npublic class InstrumentationMemberAccessorTest {\n    @Mock\n    private Collaborator collaborator;\n\n    @InjectMocks\n    private ConstructorInjectedService constructorInjectedService;\n\n    @InjectMocks\n    private SetterInjectedService setterInjectedService;\n\n    @Spy\n    private PrivateConstructorService privateConstructorService;\n\n    @Test\n    void annotationInitializationUsesInstrumentationMemberAccessorForMembers() throws Exception {\n        try (AutoCloseable mocks = MockitoAnnotations.openMocks(this)) {\n            when(collaborator.message()).thenReturn(\"instrumented\");\n\n            assertThat(constructorInjectedService.message()).isEqualTo(\"instrumented\");\n            assertThat(setterInjectedService.message()).isEqualTo(\"instrumented\");\n            assertThat(setterInjectedService.setterWasUsed()).isTrue();\n            assertThat(privateConstructorService.createdByPrivateConstructor()).isTrue();\n\n            verify(collaborator).message();\n        }\n    }\n\n    interface Collaborator {\n        String message();\n    }\n\n    static class ConstructorInjectedService {\n        private final Collaborator collaborator;\n\n        ConstructorInjectedService(Collaborator collaborator) {\n            this.collaborator = collaborator;\n        }\n\n        String message() {\n            return collaborator.message();\n        }\n    }\n\n    static class SetterInjectedService {\n        private Collaborator collaborator;\n        private boolean setterWasUsed;\n\n        public void setCollaborator(Collaborator collaborator) {\n            this.collaborator = collaborator;\n            setterWasUsed = true;\n        }\n\n        String message() {\n            return collaborator.message();\n        }\n\n        boolean setterWasUsed() {\n            return setterWasUsed;\n        }\n    }\n\n    static class PrivateConstructorService {\n        private final boolean createdByPrivateConstructor;\n\n        private PrivateConstructorService() {\n            createdByPrivateConstructor = true;\n        }\n\n        boolean createdByPrivateConstructor() {\n            return createdByPrivateConstructor;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1189, "output": 1146, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 24351, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777953996598, "responseId": "resp_0b946e4e9a68fff90169f96ccd0f60819f81bd4f541bb1f25c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YjaJoqFMfqC0j42xOgPF7cFm|fc_0b946e4e9a68fff90169f96cd7e6f8819f8c850848df039f35", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2651 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java"}], "isError": false, "timestamp": 1777954010387}]}
