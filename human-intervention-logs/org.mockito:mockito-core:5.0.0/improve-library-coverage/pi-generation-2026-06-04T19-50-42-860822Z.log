 left nested classes and the importance of findClass. There might be an access issue here since a public nested interface in a public class could be loaded by a child loader, while the enclosing class is loaded by a parent. I'm questioning whether it's public; the JVM might confirm that it is. So, it seems the proxy would accept this if it's public. It's all a bit tangled, but I'm working through it!\"}]}"}, {"type": "toolCall", "id": "call_1pebQNnZtTizCth1LcRyXTvN|fc_0c92d7ab68f481aa016a21d6c2971c819099feafc55ee0faef", "name": "write", "arguments": {"path": "tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ProxyMockMakerInnerCommonClassLoaderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.file.Path;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockMakers;\nimport org.mockito.Mockito;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.withSettings;\n\npublic class ProxyMockMakerInnerCommonClassLoaderTest {\n    private static final String LEFT_INTERFACE =\n            ProxyMockMakerInnerCommonClassLoaderTest.class.getName() + \"$LeftInterface\";\n    private static final String RIGHT_INTERFACE =\n            ProxyMockMakerInnerCommonClassLoaderTest.class.getName() + \"$RightInterface\";\n\n    @Test\n    void proxyMockMakerCreatesMockForInterfacesFromUnrelatedClassLoaders() throws Exception {\n        try {\n            createProxyMockForInterfacesFromUnrelatedClassLoaders();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @SuppressWarnings({\"rawtypes\", \"unchecked\"})\n    private static void createProxyMockForInterfacesFromUnrelatedClassLoaders() throws Exception {\n        URL[] classPathUrls = currentClassPathUrls();\n\n        try (SelectiveInterfaceClassLoader leftLoader =\n                        new SelectiveInterfaceClassLoader(classPathUrls, LEFT_INTERFACE);\n                SelectiveInterfaceClassLoader rightLoader =\n                        new SelectiveInterfaceClassLoader(classPathUrls, RIGHT_INTERFACE)) {\n            Class<?> primaryInterface = Class.forName(LEFT_INTERFACE, true, leftLoader);\n            Class<?> extraInterface = Class.forName(RIGHT_INTERFACE, true, rightLoader);\n\n            Object mock = Mockito.mock(\n                    (Class) primaryInterface,\n                    withSettings().mockMaker(MockMakers.PROXY).extraInterfaces(extraInterface));\n\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n            assertThat(primaryInterface.isInstance(mock)).isTrue();\n            assertThat(extraInterface.isInstance(mock)).isTrue();\n            assertThat(Arrays.asList(mock.getClass().getInterfaces()))\n                    .contains(primaryInterface, extraInterface);\n        }\n    }\n\n    private static URL[] currentClassPathUrls() throws IOException {\n        String[] classPathEntries = System.getProperty(\"java.class.path\", \"\")\n                .split(File.pathSeparator);\n        List<URL> urls = new ArrayList<>();\n        for (String classPathEntry : classPathEntries) {\n            if (!classPathEntry.isBlank()) {\n                urls.add(Path.of(classPathEntry).toUri().toURL());\n            }\n        }\n        return urls.toArray(URL[]::new);\n    }\n\n    public interface LeftInterface {\n        String leftValue();\n    }\n\n    public interface RightInterface {\n        String rightValue();\n    }\n\n    private static final class SelectiveInterfaceClassLoader extends URLClassLoader {\n        private final String ownedInterfaceName;\n\n        private SelectiveInterfaceClassLoader(URL[] urls, String ownedInterfaceName) {\n            super(urls, ClassLoader.getSystemClassLoader());\n            this.ownedInterfaceName = ownedInterfaceName;\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null && ownedInterfaceName.equals(name)) {\n                    loadedClass = findClass(name);\n                } else if (loadedClass == null && isPeerInterface(name)) {\n                    throw new ClassNotFoundException(name);\n                } else if (loadedClass == null) {\n                    loadedClass = super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        private static boolean isPeerInterface(String name) {\n            return LEFT_INTERFACE.equals(name) || RIGHT_INTERFACE.equals(name);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ProxyMockMakerInnerCommonClassLoaderTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_mockito.mockito_core;\\n\\nimport java.io.File;\\nimport java.io.IOException;\\nimport java.net.URL;\\nimport java.net.URLClassLoader;\\nimport java.nio.file.Path;\\nimport java.util.ArrayList;\\nimport java.util.Arrays;\\nimport java.util.List;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\nimport org.mockito.MockMakers;\\nimport org.mockito.Mockito;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.mockito.Mockito.withSettings;\\n\\npublic class ProxyMockMakerInnerCommonClassLoaderTest {\\n    private static final String LEFT_INTERFACE =\\n            ProxyMockMakerInnerCommonClassLoaderTest.class.getName() + \\\"$LeftInterface\\\";\\n    private static final String RIGHT_INTERFACE =\\n            ProxyMockMakerInnerCommonClassLoaderTest.class.getName() + \\\"$RightInterface\\\";\\n\\n    @Test\\n    void proxyMockMakerCreatesMockForInterfacesFromUnrelatedClassLoaders() throws Exception {\\n        try {\\n            createProxyMockForInterfacesFromUnrelatedClassLoaders();\\n        } catch (Error error) {\\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n                throw error;\\n            }\\n        }\\n    }\\n\\n    @SuppressWarnings({\\\"rawtypes\\\", \\\"unchecked\\\"})\\n    private static void createProxyMockForInterfacesFromUnrelatedClassLoaders() throws Exception {\\n        URL[] classPathUrls = currentClassPathUrls();\\n\\n        try (SelectiveInterfaceClassLoader leftLoader =\\n                        new SelectiveInterfaceClassLoader(classPathUrls, LEFT_INTERFACE);\\n                SelectiveInterfaceClassLoader rightLoader =\\n                        new SelectiveInterfaceClassLoader(classPathUrls, RIGHT_INTERFACE)) {\\n            Class<?> primaryInterface = Class.forName(LEFT_INTERFACE, true, leftLoader);\\n            Class<?> extraInterface = Class.forName(RIGHT_INTERFACE, true, rightLoader);\\n\\n            Object mock = Mockito.mock(\\n                    (Class) primaryInterface,\\n                    withSettings().mockMaker(MockMakers.PROXY).extraInterfaces(extraInterface));\\n\\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\\n            assertThat(primaryInterface.isInstance(mock)).isTrue();\\n            assertThat(extraInterface.isInstance(mock)).isTrue();\\n            assertThat(Arrays.asList(mock.getClass().getInterfaces()))\\n                    .contains(primaryInterface, extraInterface);\\n        }\\n    }\\n\\n    private static URL[] currentClassPathUrls() throws IOException {\\n        String[] classPathEntries = System.getProperty(\\\"java.class.path\\\", \\\"\\\")\\n                .split(File.pathSeparator);\\n        List<URL> urls = new ArrayList<>();\\n        for (String classPathEntry : classPathEntries) {\\n            if (!classPathEntry.isBlank()) {\\n                urls.add(Path.of(classPathEntry).toUri().toURL());\\n            }\\n        }\\n        return urls.toArray(URL[]::new);\\n    }\\n\\n    public interface LeftInterface {\\n        String leftValue();\\n    }\\n\\n    public interface RightInterface {\\n        String rightValue();\\n    }\\n\\n    private static final class SelectiveInterfaceClassLoader extends URLClassLoader {\\n        private final String ownedInterfaceName;\\n\\n        private SelectiveInterfaceClassLoader(URL[] urls, String ownedInterfaceName) {\\n            super(urls, ClassLoader.getSystemClassLoader());\\n            this.ownedInterfaceName = ownedInterfaceName;\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            synchronized (getClassLoadingLock(name)) {\\n                Class<?> loadedClass = findLoadedClass(name);\\n                if (loadedClass == null && ownedInterfaceName.equals(name)) {\\n                    loadedClass = findClass(name);\\n                } else if (loadedClass == null && isPeerInterface(name)) {\\n                    throw new ClassNotFoundException(name);\\n                } else if (loadedClass == null) {\\n                    loadedClass = super.loadClass(name, false);\\n                }\\n                if (resolve) {\\n                    resolveClass(loadedClass);\\n                }\\n                return loadedClass;\\n            }\\n        }\\n\\n        private static boolean isPeerInterface(String name) {\\n            return LEFT_INTERFACE.equals(name) || RIGHT_INTERFACE.equals(name);\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1644, "output": 3013, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 26161, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780602515717, "responseId": "resp_0c92d7ab68f481aa016a21d69476848190bca89d52476e7b3f"}}
