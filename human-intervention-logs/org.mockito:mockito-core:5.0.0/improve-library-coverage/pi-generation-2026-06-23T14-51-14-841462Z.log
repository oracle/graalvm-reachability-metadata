[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/MethodHandleProxyInnerLegacyVersionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockMakers;\nimport org.mockito.Mockito;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.CALLS_REAL_METHODS;\nimport static org.mockito.Mockito.when;\nimport static org.mockito.Mockito.withSettings;\n\npublic class MethodHandleProxyInnerLegacyVersionTest {\n    @Test\n    void proxyMockMakerInvokesInterfaceDefaultMethods() {\n        DefaultGreetingService service =\n                Mockito.mock(\n                        DefaultGreetingService.class,\n                        withSettings()\n                                .mockMaker(MockMakers.PROXY)\n                                .defaultAnswer(CALLS_REAL_METHODS));\n\n        when(service.name()).thenReturn(\"Mockito\");\n\n        assertThat(service.greeting()).isEqualTo(\"Hello Mockito\");\n        assertThat(Mockito.mockingDetails(service).isMock()).isTrue();\n    }\n\n    private interface DefaultGreetingService {\n        String name();\n\n        default String greeting() {\n            return \"Hello \" + name();\n        }\n    }\n}\n"}
