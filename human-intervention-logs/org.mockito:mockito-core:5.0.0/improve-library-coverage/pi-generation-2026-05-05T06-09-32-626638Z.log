  package org_mockito.mockito_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.MockMakers;
  import org.mockito.Mockito;
  import org.mockito.exceptions.base.MockitoException;
  
  import java.nio.file.spi.FileSystemProvider;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.withSettings;
  
  public class ModuleHandlerInnerModuleSystemFoundTest {
      private static final String DIRECT_BUFFER_TYPE = "sun.nio.ch.DirectBuffer";
  
      @Test
      void subclassMockMakerAdjustsModuleGraphForNonExportedJdkZipfsProvider() {
          try {
              FileSystemProvider provider = findJarFileSystemProvider();
              Class<FileSystemProvider> providerType = fileSystemProviderType(provider);
  
              FileSystemProvider mock =
                      Mockito.mock(providerType, withSettings().mockMaker(MockMakers.SUBCLASS));
              Mockito.when(mock.getScheme()).thenReturn("mock-jar");
  
              assertThat(mock.getScheme()).isEqualTo("mock-jar");
              assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();
          } catch (MockitoException exception) {
              if (hasUnsupportedFeatureError(exception)) {
                  return;
              }
              Throwable rootCause = rootCause(exception);
              if (isModuleProbeClassLookupFailure(rootCause)) {
                  return;
              }
              assertThat(rootCause)
                      .isInstanceOf(IllegalAccessError.class)
                      .hasMessageContaining("does not read");
          } catch (RuntimeException exception) {
              if (!hasUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!hasUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void subclassMockMakerLooksUpInjectionBaseWithChildContextLoader() throws Exception {
          Thread thread = Thread.currentThread();
          ClassLoader originalLoader = thread.getContextClassLoader();
          try {
              ClassLoader childLoader = new ChildContextLoader(originalLoader);
              thread.setContextClassLoader(childLoader);
              Class<?> directBufferType =
                      ClassLoader.getSystemClassLoader().loadClass(DIRECT_BUFFER_TYPE);
  
              Object mock =
                      Mockito.mock(
                              directBufferType,
                              withSettings().mockMaker(MockMakers.SUBCLASS));
  
              assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();
          } catch (MockitoException exception) {
              if (hasUnsupportedFeatureError(exception)) {
                  return;
              }
              assertThat(rootCause(exception))
                      .hasMessageContaining(
                              "Cannot adjust module graph for modules in the bootstrap loader");
          } catch (RuntimeException exception) {
              if (!hasUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!hasUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              thread.setContextClassLoader(originalLoader);
          }
      }
  
      private static FileSystemProvider findJarFileSystemProvider() {
          return FileSystemProvider.installedProviders().stream()
                  .filter(provider -> "jar".equalsIgnoreCase(provider.getScheme()))
                  .findFirst()
                  .orElseThrow(
                          () ->
                                  new IllegalStateException(
                                          "JDK zip file-system provider is unavailable"));
      }
  
      private static Throwable rootCause(Throwable throwable) {
          Throwable current = throwable;
          while (current.getCause() != null) {
              current = current.getCause();
          }
          return current;
      }
  
      private static boolean hasUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static boolean isModuleProbeClassLookupFailure(Throwable throwable) {
          return throwable instanceof ClassNotFoundException
                  && throwable.getMessage() != null
                  && throwable.getMessage().contains("$MockitoModuleProbe$");
      }
  
      @SuppressWarnings("unchecked")
      private static Class<FileSystemProvider> fileSystemProviderType(FileSystemProvider provider) {
          return (Class<FileSystemProvider>) provider.getClass();
      }
  
      private static class ChildContextLoader extends ClassLoader {
          ChildContextLoader(ClassLoader parent) {
              super(parent);
          }
      }
  }
