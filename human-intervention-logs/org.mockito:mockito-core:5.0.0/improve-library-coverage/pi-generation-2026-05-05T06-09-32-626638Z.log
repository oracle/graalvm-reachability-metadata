[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/PluginLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\nimport java.net.URL;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PluginLoaderTest {\n    private static final String PLUGINS_TYPE = \"org.mockito.internal.configuration.plugins.Plugins\";\n\n    @Test\n    void loadPluginCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Exception {\n        try {\n            withIsolatedMockito(\n                    mockitoLoader -> {\n                        Class<?> pluginsType = mockitoLoader.loadClass(PLUGINS_TYPE);\n                        Object logger = pluginsType.getMethod(\"getMockitoLogger\").invoke(null);\n\n                        InvocationTargetException exception =\n                                assertInvocationFails(logger, \"log\", \"message\");\n\n                        assertThat(exception.getCause())\n                                .isInstanceOf(IllegalStateException.class)\n                                .hasMessageContaining(\"Could not initialize plugin\")\n                                .hasMessageContaining(\"org.mockito.plugins.MockitoLogger\");\n                    });\n        } catch (Error error) {\n            if (!hasUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void loadPluginsCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Exception {\n        try {\n            withIsolatedMockito(\n                    mockitoLoader -> {\n                        Class<?> pluginsType = mockitoLoader.loadClass(PLUGINS_TYPE);\n                        List<?> resolvers =\n                                (List<?>) pluginsType.getMethod(\"getMockResolvers\").invoke(null);\n\n                        assertThat(resolvers).hasSize(1);\n                        InvocationTargetException exception =\n                                assertInvocationFails(resolvers.get(0), \"resolve\", new Object());\n\n                        assertThat(exception.getCause())\n                                .isInstanceOf(IllegalStateException.class)\n                                .hasMessageContaining(\"Could not initialize plugin\")\n                                .hasMessageContaining(\"org.mockito.plugins.MockResolver\");\n                    });\n        } catch (Error error) {\n            if (!hasUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static InvocationTargetException assertInvocationFails(\n            Object target, String methodName, Object argument) throws NoSuchMethodException {\n        Method method = target.getClass().getMethod(methodName, Object.class);\n        try {\n            method.invoke(target, argument);\n        } catch (IllegalAccessException exception) {\n            throw new AssertionError(\"Public plugin method should be invocable\", exception);\n        } catch (InvocationTargetException exception) {\n            return exception;\n        }\n        throw new AssertionError(\"Expected plugin proxy invocation to fail\");\n    }\n\n    private static void withIsolatedMockito(IsolatedMockitoOperation operation) throws Exception {\n        Thread thread = Thread.currentThread();\n        ClassLoader originalLoader = thread.getContextClassLoader();\n        ClassLoader mockitoLoader = new IsolatedMockitoClassLoader(PluginLoaderTest.class.getClassLoader());\n        ClassLoader failingResourceLoader = new FailingMockitoExtensionResourceLoader(mockitoLoader);\n        try {\n            thread.setContextClassLoader(failingResourceLoader);\n            operation.run(mockitoLoader);\n        } finally {\n            thread.setContextClassLoader(originalLoader);\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private interface IsolatedMockitoOperation {\n        void run(ClassLoader mockitoLoader) throws Exception;\n    }\n\n    private static final class FailingMockitoExtensionResourceLoader extends ClassLoader {\n        private FailingMockitoExtensionResourceLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (name.startsWith(\"mockito-extensions/\")) {\n                throw new IOException(\"Deliberate resource lookup failure for \" + name);\n            }\n            return super.getResources(name);\n        }\n    }\n\n    private static final class IsolatedMockitoClassLoader extends ClassLoader {\n        private IsolatedMockitoClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> type = findLoadedClass(name);\n                if (type == null) {\n                    type = loadFreshMockitoClassOrDelegate(name);\n                }\n                if (resolve) {\n                    resolveClass(type);\n                }\n                return type;\n            }\n        }\n\n        private Class<?> loadFreshMockitoClassOrDelegate(String name) throws ClassNotFoundException {\n            if (name.startsWith(\"org.mockito.\")) {\n                try {\n                    return findClass(name);\n                } catch (ClassNotFoundException ignored) {\n                    return super.loadClass(name, false);\n                }\n            }\n            return super.loadClass(name, false);\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream input = getParent().getResourceAsStream(resourceName)) {\n                if (input == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                byte[] classBytes = input.readAllBytes();\n                return defineClass(name, classBytes, 0, classBytes.length);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n    }\n}\n"}
