  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.junit.runner.Description;
  import org.junit.runner.manipulation.Filter;
  import org.junit.runner.manipulation.NoTestsRemainException;
  import org.junit.runner.notification.RunNotifier;
  import org.mockito.internal.runners.InternalRunner;
  import org.mockito.internal.runners.util.RunnerProvider;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RunnerProviderTest {
      @Test
      void createsInternalRunnerByClassNameWithConstructorArguments() throws Exception {
          RunnerProvider provider = new RunnerProvider();
  
          InternalRunner runner = provider.newInstance(RecordingInternalRunner.class.getName(), "sample");
  
          assertThat(runner).isInstanceOf(RecordingInternalRunner.class);
          RecordingInternalRunner recordingRunner = (RecordingInternalRunner) runner;
          assertThat(recordingRunner.name()).isEqualTo("sample");
          assertThat(recordingRunner.getDescription().getDisplayName()).isEqualTo("sample");
      }
  
      public static class RecordingInternalRunner implements InternalRunner {
          private final String name;
  
          public RecordingInternalRunner(String name) {
              this.name = name;
          }
  
          String name() {
              return name;
          }
  
          @Override
          public void run(RunNotifier notifier) {
              notifier.fireTestStarted(getDescription());
              notifier.fireTestFinished(getDescription());
          }
  
          @Override
          public Description getDescription() {
              return Description.createSuiteDescription(name);
          }
  
          @Override
          public void filter(Filter filter) throws NoTestsRemainException {
              // The test runner has a single synthetic suite, so filtering never removes it.
          }
      }
  }
