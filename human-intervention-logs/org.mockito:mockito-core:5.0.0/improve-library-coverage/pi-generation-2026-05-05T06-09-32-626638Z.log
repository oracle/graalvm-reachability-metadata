  package org_mockito.mockito_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.util.Enumeration;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PluginLoaderTest {
      private static final String PLUGINS_TYPE = "org.mockito.internal.configuration.plugins.Plugins";
  
      @Test
      void loadPluginCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Exception {
          try {
              withIsolatedMockito(
                      mockitoLoader -> {
                          Class<?> pluginsType = mockitoLoader.loadClass(PLUGINS_TYPE);
                          Object logger = pluginsType.getMethod("getMockitoLogger").invoke(null);
  
                          InvocationTargetException exception =
                                  assertInvocationFails(
                                          mockitoLoader,
                                          logger,
                                          "org.mockito.plugins.MockitoLogger",
                                          "log",
                                          "message");
  
                          assertThat(exception.getCause())
                                  .isInstanceOf(IllegalStateException.class)
                                  .hasMessageContaining("Could not initialize plugin")
                                  .hasMessageContaining("org.mockito.plugins.MockitoLogger");
                      });
          } catch (Error error) {
              if (!hasUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void loadPluginsCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Exception {
          try {
              withIsolatedMockito(
                      mockitoLoader -> {
                          Class<?> pluginsType = mockitoLoader.loadClass(PLUGINS_TYPE);
                          List<?> resolvers =
                                  (List<?>) pluginsType.getMethod("getMockResolvers").invoke(null);
  
                          assertThat(resolvers).hasSize(1);
                          InvocationTargetException exception =
                                  assertInvocationFails(
                                          mockitoLoader,
                                          resolvers.get(0),
                                          "org.mockito.plugins.MockResolver",
                                          "resolve",
                                          new Object());
  
                          assertThat(exception.getCause())
                                  .isInstanceOf(IllegalStateException.class)
                                  .hasMessageContaining("Could not initialize plugin")
                                  .hasMessageContaining("org.mockito.plugins.MockResolver");
                      });
          } catch (Error error) {
              if (!hasUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static InvocationTargetException assertInvocationFails(
              ClassLoader mockitoLoader,
              Object target,
              String pluginInterfaceName,
              String methodName,
              Object argument)
              throws ReflectiveOperationException {
          Class<?> pluginInterface = mockitoLoader.loadClass(pluginInterfaceName);
          Method method = pluginInterface.getMethod(methodName, Object.class);
          try {
              method.invoke(target, argument);
          } catch (InvocationTargetException exception) {
              return exception;
          }
          throw new AssertionError("Expected plugin proxy invocation to fail");
      }
  
      private static void withIsolatedMockito(IsolatedMockitoOperation operation) throws Exception {
          Thread thread = Thread.currentThread();
          ClassLoader originalLoader = thread.getContextClassLoader();
          ClassLoader mockitoLoader =
                  new IsolatedMockitoClassLoader(PluginLoaderTest.class.getClassLoader());
          ClassLoader failingResourceLoader =
                  new FailingMockitoExtensionResourceLoader(mockitoLoader);
          try {
              thread.setContextClassLoader(failingResourceLoader);
              operation.run(mockitoLoader);
          } finally {
              thread.setContextClassLoader(originalLoader);
          }
      }
  
