  package org_mockito.mockito_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.MockedConstruction;
  import org.mockito.Mockito;
  import org.mockito.exceptions.base.MockitoException;
  import org.mockito.internal.creation.MockSettingsImpl;
  import org.mockito.internal.handler.MockHandlerFactory;
  import org.mockito.mock.MockCreationSettings;
  import org.mockito.plugins.MockMaker;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class StackWalkerCheckerTest {
      @Test
      void mockConstructionUsesStackWalkerForDirectConstructorCalls() {
          runAllowingUnsupportedFeature(
                  () -> {
                      MockMaker.ConstructionMockControl<ConstructedService> control =
                              createConstructionMock(ConstructedService.class);
                      control.enable();
                      try {
                          ConstructedService service = new ConstructedService("real");
  
                          assertThat(service.message()).isNull();
                          assertThat(control.getMocks()).containsExactly(service);
                      } finally {
                          control.disable();
                      }
                  });
      }
  
      @Test
      void mockConstructionUsesStackWalkerForSubclassConstructorCalls() {
          runAllowingUnsupportedFeature(
                  () -> {
                      MockMaker.ConstructionMockControl<BaseService> control =
                              createConstructionMock(BaseService.class);
                      control.enable();
                      try {
                          DerivedService service = new DerivedService();
  
                          assertThat(service.message()).isEqualTo("base:derived");
                          assertThat(control.getMocks()).isEmpty();
                      } finally {
                          control.disable();
                      }
                  });
      }
  
      private static <T> MockMaker.ConstructionMockControl<T> createConstructionMock(
              Class<T> type) {
          MockMaker inlineMockMaker = Mockito.framework().getPlugins().getInlineMockMaker();
          return inlineMockMaker.createConstructionMock(
                  type,
                  context -> mockCreationSettings(type),
                  context -> MockHandlerFactory.createMockHandler(mockCreationSettings(type)),
                  (mock, context) -> {});
      }
  
      @SuppressWarnings("unchecked")
      private static <T> MockCreationSettings<T> mockCreationSettings(Class<T> type) {
          MockSettingsImpl<T> settings = (MockSettingsImpl<T>) Mockito.withSettings();
          return settings.build(type);
      }
  
      private static void runAllowingUnsupportedFeature(ThrowingRunnable action) {
          try {
              action.run();
          } catch (MockitoException exception) {
              if (!hasUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } catch (RuntimeException exception) {
              if (!hasUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static boolean hasUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error
                      && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      @FunctionalInterface
      private interface ThrowingRunnable {
          void run();
      }
  
      public static class ConstructedService {
          private final String message;
  
          public ConstructedService(String message) {
              this.message = message;
          }
  
          public String message() {
              return message;
          }
      }
  
      public static class BaseService {
          private final String value;
  
          public BaseService(String value) {
              this.value = value;
          }
  
          public String message() {
              return "base:" + value;
          }
      }
  
      public static class DerivedService extends BaseService {
          public DerivedService() {
              super("derived");
          }
      }
  }
