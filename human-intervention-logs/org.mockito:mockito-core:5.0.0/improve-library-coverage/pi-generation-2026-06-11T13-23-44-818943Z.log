  import java.util.stream.IntStream;
  import java.util.stream.LongStream;
  import java.util.stream.Stream;
  import org.junit.jupiter.api.Test;
  
  public class JavaEightUtilTest {
      @Test
      void returnsEmptyJavaEightValuesFromUnstubbedConcreteClassMock() {
          JavaEightDefaults defaults = mock(JavaEightDefaults.class);
  
          assertThat(defaults.optional()).isEmpty();
          assertThat(defaults.optionalDouble()).isEmpty();
          assertThat(defaults.optionalInt()).isEmpty();
          assertThat(defaults.optionalLong()).isEmpty();
          assertThat(defaults.stream()).isEmpty();
          assertThat(defaults.doubleStream().count()).isZero();
          assertThat(defaults.intStream().count()).isZero();
          assertThat(defaults.longStream().count()).isZero();
          assertThat(defaults.duration()).isEqualTo(Duration.ZERO);
          assertThat(defaults.period()).isEqualTo(Period.ZERO);
      }
  
      public static class JavaEightDefaults {
          public Optional<String> optional() {
              return Optional.of("real");
          }
  
          public OptionalDouble optionalDouble() {
              return OptionalDouble.of(1.5d);
          }
  
          public OptionalInt optionalInt() {
              return OptionalInt.of(1);
          }
  
          public OptionalLong optionalLong() {
              return OptionalLong.of(1L);
          }
  
          public Stream<String> stream() {
              return Stream.of("real");
          }
  
          public DoubleStream doubleStream() {
              return DoubleStream.of(1.5d);
          }
  
          public IntStream intStream() {
              return IntStream.of(1);
          }
  
          public LongStream longStream() {
              return LongStream.of(1L);
          }
  
          public Duration duration() {
              return Duration.ofSeconds(1);
          }
  
          public Period period() {
              return Period.ofDays(1);
          }
      }
  }
