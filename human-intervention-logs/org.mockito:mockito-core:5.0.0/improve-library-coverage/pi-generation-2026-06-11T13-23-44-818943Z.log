  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.AdditionalAnswers;
  import org.mockito.ArgumentCaptor;
  import org.mockito.InjectMocks;
  import org.mockito.Mock;
  import org.mockito.MockitoAnnotations;
  import org.mockito.Spy;
  
  public class InstrumentationMemberAccessorTest {
      @Test
      void initializesSpyWithPrivateConstructor() throws Exception {
          SpyFixture fixture = new SpyFixture();
  
          try (AutoCloseable mocks = MockitoAnnotations.openMocks(fixture)) {
              assertThat(fixture.counter.increment()).isEqualTo(8);
              verify(fixture.counter).increment();
          }
      }
  
      @Test
      void delegatesCallsThroughMemberAccessor() {
          GreetingContract greeting =
                  mock(
                          GreetingContract.class,
                          AdditionalAnswers.delegatesTo(new GreetingDelegate()));
  
          assertThat(greeting.greet("Ada")).isEqualTo("Hello Ada");
          verify(greeting).greet("Ada");
      }
  
