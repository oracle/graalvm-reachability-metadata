  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.when;
  
  import java.util.function.Function;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.MockedConstruction;
  import org.mockito.Mockito;
  import org.mockito.internal.creation.MockSettingsImpl;
  import org.mockito.internal.handler.MockHandlerFactory;
  import org.mockito.invocation.MockHandler;
  import org.mockito.mock.MockCreationSettings;
  import org.mockito.plugins.MockMaker;
  
  public class StackWalkerCheckerTest {
      @Test
      void constructionMockLeavesSubclassConstructionUnmocked() {
          try {
              exerciseInlineConstructionMock();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void exerciseInlineConstructionMock() {
          MockMaker inlineMockMaker = Mockito.framework().getPlugins().getInlineMockMaker();
          Function<MockedConstruction.Context, MockCreationSettings<ConstructedGreeter>>
                  settingsFactory = context -> new MockSettingsImpl<ConstructedGreeter>().build(
                          ConstructedGreeter.class);
          Function<MockedConstruction.Context, MockHandler<ConstructedGreeter>> handlerFactory =
                  context -> MockHandlerFactory.createMockHandler(settingsFactory.apply(context));
          MockMaker.ConstructionMockControl<ConstructedGreeter> control =
                  inlineMockMaker.createConstructionMock(
                          ConstructedGreeter.class,
                          settingsFactory,
                          handlerFactory,
                          (mock, context) -> when(mock.greeting()).thenReturn(
                                  "mocked " + context.getCount()));
  
          control.enable();
          try {
              ConstructedGreeter direct = new ConstructedGreeter("Ada");
              ChildGreeter child = new ChildGreeter("Bob");
  
              assertThat(direct.greeting()).isEqualTo("mocked 1");
              assertThat(child.greeting()).isEqualTo("child real Bob");
              assertThat(control.getMocks()).containsExactly(direct);
          } finally {
              control.disable();
              inlineMockMaker.clearAllCaches();
          }
      }
  
      public static class ConstructedGreeter {
          private final String name;
  
          public ConstructedGreeter(String name) {
              this.name = name;
          }
  
          public String greeting() {
              return "real " + name;
          }
      }
  
      public static class ChildGreeter extends ConstructedGreeter {
          public ChildGreeter(String name) {
              super(name);
          }
  
          @Override
          public String greeting() {
              return "child " + super.greeting();
          }
      }
  }
