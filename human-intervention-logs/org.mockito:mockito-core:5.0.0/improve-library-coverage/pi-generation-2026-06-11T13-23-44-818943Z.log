 int getCount();\n\n        Constructor<?> constructor();\n\n        List<?> arguments();\n    }\n\n    interface MockInitializer<T> {\n\n        void prepare(T mock, Context context) throws Throwable;\n    }\n}\n"}], "isError": false, "timestamp": 1781184146726}]}
