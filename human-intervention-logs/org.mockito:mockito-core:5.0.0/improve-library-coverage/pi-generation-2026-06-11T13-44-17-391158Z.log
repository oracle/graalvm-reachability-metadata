quals(sku) ? quantity * 25 : quantity * 10;\n                            });\n\n            assertThat(service.price(\"premium\", 3)).isEqualTo(75);\n            assertThat(service.price(\"standard\", 4)).isEqualTo(40);\n\n            ArgumentCaptor<String> skuCaptor = ArgumentCaptor.forClass(String.class);\n            verify(service).price(skuCaptor.capture(), eq(3));\n            assertThat(skuCaptor.getValue()).isEqualTo(\"premium\");\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void initializesAnnotatedConcreteInlineMockInMockitoSession() {\n        try {\n            MockitoSession session =\n                    Mockito.mockitoSession()\n                            .initMocks(this)\n                            .strictness(Strictness.STRICT_STUBS)\n                            .startMocking();\n            try {\n                when(annotatedService.describe(\"standard\")).thenReturn(\"mocked standard order\");\n\n                assertThat(annotatedService.describe(\"standard\")).isEqualTo(\"mocked standard order\");\n                verify(annotatedService).describe(\"standard\");\n            } finally {\n                session.finishMocking();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public static class InlineOrderService {\n        private final String source;\n        private final int basePrice;\n\n        public InlineOrderService(String source, int basePrice) {\n            this.source = source == null ? \"default\" : source;\n            this.basePrice = basePrice;\n        }\n\n        public int price(String sku, int quantity) {\n            return basePrice + sku.length() + quantity;\n        }\n\n        public String describe(String sku) {\n            return source + \" \" + sku;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781185613067}, {"role": "toolResult", "toolCallId": "call_PkFQ1XjhiZZEoVuaF385Icjk|fc_06ec292419a8e6ab016a2abc4cd0448197a27ae6f8154d2bad", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.mockito:mockito-core:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'junit:junit:4.13.2'\n    testImplementation \"org.mockito:mockito-subclass:5.0.0\"\n}\n\ntest {\n    jvmArgs \"-Djdk.attach.allowAttachSelf=true\"\n    jvmArgs \"-Dnet.bytebuddy.experimental=true\"\n}\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add(\"-Dnet.bytebuddy.experimental=true\")\n            runtimeArgs(\"-Dnet.bytebuddy.experimental=true\")\n        }\n    }\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781185613067}]}
