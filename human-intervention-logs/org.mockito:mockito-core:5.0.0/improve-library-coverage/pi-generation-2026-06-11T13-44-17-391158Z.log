 methodName) throws Exception {\n        try (URLClassLoader classLoader =\n                new URLClassLoader(testClasspathUrls(), ClassLoader.getPlatformClassLoader())) {\n            Class<?> scenario =\n                    classLoader.loadClass(\n                            \"org_mockito.mockito_core.InlineDelegateByteBuddyMockMakerTest$\"\n                                    + \"IsolatedInlineMockitoScenario\");\n            try {\n                scenario.getMethod(methodName).invoke(null);\n            } catch (InvocationTargetException exception) {\n                rethrowScenarioFailure(exception.getCause());\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static URL[] testClasspathUrls() {\n        String[] entries = System.getProperty(\"java.class.path\").split(System.getProperty(\"path.separator\"));\n        URL[] urls = new URL[entries.length];\n        for (int i = 0; i < entries.length; i++) {\n            try {\n                urls[i] = Path.of(entries[i]).toUri().toURL();\n            } catch (Exception exception) {\n                throw new IllegalStateException(\"Cannot convert classpath entry to URL: \" + entries[i], exception);\n            }\n        }\n        return urls;\n    }\n\n    private static void rethrowScenarioFailure(Throwable failure) throws Exception {\n        if (failure instanceof Error) {\n            throw (Error) failure;\n        } else if (failure instanceof Exception) {\n            throw (Exception) failure;\n        }\n        throw new AssertionError(failure);\n    }\n\n    public static class IsolatedInlineMockitoScenario {\n        public static void exerciseInlineMockMaker() {\n            InlineOrderService service =\n                    mock(InlineOrderService.class, withSettings().mockMaker(MockMakers.INLINE));\n\n            when(service.price(anyString(), anyInt()))\n                    .thenAnswer(\n                            invocation -> {\n                                String sku = invocation.getArgument(0);\n                                int quantity = invocation.getArgument(1);\n                                return \"premium\".equals(sku) ? quantity * 25 : quantity * 10;\n                            });\n\n            assertThat(service.price(\"premium\", 3)).isEqualTo(75);\n            assertThat(service.price(\"standard\", 4)).isEqualTo(40);\n\n            ArgumentCaptor<String> skuCaptor = ArgumentCaptor.forClass(String.class);\n            verify(service).price(skuCaptor.capture(), eq(3));\n            assertThat(skuCaptor.getValue()).isEqualTo(\"premium\");\n        }\n\n        public static void exerciseInlineInitializationDiagnostic() {\n            String previousJavaHome = System.getProperty(\"java.home\");\n            String previousAttachSelf = System.getProperty(\"jdk.attach.allowAttachSelf\");\n            String previousLatent = System.getProperty(\"net.bytebuddy.agent.latent\");\n            System.setProperty(\n                    \"java.home\",\n                    Path.of(\"build\", \"missing-java-home-for-inline-mock-maker\").toAbsolutePath().toString());\n            System.setProperty(\"jdk.attach.allowAttachSelf\", \"false\");\n            System.setProperty(\"net.bytebuddy.agent.latent\", \"true\");\n            try {\n                assertThatThrownBy(\n                                () ->\n                                        mock(\n                                                Runnable.class,\n                                                withSettings().mockMaker(MockMakers.INLINE)))\n                        .isInstanceOf(MockitoException.class)\n                        .hasMessageContaining(\"Could not initialize inline Byte Buddy mock maker\");\n            } finally {\n                setOrClearProperty(\"java.home\", previousJavaHome);\n                setOrClearProperty(\"jdk.attach.allowAttachSelf\", previousAttachSelf);\n                setOrClearProperty(\"net.bytebuddy.agent.latent\", previousLatent);\n            }\n        }\n\n        private static void setOrClearProperty(String key, String value) {\n            if (value == null) {\n                System.clearProperty(key);\n            } else {\n                System.setProperty(key, value);\n            }\n        }\n    }\n\n    public static class InlineOrderService {\n        private final String source;\n        private final int basePrice;\n\n        public InlineOrderService(String source, int basePrice) {\n            this.source = source == null ? \"default\" : source;\n            this.basePrice = basePrice;\n        }\n\n        public int price(String sku, int quantity) {\n            return basePrice + sku.length() + quantity;\n        }\n\n        public String describe(String sku) {\n            return source + \" \" + sku;\n        }\n    }\n}\n"}
