[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InlineDelegateByteBuddyMockMakerInnerInlineConstructionMockContextTest.java","edits":[{"oldText":"import static org.mockito.Mockito.RETURNS_DEFAULTS;\nimport static org.mockito.Mockito.verify;\nimport static org.mockito.Mockito.when;\n","newText":"import static org.mockito.Mockito.RETURNS_DEFAULTS;\n"},{"oldText":"import java.util.List;\n","newText":"import java.util.List;\nimport java.util.concurrent.atomic.AtomicReference;\n"},{"oldText":"            MockMaker.ConstructionMockControl<ConstructedOrder> control =\n                    mockMaker.createConstructionMock(\n                            ConstructedOrder.class,\n                            context -> settings,\n                            context -> createMockHandler(settings),\n                            this::initializeConstructedOrderMock);\n\n            control.enable();\n            try {\n                ConstructedOrder order =\n                        new ConstructedOrder(\"sku-1\", 3, Collaborator.DEFAULT);\n\n                assertThat(order.describe()).isEqualTo(\"mocked sku-1 x3\");\n                verify(order).describe();\n                assertThat(control.getMocks()).containsExactly(order);\n            } finally {\n","newText":"            AtomicReference<Constructor<?>> constructor = new AtomicReference<>();\n            AtomicReference<List<?>> arguments = new AtomicReference<>();\n            MockMaker.ConstructionMockControl<ConstructedOrder> control =\n                    mockMaker.createConstructionMock(\n                            ConstructedOrder.class,\n                            context -> settings,\n                            context -> createMockHandler(settings),\n                            (mock, context) ->\n                                    initializeConstructedOrderMock(\n                                            mock, context, constructor, arguments));\n\n            control.enable();\n            try {\n                ConstructedOrder order = new ConstructedOrder(\"sku-1\", 3, Collaborator.DEFAULT);\n\n                assertThat(control.getMocks()).containsExactly(order);\n                assertThat(arguments.get()).isEqualTo(List.of(\"sku-1\", 3, Collaborator.DEFAULT));\n                assertThat(constructor.get().getDeclaringClass()).isEqualTo(ConstructedOrder.class);\n                assertThat(constructor.get().getParameterTypes())\n                        .containsExactly(String.class, int.class, Collaborator.class);\n            } finally {\n"},{"oldText":"    private void initializeConstructedOrderMock(\n            ConstructedOrder mock, MockedConstruction.Context context) {\n        Constructor<?> constructor = context.constructor();\n        assertThat(context.getCount()).isEqualTo(1);\n        assertThat(context.arguments()).isEqualTo(List.of(\"sku-1\", 3, Collaborator.DEFAULT));\n        assertThat(constructor.getDeclaringClass()).isEqualTo(ConstructedOrder.class);\n        assertThat(constructor.getParameterTypes())\n                .containsExactly(String.class, int.class, Collaborator.class);\n        when(mock.describe()).thenReturn(\"mocked sku-1 x3\");\n    }\n","newText":"    private void initializeConstructedOrderMock(\n            ConstructedOrder mock,\n            MockedConstruction.Context context,\n            AtomicReference<Constructor<?>> constructor,\n            AtomicReference<List<?>> arguments) {\n        assertThat(mock).isInstanceOf(ConstructedOrder.class);\n        assertThat(context.getCount()).isEqualTo(1);\n        constructor.set(context.constructor());\n        arguments.set(context.arguments());\n    }\n"}]}
