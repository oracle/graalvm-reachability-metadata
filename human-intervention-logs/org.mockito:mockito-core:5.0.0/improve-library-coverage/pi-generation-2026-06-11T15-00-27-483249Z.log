containsExactly(String.class, int.class, Collaborator.class);\n        when(mock.describe()).thenReturn(\"mocked sku-1 x3\");\n    }\n\n    public static class ConstructedOrder {\n        private final String sku;\n        private final int quantity;\n        private final Collaborator collaborator;\n\n        public ConstructedOrder(String sku, int quantity, Collaborator collaborator) {\n            this.sku = sku;\n            this.quantity = quantity;\n            this.collaborator = collaborator;\n        }\n\n        public String describe() {\n            return collaborator.prefix() + \" \" + sku + \" x\" + quantity;\n        }\n    }\n\n    public static class Collaborator {\n        static final Collaborator DEFAULT = new Collaborator(\"real\");\n\n        private final String prefix;\n\n        public Collaborator(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String prefix() {\n            return prefix;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1034, "output": 965, "cacheRead": 37376, "cacheWrite": 0, "totalTokens": 39375, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781189929718, "responseId": "resp_0ec753bfee22910d016a2acd2a91308190ad827d17e7cad014"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_CydFFQpZWfvGDrqmKHhwKvlX|fc_0ec753bfee22910d016a2acd2f7cc88190bb3a73fc41ce5f04", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3897 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InlineDelegateByteBuddyMockMakerInnerInlineConstructionMockContextTest.java"}], "isError": false, "timestamp": 1781189946442}]}
