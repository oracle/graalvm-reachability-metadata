  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.RETURNS_DEFAULTS;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  
  import java.lang.reflect.Constructor;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.MockedConstruction;
  import org.mockito.internal.creation.MockSettingsImpl;
  import org.mockito.internal.creation.bytebuddy.InlineByteBuddyMockMaker;
  import org.mockito.internal.handler.MockHandlerFactory;
  import org.mockito.invocation.MockHandler;
  import org.mockito.mock.MockCreationSettings;
  import org.mockito.plugins.MockMaker;
  
  public class InlineDelegateByteBuddyMockMakerInnerInlineConstructionMockContextTest {
      @Test
      void exposesConstructedObjectArgumentsAndConstructorToInitializer() {
          try {
              InlineByteBuddyMockMaker mockMaker = new InlineByteBuddyMockMaker();
              MockSettingsImpl<ConstructedOrder> mockSettings = new MockSettingsImpl<>();
              mockSettings.defaultAnswer(RETURNS_DEFAULTS);
              MockCreationSettings<ConstructedOrder> settings =
                      mockSettings.build(ConstructedOrder.class);
              MockMaker.ConstructionMockControl<ConstructedOrder> control =
                      mockMaker.createConstructionMock(
                              ConstructedOrder.class,
                              context -> settings,
                              context -> createMockHandler(settings),
                              this::initializeConstructedOrderMock);
  
              control.enable();
              try {
                  ConstructedOrder order =
                          new ConstructedOrder("sku-1", 3, Collaborator.DEFAULT);
  
                  assertThat(order.describe()).isEqualTo("mocked sku-1 x3");
                  verify(order).describe();
                  assertThat(control.getMocks()).containsExactly(order);
              } finally {
                  control.disable();
                  mockMaker.clearAllMocks();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private MockHandler<ConstructedOrder> createMockHandler(
              MockCreationSettings<ConstructedOrder> settings) {
          return MockHandlerFactory.createMockHandler(settings);
      }
  
      private void initializeConstructedOrderMock(
              ConstructedOrder mock, MockedConstruction.Context context) {
          Constructor<?> constructor = context.constructor();
          assertThat(context.getCount()).isEqualTo(1);
          assertThat(context.arguments()).containsExactly("sku-1", 3, Collaborator.DEFAULT);
          assertThat(constructor.getDeclaringClass()).isEqualTo(ConstructedOrder.class);
          assertThat(constructor.getParameterTypes())
                  .containsExactly(String.class, int.class, Collaborator.class);
          when(mock.describe()).thenReturn("mocked sku-1 x3");
      }
  
      public static class ConstructedOrder {
          private final String sku;
          private final int quantity;
          private final Collaborator collaborator;
  
          public ConstructedOrder(String sku, int quantity, Collaborator collaborator) {
              this.sku = sku;
              this.quantity = quantity;
              this.collaborator = collaborator;
          }
  
          public String describe() {
              return collaborator.prefix() + " " + sku + " x" + quantity;
          }
      }
  
      public static class Collaborator {
          static final Collaborator DEFAULT = new Collaborator("real");
  
          private final String prefix;
  
          public Collaborator(String prefix) {
              this.prefix = prefix;
          }
  
          public String prefix() {
              return prefix;
          }
      }
  }
