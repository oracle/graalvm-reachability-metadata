                  return false;
              }
  
              for (Method m : clazz.getDeclaredMethods()) {
                  if (m.getName().equalsIgnoreCase(method.getName())
                          && Arrays.equals(m.getParameterTypes(), method.getParameterTypes())) {
                      return true;
                  }
              }
  
              return false;
          }
      }
