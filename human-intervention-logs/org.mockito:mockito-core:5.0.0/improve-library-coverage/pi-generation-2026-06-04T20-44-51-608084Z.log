      systemProperty "net.bytebuddy.experimental", "true"
      systemProperty "java.security.manager", "allow"
  }
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
