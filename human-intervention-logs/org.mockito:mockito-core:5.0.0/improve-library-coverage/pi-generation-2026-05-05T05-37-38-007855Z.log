port org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.Mockito;\nimport org.objenesis.ObjenesisStd;\n\nimport static net.bytebuddy.description.modifier.Ownership.STATIC;\nimport static net.bytebuddy.description.modifier.Visibility.PUBLIC;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class KotlinInlineClassUtilTest {\n    @Test\n    void stubbingMethodReturningUnderlyingTypeUnboxesKotlinInlineClassValue() {\n        runAllowingUnsupportedFeature(\n                () -> {\n                    Object inlineValue = newInlineValue();\n                    UnderlyingTypeService service = Mockito.mock(UnderlyingTypeService.class);\n\n                    Mockito.doReturn(inlineValue).when(service).value();\n\n                    assertThat(service.value()).isEqualTo(\"underlying-value\");\n                });\n    }\n\n    private static Object newInlineValue() {\n        Class<?> inlineClass =\n                new ByteBuddy()\n                        .with(TypeValidation.DISABLED)\n                        .subclass(Object.class)\n                        .name(\"org_mockito.mockito_core.GeneratedKotlinInlineString\")\n                        .annotateType(AnnotationDescription.Builder.ofType(JvmInline.class).build())\n                        .defineMethod(\"box-impl\", Object.class, PUBLIC, STATIC)\n                        .withParameters(String.class)\n                        .intercept(FixedValue.nullValue())\n                        .defineMethod(\"unbox-impl\", String.class, PUBLIC)\n                        .intercept(FixedValue.value(\"underlying-value\"))\n                        .make()\n                        .load(\n                                KotlinInlineClassUtilTest.class.getClassLoader(),\n                                ClassLoadingStrategy.Default.INJECTION)\n                        .getLoaded();\n        return new ObjenesisStd().newInstance(inlineClass);\n    }\n\n    private static void runAllowingUnsupportedFeature(ThrowingRunnable action) {\n        try {\n            action.run();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run();\n    }\n\n    public interface UnderlyingTypeService {\n        String value();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1997, "output": 1184, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 29805, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777959392748, "responseId": "resp_02709832a3c45bfb0169f981e133308192a517e29aa068d00e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_c2blUOx89VQYA9NPCMGvyvNX|fc_02709832a3c45bfb0169f981eb478c819298ce1622fa2fce6e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2916 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/KotlinInlineClassUtilTest.java"}], "isError": false, "timestamp": 1777959406067}]}
