[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/SubclassInjectionLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SubclassInjectionLoaderTest {\n    @Test\n    void initializesLookupBasedInjectionLoaderWhenUnsafeInjectionIsDisabled() throws Exception {\n        String previous = System.getProperty(\"org.mockito.internal.noUnsafeInjection\");\n        System.setProperty(\"org.mockito.internal.noUnsafeInjection\", \"true\");\n        try {\n            Class<?> loaderType = Class.forName(\n                    \"org.mockito.internal.creation.bytebuddy.SubclassInjectionLoader\");\n            Constructor<?> constructor = loaderType.getDeclaredConstructor();\n            constructor.setAccessible(true);\n            Object loader = constructor.newInstance();\n\n            assertThat(loaderType.getMethod(\"isDisrespectingOpenness\").invoke(loader))\n                    .isEqualTo(false);\n        } finally {\n            if (previous == null) {\n                System.clearProperty(\"org.mockito.internal.noUnsafeInjection\");\n            } else {\n                System.setProperty(\"org.mockito.internal.noUnsafeInjection\", previous);\n            }\n        }\n    }\n\n    @Test\n    void resolvesLookupStrategyForLocalMockClass() throws Exception {\n        String previous = System.getProperty(\"org.mockito.internal.noUnsafeInjection\");\n        System.setProperty(\"org.mockito.internal.noUnsafeInjection\", \"true\");\n        try {\n            Class<?> loaderType = Class.forName(\n                    \"org.mockito.internal.creation.bytebuddy.SubclassInjectionLoader\");\n            Constructor<?> constructor = loaderType.getDeclaredConstructor();\n            constructor.setAccessible(true);\n            Object loader = constructor.newInstance();\n\n            Method resolveStrategy = loaderType.getMethod(\n                    \"resolveStrategy\", Class.class, ClassLoader.class, boolean.class);\n            Object strategy = resolveStrategy.invoke(\n                    loader,\n                    LocalMockTarget.class,\n                    LocalMockTarget.class.getClassLoader(),\n                    true);\n\n            assertThat(strategy).isNotNull();\n        } finally {\n            if (previous == null) {\n                System.clearProperty(\"org.mockito.internal.noUnsafeInjection\");\n            } else {\n                System.setProperty(\"org.mockito.internal.noUnsafeInjection\", previous);\n            }\n        }\n    }\n\n    public static class LocalMockTarget {\n    }\n}\n"}
