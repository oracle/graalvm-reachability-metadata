[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/MockitoDynamicTestSupport.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\n\nimport java.util.concurrent.Callable;\n\nfinal class MockitoDynamicTestSupport {\n    private MockitoDynamicTestSupport() {\n    }\n\n    static <T> T callAllowingUnsupportedDynamicLoading(Callable<T> callable) throws Exception {\n        try {\n            return callable.call();\n        } catch (Error error) {\n            if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return null;\n            }\n            throw error;\n        }\n    }\n\n    static void runAllowingUnsupportedDynamicLoading(CheckedRunnable runnable) throws Exception {\n        callAllowingUnsupportedDynamicLoading(\n                () -> {\n                    runnable.run();\n                    return null;\n                });\n    }\n\n    interface CheckedRunnable {\n        void run() throws Exception;\n    }\n}\n"}
