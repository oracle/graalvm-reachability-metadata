  public class StackWalkerCheckerTest {
      @Test
      void checksConstructionCallStackBeforeMockingConstructor() throws Exception {
          MockitoDynamicTestSupport.runAllowingUnsupportedDynamicLoading(
                  () -> {
                      try (MockedConstruction<StackCheckedConstruction> mocked =
