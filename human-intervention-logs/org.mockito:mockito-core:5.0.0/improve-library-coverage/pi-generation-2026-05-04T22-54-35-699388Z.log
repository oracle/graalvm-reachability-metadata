  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Constructor;
  import java.util.function.Predicate;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class StackTraceCheckerTest {
      @Test
      @SuppressWarnings("unchecked")
      void detectsSubclassConstructorFromStackTrace() throws Exception {
          Class<?> checkerType = Class.forName(
                  "org.mockito.internal.creation.bytebuddy.StackTraceChecker");
          Constructor<?> constructor = checkerType.getDeclaredConstructor();
          constructor.setAccessible(true);
          Predicate<Class<?>> checker = (Predicate<Class<?>>) constructor.newInstance();
  
          CheckedSubclass checkedSubclass = new CheckedSubclass(checker);
  
          assertThat(checkedSubclass.detectedSubclassConstructor()).isTrue();
      }
  
      private static class CheckedBase {
          private final boolean detectedSubclassConstructor;
  
          private CheckedBase(Predicate<Class<?>> checker) {
              detectedSubclassConstructor = checker.test(CheckedBase.class);
          }
  
          private boolean detectedSubclassConstructor() {
              return detectedSubclassConstructor;
          }
      }
  
      private static class CheckedSubclass extends CheckedBase {
          private CheckedSubclass(Predicate<Class<?>> checker) {
              super(checker);
          }
      }
  }
