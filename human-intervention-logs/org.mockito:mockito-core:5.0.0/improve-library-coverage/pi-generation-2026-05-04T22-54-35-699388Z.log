                          assertThat(Mockito.mockingDetails(construction).isMock()).isTrue();
                          assertThat(mocked.constructed()).containsExactly(construction);
                      }
                  });
      }
  
      public static class StackCheckedConstruction {
          public StackCheckedConstruction() {
          }
      }
