  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.mockingDetails;
  import static org.mockito.Mockito.reset;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  import static org.mockito.Mockito.withSettings;
  
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.plugins.MockResolver;
  
  public class PluginInitializerTest {
      @Test
      void loadsMockResolverPluginAndAppliesItToMockitoDslObjects() {
          GreetingService service = mock(GreetingService.class, withSettings().name("service"));
          when(service.greet("Ada")).thenAnswer(invocation -> "Hello " + invocation.getArgument(0));
          WrappedGreetingService wrappedService = new WrappedGreetingService(service);
  
          assertThat(mockingDetails(wrappedService).isMock()).isTrue();
          assertThat(
                          mockingDetails(wrappedService)
                                  .getMockCreationSettings()
                                  .getMockName()
                                  .toString())
                  .isEqualTo("service");
          assertThat(wrappedService.greet("Ada")).isEqualTo("Hello Ada");
          verify(service).greet("Ada");
  
          reset(wrappedService);
  
          assertThat(service.greet("Ada")).isNull();
          assertThat(WrappedMockResolver.instantiations()).isGreaterThanOrEqualTo(1);
          assertThat(WrappedMockResolver.resolutions()).isGreaterThanOrEqualTo(2);
      }
  
      public static class WrappedMockResolver implements MockResolver {
          private static final AtomicInteger INSTANTIATIONS = new AtomicInteger();
          private static final AtomicInteger RESOLUTIONS = new AtomicInteger();
  
          public WrappedMockResolver() {
              INSTANTIATIONS.incrementAndGet();
          }
  
          @Override
          public Object resolve(Object instance) {
              RESOLUTIONS.incrementAndGet();
              if (instance instanceof WrappedGreetingService) {
                  return ((WrappedGreetingService) instance).mock;
              }
              return instance;
          }
  
          static int instantiations() {
              return INSTANTIATIONS.get();
          }
  
          static int resolutions() {
              return RESOLUTIONS.get();
          }
      }
  
      public static class WrappedGreetingService {
          private final GreetingService mock;
  
          WrappedGreetingService(GreetingService mock) {
              this.mock = mock;
          }
  
          public String greet(String name) {
              return mock.greet(name);
          }
      }
  
      public static class GreetingService {
          public String greet(String name) {
              return "unmocked " + name;
          }
      }
  }
