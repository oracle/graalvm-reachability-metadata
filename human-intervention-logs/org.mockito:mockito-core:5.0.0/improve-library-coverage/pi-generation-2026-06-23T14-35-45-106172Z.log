ertThat;\n\npublic class ByteBuddyCrossClassLoaderSerializationSupportInnerCrossClassLoaderSerializationProxyTest {\n    private static final String TEST_CLASS_NAME =\n            \"org_mockito.mockito_core.\"\n                    + \"ByteBuddyCrossClassLoaderSerializationSupportInnerCrossClassLoaderSerializationProxyTest\";\n    private static final String MOCK_MAKER_EXTENSION =\n            \"mockito-extensions/org.mockito.plugins.MockMaker\";\n\n    @Test\n    void byteBuddyMockMakerSerializesAndDeserializesAcrossClassLoaders() throws Exception {\n        Thread currentThread = Thread.currentThread();\n        ClassLoader previousContextClassLoader = currentThread.getContextClassLoader();\n        try (ByteBuddyMockitoClassLoader classLoader =\n                new ByteBuddyMockitoClassLoader(testClasspathUrls())) {\n            currentThread.setContextClassLoader(classLoader);\n            Class<?> testClass = classLoader.loadClass(TEST_CLASS_NAME);\n            Object result =\n                    testClass\n                            .getMethod(\"serializeAndDeserializeSerializableMockWithByteBuddy\")\n                            .invoke(null);\n\n            assertThat(result).isEqualTo(\"greeting from a serialized mock\");\n        } catch (InvocationTargetException exception) {\n            rethrowUnlessUnsupportedFeatureError(exception.getCause());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            currentThread.setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    public static String serializeAndDeserializeSerializableMockWithByteBuddy() throws Exception {\n        SerializableGreetingService service =\n                Mockito.mock(\n                        SerializableGreetingService.class,\n                        Mockito.withSettings().serializable(SerializableMode.ACROSS_CLASSLOADERS));\n        Mockito.when(service.greeting()).thenReturn(\"greeting from a serialized mock\");\n\n        SerializableGreetingService deserializedService = serializeAndDeserialize(service);\n        if (!Mockito.mockingDetails(deserializedService).isMock()) {\n            throw new AssertionError(\"Deserialized service should remain a Mockito mock\");\n        }\n        return deserializedService.greeting();\n    }\n\n    private static SerializableGreetingService serializeAndDeserialize(\n            SerializableGreetingService service) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(bytes)) {\n            objectOutputStream.writeObject(service);\n        }\n\n        try (ObjectInputStream objectInputStream =\n                new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (SerializableGreetingService) objectInputStream.readObject();\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Throwable throwable) {\n        if (throwable instanceof Error error\n                && NativeImageSupport.isUnsupportedFeatureError(error)) {\n            return;\n        }\n        if (throwable instanceof RuntimeException runtimeException) {\n            throw runtimeException;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n        throw new AssertionError(throwable);\n    }\n\n    private static URL[] testClasspathUrls() {\n        return Arrays.stream(System.getProperty(\"java.class.path\", \"\").split(File.pathSeparator))\n                .filter(entry -> !entry.isEmpty())\n                .map(File::new)\n                .map(File::toURI)\n                .map(uri -> {\n                    try {\n                        return uri.toURL();\n                    } catch (Exception exception) {\n                        throw new IllegalStateException(exception);\n                    }\n                })\n                .toArray(URL[]::new);\n    }\n\n    private static class ByteBuddyMockitoClassLoader extends URLClassLoader {\n        ByteBuddyMockitoClassLoader(URL[] urls) {\n            super(urls, ClassLoader.getPlatformClassLoader());\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\n                return null;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) {\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\n                return Collections.emptyEnumeration();\n            }\n            try {\n                return super.getResources(name);\n            } catch (Exception exception) {\n                throw new IllegalStateException(exception);\n            }\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (isChildFirstClass(name)) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loaded = findLoadedClass(name);\n                    if (loaded == null) {\n                        try {\n                            loaded = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loaded = super.loadClass(name, false);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loaded);\n                    }\n                    return loaded;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private static boolean isChildFirstClass(String name) {\n            return name.startsWith(\"org.mockito.\")\n                    || name.startsWith(\"net.bytebuddy.\")\n                    || name.startsWith(\"org.objenesis.\")\n                    || name.equals(TEST_CLASS_NAME)\n                    || name.equals(\"org_mockito.mockito_core.SerializableGreetingService\");\n        }\n    }\n}\n\ninterface SerializableGreetingService extends Serializable {\n    String greeting();\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 572, "output": 2197, "cacheRead": 35328, "cacheWrite": 0, "totalTokens": 38097, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782225197141, "responseId": "resp_07ea5a3b0e20e213016a3a992df45081938223b1f8ca484cab"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_l8jbVQgToPPis0wG8zslx6iD|fc_07ea5a3b0e20e213016a3a99443ef88193b361f03bd5012e60", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6934 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ByteBuddyCrossClassLoaderSerializationSupportInnerCrossClassLoaderSerializationProxyTest.java"}], "isError": false, "timestamp": 1782225235784}]}
