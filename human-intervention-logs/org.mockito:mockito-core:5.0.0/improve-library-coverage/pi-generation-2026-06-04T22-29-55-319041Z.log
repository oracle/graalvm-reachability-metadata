mItZtqzYWRJleC17DVWeFDzjC2bY7DctD_5OAjm3EvZBW5Rzyub4AEB6j7rLdZEPoCPqKZ9eHlNsrXXCjsDm4oq1a8ZwIoKxqnjZ_ac5HJZcJrh-3z5ONqoKvqUNWPFrelA10t9eTCcoK9txHNGWXJQV51BxF7n2rGuoA_NgHpcRH0QgIsHm_UHMwDWY3I=\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_hboRgwp5SNt5CZT6EAqcwtBj|fc_0ec0321e094f7b3e016a21fc2653b881979fd235c1869eb7a2", "name": "edit", "arguments": {"path": "tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java", "edits": [{"oldText": "import java.util.Map;\nimport java.util.Optional;\nimport java.util.Set;\nimport java.util.stream.Stream;\n", "newText": "import java.util.HashMap;\nimport java.util.Map;\nimport java.util.Optional;\nimport java.util.Set;\nimport java.util.stream.Stream;\n"}, {"oldText": "    private static final String MODULE_NAME = \"mockito.test.module\";\n    private static final String HIDDEN_PACKAGE = \"sample.hidden\";\n    private static final String HIDDEN_TYPE_NAME = HIDDEN_PACKAGE + \".HiddenService\";\n    private static final String HIDDEN_TYPE_RESOURCE = \"sample/hidden/HiddenService.class\";\n", "newText": "    private static final String HIDDEN_MODULE_NAME = \"mockito.test.hidden.module\";\n    private static final String EXTRA_INTERFACE_MODULE_NAME = \"mockito.test.extra.module\";\n    private static final String HIDDEN_PACKAGE = \"sample.hidden\";\n    private static final String EXTRA_INTERFACE_PACKAGE = \"sample.extra\";\n    private static final String HIDDEN_TYPE_NAME = HIDDEN_PACKAGE + \".HiddenService\";\n    private static final String EXTRA_INTERFACE_TYPE_NAME =\n            EXTRA_INTERFACE_PACKAGE + \".ExtraService\";\n    private static final String HIDDEN_TYPE_RESOURCE = \"sample/hidden/HiddenService.class\";\n    private static final String EXTRA_INTERFACE_RESOURCE = \"sample/extra/ExtraService.class\";\n"}, {"oldText": "            Object mock = mockHiddenTypeFromNamedModule();\n\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n", "newText": "            Object mock = mockHiddenTypeFromNamedModuleWithExtraInterface();\n\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n            assertThat(loadExtraInterfaceFromMock(mock).isInstance(mock)).isTrue();\n"}, {"oldText": "    private static Object mockHiddenTypeFromNamedModule() throws Exception {\n        Class<?> hiddenType = loadHiddenTypeFromNamedModule();\n\n        assertThat(hiddenType.getModule().isNamed()).isTrue();\n        assertThat(hiddenType.getModule().isExported(HIDDEN_PACKAGE)).isFalse();\n\n        return Mockito.mock(hiddenType, withSettings().mockMaker(MockMakers.SUBCLASS));\n    }\n\n    private static Class<?> loadHiddenTypeFromNamedModule() throws ClassNotFoundException {\n        ModuleLayer parent = ModuleLayer.boot();\n        ModuleFinder finder = new InMemoryModuleFinder();\n        Configuration configuration =\n                parent.configuration().resolve(finder, ModuleFinder.of(), Set.of(MODULE_NAME));\n        ModuleLayer layer =\n                parent.defineModulesWithOneLoader(\n                        configuration, ClassLoader.getSystemClassLoader());\n\n        return layer.findLoader(MODULE_NAME).loadClass(HIDDEN_TYPE_NAME);\n    }\n", "newText": "    private static Object mockHiddenTypeFromNamedModuleWithExtraInterface() throws Exception {\n        ModuleLayer layer = loadTestModules();\n        Class<?> hiddenType = layer.findLoader(HIDDEN_MODULE_NAME).loadClass(HIDDEN_TYPE_NAME);\n        Class<?> extraInterface =\n                layer.findLoader(EXTRA_INTERFACE_MODULE_NAME).loadClass(EXTRA_INTERFACE_TYPE_NAME);\n\n        assertThat(hiddenType.getModule().isNamed()).isTrue();\n        assertThat(hiddenType.getModule().isExported(HIDDEN_PACKAGE)).isFalse();\n        assertThat(hiddenType.getClassLoader()).isNotEqualTo(extraInterface.getClassLoader());\n\n        return Mockito.mock(\n                hiddenType,\n                withSettings()\n                        .mockMaker(MockMakers.SUBCLASS)\n                        .extraInterfaces(extraInterface));\n    }\n\n    private static Class<?> loadExtraInterfaceFromMock(Object mock) throws ClassNotFoundException {\n        return mock.getClass().getClassLoader().loadClass(EXTRA_INTERFACE_TYPE_NAME);\n    }\n\n    private static ModuleLayer loadTestModules() {\n        ModuleLayer parent = ModuleLayer.boot();\n        ModuleFinder finder = new InMemoryModuleFinder();\n        Configuration configuration =\n                parent.configuration()\n                        .resolve(\n                                finder,\n                                ModuleFinder.of(),\n                                Set.of(HIDDEN_MODULE_NAME, EXTRA_INTERFACE_MODULE_NAME));\n        return parent.defineModulesWithManyLoaders(\n                configuration, ClassLoader.getSystemClassLoader());\n    }\n"}, {"oldText": "    private static final class InMemoryModuleFinder implements ModuleFinder {\n        private final ModuleReference moduleReference;\n\n        private InMemoryModuleFinder() {\n            ModuleDescriptor descriptor =\n                    ModuleDescriptor.newModule(MODULE_NAME)\n                            .packages(Set.of(HIDDEN_PACKAGE))\n                            .build();\n            moduleReference =\n                    new InMemoryModuleReference(\n                            descriptor, Map.of(HIDDEN_TYPE_RESOURCE, hiddenServiceBytes()));\n        }\n\n        @Override\n        public Optional<ModuleReference> find(String name) {\n            if (MODULE_NAME.equals(name)) {\n                return Optional.of(moduleReference);\n            }\n            return Optional.empty();\n        }\n\n        @Override\n        public Set<ModuleReference> findAll() {\n            return Set.of(moduleReference);\n        }\n    }\n", "newText": "    private static final class InMemoryModuleFinder implements ModuleFinder {\n        private final Map<String, ModuleReference> modules;\n\n        private InMemoryModuleFinder() {\n            ModuleDescriptor hiddenDescriptor =\n                    ModuleDescriptor.newModule(HIDDEN_MODULE_NAME)\n                            .packages(Set.of(HIDDEN_PACKAGE))\n                            .build();\n            ModuleDescriptor extraInterfaceDescriptor =\n                    ModuleDescriptor.newModule(EXTRA_INTERFACE_MODULE_NAME)\n                            .exports(EXTRA_INTERFACE_PACKAGE)\n                            .build();\n\n            modules =\n                    Map.of(\n                            HIDDEN_MODULE_NAME,\n                            new InMemoryModuleReference(\n                                    hiddenDescriptor, hiddenModuleResources()),\n                            EXTRA_INTERFACE_MODULE_NAME,\n                            new InMemoryModuleReference(\n                                    extraInterfaceDescriptor,\n                                    Map.of(EXTRA_INTERFACE_RESOURCE, extraInterfaceBytes())));\n        }\n\n        @Override\n        public Optional<ModuleReference> find(String name) {\n            return Optional.ofNullable(modules.get(name));\n        }\n\n        @Override\n        public Set<ModuleReference> findAll() {\n            return Set.copyOf(modules.values());\n        }\n    }\n\n    private static Map<String, byte[]> hiddenModuleResources() {\n        Map<String, byte[]> resources = new HashMap<>();\n        resources.put(HIDDEN_TYPE_RESOURCE, hiddenServiceBytes());\n        resources.put(injectionBaseCollisionResource(), injectionBaseCollisionBytes());\n        return Map.copyOf(resources);\n    }\n\n    private static String injectionBaseCollisionResource() {\n        return HIDDEN_PACKAGE.replace('.', '/')\n                + \"/InjectionBase$\"\n                + injectionBaseSuffix()\n                + \".class\";\n    }\n\n    private static int injectionBaseSuffix() {\n        return Math.abs(Mockito.class.hashCode());\n    }\n"},