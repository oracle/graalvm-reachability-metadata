kito;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MockitoTest {\n    @Test\n    void test() {\n        MyService myService = Mockito.mock(MyService.class);\n        Mockito.when(myService.getGreeting()).thenReturn(\"Hello Mockito\");\n        assertThat(myService.getGreeting()).isEqualTo(\"Hello Mockito\");\n    }\n}\n"}], "isError": false, "timestamp": 1778775181266}, {"role": "toolResult", "toolCallId": "call_SWuXcXGnsRREu3fCuWYv7C9K|fc_0b2f69fb67bb8853016a05f48cfea8819e8a91b6bb8b859a4a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.mockito.MockMakers;\nimport org.mockito.Mockito;\nimport org.mockito.exceptions.base.MockitoException;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.lang.module.ModuleFinder;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Set;\n\nimport javax.tools.JavaCompiler;\nimport javax.tools.ToolProvider;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.withSettings;\n\npublic class ModuleHandlerInnerModuleSystemFoundTest {\n    private static final String JAVAC_CONTEXT_CLASS_NAME = \"com.sun.tools.javac.util.Context\";\n    private static final String DYNAMIC_MODULE_NAME = \"dynamic.mockito.sample\";\n    private static final String DYNAMIC_MODULE_TYPE_NAME = \"sample.internal.ModuleType\";\n    private static final String EXTRA_INTERFACE_CLASS_NAME =\n            \"org_mockito.mockito_core.ModuleHandlerInnerModuleSystemFoundExtraInterface\";\n    private static final String JAVAC_INJECTION_BASE_PREFIX =\n            \"com.sun.tools.javac.util.InjectionBase$\";\n    private static final int CLASS_FILE_MAGIC = 0xCAFEBABE;\n    private static final int JAVA_8_CLASS_FILE_VERSION = 52;\n    private static final int CONSTANT_POOL_SIZE = 5;\n    private static final int CONSTANT_CLASS = 7;\n    private static final int CONSTANT_UTF8 = 1;\n    private static final int PUBLIC_SUPER_CLASS = 0x0021;\n    private static final int PUBLIC_ABSTRACT_INTERFACE = 0x0601;\n\n    @Test\n    void createsSubclassMockForConcealedJdkCompilerType() throws Exception {\n        try {\n            Class<?> contextType = Class.forName(JAVAC_CONTEXT_CLASS_NAME);\n\n            Object mock =\n                    Mockito.mock(\n                            contextType,\n                            withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(contextType.isInstance(mock)).isTrue();\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return;\n            }\n            assertExpectedMockitoFailure(exception);\n        } catch (Error error) {\n            ignoreNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    void createsSubclassMockForConcealedTypeFromDynamicModule(@TempDir Path temporaryDirectory)\n            throws Exception {\n        try {\n            Class<?> moduleType = compileAndLoadConcealedModuleType(temporaryDirectory);\n\n            Object mock =\n                    Mockito.mock(\n                            moduleType,\n                            withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(moduleType.isInstance(mock)).isTrue();\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return;\n            }\n            assertExpectedMockitoFailure(exception);\n        } catch (Error error) {\n            ignoreNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    void createsSubclassMockWithExtraInterfaceFromIsolatedLoader() throws Exception {\n        try {\n            Class<?> contextType = Class.forName(JAVAC_CONTEXT_CLASS_NAME);\n            Class<?> extraInterface = loadExtraInterfaceWithIsolatedLoader();\n\n            Object mock =\n                    Mockito.mock(\n                            contextType,\n                            withSettings()\n                                    .mockMaker(MockMakers.SUBCLASS)\n                                    .extraInterfaces(extraInterface));\n\n            assertThat(contextType.isInstance(mock)).isTrue();\n            assertThat(extraInterface.isInstance(mock)).isTrue();\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return;\n            }\n            assertExpectedMockitoFailure(exception);\n        } catch (Error error) {\n            ignoreNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    private static void assertExpectedMockitoFailure(MockitoException exception) {\n        assertThat(exception.getMessage()).containsAnyOf(\"mock\", \"Mock\", \"module\", \"Mockito\");\n    }\n\n    private static Class<?> compileAndLoadConcealedModuleType(Path temporaryDirectory)\n            throws IOException, ClassNotFoundException {\n        Path sourceDirectory = temporaryDirectory.resolve(\"src\").resolve(DYNAMIC_MODULE_NAME);\n        Path packageDirectory = sourceDirectory.resolve(\"sample\").resolve(\"internal\");\n        Files.createDirectories(packageDirectory);\n        Path moduleInfo = sourceDirectory.resolve(\"module-info.java\");\n        Files.writeString(moduleInfo, \"module \" + DYNAMIC_MODULE_NAME + \" { }\\n\");\n        Path moduleType = packageDirectory.resolve(\"ModuleType.java\");\n        Files.writeString(\n                moduleType,\n                \"\"\"\n                package sample.internal;\n\n                public class ModuleType {\n                    public ModuleType() {\n                    }\n                }\n                \"\"\");\n\n        Path outputDirectory = temporaryDirectory.resolve(\"classes\");\n        Files.createDirectories(outputDirectory);\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\n        assertThat(compiler).isNotNull();\n        int exitCode =\n                compiler.run(\n                        null,\n                        null,\n                        null,\n                        \"-d\",\n                        outputDirectory.toString(),\n                        moduleInfo.toString(),\n                        moduleType.toString());\n        assertThat(exitCode).isZero();\n\n        ModuleLayer layer =\n                ModuleLayer.boot()\n                        .defineModulesWithOneLoader(\n                                ModuleLayer.boot()\n                                        .configuration()\n                                        .resolve(\n                                                ModuleFinder.of(outputDirectory),\n                                                ModuleFinder.of(),\n                                                Set.of(DYNAMIC_MODULE_NAME)),\n                                ClassLoader.getSystemClassLoader());\n        return layer.findLoader(DYNAMIC_MODULE_NAME).loadClass(DYNAMIC_MODULE_TYPE_NAME);\n    }\n\n    private static Class<?> loadExtraInterfaceWithIsolatedLoader() throws ClassNotFoundException {\n        ClassLoader parent = ModuleHandlerInnerModuleSystemFoundTest.class.getClassLoader();\n        ClassLoader loader = new IsolatedInterfaceLoader(parent);\n        return loader.loadClass(EXTRA_INTERFACE_CLASS_NAME);\n    }\n\n    private static void ignoreNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static class IsolatedInterfaceLoader extends ClassLoader {\n        IsolatedInterfaceLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (EXTRA_INTERFACE_CLASS_NAME.equals(name)\n                            || isInjectionBaseProbeName(name)) {\n                        loadedClass = findClass(name);\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            try {\n                if (EXTRA_INTERFACE_CLASS_NAME.equals(name)) {\n                    byte[] classBytes = minimalTypeBytes(name, PUBLIC_ABSTRACT_INTERFACE);\n                    return defineClass(name, classBytes, 0, classBytes.length);\n                } else if (isInjectionBaseProbeName(name)) {\n                    byte[] classBytes = minimalTypeBytes(name, PUBLIC_SUPER_CLASS);\n                    return defineClass(name, classBytes, 0, classBytes.length);\n                }\n                return super.findClass(name);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n\n        private static boolean isInjectionBaseProbeName(String name) {\n            int suffix = Math.abs(Mockito.class.hashCode());\n            return name.equals(JAVAC_INJECTION_BASE_PREFIX + suffix)\n                    || name.equals(JAVAC_INJECTION_BASE_PREFIX + 0);\n        }\n\n        private static byte[] minimalTypeBytes(String name, int access) throws IOException {\n            String internalName = name.replace('.', '/');\n            ByteArrayOutputStream output = new ByteArrayOutputStream();\n            DataOutputStream classFile = new DataOutputStream(output);\n            classFile.writeInt(CLASS_FILE_MAGIC);\n            classFile.writeShort(0);\n            classFile.writeShort(JAVA_8_CLASS_FILE_VERSION);\n            classFile.writeShort(CONSTANT_POOL_SIZE);\n            classFile.writeByte(CONSTANT_CLASS);\n            classFile.writeShort(2);\n            classFile.writeByte(CONSTANT_UTF8);\n            classFile.writeUTF(internalName);\n            classFile.writeByte(CONSTANT_CLASS);\n            classFile.writeShort(4);\n            classFile.writeByte(CONSTANT_UTF8);\n            classFile.writeUTF(\"java/lang/Object\");\n            classFile.writeShort(access);\n            classFile.writeShort(1);\n            classFile.writeShort(3);\n            classFile.writeShort(0);\n            classFile.writeShort(0);\n            classFile.writeShort(0);\n            classFile.writeShort(0);\n            classFile.flush();\n            return output.toByteArray();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778775181266}, {"role": "toolResult", "toolCallId": "call_nBOgoXxM4MTXnrb5ocdQa0D6|fc_0b2