  package org_mockito.mockito_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.exceptions.base.MockitoException;
  import org.mockito.internal.creation.MockSettingsImpl;
  import org.mockito.internal.creation.bytebuddy.InlineByteBuddyMockMaker;
  import org.mockito.internal.handler.MockHandlerFactory;
  import org.mockito.mock.MockCreationSettings;
  import org.mockito.plugins.MockMaker;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class StackWalkerCheckerTest {
      @Test
      void constructionMockChecksWhetherCallComesFromSubclassConstructor() {
          try {
              MockCreationSettings<ConstructedBase> settings =
                      new MockSettingsImpl<ConstructedBase>().build(ConstructedBase.class);
              InlineByteBuddyMockMaker mockMaker = new InlineByteBuddyMockMaker();
              MockMaker.ConstructionMockControl<ConstructedBase> control =
                      mockMaker.createConstructionMock(
                              ConstructedBase.class,
                              context -> settings,
                              context -> MockHandlerFactory.createMockHandler(settings),
                              (mock, context) -> {});
  
              control.enable();
              try {
                  ConstructedBase directConstruction = new ConstructedBase("direct");
                  assertThat(control.getMocks()).containsExactly(directConstruction);
  
                  ConstructedSubclass subclassConstruction = new ConstructedSubclass();
                  assertThat(subclassConstruction.createdByRealConstructor()).isTrue();
                  assertThat(control.getMocks()).containsExactly(directConstruction);
              } finally {
                  control.disable();
              }
          } catch (MockitoException exception) {
              if (hasUnsupportedFeatureErrorCause(exception)) {
                  return;
              }
              throw exception;
          } catch (Error error) {
              ignoreNativeImageUnsupportedFeature(error);
          }
      }
  
      private static void ignoreNativeImageUnsupportedFeature(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public static class ConstructedBase {
          private final String name;
  
          public ConstructedBase(String name) {
              this.name = name;
          }
  
          public String name() {
              return name;
          }
      }
  
      public static class ConstructedSubclass extends ConstructedBase {
          private final boolean createdByRealConstructor;
  
          public ConstructedSubclass() {
              super("subclass");
              this.createdByRealConstructor = true;
          }
  
          public boolean createdByRealConstructor() {
              return createdByRealConstructor;
          }
