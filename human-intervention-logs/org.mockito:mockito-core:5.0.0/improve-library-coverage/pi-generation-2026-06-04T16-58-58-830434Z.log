 Optional<String> optional();\n\n        OptionalDouble optionalDouble();\n\n        OptionalInt optionalInt();\n\n        OptionalLong optionalLong();\n\n        Stream<String> stream();\n\n        DoubleStream doubleStream();\n\n        IntStream intStream();\n\n        LongStream longStream();\n\n        Duration duration();\n\n        Period period();\n    }\n}\n"}
