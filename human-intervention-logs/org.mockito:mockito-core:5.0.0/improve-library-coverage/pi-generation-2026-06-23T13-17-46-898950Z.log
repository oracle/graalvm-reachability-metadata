  package org_mockito.mockito_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.MockMakers;
  import org.mockito.Mockito;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InlineDelegateByteBuddyMockMakerTest {
      @Test
      void inlineMockMakerCreatesAndStubsAnInterfaceMock() {
          String previousExperimentalSetting =
                  System.setProperty("net.bytebuddy.experimental", "true");
          try {
              GreetingService service = Mockito.mock(
                      GreetingService.class,
                      Mockito.withSettings().mockMaker(MockMakers.INLINE));
              Mockito.when(service.greeting("Mockito")).thenReturn("Hello Mockito");
  
              assertThat(service.greeting("Mockito")).isEqualTo("Hello Mockito");
              assertThat(Mockito.mockingDetails(service).isMock()).isTrue();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              Mockito.framework().clearInlineMocks();
              restoreSystemProperty("net.bytebuddy.experimental", previousExperimentalSetting);
          }
      }
  
      private static void restoreSystemProperty(String key, String value) {
          if (value == null) {
              System.clearProperty(key);
          } else {
              System.setProperty(key, value);
          }
      }
  
      interface GreetingService {
          String greeting(String name);
      }
  }
