  package org_mockito.mockito_core;
  
  import java.io.File;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.file.Path;
  import java.util.Arrays;
  import java.util.function.Supplier;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.mockito.MockMakers;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InlineDelegateByteBuddyMockMakerTest {
      @Test
      void inlineMockMakerCreatesAndStubsAnInterfaceMock() throws Exception {
          try (ChildFirstLibraryClassLoader classLoader =
                  new ChildFirstLibraryClassLoader(testClasspathUrls())) {
              Class<?> mockito = classLoader.loadClass("org.mockito.Mockito");
              Class<?> ongoingStubbing = classLoader.loadClass("org.mockito.stubbing.OngoingStubbing");
              Supplier<?> supplier = (Supplier<?>) createInlineMock(mockito, Supplier.class);
  
              Object stubbing = mockito.getMethod("when", Object.class).invoke(null, supplier.get());
              ongoingStubbing.getMethod("thenReturn", Object.class).invoke(stubbing, "Hello Mockito");
  
              assertThat(supplier.get()).isEqualTo("Hello Mockito");
              assertThat(isMock(mockito, supplier)).isTrue();
              clearInlineMocks(mockito);
          } catch (InvocationTargetException exception) {
              rethrowUnlessUnsupportedFeatureError(exception.getCause());
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void inlineMockMakerReportsInitializationFailureWhenDispatcherJarCannotBeCreated(
              @TempDir Path temporaryDirectory) throws Exception {
          String previousTemporaryDirectory = System.getProperty("java.io.tmpdir");
          System.setProperty("java.io.tmpdir", temporaryDirectory.resolve("missing").toString());
          try (ChildFirstLibraryClassLoader classLoader =
                  new ChildFirstLibraryClassLoader(testClasspathUrls())) {
              Class<?> mockito = classLoader.loadClass("org.mockito.Mockito");
  
              try {
                  createInlineMock(mockito, Runnable.class);
              } catch (InvocationTargetException exception) {
                  Throwable cause = exception.getCause();
                  if (cause instanceof Error error
                          && NativeImageSupport.isUnsupportedFeatureError(error)) {
                      return;
                  }
                  assertThat(cause)
                          .isInstanceOf(RuntimeException.class)
                          .hasMessageContaining("Could not initialize inline Byte Buddy mock maker");
                  return;
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
              return;
          } finally {
              restoreSystemProperty("java.io.tmpdir", previousTemporaryDirectory);
          }
          throw new AssertionError("Expected inline mock maker initialization to fail");
      }
  
      private static Object createInlineMock(Class<?> mockito, Class<?> typeToMock) throws Exception {
