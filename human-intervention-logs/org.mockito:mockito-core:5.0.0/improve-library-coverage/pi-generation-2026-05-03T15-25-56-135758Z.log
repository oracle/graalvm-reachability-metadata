[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ForwardsInvocationsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.AdditionalAnswers;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.mock;\nimport static org.mockito.Mockito.withSettings;\n\npublic class ForwardsInvocationsTest {\n    @Test\n    void delegatesMockInvocationToObjectWithMatchingMethod() {\n        Delegate delegate = new Delegate();\n        ForwardedService service = mock(\n                ForwardedService.class, withSettings().defaultAnswer(AdditionalAnswers.delegatesTo(delegate)));\n\n        assertThat(service.join(\"a\", \"b\")).isEqualTo(\"a:b\");\n    }\n\n    public interface ForwardedService {\n        String join(String first, String second);\n    }\n\n    public static final class Delegate {\n        public String join(String first, String second) {\n            return first + \":\" + second;\n        }\n    }\n}\n"}
