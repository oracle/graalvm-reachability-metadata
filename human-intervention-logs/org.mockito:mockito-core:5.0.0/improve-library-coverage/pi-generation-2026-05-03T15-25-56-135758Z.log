  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.AdditionalAnswers;
  import org.mockito.stubbing.Answer2;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.when;
  
  public class AnswerFunctionalInterfacesTest {
      @Test
      void adaptsStronglyTypedAnswerFunctionalInterface() {
          Calculator calculator = mock(Calculator.class);
          when(calculator.add(2, 3)).thenAnswer(AdditionalAnswers.answer(new SumAnswer()));
  
          assertThat(calculator.add(2, 3)).isEqualTo(5);
      }
  
      public interface Calculator {
          int add(int left, int right);
      }
  
      public static final class SumAnswer implements Answer2<Integer, Integer, Integer> {
          @Override
          public Integer answer(Integer left, Integer right) {
              return left + right;
          }
