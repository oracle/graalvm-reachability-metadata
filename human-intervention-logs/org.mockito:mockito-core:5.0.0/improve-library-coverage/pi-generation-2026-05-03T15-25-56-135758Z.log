[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/JavaEightUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.internal.util.JavaEightUtil;\n\nimport java.time.Duration;\nimport java.time.Period;\nimport java.util.Optional;\nimport java.util.OptionalDouble;\nimport java.util.OptionalInt;\nimport java.util.OptionalLong;\nimport java.util.stream.DoubleStream;\nimport java.util.stream.IntStream;\nimport java.util.stream.LongStream;\nimport java.util.stream.Stream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JavaEightUtilTest {\n    @Test\n    void createsJavaEightEmptyValuesThroughMockitoUtility() {\n        assertThat(JavaEightUtil.emptyOptional()).isEqualTo(Optional.empty());\n        assertThat(JavaEightUtil.emptyOptionalDouble()).isEqualTo(OptionalDouble.empty());\n        assertThat(JavaEightUtil.emptyOptionalInt()).isEqualTo(OptionalInt.empty());\n        assertThat(JavaEightUtil.emptyOptionalLong()).isEqualTo(OptionalLong.empty());\n        assertThat(JavaEightUtil.emptyDuration()).isEqualTo(Duration.ZERO);\n        assertThat(JavaEightUtil.emptyPeriod()).isEqualTo(Period.ZERO);\n\n        assertThat((Stream<?>) JavaEightUtil.emptyStream()).isEmpty();\n        assertThat(((DoubleStream) JavaEightUtil.emptyDoubleStream()).count()).isZero();\n        assertThat(((IntStream) JavaEightUtil.emptyIntStream()).count()).isZero();\n        assertThat(((LongStream) JavaEightUtil.emptyLongStream()).count()).isZero();\n    }\n}\n"}
