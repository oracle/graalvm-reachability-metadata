[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/SerializableMethodTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.internal.invocation.SerializableMethod;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SerializableMethodTest {\n    @Test\n    void resolvesJavaMethodAfterSerializationRoundTrip() throws Exception {\n        Method method = MethodCarrier.class.getDeclaredMethod(\"join\", String.class);\n        SerializableMethod serializableMethod = new SerializableMethod(method);\n\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(serializableMethod);\n        }\n\n        SerializableMethod restored;\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            restored = (SerializableMethod) input.readObject();\n        }\n\n        assertThat(restored.getJavaMethod().getName()).isEqualTo(\"join\");\n    }\n\n    public static final class MethodCarrier {\n        private String join(String value) {\n            return value;\n        }\n    }\n}\n"}
