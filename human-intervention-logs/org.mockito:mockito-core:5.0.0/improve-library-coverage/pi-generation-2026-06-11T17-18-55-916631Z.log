[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockMakers;\nimport org.mockito.Mockito;\n\nimport java.io.IOException;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Base64;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ModuleHandlerInnerModuleSystemFoundTest {\n    private static final String MODULE_NAME = \"mockito.fixture\";\n    private static final String HIDDEN_TYPE_NAME = \"fixture.hidden.HiddenType\";\n    private static final String MODULE_INFO_CLASS =\n            \"yv66vgAAAEEACwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZv\"\n                    + \"LmphdmEBAAZNb2R1bGUTAAcBAA9tb2NraXRvLmZpeHR1cmUTAAkBAAlqYXZhLmJh\"\n                    + \"c2UBAAIyMYAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAABYABgAAAAAAAQAIgAAA\"\n                    + \"CgAAAAAAAAAA\";\n    private static final String HIDDEN_TYPE_CLASS =\n            \"yv66vgAAAEEAEQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+\"\n                    + \"AQADKClWCAAIAQAEcmVhbAcACgEAGWZpeHR1cmUvaGlkZGVuL0hpZGRlblR5cGUB\"\n                    + \"AARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAHbWVzc2FnZQEAFCgpTGphdmEvbGFu\"\n                    + \"Zy9TdHJpbmc7AQAKU291cmNlRmlsZQEAD0hpZGRlblR5cGUuamF2YQAhAAkAAgAA\"\n                    + \"AAAAAgABAAUABgABAAsAAAAdAAEAAQAAAAUqtwABsQAAAAEADAAAAAYAAQAAAA\"\n                    + \"MAAQANAA4AAQALAAAAGwABAAEAAAADEgewAAAAAQAMAAAABgABAAAABQABAA8A\"\n                    + \"AAACABA=\";\n\n    @Test\n    void subclassMockMakerMocksClassFromNonExportedIsolatedNamedModule() throws Exception {\n        try {\n            Class<?> hiddenType = loadHiddenTypeFromIsolatedNamedModule();\n\n            Object mock = Mockito.mock(hiddenType, Mockito.withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(mock).isInstanceOf(hiddenType);\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Class<?> loadHiddenTypeFromIsolatedNamedModule() throws IOException, ClassNotFoundException {\n        Path modulePath = Files.createTempDirectory(\"mockito-module-fixture\");\n        Path moduleRoot = modulePath.resolve(MODULE_NAME);\n        Path packageRoot = moduleRoot.resolve(\"fixture\").resolve(\"hidden\");\n        Files.createDirectories(packageRoot);\n        Files.write(moduleRoot.resolve(\"module-info.class\"), Base64.getDecoder().decode(MODULE_INFO_CLASS));\n        Files.write(packageRoot.resolve(\"HiddenType.class\"), Base64.getDecoder().decode(HIDDEN_TYPE_CLASS));\n\n        ModuleFinder finder = ModuleFinder.of(modulePath);\n        Configuration configuration =\n                ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(MODULE_NAME));\n        ModuleLayer layer = ModuleLayer.boot().defineModulesWithOneLoader(configuration, null);\n        return layer.findLoader(MODULE_NAME).loadClass(HIDDEN_TYPE_NAME);\n    }\n}\n"}
