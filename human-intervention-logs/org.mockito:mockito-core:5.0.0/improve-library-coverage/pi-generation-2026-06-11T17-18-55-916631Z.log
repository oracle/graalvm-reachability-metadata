          \"yv66vgAAAEEAEQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+\"\n                    + \"AQADKClWCAAIAQAEcmVhbAcACgEAGWZpeHR1cmUvb3BlbmVkL09wZW5lZFR5cGUB\"\n                    + \"AARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAHbWVzc2FnZQEAFCgpTGphdmEvbGFu\"\n                    + \"Zy9TdHJpbmc7AQAKU291cmNlRmlsZQEAD09wZW5lZFR5cGUuamF2YQAhAAkAAgAA\"\n                    + \"AAAAAgABAAUABgABAAsAAAAdAAEAAQAAAAUqtwABsQAAAAEADAAAAAYAAQAAAA\"\n                    + \"MAAQANAA4AAQALAAAAGwABAAEAAAADEgewAAAAAQAMAAAABgABAAAABQABAA8A\"\n                    + \"AAACABA=\";\n\n    @Test\n    void subclassMockMakerCreatesInterfaceMockThroughByteBuddyModuleHandler() {\n        try {\n            @SuppressWarnings(\"unchecked\")\n            List<String> names =\n                    Mockito.mock(List.class, Mockito.withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            Mockito.when(names.get(0)).thenReturn(\"mockito\");\n\n            assertThat(names.get(0)).isEqualTo(\"mockito\");\n            Mockito.verify(names).get(0);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void subclassMockMakerMocksClassFromOpenedNamedModule() throws Exception {\n        try {\n            Class<?> openedType = loadOpenedTypeFromNamedModule();\n\n            Object mock =\n                    Mockito.mock(openedType, Mockito.withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(mock).isInstanceOf(openedType);\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Class<?> loadOpenedTypeFromNamedModule() throws IOException, ClassNotFoundException {\n        Path modulePath = Files.createTempDirectory(\"mockito-module-fixture\");\n        Path moduleRoot = modulePath.resolve(MODULE_NAME);\n        Path packageRoot = moduleRoot.resolve(\"fixture\").resolve(\"opened\");\n        Files.createDirectories(packageRoot);\n        Files.write(\n                moduleRoot.resolve(\"module-info.class\"),\n                Base64.getDecoder().decode(MODULE_INFO_CLASS));\n        Files.write(\n                packageRoot.resolve(\"OpenedType.class\"),\n                Base64.getDecoder().decode(OPENED_TYPE_CLASS));\n\n        ModuleFinder finder = ModuleFinder.of(modulePath);\n        Configuration configuration =\n                ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(MODULE_NAME));\n        ModuleLayer layer =\n                ModuleLayer.boot()\n                        .defineModulesWithOneLoader(\n                                configuration, ClassLoader.getSystemClassLoader());\n        return layer.findLoader(MODULE_NAME).loadClass(OPENED_TYPE_NAME);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2963, "output": 1407, "cacheRead": 40960, "cacheWrite": 0, "totalTokens": 45330, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781198820719, "responseId": "resp_060b9a2a5f3480d0016a2aefe5ecbc8196b1e9dfcd8c06097e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_x8UMHRhAlWHKEkyRbQEVd6qN|fc_060b9a2a5f3480d0016a2aefee6bd88196919055de44d5137b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4264 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java"}], "isError": false, "timestamp": 1781198843486}]}
