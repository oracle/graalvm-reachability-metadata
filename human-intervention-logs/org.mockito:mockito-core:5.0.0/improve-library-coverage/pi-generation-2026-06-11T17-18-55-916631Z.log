[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java","edits":[{"oldText":"    private static final String OPENED_TYPE_NAME = \"fixture.opened.OpenedType\";\n    private static final String MODULE_INFO_CLASS =\n            \"yv66vgAAAEEADQcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZv\"\n                    + \"LmphdmEBAAZNb2R1bGUTAAcBAA9tb2NraXRvLmZpeHR1cmUTAAkBAAlqYXZhLmJh\"\n                    + \"c2UBAAIyMRQADAEADmZpeHR1cmUvb3BlbmVkgAAAAQAAAAAAAAAAAAIAAwAAAAIA\"\n                    + \"BAAFAAAAHAAGACAAAAABAAiAAAAKAAEACwAAAAAAAAAAAAA=\";\n    private static final String OPENED_TYPE_CLASS =\n            \"yv66vgAAAEEAEQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+\"\n                    + \"AQADKClWCAAIAQAEcmVhbAcACgEAGWZpeHR1cmUvb3BlbmVkL09wZW5lZFR5cGUB\"\n                    + \"AARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAHbWVzc2FnZQEAFCgpTGphdmEvbGFu\"\n                    + \"Zy9TdHJpbmc7AQAKU291cmNlRmlsZQEAD09wZW5lZFR5cGUuamF2YQAhAAkAAgAA\"\n                    + \"AAAAAgABAAUABgABAAsAAAAdAAEAAQAAAAUqtwABsQAAAAEADAAAAAYAAQAAAA\"\n                    + \"MAAQANAA4AAQALAAAAGwABAAEAAAADEgewAAAAAQAMAAAABgABAAAABQABAA8A\"\n                    + \"AAACABA=\";","newText":"    private static final String HIDDEN_TYPE_NAME = \"fixture.hidden.HiddenType\";\n    private static final String MODULE_INFO_CLASS =\n            \"yv66vgAAAEEACwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZv\"\n                    + \"LmphdmEBAAZNb2R1bGUTAAcBAA9tb2NraXRvLmZpeHR1cmUTAAkBAAlqYXZhLmJh\"\n                    + \"c2UBAAIyMYAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAABYABgAAAAAAAQAIgAAA\"\n                    + \"CgAAAAAAAAAA\";\n    private static final String HIDDEN_TYPE_CLASS =\n            \"yv66vgAAAEEAEQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+\"\n                    + \"AQADKClWCAAIAQAEcmVhbAcACgEAGWZpeHR1cmUvaGlkZGVuL0hpZGRlblR5cGUB\"\n                    + \"AARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAHbWVzc2FnZQEAFCgpTGphdmEvbGFu\"\n                    + \"Zy9TdHJpbmc7AQAKU291cmNlRmlsZQEAD0hpZGRlblR5cGUuamF2YQAhAAkAAgAA\"\n                    + \"AAAAAgABAAUABgABAAsAAAAdAAEAAQAAAAUqtwABsQAAAAEADAAAAAYAAQAAAA\"\n                    + \"MAAQANAA4AAQALAAAAGwABAAEAAAADEgewAAAAAQAMAAAABgABAAAABQABAA8A\"\n                    + \"AAACABA=\";"},{"oldText":"    void subclassMockMakerMocksClassFromOpenedNamedModule() throws Exception {\n        try {\n            Class<?> openedType = loadOpenedTypeFromNamedModule();\n\n            Object mock =\n                    Mockito.mock(openedType, Mockito.withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(mock).isInstanceOf(openedType);\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Class<?> loadOpenedTypeFromNamedModule()\n            throws IOException, ClassNotFoundException {\n        Path modulePath = Files.createTempDirectory(\"mockito-module-fixture\");\n        Path moduleRoot = modulePath.resolve(MODULE_NAME);\n        Path packageRoot = moduleRoot.resolve(\"fixture\").resolve(\"opened\");\n        Files.createDirectories(packageRoot);\n        Files.write(\n                moduleRoot.resolve(\"module-info.class\"),\n                Base64.getDecoder().decode(MODULE_INFO_CLASS));\n        Files.write(\n                packageRoot.resolve(\"OpenedType.class\"),\n                Base64.getDecoder().decode(OPENED_TYPE_CLASS));\n\n        ModuleFinder finder = ModuleFinder.of(modulePath);\n        Configuration configuration =\n                ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(MODULE_NAME));\n        ModuleLayer layer =\n                ModuleLayer.boot()\n                        .defineModulesWithOneLoader(\n                                configuration, ClassLoader.getSystemClassLoader());\n        return layer.findLoader(MODULE_NAME).loadClass(OPENED_TYPE_NAME);\n    }","newText":"    void subclassMockMakerMocksClassFromNonExportedNamedModule() throws Exception {\n        try {\n            Class<?> hiddenType = loadHiddenTypeFromNamedModule();\n\n            Object mock =\n                    Mockito.mock(hiddenType, Mockito.withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(mock).isInstanceOf(hiddenType);\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Class<?> loadHiddenTypeFromNamedModule()\n            throws IOException, ClassNotFoundException {\n        Path modulePath = Files.createTempDirectory(\"mockito-module-fixture\");\n        Path moduleRoot = modulePath.resolve(MODULE_NAME);\n        Path packageRoot = moduleRoot.resolve(\"fixture\").resolve(\"hidden\");\n        Files.createDirectories(packageRoot);\n        Files.write(\n                moduleRoot.resolve(\"module-info.class\"),\n                Base64.getDecoder().decode(MODULE_INFO_CLASS));\n        Files.write(\n                packageRoot.resolve(\"HiddenType.class\"),\n                Base64.getDecoder().decode(HIDDEN_TYPE_CLASS));\n\n        ModuleFinder finder = ModuleFinder.of(modulePath);\n        Configuration configuration =\n                ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(MODULE_NAME));\n        ModuleLayer layer =\n                ModuleLayer.boot()\n                        .defineModulesWithOneLoader(\n                                configuration, ClassLoader.getSystemClassLoader());\n        retu