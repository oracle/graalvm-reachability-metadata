          assertThat(method.invoke(null)).isEqualTo(\"mocked construction\");\n        } catch (InvocationTargetException exception) {\n            rethrowUnlessUnsupportedFeatureError(exception.getCause());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            currentThread.setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    public static String exerciseConstructionMockWithInlineMockMaker() {\n        try (MockedConstruction<ConstructedGreeting> mockedConstruction =\n                Mockito.mockConstruction(\n                        ConstructedGreeting.class,\n                        (mock, context) -> {\n                            Constructor<?> constructor = context.constructor();\n\n                            verifyConstructionContext(context, constructor);\n                            when(mock.message()).thenReturn(\"mocked construction\");\n                        })) {\n            ConstructedGreeting greeting =\n                    new ConstructedGreeting(\"Mockito\", 5, new GreetingFormat(\"Hello\"));\n\n            if (!\"mocked construction\".equals(greeting.message())) {\n                throw new AssertionError(\"Constructed mock did not use the configured answer\");\n            }\n            if (!mockedConstruction.constructed().equals(List.of(greeting))) {\n                throw new AssertionError(\"Constructed mocks were not recorded\");\n            }\n            return greeting.message();\n        }\n    }\n\n    private static void verifyConstructionContext(\n            MockedConstruction.Context context, Constructor<?> constructor) {\n        if (context.getCount() != 1) {\n            throw new AssertionError(\"Unexpected construction count: \" + context.getCount());\n        }\n        if (!context.arguments().equals(List.of(\"Mockito\", 5, new GreetingFormat(\"Hello\")))) {\n            throw new AssertionError(\"Unexpected construction arguments: \" + context.arguments());\n        }\n        if (constructor.getDeclaringClass() != ConstructedGreeting.class) {\n            throw new AssertionError(\"Unexpected constructor declaring class: \" + constructor);\n        }\n        if (!Arrays.equals(\n                constructor.getParameterTypes(),\n                new Class<?>[] {String.class, int.class, GreetingFormat.class})) {\n            throw new AssertionError(\n                    \"Unexpected constructor parameter types: \"\n                            + Arrays.toString(constructor.getParameterTypes()));\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Throwable throwable) {\n        if (throwable instanceof Error error\n                && NativeImageSupport.isUnsupportedFeatureError(error)) {\n            return;\n        }\n        if (throwable instanceof RuntimeException runtimeException) {\n            throw runtimeException;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n        throw new AssertionError(throwable);\n    }\n\n    private static URL[] testClasspathUrls() {\n        return Arrays.stream(System.getProperty(\"java.class.path\", \"\").split(File.pathSeparator))\n                .filter(entry -> !entry.isEmpty())\n                .map(File::new)\n                .map(File::toURI)\n                .map(uri -> {\n                    try {\n                        return uri.toURL();\n                    } catch (Exception exception) {\n                        throw new IllegalStateException(exception);\n                    }\n                })\n                .toArray(URL[]::new);\n    }\n\n    public static class ConstructedGreeting {\n        private final String name;\n        private final int repeats;\n        private final GreetingFormat format;\n\n        public ConstructedGreeting(String name, int repeats, GreetingFormat format) {\n            this.name = name;\n            this.repeats = repeats;\n            this.format = format;\n        }\n\n        public String message() {\n            return format.prefix() + \" \" + name + \" \".repeat(repeats).trim();\n        }\n    }\n\n    public record GreetingFormat(String prefix) {}\n\n    private static class InlineMockMakerClassLoader extends URLClassLoader {\n        InlineMockMakerClassLoader(URL[] urls) {\n            super(urls, ClassLoader.getPlatformClassLoader());\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\n                return null;\n            }\n            return super.getResource(name);\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) throws IOException {\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\n                return Collections.emptyEnumeration();\n            }\n            return super.getResources(name);\n        }\n\n        @Override\n        public InputStream getResourceAsStream(String name) {\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\n                return null;\n            }\n            return super.getResourceAsStream(name);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (isChildLoadedClass(name)) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loaded = findLoadedClass(name);\n                    if (loaded == null) {\n                        try {\n                            loaded = findClass(name);\n                        } catch (ClassNotFoundException ignored) {\n                            loaded = super.loadClass(name, false);\n                        }\n                    }\n                    if (resolve) {\n                        resolveClass(loaded);\n                    }\n                    return loaded;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private static boolean isChildLoadedClass(String name) {\n            return name.startsWith(\"org.mockito.\")\n                    || name.startsWith(\"net.bytebuddy.\")\n                    || name.startsWith(\"org.objenesis.\")\n                    || name.startsWith(\n                            \"org_mockito.mockito_core.\"\n                                    + \"InlineDelegateByteBuddyMockMakerInner\"\n                                    + \"InlineConstructionMockContextTest\");\n        }\n    }\n}\n"}
