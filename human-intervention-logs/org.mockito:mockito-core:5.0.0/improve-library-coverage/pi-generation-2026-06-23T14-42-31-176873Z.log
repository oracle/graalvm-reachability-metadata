ved via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport java.lang.reflect.Constructor;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockedConstruction;\nimport org.mockito.Mockito;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.when;\n\npublic class InlineDelegateByteBuddyMockMakerInnerInlineConstructionMockContextTest {\n    @Test\n    void constructionMockContextResolvesTheInvokedConstructor() {\n        try {\n            try (MockedConstruction<ConstructedGreeting> mockedConstruction =\n                    Mockito.mockConstruction(\n                            ConstructedGreeting.class,\n                            (mock, context) -> {\n                                Constructor<?> constructor = context.constructor();\n\n                                assertThat(context.getCount()).isEqualTo(1);\n                                assertThat(context.arguments())\n                                        .containsExactly(\"Mockito\", 5, new GreetingFormat(\"Hello\"));\n                                assertThat(constructor.getDeclaringClass())\n                                        .isEqualTo(ConstructedGreeting.class);\n                                assertThat(constructor.getParameterTypes())\n                                        .containsExactly(String.class, int.class, GreetingFormat.class);\n                                when(mock.message()).thenReturn(\"mocked construction\");\n                            })) {\n                ConstructedGreeting greeting =\n                        new ConstructedGreeting(\"Mockito\", 5, new GreetingFormat(\"Hello\"));\n\n                assertThat(greeting.message()).isEqualTo(\"mocked construction\");\n                assertThat(mockedConstruction.constructed()).containsExactly(greeting);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public static class ConstructedGreeting {\n        private final String name;\n        private final int repeats;\n        private final GreetingFormat format;\n\n        public ConstructedGreeting(String name, int repeats, GreetingFormat format) {\n            this.name = name;\n            this.repeats = repeats;\n            this.format = format;\n        }\n\n        public String message() {\n            return format.prefix() + \" \" + name + \" \".repeat(repeats).trim();\n        }\n    }\n\n    public record GreetingFormat(String prefix) {}\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 10033, "output": 833, "cacheRead": 18432, "cacheWrite": 0, "totalTokens": 29298, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782225710189, "responseId": "resp_086a393d1c3bd8e5016a3a9b2f269c8193bcfe2ef7bbd75772"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_GvS4UdzJ3X04howYG7j3C8zJ|fc_086a393d1c3bd8e5016a3a9b35afac8193ba39c415888922fc", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2748 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InlineDelegateByteBuddyMockMakerInnerInlineConstructionMockContextTest.java"}], "isError": false, "timestamp": 1782225722165}]}
