      @Test
      void constructionMockContextResolvesTheInvokedConstructor() {
          try {
              try (MockedConstruction<ConstructedGreeting> mockedConstruction =
                      Mockito.mockConstruction(
                              ConstructedGreeting.class,
                              (mock, context) -> {
                                  Constructor<?> constructor = context.constructor();
  
                                  assertThat(context.getCount()).isEqualTo(1);
                                  assertThat(context.arguments())
                                          .containsExactly("Mockito", 5, new GreetingFormat("Hello"));
                                  assertThat(constructor.getDeclaringClass())
                                          .isEqualTo(ConstructedGreeting.class);
                                  assertThat(constructor.getParameterTypes())
                                          .containsExactly(
                                                  String.class, int.class, GreetingFormat.class);
                                  when(mock.message()).thenReturn("mocked construction");
                              })) {
                  ConstructedGreeting greeting =
                          new ConstructedGreeting("Mockito", 5, new GreetingFormat("Hello"));
  
                  assertThat(greeting.message()).isEqualTo("mocked construction");
                  assertThat(mockedConstruction.constructed()).containsExactly(greeting);
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
  
