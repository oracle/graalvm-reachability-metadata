              MockName name = MockUtil.getMockName(mock);
              if (name.isDefault()) {
                  return "Mock for "
                          + MockUtil.getMockSettings(mock).getTypeToMock().getSimpleName()
                          + ", hashCode: "
                          + mock.hashCode();
              } else {
