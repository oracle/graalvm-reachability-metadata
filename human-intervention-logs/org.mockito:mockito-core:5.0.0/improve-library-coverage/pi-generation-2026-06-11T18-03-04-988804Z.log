ssertions.assertThat;\n\npublic class InstrumentationMemberAccessorTest {\n    @Test\n    void defaultMemberAccessorCreatesInvokesReadsAndWritesMembers() throws Exception {\n        MemberAccessor memberAccessor =\n                Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        Constructor<AccessorTarget> constructor =\n                AccessorTarget.class.getDeclaredConstructor(String.class);\n        Method greeting = AccessorTarget.class.getDeclaredMethod(\"greeting\", String.class);\n        Field value = AccessorTarget.class.getDeclaredField(\"value\");\n\n        AccessorTarget target = (AccessorTarget) memberAccessor.newInstance(constructor, \"initial\");\n        assertThat(memberAccessor.get(value, target)).isEqualTo(\"initial\");\n\n        memberAccessor.set(value, target, \"updated\");\n\n        assertThat(memberAccessor.invoke(greeting, target, \"hello\")).isEqualTo(\"hello updated\");\n    }\n\n    public static class AccessorTarget {\n        private String value;\n\n        public AccessorTarget(String value) {\n            this.value = value;\n        }\n\n        private String greeting(String prefix) {\n            return prefix + \" \" + value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781200477465}, {"role": "toolResult", "toolCallId": "call_eS9VirHgjhyHcsF7qkH6Fz5Y|fc_0698b193315208ba016a2af65d18548196be2ae75c5470f6e8", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockMakers;\nimport org.mockito.Mockito;\n\nimport java.io.IOException;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Base64;\nimport java.util.List;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ModuleHandlerInnerModuleSystemFoundTest {\n    private static final String MODULE_NAME = \"mockito.fixture\";\n    private static final String HIDDEN_TYPE_NAME = \"fixture.hidden.HiddenType\";\n    private static final String MODULE_INFO_CLASS =\n            \"yv66vgAAAEEACwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZv\"\n                    + \"LmphdmEBAAZNb2R1bGUTAAcBAA9tb2NraXRvLmZpeHR1cmUTAAkBAAlqYXZhLmJh\"\n                    + \"c2UBAAIyMYAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAABYABgAAAAAAAQAIgAAA\"\n                    + \"CgAAAAAAAAAA\";\n    private static final String HIDDEN_TYPE_CLASS =\n            \"yv66vgAAAEEAEQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+\"\n                    + \"AQADKClWCAAIAQAEcmVhbAcACgEAGWZpeHR1cmUvaGlkZGVuL0hpZGRlblR5cGUB\"\n                    + \"AARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAHbWVzc2FnZQEAFCgpTGphdmEvbGFu\"\n                    + \"Zy9TdHJpbmc7AQAKU291cmNlRmlsZQEAD0hpZGRlblR5cGUuamF2YQAhAAkAAgAA\"\n                    + \"AAAAAgABAAUABgABAAsAAAAdAAEAAQAAAAUqtwABsQAAAAEADAAAAAYAAQAAAA\"\n                    + \"MAAQANAA4AAQALAAAAGwABAAEAAAADEgewAAAAAQAMAAAABgABAAAABQABAA8A\"\n                    + \"AAACABA=\";\n\n    @Test\n    void subclassMockMakerCreatesInterfaceMockThroughByteBuddyModuleHandler() {\n        try {\n            @SuppressWarnings(\"unchecked\")\n            List<String> names =\n                    Mockito.mock(List.class, Mockito.withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            Mockito.when(names.get(0)).thenReturn(\"mockito\");\n\n            assertThat(names.get(0)).isEqualTo(\"mockito\");\n            Mockito.verify(names).get(0);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void subclassMockMakerMocksClassFromNonExportedNamedModule() throws Exception {\n        try {\n            Class<?> hiddenType = loadHiddenTypeFromNamedModule();\n\n            Object mock =\n                    Mockito.mock(hiddenType, Mockito.withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(mock).isInstanceOf(hiddenType);\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static Class<?> loadHiddenTypeFromNamedModule()\n            throws IOException, ClassNotFoundException {\n        Path modulePath = Files.createTempDirectory(\"mockito-module-fixture\");\n        Path moduleRoot = modulePath.resolve(MODULE_NAME);\n        Path packageRoot = moduleRoot.resolve(\"fixture\").resolve(\"hidden\");\n        Files.createDirectories(packageRoot);\n        Files.write(\n                moduleRoot.resolve(\"module-info.class\"),\n                Base64.getDecoder().decode(MODULE_INFO_CLASS));\n        Files.write(\n                packageRoot.resolve(\"HiddenType.class\"),\n                Base64.getDecoder().decode(HIDDEN_TYPE_CLASS));\n\n        ModuleFinder finder = ModuleFinder.of(modulePath);\n        Configuration configuration =\n                ModuleLayer.boot()\n                        .configuration()\n                        .resolve(finder, ModuleFinder.of(), Set.of(MODULE_NAME));\n        ModuleLayer layer =\n                ModuleLayer.boot()\n                        .defineModulesWithOneLoader(\n                                configuration, ClassLoader.getSystemClassLoader());\n        return layer.findLoader(MODULE_NAME).loadClass(HIDDEN_TYPE_NAME);\n    }\n}\n"}], "isError": false, "timestamp": 1781200477465}, {"role": "toolResult", "toolCallId": "call_ataBV7ySjIXQdqXFit3EK3oJ|fc_0698b193315208b