ate static <T> MockCreationSettings<T> mockCreationSettings(Class<T> type) {\n        MockSettingsImpl<T> settings = (MockSettingsImpl<T>) Mockito.withSettings();\n        return settings.build(type);\n    }\n\n    static class ConstructedService {\n        private final String name;\n\n        ConstructedService(String name) {\n            this.name = \"real:\" + name;\n        }\n\n        String name() {\n            return name;\n        }\n    }\n\n    static final class ChildService extends ConstructedService {\n        ChildService(String name) {\n            super(name);\n        }\n\n        String childName() {\n            return \"child:\" + name();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781274334565}}
