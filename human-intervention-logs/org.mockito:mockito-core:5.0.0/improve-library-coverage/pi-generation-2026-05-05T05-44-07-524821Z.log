  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.MockitoAnnotations;
  import org.mockito.Spy;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class SpyAnnotationEngineTest {
      @Spy private ConstructorRequiredService service;
  
      @Test
      void openMocksReportsUnassignedSpyWithoutNoArgConstructor() {
          assertThatThrownBy(() -> MockitoAnnotations.openMocks(this))
                  .hasMessageContaining("Unable to initialize @Spy annotated field 'service'")
                  .hasMessageContaining(
                          "Please ensure that the type 'ConstructorRequiredService' has a no-arg constructor.");
      }
  
      public static class ConstructorRequiredService {
          private final String greeting;
  
          public ConstructorRequiredService(String greeting) {
              this.greeting = greeting;
          }
  
          public String greeting() {
              return greeting;
          }
      }
  }
