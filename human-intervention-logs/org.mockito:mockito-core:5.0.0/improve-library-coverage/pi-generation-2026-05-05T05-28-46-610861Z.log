  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.Mockito;
  import org.mockito.plugins.MockResolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PluginInitializerTest {
      @Test
      void loadsMockResolverPluginUsingExtensionResource() {
          MyService mock = Mockito.mock(MyService.class);
          MockWrapper wrapper = new MockWrapper(mock);
  
          assertThat(Mockito.mockingDetails(wrapper).isMock()).isTrue();
      }
  
      public static final class UnwrappingMockResolver implements MockResolver {
          public UnwrappingMockResolver() {
          }
  
          @Override
          public Object resolve(Object instance) {
              if (instance instanceof MockWrapper) {
                  return ((MockWrapper) instance).mock;
              }
              return instance;
          }
      }
  
      private static final class MockWrapper {
          private final Object mock;
  
          private MockWrapper(Object mock) {
              this.mock = mock;
          }
      }
  }
