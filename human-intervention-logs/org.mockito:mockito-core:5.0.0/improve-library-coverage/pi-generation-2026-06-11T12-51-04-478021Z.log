  class PluginRegistry {
  
      private final PluginSwitch pluginSwitch =
              new PluginLoader(new DefaultPluginSwitch()).loadPlugin(PluginSwitch.class);
  
      private final MockMaker mockMaker =
              new PluginLoader(
                              pluginSwitch,
