[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java","edits":[{"oldText":"import org.mockito.MockitoAnnotations;\n\nimport static org.assertj.core.api.Assertions.assertThat;","newText":"import org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.plugins.MemberAccessor;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;"},{"oldText":"public class InstrumentationMemberAccessorTest {\n    @Test\n    void initializesInjectMocksFieldAndInjectsConcreteClassMocks() throws Exception {","newText":"public class InstrumentationMemberAccessorTest {\n    @Test\n    void defaultMemberAccessorInvokesConstructorsMethodsAndFields() throws Exception {\n        MemberAccessor accessor = Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        Constructor<AccessorTarget> constructor = AccessorTarget.class.getConstructor(String.class);\n        AccessorTarget target = (AccessorTarget) accessor.newInstance(constructor, \"initial\");\n\n        Field name = AccessorTarget.class.getDeclaredField(\"name\");\n        assertThat(accessor.get(name, target)).isEqualTo(\"initial\");\n        accessor.set(name, target, \"updated\");\n\n        Method greet = AccessorTarget.class.getDeclaredMethod(\"greet\", String.class);\n        assertThat(accessor.invoke(greet, target, \"Hello\")).isEqualTo(\"Hello updated\");\n    }\n\n    @Test\n    void initializesInjectMocksFieldAndInjectsConcreteClassMocks() throws Exception {"},{"oldText":"    public static class InjectionFixture {","newText":"    public static class AccessorTarget {\n        private String name;\n\n        public AccessorTarget(String name) {\n            this.name = name;\n        }\n\n        private String greet(String salutation) {\n            return salutation + \" \" + name;\n        }\n    }\n\n    public static class InjectionFixture {"}]}
[tool-call] end id=call_9LnXiwoqgKCwiD6SNZCNFSrO|fc_0dbce881de233c11016a2ab01fe4188195a0356bfb622003d6 name=edit args={"path": "tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java", "edits": [{"oldText": "import org.mockito.MockitoAnnotations;\n\nimport static org.assertj.core.api.Assertions.assertThat;", "newText": "import org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.plugins.MemberAccessor;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;"}, {"oldText": "public class InstrumentationMemberAccessorTest {\n    @Test\n    void initializesInjectMocksFieldAndInjectsConcreteClassMocks() throws Exception {", "newText": "public class InstrumentationMemberAccessorTest {\n    @Test\n    void defaultMemberAccessorInvokesConstructorsMethodsAndFields() throws Exception {\n        MemberAccessor accessor = Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        Constructor<AccessorTarget> constructor = AccessorTarget.class.getConstructor(String.class);\n        AccessorTarget target = (AccessorTarget) accessor.newInstance(constructor, \"initial\");\n\n        Field name = AccessorTarget.class.getDeclaredField(\"name\");\n        assertThat(accessor.get(name, target)).isEqualTo(\"initial\");\n        accessor.set(name, target, \"updated\");\n\n        Method greet = AccessorTarget.class.getDeclaredMethod(\"greet\", String.class);\n        assertThat(accessor.invoke(greet, target, \"Hello\")).isEqualTo(\"Hello updated\");\n    }\n\n    @Test\n    void initializesInjectMocksFieldAndInjectsConcreteClassMocks() throws Exception {"}, {"oldText": "    public static class InjectionFixture {", "newText": "    public static class AccessorTarget {\n        private String name;\n\n        public AccessorTarget(String name) {\n            this.name