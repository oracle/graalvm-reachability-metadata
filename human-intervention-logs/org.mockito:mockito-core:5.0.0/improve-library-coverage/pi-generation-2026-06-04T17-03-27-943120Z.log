[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/StackWalkerCheckerTest.java","edits":[{"oldText":"import org.mockito.MockedConstruction;\nimport org.mockito.Mockito;\n","newText":"import org.mockito.Mockito;\nimport org.mockito.plugins.MockMaker;\n"},{"oldText":"    private static void exerciseConstructionMockingWithSubclassConstructor() {\n        try (MockedConstruction<ConstructedBase> mocked =\n                Mockito.mockConstruction(\n                        ConstructedBase.class,\n                        (mock, context) -> Mockito.when(mock.name()).thenReturn(\"mocked\"))) {\n            ConstructedBase directConstruction = new ConstructedBase(\"direct\");\n            assertThat(directConstruction.name()).isEqualTo(\"mocked\");\n            assertThat(mocked.constructed()).containsExactly(directConstruction);\n\n            ConstructedChild subclassConstruction = new ConstructedChild(\"subclass\");\n            assertThat(subclassConstruction.name()).isEqualTo(\"real-subclass\");\n            assertThat(mocked.constructed()).containsExactly(directConstruction);\n        }\n    }\n","newText":"    private static void exerciseConstructionMockingWithSubclassConstructor() {\n        MockMaker inlineMockMaker = Mockito.framework().getPlugins().getInlineMockMaker();\n        MockMaker.ConstructionMockControl<ConstructedBase> control =\n                inlineMockMaker.createConstructionMock(\n                        ConstructedBase.class,\n                        context -> {\n                            throw new AssertionError(\"subclass construction should stay real\");\n                        },\n                        context -> {\n                            throw new AssertionError(\"subclass construction should stay real\");\n                        },\n                        (mock, context) -> {\n                            throw new AssertionError(\"subclass construction should stay real\");\n                        });\n        control.enable();\n        try {\n            ConstructedChild subclassConstruction = new ConstructedChild(\"subclass\");\n            assertThat(subclassConstruction.name()).isEqualTo(\"real-subclass\");\n        } finally {\n            control.disable();\n        }\n    }\n"}]}
