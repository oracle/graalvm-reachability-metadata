oSession()\n                            .initMocks(this)\n                            .strictness(Strictness.STRICT_STUBS)\n                            .startMocking();\n            try {\n                when(annotatedService.describe(\"standard\")).thenReturn(\"mocked standard order\");\n\n                assertThat(annotatedService.describe(\"standard\"))\n                        .isEqualTo(\"mocked standard order\");\n                verify(annotatedService).describe(\"standard\");\n            } finally {\n                session.finishMocking();\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    public static class InlineOrderService {\n        private final String source;\n        private final int basePrice;\n\n        public InlineOrderService(String source, int basePrice) {\n            this.source = source == null ? \"default\" : source;\n            this.basePrice = basePrice;\n        }\n\n        public int price(String sku, int quantity) {\n            return basePrice + sku.length() + quantity;\n        }\n\n        public String describe(String sku) {\n            return source + \" \" + sku;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781188270653}, {"role": "toolResult", "toolCallId": "call_p6IEy1yOkBKmkp3urGs1Yh35|fc_07a6a49c334623cf016a2ac6ae6d6481969ecc8f30fda2c42b", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.mock;\nimport static org.mockito.Mockito.verify;\nimport static org.mockito.Mockito.when;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.AdditionalAnswers;\nimport org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.MockitoAnnotations;\nimport org.mockito.Spy;\n\npublic class ReflectionMemberAccessorTest {\n    @Test\n    void initializesSpyUsingPrivateConstructorAndFieldAccess() throws Exception {\n        SpyFixture fixture = new SpyFixture();\n\n        try (AutoCloseable mocks = MockitoAnnotations.openMocks(fixture)) {\n            assertThat(fixture.counter.increment()).isEqualTo(8);\n            verify(fixture.counter).increment();\n        }\n    }\n\n    @Test\n    void injectsMocksIntoPrivateFieldsOfConstructedService() throws Exception {\n        InjectionFixture fixture = new InjectionFixture();\n\n        try (AutoCloseable mocks = MockitoAnnotations.openMocks(fixture)) {\n            when(fixture.repository.findName(\"42\")).thenReturn(\"Ada\");\n            when(fixture.auditTrail.record(\"Ada\")).thenReturn(\"recorded Ada\");\n\n            assertThat(fixture.service.greet(\"42\")).isEqualTo(\"Hello Ada\");\n            assertThat(fixture.service.audit(\"Ada\")).isEqualTo(\"recorded Ada\");\n\n            verify(fixture.repository).findName(\"42\");\n            verify(fixture.auditTrail).record(\"Ada\");\n        }\n    }\n\n    @Test\n    void delegatesMockCallsToRealObjectThroughMemberAccessor() {\n        GreetingContract greeting =\n                mock(\n                        GreetingContract.class,\n                        AdditionalAnswers.delegatesTo(new GreetingDelegate(\"Hello\")));\n\n        assertThat(greeting.greet(\"Ada\")).isEqualTo(\"Hello Ada\");\n        verify(greeting).greet(\"Ada\");\n    }\n\n    public static class SpyFixture {\n        @Spy\n        PrivateConstructorCounter counter;\n    }\n\n    public static class PrivateConstructorCounter {\n        private int value;\n\n        private PrivateConstructorCounter() {\n            value = 7;\n        }\n\n        public int increment() {\n            return ++value;\n        }\n    }\n\n    public static class InjectionFixture {\n        @Mock\n        Repository repository;\n\n        @Mock\n        AuditTrail auditTrail;\n\n        @InjectMocks\n        GreetingService service;\n    }\n\n    public static class GreetingService {\n        private Repository repository;\n        private AuditTrail auditTrail;\n\n        private GreetingService() {}\n\n        public String greet(String id) {\n            return \"Hello \" + repository.findName(id);\n        }\n\n        public String audit(String name) {\n            return auditTrail.record(name);\n        }\n    }\n\n    public static class Repository {\n        public String findName(String id) {\n            return \"real \" + id;\n        }\n    }\n\n    public static class AuditTrail {\n        public String record(String name) {\n            return \"real \" + name;\n        }\n    }\n\n    public interface GreetingContract {\n        String greet(String name);\n    }\n\n    public static class GreetingDelegate {\n        private final String salutation;\n\n        public GreetingDelegate(String salutation) {\n            this.salutation = salutation;\n        }\n\n        public String greet(String name) {\n            return salutation + \" \" + name;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781188270653}, {"role": "toolResult", "toolCallId": "call_rNpA5X8Wdf7hyVMK8nhFladu|fc_07a6a49c334623cf016a2ac6ae6d6c8196bd89a43720ee4f95", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.mock;\nimport static org.mockito.Mockito.mockingDetails;\nimport static org.mockito.Mockito.reset;\nimport static org.mockito.Mockito.verify;\nimport static org.mockito.Mockito.when;\nimport static org.mockito.Mockito.withSettings;\n\nimport java.util.concurrent.atomic.AtomicInteger;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.plugins.MockResolver;\n\npublic class PluginInitializerTest {\n    @Test\n    void loadsMockResolverPluginAndAppliesItToMockitoDslObjects() {\n        GreetingService service = mock(GreetingService.class, withSettings().name(\"service\"));\n        when(service.greet(\"Ada\")).thenAnswer(invocation -> \"Hello \" + invocation.getArgument(0));\n        WrappedGreetingService wrappedService = new WrappedGreetingService(service);\n\n        assertThat(mockingDetails(wrappedService).isMock()).isTrue();\n        assertThat(\n                        mockingDetails(wrappedService)\n                                .getMockCreationSettings()\n                                .getMockName()\n                                .toString())\n                .isEqualTo(\"service\");\n        assertThat(wrappedService.greet(\"Ada\")).isEqualTo(\"Hello Ada\");\n        verify(service).greet(\"Ada\");\n\n        reset(wrappedService);\n\n        assertThat(service.greet(\"Ada\")).isNull();\n        assertThat(WrappedMockResolver.instantiations()).isGreaterThanOrEqualTo(1);\n        assertThat(WrappedMockResolver.resolutions()).isGreaterThanOrEqualTo(2);\n    }\n\n    public static class WrappedMockResolver implements MockResolver {\n        private static final AtomicInteger INSTANTIATIONS = new AtomicInteger();\n        private static final AtomicInteger RESOLUTIONS = new AtomicInteger();\n\n        public WrappedMockResolver() {\n            INSTANTIATIONS.incrementAndGet();\n        }\n\n        @Override\n        public Object resolve(Object instance) {\n            RESOLUTIONS.incrementAndGet();\n            if (instance instanceof WrappedGreetingService) {\n                return ((WrappedGreetingService) instance).mock;\n            }\n            return instance;\n        }\n\n        static int instantiations() {\n            return INSTANTIATIONS.get();\n        }\n\n        static int resolutions() {\n            return RESOLUTIONS.get();\n        }\n    }\n\n    public static class WrappedGreetingService {\n        private final GreetingService mock;\n\n        WrappedGreetingService(GreetingService mock) {\n            this.mock = mock;\n        }\n\n        public String greet(String name) {\n            return mock.greet(name);\n        }\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"unmocked \" + name;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781188270653}]}
