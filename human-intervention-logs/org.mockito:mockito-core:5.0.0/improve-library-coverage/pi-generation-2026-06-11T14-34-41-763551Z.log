  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.stubbing.OngoingStubbing;
  
  public class KotlinInlineClassUtilTest {
      @Test
      @SuppressWarnings({"rawtypes", "unchecked"})
      void stubsUnderlyingReturnTypeWithBoxedKotlinInlineClassValue() {
          GreetingLookup lookup = mock(GreetingLookup.class);
  
          OngoingStubbing stubbing = when(lookup.greeting());
          stubbing.thenReturn(KotlinInlineGreetingFactory.boxed("Hello Kotlin inline class"));
  
          assertThat(lookup.greeting()).isEqualTo("Hello Kotlin inline class");
          verify(lookup).greeting();
      }
  
      public interface GreetingLookup {
          String greeting();
      }
  }
[tool-exec] end id=call_1NXglaI1OBGSkZx42PTcAAln|fc_07a6a49c334623cf016a2ac759b8bc8196bf8554032188be32 name=read status=success
