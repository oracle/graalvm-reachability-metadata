      testImplementation "org.mockito:mockito-subclass:$libraryVersion"
  }
  
  kotlin {
      jvmToolchain(21)
      sourceSets {
          test {
              kotlin.srcDir("src/test/java")
          }
      }
  }
  
  compileTestKotlin {
      kotlinOptions.jvmTarget = "21"
  }
  
  test {
      jvmArgs "-Djdk.attach.allowAttachSelf=true"
      jvmArgs "-Dnet.bytebuddy.experimental=true"
  }
  graalvmNative {
      binaries {
          test {
              buildArgs.add("-Dnet.bytebuddy.experimental=true")
