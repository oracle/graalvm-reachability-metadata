  package org_mockito.mockito_core
  
  @JvmInline
  value class KotlinInlineGreeting(val text: String)
  
  object KotlinInlineGreetingFactory {
      @JvmStatic
      fun boxed(text: String): Any = KotlinInlineGreeting(text)
  }
