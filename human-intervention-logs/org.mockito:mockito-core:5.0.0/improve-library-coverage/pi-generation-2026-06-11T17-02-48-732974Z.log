[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java","edits":[{"oldText":"import org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.Mockito;\nimport org.mockito.MockitoAnnotations;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InstrumentationMemberAccessorTest {\n    @Test\n    void opensMocksInjectsInterfaceMockThroughConstructorsSettersAndFields() throws Exception {\n        AnnotationFixture fixture = new AnnotationFixture();\n\n        try (AutoCloseable mocks = MockitoAnnotations.openMocks(fixture)) {\n            Mockito.when(fixture.myService.getGreeting()).thenReturn(\"Hello from annotation mock\");\n\n            assertThat(fixture.constructorInjected.greeting())\n                    .isEqualTo(\"constructor: Hello from annotation mock\");\n            assertThat(fixture.setterInjected.greeting())\n                    .isEqualTo(\"setter: Hello from annotation mock\");\n\n            Mockito.verify(fixture.myService, Mockito.times(2)).getGreeting();\n        }\n    }\n\n    public static class AnnotationFixture {\n        @Mock private MyService myService;\n\n        @InjectMocks private ConstructorInjectedService constructorInjected;\n\n        @InjectMocks private SetterInjectedService setterInjected;\n    }\n\n    public static class ConstructorInjectedService {\n        private final MyService myService;\n\n        public ConstructorInjectedService(MyService myService) {\n            this.myService = myService;\n        }\n\n        public String greeting() {\n            return \"constructor: \" + myService.getGreeting();\n        }\n    }\n\n    public static class SetterInjectedService {\n        private MyService myService;\n\n        public SetterInjectedService() {}\n\n        public void setMyService(MyService myService) {\n            this.myService = myService;\n        }\n\n        public String greeting() {\n            return \"setter: \" + myService.getGreeting();\n        }\n    }\n}\n","newText":"import org.mockito.Mockito;\nimport org.mockito.plugins.MemberAccessor;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InstrumentationMemberAccessorTest {\n    @Test\n    void defaultMemberAccessorCreatesInvokesReadsAndWritesMembers() throws Exception {\n        MemberAccessor memberAccessor =\n                Mockito.framework().getPlugins().getDefaultPlugin(MemberAccessor.class);\n        Constructor<AccessorTarget> constructor =\n                AccessorTarget.class.getDeclaredConstructor(String.class);\n        Method greeting = AccessorTarget.class.getDeclaredMethod(\"greeting\", String.class);\n        Field value = AccessorTarget.class.getDeclaredField(\"value\");\n\n        AccessorTarget target = (AccessorTarget) memberAccessor.newInstance(constructor, \"initial\");\n        assertThat(memberAccessor.get(value, target)).isEqualTo(\"initial\");\n\n        memberAccessor.set(value, target, \"updated\");\n\n        assertThat(memberAccessor.invoke(greeting, target, \"hello\")).isEqualTo(\"hello updated\");\n    }\n\n    public static class AccessorTarget {\n        private String value;\n\n        public AccessorTarget(String value) {\n            this.value = value;\n        }\n\n        private String greeting(String prefix) {\n            return prefix + \" \" + value;\n        }\n    }\n}\n"}]}
