  package org_mockito.mockito_core;
  
  import java.io.File;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Arrays;
  import java.util.Comparator;
  import java.util.stream.Stream;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.catchThrowable;
  
  public class PluginLoaderTest {
      private static final String MISSING_PLUGIN_CLASS =
              "org_mockito.mockito_core.MissingMockitoPlugin";
  
      @Test
      void loadPluginCreatesDiagnosticProxyForMalformedSinglePlugin() throws Exception {
          withMalformedPlugin(
                  "org.mockito.plugins.DoNotMockEnforcer",
                  classLoader -> {
                      Class<?> mockito = classLoader.loadClass("org.mockito.Mockito");
                      Method mock = mockito.getMethod("mock", Class.class);
  
                      InvocationTargetException exception =
                              assertInvocationTargetException(
                                      catchThrowable(() -> mock.invoke(null, Runnable.class)));
                      assertThat(exception.getCause())
                              .isInstanceOf(IllegalStateException.class)
                              .hasMessageContaining(
                                      "Could not initialize plugin: interface "
                                              + "org.mockito.plugins.DoNotMockEnforcer");
                  });
      }
  
      @Test
      void loadPluginsCreatesDiagnosticProxyForMalformedMultiPlugin() throws Exception {
          withMalformedPlugin(
                  "org.mockito.plugins.MockResolver",
                  classLoader -> {
                      Class<?> mockito = classLoader.loadClass("org.mockito.Mockito");
                      Object details =
                              mockito.getMethod("mockingDetails", Object.class)
                                      .invoke(null, new Object());
                      Class<?> mockingDetails = classLoader.loadClass("org.mockito.MockingDetails");
                      Method isMock = mockingDetails.getMethod("isMock");
  
                      InvocationTargetException exception =
                              assertInvocationTargetException(
                                      catchThrowable(() -> isMock.invoke(details)));
                      assertThat(exception.getCause())
                              .isInstanceOf(IllegalStateException.class)
                              .hasMessageContaining(
                                      "Could not initialize plugin: interface "
                                              + "org.mockito.plugins.MockResolver");
                  });
      }
  
      private static void withMalformedPlugin(String pluginType, ClassLoaderScenario scenario)
              throws Exception {
          Path extensionRoot = Files.createTempDirectory("mockito-plugin-loader-test");
          try {
              Path extensionFile = extensionRoot.resolve("mockito-extensions").resolve(pluginType);
              Files.createDirectories(extensionFile.getParent());
              Files.writeString(extensionFile, MISSING_PLUGIN_CLASS + "\n", StandardCharsets.UTF_8);
  
              URL[] urls = prepend(extensionRoot.toUri().toURL(), testClasspathUrls());
              Thread currentThread = Thread.currentThread();
              ClassLoader previousContextClassLoader = currentThread.getContextClassLoader();
              try (ChildFirstLibraryClassLoader classLoader =
                      new ChildFirstLibraryClassLoader(urls)) {
                  currentThread.setContextClassLoader(classLoader);
                  scenario.run(classLoader);
              } catch (Error error) {
                  if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                      throw error;
                  }
              } finally {
                  currentThread.setContextClassLoader(previousContextClassLoader);
              }
          } finally {
              deleteRecursively(extensionRoot);
          }
      }
  
      private static InvocationTargetException assertInvocationTargetException(Throwable throwable) {
          assertThat(throwable).isInstanceOf(InvocationTargetException.class);
          return (InvocationTargetException) throwable;
      }
  
      private static URL[] prepend(URL first, URL[] rest) {
          URL[] urls = new URL[rest.length + 1];
          urls[0] = first;
          System.arraycopy(rest, 0, urls, 1, rest.length);
          return urls;
      }
  
      private static URL[] testClasspathUrls() {
          return Arrays.stream(System.getProperty("java.class.path", "").split(File.pathSeparator))
                  .filter(entry -> !entry.isEmpty())
                  .map(File::new)
                  .map(File::toURI)
                  .map(uri -> {
                      try {
                          return uri.toURL();
                      } catch (Exception exception) {
                          throw new IllegalStateException(exception);
                      }
                  })
                  .toArray(URL[]::new);
      }
  
      private static void deleteRecursively(Path root) throws Exception {
          if (!Files.exists(root)) {
              return;
          }
          try (Stream<Path> paths = Files.walk(root)) {
              paths.sorted(Comparator.reverseOrder())
                      .forEach(path -> {
                          try {
                              Files.delete(path);
                          } catch (Exception exception) {
                              throw new IllegalStateException(exception);
                          }
                      });
          }
      }
  
      private interface ClassLoaderScenario {
          void run(ClassLoader classLoader) throws Exception;
      }
  
      private static class ChildFirstLibraryClassLoader extends URLClassLoader {
          ChildFirstLibraryClassLoader(URL[] urls) {
              super(urls, ClassLoader.getPlatformClassLoader());
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (isLibraryClass(name)) {
                  synchronized (getClassLoadingLock(name)) {
                      Class<?> loaded = findLoadedClass(name);
                      if (loaded == null) {
                          try {
                              loaded = findClass(name);
                          } catch (ClassNotFoundException ignored) {
                              loaded = super.loadClass(name, false);
                          }
                      }
                      if (resolve) {
                          resolveClass(loaded);
                      }
                      return loaded;
