  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.MockMakers;
  import org.mockito.Mockito;
  import org.mockito.internal.creation.bytebuddy.InlineByteBuddyMockMaker;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InlineDelegateByteBuddyMockMakerTest {
      @Test
      void createsInlineMockForFinalClass() throws Exception {
          MockitoDynamicAccessSupport.runAllowingUnsupportedFeatureError(
                  () -> {
                      FinalInlineTarget target =
                              Mockito.mock(
                                      FinalInlineTarget.class,
                                      Mockito.withSettings().mockMaker(MockMakers.INLINE));
                      Mockito.when(target.name()).thenReturn("inline");
  
                      assertThat(target.name()).isEqualTo("inline");
                  });
      }
  
      @Test
      void createsInstanceThroughInlineInstantiator() throws Exception {
          MockitoDynamicAccessSupport.runAllowingUnsupportedFeatureError(
                  () -> {
                      InlineByteBuddyMockMaker mockMaker = new InlineByteBuddyMockMaker();
  
                      ConstructedInlineTarget target = mockMaker.newInstance(ConstructedInlineTarget.class);
  
                      assertThat(target.count).isZero();
                  });
      }
  
      public static final class FinalInlineTarget {
          public String name() {
              return "real";
          }
      }
  
      public static class ConstructedInlineTarget {
          private final int count;
  
          public ConstructedInlineTarget(int count) {
              this.count = count;
          }
      }
  }
