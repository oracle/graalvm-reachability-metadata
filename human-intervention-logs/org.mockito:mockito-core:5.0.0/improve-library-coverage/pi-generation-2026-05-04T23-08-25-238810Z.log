  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.Answers;
  import org.mockito.Mockito;
  import org.mockito.internal.creation.MockSettingsImpl;
  import org.mockito.internal.creation.bytebuddy.InlineByteBuddyMockMaker;
  import org.mockito.internal.handler.MockHandlerFactory;
  import org.mockito.mock.MockCreationSettings;
  import org.mockito.plugins.MockMaker;
  
  import java.lang.reflect.Constructor;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InlineDelegateByteBuddyMockMakerInnerInlineConstructionMockContextTest {
      @Test
      void exposesConstructorFromConstructionMockContext() throws Exception {
          MockitoDynamicAccessSupport.runAllowingUnsupportedFeatureError(
                  () -> {
                      InlineByteBuddyMockMaker mockMaker = new InlineByteBuddyMockMaker();
                      MockCreationSettings<ConstructorTarget> settings =
                              ((MockSettingsImpl<ConstructorTarget>)
                                              Mockito.withSettings()
                                                      .defaultAnswer(Answers.RETURNS_DEFAULTS))
                                      .build(ConstructorTarget.class);
                      MockMaker.ConstructionMockControl<ConstructorTarget> control =
                              mockMaker.createConstructionMock(
                                      ConstructorTarget.class,
                                      context -> settings,
                                      context -> MockHandlerFactory.createMockHandler(settings),
                                      (mock, context) -> {
                                          Constructor<?> constructor = context.constructor();
                                          assertThat(constructor.getParameterTypes())
                                                  .containsExactly(String.class, int.class);
                                          assertThat(context.arguments()).hasSize(2);
                                          assertThat(context.arguments().get(0)).isEqualTo("value");
                                          assertThat(context.arguments().get(1)).isEqualTo(7);
                                      });
                      boolean enabled = false;
                      try {
                          control.enable();
                          enabled = true;
                          ConstructorTarget target = new ConstructorTarget("value", 7);
  
                          assertThat(control.getMocks()).containsExactly(target);
                      } finally {
                          if (enabled) {
                              control.disable();
                          }
                      }
                  });
      }
  
      public static class ConstructorTarget {
          public ConstructorTarget(String value, int count) {}
      }
  }
