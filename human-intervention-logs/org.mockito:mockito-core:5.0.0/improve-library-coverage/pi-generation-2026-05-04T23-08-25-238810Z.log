  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.Mockito;
  
  import java.io.IOException;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  import static org.mockito.Mockito.doThrow;
  
  public class InvocationInfoTest {
      @Test
      void validatesCheckedExceptionDeclaredByParentInterface() throws Exception {
          DynamicAccessService service = Mockito.mock(DynamicAccessService.class);
          doThrow(new IOException("declared by parent")).when(service).risky();
  
          assertThatThrownBy(service::risky).isInstanceOf(IOException.class);
      }
  }
