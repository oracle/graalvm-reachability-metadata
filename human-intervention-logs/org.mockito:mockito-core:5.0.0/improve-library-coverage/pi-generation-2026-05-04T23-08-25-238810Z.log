  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.MockMakers;
  import org.mockito.Mockito;
  import org.mockito.mock.SerializableMode;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteBuddyCrossClassLoaderSerializationSupportInnerCrossClassLoaderSerializationProxyTest {
      @Test
      void serializesAndDeserializesAcrossClassLoadersUsingSerializationProxy() throws Exception {
          MockitoDynamicAccessSupport.runAllowingUnsupportedFeatureError(
                  () -> {
                      SerializableTarget target =
                              Mockito.mock(
                                      SerializableTarget.class,
                                      Mockito.withSettings()
                                              .mockMaker(MockMakers.SUBCLASS)
                                              .serializable(SerializableMode.ACROSS_CLASSLOADERS));
                      Mockito.when(target.value()).thenReturn("serialized");
  
                      SerializableTarget copy = roundTrip(target);
  
                      assertThat(copy.value()).isEqualTo("serialized");
                  });
      }
  
      private static SerializableTarget roundTrip(SerializableTarget target) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {
              outputStream.writeObject(target);
          }
          try (ObjectInputStream inputStream =
                  new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (SerializableTarget) inputStream.readObject();
          }
      }
  
      public static class SerializableTarget {
          public String value() {
              return "real";
          }
      }
  }
