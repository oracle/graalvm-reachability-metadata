  package org_mockito.mockito_core;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  
  final class MockitoDynamicAccessSupport {
      private MockitoDynamicAccessSupport() {}
  
      static void runAllowingUnsupportedFeatureError(CheckedRunnable runnable) throws Exception {
          try {
              runnable.run();
          } catch (Error error) {
              if (NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return;
              }
              throw error;
          }
      }
  
      interface CheckedRunnable {
          void run() throws Exception;
      }
  }
