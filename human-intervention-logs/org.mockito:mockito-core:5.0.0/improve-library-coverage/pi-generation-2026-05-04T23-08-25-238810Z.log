  public class MethodHandleProxyInnerLegacyVersionTest {
      @Test
      void invokesDefaultMethodThroughProxyMockMaker() {
          LegacyDefaultMethodService service =
                  Mockito.mock(
                          LegacyDefaultMethodService.class,
                          Mockito.withSettings()
                                  .mockMaker(MockMakers.PROXY)
                                  .defaultAnswer(Answers.CALLS_REAL_METHODS));
  
          assertThat(service.defaultValue()).isEqualTo("legacy default");
      }
  
      interface LegacyDefaultMethodService {
          default String defaultValue() {
              return "legacy default";
          }
      }
  }
