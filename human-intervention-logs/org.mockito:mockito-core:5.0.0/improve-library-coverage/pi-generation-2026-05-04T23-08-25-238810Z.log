  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.Answers;
  import org.mockito.Mockito;
  import org.mockito.exceptions.verification.SmartNullPointerException;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class ReturnsSmartNullsInnerThrowsSmartNullPointerTest {
      @Test
      void reportsSmartNullInvocationLocation() {
          DynamicAccessService service =
                  Mockito.mock(DynamicAccessService.class, Answers.RETURNS_SMART_NULLS);
  
          ChildDependency child = service.child();
  
          assertThatThrownBy(child::name).isInstanceOf(SmartNullPointerException.class);
      }
  }
