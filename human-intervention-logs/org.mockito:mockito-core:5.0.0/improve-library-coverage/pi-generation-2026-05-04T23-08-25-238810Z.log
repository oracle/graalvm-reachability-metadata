[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/InstrumentationMemberAccessorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.internal.configuration.plugins.Plugins;\nimport org.mockito.plugins.MemberAccessor;\n\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class InstrumentationMemberAccessorTest {\n    @Test\n    void accessesConstructorMethodAndFieldThroughConfiguredMemberAccessor() throws Exception {\n        MemberAccessor accessor = Plugins.getMemberAccessor();\n        Constructor<ReflectiveTarget> constructor = ReflectiveTarget.class.getDeclaredConstructor(String.class);\n        ReflectiveTarget target = (ReflectiveTarget) accessor.newInstance(constructor, \"created\");\n\n        Field value = ReflectiveTarget.class.getDeclaredField(\"value\");\n        accessor.set(value, target, \"updated\");\n        assertThat(accessor.get(value, target)).isEqualTo(\"updated\");\n\n        Method greet = ReflectiveTarget.class.getDeclaredMethod(\"greet\", String.class);\n        assertThat(accessor.invoke(greet, target, \"hello\")).isEqualTo(\"hello updated\");\n    }\n\n    static class ReflectiveTarget {\n        private String value;\n\n        ReflectiveTarget(String value) {\n            this.value = value;\n        }\n\n        private String greet(String prefix) {\n            return prefix + \" \" + value;\n        }\n    }\n}\n"}
