o.Mockito;\n\nimport java.io.IOException;\nimport java.io.InputStream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProxyMockMakerInnerCommonClassLoaderTest {\n    @Test\n    void createsProxyMockForInterfacesFromSiblingClassLoaders() throws Exception {\n        MockitoDynamicAccessSupport.runAllowingUnsupportedFeatureError(\n                () -> {\n                    Class<?> left = new IsolatedInterfaceLoader().loadClass(LeftInterface.class.getName());\n                    Class<?> right =\n                            new IsolatedInterfaceLoader().loadClass(RightInterface.class.getName());\n\n                    Object mock =\n                            Mockito.mock(\n                                    Object.class,\n                                    Mockito.withSettings()\n                                            .mockMaker(MockMakers.PROXY)\n                                            .extraInterfaces(left, right));\n\n                    assertThat(left.isInstance(mock)).isTrue();\n                    assertThat(right.isInstance(mock)).isTrue();\n                });\n    }\n\n    public interface LeftInterface {}\n\n    public interface RightInterface {}\n\n    static class IsolatedInterfaceLoader extends ClassLoader {\n        IsolatedInterfaceLoader() {\n            super(null);\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream inputStream =\n                    ProxyMockMakerInnerCommonClassLoaderTest.class\n                            .getClassLoader()\n                            .getResourceAsStream(resourceName)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                byte[] bytes = inputStream.readAllBytes();\n                return defineClass(name, bytes, 0, byt