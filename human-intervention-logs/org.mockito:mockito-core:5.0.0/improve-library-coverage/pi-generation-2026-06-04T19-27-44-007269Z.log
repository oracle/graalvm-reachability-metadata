  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.MockMakers;
  import org.mockito.Mockito;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.when;
  import static org.mockito.Mockito.withSettings;
  
  public class SubclassInjectionLoaderTest {
      static {
          System.setProperty("net.bytebuddy.experimental", "true");
          System.setProperty("org.mockito.internal.noUnsafeInjection", "true");
      }
  
      @Test
      void subclassMockMakerCreatesStubbedConcreteClassWithoutUnsafeInjection() {
          GreetingService service =
                  Mockito.mock(GreetingService.class, withSettings().mockMaker(MockMakers.SUBCLASS));
  
          when(service.greeting("Mockito")).thenReturn("Hello Mockito");
  
          assertThat(service.greeting("Mockito")).isEqualTo("Hello Mockito");
          assertThat(Mockito.mockingDetails(service).getMockCreationSettings().getMockMaker())
                  .isEqualTo(MockMakers.SUBCLASS);
      }
  
      public static class GreetingService {
          public String greeting(String name) {
              return "Hello " + name;
          }
      }
  }
