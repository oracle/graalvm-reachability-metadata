                                      new InvocationHandler() {
                                          @Override
                                          public Object invoke(
                                                  Object proxy, Method method, Object[] args)
                                                  throws Throwable {
                                              throw new IllegalStateException(
                                                      "Could not initialize plugin: " + pluginType,
                                                      t);
                                          }
                                      }));
          }
      }
