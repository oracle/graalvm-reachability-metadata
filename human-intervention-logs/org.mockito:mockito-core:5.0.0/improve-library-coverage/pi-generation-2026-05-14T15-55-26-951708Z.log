  +++ b/tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java
  @@ -0,0 +1,166 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package org_mockito.mockito_core;
  +
  +import org.graalvm.internal.tck.NativeImageSupport;
  +import org.junit.jupiter.api.Test;
  +import org.mockito.MockMakers;
  +import org.mockito.Mockito;
  +import org.mockito.exceptions.base.MockitoException;
  +
  +import java.io.ByteArrayOutputStream;
  +import java.io.DataOutputStream;
  +import java.io.IOException;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +import static org.mockito.Mockito.withSettings;
  +
  +public class ModuleHandlerInnerModuleSystemFoundTest {
  +    private static final String JAVAC_CONTEXT_CLASS_NAME = "com.sun.tools.javac.util.Context";
  +    private static final String EXTRA_INTERFACE_CLASS_NAME =
  +            "org_mockito.mockito_core.ModuleHandlerInnerModuleSystemFoundExtraInterface";
  +
  +    @Test
  +    void createsSubclassMockForConcealedJdkCompilerType() throws Exception {
  +        try {
  +            Class<?> contextType = Class.forName(JAVAC_CONTEXT_CLASS_NAME);
  +
  +            Object mock =
  +                    Mockito.mock(
  +                            contextType,
  +                            withSettings().mockMaker(MockMakers.SUBCLASS));
  +
  +            assertThat(contextType.isInstance(mock)).isTrue();
  +            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();
  +        } catch (MockitoException exception) {
  +            if (hasUnsupportedFeatureErrorCause(exception)) {
  +                return;
  +            }
  +            assertExpectedMockitoFailure(exception);
  +        } catch (Error error) {
  +            ignoreNativeImageUnsupportedFeature(error);
  +        }
  +    }
  +
  +    @Test
  +    void createsSubclassMockWithExtraInterfaceFromIsolatedLoader() throws Exception {
  +        try {
  +            Class<?> contextType = Class.forName(JAVAC_CONTEXT_CLASS_NAME);
  +            Class<?> extraInterface = loadExtraInterfaceWithIsolatedLoader();
  +
  +            Object mock =
  +                    Mockito.mock(
  +                            contextType,
  +                            withSettings()
  +                                    .mockMaker(MockMakers.SUBCLASS)
  +                                    .extraInterfaces(extraInterface));
  +
  +            assertThat(contextType.isInstance(mock)).isTrue();
  +            assertThat(extraInterface.isInstance(mock)).isTrue();
  +            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();
  +        } catch (MockitoException exception) {
  +            if (hasUnsupportedFeatureErrorCause(exception)) {
  +                return;
  +            }
  +            assertExpectedMockitoFailure(exception);
  +        } catch (Error error) {
  +            ignoreNativeImageUnsupportedFeature(error);
  +        }
  +    }
  +
  +    private static void assertExpectedMockitoFailure(MockitoException exception) {
  +        assertThat(exception.getMessage()).containsAnyOf("mock", "Mock", "module", "Mockito");
  +    }
  +
  +    private static Class<?> loadExtraInterfaceWithIsolatedLoader() throws ClassNotFoundException {
  +        ClassLoader parent = ModuleHandlerInnerModuleSystemFoundTest.class.getClassLoader();
  +        ClassLoader loader = new IsolatedInterfaceLoader(parent);
  +        return loader.loadClass(EXTRA_INTERFACE_CLASS_NAME);
  +    }
  +
  +    private static void ignoreNativeImageUnsupportedFeature(Error error) {
  +        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
  +            throw error;
  +        }
  +    }
  +
  +    private static boolean hasUnsup
