[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java","edits":[{"oldText":"import org.junit.jupiter.api.Test;\nimport org.mockito.MockMakers;","newText":"import org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.mockito.MockMakers;"},{"oldText":"import java.io.IOException;","newText":"import java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.List;\nimport java.util.Set;\n\nimport javax.tools.JavaCompiler;\nimport javax.tools.ToolProvider;"},{"oldText":"    private static final String JAVAC_CONTEXT_CLASS_NAME = \"com.sun.tools.javac.util.Context\";","newText":"    private static final String JAVAC_CONTEXT_CLASS_NAME = \"com.sun.tools.javac.util.Context\";\n    private static final String DYNAMIC_MODULE_NAME = \"dynamic.mockito.module\";\n    private static final String DYNAMIC_MODULE_TYPE_NAME = \"sample.internal.ModuleType\";"},{"oldText":"    @Test\n    void createsSubclassMockWithExtraInterfaceFromIsolatedLoader() throws Exception {","newText":"    @Test\n    void createsSubclassMockForConcealedTypeFromDynamicModule(@TempDir Path temporaryDirectory)\n            throws Exception {\n        try {\n            Class<?> moduleType = compileAndLoadConcealedModuleType(temporaryDirectory);\n\n            Object mock =\n                    Mockito.mock(\n                            moduleType,\n                            withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(moduleType.isInstance(mock)).isTrue();\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return;\n            }\n            assertExpectedMockitoFailure(exception);\n        } catch (Error error) {\n            ignoreNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    void createsSubclassMockWithExtraInterfaceFromIsolatedLoader() throws Exception {"},{"oldText":"    private static void assertExpectedMockitoFailure(MockitoException exception) {\n        assertThat(exception.getMessage()).containsAnyOf(\"mock\", \"Mock\", \"module\", \"Mockito\");\n    }\n\n    private static Class<?> loadExtraInterfaceWithIsolatedLoader() throws ClassNotFoundException {","newText":"    private static void assertExpectedMockitoFailure(MockitoException exception) {\n        assertThat(exception.getMessage()).containsAnyOf(\"mock\", \"Mock\", \"module\", \"Mockito\");\n    }\n\n    private static Class<?> compileAndLoadConcealedModuleType(Path temporaryDirectory)\n            throws IOException, ClassNotFoundException {\n        Path sourceDirectory = temporaryDirectory.resolve(\"src\").resolve(DYNAMIC_MODULE_NAME);\n        Path packageDirectory = sourceDirectory.resolve(\"sample\").resolve(\"internal\");\n        Files.createDirectories(packageDirectory);\n        Path moduleInfo = sourceDirectory.resolve(\"module-info.java\");\n        Files.writeString(moduleInfo, \"module \" + DYNAMIC_MODULE_NAME + \" { }\\n\");\n        Path moduleType = packageDirectory.resolve(\"ModuleType.java\");\n        Files.writeString(\n                moduleType,\n                \"\"\"\n                package sample.internal;\n\n                public class ModuleType {\n                    public ModuleType() {\n                    }\n                }\n                \"\"\");\n\n        Path outputDirectory = temporaryDirectory.resolve(\"classes\");\n        Files.createDirectories(outputDirectory);\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\n        assertThat(compiler).isNotNull();\n        int exitCode =\n                compiler.run(\n                        null,\n                        null,\n                        null,\n                        \"-d\",\n                        outputDirectory.toString(),\n                        moduleInfo.toString(),\n                        moduleType.toString());\n        assertThat(exitCode).isZero();\n\n        ModuleLayer layer =\n                ModuleLayer.boot()\n                        .defineModulesWithOneLoader(\n                                ModuleLayer.boot()\n                                        .configuration()\n                                        .resolve(\n                                                java.lang.module.ModuleFinder.of(outputDirectory),\n                                                java.lang.module.ModuleFinder.of(),\n                                                Set.of(DYNAMIC_MODULE_NAME)),\n                                ClassLoader.getSystemClassLoader());\n        return layer.findLoader(DYNAMIC_MODULE_NAME).loadClass(DYNAMIC_MODULE_TYPE_NAME);\n    }\n\n    private static Class<?> loadExtraInterfaceWithIsolatedLoader() throws ClassNotFoundException {"}]}
