ception {\n        try {\n            Class<?> contextType = Class.forName(JAVAC_CONTEXT_CLASS_NAME);\n\n            Object mock =\n                    Mockito.mock(\n                            contextType,\n                            withSettings().mockMaker(MockMakers.SUBCLASS));\n\n            assertThat(contextType.isInstance(mock)).isTrue();\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            assertThat(exception).hasMessageContaining(\"mock\");\n        } catch (Error error) {\n            ignoreNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    void createsSubclassMockWithExtraInterfaceFromIsolatedLoader() throws Exception {\n        try {\n            Class<?> contextType = Class.forName(JAVAC_CONTEXT_CLASS_NAME);\n            Class<?> extraInterface = loadExtraInterfaceWithIsolatedLoader();\n\n            Object mock =\n                    Mockito.mock(\n                            contextType,\n                            withSettings()\n                                    .mockMaker(MockMakers.SUBCLASS)\n                                    .extraInterfaces(extraInterface));\n\n            assertThat(contextType.isInstance(mock)).isTrue();\n            assertThat(extraInterface.isInstance(mock)).isTrue();\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return;\n            }\n            assertThat(exception).hasMessageContaining(\"mock\");\n        } catch (Error error) {\n            ignoreNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    private static Class<?> loadExtraInterfaceWithIsolatedLoader() throws ClassNotFoundException {\n        ClassLoader parent = ModuleHandlerInnerModuleSystemFoundTest.class.getClassLoader();\n        ClassLoader loader = new IsolatedInterfaceLoader(parent);\n        return loader.loadClass(EXTRA_INTERFACE_CLASS_NAME);\n    }\n\n    private static void ignoreNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public interface IsolatedExtraInterface {}\n\n    private static class IsolatedInterfaceLoader extends ClassLoader {\n        IsolatedInterfaceLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (EXTRA_INTERFACE_CLASS_NAME.equals(name)) {\n                        loadedClass = findClass(name);\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (!EXTRA_INTERFACE_CLASS_NAME.equals(name)) {\n                return super.findClass(name);\n            }\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream input = getParent().getResourceAsStream(resourceName)) {\n                if (input