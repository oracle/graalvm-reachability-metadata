mock).isMock()).isTrue();\n        } catch (MockitoException exception) {\n            if (hasUnsupportedFeatureErrorCause(exception)) {\n                return;\n            }\n            assertExpectedMockitoFailure(exception);\n        } catch (Error error) {\n            ignoreNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    private static void assertExpectedMockitoFailure(MockitoException exception) {\n        assertThat(exception.getMessage()).containsAnyOf(\"mock\", \"Mock\", \"module\", \"Mockito\");\n    }\n\n    private static Class<?> loadExtraInterfaceWithIsolatedLoader() throws ClassNotFoundException {\n        ClassLoader parent = ModuleHandlerInnerModuleSystemFoundTest.class.getClassLoader();\n        ClassLoader loader = new IsolatedInterfaceLoader(parent);\n        return loader.loadClass(EXTRA_INTERFACE_CLASS_NAME);\n    }\n\n    private static void ignoreNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureErrorCause(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static class IsolatedInterfaceLoader extends ClassLoader {\n        IsolatedInterfaceLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    if (EXTRA_INTERFACE_CLASS_NAME.equals(name)\n                            || isInjectionBaseProbeName(name)) {\n                        loadedClass = findClass(name);\n                    } else {\n                        loadedClass = super.loadClass(name, false);\n                    }\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            try {\n                if (EXTRA_INTERFACE_CLASS_NAME.equals(name)) {\n                    byte[] classBytes = minimalTypeBytes(name, PUBLIC_ABSTRACT_INTERFACE);\n                    return defineClass(name, classBytes, 0, classBytes.length);\n                } else if (isInjectionBaseProbeName(name)) {\n                    byte[] classBytes = minimalTypeBytes(name, PUBLIC_SUPER_CLASS);\n                    return defineClass(name, classBytes, 0, classBytes.length);\n                }\n                return super.findClass(name);\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n\n        private static boolean isInjectionBaseProbeName(String name) {\n            int suffix = Math.abs(Mockito.class.hashCode());\n            return name.equals(JAVAC_INJECTION_BASE_PREFIX + suffix)\n                    || name.equals(JAVAC_INJECTION_BASE_PREFIX + 0);\n        }\n\n        private static byte[] minimalTypeBytes(String name, int access) throws IOException {\n            String internalName = name.replace('.', '/');\n            ByteArrayOutputStream output = new ByteArrayOutputStream();\n            DataOutputStream classFile = new DataOutputStream(output);\n            classFile.writeInt(CLASS_FILE_MAGIC);\n            classFile.writeShort(0);\n            classFile.writeShort(JAVA_8_CLASS_FILE_VERSION);\n            classFile.writeShort(CONSTANT_POOL_SI