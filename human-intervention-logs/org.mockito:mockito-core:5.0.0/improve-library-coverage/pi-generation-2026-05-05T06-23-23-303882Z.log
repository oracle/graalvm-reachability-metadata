if (current instanceof Error error\n                    && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    @FunctionalInterface\n    private interface ThrowingRunnable {\n        void run();\n    }\n\n    public static class ConstructedService {\n        private final String message;\n\n        public ConstructedService(String message) {\n            this.message = message;\n        }\n\n        public String message() {\n            return message;\n        }\n    }\n\n    public static class BaseService {\n        private final String value;\n\n        public BaseService(String value) {\n            this.value = value;\n        }\n\n        public String message() {\n            return \"base:\" + value;\n        }\n    }\n\n    public static class DerivedService extends BaseService {\n        public DerivedService() {\n            super(\"derived\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777963162578}}
