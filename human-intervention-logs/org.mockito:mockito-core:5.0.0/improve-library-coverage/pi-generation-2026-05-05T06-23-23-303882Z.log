rows IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n", "newText": "    @Test\n    void readResolveReturnsObjectFromProxyPayload() throws Exception {\n        byte[] proxyStream = serializedProxyStream(serialize(\"resolved payload\"));\n\n        assertThat(deserialize(proxyStream)).isEqualTo(\"resolved payload\");\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serializedProxyStream(byte[] serializedMock) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream outputStream = new DataOutputStream(bytes);\n        outputStream.writeShort(0xACED);\n        outputStream.writeShort(5);\n        outputStream.writeByte(0x73);\n        outputStream.writeByte(0x72);\n        outputStream.writeUTF(PROXY_CLASS_NAME);\n        outputStream.writeLong(PROXY_SERIAL_VERSION_UID);\n        outputStream.writeByte(0x02);\n        outputStream.writeShort(3);\n        writeObjectField(outputStream, \"extraInterfaces\", \"Ljava/util/Set;\");\n        writeObjectField(outputStream, \"serializedMock\", \"[B\");\n        writeObjectField(outputStream, \"typeToMock\", \"Ljava/lang/Class;\");\n        outputStream.writeByte(0x78);\n        outputStream.writeByte(0x70);\n        outputStream.writeByte(0x70);\n        writeSerializedContent(outputStream, serializedMock);\n        outputStream.writeByte(0x70);\n        outputStream.close();\n        return bytes.toByteArray();\n    }\n\n    private static void writeOb