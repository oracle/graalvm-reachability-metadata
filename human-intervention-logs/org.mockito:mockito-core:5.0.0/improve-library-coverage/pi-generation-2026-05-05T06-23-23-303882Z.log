  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.plugins.MockResolver;
  import org.mockito.plugins.MockitoLogger;
  import org.mockito.plugins.PluginSwitch;
  
  import java.io.IOException;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.net.URL;
  import java.util.Enumeration;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class PluginLoaderTest {
      private static final String PLUGIN_LOADER_TYPE =
              "org.mockito.internal.configuration.plugins.PluginLoader";
  
      @Test
      void loadPluginCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Throwable {
          Object pluginLoader = newPluginLoader();
  
          MockitoLogger logger =
                  withFailingMockitoExtensionLookup(
                          () -> (MockitoLogger) loadPlugin(pluginLoader, MockitoLogger.class));
  
          assertThatThrownBy(() -> logger.log("message"))
                  .isInstanceOf(IllegalStateException.class)
                  .hasMessageContaining("Could not initialize plugin")
                  .hasMessageContaining("org.mockito.plugins.MockitoLogger");
      }
  
      @Test
      void loadPluginsCreatesFailureProxyWhenPluginResourceDiscoveryFails() throws Throwable {
          Object pluginLoader = newPluginLoader();
  
          List<MockResolver> resolvers =
                  withFailingMockitoExtensionLookup(
                          () -> loadPlugins(pluginLoader, MockResolver.class));
  
          assertThat(resolvers).hasSize(1);
          assertThatThrownBy(() -> resolvers.get(0).resolve(new Object()))
                  .isInstanceOf(IllegalStateException.class)
                  .hasMessageContaining("Could not initialize plugin")
                  .hasMessageContaining("org.mockito.plugins.MockResolver");
      }
  
      private static Object newPluginLoader() throws Throwable {
          Class<?> pluginLoaderType = Class.forName(PLUGIN_LOADER_TYPE);
          MethodHandles.Lookup lookup =
                  MethodHandles.privateLookupIn(pluginLoaderType, MethodHandles.lookup());
          MethodHandle constructor =
                  lookup.findConstructor(
                          pluginLoaderType, MethodType.methodType(void.class, PluginSwitch.class));
          return constructor.invoke(new EnabledPluginSwitch());
      }
  
      private static Object loadPlugin(Object pluginLoader, Class<?> pluginType) throws Throwable {
          MethodHandle loadPlugin = pluginLoaderMethod("loadPlugin", Object.class);
          return loadPlugin.invoke(pluginLoader, pluginType);
      }
  
      @SuppressWarnings("unchecked")
      private static <T> List<T> loadPlugins(Object pluginLoader, Class<T> pluginType)
              throws Throwable {
          MethodHandle loadPlugins = pluginLoaderMethod("loadPlugins", List.class);
          return (List<T>) loadPlugins.invoke(pluginLoader, pluginType);
      }
  
      private static MethodHandle pluginLoaderMethod(String name, Class<?> returnType)
              throws ReflectiveOperationException {
          Class<?> pluginLoaderType = Class.forName(PLUGIN_LOADER_TYPE);
          MethodHandles.Lookup lookup =
                  MethodHandles.privateLookupIn(pluginLoaderType, MethodHandles.lookup());
          return lookup.findVirtual(
                  pluginLoaderType, name, MethodType.methodType(returnType, Class.class));
      }
  
      private static <T> T withFailingMockitoExtensionLookup(ThrowingSupplier<T> action)
              throws Throwable {
          Thread thread = Thread.currentThread();
          ClassLoader originalLoader = thread.getContextClassLoader();
          try {
              thread.setContextClassLoader(
                      new FailingMockitoExtensionResourceLoader(originalLoader));
              return action.get();
          } finally {
              thread.setContextClassLoader(originalLoader);
          }
      }
  
      private interface ThrowingSupplier<T> {
          T get() throws Throwable;
      }
  
      private static final class EnabledPluginSwitch implements PluginSwitch {
          @Override
          public boolean isEnabled(String pluginClassName) {
              return true;
          }
      }
  
      private static final class FailingMockitoExtensionResourceLoader extends ClassLoader {
          private FailingMockitoExtensionResourceLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              if (name.startsWith("mockito-extensions/")) {
                  throw new IOException("Deliberate resource lookup failure for " + name);
              }
              return super.getResources(name);
          }
      }
  }
