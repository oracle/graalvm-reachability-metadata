ructedBase(String name) {\n            this.name = \"real-\" + name;\n        }\n\n        public String name() {\n            return name;\n        }\n    }\n\n    public static final class ConstructedChild extends ConstructedBase {\n        public ConstructedChild(String name) {\n            super(name);\n        }\n    }\n}\n"}
