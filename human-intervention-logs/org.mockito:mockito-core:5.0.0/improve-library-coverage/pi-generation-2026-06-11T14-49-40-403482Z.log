  package org_mockito.mockito_core;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.mock.SerializableMode;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  import static org.mockito.Mockito.withSettings;
  
  public class ByteBuddyCrossClassLoaderSerializationSupportInnerCrossClassLoaderSerializationProxyTest {
      @Test
      void serializesAndDeserializesConcreteMockAcrossClassLoaders() throws Exception {
          GreetingService greetingService =
                  mock(
                          GreetingService.class,
                          withSettings()
                                  .serializable(SerializableMode.ACROSS_CLASSLOADERS)
                                  .extraInterfaces(NamedService.class));
          NamedService namedService = (NamedService) greetingService;
          when(greetingService.greetingFor("GraalVM")).thenReturn("Hello GraalVM");
          when(namedService.name()).thenReturn("mockito");
  
          GreetingService deserializedGreetingService = serializeAndDeserialize(greetingService);
          NamedService deserializedNamedService = (NamedService) deserializedGreetingService;
  
          assertThat(deserializedGreetingService.greetingFor("GraalVM")).isEqualTo("Hello GraalVM");
          assertThat(deserializedNamedService.name()).isEqualTo("mockito");
          verify(deserializedGreetingService).greetingFor("GraalVM");
          verify(deserializedNamedService).name();
      }
  
      private static <T> T serializeAndDeserialize(T mock)
              throws IOException, ClassNotFoundException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(bytes)) {
              objectOutputStream.writeObject(mock);
          }
  
          try (ObjectInputStream objectInputStream =
                  new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              @SuppressWarnings("unchecked")
              T deserializedMock = (T) objectInputStream.readObject();
              return deserializedMock;
          }
      }
  
      public static class GreetingService {
          public String greetingFor(String name) {
              return "Hi " + name;
          }
      }
  
      public interface NamedService {
          String name();
      }
  }
