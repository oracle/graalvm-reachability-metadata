emptyOptionalDouble()).isEmpty();\n        assertThat((OptionalInt) JavaEightUtil.emptyOptionalInt()).isEmpty();\n        assertThat((OptionalLong) JavaEightUtil.emptyOptionalLong()).isEmpty();\n    }\n\n    @Test\n    void createsEmptyStreamTypesThroughUtilityFactories() {\n        assertThat(((Stream<?>) JavaEightUtil.emptyStream()).count()).isZero();\n        assertThat(((DoubleStream) JavaEightUtil.emptyDoubleStream()).count()).isZero();\n        assertThat(((IntStream) JavaEightUtil.emptyIntStream()).count()).isZero();\n        assertThat(((LongStream) JavaEightUtil.emptyLongStream()).count()).isZero();\n    }\n\n    @Test\n    void readsZeroTemporalValuesThroughUtilityFactories() {\n        assertThat((Duration) JavaEightUtil.emptyDuration()).isEqualTo(Duration.ZERO);\n        assertThat((Period) JavaEightUtil.emptyPeriod()).isEqualTo(Period.ZERO);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 464, "output": 717, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 16029, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778774945986, "responseId": "resp_03af1353ca3c9f56016a05f3a2531481a28b5e02cfd089d89c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_q617zV4o3Nd1mLOlkUsTiHpD|fc_03af1353ca3c9f56016a05f3a6ce2481a2ac8362a7c733387c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1785 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/JavaEightUtilTest.java"}], "isError": false, "timestamp": 1778774953957}]}
