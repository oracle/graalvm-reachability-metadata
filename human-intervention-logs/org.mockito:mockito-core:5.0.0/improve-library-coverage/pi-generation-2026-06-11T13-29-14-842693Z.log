t org.mockito.junit.MockitoJUnitRunner;\n\npublic class RunnerProviderTest {\n    @Test\n    public void createsDefaultInternalRunnerForMockitoJunitRunner() {\n        Result result = JUnitCore.runClasses(MockitoRunnerTarget.class);\n\n        assertThat(result.wasSuccessful()).isTrue();\n        assertThat(result.getRunCount()).isEqualTo(1);\n        assertThat(result.getFailures()).isEmpty();\n    }\n\n    @RunWith(MockitoJUnitRunner.class)\n    public static class MockitoRunnerTarget {\n        @Mock\n        Collaborator collaborator;\n\n        @Test\n        public void initializesAnnotatedMocksAndRunsJunitFourTest() {\n            when(collaborator.message()).thenReturn(\"created by Mockito runner\");\n\n            assertThat(collaborator.message()).isEqualTo(\"created by Mockito runner\");\n            verify(collaborator).message();\n        }\n    }\n\n    public static class Collaborator {\n        public String message() {\n            return \"real collaborator\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3302, "output": 882, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 27224, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781184422862, "responseId": "resp_023f6ddaa1494552016a2ab7a780a881968494bd9fe002263e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_H0ZLiQ1QHjj6XZoLiJHEEjel|fc_023f6ddaa1494552016a2ab7b5d250819688f8fa4ec63dcd59", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1509 bytes to tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/RunnerProviderTest.java"}], "isError": false, "timestamp": 1781184440168}]}
