ate {\n        public String greet(String name) {\n            return \"Hello \" + name;\n        }\n    }\n\n    public static class InjectionFixture {\n        @Mock\n        Repository repository;\n\n        @Mock\n        AuditTrail auditTrail;\n\n        @InjectMocks\n        GreetingService service;\n    }\n\n    public static class GreetingService {\n        private Repository repository;\n        private AuditTrail auditTrail;\n\n        public GreetingService() {}\n\n        public void setRepository(Repository repository) {\n            this.repository = repository;\n        }\n\n        public String greet(String id) {\n            return \"Hello \" + repository.findName(id);\n        }\n\n        public String audit(String name) {\n            return auditTrail.record(name);\n        }\n    }\n\n    public static class Repository {\n        public String findName(String id) {\n            return \"real \" + id;\n        }\n    }\n\n    public static class AuditTrail {\n        public String record(String name) {\n            return \"real \" + name;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781184388322}, {"role": "toolResult", "toolCallId": "call_9EEOjnzfvr0ADUkUDrKGJ8A7|fc_023f6ddaa1494552016a2ab78418c4819689f75574f56aaa3c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.mock;\nimport static org.mockito.Mockito.verify;\nimport static org.mockito.Mockito.when;\nimport static org.mockito.Mockito.withSettings;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ModuleHandlerInnerModuleSystemFoundTest {\n    @Test\n    void mocksConcreteClassWithAdditionalInterface() {\n        GreetingService service =\n                mock(GreetingService.class, withSettings().extraInterfaces(Auditable.class));\n        Auditable auditable = (Auditable) service;\n\n        when(service.greet(\"Ada\")).thenReturn(\"Hello Ada\");\n        when(auditable.audit(\"Ada\")).thenReturn(\"recorded Ada\");\n\n        assertThat(service.greet(\"Ada\")).isEqualTo(\"Hello Ada\");\n        assertThat(auditable.audit(\"Ada\")).isEqualTo(\"recorded Ada\");\n        verify(service).greet(\"Ada\");\n        verify(auditable).audit(\"Ada\");\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"real \" + name;\n        }\n    }\n\n    public interface Auditable {\n        String audit(String name);\n    }\n}\n"}], "isError": false, "timestamp": 1781184388322}, {"role": "toolResult", "toolCallId": "call_HPOb0CU5BDEfhKClHxsb97I6|fc_023f6ddaa1494552016a2ab78418c88196a4e12651ade9715b", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.mock;\n\nimport java.time.Duration;\nimport java.time.Period;\nimport java.util.Optional;\nimport java.util.OptionalDouble;\nimport java.util.OptionalInt;\nimport java.util.OptionalLong;\nimport java.util.stream.DoubleStream;\nimport java.util.stream.IntStream;\nimport java.util.stream.LongStream;\nimport java.util.stream.Stream;\nimport org.junit.jupiter.api.Test;\n\npublic class JavaEightUtilTest {\n    @Test\n    void returnsEmptyJavaEightValuesFromUnstubbedConcreteClassMock() {\n        JavaEightDefaults defaults = mock(JavaEightDefaults.class);\n\n        assertThat(defaults.optional()).isEmpty();\n        assertThat(defaults.optionalDouble()).isEmpty();\n        assertThat(defaults.optionalInt()).isEmpty();\n        assertThat(defaults.optionalLong()).isEmpty();\n        assertThat(defaults.stream()).isEmpty();\n        assertThat(defaults.doubleStream().count()).isZero();\n        assertThat(defaults.intStream().count()).isZero();\n        assertThat(defaults.longStream().count()).isZero();\n        assertThat(defaults.duration()).isEqualTo(Duration.ZERO);\n        assertThat(defaults.period()).isEqualTo(Period.ZERO);\n    }\n\n    public static class JavaEightDefaults {\n        public Optional<String> optional() {\n            return Optional.of(\"real\");\n        }\n\n        public OptionalDouble optionalDouble() {\n            return OptionalDouble.of(1.5d);\n        }\n\n        public OptionalInt optionalInt() {\n            return OptionalInt.of(1);\n        }\n\n        public OptionalLong optionalLong() {\n            return OptionalLong.of(1L);\n        }\n\n        public Stream<String> stream() {\n            return Stream.of(\"real\");\n        }\n\n        public DoubleStream doubleStream() {\n            return DoubleStream.of(1.5d);\n        }\n\n        public IntStream intStream() {\n            return IntStream.of(1);\n        }\n\n        public LongStream longStream() {\n            return LongStream.of(1L);\n        }\n\n        public Duration duration() {\n            return Duration.ofSeconds(1);\n        }\n\n        public Period period() {\n            return Period.ofDays(1);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781184388322}, {"role": "toolResult", "toolCallId": "call_4RyapTjlD5iN2BIdiyV7zptb|fc_023f6ddaa1494552016a2ab78418d08196ba5730f0386f3125", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.doReturn;\n\nimport java.util.function.Function;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockedConstruction;\nimport org.mockito.Mockito;\nimport org.mockito.internal.creation.MockSettingsImpl;\nimport org.mockito.internal.handler.MockHandlerFactory;\nimport org.mockito.invocation.MockHandler;\nimport org.mockito.mock.MockCreationSettings;\nimport org.mockito.plugins.MockMaker;\n\npublic class StackWalkerCheckerTest {\n    @Test\n    void constructionMockLeavesSubclassConstructionUnmocked() {\n        try {\n            exerciseInlineConstructionMock();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void exerciseInlineConstructionMock() {\n        MockMaker inlineMockMaker = Mockito.framework().getPlugins().getInlineMockMaker();\n        Function<MockedConstruction.Context, MockCreationSettings<ConstructedGreeter>>\n                settingsFactory = context -> buildSettings();\n        Function<MockedConstruction.Context, MockHandler<ConstructedGreeter>> handlerFactory =\n                context -> MockHandlerFactory.createMockHandler(settingsFactory.apply(context));\n        MockMaker.ConstructionMockControl<ConstructedGreeter> control =\n                inlineMockMaker.createConstructionMock(\n                        ConstructedGreeter.class,\n                        settingsFactory,\n                        handlerFactory,\n                        (mock, context) ->\n                                doReturn(\"mocked \" + context.getCount()).when(mock).greeting());\n\n        control.enable();\n        try {\n            ConstructedGreeter direct = new ConstructedGreeter(\"Ada\");\n            ChildGreeter child = new ChildGreeter(\"Bob\");\n\n            assertThat(direct.greeting()).isEqualTo(\"mocked 1\");\n            assertThat(child.greeting()).isEqualTo(\"child real Bob\");\n            assertThat(control.getMocks()).containsExactly(direct);\n        } finally {\n            control.disable();\n            inlineMockMaker.clearAllCaches();\n        }\n    }\n\n    private static MockCreationSettings<ConstructedGreeter> buildSettings() {\n        MockSettingsImpl<ConstructedGreeter> settings = new MockSettingsImpl<>();\n        settings.defaultAnswer(Mockito.RETURNS_DEFAULTS);\n        return settings.build(ConstructedGreeter.class);\n    }\n\n    public static class ConstructedGreeter {\n        private final String name;\n\n        public ConstructedGreeter(String name) {\n            this.name = name;\n        }\n\n        public String greeting() {\n            return \"real \" + name;\n        }\n    }\n\n    public static class ChildGreeter extends ConstructedGreeter {\n        public ChildGreeter(String name) {\n            super(name);\n        }\n\n        @Override\n        public String greeting() {\n            return \"child \" + super.greeting();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781184388322}]}
