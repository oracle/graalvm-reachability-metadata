  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  
  import org.junit.runner.JUnitCore;
  import org.junit.runner.Result;
  import org.junit.runner.RunWith;
  import org.junit.Test;
  import org.mockito.Mock;
  import org.mockito.junit.MockitoJUnitRunner;
  
  public class RunnerProviderTest {
      @Test
      public void createsDefaultInternalRunnerForMockitoJunitRunner() {
          Result result = JUnitCore.runClasses(MockitoRunnerTarget.class);
  
          assertThat(result.wasSuccessful()).isTrue();
          assertThat(result.getRunCount()).isEqualTo(1);
          assertThat(result.getFailures()).isEmpty();
      }
  
      @RunWith(MockitoJUnitRunner.class)
      public static class MockitoRunnerTarget {
          @Mock
          Collaborator collaborator;
  
          @Test
          public void initializesAnnotatedMocksAndRunsJunitFourTest() {
              when(collaborator.message()).thenReturn("created by Mockito runner");
  
              assertThat(collaborator.message()).isEqualTo("created by Mockito runner");
              verify(collaborator).message();
          }
      }
  
      public static class Collaborator {
          public String message() {
              return "real collaborator";
          }
      }
  }
