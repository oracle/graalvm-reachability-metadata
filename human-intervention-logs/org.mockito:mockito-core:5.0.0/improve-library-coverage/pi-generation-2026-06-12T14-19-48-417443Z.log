andlers =\n                context -> MockHandlerFactory.createMockHandler(settings.apply(context));\n        MockedConstruction.MockInitializer<ConstructedService> initializer =\n                (mock, context) -> {\n                    constructorArguments.add(context.arguments());\n                    when(mock.name()).thenReturn(\"mocked:\" + context.arguments().get(0));\n                };\n        MockMaker.ConstructionMockControl<ConstructedService> control =\n                inlineMockMaker.createConstructionMock(\n                        ConstructedService.class, settings, handlers, initializer);\n\n        control.enable();\n        try {\n            ConstructedService direct = new ConstructedService(\"direct\");\n            ChildService child = new ChildService(\"child\");\n\n            assertThat(direct.name()).isEqualTo(\"mocked:direct\");\n            assertThat(Mockito.mockingDetails(direct).isMock()).isTrue();\n            assertThat(child.childName()).isEqualTo(\"child:real:child\");\n            assertThat(Mockito.mockingDetails(child).isMock()).isFalse();\n            assertThat(control.getMocks()).containsExactly(direct);\n            assertThat(constructorArguments).containsExactly(List.of(\"direct\"));\n        } finally {\n            control.disable();\n        }\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> MockCreationSettings<T> mockCreationSettings(Class<T> type) {\n        MockSettingsImpl<T> settings = (MockSettingsImpl<T>) Mockito.withSettings();\n        return settings.build(type);\n    }\n\n    static class ConstructedService {\n        private final String name;\n\n        ConstructedService(String name) {\n            this.name = \"real:\" + name;\n        }\n\n        String name() {\n            return name;\n        }\n    }\n\n    static final class ChildService extends ConstructedService {\n        ChildService(String name) {\n            super(name);\n        }\n\n        String childName() {\n            return \"child:\" + name();\n        }\n    }\n}\n"}
