see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.function.Function;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.mockito.MockedConstruction;\nimport org.mockito.Mockito;\nimport org.mockito.internal.creation.MockSettingsImpl;\nimport org.mockito.internal.handler.MockHandlerFactory;\nimport org.mockito.invocation.MockHandler;\nimport org.mockito.mock.MockCreationSettings;\nimport org.mockito.plugins.MockMaker;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.when;\n\npublic class StackWalkerCheckerTest {\n    @Test\n    void inlineConstructionMockLeavesSubclassSuperConstructionUnmocked() {\n        try {\n            assertInlineConstructionMockLeavesSubclassSuperConstructionUnmocked();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void assertInlineConstructionMockLeavesSubclassSuperConstructionUnmocked() {\n        MockMaker inlineMockMaker = Mockito.framework().getPlugins().getInlineMockMaker();\n        List<List<?>> constructorArguments = new ArrayList<>();\n        Function<MockedConstruction.Context, MockCreationSettings<ConstructedService>> settings =\n                context -> mockCreationSettings(ConstructedService.class);\n        Function<MockedConstruction.Context, MockHandler<ConstructedService>> handlers =\n                context -> MockHandlerFactory.createMockHandler(settings.apply(context));\n        MockedConstruction.MockInitializer<ConstructedService> initializer =\n                (mock, context) -> {\n                    constructorArguments.add(context.arguments());\n                    when(mock.name()).thenReturn(\"mocked:\" + context.arguments().get(0));\n                };\n        MockMaker.ConstructionMockControl<ConstructedService> control =\n                inlineMockMaker.createConstructionMock(\n                        ConstructedService.class, settings, handlers, initializer);\n\n        control.enable();\n        try {\n            ConstructedService direct = new ConstructedService(\"direct\");\n            ChildService child = new ChildService(\"child\");\n\n            assertThat(direct.name()).isEqualTo(\"mocked:direct\");\n            assertThat(Mockito.mockingDetails(direct).isMock()).isTrue();\n            assertThat(child.childName()).isEqualTo(\"child:real:child\");\n            assertThat(Mockito.mockingDetails(child).isMock()).isFalse();\n            assertThat(control.getMocks()).containsExactly(direct);\n            assertThat(constructorArguments).containsExactly(List.of(\"direct\"));\n        } finally {\n            control.disable();\n        }\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> MockCreationSettings<T> mockCreationSettings(Class<T> type) {\n        MockSettingsImpl<T> settings = (MockSettingsImpl<T>) Mockito.withSettings();\n        return settings.build(type);\n    }\n\n    static class ConstructedService {\n        private final String name;\n\n        ConstructedService(String name) {\n            this.name = \"real:\" + name;\n        }\n\n        String name() {\n            return name;\n        }\n    }\n\n    static final class ChildService extends ConstructedService {\n        ChildService(String name) {\n            super(name);\n        }\n\n        String childName() {\n            return \"child:\" + name();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 339, "output": 2023, "cacheRead": 38400, "cacheWrite": 0, "totalTokens": 40762, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781273862552, "responseId": "resp_079dd186eea