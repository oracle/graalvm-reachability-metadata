              if (!type.isAssignableFrom(owner.getClass())) {
                  throw new IllegalArgumentException("Cannot access " + target + " on " + owner);
              }
          }
  
          Object[] args = values;
          if (args == null) {
              args = new Object[0];
          }
  
          if (types.length != args.length) {
              throw new IllegalArgumentException(
