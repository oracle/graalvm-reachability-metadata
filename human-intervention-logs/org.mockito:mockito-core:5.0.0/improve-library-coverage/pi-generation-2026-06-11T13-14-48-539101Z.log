[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.Mockito.mock;\nimport static org.mockito.Mockito.verify;\nimport static org.mockito.Mockito.when;\n\nimport java.nio.file.spi.FileSystemProvider;\nimport java.util.Locale;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ModuleHandlerInnerModuleSystemFoundTest {\n    @Test\n    void mocksConcreteProviderDiscoveredFromJdkModule() {\n        FileSystemProvider zipProvider =\n                FileSystemProvider.installedProviders().stream()\n                        .filter(provider -> \"jar\".equals(provider.getScheme().toLowerCase(Locale.ROOT)))\n                        .findFirst()\n                        .orElseThrow(\n                                () ->\n                                        new IllegalStateException(\n                                                \"The JDK zip file system provider is required\"));\n        Class<? extends FileSystemProvider> providerType =\n                zipProvider.getClass().asSubclass(FileSystemProvider.class);\n\n        FileSystemProvider provider = mock(providerType);\n        when(provider.getScheme()).thenReturn(\"mock-jar\");\n\n        assertThat(provider.getScheme()).isEqualTo(\"mock-jar\");\n        verify(provider).getScheme();\n    }\n}\n"}
