[tool-call] end id=call_Ss9zoZ6ee6uaLLwZgA72hUDp|fc_0cf58f977881a6b7016a2ab53caa1c81969ef3c0de4ccaad97 name=edit args={"path": "tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/ModuleHandlerInnerModuleSystemFoundTest.java", "edits": [{"oldText": "import java.nio.file.spi.FileSystemProvider;\nimport java.util.Locale;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ModuleHandlerInnerModuleSystemFoundTest {\n    @Test\n    void mocksConcreteProviderDiscoveredFromJdkModule() {\n        FileSystemProvider zipProvider =\n                FileSystemProvider.installedProviders().stream()\n                        .filter(\n                                provider ->\n                                        \"jar\"\n                                                .equals(\n                                                        provider.getScheme()\n                                                                .toLowerCase(Locale.ROOT)))\n                        .findFirst()\n                        .orElseThrow(\n                                () ->\n                                        new IllegalStateException(\n                                                \"The JDK zip file system provider is required\"));\n        Class<? extends FileSystemProvider> providerType =\n                zipProvider.getClass().asSubclass(FileSystemProvider.class);\n\n        FileSystemProvider provider = mock(providerType);\n        when(provider.getScheme()).thenReturn(\"mock-jar\");\n\n        assertThat(provider.getScheme()).isEqualTo(\"mock-jar\");\n        verify(provider).getScheme();\n    }\n}\n", "newText": "import java.io.IOException;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Locale;\n\nimport javax.tools.StandardJavaFileManager;\nimport javax.tools.ToolProvider;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ModuleHandlerInnerModuleSystemFoundTest {\n    @Test\n    void mocksConcreteFileManagerDiscoveredFromCompilerApi() throws IOException {\n        StandardJavaFileManager realFileManager =\n                ToolProvider.getSystemJavaCompiler()\n                        .getStandardFileManager(null, Locale.ROOT, StandardCharsets.UTF_8);\n        try {\n            Class<? extends StandardJavaFileManager> fileManagerType =\n                    realFileManager.getClass().asSubclass(StandardJavaFileManager.class);\n\n            StandardJavaFileManager fileManager = mock(fileManagerType);\n            when(fileManager.isSupportedOption(\"-classpath\")).thenReturn(1);\n\n            assertThat(fileManager.isSupportedOption(\"-classpath\")).isEqualTo(1);\n            verify(fileManager).isSupportedOption(\"-classpath\");\n        } finally {\n            realFileManager.close();\n        }\n    }\n}\n"}]}
