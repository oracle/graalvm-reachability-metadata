  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  import static org.mockito.Mockito.withSettings;
  
  import org.junit.jupiter.api.Test;
  
  public class ModuleHandlerInnerModuleSystemFoundTest {
      @Test
      void mocksConcreteClassWithAdditionalInterface() {
          GreetingService service =
                  mock(GreetingService.class, withSettings().extraInterfaces(Auditable.class));
          Auditable auditable = (Auditable) service;
  
          when(service.greet("Ada")).thenReturn("Hello Ada");
          when(auditable.audit("Ada")).thenReturn("recorded Ada");
  
          assertThat(service.greet("Ada")).isEqualTo("Hello Ada");
          assertThat(auditable.audit("Ada")).isEqualTo("recorded Ada");
          verify(service).greet("Ada");
          verify(auditable).audit("Ada");
      }
  
      public static class GreetingService {
          public String greet(String name) {
              return "real " + name;
          }
      }
  
      public interface Auditable {
          String audit(String name);
      }
  }
