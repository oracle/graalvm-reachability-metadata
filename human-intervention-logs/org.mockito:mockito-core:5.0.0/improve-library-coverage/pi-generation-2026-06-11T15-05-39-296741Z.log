  package org_mockito.mockito_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.mockito.ArgumentMatchers.anyInt;
  import static org.mockito.ArgumentMatchers.anyString;
  import static org.mockito.ArgumentMatchers.eq;
  import static org.mockito.Mockito.mock;
  import static org.mockito.Mockito.verify;
  import static org.mockito.Mockito.when;
  import static org.mockito.Mockito.withSettings;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.mockito.ArgumentCaptor;
  import org.mockito.Mock;
  import org.mockito.MockMakers;
  import org.mockito.Mockito;
  import org.mockito.MockitoSession;
  import org.mockito.quality.Strictness;
  
  public class InlineDelegateByteBuddyMockMakerTest {
      @Mock(mockMaker = MockMakers.INLINE)
      InlineOrderService annotatedService;
  
      @Test
      void createsConcreteMockWithInlineMockMakerAndCustomAnswer() {
          try {
              InlineOrderService service =
                      mock(InlineOrderService.class, withSettings().mockMaker(MockMakers.INLINE));
  
              when(service.price(anyString(), anyInt()))
                      .thenAnswer(
                              invocation -> {
                                  String sku = invocation.getArgument(0);
                                  int quantity = invocation.getArgument(1);
                                  return "premium".equals(sku) ? quantity * 25 : quantity * 10;
                              });
  
              assertThat(service.price("premium", 3)).isEqualTo(75);
              assertThat(service.price("standard", 4)).isEqualTo(40);
  
              ArgumentCaptor<String> skuCaptor = ArgumentCaptor.forClass(String.class);
              verify(service).price(skuCaptor.capture(), eq(3));
              assertThat(skuCaptor.getValue()).isEqualTo("premium");
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void initializesAnnotatedConcreteInlineMockInMockitoSession() {
          try {
              MockitoSession session =
                      Mockito.mockitoSession()
                              .initMocks(this)
                              .strictness(Strictness.STRICT_STUBS)
                              .startMocking();
              try {
                  when(annotatedService.describe("standard")).thenReturn("mocked standard order");
  
                  assertThat(annotatedService.describe("standard"))
                          .isEqualTo("mocked standard order");
                  verify(annotatedService).describe("standard");
              } finally {
                  session.finishMocking();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      public static class InlineOrderService {
          private final String source;
          private final int basePrice;
  
          public InlineOrderService(String source, int basePrice) {
              this.source = source == null ? "default" : source;
              this.basePrice = basePrice;
          }
  
          public int price(String sku, int quantity) {
              return basePrice + sku.length() + quantity;
          }
  
          public String describe(String sku) {
              return source + " " + sku;
          }
      }
  }
