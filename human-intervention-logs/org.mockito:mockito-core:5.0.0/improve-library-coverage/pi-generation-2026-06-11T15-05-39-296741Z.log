[tool-call] delta {"path":"tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/SubclassInjectionLoaderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.mockito.ArgumentMatchers.eq;\nimport static org.mockito.Mockito.mock;\nimport static org.mockito.Mockito.verify;\nimport static org.mockito.Mockito.when;\nimport static org.mockito.Mockito.withSettings;\n\nimport org.junit.jupiter.api.Test;\nimport org.mockito.ArgumentCaptor;\nimport org.mockito.MockMakers;\n\npublic class SubclassInjectionLoaderTest {\n    @Test\n    void createsConcreteClassMockWithStubbingVerificationAndCaptor() {\n        OrderService service = mock(OrderService.class, withSettings().mockMaker(MockMakers.SUBCLASS));\n\n        when(service.describe(eq(\"book\"), eq(3))).thenReturn(\"mocked book x3\");\n\n        assertThat(service.describe(\"book\", 3)).isEqualTo(\"mocked book x3\");\n\n        ArgumentCaptor<String> itemCaptor = ArgumentCaptor.forClass(String.class);\n        verify(service).describe(itemCaptor.capture(), eq(3));\n        assertThat(itemCaptor.getValue()).isEqualTo(\"book\");\n    }\n\n    @Test\n    void usesCustomAnswerForConcreteClassMock() {\n        PricingService service = mock(PricingService.class, withSettings().mockMaker(MockMakers.SUBCLASS));\n\n        when(service.total(eq(\"premium\"), eq(4)))\n                .thenAnswer(\n                        invocation -> {\n                            String tier = invocation.getArgument(0);\n                            int quantity = invocation.getArgument(1);\n                            return tier.length() * quantity;\n                        });\n\n        assertThat(service.total(\"premium\", 4)).isEqualTo(28);\n        verify(service).total(\"premium\", 4);\n    }\n\n    public static class OrderService {\n        public String describe(String item, int quantity) {\n            return item + \" x\" + quantity;\n        }\n    }\n\n    public static class PricingService {\n        public int total(String tier, int quantity) {\n            return tier.length() + quantity;\n        }\n    }\n}\n"}
