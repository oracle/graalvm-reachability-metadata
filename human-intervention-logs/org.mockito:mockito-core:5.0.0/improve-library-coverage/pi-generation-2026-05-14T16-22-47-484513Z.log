  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.Mockito;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MockitoTest {
      @Test
      void test() {
          MyService myService = Mockito.mock(MyService.class);
          Mockito.when(myService.getGreeting()).thenReturn("Hello Mockito");
          assertThat(myService.getGreeting()).isEqualTo("Hello Mockito");
      }
  }
[tool-exec] end id=call_Oe2pDsY17454S42ylnlhlkd9|fc_08ed1f2dc4e07dfc016a05f678dbf8819581da6a7404f4e798 name=read status=success
  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_mockito.mockito_core;
  
  import org.junit.jupiter.api.Test;
  import org.mockito.AdditionalAnswers;
  import org.mockito.InjectMocks;
  import org.mockito.Mock;
  import org.mockito.Mockito;
  import org.mockito.MockitoAnnotations;
  import org.mockito.internal.util.reflection.ModuleMemberAccessor;
  import org.mockito.plugins.MemberAccessor;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class InstrumentationMemberAccessorTest {
      @Mock
      private MyService service;
  
      @InjectMocks
      private Subject subject;
  
      @Test
      void initializesAndInjectsFieldsThroughMockitoAnnotations() throws Exception {
          try (AutoCloseable mocks = MockitoAnnotations.openMocks(this)) {
              Mockito.when(service.getGreeting()).thenReturn("injected");
  
              assertThat(subject.greeting()).isEqualTo("hello injected");
          }
      }
  
      @Test
      void invokesDelegatedMethodsThroughMockitoAnswer() {
          MyService mock =
                  Mockito.mock(
                          MyService.class,
                          AdditionalAnswers.delegatesTo((MyService) () -> "delegated"));
  
          assertThat(mock.getGreeting()).isEqualTo("delegated");
      }
  
      @Test
      void accessesMembersThroughModuleMemberAccessor() throws Exception {
          MemberAccessor accessor = new ModuleMemberAccessor();
  
          Constructor<SampleComponent> constructor =
                  SampleComponent.class.getDeclaredConstructor(String.class);
          SampleComponent component = (SampleComponent) accessor.newInstance(constructor, "alpha");
  
          Method greeting = SampleComponent.class.getDeclaredMethod("greeting", String.class);
          assertThat(accessor.invoke(greeting, component, "hello")).isEqualTo("hello alpha");
  
          Field message = SampleComponent.class.getDeclaredField("message");
          assertThat(accessor.get(message, component)).isEqualTo("alpha");
  
          accessor.set(message, component, "beta");
          assertThat(accessor.get(message, component)).isEqualTo("beta");
          assertThat(accessor.invoke(greeting, component, "hello")).isEqualTo("hello beta");
      }
  
      private static class Subject {
          private MyService service;
  
          private String greeting() {
              return "hello " + service.getGreeting();
          }
      }
  
      private static class SampleComponent {
          private String message;
  
          private SampleComponent(String message) {
              this.message = message;
          }
  
          private String greeting(String prefix) {
              return prefix + " " + message;
          }
      }
  }
