      @Override
      public TypeMockability isTypeMockable(Class<?> type) {
          return new TypeMockability() {
              @Override
              public boolean mockable() {
                  return type.isInterface() || type == Object.class;
              }
  
              @Override
              public String nonMockableReason() {
