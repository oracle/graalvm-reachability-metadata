();\n\n        void disable();\n    }\n\n    interface ConstructionMockControl<T> {\n\n        Class<T> getType();\n\n        void enable();\n\n        void disable();\n\n        List<T> getMocks();\n    }\n}\n"}], "isError": false, "timestamp": 1780600879706}]}
