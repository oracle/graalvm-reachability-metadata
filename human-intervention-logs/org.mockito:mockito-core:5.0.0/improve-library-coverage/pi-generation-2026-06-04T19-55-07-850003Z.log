      }
  
      @Test
      void test() {
          MyService myService = Mockito.mock(MyService.class);
          Mockito.when(myService.getGreeting()).thenReturn("Hello Mockito");
          assertThat(myService.getGreeting()).isEqualTo("Hello Mockito");
      }
  }
