rivate static final String HIDDEN_PACKAGE = \\\"sample.hidden\\\";\\n    private static final String HIDDEN_TYPE_NAME = HIDDEN_PACKAGE + \\\".HiddenService\\\";\\n    private static final String HIDDEN_TYPE_RESOURCE = \\\"sample/hidden/HiddenService.class\\\";\\n\", \"newText\": \"    private static final String HIDDEN_MODULE_NAME = \\\"mockito.test.hidden.module\\\";\\n    private static final String EXTRA_INTERFACE_MODULE_NAME = \\\"mockito.test.extra.module\\\";\\n    private static final String HIDDEN_PACKAGE = \\\"sample.hidden\\\";\\n    private static final String EXTRA_INTERFACE_PACKAGE = \\\"sample.extra\\\";\\n    private static final String HIDDEN_TYPE_NAME = HIDDEN_PACKAGE + \\\".HiddenService\\\";\\n    private static final String EXTRA_INTERFACE_TYPE_NAME =\\n            EXTRA_INTERFACE_PACKAGE + \\\".ExtraService\\\";\\n    private static final String HIDDEN_TYPE_RESOURCE = \\\"sample/hidden/HiddenService.class\\\";\\n    private static final String EXTRA_INTERFACE_RESOURCE = \\\"sample/extra/ExtraService.class\\\";\\n\"}, {\"oldText\": \"            Object mock = mockHiddenTypeFromNamedModule();\\n\\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\\n\", \"newText\": \"            Object mock = mockHiddenTypeFromNamedModuleWithExtraInterface();\\n\\n            assertThat(Mockito.mockingDetails(mock).isMock()).isTrue();\\n            assertThat(loadExtraInterfaceFromMock(mock).isInstance(mock)).isTrue();\\n\"}, {\"oldText\": \"    private static Object mockHiddenTypeFromNamedModule() throws Exception {\\n        Class<?> hiddenType = loadHiddenTypeFromNamedModule();\\n\\n        assertThat(hiddenType.getModule().isNamed()).isTrue();\\n        assertThat(hiddenType.getModule().isExported(HIDDEN_PACKAGE)).isFalse();\\n\\n        return Mockito.mock(hiddenType, withSettings().mockMaker(MockMakers.SUBCLASS));\\n    }\\n\\n    private static Class<?> loadHiddenTypeFromNamedModule() throws ClassNotFoundException {\\n        ModuleLay