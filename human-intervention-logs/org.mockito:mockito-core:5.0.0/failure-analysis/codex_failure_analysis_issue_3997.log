t;\\n\\n        public ConstructedGreeting(String name, int repeats, GreetingFormat format) {\\n            this.name = name;\\n            this.repeats = repeats;\\n            this.format = format;\\n        }\\n\\n        public String message() {\\n            return format.prefix() + \\\" \\\" + name + \\\" \\\".repeat(repeats).trim();\\n        }\\n    }\\n\\n    public record GreetingFormat(String prefix) {}\\n\\n    private static class InlineMockMakerClassLoader extends URLClassLoader {\\n        InlineMockMakerClassLoader(URL[] urls) {\\n            super(urls, ClassLoader.getPlatformClassLoader());\\n        }\\n\\n        @Override\\n        public URL getResource(String name) {\\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\\n                return null;\\n            }\\n            return super.getResource(name);\\n        }\\n\\n        @Override\\n        public Enumeration<URL> getResources(String name) throws IOException {\\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\\n                return Collections.emptyEnumeration();\\n            }\\n            return super.getResources(name);\\n        }\\n\\n        @Override\\n        public InputStream getResourceAsStream(String name) {\\n            if (MOCK_MAKER_EXTENSION.equals(name)) {\\n                return null;\\n            }\\n            return super.getResourceAsStream(name);\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            if (isChildLoadedClass(name)) {\\n                synchronized (getClassLoadingLock(name)) {\\n                    Class<?> loaded = findLoadedClass(name);\\n                    if (loaded == null) {\\n                        try {\\n                            loaded = findClass(name);\\n                        } catch (ClassNotFoundException ignored) {\\n                            loaded = super.loadClass(name, false);\\n                        }\\n                    }\\n                    if (resolve) {\\n                        resolveClass(loaded);\\n                    }\\n                    return loaded;\\n                }\\n            }\\n            return super.loadClass(name, resolve);\\n        }\\n\\n        private static boolean isChildLoadedClass(String name) {\\n            return name.startsWith(\\\"org.mockito.\\\")\\n                    || name.startsWith(\\\"net.bytebuddy.\\\")\\n                    || name.startsWith(\\\"org.objenesis.\\\")\\n                    || name.startsWith(\\n                            \\\"org_mockito.mockito_core.\\\"\\n                                    + \\\"InlineDelegateByteBuddyMockMakerInner\\\"\\n                                    + \\\"InlineConstructionMockContextTest\\\");\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_32\",\"type\":\"command_execution\",\"command\":\"/usr/bin/zsh -lc \\\"sed -n '1,220p' tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/PluginInitializerTest.java\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_32\",\"type\":\"command_execution\",\"command\":\"/usr/bin/zsh -lc \\\"sed -n '1,220p' tests/src/org.mockito/mockito-core/5.0.0/src/test/java/org_mockito/mockito_core/PluginInitializerTest.java\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_mockito.mockito_core;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.mockito.Mockito;\\nimport org.mockito.plugins.MockResolver;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.mockito.Mockito.verify;\\nimport static org.mockito.Mockito.when;\\n\\npub