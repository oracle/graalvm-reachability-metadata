FACE_MODULE_NAME));\\n        return parent.defineModulesWithManyLoaders(\\n                configuration, ClassLoader.getSystemClassLoader());\\n    }\\n\\n    private static Error findUnsupportedFeatureError(Throwable throwable) {\\n        Throwable current = throwable;\\n        while (current != null) {\\n            if (current instanceof Error\\n                    && NativeImageSupport.isUnsupportedFeatureError((Error) current)) {\\n                return (Error) current;\\n            }\\n            current = current.getCause();\\n        }\\n        return null;\\n    }\\n\\n    private static final class InMemoryModuleFinder implements ModuleFinder {\\n        private final Map<String, ModuleReference> modules;\\n\\n        private InMemoryModuleFinder() {\\n            ModuleDescriptor hiddenDescriptor =\\n                    ModuleDescriptor.newModule(HIDDEN_MODULE_NAME)\\n                            .packages(Set.of(HIDDEN_PACKAGE))\\n                            .build();\\n            ModuleDescriptor extraInterfaceDescriptor =\\n                    ModuleDescriptor.newModule(EXTRA_INTERFACE_MODULE_NAME)\\n                            .exports(EXTRA_INTERFACE_PACKAGE)\\n                            .build();\\n\\n            modules =\\n                    Map.of(\\n                            HIDDEN_MODULE_NAME,\\n                            new InMemoryModuleReference(\\n                                    hiddenDescriptor, hiddenModuleResources()),\\n                            EXTRA_INTERFACE_MODULE_NAME,\\n                            new InMemoryModuleReference(\\n                                    extraInterfaceDescriptor,\\n                                    Map.of(EXTRA_INTERFACE_RESOURCE, extraInterfaceBytes())));\\n        }\\n\\n        @Override\\n        public Optional<ModuleReference> find(String name) {\\n            return Optional.ofNullable(modules.get(name));\\n        }\\n\\n        @Override\\n        public Set<ModuleReference> findAll() {\\n            return Set.copyOf(modules.values());\\n        }\\n    }\\n\\n    private static Map<String, byte[]> hiddenModuleResources() {\\n        Map<String, byte[]> resources = new HashMap<>();\\n        resources.put(HIDDEN_TYPE_RESOURCE, hiddenServiceBytes());\\n        resources.put(injectionBaseCollisionResource(), injectionBaseCollisionBytes());\\n        return Map.copyOf(resources);\\n    }\\n\\n    private static String injectionBaseCollisionResource() {\\n        return HIDDEN_PACKAGE.replace('.', '/')\\n                + \\\"/InjectionBase$\\\"\\n                + injectionBaseSuffix()\\n                + \\\".class\\\";\\n    }\\n\\n    private static int injectionBaseSuffix() {\\n        return Math.abs(Mockito.class.hashCode());\\n    }\\n\\n    private static byte[] hiddenServiceBytes() {\\n        return new ByteBuddy()\\n                .subclass(Object.class)\\n                .name(HIDDEN_TYPE_NAME)\\n                .modifiers(Visibility.PUBLIC)\\n                .defineMethod(\\\"greeting\\\", String.class, Visibility.PUBLIC)\\n                .intercept(FixedValue.value(\\\"real\\\"))\\n                .make()\\n                .getBytes();\\n    }\\n\\n    private static byte[] injectionBaseCollisionBytes() {\\n        return new ByteBuddy()\\n                .subclass(Object.class)\\n                .name(HIDDEN_PACKAGE + \\\".InjectionBase$\\\" + injectionBaseSuffix())\\n                .modifiers(Visibility.PUBLIC)\\n                .make()\\n                .getBytes();\\n    }\\n\\n    private static byte[] extraInterfaceBytes() {\\n        return new ByteBuddy()\\n                .makeInterface()\\n                .name(EXTRA_INTERFACE_TYPE_NAME)\\n                .modifiers(Visibility.PUBLIC)\\n                .make()\\n                .getBytes();\\n    }\\n\\n    private static final class InMemoryModuleReference extends ModuleReference {\\n        private final Map<String, byte[]> resources;\\n\\n        private InM