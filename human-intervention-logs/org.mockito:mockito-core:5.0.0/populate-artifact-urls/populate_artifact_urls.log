for v in "$versions[@]"; do
  url="https://github.com/mockito/mockito/tree/v$v"
  code=$(curl -L -s -o /dev/null -w '"'%{http_code}' \""'$url")
  if [ "$code" != "200" ]; then
    echo "$v $code $url"
    bad=1
  fi
done
