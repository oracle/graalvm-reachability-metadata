Console\"))\n116:    val specError: String = TerminalRendering.missingLayersForZIOSpec(Set(\"zio.Clock\", \"zio.Random\"))\n117:    val customError: String = TerminalRendering.missingLayersCustomError(Set(\"example.Service\"), \"workflow\", \"CUSTOM ERROR\")\n136:    val unusedLayers: String = TerminalRendering.unusedLayersError(List(\"Clock.live\", \"Console.test\"))\n137:    val unusedProvideSomeTypes: String = TerminalRendering.unusedProvideSomeLayersError(List(\"java.lang.String\"))\n138:    val provideSomeNothingEnv: String = TerminalRendering.provideSomeNothingEnvError\n139:    val superfluousProvideCustom: String = TerminalRendering.superfluousProvideCustomError\n162:    val ambiguous: String = TerminalRendering.ambiguousLayersError(\n168:    val circular: String = TerminalRendering.circularityError(List(\"Database.live\" -> \"UserService.live\"))\n188:    val rendered: String = TerminalRendering.ambiguousLayersError(\n203:    val rendered: String = TerminalRendering.byNameParameterInMacroError(\n220:    val rendered: String = TerminalRendering.byNameParameterInMacroError(\n238:    val missingTransitive: LayerWiringError.MissingTransitive =\n239:      LayerWiringError.MissingTransitive(\"UserService.live\", List(\"zio.Console\", \"zio.Random\"))\n247:    assertThat(missingTransitive.layer).isEqualTo(\"UserService.live\")\n248:    assertThat(missingTransitive.deps).isEqualTo(List(\"zio.Console\", \"zio.Random\"))\n249:    assertThat(missingTransitive.copy(deps = List(\"zio.Clock\"))).isEqualTo(\n250:      LayerWiringError.MissingTransitive(\"UserService.live\", List(\"zio.Clock\"))\n252:    assertThat(missingTransitive.productElementName(1)).isEqualTo(\"deps\")\n267:      TerminalRendering.main(Array.empty)\n281:  def ansiCodeSingletonsAndLayerWiringErrorsCanBePatternMatched(): Unit = {\n298:      LayerWiringError.MissingTransitive(\"B\", List(\"C\", \"D\")),\n302:      case LayerWiringError.MissingTransitive(layer, ds) => s\"transitive:$layer:${ds.mkString(\",\")}\"\n308:    assertThat(wiringDescriptions).isEqualTo(List(\"missing:A\", \"transitive:B:C,D\", \"circular:E:F\"))\n"}], "isError": false, "timestamp": 1778019879636}]}
