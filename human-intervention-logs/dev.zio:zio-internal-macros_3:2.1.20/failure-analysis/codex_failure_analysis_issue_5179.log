t\": [{\"type\": \"text\", \"text\": \"tests/src/dev.zio/zio-internal-macros_3/2.1.15/src/test/scala/dev_zio/zio_internal_macros_3/Zio_internal_macros_3Test.scala\\n14:import zio.internal.TerminalRendering\\n15:import zio.internal.TerminalRendering.LayerWiringError\\n16:import zio.internal.TerminalRendering.*\\n17:import zio.internal.ansi.*\\n19:class Zio_internal_macros_3Test {\\n21:  def ansiCodesAndStringExtensionsApplyExpectedTerminalEscapes(): Unit = {\\n68:    assertThat(TerminalRendering.pluralize(0, \\\"type\\\", \\\"types\\\")).isEqualTo(\\\"0 types\\\")\\n69:    assertThat(TerminalRendering.pluralize(1, \\\"type\\\", \\\"types\\\")).isEqualTo(\\\"type\\\")\\n70:    assertThat(TerminalRendering.pluralize(2, \\\"type\\\", \\\"types\\\")).isEqualTo(\\\"2 types\\\")\\n71:    assertThat(TerminalRendering.pluralizeLayers(1)).isEqualTo(\\\"layer\\\")\\n72:    assertThat(TerminalRendering.pluralizeLayers(3)).isEqualTo(\\\"3 layers\\\")\\n73:    assertThat(TerminalRendering.pluralizeTypes(1)).isEqualTo(\\\"type\\\")\\n74:    assertThat(TerminalRendering.pluralizeTypes(4)).isEqualTo(\\\"4 types\\\")\\n78:  def missingLayerRendererIncludesTopLevelTransitiveAndProvideSomeGuidance(): Unit = {\\n79:    val rendered: String = TerminalRendering.missingLayersError(\\n81:      transitive = Map(\\\"UserService.live\\\" -> List(\\\"zio.Console\\\", \\\"example.Repository\\\")),\\n99:    val withoutProvideSome: String = TerminalRendering.missingLayersError(\\n101:      transitive = Map.empty,\\n104:    val withDefaults: String = TerminalRendering.missingLayersError(List(\\\"zio.Random\\\"))\\n114:  def customMissingLayerRenderersDescribeZioAppAndSpecFailures(): Unit = {\\n115:    val appError: String = TerminalRendering.missingLayersForZIOApp(Set(\\\"zio.Console\\\"))\\n116:    val specError: String = TerminalRendering.missingLayersForZIOSpec(Set(\\\"zio.Clock\\\", \\\"zio.Random\\\"))\\n117:    val customError: String = TerminalRendering.missingLayersCustomError(Set(\\\"examp