")\n                .contains(\"mode\")\n                .contains(\"labels\");\n    }\n\n    @Target(ElementType.TYPE)\n    @Retention(RetentionPolicy.RUNTIME)\n    private @interface SampleAnnotation {\n        String value() default \"default-value\";\n\n        int number() default 1;\n\n        Class<?> targetType() default Object.class;\n\n        SampleMode mode() default SampleMode.DEFAULT;\n\n        String[] labels() default {};\n    }\n\n    private enum SampleMode {\n        DEFAULT,\n        ENABLED\n    }\n\n    private static final class SampleAnnotationLiteral implements SampleAnnotation {\n        @Override\n        public String value() {\n            return \"copied-value\";\n        }\n\n        @Override\n        public int number() {\n            return 42;\n        }\n\n        @Override\n        public Class<?> targetType() {\n            return String.class;\n        }\n\n        @Override\n        public SampleMode mode() {\n            return SampleMode.ENABLED;\n        }\n\n        @Override\n        public String[] labels() {\n            return new String[] { \"alpha\", \"beta\" };\n        }\n\n        @Override\n        public Class<? extends Annotation> annotationType() {\n            return SampleAnnotation.class;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 667, "output": 833, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 38364, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777790846794, "responseId": "resp_041b44b396a3a6480169f6ef7f4a30819e855e462ca7d8814c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_7WE85WtukoVZxXBv7WYvMYyg|fc_041b44b396a3a6480169f6ef82b4ac819e97da0c4fcde440b7", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2633 bytes to tests/src/io.quarkus.gizmo/gizmo2/2.0.0.Beta10/src/test/java/io_quarkus_gizmo/gizmo2/AnnotationCrea