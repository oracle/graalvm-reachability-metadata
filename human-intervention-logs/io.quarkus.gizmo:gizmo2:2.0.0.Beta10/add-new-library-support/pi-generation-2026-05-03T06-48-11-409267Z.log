[tool-call] delta {"path":"tests/src/io.quarkus.gizmo/gizmo2/2.0.0.Beta10/src/test/java/io_quarkus_gizmo/gizmo2/AnnotationCreatorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus_gizmo.gizmo2;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.annotation.Annotation;\nimport java.lang.annotation.ElementType;\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\nimport java.lang.annotation.Target;\nimport java.nio.charset.StandardCharsets;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\n\nimport io.quarkus.gizmo2.Gizmo;\n\npublic class AnnotationCreatorTest {\n    @Test\n    void copiesValuesFromAnnotationInstance() {\n        Map<String, byte[]> generatedClasses = new LinkedHashMap<>();\n        Gizmo.create(generatedClasses::put).class_(\"io.quarkus.gizmo2.generated.AnnotationCopyTarget\",\n                classCreator -> classCreator.addAnnotation(new SampleAnnotationLiteral()));\n\n        byte[] classBytes = generatedClasses.get(\"io/quarkus/gizmo2/generated/AnnotationCopyTarget.class\");\n        assertThat(classBytes).isNotNull();\n\n        String classFileText = new String(classBytes, StandardCharsets.ISO_8859_1);\n        assertThat(classFileText)\n                .contains(\"copied-value\")\n                .contains(\"number\")\n                .contains(\"targetType\")\n                .contains(\"mode\")\n                .contains(\"labels\");\n    }\n\n    @Target(ElementType.TYPE)\n    @Retention(RetentionPolicy.RUNTIME)\n    private @interface SampleAnnotation {\n        String value() default \"default-value\";\n\n        int number() default 1;\n\n        Class<?> targetType() default Object.class;\n\n        SampleMode mode() default SampleMode.DEFAULT;\n\n        String[] labels() default {};\n    }\n\n    private enum SampleMode {\n        DEFAULT,\n        ENABLED\n    }\n\n    private static final class SampleAnnotationLiteral implements SampleAnnotation {\n        @Override\n        public String value() {\n            return \"copied-value\";\n        }\n\n        @Override\n        public int number() {\n            return 42;\n        }\n\n        @Override\n        public Class<?> targetType() {\n            return String.class;\n        }\n\n        @Override\n        public SampleMode mode() {\n            return SampleMode.ENABLED;\n        }\n\n        @Override\n        public String[] labels() {\n            return new String[] { \"alpha\", \"beta\" };\n        }\n\n        @Override\n        public Class<? extends Annotation> annotationType() {\n            return SampleAnnotation.class;\n        }\n    }\n}\n"}
