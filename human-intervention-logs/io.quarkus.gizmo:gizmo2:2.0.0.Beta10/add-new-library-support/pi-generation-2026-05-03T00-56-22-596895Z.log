  new file mode 100644
  index 0000000000..e4af34943b
  --- /dev/null
  +++ 2/tests/src/io.quarkus.gizmo/gizmo2/2.0.0.Beta10/src/test/java/io_quarkus_gizmo/gizmo2/AnnotationCreatorTest.java
  @@ -0,0 +1,92 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package io_quarkus_gizmo.gizmo2;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +import java.lang.annotation.Annotation;
  +import java.lang.annotation.ElementType;
  +import java.lang.annotation.Retention;
  +import java.lang.annotation.RetentionPolicy;
  +import java.lang.annotation.Target;
  +import java.util.LinkedHashMap;
  +import java.util.Map;
  +
  +import org.junit.jupiter.api.Test;
  +
  +import io.quarkus.gizmo2.ClassOutput;
  +import io.quarkus.gizmo2.Gizmo;
  +
  +public class AnnotationCreatorTest {
  +    @Test
  +    void copiesAnnotationInstanceElementsOntoGeneratedClass() {
  +        Map<String, byte[]> generatedClasses = new LinkedHashMap<>();
  +        ClassOutput output = generatedClasses::put;
  +
  +        Gizmo.create(output).class_("example.GeneratedWithCopiedAnnotation", classCreator -> {
  +            classCreator.addAnnotation(exampleAnnotation());
  +        });
  +
  +        assertThat(generatedClasses)
  +                .containsKey("example/GeneratedWithCopiedAnnotation.class");
  +        assertThat(generatedClasses.get("example/GeneratedWithCopiedAnnotation.class"))
  +                .isNotEmpty();
  +    }
  +
  +    private static ExampleAnnotation exampleAnnotation() {
  +        return new ExampleAnnotation() {
  +            @Override
  +            public String value() {
  +                return "copied-from-instance";
  +            }
  +
  +            @Override
  +            public int priority() {
  +                return 7;
  +            }
  +
  +            @Override
  +            public Class<?> targetType() {
  +                return Map.class;
  +            }
  +
  +            @Override
  +            public ExampleMode mode() {
  +                return ExampleMode.SLOW;
  +            }
  +
  +            @Override
  +            public String[] tags() {
  +                return new String[] { "alpha", "beta" };
  +            }
  +
  +            @Override
  +            public Class<? extends Annotation> annotationType() {
  +                return ExampleAnnotation.class;
  +            }
  +        };
  +    }
  +
  +    @Target(ElementType.TYPE)
  +    @Retention(RetentionPolicy.RUNTIME)
  +    public @interface ExampleAnnotation {
  +        String value();
  +
  +        int priority() default 1;
  +
  +        Class<?> targetType();
  +
  +        ExampleMode mode();
  +
  +        String[] tags();
  +    }
  +
  +    public enum ExampleMode {
  +        FAST,
  +        SLOW
  +    }
  +}
