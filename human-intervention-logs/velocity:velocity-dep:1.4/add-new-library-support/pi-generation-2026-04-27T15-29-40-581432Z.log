                          Node lineNode = lineNodes.item(k);
                          if (!(lineNode instanceof Element lineElement) || !"line".equals(lineElement.getTagName())) {
                              continue;
                          }
                          int coveredInstructions = Integer.parseInt(lineElement.getAttribute("ci"));
