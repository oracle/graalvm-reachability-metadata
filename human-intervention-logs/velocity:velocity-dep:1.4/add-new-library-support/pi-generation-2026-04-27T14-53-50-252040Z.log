                  !isMatch(RESULTS_DIR,COMPARE_DIR,"book","txt","txt") ||
                  !isMatch(RESULTS_DIR,COMPARE_DIR,"Test","txt","txt"))
              {
                  fail("Output is incorrect!");
              }
          }            
          catch(Exception e)
          {
              /*
               * do nothing.
               */
          }
      }
  }
