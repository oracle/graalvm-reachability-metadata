  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "velocity:velocity-dep:$libraryVersion"
      testImplementation 'org.apache.ant:ant:1.10.14'
      testImplementation 'junit:junit:4.13.2'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      binaries {
          all {
              buildArgs.add('--initialize-at-run-time=org.apache.velocity.test.IntrospectorTestCase')
              buildArgs.add('--initialize-at-run-time=org.apache.velocity.test.IntrospectorTestCase2')
              buildArgs.add('--initialize-at-run-time=org.apache.velocity.test.IntrospectorTestCase3')
              buildArgs.add('--initialize-at-run-time=org.apache.velocity.test.ParserTestCase')
              buildArgs.add('--initialize-at-run-time=org.apache.velocity.texen.Generator')
              buildArgs.add('--initialize-at-run-time=org.apache.log.format.ExtendedPatternFormatter')
          }
      }
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
