[tool-call] delta {"path":"tests/src/org.apache.hadoop/hadoop-yarn-common/2.2.0/src/test/java/org_apache_hadoop/hadoop_yarn_common/SerializedExceptionPBImplTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_yarn_common;\n\nimport java.io.IOException;\n\nimport org.apache.hadoop.yarn.api.records.impl.pb.SerializedExceptionPBImpl;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SerializedExceptionPBImplTest {\n    @Test\n    void deserializeRecreatesExceptionAndCause() {\n        IllegalArgumentException cause = new IllegalArgumentException(\"invalid container id\");\n        IOException original = new IOException(\"container status lookup failed\", cause);\n        SerializedExceptionPBImpl serialized = new SerializedExceptionPBImpl();\n\n        serialized.init(original);\n\n        Throwable deserialized = serialized.deSerialize();\n        assertThat(deserialized)\n                .isInstanceOf(IOException.class)\n                .hasMessage(\"container status lookup failed\")\n                .hasCauseInstanceOf(IllegalArgumentException.class);\n        assertThat(deserialized.getCause()).hasMessage(\"invalid container id\");\n    }\n}\n"}
