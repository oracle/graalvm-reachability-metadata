      public WebApp start() {
        return start(null);
      }
  
      private String inferHostClass() {
        String thisClass = this.getClass().getName();
        Throwable t = new Throwable();
        for (StackTraceElement e : t.getStackTrace()) {
          if (e.getClassName().equals(thisClass)) continue;
