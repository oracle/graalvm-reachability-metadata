[tool-call] delta {"path":"tests/src/org.apache.hadoop/hadoop-yarn-common/2.2.0/src/test/java/org_apache_hadoop/hadoop_yarn_common/RouterTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_hadoop.hadoop_yarn_common;\n\nimport org.apache.hadoop.conf.Configuration;\nimport org.apache.hadoop.yarn.webapp.Controller;\nimport org.apache.hadoop.yarn.webapp.View;\nimport org.apache.hadoop.yarn.webapp.WebApp;\nimport org.apache.hadoop.yarn.webapp.WebApps;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RouterTest {\n    @Test\n    void webAppSetupRegistersControllerRouteAndLoadsDefaultView() {\n        WebApp webApp = null;\n        try {\n            webApp = WebApps.$for(\"router\", RouterApplication.class, new RouterApplication())\n                    .at(\"127.0.0.1\", 0, true)\n                    .with(new Configuration(false))\n                    .start(new RoutedWebApp());\n\n            assertThat(webApp.name()).isEqualTo(\"router\");\n            assertThat(webApp.getServePathSpecs()).contains(\"/router\", \"/router/*\");\n        } finally {\n            if (webApp != null) {\n                webApp.stop();\n            }\n        }\n    }\n\n    public static final class RouterApplication {\n    }\n\n    public static final class RoutedWebApp extends WebApp {\n        @Override\n        public void setup() {\n            route(\"/sample\", SampleController.class);\n        }\n    }\n\n    public static final class SampleController extends Controller {\n        @Override\n        public void index() {\n        }\n    }\n}\n\nfinal class SampleView extends View {\n    @Override\n    public void render() {\n    }\n}\n"}
