r;\nimport org.apache.hadoop.yarn.webapp.View;\nimport org.apache.hadoop.yarn.webapp.WebApp;\nimport org.apache.hadoop.yarn.webapp.WebApps;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RouterTest {\n    @Test\n    void webAppSetupRegistersControllerRouteAndLoadsDefaultView() {\n        WebApp webApp = null;\n        try {\n            webApp = WebApps.$for(\"router\", RouterApplication.class, new RouterApplication())\n                    .at(\"127.0.0.1\", 0, true)\n                    .with(new Configuration(false))\n                    .start(new RoutedWebApp());\n\n            assertThat(webApp.name()).isEqualTo(\"router\");\n            assertThat(webApp.getServePathSpecs()).contains(\"/router\", \"/router/*\");\n        } finally {\n            if (webApp != null) {\n                webApp.stop();\n            }\n        }\n    }\n\n    public static final class RouterApplication {\n    }\n\n    public static final class RoutedWebApp extends WebApp {\n        @Override\n        public void setup() {\n            route(\"/sample\", SampleController.class);\n        }\n    }\n\n    public static final class SampleController extends Controller {\n        @Override\n        public void index() {\n        }\n    }\n}\n\nfinal class SampleView extends View {\n    @Override\n    public void render() {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 576, "output": 995, "cacheRead": 22016, "cacheWrite": 0, "totalTokens": 23587, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778278924445, "responseId": "resp_02c16e12487490200169fe620d222c819c872d1237fd35d8ce"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_XB1uuJlNDIC5QesXavRpCdef|fc_02c16e12487490200169fe6216ccb4819cb9f9c384329d274c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1680