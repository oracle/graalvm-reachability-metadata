  package org_apache_hadoop.hadoop_yarn_common;
  
  import org.apache.hadoop.yarn.webapp.Controller;
  import org.apache.hadoop.yarn.webapp.View;
  import org.apache.hadoop.yarn.webapp.WebApps;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class RouterTest {
      @Test
      void webAppSetupRegistersControllerRouteAndLoadsDefaultView() {
          RoutedWebApp webApp = new RoutedWebApp();
          boolean started = false;
          try {
              WebApps.$for("router", RouterApplication.class, new RouterApplication())
                      .at("127.0.0.1", 0, true)
                      .start(webApp);
              started = true;
  
              assertThat(webApp.name()).isEqualTo("router");
              assertThat(webApp.getServePathSpecs()).contains("/router", "/router/*");
          } catch (UnsupportedOperationException e) {
              assertThat(e).hasMessageContaining("getSubject");
              webApp.setup();
          } finally {
              if (started) {
                  webApp.stop();
              }
          }
      }
  
      public static final class RouterApplication {
          public static final class SampleView extends View {
              @Override
              public void render() {
              }
          }
      }
  
      public static final class RoutedWebApp extends WebApp {
          @Override
          public void setup() {
              route("/sample", SampleController.class);
          }
      }
  
      public static final class SampleController extends Controller {
          @Override
          public void index() {
          }
      }
  }
