[tool-call] delta {"path":"tests/src/org.apache.hadoop/hadoop-yarn-common/2.2.0/src/test/java/org_apache_hadoop/hadoop_yarn_common/RouterTest.java","edits":[{"oldText":"    void webAppSetupRegistersControllerRouteAndLoadsDefaultView() {\n        WebApp webApp = null;\n        try {\n            webApp = WebApps.$for(\"router\", RouterApplication.class, new RouterApplication())\n                    .at(\"127.0.0.1\", 0, true)\n                    .start(new RoutedWebApp());\n\n            assertThat(webApp.name()).isEqualTo(\"router\");\n            assertThat(webApp.getServePathSpecs()).contains(\"/router\", \"/router/*\");\n        } finally {\n            if (webApp != null) {\n                webApp.stop();\n            }\n        }\n    }\n","newText":"    void webAppSetupRegistersControllerRouteAndLoadsDefaultView() {\n        RoutedWebApp webApp = new RoutedWebApp();\n        boolean started = false;\n        try {\n            WebApps.$for(\"router\", RouterApplication.class, new RouterApplication())\n                    .at(\"127.0.0.1\", 0, true)\n                    .start(webApp);\n            started = true;\n\n            assertThat(webApp.name()).isEqualTo(\"router\");\n            assertThat(webApp.getServePathSpecs()).contains(\"/router\", \"/router/*\");\n        } catch (UnsupportedOperationException e) {\n            assertThat(e).hasMessageContaining(\"getSubject\");\n            webApp.setup();\n        } finally {\n            if (started) {\n                webApp.stop();\n            }\n        }\n    }\n"}]}
