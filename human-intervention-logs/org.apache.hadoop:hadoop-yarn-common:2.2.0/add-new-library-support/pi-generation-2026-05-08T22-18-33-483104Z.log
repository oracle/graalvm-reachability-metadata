  package org_apache_hadoop.hadoop_yarn_common;
  
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.apache.hadoop.yarn.webapp.hamlet.HamletGen;
  import org.apache.hadoop.yarn.webapp.hamlet.HamletImpl;
  import org.apache.hadoop.yarn.webapp.hamlet.HamletSpec;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class HamletGenTest {
      @Test
      void generateHamletImplementationFromDefaultSpec(@TempDir Path tempDir) throws Exception {
          Path outputBase = tempDir.resolve("GeneratedHamlet");
          String outputName = outputBase.toString().replace('\\', '/');
  
          new HamletGen().generate(
                  HamletSpec.class,
                  HamletImpl.class,
                  outputName,
                  HamletImpl.class.getPackage().getName());
  
          assertGeneratedHamletSource(tempDir.resolve("GeneratedHamlet.java"), "GeneratedHamlet");
      }
  
      @Test
      void mainLoadsConfiguredSpecAndImplementationClasses(@TempDir Path tempDir) throws Exception {
          Path outputBase = tempDir.resolve("GeneratedFromMainHamlet");
          String outputName = outputBase.toString().replace('\\', '/');
  
          HamletGen.main(new String[] {
                  "--spec-class", HamletSpec.class.getName(),
                  "--impl-class", HamletImpl.class.getName(),
                  "--output-class", outputName,
                  "--output-package", HamletImpl.class.getPackage().getName()
          });
  
          assertGeneratedHamletSource(tempDir.resolve("GeneratedFromMainHamlet.java"), "GeneratedFromMainHamlet");
      }
  
      private static void assertGeneratedHamletSource(Path generatedSource, String className) throws Exception {
          assertThat(generatedSource).exists();
  
          String source = Files.readString(generatedSource, StandardCharsets.UTF_8);
          assertThat(source)
                  .contains("public class " + className + " extends HamletImpl")
                  .contains("implements HamletSpec._Html")
                  .contains("private <T extends _> A<T> a_(T e, boolean inline)")
                  .contains("public HEAD<" + className + "> head()")
                  .contains("return title()._(cdata)._();");
      }
  }
