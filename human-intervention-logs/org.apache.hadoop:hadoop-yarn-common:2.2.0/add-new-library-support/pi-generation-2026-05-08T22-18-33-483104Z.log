  package org_apache_hadoop.hadoop_yarn_common;
  
  import java.util.Collections;
  
  import org.apache.hadoop.yarn.state.Graph;
  import org.apache.hadoop.yarn.state.StateMachineFactory;
  import org.apache.hadoop.yarn.state.VisualizeStateMachine;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class VisualizeStateMachineTest {
      @Test
      void getGraphFromClassesLoadsFactoryFieldAndGeneratesGraph() throws Exception {
          Graph graph = VisualizeStateMachine.getGraphFromClasses(
                  "MachineGraph",
                  Collections.singletonList(MachineImpl.class.getName()));
  
          assertThat(graph.getName()).isEqualTo("MachineGraph");
          assertThat(graph.generateGraphViz())
                  .contains("digraph MachineGraph")
                  .contains("\"MachineGraph.START\" [ label = START ];")
                  .contains("\"MachineGraph.FINISHED\" [ label = FINISHED ];")
                  .contains("\"MachineGraph.START\" -> \"MachineGraph.FINISHED\" [ label = \"BEGIN\" ];");
      }
  
      private enum MachineState {
          START,
          FINISHED
      }
  
      private enum MachineEventType {
          BEGIN
      }
  
      private static final class MachineImpl {
          @SuppressWarnings("unused")
          private static final StateMachineFactory
                  <MachineImpl, MachineState, MachineEventType, String> stateMachineFactory =
                  new StateMachineFactory<MachineImpl, MachineState, MachineEventType, String>(MachineState.START)
                          .addTransition(MachineState.START, MachineState.FINISHED, MachineEventType.BEGIN)
                          .installTopology();
      }
  }
