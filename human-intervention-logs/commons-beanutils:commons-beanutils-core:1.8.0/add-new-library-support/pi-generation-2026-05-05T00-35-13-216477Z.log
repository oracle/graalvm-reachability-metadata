\");\n\n        assertThat(value).isInstanceOf(LinkedList.class);\n        assertThat(bean.size(\"names\")).isZero();\n    }\n\n    @Test\n    void createsConcreteMappedProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"attributes\", TreeMap.class);\n\n        Object value = bean.get(\"attributes\");\n        bean.set(\"attributes\", \"answer\", \"forty-two\");\n\n        assertThat(value).isInstanceOf(TreeMap.class);\n        assertThat(bean.get(\"attributes\", \"answer\")).isEqualTo(\"forty-two\");\n    }\n\n    @Test\n    void createsNestedDynaBeanProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"child\", LazyDynaBean.class);\n\n        Object value = bean.get(\"child\");\n\n        assertThat(value).isInstanceOf(DynaBean.class);\n    }\n\n    @Test\n    void createsSimpleBeanPropertiesWithPublicConstructors() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"holder\", ConstructibleValue.class);\n\n        Object value = bean.get(\"holder\");\n\n        assertThat(value).isInstanceOf(ConstructibleValue.class);\n        assertThat(((ConstructibleValue) value).getValue()).isEqualTo(\"created\");\n    }\n\n    public static class ConstructibleValue {\n        private final String value = \"created\";\n\n        public String getValue() {\n            return value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 437, "output": 1383, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 26908, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777941268828, "responseId": "resp_0f19118669f663c00169f93b17da708