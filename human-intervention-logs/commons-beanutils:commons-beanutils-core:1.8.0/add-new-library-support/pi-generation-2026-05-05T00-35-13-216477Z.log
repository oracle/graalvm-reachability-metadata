[tool-call] delta {"path":"tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/LazyDynaBeanTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.util.LinkedList;\nimport java.util.TreeMap;\n\nimport org.apache.commons.beanutils.DynaBean;\nimport org.apache.commons.beanutils.LazyDynaBean;\nimport org.apache.commons.beanutils.MutableDynaClass;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LazyDynaBeanTest {\n    @Test\n    void createsAndGrowsArrayBackedIndexedProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"scores\", int[].class);\n\n        Object initialValue = bean.get(\"scores\");\n        Object grownValue = bean.get(\"scores\", 2);\n\n        assertThat(initialValue).isInstanceOf(int[].class);\n        assertThat(bean.size(\"scores\")).isEqualTo(3);\n        assertThat(grownValue).isEqualTo(0);\n    }\n\n    @Test\n    void createsConcreteListBackedIndexedProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"names\", LinkedList.class);\n\n        Object value = bean.get(\"names\");\n\n        assertThat(value).isInstanceOf(LinkedList.class);\n        assertThat(bean.size(\"names\")).isZero();\n    }\n\n    @Test\n    void createsConcreteMappedProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"attributes\", TreeMap.class);\n\n        Object value = bean.get(\"attributes\");\n        bean.set(\"attributes\", \"answer\", \"forty-two\");\n\n        assertThat(value).isInstanceOf(TreeMap.class);\n        assertThat(bean.get(\"attributes\", \"answer\")).isEqualTo(\"forty-two\");\n    }\n\n    @Test\n    void createsNestedDynaBeanProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"child\", LazyDynaBean.class);\n\n        Object value = bean.get(\"child\");\n\n        assertThat(value).isInstanceOf(DynaBean.class);\n    }\n\n    @Test\n    void createsSimpleBeanPropertiesWithPublicConstructors() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"holder\", ConstructibleValue.class);\n\n        Object value = bean.get(\"holder\");\n\n        assertThat(value).isInstanceOf(ConstructibleValue.class);\n        assertThat(((ConstructibleValue) value).getValue()).isEqualTo(\"created\");\n    }\n\n    public static class ConstructibleValue {\n        private final String value = \"created\";\n\n        public String getValue() {\n            return value;\n        }\n    }\n}\n"}
[tool-call] end id=call_YtV0E1qanRwEHa6Gs4iPzXiN|fc_0f19118669f663c00169f93b1f7b1c81a3a777a0e834eecbe9 name=write args={"path": "tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/LazyDynaBeanTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.util.LinkedList;\nimport java.util.TreeMap;\n\nimport org.apache.commons.beanutils.DynaBean;\nimport org.apache.commons.beanutils.LazyDynaBean;\nimport org.apache.commons.beanutils.MutableDynaClass;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LazyDynaBeanTest {\n    @Test\n    void createsAndGrowsArrayBackedIndexedProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"scores\", int[].class);\n\n        Object initialValue = bean.get(\"scores\");\n        Object grownValue = bean.get(\"scores\", 2);\n\n        assertThat(initialValue).isInstanceOf(int[].class);\n        assertThat(bean.size(\"scores\")).isEqualTo(3);\n        assertThat(grownValue).isEqualTo(0);\n    }\n\n    @Test\n    void createsConcreteListBackedIndexedProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"names\", LinkedList.class);\n\n        Object value = bean.get(\"names\");\n\n        assertThat(value).isInstanceOf(LinkedList.class);\n        assertThat(bean.size(\"names\")).isZero();\n    }\n\n    @Test\n    void createsConcreteMappedProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"attributes\", TreeMap.class);\n\n        Object value = bean.get(\"attributes\");\n        bean.set(\"attributes\", \"answer\", \"forty-two\");\n\n        assertThat(value).isInstanceOf(TreeMap.class);\n        assertThat(bean.get(\"attributes\", \"answer\")).isEqualTo(\"forty-two\");\n    }\n\n    @Test\n    void createsNestedDynaBeanProperties() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"child\", LazyDynaBean.class);\n\n        Object value = bean.get(\"child\");\n\n        assertThat(value).isInstanceOf(DynaBean.class);\n    }\n\n    @Test\n    void createsSimpleBeanPropertiesWithPublicConstructors() {\n        LazyDynaBean bean = new LazyDynaBean();\n        MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();\n        dynaClass.add(\"holder\", ConstructibleValue.class);\n\n        Object value = bean.get(\"holder\");\n\n        assertThat(value).isInstanceOf(ConstructibleValue.class);\n        assertThat(((ConstructibleValue) value).getValue()).isEqualTo(\"created\");\n    }\n\n    public static class ConstructibleValue {\n        private final String value = \"created\";\n\n        public String getValue() {\n            return value;\n        }\n    }\n}\n"}
