  package commons_beanutils.commons_beanutils_core;
  
  import java.util.LinkedList;
  import java.util.TreeMap;
  
  import org.apache.commons.beanutils.DynaBean;
  import org.apache.commons.beanutils.LazyDynaBean;
  import org.apache.commons.beanutils.MutableDynaClass;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LazyDynaBeanTest {
      @Test
      void createsAndGrowsArrayBackedIndexedProperties() {
          LazyDynaBean bean = new LazyDynaBean();
          MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();
          dynaClass.add("scores", int[].class);
  
          Object initialValue = bean.get("scores");
          Object grownValue = bean.get("scores", 2);
  
          assertThat(initialValue).isInstanceOf(int[].class);
          assertThat(bean.size("scores")).isEqualTo(3);
          assertThat(grownValue).isEqualTo(0);
      }
  
      @Test
      void createsConcreteListBackedIndexedProperties() {
          LazyDynaBean bean = new LazyDynaBean();
          MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();
          dynaClass.add("names", LinkedList.class);
  
          Object value = bean.get("names");
  
          assertThat(value).isInstanceOf(LinkedList.class);
          assertThat(bean.size("names")).isZero();
      }
  
      @Test
      void createsConcreteMappedProperties() {
          LazyDynaBean bean = new LazyDynaBean();
          MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();
          dynaClass.add("attributes", TreeMap.class);
  
          Object value = bean.get("attributes");
          bean.set("attributes", "answer", "forty-two");
  
          assertThat(value).isInstanceOf(TreeMap.class);
          assertThat(bean.get("attributes", "answer")).isEqualTo("forty-two");
      }
  
      @Test
      void createsNestedDynaBeanProperties() {
          LazyDynaBean bean = new LazyDynaBean();
          MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();
          dynaClass.add("child", LazyDynaBean.class);
  
          Object value = bean.get("child");
  
          assertThat(value).isInstanceOf(DynaBean.class);
      }
  
      @Test
      void createsSimpleBeanPropertiesWithPublicConstructors() {
          LazyDynaBean bean = new LazyDynaBean();
          MutableDynaClass dynaClass = (MutableDynaClass) bean.getDynaClass();
          dynaClass.add("holder", ConstructibleValue.class);
  
          Object value = bean.get("holder");
  
          assertThat(value).isInstanceOf(ConstructibleValue.class);
          assertThat(((ConstructibleValue) value).getValue()).isEqualTo("created");
      }
  
      public static class ConstructibleValue {
          private final String value = "created";
  
          public String getValue() {
              return value;
          }
      }
  }
