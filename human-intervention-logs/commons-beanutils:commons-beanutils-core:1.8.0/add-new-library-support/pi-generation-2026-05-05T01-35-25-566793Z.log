CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.ArrayList;\n\nimport org.apache.commons.beanutils.DynaProperty;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DynaPropertyTest {\n    @Test\n    void defaultPropertyUsesObjectType() {\n        DynaProperty property = new DynaProperty(\"value\");\n\n        assertThat(property.getName()).isEqualTo(\"value\");\n        assertThat(property.getType()).isEqualTo(Object.class);\n        assertThat(property.getContentType()).isNull();\n        assertThat(property.isIndexed()).isFalse();\n        assertThat(property.isMapped()).isFalse();\n    }\n\n    @Test\n    void serializesAndDeserializesIndexedPropertyClassMetadata() throws Exception {\n        DynaProperty property = new DynaProperty(\"names\", ArrayList.class, String.class);\n\n        DynaProperty restored = roundTrip(property);\n\n        assertThat(restored).isEqualTo(property);\n        assertThat(restored).isNotSameAs(property);\n        assertThat(restored.getName()).isEqualTo(\"names\");\n        assertThat(restored.getType()).isEqualTo(ArrayList.class);\n        assertThat(restored.getContentType()).isEqualTo(String.class);\n        assertThat(restored.isIndexed()).isTrue();\n    }\n\n    private DynaProperty roundTrip(DynaProperty property) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(property);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (DynaProperty) inputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 494, "output": 943, "cacheRead": 13824, "cacheWrite": 0, "totalTokens": 15261, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777944903107, "responseId": "resp_0be52162c2275dff0169f94947742081a2a7552426d6481dcd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_bEQJbxxK2aDcCURJJ8u9HtFG|fc_0be52162c2275dff0169f9494d7f7481a2bd904a80e0220f24", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2080 bytes to tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/DynaPropertyTest.java"}], "isError": false, "timestamp": 1777944912523}]}
