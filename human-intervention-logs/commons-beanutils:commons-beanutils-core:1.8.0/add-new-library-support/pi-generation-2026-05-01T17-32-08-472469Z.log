  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.ArrayList;
  import java.util.HashMap;
  
  import org.apache.commons.beanutils.DynaBean;
  import org.apache.commons.beanutils.DynaProperty;
  import org.apache.commons.beanutils.LazyDynaBean;
  import org.apache.commons.beanutils.LazyDynaClass;
  import org.junit.jupiter.api.Test;
  
  public class LazyDynaBeanTest {
  
      @Test
      void createsConcreteIndexedPropertyOnDemand() {
          LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass("indexed", new DynaProperty[] {
                  new DynaProperty("items", ArrayList.class)
          }));
  
          Object items = bean.get("items");
  
          assertThat(items).isInstanceOf(ArrayList.class);
          assertThat(bean.size("items")).isZero();
      }
  
      @Test
      void createsConcreteMappedPropertyOnDemand() {
          LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass("mapped", new DynaProperty[] {
                  new DynaProperty("attributes", HashMap.class)
          }));
  
          Object attributes = bean.get("attributes");
  
          assertThat(attributes).isInstanceOf(HashMap.class);
          assertThat(bean.size("attributes")).isZero();
      }
  
      @Test
      void createsNestedDynaBeanPropertyOnDemand() {
          LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass("dyna", new DynaProperty[] {
                  new DynaProperty("child", LazyDynaBean.class)
          }));
  
          Object child = bean.get("child");
  
          assertThat(child).isInstanceOf(DynaBean.class);
          assertThat(((DynaBean) child).getDynaClass()).isNotNull();
      }
  
      @Test
      void createsOrdinaryBeanPropertyOnDemand() {
          LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass("ordinary", new DynaProperty[] {
                  new DynaProperty("value", OrdinaryValue.class)
          }));
  
          Object value = bean.get("value");
  
          assertThat(value).isInstanceOf(OrdinaryValue.class);
          assertThat(((OrdinaryValue) value).label()).isEqualTo("created");
      }
  
      @Test
      void createsAndGrowsArrayIndexedPropertyOnDemand() {
          LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass("array", new DynaProperty[] {
                  new DynaProperty("values", OrdinaryValue[].class)
          }));
  
          Object initialValues = bean.get("values");
          Object grownValue = bean.get("values", 2);
  
          assertThat(initialValues).isInstanceOf(OrdinaryValue[].class);
          assertThat((OrdinaryValue[]) initialValues).isEmpty();
          assertThat(grownValue).isInstanceOf(OrdinaryValue.class);
          assertThat(((OrdinaryValue[]) bean.get("values"))).hasSize(3);
      }
  
      public static class OrdinaryValue {
          private final String label;
  
          public OrdinaryValue() {
              this.label = "created";
          }
  
          String label() {
              return label;
          }
      }
  }
