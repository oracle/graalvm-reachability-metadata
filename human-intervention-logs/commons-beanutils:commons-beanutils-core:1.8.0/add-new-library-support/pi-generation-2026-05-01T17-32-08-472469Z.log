  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.HashMap;
  import java.util.Map;
  
  import org.apache.commons.beanutils.DynaBean;
  import org.apache.commons.beanutils.DynaProperty;
  import org.apache.commons.beanutils.LazyDynaClass;
  import org.apache.commons.beanutils.LazyDynaList;
  import org.junit.jupiter.api.Test;
  
  public class LazyDynaListTest {
  
      @Test
      void convertsStoredMapsToConcreteArray() {
          LazyDynaList list = new LazyDynaList(HashMap.class);
          HashMap<String, Object> first = new HashMap<>();
          first.put("name", "alpha");
          HashMap<String, Object> second = new HashMap<>();
          second.put("name", "bravo");
  
          list.add(first);
          list.add(second);
  
          Object[] values = list.toArray();
  
          assertThat(values).isInstanceOf(HashMap[].class);
          assertThat(values).containsExactly(first, second);
      }
  
      @Test
      void convertsStoredMapsToSuppliedArrayType() {
          LazyDynaList list = new LazyDynaList(HashMap.class);
          HashMap<String, Object> entry = new HashMap<>();
          entry.put("active", Boolean.TRUE);
          list.add(entry);
  
          HashMap[] values = (HashMap[]) list.toArray(new HashMap[0]);
  
          assertThat(values).containsExactly(entry);
      }
  
      @Test
      void convertsGeneratedElementsToDynaBeanArray() {
          LazyDynaClass dynaClass = new LazyDynaClass("entry", new DynaProperty[] {
                  new DynaProperty("name", String.class),
                  new DynaProperty("attributes", Map.class)
          });
          LazyDynaList list = new LazyDynaList(dynaClass);
  
          DynaBean first = (DynaBean) list.get(0);
          first.set("name", "alpha");
          DynaBean second = (DynaBean) list.get(1);
          second.set("name", "bravo");
  
          DynaBean[] values = list.toDynaBeanArray();
  
          assertThat(values).hasSize(2);
          assertThat(values[0].get("name")).isEqualTo("alpha");
          assertThat(values[1].get("name")).isEqualTo("bravo");
      }
  }
