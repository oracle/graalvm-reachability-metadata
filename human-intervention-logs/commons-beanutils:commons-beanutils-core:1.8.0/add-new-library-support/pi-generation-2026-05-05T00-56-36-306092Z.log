ee <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.util.Map;\nimport java.util.TreeMap;\n\nimport org.apache.commons.beanutils.DynaBean;\nimport org.apache.commons.beanutils.LazyDynaList;\nimport org.apache.commons.beanutils.LazyDynaMap;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LazyDynaListTest {\n    @Test\n    void createsLazyMapElementsAndConvertsThemBackToTypedArrays() {\n        LazyDynaList list = new LazyDynaList(TreeMap.class);\n        DynaBean bean = (DynaBean) list.get(0);\n        bean.set(\"name\", \"first\");\n\n        Object[] rawArray = list.toArray();\n        Object[] typedArray = list.toArray(new TreeMap[0]);\n        DynaBean[] dynaBeanArray = list.toDynaBeanArray();\n\n        assertThat(rawArray).isInstanceOf(TreeMap[].class);\n        assertThat(rawArray).hasSize(1);\n        assertThat((Map) rawArray[0]).containsEntry(\"name\", \"first\");\n        assertThat(typedArray).isInstanceOf(TreeMap[].class);\n        assertThat(typedArray).containsExactly(rawArray[0]);\n        assertThat(dynaBeanArray).hasSize(1);\n        assertThat(dynaBeanArray[0]).isInstanceOf(LazyDynaMap.class);\n        assertThat(dynaBeanArray[0].get(\"name\")).isEqualTo(\"first\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1359, "output": 1205, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 32260, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777942570597, "responseId": "resp_03fd0183adbc99370169f9402b2ee881969a60226ce600f986"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_TgzcwCmmRstERuVuP5WClBT1|fc_03fd0183adbc99370169f94033bba08196929eb09c1fd7818e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1449 bytes to tests/src/commons-beanutils/commons