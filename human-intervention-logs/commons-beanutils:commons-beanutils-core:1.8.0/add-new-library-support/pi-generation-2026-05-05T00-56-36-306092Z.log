  package commons_beanutils.commons_beanutils_core;
  
  import org.apache.commons.beanutils.MethodUtils;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodUtilsTest {
      @Test
      void invokesMatchingInstanceMethodWithAssignableArgumentType() throws Exception {
          MethodUtils.clearCache();
          SampleMethods target = new SampleMethods();
  
          Object result = MethodUtils.invokeMethod(target, "describe", new Object[] {"beanutils"});
  
          assertThat(result).isEqualTo("instance:beanutils");
      }
  
      @Test
      void invokesExactInstanceMethod() throws Exception {
          MethodUtils.clearCache();
          SampleMethods target = new SampleMethods();
  
          Object result = MethodUtils.invokeExactMethod(target, "exact", new Object[] {"value"});
  
          assertThat(result).isEqualTo("exact:value");
      }
  
      @Test
      void invokesMatchingInstanceMethodWithExactArgumentType() throws Exception {
          MethodUtils.clearCache();
          SampleMethods target = new SampleMethods();
  
          Object result = MethodUtils.invokeMethod(target, "exact", new Object[] {"direct"});
  
          assertThat(result).isEqualTo("exact:direct");
      }
  
      @Test
      void invokesMatchingStaticMethodWithAssignableArgumentType() throws Exception {
          MethodUtils.clearCache();
  
          Object result = MethodUtils.invokeStaticMethod(
                  SampleMethods.class, "staticDescribe", new Object[] {"beanutils"});
  
          assertThat(result).isEqualTo("static:beanutils");
      }
  
      @Test
      void invokesExactStaticMethod() throws Exception {
          MethodUtils.clearCache();
  
          Object result = MethodUtils.invokeExactStaticMethod(
                  SampleMethods.class, "staticExact", new Object[] {"value"});
  
          assertThat(result).isEqualTo("static-exact:value");
      }
  
      @Test
      void findsAccessibleMethodDeclaredOnPublicClass() {
          MethodUtils.clearCache();
  
          assertThat(MethodUtils.getAccessibleMethod(SampleMethods.class, "exact", new Class[] {String.class}))
                  .isNotNull();
      }
  
      @Test
      void findsAccessibleMethodThroughPublicSuperclassOfNonPublicClass() {
          MethodUtils.clearCache();
  
          assertThat(MethodUtils.getAccessibleMethod(HiddenChild.class, "parentValue", new Class[0]))
                  .isNotNull();
      }
  
  
