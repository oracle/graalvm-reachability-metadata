  package commons_beanutils.commons_beanutils_core;
  
  import java.util.ArrayList;
  import java.util.HashMap;
  
  import org.apache.commons.beanutils.LazyDynaBean;
  import org.apache.commons.beanutils.LazyDynaClass;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LazyDynaBeanTest {
      @Test
      void instantiatesDeclaredListMapAndDynaBeanPropertyTypes() {
          LazyDynaClass dynaClass = new LazyDynaClass();
          dynaClass.add("child", CustomDynaBean.class);
          dynaClass.add("items", CustomList.class);
          dynaClass.add("attributes", CustomMap.class);
  
          LazyDynaBean bean = new LazyDynaBean(dynaClass);
  
          Object child = bean.get("child");
          bean.set("items", 1, "second");
          bean.set("attributes", "answer", Integer.valueOf(42));
  
          assertThat(child).isInstanceOf(CustomDynaBean.class);
          assertThat(bean.get("items")).isInstanceOf(CustomList.class);
          assertThat(bean.get("items", 0)).isNull();
          assertThat(bean.get("items", 1)).isEqualTo("second");
          assertThat(bean.get("attributes")).isInstanceOf(CustomMap.class);
          assertThat(bean.get("attributes", "answer")).isEqualTo(Integer.valueOf(42));
      }
  
      @Test
      void growsTypedArrayPropertiesWithInstantiatedElements() {
          LazyDynaClass dynaClass = new LazyDynaClass();
          dynaClass.add("values", SimpleValue[].class);
          LazyDynaBean bean = new LazyDynaBean(dynaClass);
  
          Object value = bean.get("values", 2);
  
          assertThat(value).isInstanceOf(SimpleValue.class);
          assertThat(((SimpleValue) value).getName()).isEqualTo("created");
          assertThat(bean.size("values")).isEqualTo(3);
          assertThat((SimpleValue[]) bean.get("values")).hasSize(3);
  
          SimpleValue replacement = new SimpleValue("replacement");
          bean.set("values", 1, replacement);
  
          assertThat(bean.get("values", 1)).isSameAs(replacement);
      }
  
      public static class CustomDynaBean extends LazyDynaBean {
          private static final long serialVersionUID = 1L;
      }
  
      public static class CustomList extends ArrayList<Object> {
          private static final long serialVersionUID = 1L;
      }
  
      public static class CustomMap extends HashMap<String, Object> {
          private static final long serialVersionUID = 1L;
      }
  
      public static class SimpleValue {
          private final String name;
  
          public SimpleValue() {
              this("created");
          }
  
          public SimpleValue(String name) {
              this.name = name;
          }
  
          public String getName() {
              return name;
          }
      }
  }
