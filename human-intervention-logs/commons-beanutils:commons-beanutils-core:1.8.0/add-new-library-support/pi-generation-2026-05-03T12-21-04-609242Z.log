  package commons_beanutils.commons_beanutils_core;
  
  import java.lang.reflect.Constructor;
  
  import org.apache.commons.beanutils.ConstructorUtils;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConstructorUtilsTest {
      @Test
      void invokesExactConstructorAndExposesAccessibleConstructor() throws Exception {
          Object result = ConstructorUtils.invokeExactConstructor(ExactConstructorTarget.class,
                  new Object[]{"beanutils"}, new Class[]{String.class});
          Constructor constructor = ConstructorUtils.getAccessibleConstructor(ExactConstructorTarget.class,
                  new Class[]{String.class});
  
          assertThat(result).isInstanceOf(ExactConstructorTarget.class);
          assertThat(((ExactConstructorTarget) result).describe()).isEqualTo("exact:beanutils");
          assertThat(constructor).isNotNull();
          assertThat(constructor.getParameterTypes()).containsExactly(String.class);
      }
  
      @Test
      void invokesDirectMatchingAccessibleConstructor() throws Exception {
          Object result = ConstructorUtils.invokeConstructor(AssignableConstructorTarget.class,
                  new Object[]{Integer.valueOf(42)}, new Class[]{Number.class});
  
          assertThat(result).isInstanceOf(AssignableConstructorTarget.class);
          assertThat(((AssignableConstructorTarget) result).describe()).isEqualTo("number:42");
      }
  
      @Test
      void invokesBestMatchingAccessibleConstructor() throws Exception {
          Object result = ConstructorUtils.invokeConstructor(AssignableConstructorTarget.class,
                  new Object[]{Integer.valueOf(42)}, new Class[]{Integer.class});
  
          assertThat(result).isInstanceOf(AssignableConstructorTarget.class);
          assertThat(((AssignableConstructorTarget) result).describe()).isEqualTo("number:42");
      }
  
      public static class ExactConstructorTarget {
          private final String value;
  
          public ExactConstructorTarget(String value) {
              this.value = value;
          }
  
          public String describe() {
              return "exact:" + value;
          }
      }
  
      public static class AssignableConstructorTarget {
          private final Number value;
  
          public AssignableConstructorTarget(Number value) {
              this.value = value;
          }
  
          public String describe() {
              return "number:" + value;
          }
      }
  }
