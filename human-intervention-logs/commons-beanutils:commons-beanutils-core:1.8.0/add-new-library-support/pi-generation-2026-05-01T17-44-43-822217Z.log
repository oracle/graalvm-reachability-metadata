  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.TreeMap;
  import java.util.concurrent.atomic.AtomicInteger;
  
  import org.apache.commons.beanutils.converters.ClassConverter;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class ClassConverterTest {
  
      @Test
      void convertsClassNameWithContextClassLoader() {
          ClassConverter converter = new ClassConverter();
          ClassLoader contextClassLoader = ClassConverterTest.class.getClassLoader();
          ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
  
          try {
              Thread.currentThread().setContextClassLoader(contextClassLoader);
  
              Object converted = converter.convert(Class.class, AtomicInteger.class.getName());
  
              assertThat(converted).isSameAs(AtomicInteger.class);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              Thread.currentThread().setContextClassLoader(previousContextClassLoader);
          }
      }
  
      @Test
      void resolvesDefaultClassTargetWhenTypeIsNotSpecified() {
          ClassConverter converter = new ClassConverter();
  
          try {
              Object converted = converter.convert(null, TreeMap.class.getName());
  
              assertThat(converted).isSameAs(TreeMap.class);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void fallsBackToConverterClassLoaderWhenContextClassLoaderCannotResolveClass() {
          ClassConverter converter = new ClassConverter();
          FailingClassLoader failingClassLoader = new FailingClassLoader(TreeMap.class.getName());
          ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
  
          try {
              Thread.currentThread().setContextClassLoader(failingClassLoader);
  
              Object converted = converter.convert(Class.class, TreeMap.class.getName());
  
              assertThat(converted).isSameAs(TreeMap.class);
              assertThat(failingClassLoader.loadAttempts()).isEqualTo(1);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              Thread.currentThread().setContextClassLoader(previousContextClassLoader);
          }
      }
  
      private static final class FailingClassLoader extends ClassLoader {
          private final String rejectedClassName;
          private int loadAttempts;
  
          private FailingClassLoader(String rejectedClassName) {
              super(ClassConverterTest.class.getClassLoader());
              this.rejectedClassName = rejectedClassName;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (rejectedClassName.equals(name)) {
                  loadAttempts++;
                  throw new ClassNotFoundException(name);
              }
              return super.loadClass(name);
          }
  
          private int loadAttempts() {
              return loadAttempts;
          }
      }
  }
