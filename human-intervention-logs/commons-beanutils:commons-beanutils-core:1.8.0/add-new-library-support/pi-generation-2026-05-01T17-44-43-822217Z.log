Impl;\nimport javax.sql.rowset.RowSetProvider;\n\nimport org.apache.commons.beanutils.DynaProperty;\nimport org.apache.commons.beanutils.ResultSetDynaClass;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class JDBCDynaClassTest {\n\n    @Test\n    void introspectsJdbcMetadataColumnClassesThroughPublicResultSetDynaClass() throws Exception {\n        CountingClassLoader countingClassLoader = new CountingClassLoader(JDBCDynaClassTest.class.getClassLoader(),\n                String.class.getName());\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            Thread.currentThread().setContextClassLoader(countingClassLoader);\n\n            ResultSetDynaClass dynaClass = new ResultSetDynaClass(createResultSet(), false);\n\n            DynaProperty name = dynaClass.getDynaProperty(\"NAME\");\n            DynaProperty startedAt = dynaClass.getDynaProperty(\"STARTED_AT\");\n            assertThat(dynaClass.getDynaProperties()).hasSize(2);\n            assertThat(name.getType()).isSameAs(String.class);\n            assertThat(startedAt.getType()).isSameAs(Time.class);\n            assertThat(countingClassLoader.loadAttempts()).isEqualTo(1);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    private static CachedRowSet createResultSet() throws Exception {\n        RowSetMetaDataImpl metadata = new RowSetMetaDataImpl();\n        metadata.setColumnCount(2);\n        metadata.setColumnName(1, \"NAME\");\n        metadata.setColumnType(1, Types.VARCHAR);\n        metadata.setColumnTypeName(1, \"VARCHAR\");\n        metadata.setColumnName(2, \"STARTED_AT\");\n        metadata.setColumnType(2, Types.TIME);\n        metadata.setColumnTypeName(2, \"TIME\");\n\n        CachedRowSet rowSet = RowSetProvider.newFactory().createCachedRowSet();\n        rowSet.setMetaData(metadata);\n        return rowSet;\n    }\n\n    private static final class CountingClassLoader extends ClassLoader {\n        private final String countedClassName;\n        private int loadAttempts;\n\n        private CountingClassLoader(ClassLoader parent, String countedClassName) {\n            super(parent);\n            this.countedClassName = countedClassName;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (countedClassName.equals(name)) {\n                loadAttempts++;\n            }\n            return super.loadClass(name);\n        }\n\n        private int loadAttempts() {\n            return loadAttempts;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 624, "output": 1621, "cacheRead": 36352, "cacheWrite": 0, "totalTokens": 38597, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777657438969, "responseId": "resp_0ec8dbc3fdaeda6d0169f4e65f6de88190ad11825084f5580a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_NgBhbhdf6P8ogSARQn6se0Zr|fc_0ec8dbc3fdaeda6d0169f4e66be0bc819092b63af08f922b8b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3211 bytes to tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/JDBCDynaClassTest.java"}], "isError": false, "timestamp": 1777657455085}]}
