  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.sql.Date;
  import java.sql.ResultSet;
  import java.sql.ResultSetMetaData;
  import java.sql.Types;
  
  import org.apache.commons.beanutils.DynaProperty;
  import org.apache.commons.beanutils.ResultSetDynaClass;
  import org.junit.jupiter.api.Test;
  
  public class JDBCDynaClassTest {
  
      @Test
      void introspectsDateColumnUsingJdbcDateClassLiteral() throws Exception {
          ResultSetDynaClass dynaClass = new ResultSetDynaClass(createResultSet("STARTED_ON", Types.DATE,
                  Date.class.getName()), false);
  
          DynaProperty startedOn = dynaClass.getDynaProperty("STARTED_ON");
  
          assertThat(dynaClass.getDynaProperties()).hasSize(1);
          assertThat(startedOn.getType()).isSameAs(Date.class);
      }
  
      @Test
      void introspectsMetadataColumnClassNameThroughContextClassLoader() throws Exception {
          FixedClassLoader contextClassLoader = new FixedClassLoader(JDBCDynaClassTest.class.getClassLoader(),
                  ColumnValue.class);
          ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
  
          try {
              Thread.currentThread().setContextClassLoader(contextClassLoader);
  
              ResultSetDynaClass dynaClass = new ResultSetDynaClass(createResultSet("ATTEMPTS", Types.JAVA_OBJECT,
                      ColumnValue.class.getName()), false);
  
              DynaProperty attempts = dynaClass.getDynaProperty("ATTEMPTS");
              assertThat(dynaClass.getDynaProperties()).hasSize(1);
              assertThat(attempts.getType()).isSameAs(ColumnValue.class);
              assertThat(contextClassLoader.loadAttempts()).isEqualTo(1);
          } finally {
              Thread.currentThread().setContextClassLoader(previousContextClassLoader);
          }
      }
  
      private static ResultSet createResultSet(String columnName, int columnType, String columnClassName) {
          ResultSetMetaData metadata = createMetadata(columnName, columnType, columnClassName);
          InvocationHandler handler = (proxy, method, args) -> {
              if ("getMetaData".equals(method.getName())) {
                  return metadata;
              }
              return defaultValue(method);
          };
          return (ResultSet) Proxy.newProxyInstance(JDBCDynaClassTest.class.getClassLoader(),
                  new Class<?>[] {ResultSet.class}, handler);
      }
  
      private static ResultSetMetaData createMetadata(String columnName, int columnType, String columnClassName) {
          InvocationHandler handler = (proxy, method, args) -> {
              String methodName = method.getName();
              if ("getColumnCount".equals(methodName)) {
                  return 1;
              }
              if (args == null || args.length == 0 || !(args[0] instanceof Integer)) {
                  return defaultValue(method);
              }
              if ("getColumnName".equals(methodName)) {
                  return columnName;
              }
              if ("getColumnType".equals(methodName)) {
                  return columnType;
              }
              if ("getColumnClassName".equals(methodName)) {
                  return columnClassName;
              }
              return defaultValue(method);
          };
          return (ResultSetMetaData) Proxy.newProxyInstance(JDBCDynaClassTest.class.getClassLoader(),
                  new Class<?>[] {ResultSetMetaData.class}, handler);
      }
  
      private static Object defaultValue(Method method) {
          Class<?> returnType = method.getReturnType();
          if (boolean.class.equals(returnType)) {
              return false;
          }
          if (byte.class.equals(returnType)) {
              return (byte) 0;
          }
          if (short.class.equals(returnType)) {
              return (short) 0;
          }
          if (int.class.equals(returnType)) {
              return 0;
          }
          if (long.class.equals(returnType)) {
              return 0L;
          }
          if (float.class.equals(returnType)) {
              return 0.0F;
          }
          if (double.class.equals(returnType)) {
              return 0.0D;
          }
          if (char.class.equals(returnType)) {
              return '\0';
          }
          return null;
      }
  
      private static final class FixedClassLoader extends ClassLoader {
          private final Class<?> fixedClass;
          private int loadAttempts;
  
          private FixedClassLoader(ClassLoader parent, Class<?> fixedClass) {
              super(parent);
              this.fixedClass = fixedClass;
          }
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (fixedClass.getName().equals(name)) {
                  loadAttempts++;
                  return fixedClass;
              }
              return super.loadClass(name);
          }
  
          private int loadAttempts() {
              return loadAttempts;
          }
      }
  
      private static final class ColumnValue {
      }
  }
