  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.Map;
  
  import org.apache.commons.beanutils.DynaProperty;
  import org.junit.jupiter.api.Test;
  
  public class DynaPropertyTest {
  
      @Test
      void defaultPropertyUsesObjectTypeLoadedByName() {
          DynaProperty property = new DynaProperty("value");
  
          assertThat(property.getName()).isEqualTo("value");
          assertThat(property.getType()).isEqualTo(Object.class);
          assertThat(property.getContentType()).isNull();
          assertThat(property.isIndexed()).isFalse();
          assertThat(property.isMapped()).isFalse();
      }
  
      @Test
      void serializationRoundTripPreservesReferenceClassType() throws Exception {
          DynaProperty property = new DynaProperty("title", String.class);
  
          DynaProperty copy = roundTrip(property);
  
          assertThat(copy).isEqualTo(property);
          assertThat(copy.getName()).isEqualTo("title");
          assertThat(copy.getType()).isEqualTo(String.class);
          assertThat(copy.getContentType()).isNull();
          assertThat(copy.isIndexed()).isFalse();
          assertThat(copy.isMapped()).isFalse();
      }
  
      @Test
      void serializationRoundTripPreservesMappedReferenceContentType() throws Exception {
          DynaProperty property = new DynaProperty("attributes", Map.class, Integer.class);
  
          DynaProperty copy = roundTrip(property);
  
          assertThat(copy).isEqualTo(property);
          assertThat(copy.getName()).isEqualTo("attributes");
          assertThat(copy.getType()).isEqualTo(Map.class);
          assertThat(copy.getContentType()).isEqualTo(Integer.class);
          assertThat(copy.isIndexed()).isFalse();
          assertThat(copy.isMapped()).isTrue();
      }
  
      private static DynaProperty roundTrip(DynaProperty property) throws Exception {
          byte[] serialized = serialize(property);
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              Object copy = input.readObject();
              assertThat(copy).isInstanceOf(DynaProperty.class);
              return (DynaProperty) copy;
          }
      }
  
      private static byte[] serialize(DynaProperty property) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(property);
          }
          return bytes.toByteArray();
      }
  }
