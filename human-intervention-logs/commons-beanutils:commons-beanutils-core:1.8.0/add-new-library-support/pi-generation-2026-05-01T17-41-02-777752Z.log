  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Arrays;
  import java.util.List;
  
  import org.apache.commons.beanutils.converters.ArrayConverter;
  import org.apache.commons.beanutils.converters.IntegerConverter;
  import org.apache.commons.beanutils.converters.StringConverter;
  import org.junit.jupiter.api.Test;
  
  public class ArrayConverterTest {
  
      @Test
      void constructorCreatesEmptyDefaultTypeInstanceWithoutDefaultValue() {
          ArrayConverter converter = new ArrayConverter(String[].class, new StringConverter());
  
          Object converted = converter.convert(String[].class, Arrays.asList("alpha", "beta"));
  
          assertThat(converted).isInstanceOf(String[].class);
          assertThat((String[]) converted).containsExactly("alpha", "beta");
      }
  
      @Test
      void constructorCreatesConfiguredDefaultArray() {
          ArrayConverter converter = new ArrayConverter(String[].class, new StringConverter(), 3);
  
          Object defaultValue = converter.convert(String[].class, null);
  
          assertThat(defaultValue).isInstanceOf(String[].class);
          assertThat((String[]) defaultValue).containsExactly(null, null, null);
      }
  
      @Test
      void convertsCollectionElementsToRequestedArrayType() {
          ArrayConverter converter = new ArrayConverter(Integer[].class, new IntegerConverter());
          List<String> values = Arrays.asList("1", "2", "3");
  
          Object converted = converter.convert(Integer[].class, values);
  
          assertThat(converted).isInstanceOf(Integer[].class);
          assertThat((Integer[]) converted).containsExactly(1, 2, 3);
      }
  
      @Test
      void createsDefaultArrayForRequestedCompatibleArrayType() {
          ArrayConverter converter = new ArrayConverter(Integer[].class, new IntegerConverter(), 2);
  
          Object defaultValue = converter.convert(Long[].class, null);
  
          assertThat(defaultValue).isInstanceOf(Long[].class);
          assertThat((Long[]) defaultValue).containsExactly(null, null);
      }
  
      @Test
      void convertsEmptyArrayToNullStringDefault() {
          ArrayConverter converter = new ArrayConverter(String[].class, new StringConverter());
  
          Object converted = converter.convert(String.class, new String[0]);
  
          assertThat(converted).isNull();
      }
  }
