onverterTest {\n\n    @Test\n    void convertsClassNameWithContextClassLoader() {\n        ClassConverter converter = new ClassConverter();\n\n        try {\n            Object converted = converter.convert(Class.class, AtomicInteger.class.getName());\n\n            assertThat(converted).isSameAs(AtomicInteger.class);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void resolvesDefaultClassTargetWhenTypeIsNotSpecified() {\n        ClassConverter converter = new ClassConverter();\n\n        try {\n            Object converted = converter.convert(null, TreeMap.class.getName());\n\n            assertThat(converted).isSameAs(TreeMap.class);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void fallsBackToConverterClassLoaderWhenContextClassLoaderCannotResolveClass() {\n        ClassConverter converter = new ClassConverter();\n        FailingClassLoader failingClassLoader = new FailingClassLoader(TreeMap.class.getName());\n        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n\n        try {\n            Thread.currentThread().setContextClassLoader(failingClassLoader);\n\n            Object converted = converter.convert(Class.class, TreeMap.class.getName());\n\n            assertThat(converted).isSameAs(TreeMap.class);\n            assertThat(failingClassLoader.loadAttempts()).isEqualTo(1);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n        }\n    }\n\n    private static final class FailingClassLoader extends ClassLoader {\n        private final String rejectedClassName;\n        private int loadAttempts;\n\n        private FailingClassLoader(String rejectedClassName) {\n            super(ClassConverterTest.class.getClassLoader());\n            this.rejectedClassName = rejectedClassName;\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            if (rejectedClassName.equals(name)) {\n                loadAttempts++;\n                throw new ClassNotFoundException(name);\n            }\n            return super.loadClass(name);\n        }\n\n        private int loadAttempts() {\n            return loadAttempts;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2032, "output": 2174, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 41070, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777657203663, "responseId": "resp_0149fc13fe24b9170169f4e5741c208196883e1cec42d53115"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Oa7nQTXQp7D3BGevHtpFXuTE|fc_0149fc13fe24b9170169f4e58a5b988196957685d3b104011b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3151 bytes to tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/ClassConverterTest.java"}], "isError": false, "timestamp": 1777657230956}]}
