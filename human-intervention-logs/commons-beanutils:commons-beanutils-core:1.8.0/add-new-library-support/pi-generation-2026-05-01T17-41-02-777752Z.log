  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.apache.commons.beanutils.BeanUtilsBean;
  import org.junit.jupiter.api.Test;
  
  public class BeanUtilsBeanTest {
  
      @Test
      void initializesThrowableCausesThroughBeanUtilsBean() {
          BeanUtilsBean beanUtils = new BeanUtilsBean();
          Throwable target = new IllegalStateException("target");
          Throwable cause = new IllegalArgumentException("cause");
  
          boolean initialized = beanUtils.initCause(target, cause);
  
          assertThat(initialized).isTrue();
          assertThat(target.getCause()).isSameAs(cause);
      }
  
      @Test
      void cloneBeanCreatesNewJavaBeanInstanceAndCopiesProperties() throws Exception {
          BeanUtilsBean beanUtils = new BeanUtilsBean();
          SampleBean original = new SampleBean();
          original.setName("Grace Hopper");
          original.setCount(42);
  
          SampleBean clone = (SampleBean) beanUtils.cloneBean(original);
  
          assertThat(clone).isNotSameAs(original);
          assertThat(clone.getName()).isEqualTo("Grace Hopper");
          assertThat(clone.getCount()).isEqualTo(42);
      }
  
      public static class SampleBean {
          private String name;
          private int count;
  
          public SampleBean() {
          }
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getCount() {
              return count;
          }
  
          public void setCount(int count) {
              this.count = count;
          }
      }
  }
