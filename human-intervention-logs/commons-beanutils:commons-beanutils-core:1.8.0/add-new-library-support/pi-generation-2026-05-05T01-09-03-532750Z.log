rterTest {\n    @Test\n    void convertsCollectionElementsToPrimitiveArray() {\n        ArrayConverter converter = new ArrayConverter(int[].class, new IntegerConverter());\n\n        Object result = converter.convert(int[].class, Arrays.asList(\"1\", \"2\", \"-3\"));\n\n        assertThat(result).isInstanceOf(int[].class);\n        assertThat((int[]) result).containsExactly(1, 2, -3);\n    }\n\n    @Test\n    void createsConfiguredDefaultArrayForMissingValues() {\n        ArrayConverter converter = new ArrayConverter(Integer[].class, new IntegerConverter(), 2);\n\n        Object result = converter.convert(Integer[].class, null);\n\n        assertThat(result).isInstanceOf(Integer[].class);\n        assertThat((Integer[]) result).hasSize(2).containsOnlyNulls();\n    }\n\n    @Test\n    void createsDefaultArrayForRequestedArrayType() {\n        ArrayConverter converter = new ArrayConverter(Integer[].class, new IntegerConverter(), 3);\n\n        Object result = converter.convert(String[].class, null);\n\n        assertThat(result).isInstanceOf(String[].class);\n        assertThat((String[]) result).hasSize(3).containsOnlyNulls();\n    }\n\n    @Test\n    void convertsEmptyArrayToDefaultStringValue() {\n        ArrayConverter converter = new ArrayConverter(Integer[].class, new IntegerConverter());\n\n        Object result = converter.convert(String.class, new Integer[0]);\n\n        assertThat(result).isNull();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1243, "output": 1387, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 21574, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777943315513, "responseId": "resp_04bdbcf341f809090169f94313ffc881a3b5cbd9fc89d35107"}}
