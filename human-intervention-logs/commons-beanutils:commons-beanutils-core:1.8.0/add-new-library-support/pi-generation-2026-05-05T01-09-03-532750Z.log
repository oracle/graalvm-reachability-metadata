      protected Object convertArray(Object value) {
          if (value == null) {
              return null;
          }
          if (value.getClass().isArray()) {
              if (Array.getLength(value) > 0) {
                  return Array.get(value, 0);
              } else {
                  return null;
              }
          }
          if (value instanceof Collection) {
              Collection collection = (Collection)value;
