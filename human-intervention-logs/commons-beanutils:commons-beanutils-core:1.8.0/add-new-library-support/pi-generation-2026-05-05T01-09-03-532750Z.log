  package commons_beanutils.commons_beanutils_core;
  
  import java.lang.reflect.Constructor;
  
  import org.apache.commons.beanutils.ConstructorUtils;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConstructorUtilsTest {
      @Test
      void findsAccessibleConstructorByExactSignature() {
          Constructor<?> constructor = ConstructorUtils.getAccessibleConstructor(
                  ExactConstructible.class, new Class[] {String.class});
  
          assertThat(constructor).isNotNull();
          assertThat(constructor.getDeclaringClass()).isEqualTo(ExactConstructible.class);
      }
  
      @Test
      void invokesMatchingConstructorWithExactSignature() throws Exception {
          Object result = ConstructorUtils.invokeConstructor(
                  ExactConstructible.class, new Object[] {"beanutils"}, new Class[] {String.class});
  
          assertThat(result).isInstanceOf(ExactConstructible.class);
          assertThat(((ExactConstructible) result).getValue()).isEqualTo("exact:beanutils");
      }
  
      @Test
      void invokesMatchingConstructorWithAssignableSignature() throws Exception {
          Object result = ConstructorUtils.invokeConstructor(
                  AssignableConstructible.class, new Object[] {"beanutils"}, new Class[] {String.class});
  
          assertThat(result).isInstanceOf(AssignableConstructible.class);
          assertThat(((AssignableConstructible) result).getValue()).isEqualTo("assignable:beanutils");
      }
  
      @Test
      void invokesExactConstructorByExactSignature() throws Exception {
          Object result = ConstructorUtils.invokeExactConstructor(
                  ExactConstructible.class, new Object[] {"beanutils"}, new Class[] {String.class});
  
          assertThat(result).isInstanceOf(ExactConstructible.class);
          assertThat(((ExactConstructible) result).getValue()).isEqualTo("exact:beanutils");
      }
  
      public static class ExactConstructible {
          private final String value;
  
          public ExactConstructible(String value) {
              this.value = "exact:" + value;
          }
  
          public String getValue() {
              return value;
          }
      }
  
      public static class AssignableConstructible {
          private final String value;
  
          public AssignableConstructible(CharSequence value) {
              this.value = "assignable:" + value;
          }
  
          public String getValue() {
              return value;
          }
      }
  }
