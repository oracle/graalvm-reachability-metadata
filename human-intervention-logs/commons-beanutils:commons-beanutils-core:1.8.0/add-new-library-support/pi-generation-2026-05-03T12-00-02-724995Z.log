assertThat(directMethod).isNotNull();\n        assertThat(directMethod.invoke(new MatchingTarget(), \"fast\")).isEqualTo(\"direct:fast\");\n\n        assertThat(bestMethod).isNotNull();\n        assertThat(bestMethod.getParameterTypes()).containsExactly(Number.class);\n        assertThat(bestMethod.invoke(new MatchingTarget(), Integer.valueOf(5))).isEqualTo(\"best:5\");\n    }\n\n    public static class MatchingTarget {\n        public String describeNumber(Number value) {\n            return \"number:\" + value;\n        }\n\n        public String chooseBest(Number value) {\n            return \"best:\" + value;\n        }\n\n        public String directMatch(String value) {\n            return \"direct:\" + value;\n        }\n\n        public static String describeStaticNumber(Number value) {\n            return \"static-number:\" + value;\n        }\n    }\n\n    public static class ExactTarget {\n        public String echo(String value) {\n            return \"instance:\" + value;\n        }\n\n        public static String echoStatic(String value) {\n            return \"static:\" + value;\n        }\n    }\n\n    public interface Greeting {\n        String greet(String name);\n    }\n\n    private static class InterfaceBackedTarget implements Greeting {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    public static class PublicSuperclass {\n        public String fromSuperclass(String name) {\n            return \"super \" + name;\n        }\n    }\n\n    private static class SuperclassBackedTarget extends PublicSuperclass {\n    }\n}\n"}], "isError": false, "timestamp": 1777809569085}]}
