[tool-call] delta {"path":"tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/ConstructorUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.lang.reflect.Constructor;\n\nimport org.apache.commons.beanutils.ConstructorUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConstructorUtilsTest {\n    @Test\n    void invokesExactConstructorAndExposesAccessibleConstructor() throws Exception {\n        Object result = ConstructorUtils.invokeExactConstructor(ExactConstructorTarget.class,\n                new Object[]{\"beanutils\"}, new Class[]{String.class});\n        Constructor constructor = ConstructorUtils.getAccessibleConstructor(ExactConstructorTarget.class,\n                new Class[]{String.class});\n\n        assertThat(result).isInstanceOf(ExactConstructorTarget.class);\n        assertThat(((ExactConstructorTarget) result).describe()).isEqualTo(\"exact:beanutils\");\n        assertThat(constructor).isNotNull();\n        assertThat(constructor.getParameterTypes()).containsExactly(String.class);\n    }\n\n    @Test\n    void invokesBestMatchingAccessibleConstructor() throws Exception {\n        Object result = ConstructorUtils.invokeConstructor(AssignableConstructorTarget.class,\n                new Object[]{Integer.valueOf(42)}, new Class[]{Integer.class});\n\n        assertThat(result).isInstanceOf(AssignableConstructorTarget.class);\n        assertThat(((AssignableConstructorTarget) result).describe()).isEqualTo(\"number:42\");\n    }\n\n    public static class ExactConstructorTarget {\n        private final String value;\n\n        public ExactConstructorTarget(String value) {\n            this.value = value;\n        }\n\n        public String describe() {\n            return \"exact:\" + value;\n        }\n    }\n\n    public static class AssignableConstructorTarget {\n        private final Number value;\n\n        public AssignableConstructorTarget(Number value) {\n            this.value = value;\n        }\n\n        public String describe() {\n            return \"number:\" + value;\n        }\n    }\n}\n"}
[tool-call] end id=call_Vm3pu6oGhuBgGCHPpZSAdlkA|fc_081985e9d3b600880169f738b2df5481919a4f40615b726dcd name=write args={"path": "tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/ConstructorUtilsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.lang.reflect.Constructor;\n\nimport org.apache.commons.beanutils.ConstructorUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConstructorUtilsTest {\n    @Test\n    void invokesExactConstructorAndExposesAccessibleConstructor() throws Exception {\n        Object result = ConstructorUtils.invokeExactConstructor(ExactConstructorTarget.class,\n                new Object[]{\"beanutils\"}, new Class[]{String.class});\n        Constructor constructor = ConstructorUtils.getAccessibleConstructor(ExactConstructorTarget.class,\n                new Class[]{String.class});\n\n        assertThat(result).isInstanceOf(ExactConstructorTarget.class);\n        assertThat(((ExactConstructorTarget) result).describe()).isEqualTo(\"exact:beanutils\");\n        assertThat(constructor).isNotNull();\n        assertThat(constructor.getParameterTypes()).containsExactly(String.class);\n    }\n\n    @Test\n    void invokesBestMatchingAccessibleConstructor() throws Exception {\n        Object result = ConstructorUtils.invokeConstructor(AssignableConstructorTarget.class,\n                new Object[]{Integer.valueOf(42)}, new Class[]{Integer.class});\n\n        assertThat(result).isInstanceOf(AssignableConstructorTarget.class);\n        assertThat(((AssignableConstructorTarget) result).describe()).isEqualTo(\"number:42\");\n    }\n\n    public static class ExactConstructorTarget {\n  