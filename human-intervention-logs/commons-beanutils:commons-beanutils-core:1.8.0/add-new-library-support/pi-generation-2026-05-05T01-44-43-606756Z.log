/\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"commons-beanutils:commons-beanutils-core:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777945314378}, {"role": "toolResult", "toolCallId": "call_1pWBryEbq58EJwitn4uL6XID|fc_0c214f9875a02c830169f94ae21f4881a18f3d3264291f65ed", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport org.apache.commons.beanutils.BeanUtilsBean;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BeanUtilsBeanTest {\n    @Test\n    void clonesSimpleJavaBeanUsingDefaultConstructor() throws Exception {\n        BeanUtilsBean beanUtilsBean = new BeanUtilsBean();\n        CopyableBean source = new CopyableBean();\n        List<String> labels = new ArrayList<>();\n        labels.add(\"original\");\n        source.setName(\"beanutils\");\n        source.setCount(42);\n        source.setLabels(labels);\n\n        Object clone = beanUtilsBean.cloneBean(source);\n\n        assertThat(clone).isInstanceOf(CopyableBean.class);\n        assertThat(clone).isNotSameAs(source);\n        CopyableBean copied = (CopyableBean) clone;\n        assertThat(copied.getName()).isEqualTo(\"beanutils\");\n        assertThat(copied.getCount()).isEqualTo(42);\n        assertThat(copied.getLabels()).isSameAs(labels);\n    }\n\n    @Test\n    void initializesThrowableCauseThroughPublicApi() {\n        BeanUtilsBean beanUtilsBean = new BeanUtilsBean();\n        IllegalArgumentException wrapper = new IllegalArgumentException(\"wrapper\");\n        IllegalStateException cause = new IllegalStateException(\"cause\");\n\n        boolean initialized = beanUtilsBean.initCause(wrapper, cause);\n\n        assertThat(initialized).isTrue();\n        assertThat(wrapper.getCause()).isSameAs(cause);\n    }\n\n    public static class CopyableBean {\n        private String name;\n        private int count;\n        private List<String> labels;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n\n        public List<String> getLabels() {\n            return labels;\n        }\n\n        public void setLabels(List<String> labels) {\n            this.labels = labels;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777945314378}, {"role": "toolResult", "toolCallId": "call_b3ubcTCLDp0wddXGMGJTu0jp|fc_0c214f9875a02c830169f94ae21f5081a19b2f6946aa170949", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport org.apache.commons.beanutils.MethodUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MethodUtilsTest {\n    @Test\n    void invokesMatchingInstanceMethodWithAssignableArgumentType() throws Exception {\n        MethodUtils.clearCache();\n        SampleMethods target = new SampleMethods();\n\n        Object result = MethodUtils.invokeMethod(target, \"describe\", new Object[] {\"beanutils\"});\n\n        assertThat(result).isEqualTo(\"instance:beanutils\");\n    }\n\n    @Test\n    void invokesExactInstanceMethod() throws Exception {\n        MethodUtils.clearCache();\n        SampleMethods target = new SampleMethods();\n\n        Object result = MethodUtils.invokeExactMethod(target, \"exact\", new Object[] {\"value\"});\n\n        assertThat(result).isEqualTo(\"exact:value\");\n    }\n\n    @Test\n    void invokesMatchingInstanceMethodWithExactArgumentType() throws Exception {\n        MethodUtils.clearCache();\n        SampleMethods target = new SampleMethods();\n\n        Object result = MethodUtils.invokeMethod(target, \"exact\", new Object[] {\"direct\"});\n\n        assertThat(result).isEqualTo(\"exact:direct\");\n    }\n\n    @Test\n    void invokesMatchingStaticMethodWithAssignableArgumentType() throws Exception {\n        MethodUtils.clearCache();\n\n        Object result = MethodUtils.invokeStaticMethod(\n                SampleMethods.class, \"staticDescribe\", new Object[] {\"beanutils\"});\n\n        assertThat(result).isEqualTo(\"static:beanutils\");\n    }\n\n    @Test\n    void invokesExactStaticMethod() throws Exception {\n        MethodUtils.clearCache();\n\n        Object result = MethodUtils.invokeExactStaticMethod(\n                SampleMethods.class, \"staticExact\", new Object[] {\"value\"});\n\n        assertThat(result).isEqualTo(\"static-exact:value\");\n    }\n\n    @Test\n    void findsAccessibleMethodDeclaredOnPublicClass() {\n        MethodUtils.clearCache();\n\n        assertThat(MethodUtils.getAccessibleMethod(SampleMethods.class, \"exact\", new Class[] {String.class}))\n                .isNotNull();\n    }\n\n    @Test\n    void findsAccessibleMethodThroughPublicSuperclassOfNonPublicClass() {\n        MethodUtils.clearCache();\n\n        assertThat(MethodUtils.getAccessibleMethod(HiddenChild.class, \"parentValue\", new Class[0]))\n                .isNotNull();\n    }\n\n    @Test\n    void findsAccessibleMethodThroughPublicInterfaceOfNonPublicClass() {\n        MethodUtils.clearCache();\n\n        assertThat(MethodUtils.getAccessibleMethod(HiddenImplementation.class, \"interfaceValue\", new Class[0]))\n                .isNotNull();\n    }\n\n    @Test\n    void choosesMatchingAccessibleMethodWhenNoExactSignatureExists() throws Exception {\n        MethodUtils.clearCache();\n        SampleMethods target = new SampleMethods();\n\n        assertThat(MethodUtils.getMatchingAccessibleMethod(SampleMethods.class, \"describe\", new Class[] {String.class}))\n                .isNotNull();\n        assertThat(MethodUtils.invokeMethod(target, \"describe\", new Object[] {\"chosen\"}))\n                .isEqualTo(\"instance:chosen\");\n    }\n\n    public static class SampleMethods {\n        public String describe(CharSequence value) {\n            return \"instance:\" + value;\n        }\n\n        public String exact(String value) {\n            return \"exact:\" + value;\n        }\n\n        public static String staticDescribe(CharSequence value) {\n            return \"static:\" + value;\n        }\n\n        public static String staticExact(String value) {\n            return \"static-exact:\" + value;\n        }\n    }\n\n    public static class AccessibleParent {\n        public String parentValue() {\n            return \"parent\";\n        }\n    }\n\n    public interface AccessibleContract {\n        String interfaceValue();\n    }\n\n    private static class HiddenChild extends AccessibleParent {\n    }\n\n    private static class HiddenImplementation implements AccessibleContract {\n        public String interfaceValue() {\n            return \"interface\";\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777945314378}]}
