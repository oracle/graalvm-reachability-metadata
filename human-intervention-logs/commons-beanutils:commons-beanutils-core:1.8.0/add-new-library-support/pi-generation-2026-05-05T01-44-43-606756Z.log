  package commons_beanutils.commons_beanutils_core;
  
  import java.util.ArrayList;
  import java.util.List;
  
  import org.apache.commons.beanutils.BeanUtilsBean;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BeanUtilsBeanTest {
      @Test
      void clonesSimpleJavaBeanUsingDefaultConstructor() throws Exception {
          BeanUtilsBean beanUtilsBean = new BeanUtilsBean();
          CopyableBean source = new CopyableBean();
          List<String> labels = new ArrayList<>();
          labels.add("original");
          source.setName("beanutils");
          source.setCount(42);
          source.setLabels(labels);
  
          Object clone = beanUtilsBean.cloneBean(source);
  
          assertThat(clone).isInstanceOf(CopyableBean.class);
          assertThat(clone).isNotSameAs(source);
          CopyableBean copied = (CopyableBean) clone;
          assertThat(copied.getName()).isEqualTo("beanutils");
          assertThat(copied.getCount()).isEqualTo(42);
          assertThat(copied.getLabels()).isSameAs(labels);
      }
  
      @Test
      void initializesThrowableCauseThroughPublicApi() {
          BeanUtilsBean beanUtilsBean = new BeanUtilsBean();
          IllegalArgumentException wrapper = new IllegalArgumentException("wrapper");
          IllegalStateException cause = new IllegalStateException("cause");
  
          boolean initialized = beanUtilsBean.initCause(wrapper, cause);
  
          assertThat(initialized).isTrue();
          assertThat(wrapper.getCause()).isSameAs(cause);
      }
  
      public static class CopyableBean {
          private String name;
          private int count;
          private List<String> labels;
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public int getCount() {
              return count;
          }
  
          public void setCount(int count) {
              this.count = count;
          }
  
          public List<String> getLabels() {
              return labels;
          }
  
          public void setLabels(List<String> labels) {
              this.labels = labels;
          }
      }
  }
