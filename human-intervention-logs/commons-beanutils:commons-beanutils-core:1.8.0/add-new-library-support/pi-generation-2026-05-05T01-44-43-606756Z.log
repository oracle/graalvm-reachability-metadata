ssLoaderRef);\n\n            ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n            GeneratedBeanClassLoader reloadingClassLoader = new GeneratedBeanClassLoader();\n            try {\n                Thread.currentThread().setContextClassLoader(reloadingClassLoader);\n\n                Method reloadedMethod = scenario.descriptor.getMappedReadMethod();\n\n                assertThat(reloadedMethod.getName()).isEqualTo(\"getValues\");\n                assertThat(reloadedMethod.getDeclaringClass().getClassLoader()).isSameAs(reloadingClassLoader);\n            } finally {\n                Thread.currentThread().setContextClassLoader(originalClassLoader);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void triesFallbackClassLookupWhenThreadContextClassLoaderCannotReloadMappedMethodClass() throws Exception {\n        try {\n            DescriptorScenario scenario = newDescriptorScenario();\n            forceReferencesToClear(scenario.methodRef, scenario.beanClassRef, scenario.classLoaderRef);\n\n            ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n            try {\n                Thread.currentThread().setContextClassLoader(new RejectingClassLoader());\n\n                assertThatThrownBy(() -> scenario.descriptor.getMappedReadMethod())\n                        .isInstanceOf(RuntimeException.class)\n                        .hasMessageContaining(\"could not be reconstructed\");\n            } finally {\n                Thread.currentThread().setContextClassLoader(originalClassLoader);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static DescriptorScenario newDescriptorScenario()\n            throws ClassNotFoundException, IntrospectionException {\n        GeneratedBeanClassLoader classLoader = new GeneratedBeanClassLoader();\n        Class<?> beanClass = classLoader.loadClass(GENERATED_BEAN_CLASS_NAME);\n        MappedPropertyDescriptor descriptor = new MappedPropertyDescriptor(\"values\", beanClass);\n        Method mappedReadMethod = descriptor.getMappedReadMethod();\n        MethodUtils.clearCache();\n\n        return new DescriptorScenario(\n                descriptor,\n                new WeakReference<>(mappedReadMethod),\n                new WeakReference<>(beanClass),\n                new WeakReference<>(classLoader));\n    }\n\n    private static void forceReferencesToClear(WeakReference<?>... references) throws InterruptedException {\n        long deadline = System.nanoTime() + 30_000_000_000L;\n        while (!allReferencesCleared(references) && System.nanoTime() < deadline) {\n            System.gc();\n            List<byte[]> pressure = new ArrayList<>();\n            try {\n                int maxChunks = maximumPressureChunks();\n                for (int i = 0; i < maxChunks && !allReferencesCleared(references); i++) {\n                    pressure.add(new byte[CHUNK_BYTES]);\n                }\n            } catch (OutOfMemoryError expected) {\n                pressure.clear();\n                System.gc();\n            } finally {\n                pressure.clear();\n            }\n            System.gc();\n            Thread.sleep(100L);\n        }\n        assertThat(allReferencesCleared(references))\n                .as(\"method, generated class, and generated class loader references were cleared\")\n                .isTrue();\n    }\n\n    private static int maximumPressureChunks() {\n        long maxMemory = Runtime.getRuntime().maxMemory();\n        if (maxMemory == Long.MAX_VALUE) {\n            return 256;\n        }\n        return (int) Math.max(1L, Math.min(256L, maxMemory / CHUNK_BYTES));\n    }\n\n    private static boolean allReferencesCleared(WeakReference<?>... references) {\n        for (WeakReference<?> reference : references) {\n            if (reference.get() != null) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    private static byte[] generatedBeanClassBytes() {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try {\n            DataOutputStream out = new DataOutputStream(bytes);\n            out.writeInt(0xCAFEBABE);\n            out.writeShort(0);\n            out.writeShort(52);\n            out.writeShort(16);\n            writeUtf8(out, GENERATED_BEAN_INTERNAL_NAME);\n            writeClass(out, 1);\n            writeUtf8(out, \"java/lang/Object\");\n            writeClass(out, 3);\n            writeUtf8(out, \"<init>\");\n            writeUtf8(out, \"()V\");\n            writeUtf8(out, \"Code\");\n            writeNameAndType(out, 5, 6);\n            writeMethodRef(out, 4, 8);\n            writeUtf8(out, \"getValues\");\n            writeUtf8(out, \"(Ljava/lang/String;)Ljava/lang/String;\");\n            writeUtf8(out, \"setValues\");\n            writeUtf8(out, \"(Ljava/lang/String;Ljava/lang/String;)V\");\n            writeUtf8(out, \"SourceFile\");\n            writeUtf8(out, \"MappedReferenceBean.java\");\n\n            out.writeShort(0x0021);\n            out.writeShort(2);\n            out.writeShort(4);\n            out.writeShort(0);\n            out.writeShort(0);\n            out.writeShort(3);\n            writeMethod(out, 5, 6, 1, 1, new byte[] {(byte) 0x2A, (byte) 0xB7, 0, 9, (byte) 0xB1});\n            writeMethod(out, 10, 11, 1, 2, new byte[] {(byte) 0x2B, (byte) 0xB0});\n            writeMethod(out, 12, 13, 0, 3, new byte[] {(byte) 0xB1});\n            out.writeShort(1);\n            out.writeShort(14);\n            out.writeInt(2);\n            out.writeShort(15);\n        } catch (IOException impossible) {\n            throw new IllegalStateException(impossible);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static void writeUtf8(DataOutputStream out, String value) throws IOException {\n        out.writeByte(1);\n        out.writeUTF(value);\n    }\n\n    private static void writeClass(DataOutputStream out, int nameIndex) throws IOException {\n        out.writeByte(7);\n        out.writeShort(nameIndex);\n    }\n\n    private static void writeNameAndType(DataOutputStream out, int nameIndex, int descriptorIndex) throws IOException {\n        out.writeByte(12);\n        out.writeShort(nameIndex);\n        out.writeShort(descriptorIndex);\n    }\n\n    private static void writeMethodRef(DataOutputStream out, int classIndex, int nameAndTypeIndex) throws IOException {\n        out.writeByte(10);\n        out.writeShort(classIndex);\n        out.writeShort(nameAndTypeIndex);\n    }\n\n    private static void writeMethod(\n            DataOutputStream out,\n            int nameIndex,\n            int descriptorIndex,\n            int maxStack,\n            int maxLocals,\n            byte[] code\n    ) throws IOException {\n        out.writeShort(0x0001);\n        out.writeShort(nameIndex);\n        out.writeShort(descriptorIndex);\n        out.writeShort(1);\n        out.writeShort(7);\n        out.writeInt(12 + code.length);\n        out.writeShort(maxStack);\n        out.writeShort(maxLocals);\n        out.writeInt(code.length);\n        out.write(code);\n        out.writeShort(0);\n        out.writeShort(0);\n    }\n\n    private static final class GeneratedBeanClassLoader extends ClassLoader {\n        private static final byte[] CLASS_BYTES = generatedBeanClassBytes();\n\n        private GeneratedBeanClassLoader() {\n            super(MappedPropertyDescriptorInnerMappedMethodReferenceTest.class.getClassLoader());\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (!GENERATED_BEAN_CLASS_NAME.equals(name)) {\n                throw new Cl