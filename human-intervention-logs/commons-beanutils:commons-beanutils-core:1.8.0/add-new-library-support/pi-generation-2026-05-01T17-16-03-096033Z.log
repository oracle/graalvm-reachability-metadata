oid invokeStaticMethodsThroughExactAndFlexibleLookup() throws Exception {\n        Object primitiveType = MethodUtils.invokeStaticMethod(MethodUtils.class, \"getPrimitiveType\",\n                new Object[] {Integer.class});\n        Object clearedEntries = MethodUtils.invokeExactStaticMethod(MethodUtils.class, \"clearCache\", null, null);\n\n        assertThat(primitiveType).isEqualTo(Integer.TYPE);\n        assertThat(clearedEntries).isInstanceOf(Integer.class);\n    }\n\n    @Test\n    void accessibleMethodLookupFindsPublicInterfaceAndSuperclassDeclarations() {\n        Method interfaceMethod = MethodUtils.getAccessibleMethod(PackagePrivateGreetingTarget.class, \"greet\",\n                new Class[] {String.class});\n        Method superclassMethod = MethodUtils.getAccessibleMethod(PackagePrivateOverride.class, \"inheritedEcho\",\n                new Class[] {String.class});\n\n        assertThat(interfaceMethod).isNotNull();\n        assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(Greeting.class);\n        assertThat(superclassMethod).isNotNull();\n        assertThat(superclassMethod.getDeclaringClass()).isEqualTo(PublicBase.class);\n    }\n\n    public interface Greeting {\n        String greet(String name);\n    }\n\n    static class PackagePrivateGreetingTarget implements Greeting {\n        @Override\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    public static class PublicBase {\n        public String inheritedEcho(String value) {\n            return \"base:\" + value;\n        }\n    }\n\n    static class PackagePrivateOverride extends PublicBase {\n        @Override\n        public String inheritedEcho(String value) {\n            return \"override:\" + value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 417, "output": 2064, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 34225, "cost": {"input": 0, "output": 0, "