[tool-call] delta {"path":"tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/MethodUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\n\nimport org.apache.commons.beanutils.LazyDynaBean;\nimport org.apache.commons.beanutils.MethodUtils;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class MethodUtilsTest {\n\n    @BeforeEach\n    void disableMethodCache() {\n        MethodUtils.setCacheMethods(false);\n        MethodUtils.clearCache();\n    }\n\n    @Test\n    void invokeInstanceMethodsThroughExactAndFlexibleLookup() throws Exception {\n        LazyDynaBean bean = new LazyDynaBean();\n\n        Object setterResult = MethodUtils.invokeMethod(bean, \"set\", new Object[] {\"language\", \"Java\"});\n        Object exactValue = MethodUtils.invokeExactMethod(bean, \"get\", new Object[] {\"language\"},\n                new Class[] {String.class});\n\n        assertThat(setterResult).isNull();\n        assertThat(exactValue).isEqualTo(\"Java\");\n    }\n\n    @Test\n    void invokeStaticMethodsThroughExactAndFlexibleLookup() throws Exception {\n        Object primitiveType = MethodUtils.invokeStaticMethod(MethodUtils.class, \"getPrimitiveType\",\n                new Object[] {Integer.class});\n        Object clearedEntries = MethodUtils.invokeExactStaticMethod(MethodUtils.class, \"clearCache\", null, null);\n\n        assertThat(primitiveType).isEqualTo(Integer.TYPE);\n        assertThat(clearedEntries).isInstanceOf(Integer.class);\n    }\n\n    @Test\n    void accessibleMethodLookupFindsPublicInterfaceAndSuperclassDeclarations() {\n        Method interfaceMethod = MethodUtils.getAccessibleMethod(PackagePrivateGreetingTarget.class, \"greet\",\n                new Class[] {String.class});\n        Method superclassMethod = MethodUtils.getAccessibleMethod(PackagePrivateOverride.class, \"inheritedEcho\",\n                new Class[] {String.class});\n\n        assertThat(interfaceMethod).isNotNull();\n        assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(Greeting.class);\n        assertThat(superclassMethod).isNotNull();\n        assertThat(superclassMethod.getDeclaringClass()).isEqualTo(PublicBase.class);\n    }\n\n    public interface Greeting {\n        String greet(String name);\n    }\n\n    static class PackagePrivateGreetingTarget implements Greeting {\n        @Override\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    public static class PublicBase {\n        public String inheritedEcho(String value) {\n            return \"base:\" + value;\n        }\n    }\n\n    static class PackagePrivateOverride extends PublicBase {\n        @Override\n        public String inheritedEcho(String value) {\n            return \"override:\" + value;\n        }\n    }\n}\n"}
[tool-call] end id=call_30FORGuGBMIfDJ0BkCZeSwVg|fc_010a343f1321832f0169f4dfa0a4b881909be4ce1a385873bf name=write args={"path": "tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/MethodUtilsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\n\nimport org.apache.commons.beanutils.LazyDynaBean;\nimport org.apache.commons.beanutils.MethodUtils;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class MethodUtilsTest {\n\n    @BeforeEach\n    void disableMethodCache() {\n        MethodUtils.setCacheMethods(false);\n        MethodUtils.clearCache();\n    }\n\n    @Test\n    void invokeInstanceMethodsThroughExactAndFlexibleLookup() throws Exception {\n        LazyDynaBean bean = new LazyDynaBean();\n\n        Object setterResult = MethodUtils.invokeMethod(bean, \"set\", new Object[] {\"language\", \"Java\"});\n        Object exactValue = MethodUtils.invokeExactMethod(bean, \"get\", new Object[] {\"language\"},\n                new Class[] {String.class});\n\n        assertThat(setterResult).isNull();\n        assertThat(exactValue).isEqualTo(\"Java\");\n    }\n\n    @Test\n    void invokeStaticMethodsThroughExactAndFlexibleLookup() throws Exception {\n        Object primitiveType = MethodUtils.invokeStaticMethod(MethodUtils.class, \"getPrimitiveType\",\n                new Object[] {Integer.class});\n        Object clearedEntries = MethodUtils.invokeExactStaticMethod(MethodUtils.class, \"clearCache\", null, null);\n\n        assertThat(primitiveType).isEqualTo(Integer.TYPE);\n        assertThat(clearedEntries).isInstanceOf(Integer.class);\n    }\n\n    @Test\n    void accessibleMethodLookupFindsPublicInterfaceAndSuperclassDeclarations() {\n        Method interfaceMethod = MethodUtils.getAccessibleMethod(PackagePrivateGreetingTarget.class, \"greet\",\n                new Class[] {String.class});\n        Method superclassMethod = MethodUtils.getAccessibleMethod(PackagePrivateOverride.class, \"inheritedEcho\",\n                new Class[] {String.class});\n\n        assertThat(interfaceMethod).isNotNull();\n        assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(Greeting.class);\n        assertThat(superclassMethod).isNotNull();\n        assertThat(superclassMethod.getDeclaringClass()).isEqualTo(PublicBase.class);\n    }\n\n    public interface Greeting {\n        String greet(String name);\n    }\n\n    static class PackagePrivateGreetingTarget implements Greeting {\n        @Override\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    public static class PublicBase {\n        public String inheritedEcho(String value) {\n            return \"base:\" + value;\n        }\n    }\n\n    static class PackagePrivateOverride extends PublicBase {\n        @Override\n        public String inheritedEcho(String value) {\n            return \"override:\" + value;\n        }\n    }\n}\n"}
