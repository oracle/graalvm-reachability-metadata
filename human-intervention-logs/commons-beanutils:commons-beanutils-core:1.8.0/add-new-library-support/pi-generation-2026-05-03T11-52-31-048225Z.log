[tool-call] delta {"path":"tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/LazyDynaBeanTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport java.util.ArrayList;\nimport java.util.HashMap;\n\nimport org.apache.commons.beanutils.LazyDynaBean;\nimport org.apache.commons.beanutils.LazyDynaClass;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LazyDynaBeanTest {\n    @Test\n    void instantiatesDeclaredListMapAndDynaBeanPropertyTypes() {\n        LazyDynaClass dynaClass = new LazyDynaClass();\n        dynaClass.add(\"child\", CustomDynaBean.class);\n        dynaClass.add(\"items\", CustomList.class);\n        dynaClass.add(\"attributes\", CustomMap.class);\n\n        LazyDynaBean bean = new LazyDynaBean(dynaClass);\n\n        Object child = bean.get(\"child\");\n        bean.set(\"items\", 1, \"second\");\n        bean.set(\"attributes\", \"answer\", Integer.valueOf(42));\n\n        assertThat(child).isInstanceOf(CustomDynaBean.class);\n        assertThat(bean.get(\"items\")).isInstanceOf(CustomList.class);\n        assertThat(bean.get(\"items\", 0)).isNull();\n        assertThat(bean.get(\"items\", 1)).isEqualTo(\"second\");\n        assertThat(bean.get(\"attributes\")).isInstanceOf(CustomMap.class);\n        assertThat(bean.get(\"attributes\", \"answer\")).isEqualTo(Integer.valueOf(42));\n    }\n\n    @Test\n    void growsTypedArrayPropertiesWithInstantiatedElements() {\n        LazyDynaClass dynaClass = new LazyDynaClass();\n        dynaClass.add(\"values\", SimpleValue[].class);\n        LazyDynaBean bean = new LazyDynaBean(dynaClass);\n\n        Object value = bean.get(\"values\", 2);\n\n        assertThat(value).isInstanceOf(SimpleValue.class);\n        assertThat(((SimpleValue) value).getName()).isEqualTo(\"created\");\n        assertThat(bean.size(\"values\")).isEqualTo(3);\n        assertThat((SimpleValue[]) bean.get(\"values\")).hasSize(3);\n\n        SimpleValue replacement = new SimpleValue(\"replacement\");\n        bean.set(\"values\", 1, replacement);\n\n        assertThat(bean.get(\"values\", 1)).isSameAs(replacement);\n    }\n\n    public static class CustomDynaBean extends LazyDynaBean {\n    }\n\n    public static class CustomList extends ArrayList<Object> {\n        private static final long serialVersionUID = 1L;\n    }\n\n    public static class CustomMap extends HashMap<String, Object> {\n        private static final long serialVersionUID = 1L;\n    }\n\n    public static class SimpleValue {\n        private final String name;\n\n        public SimpleValue() {\n            this(\"created\");\n        }\n\n        public SimpleValue(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n    }\n}\n"}
