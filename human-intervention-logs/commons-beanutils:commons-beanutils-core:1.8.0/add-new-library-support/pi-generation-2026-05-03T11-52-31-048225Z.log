  package commons_beanutils.commons_beanutils_core;
  
  import java.lang.reflect.Method;
  
  import org.apache.commons.beanutils.MethodUtils;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class MethodUtilsTest {
      @Test
      void invokesMatchingInstanceAndStaticMethods() throws Exception {
          MatchingTarget target = new MatchingTarget();
  
          Object instanceResult = MethodUtils.invokeMethod(target, "describeNumber", new Object[]{Integer.valueOf(7)});
          Object staticResult = MethodUtils.invokeStaticMethod(MatchingTarget.class,
                  "describeStaticNumber", new Object[]{Integer.valueOf(11)});
  
          assertThat(instanceResult).isEqualTo("number:7");
          assertThat(staticResult).isEqualTo("static-number:11");
      }
  
      @Test
      void invokesExactInstanceAndStaticMethods() throws Exception {
          ExactTarget target = new ExactTarget();
  
          Object instanceResult = MethodUtils.invokeExactMethod(target, "echo", new Object[]{"beanutils"});
          Object staticResult = MethodUtils.invokeExactStaticMethod(ExactTarget.class,
                  "echoStatic", new Object[]{"core"});
  
          assertThat(instanceResult).isEqualTo("instance:beanutils");
          assertThat(staticResult).isEqualTo("static:core");
      }
  
      @Test
      void resolvesMethodsExposedByInterfacesAndSuperclasses() throws Exception {
          Method interfaceMethod = MethodUtils.getAccessibleMethod(InterfaceBackedTarget.class,
                  "greet", new Class[]{String.class});
          Method superclassMethod = MethodUtils.getAccessibleMethod(SuperclassBackedTarget.class,
                  "fromSuperclass", new Class[]{String.class});
  
          assertThat(interfaceMethod).isNotNull();
          assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(Greeting.class);
          assertThat(interfaceMethod.invoke(new InterfaceBackedTarget(), "Ada")).isEqualTo("hello Ada");
  
          assertThat(superclassMethod).isNotNull();
          assertThat(superclassMethod.getDeclaringClass()).isEqualTo(PublicSuperclass.class);
          assertThat(superclassMethod.invoke(new SuperclassBackedTarget(), "Grace")).isEqualTo("super Grace");
      }
  
      @Test
      void returnsDirectAndBestMatchingAccessibleMethods() throws Exception {
          Method directMethod = MethodUtils.getMatchingAccessibleMethod(MatchingTarget.class,
                  "directMatch", new Class[]{String.class});
          Method bestMethod = MethodUtils.getMatchingAccessibleMethod(MatchingTarget.class,
                  "chooseBest", new Class[]{Integer.class});
  
          assertThat(directMethod).isNotNull();
          assertThat(directMethod.invoke(new MatchingTarget(), "fast")).isEqualTo("direct:fast");
  
          assertThat(bestMethod).isNotNull();
          assertThat(bestMethod.getParameterTypes()).containsExactly(Number.class);
          assertThat(bestMethod.invoke(new MatchingTarget(), Integer.valueOf(5))).isEqualTo("best:5");
      }
  
