       *  via reflection
       */
      public static Object invokeStaticMethod(
              Class objectClass,
              String methodName,
              Object[] args,
              Class[] parameterTypes)
                  throws
                      NoSuchMethodException,
                      IllegalAccessException,
                      InvocationTargetException {
                      
