w DynaProperty[] {\n                new DynaProperty(\"name\", String.class),\n                new DynaProperty(\"attributes\", Map.class)\n        });\n        LazyDynaList list = new LazyDynaList(dynaClass);\n\n        DynaBean first = (DynaBean) list.get(0);\n        first.set(\"name\", \"alpha\");\n        DynaBean second = (DynaBean) list.get(1);\n        second.set(\"name\", \"bravo\");\n\n        DynaBean[] values = list.toDynaBeanArray();\n\n        assertThat(values).hasSize(2);\n        assertThat(values[0].get(\"name\")).isEqualTo(\"alpha\");\n        assertThat(values[1].get(\"name\")).isEqualTo(\"bravo\");\n    }\n}\n"}
