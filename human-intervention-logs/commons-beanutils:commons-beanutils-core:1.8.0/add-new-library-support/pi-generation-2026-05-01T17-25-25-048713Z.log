h this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.HashMap;\nimport java.util.Map;\n\nimport org.apache.commons.beanutils.DynaBean;\nimport org.apache.commons.beanutils.DynaProperty;\nimport org.apache.commons.beanutils.LazyDynaClass;\nimport org.apache.commons.beanutils.LazyDynaList;\nimport org.junit.jupiter.api.Test;\n\npublic class LazyDynaListTest {\n\n    @Test\n    void convertsStoredMapsToConcreteArray() {\n        LazyDynaList list = new LazyDynaList(HashMap.class);\n        HashMap<String, Object> first = new HashMap<>();\n        first.put(\"name\", \"alpha\");\n        HashMap<String, Object> second = new HashMap<>();\n        second.put(\"name\", \"bravo\");\n\n        list.add(first);\n        list.add(second);\n\n        Object[] values = list.toArray();\n\n        assertThat(values).isInstanceOf(HashMap[].class);\n        assertThat(values).containsExactly(first, second);\n    }\n\n    @Test\n    void convertsStoredMapsToSuppliedArrayType() {\n        LazyDynaList list = new LazyDynaList(HashMap.class);\n        HashMap<String, Object> entry = new HashMap<>();\n        entry.put(\"active\", Boolean.TRUE);\n        list.add(entry);\n\n        HashMap[] values = (HashMap[]) list.toArray(new HashMap[0]);\n\n        assertThat(values).containsExactly(entry);\n    }\n\n    @Test\n    void convertsGeneratedElementsToDynaBeanArray() {\n        LazyDynaClass dynaClass = new LazyDynaClass(\"entry\", new DynaProperty[] {\n                new DynaProperty(\"name\", String.class),\n                new DynaProperty(\"attributes\", Map.class)\n        });\n        LazyDynaList list = new LazyDynaList(dynaClass);\n\n        DynaBean first = (DynaBean) list.get(0);\n        first.set(\"name\", \"alpha\");\n        DynaBean second = (DynaBean) list.get(1);\n        second.set(\"name\", \"bravo\");\n\n        DynaBean[] values = list.toDynaBeanArray();\n\n        assertThat(values).hasSize(2);\n        assertThat(values[0].get(\"name\")).isEqualTo(\"alpha\");\n        assertThat(values[1].get(\"name\")).isEqualTo(\"bravo\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2632, "output": 1560, "cacheRead": 44544, "cacheWrite": 0, "totalTokens": 48736, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777656299414, "responseId": "resp_0ad6ceb62ba792bb0169f4e1ebf17881a0b34186e11732ac09"}}
