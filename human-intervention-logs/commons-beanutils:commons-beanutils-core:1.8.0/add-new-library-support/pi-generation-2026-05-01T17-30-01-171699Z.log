  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Constructor;
  
  import org.apache.commons.beanutils.ConstructorUtils;
  import org.junit.jupiter.api.Test;
  
  public class ConstructorUtilsTest {
  
      @Test
      void accessibleConstructorLookupFindsExactPublicSignature() {
          Constructor constructor = ConstructorUtils.getAccessibleConstructor(ExactWidget.class,
                  new Class[] {String.class});
  
          assertThat(constructor).isNotNull();
          assertThat(constructor.getDeclaringClass()).isEqualTo(ExactWidget.class);
          assertThat(constructor.getParameterTypes()).containsExactly(String.class);
      }
  
      @Test
      void invokeExactConstructorCreatesInstanceWithExactSignature() throws Exception {
          Object value = ConstructorUtils.invokeExactConstructor(ExactWidget.class, new Object[] {"exact"},
                  new Class[] {String.class});
  
          assertThat(value).isInstanceOf(ExactWidget.class);
          assertThat(((ExactWidget) value).description()).isEqualTo("exact");
      }
  
      @Test
      void invokeConstructorCreatesInstanceWithExactSignature() throws Exception {
          Object value = ConstructorUtils.invokeConstructor(ExactWidget.class, new Object[] {"flexible-exact"},
                  new Class[] {String.class});
  
          assertThat(value).isInstanceOf(ExactWidget.class);
          assertThat(((ExactWidget) value).description()).isEqualTo("flexible-exact");
      }
  
      @Test
      void invokeConstructorCreatesInstanceWithAssignableSignature() throws Exception {
          Object value = ConstructorUtils.invokeConstructor(AssignableWidget.class, new Object[] {"assignable"},
                  new Class[] {String.class});
  
          assertThat(value).isInstanceOf(AssignableWidget.class);
          assertThat(((AssignableWidget) value).description()).isEqualTo("assignable");
      }
  
      public static class ExactWidget {
          private final String description;
  
          public ExactWidget(String description) {
              this.description = description;
          }
  
          String description() {
              return description;
          }
      }
  
      public static class AssignableWidget {
          private final CharSequence description;
  
          public AssignableWidget(CharSequence description) {
              this.description = description;
          }
  
          String description() {
              return description.toString();
          }
      }
  }
