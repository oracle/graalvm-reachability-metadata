[tool-call] delta {"path":"tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/BeanUtilsBeanTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.apache.commons.beanutils.BeanUtilsBean;\nimport org.junit.jupiter.api.Test;\n\npublic class BeanUtilsBeanTest {\n\n    @Test\n    void initializesThrowableCausesThroughBeanUtilsBean() {\n        BeanUtilsBean beanUtils = new BeanUtilsBean();\n        Throwable target = new IllegalStateException(\"target\");\n        Throwable cause = new IllegalArgumentException(\"cause\");\n\n        boolean initialized = beanUtils.initCause(target, cause);\n\n        assertThat(initialized).isTrue();\n        assertThat(target.getCause()).isSameAs(cause);\n    }\n\n    @Test\n    void cloneBeanCreatesNewJavaBeanInstanceAndCopiesProperties() throws Exception {\n        BeanUtilsBean beanUtils = new BeanUtilsBean();\n        SampleBean original = new SampleBean();\n        original.setName(\"Grace Hopper\");\n        original.setCount(42);\n\n        SampleBean clone = (SampleBean) beanUtils.cloneBean(original);\n\n        assertThat(clone).isNotSameAs(original);\n        assertThat(clone.getName()).isEqualTo(\"Grace Hopper\");\n        assertThat(clone.getCount()).isEqualTo(42);\n    }\n\n    public static class SampleBean {\n        private String name;\n        private int count;\n\n        public SampleBean() {\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n    }\n}\n"}
