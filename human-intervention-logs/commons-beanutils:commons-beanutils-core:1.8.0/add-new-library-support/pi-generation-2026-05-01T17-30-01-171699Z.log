/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Method;\n\nimport org.apache.commons.beanutils.LazyDynaBean;\nimport org.apache.commons.beanutils.MethodUtils;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\npublic class MethodUtilsTest {\n\n    @BeforeEach\n    void disableMethodCache() {\n        MethodUtils.setCacheMethods(false);\n        MethodUtils.clearCache();\n    }\n\n    @Test\n    void invokeInstanceMethodsThroughExactAndFlexibleLookup() throws Exception {\n        LazyDynaBean bean = new LazyDynaBean();\n\n        Object setterResult = MethodUtils.invokeMethod(bean, \"set\", new Object[] {\"language\", \"Java\"});\n        Object exactValue = MethodUtils.invokeExactMethod(bean, \"get\", new Object[] {\"language\"},\n                new Class[] {String.class});\n\n        assertThat(setterResult).isNull();\n        assertThat(exactValue).isEqualTo(\"Java\");\n    }\n\n    @Test\n    void invokeStaticMethodsThroughExactAndFlexibleLookup() throws Exception {\n        Object primitiveType = MethodUtils.invokeStaticMethod(MethodUtils.class, \"getPrimitiveType\",\n                new Object[] {Integer.class});\n        Object clearedEntries = MethodUtils.invokeExactStaticMethod(MethodUtils.class, \"clearCache\", null, null);\n\n        assertThat(primitiveType).isEqualTo(Integer.TYPE);\n        assertThat(clearedEntries).isInstanceOf(Integer.class);\n    }\n\n    @Test\n    void accessibleMethodLookupFindsPublicInterfaceAndSuperclassDeclarations() {\n        Method interfaceMethod = MethodUtils.getAccessibleMethod(PackagePrivateGreetingTarget.class, \"greet\",\n                new Class[] {String.class});\n        Method superclassMethod = MethodUtils.getAccessibleMethod(PackagePrivateOverride.class, \"inheritedEcho\",\n                new Class[] {String.class});\n\n        assertThat(interfaceMethod).isNotNull();\n        assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(Greeting.class);\n        assertThat(superclassMethod).isNotNull();\n        assertThat(superclassMethod.getDeclaringClass()).isEqualTo(PublicBase.class);\n    }\n\n    public interface Greeting {\n        String greet(String name);\n    }\n\n    static class PackagePrivateGreetingTarget implements Greeting {\n        @Override\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    public static class PublicBase {\n        public String inheritedEcho(String value) {\n            return \"base:\" + value;\n        }\n    }\n\n    static class PackagePrivateOverride extends PublicBase {\n        @Override\n        public String inheritedEcho(String value) {\n            return \"override:\" + value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777656543408}, {"role": "toolResult", "toolCallId": "call_UljTJ9mhIOflSxM2A7Kpsj0s|fc_017f14cb0898b23b0169f4e2df20c481a0818c2ce74f24e36d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.Constructor;\n\nimport org.apache.commons.beanutils.ConstructorUtils;\nimport org.junit.jupiter.api.Test;\n\npublic class ConstructorUtilsTest {\n\n    @Test\n    void accessibleConstructorLookupFindsExactPublicSignature() {\n        Constructor constructor = ConstructorUtils.getAccessibleConstructor(ExactWidget.class,\n                new Class[] {String.class});\n\n        assertThat(constructor).isNotNull();\n        assertThat(constructor.getDeclaringClass()).isEqualTo(ExactWidget.class);\n        assertThat(constructor.getParameterTypes()).containsExactly(String.class);\n    }\n\n    @Test\n    void invokeExactConstructorCreatesInstanceWithExactSignature() throws Exception {\n        Object value = ConstructorUtils.invokeExactConstructor(ExactWidget.class, new Object[] {\"exact\"},\n                new Class[] {String.class});\n\n        assertThat(value).isInstanceOf(ExactWidget.class);\n        assertThat(((ExactWidget) value).description()).isEqualTo(\"exact\");\n    }\n\n    @Test\n    void invokeConstructorCreatesInstanceWithExactSignature() throws Exception {\n        Object value = ConstructorUtils.invokeConstructor(ExactWidget.class, new Object[] {\"flexible-exact\"},\n                new Class[] {String.class});\n\n        assertThat(value).isInstanceOf(ExactWidget.class);\n        assertThat(((ExactWidget) value).description()).isEqualTo(\"flexible-exact\");\n    }\n\n    @Test\n    void invokeConstructorCreatesInstanceWithAssignableSignature() throws Exception {\n        Object value = ConstructorUtils.invokeConstructor(AssignableWidget.class, new Object[] {\"assignable\"},\n                new Class[] {String.class});\n\n        assertThat(value).isInstanceOf(AssignableWidget.class);\n        assertThat(((AssignableWidget) value).description()).isEqualTo(\"assignable\");\n    }\n\n    public static class ExactWidget {\n        private final String description;\n\n        public ExactWidget(String description) {\n            this.description = description;\n        }\n\n        String description() {\n            return description;\n        }\n    }\n\n    public static class AssignableWidget {\n        private final CharSequence description;\n\n        public AssignableWidget(CharSequence description) {\n            this.description = description;\n        }\n\n        String description() {\n            return description.toString();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777656543408}]}
