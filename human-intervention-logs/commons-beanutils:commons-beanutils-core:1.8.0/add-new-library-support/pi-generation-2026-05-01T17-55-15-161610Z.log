  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.beans.PropertyDescriptor;
  import java.util.HashMap;
  import java.util.Map;
  
  import org.apache.commons.beanutils.DynaBean;
  import org.apache.commons.beanutils.DynaProperty;
  import org.apache.commons.beanutils.PropertyUtils;
  import org.apache.commons.beanutils.WrapDynaClass;
  import org.junit.jupiter.api.Test;
  
  public class WrapDynaClassTest {
  
      @Test
      void createsDynaBeanForBeanWithMappedProperties() throws Exception {
          PropertyDescriptor descriptor = PropertyUtils.getPropertyDescriptor(new MappedBean(), "values(language)");
          assertThat(descriptor).isNotNull();
  
          WrapDynaClass dynaClass = WrapDynaClass.createDynaClass(MappedBean.class);
  
          DynaProperty mappedProperty = dynaClass.getDynaProperty("values");
          assertThat(mappedProperty).isNotNull();
          assertThat(mappedProperty.getType()).isEqualTo(Map.class);
  
          DynaBean dynaBean = dynaClass.newInstance();
          dynaBean.set("name", "Ada Lovelace");
          dynaBean.set("values", "language", "Java");
  
          assertThat(dynaBean.getDynaClass()).isSameAs(dynaClass);
          assertThat(dynaBean.get("name")).isEqualTo("Ada Lovelace");
          assertThat(dynaBean.get("values", "language")).isEqualTo("Java");
      }
  
      public static class MappedBean {
          private final Map<String, String> values = new HashMap<>();
          private String name;
  
          public MappedBean() {
          }
  
          public String getName() {
              return name;
          }
  
          public void setName(String name) {
              this.name = name;
          }
  
          public String getValues(String key) {
              return values.get(key);
          }
  
          public void setValues(String key, String value) {
              values.put(key, value);
          }
      }
  }
