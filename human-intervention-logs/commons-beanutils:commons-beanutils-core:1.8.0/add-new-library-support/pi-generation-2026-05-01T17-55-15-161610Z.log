  import org.junit.jupiter.api.Test;
  
  public class MappedPropertyDescriptorInnerMappedMethodReferenceTest {
      private static final String MAPPED_BEAN_CLASS = "dynamic_access.MappedBean";
      private static final byte[] MAPPED_BEAN_BYTES = Base64.getDecoder().decode(
              "yv66vgAAADQAHgoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClW" +
