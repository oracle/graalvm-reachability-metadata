      public boolean initCause(Throwable throwable, Throwable cause) {
          if (INIT_CAUSE_METHOD != null && cause != null) {
              try {
                  INIT_CAUSE_METHOD.invoke(throwable, new Object[] { cause });
                  return true;
              } catch (Throwable e) {
                  return false; // can't initialize cause
