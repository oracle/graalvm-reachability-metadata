one;\n        assertThat(copied.getName()).isEqualTo(\"beanutils\");\n        assertThat(copied.getCount()).isEqualTo(42);\n        assertThat(copied.getLabels()).isSameAs(labels);\n    }\n\n    @Test\n    void initializesThrowableCauseThroughPublicApi() {\n        BeanUtilsBean beanUtilsBean = new BeanUtilsBean();\n        IllegalArgumentException wrapper = new IllegalArgumentException(\"wrapper\");\n        IllegalStateException cause = new IllegalStateException(\"cause\");\n\n        boolean initialized = beanUtilsBean.initCause(wrapper, cause);\n\n        assertThat(initialized).isTrue();\n        assertThat(wrapper.getCause()).isSameAs(cause);\n    }\n\n    public static class CopyableBean {\n        private String name;\n        private int count;\n        private List<String> labels;\n\n        public String getName() {\n            return name;\n        }\n\n        public void setName(String name) {\n            this.name = name;\n        }\n\n        public int getCount() {\n            return count;\n        }\n\n        public void setCount(int count) {\n            this.count = count;\n        }\n\n        public List<String> getLabels() {\n            return labels;\n        }\n\n        public void setLabels(List<String> labels) {\n            this.labels = labels;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1380, "output": 1166, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 17394, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777943820560, "responseId": "resp_018e20f9ba049bad0169f9450cfefc8193beeacab13b5720b1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ib6U0l5uEv8tDROQaCKbSREr|fc_018e20f9ba049bad0169f945148dd481938f95d9f78c6aa0ea", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2340 bytes to tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test