signableWidget.class);\n        assertThat(((AssignableWidget) value).description()).isEqualTo(\"assignable\");\n    }\n\n    public static class ExactWidget {\n        private final String description;\n\n        public ExactWidget(String description) {\n            this.description = description;\n        }\n\n        String description() {\n            return description;\n        }\n    }\n\n    public static class AssignableWidget {\n        private final CharSequence description;\n\n        public AssignableWidget(CharSequence description) {\n            this.description = description;\n        }\n\n        String description() {\n            return description.toString();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 521, "output": 1467, "cacheRead": 48128, "cacheWrite": 0, "totalTokens": 50116, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777656048482, "responseId": "resp_0d8ee4fb0a2a75fb0169f4e0f0ee4c81918d4d06c9630e2579"}}
