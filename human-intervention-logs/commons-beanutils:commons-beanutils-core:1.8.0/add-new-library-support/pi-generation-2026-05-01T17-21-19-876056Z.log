  package commons_beanutils.commons_beanutils_core;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Method;
  
  import org.apache.commons.beanutils.LazyDynaBean;
  import org.apache.commons.beanutils.MethodUtils;
  import org.junit.jupiter.api.BeforeEach;
  import org.junit.jupiter.api.Test;
  
  public class MethodUtilsTest {
  
      @BeforeEach
      void disableMethodCache() {
          MethodUtils.setCacheMethods(false);
          MethodUtils.clearCache();
      }
  
      @Test
      void invokeInstanceMethodsThroughExactAndFlexibleLookup() throws Exception {
          LazyDynaBean bean = new LazyDynaBean();
  
          Object setterResult = MethodUtils.invokeMethod(bean, "set", new Object[] {"language", "Java"});
          Object exactValue = MethodUtils.invokeExactMethod(bean, "get", new Object[] {"language"},
                  new Class[] {String.class});
  
          assertThat(setterResult).isNull();
          assertThat(exactValue).isEqualTo("Java");
      }
  
      @Test
      void invokeStaticMethodsThroughExactAndFlexibleLookup() throws Exception {
          Object primitiveType = MethodUtils.invokeStaticMethod(MethodUtils.class, "getPrimitiveType",
                  new Object[] {Integer.class});
          Object clearedEntries = MethodUtils.invokeExactStaticMethod(MethodUtils.class, "clearCache", null, null);
  
          assertThat(primitiveType).isEqualTo(Integer.TYPE);
          assertThat(clearedEntries).isInstanceOf(Integer.class);
      }
  
      @Test
      void accessibleMethodLookupFindsPublicInterfaceAndSuperclassDeclarations() {
          Method interfaceMethod = MethodUtils.getAccessibleMethod(PackagePrivateGreetingTarget.class, "greet",
                  new Class[] {String.class});
          Method superclassMethod = MethodUtils.getAccessibleMethod(PackagePrivateOverride.class, "inheritedEcho",
                  new Class[] {String.class});
  
          assertThat(interfaceMethod).isNotNull();
          assertThat(interfaceMethod.getDeclaringClass()).isEqualTo(Greeting.class);
          assertThat(superclassMethod).isNotNull();
          assertThat(superclassMethod.getDeclaringClass()).isEqualTo(PublicBase.class);
      }
  
      public interface Greeting {
          String greet(String name);
      }
  
      static class PackagePrivateGreetingTarget implements Greeting {
          @Override
          public String greet(String name) {
              return "hello " + name;
          }
      }
  
      public static class PublicBase {
          public String inheritedEcho(String value) {
              return "base:" + value;
          }
      }
  
      static class PackagePrivateOverride extends PublicBase {
          @Override
          public String inheritedEcho(String value) {
              return "override:" + value;
          }
      }
  }
