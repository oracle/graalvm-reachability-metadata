"tests/src/commons-beanutils/commons-beanutils-core/1.8.0/src/test/java/commons_beanutils/commons_beanutils_core/LazyDynaBeanTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage commons_beanutils.commons_beanutils_core;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.HashMap;\n\nimport org.apache.commons.beanutils.DynaBean;\nimport org.apache.commons.beanutils.DynaProperty;\nimport org.apache.commons.beanutils.LazyDynaBean;\nimport org.apache.commons.beanutils.LazyDynaClass;\nimport org.junit.jupiter.api.Test;\n\npublic class LazyDynaBeanTest {\n\n    @Test\n    void createsConcreteIndexedPropertyOnDemand() {\n        LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass(\"indexed\", new DynaProperty[] {\n                new DynaProperty(\"items\", ArrayList.class)\n        }));\n\n        Object items = bean.get(\"items\");\n\n        assertThat(items).isInstanceOf(ArrayList.class);\n        assertThat(bean.size(\"items\")).isZero();\n    }\n\n    @Test\n    void createsConcreteMappedPropertyOnDemand() {\n        LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass(\"mapped\", new DynaProperty[] {\n                new DynaProperty(\"attributes\", HashMap.class)\n        }));\n\n        Object attributes = bean.get(\"attributes\");\n\n        assertThat(attributes).isInstanceOf(HashMap.class);\n        assertThat(bean.size(\"attributes\")).isZero();\n    }\n\n    @Test\n    void createsNestedDynaBeanPropertyOnDemand() {\n        LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass(\"dyna\", new DynaProperty[] {\n                new DynaProperty(\"child\", LazyDynaBean.class)\n        }));\n\n        Object child = bean.get(\"child\");\n\n        assertThat(child).isInstanceOf(DynaBean.class);\n        assertThat(((DynaBean) child).getDynaClass()).isNotNull();\n    }\n\n    @Test\n    void createsOrdinaryBeanPropertyOnDemand() {\n        LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass(\"ordinary\", new DynaProperty[] {\n                new DynaProperty(\"value\", OrdinaryValue.class)\n        }));\n\n        Object value = bean.get(\"value\");\n\n        assertThat(value).isInstanceOf(OrdinaryValue.class);\n        assertThat(((OrdinaryValue) value).label()).isEqualTo(\"created\");\n    }\n\n    @Test\n    void createsAndGrowsArrayIndexedPropertyOnDemand() {\n        LazyDynaBean bean = new LazyDynaBean(new LazyDynaClass(\"array\", new DynaProperty[] {\n                new DynaProperty(\"values\", OrdinaryValue[].class)\n        }));\n\n        Object initialValues = bean.get(\"values\");\n        Object grownValue = bean.get(\"values\", 2);\n\n        assertThat(initialValues).isInstanceOf(OrdinaryValue[].class);\n        assertThat((OrdinaryValue[]) initialValues).isEmpty();\n        assertThat(grownValue).isInstanceOf(OrdinaryValue.class);\n        assertThat(((OrdinaryValue[]) bean.get(\"values\"))).hasSize(3);\n    }\n\n    public static class OrdinaryValue {\n        private final String label;\n\n        public OrdinaryValue() {\n            this.label = \"created\";\n        }\n\n        String label() {\n            return label;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2838, "output": 1552, "cacheRead": 47616, "cacheWrite": 0, "totalTokens": 52006, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777655886897, "responseId": "resp_0a4598976e33d9030169f4e04f72ec81968e6120d3668073fa"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tWgwyAR47HXQUouLoNYzYlJJ|fc_0a4598976e33d9030169f4e0595b788196bdc63ca9c6d06d69", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3091 bytes to tests/src/