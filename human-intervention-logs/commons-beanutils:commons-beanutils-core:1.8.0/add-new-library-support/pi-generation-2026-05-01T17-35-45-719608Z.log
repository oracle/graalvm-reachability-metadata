+AQADKClW\" +\n            \"BwAIAQAXamF2YS9sYW5nL1N0cmluZ0J1aWxkZXIKAAcAAwgACwEAB3N0b3JlZC0KAAcADQwADgAP\" +\n            \"AQAGYXBwZW5kAQAtKExqYXZhL2xhbmcvU3RyaW5nOylMamF2YS9sYW5nL1N0cmluZ0J1aWxkZXI7\" +\n            \"CgAHABEMABIAEwEACHRvU3RyaW5nAQAUKClMamF2YS9sYW5nL1N0cmluZzsHABUBABlkeW5hbWlj\" +\n            \"X2FjY2Vzcy9NYXBwZWRCZWFuAQAEQ29kZQEAD0xpbmVOdW1iZXJUYWJsZQEACWdldFZhbHVlcwEA\" +\n            \"JihMamF2YS9sYW5nL1N0cmluZzspTGphdmEvbGFuZy9TdHJpbmc7AQAJc2V0VmFsdWVzAQAnKExq\" +\n            \"YXZhL2xhbmcvU3RyaW5nO0xqYXZhL2xhbmcvU3RyaW5nOylWAQAKU291cmNlRmlsZQEAD01hcHBl\" +\n            \"ZEJlYW4uamF2YQAhABQAAgAAAAAAAwABAAUABgABABYAAAAdAAEAAQAAAAUqtwABsQAAAAEAFwAA\" +\n            \"AAYAAQAAAAMAAQAYABkAAQAWAAAALAACAAIAAAAUuwAHWbcACRIKtgAMK7YADLYAELAAAAABABcA\" +\n            \"AAAGAAEAAAAFAAEAGgAbAAEAFgAAABkAAAADAAAAAbEAAAABABcAAAAGAAEAAAAJAAEAHAAAAAIA\" +\n            \"HQ==\"\n    );\n\n    @Test\n    void reconstructsMappedMethodsAfterCachedReferencesAreReleased() throws Exception {\n        try {\n            IsolatedMappedBeanClassLoader classLoader = new IsolatedMappedBeanClassLoader(\n                    MappedPropertyDescriptorInnerMappedMethodReferenceTest.class.getClassLoader()\n            );\n            Class<?> beanClass = classLoader.loadClass(MAPPED_BEAN_CLASS);\n            MappedPropertyDescriptor descriptor = new MappedPropertyDescriptor(\"values\", beanClass);\n\n            clearCachedMethodAndClass(descriptor, \"mappedReadMethodRef\");\n            clearCachedMethodAndClass(descriptor, \"mappedWriteMethodRef\");\n\n            ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n            try {\n                Thread.currentThread().setContextClassLoader(classLoader);\n\n                Method readMethod = descriptor.getMappedReadMethod();\n                Method writeMethod = descriptor.getMappedWriteMethod();\n\n                assertThat(readMethod.getName()).isEqualTo(\"getValues\");\n                assertThat(readMethod.getReturnType()).isEqualTo(String.class);\n                assertThat(readMethod.getDeclaringClass().getClassLoader()).isSameAs(classLoader);\n                assertThat(writeMethod.getName()).isEqualTo(\"setValues\");\n                assertThat(writeMethod.getParameterTypes()).containsExactly(String.class, String.class);\n                assertThat(writeMethod.getDeclaringClass().getClassLoader()).isSameAs(classLoader);\n            } finally {\n                Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void reportsReleasedClassReferenceWhenContextClassLoaderCannotReloadTheBean() throws Exception {\n        try {\n            IsolatedMappedBeanClassLoader classLoader = new IsolatedMappedBeanClassLoader(\n                    MappedPropertyDescriptorInnerMappedMethodReferenceTest.class.getClassLoader()\n            );\n            Class<?> beanClass = classLoader.loadClass(MAPPED_BEAN_CLASS);\n            MappedPropertyDescriptor descriptor = new MappedPropertyDescriptor(\"values\", beanClass);\n            ClassLoader unavailableClassLoader = new ClassLoader(null) {\n                @Override\n                public Class<?> loadClass(String name) throws ClassNotFoundException {\n                    throw new ClassNotFoundException(name);\n                }\n            };\n\n            clearCachedMethodAndClass(descriptor, \"mappedReadMethodRef\");\n\n            ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();\n            try {\n                Thread.currentThread().setContextClassLoader(unavailableClassLoader);\n\n                assertThatThrownBy(descriptor::getMappedReadMethod)\n                        .isInstanceOf(RuntimeException.class)\n                        .hasMessageContaining(\"could not be reconstructed\")\n                        .hasMessageContaining(\"class reference has gone\");\n            } finally {\n                Thread.currentThread().setContextClassLoader(previousContextClassLoader);\n            }\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void clearCachedMethodAndClass(\n            MappedPropertyDescriptor descriptor,\n            String mappedMethodReferenceFieldName) throws Exception {\n        Object mappedMethodReference = field(MappedPropertyDescriptor.class, mappedMethodReferenceFieldName)\n                .get(descriptor);\n\n        field(mappedMethodReference.getClass(), \"methodRef\")\n                .set(mappedMethodReference, new SoftReference<>(null));\n        field(mappedMethodReference.getClass(), \"classRef\")\n                .set(mappedMethodReference, new WeakReference<>(null));\n    }\n\n    private static Field field(Class<?> targetClass, String name) throws NoSuchFieldException {\n        Field field = targetClass.getDeclaredField(name);\n        field.setAccessible(true);\n        return field;\n    }\n\n    private static final class IsolatedMappedBeanClassLoader extends ClassLoader {\n        private final Map<String, Class<?>> definedClasses = new ConcurrentHashMap<>();\n\n        private IsolatedMappedBeanClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (MAPPED_BEAN_CLASS.equals(name)) {\n                Class<?> loadedClass = definedClasses.computeIfAbsent(name, this::defineMappedBeanClass);\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n            return super.loadClass(name, resolve);\n        }\n\n        private Class<?> defineMappedBeanClass(String name) {\n            return defineClass(name, MAPPED_BEAN_BYTES, 0, MAPPED_BEAN_BYTES.length);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777657030535}]}
