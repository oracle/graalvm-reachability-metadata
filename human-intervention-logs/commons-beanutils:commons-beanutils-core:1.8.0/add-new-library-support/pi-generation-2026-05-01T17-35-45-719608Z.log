  421:     /**
  422:      * Holds a {@link Method} in a {@link SoftReference} so that it
  423:      * it doesn't prevent any ClassLoader being garbage collected, but
  424:      * tries to re-create the method if the method reference has been
  425:      * released.
  426:      *
  427:      * See http://issues.apache.org/jira/browse/BEANUTILS-291
  428:      */
  429:     private static class MappedMethodReference {
  430:         private String className;
  431:         private String methodName;
  432:         private Reference methodRef;
  433:         private Reference classRef;
  434:         private Reference writeParamTypeRef;
  435:         MappedMethodReference(Method m) {
  436:             if (m != null) {
  437:                 className = m.getDeclaringClass().getName();
  438:                 methodName = m.getName();
  439:                 methodRef = new SoftReference(m);
  440:                 classRef = new WeakReference(m.getDeclaringClass());
  441:                 Class[] types = m.getParameterTypes();
  442:                 if (types.length == 2) {
  443:                     writeParamTypeRef = new WeakReference(types[1]);
  444:                 }
  445:             }
  446:         }
  447:         private Method get() {
  448:             if (methodRef == null) {
  449:                 return null;
  450:             }
  451:             Method m = (Method)methodRef.get();
  452:             if (m == null) {
  453:                 Class clazz = (Class)classRef.get();
  454:                 if (clazz == null) {
  455:                     clazz = reLoadClass();
  456:                     if (clazz != null) {
  457:                         classRef = new WeakReference(clazz);
  458:                     }
  459:                 }
  460:                 if (clazz == null) {
  461:                     throw new RuntimeException("Method " + methodName + " for " +
  462:                             className + " could not be reconstructed - class reference has gone");
  463:                 }
  464:                 Class[] paramTypes = null;
  465:                 if (writeParamTypeRef != null) {
  466:                     paramTypes = new Class[] {String.class, (Class)writeParamTypeRef.get()};
  467:                 } else {
  468:                     paramTypes = STRING_CLASS_PARAMETER;
  469:                 }
  470:                 try {
  471:                     m = clazz.getMethod(methodName, paramTypes);
  472:                     // Un-comment following line for testing
  473:                     // System.out.println("Recreated Method " + methodName + " for " + className);
  474:                 } catch (NoSuchMethodException e) {
  475:                     throw new RuntimeException("Method " + methodName + " for " +
  476:                             className + " could not be reconstructed - method not found");
  477:                 }
  478:                 methodRef = new SoftReference(m);
  479:             }
  480:             return m;
  481:         }
  482: 
  483:         /**
  484:          * Try to re-load the class
  485:          */
  486:         private Class reLoadClass() {
  487: 
  488:             ClassLoader classLoader = Thread.currentThread().getContextClassLoader();
  489: 
  490:             // Try the context class loader
  491:             if (classLoader != null) {
  492:                 try {
  493:                     return classLoader.loadClass(className);
  494:                 } catch (Throwable t) {
  495:                     // ignore
  496:                 }
  497:             }
  498: 
  499:             // Try this class's class loader
  500:             try {
  501:                 return classLoader.loadClass(className);
  502:             } catch (Throwable t) {
  503:                 return null;
  504:             }
  505:         }
  506:     }
  507: }
