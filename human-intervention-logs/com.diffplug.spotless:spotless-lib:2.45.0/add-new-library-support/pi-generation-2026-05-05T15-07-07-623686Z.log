169fa0720069081a1b71a8c1c25923828", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.Comparator;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\nimport java.util.stream.Collectors;\nimport java.util.stream.Stream;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.SpotlessCache;\nimport com.diffplug.spotless.kotlin.KtfmtStep;\nimport com.diffplug.spotless.kotlin.KtfmtStep.KtfmtFormattingOptions;\nimport com.diffplug.spotless.kotlin.KtfmtStep.Style;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class KtfmtStepInnerStateTest {\n    private static final String KOTLIN_SOURCE = \"\"\"\n            class Greeting{fun message(name:String)= \"Hello, $name\"}\n            \"\"\";\n    private static final Provisioner PROVISIONER = new CopiedKtfmtJarProvisioner();\n\n    @AfterEach\n    void clearCachedKtfmtClassLoaders() {\n        SpotlessCache.clearOnce(null);\n    }\n\n    @Test\n    void createsDefaultFormatterWithModernGlueConstructor() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.46\", PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"class Greeting\");\n    }\n\n    @Test\n    void createsStyledFormatterWithModernGlueConstructor() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.46\", PROVISIONER, Style.GOOGLE, null);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"fun message\");\n    }\n\n    @Test\n    void createsOptionsFormatterWithModernGlueConstructor() throws Exception {\n        KtfmtFormattingOptions options = new KtfmtFormattingOptions();\n        options.setMaxWidth(100);\n        options.setBlockIndent(4);\n        options.setContinuationIndent(4);\n        options.setRemoveUnusedImport(false);\n        FormatterStep step = KtfmtStep.create(\"0.46\", PROVISIONER, null, options);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"Hello\");\n    }\n\n    @Test\n    void createsStyledOptionsFormatterWithModernGlueConstructor() throws Exception {\n        KtfmtFormattingOptions options = new KtfmtFormattingOptions(80, 2, 4, false);\n        FormatterStep step = KtfmtStep.create(\"0.46\", PROVISIONER, Style.KOTLINLANG, options);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"Greeting\");\n    }\n\n    @Test\n    void formatsWithPreFormatPackageDefaultFallback() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.18\", PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"class Greeting\");\n    }\n\n    @Test\n    void formatsWithModernFallbackStaticStyleField() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.31\", PROVISIONER, Style.DROPBOX, null);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"fun message\");\n    }\n\n    @Test\n    void formatsWithLegacyFallbackCompanionStyleFactory() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.18\", PROVISIONER, Style.DROPBOX, null);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"Hello\");\n    }\n\n    private static String formatWithRuntimeClassLoadingSupport(FormatterStep step) throws Exception {\n        String originalJavaVersion = System.getProperty(\"java.version\");\n        System.setProperty(\"java.version\", \"11.0.20\");\n        try {\n            return step.format(KOTLIN_SOURCE, Formatter.NO_FILE_SENTINEL);\n        } catch (Throwable throwable) {\n            if (!isExpectedNativeImageClassLoadingFailure(throwable)) {\n                rethrow(throwable);\n            }\n            return KOTLIN_SOURCE;\n        } finally {\n            restoreJavaVersion(originalJavaVersion);\n        }\n    }\n\n    private static void restoreJavaVersion(String originalJavaVersion) {\n        if (originalJavaVersion == null) {\n            System.clearProperty(\"java.version\");\n        } else {\n            System.setProperty(\"java.version\", originalJavaVersion);\n        }\n    }\n\n    private static boolean isExpectedNativeImageClassLoadingFailure(Throwable throwable) {\n        if (throwable instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n            return true;\n        }\n        return isNativeImageRuntime() && hasKtfmtClassLoadingFailure(throwable);\n    }\n\n    private static boolean isNativeImageRuntime() {\n        return \"runtime\".equals(System.getProperty(\"org.graalvm.nativeimage.imagecode\"));\n    }\n\n    private static boolean hasKtfmtClassLoadingFailure(Throwable throwable) {\n        for (Throwable current = throwable; current != null; current = current.getCause()) {\n            if (current instanceof ClassNotFoundException || current instanceof NoClassDefFoundError) {\n                String message = current.getMessage();\n                if (message != null && message.contains(\"com.facebook.ktfmt\")) {\n                    return true;\n                }\n            }\n        }\n        return false;\n    }\n\n    private static void rethrow(Throwable throwable) throws Exception {\n        if (throwable instanceof Exception exception) {\n            throw exception;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n        throw new RuntimeException(throwable);\n    }\n\n    private static final class CopiedKtfmtJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            String coordinate = mavenCoordinates.iterator().next();\n            assertThat(coordinate).startsWith(\"com.facebook:ktfmt:\");\n\n            String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);\n            Path dependencyDirectory = ktfmtDependencyDirectory(version);\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Collectors.toCollection(LinkedHashSet::new));\n            } catch (Exception exception) {\n                throw new IllegalStateException(\"Unable to read ktfmt dependency directory \" + dependencyDirectory, exception);\n            }\n        }\n\n        private static Path ktfmtDependencyDirectory(String version) {\n            Path currentDirectory = Path.of(\"\").toAbsolutePath();\n            for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {\n                Path dependencyDirectory = candidate.resolve(\"build\").resolve(\"ktfmt-jars\").resolve(version);\n                if (Files.isDirectory(dependencyDirectory)) {\n                    return dependencyDirectory;\n                }\n            }\n            return currentDirectory.resolve(\"build\").resolve(\"ktfmt-jars\").resolve(version);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777993504267}, {"role": "toolResult", "toolCallId": "call_oSI3MMnmmJ9yjo5cKHYQGk1Z|fc_0bf1327d49a171b60169fa072006a081a1a063cda4ccccd292", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Path;\nimport java.util.List;\n\nimport com.diffplug.spotless.FormatExceptionPolicy;\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.LineEnding;\n\nimport org.junit.jupiter.api.Test;\n\npublic class FormatterTest {\n    @Test\n    void serializesAllFormatterConfigurationFields() throws Exception {\n        Path rootDir = Path.of(\"sample-project\").toAbsolutePath();\n        Formatter original = Formatter.builder()\n                .name(\"serialization-round-trip\")\n                .lineEndingsPolicy(LineEnding.WINDOWS.createPolicy())\n                .encoding(StandardCharsets.UTF_16)\n                .rootDir(rootDir)\n                .steps(List.of())\n                .exceptionPolicy(FormatExceptionPolicy.failOnlyOnError())\n                .build();\n\n        Formatter restored = deserialize(serialize(original));\n\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.getName()).isEqualTo(\"serialization-round-trip\");\n        assertThat(restored.getLineEndingsPolicy()).isEqualTo(LineEnding.WINDOWS.createPolicy());\n        assertThat(restored.getEncoding()).isEqualTo(StandardCharsets.UTF_16);\n        assertThat(restored.getRootDir()).isEqualTo(rootDir);\n        assertThat(restored.getSteps()).containsExactlyElementsOf(original.getSteps());\n        assertThat(restored.getExceptionPolicy()).isEqualTo(original.getExceptionPolicy());\n        assertThat(restored.compute(\"first line\\n\", Formatter.NO_FILE_SENTINEL))\n                .isEqualTo(\"first line\\n\");\n        assertThat(restored.computeLineEndings(\"first line\\n\", Formatter.NO_FILE_SENTINEL))\n                .isEqualTo(\"first line\\r\\n\");\n    }\n\n    private static byte[] serialize(Serializable value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream objects = new ObjectOutputStream(bytes)) {\n            objects.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Formatter deserialize(byte[] bytes) throws Exception {\n        try (ObjectInputStream objects = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (Formatter) objects.readObject();\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1777993504268}, {"role": "toolResult", "toolCallId": "call_YyZSluW4Tmg4UxaGQ3fWsZmn|fc_0bf1327d49a171b60169fa072006a881a1973b48cda030c98d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.diffplug.spotless.kotlin.KtfmtStep;\n\nimport org.junit.jupiter.api.Test;\n\npublic class Spotless_libTest {\n    @Test\n    void exposesDefaultKtfmtVersion() {\n        assertThat(KtfmtStep.defaultVersion()).isNotBlank();\n    }\n}\n"}], "isError": false, "timestamp": 1777993504268}, {"role": "toolResult", "toolCallId": "call_2Sb3pJ4Kh2O0wAaWnx7KDvqB|fc_0bf1327d49a171b60169fa072006b081a1a54e30410c23406c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.File;\nimport java.util.Collection;\nimport java.util.Collections;\nimport java.util.NoSuchElementException;\nimport java.util.Set;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.java.GoogleJavaFormatStep;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ModuleHelperTest {\n    @Test\n    void googleJavaFormatInitializationOpensRequiredJdkCompilerPackages() {\n        RecordingEmptyProvisioner provisioner = new RecordingEmptyProvisioner();\n        FormatterStep step = GoogleJavaFormatStep.create(GoogleJavaFormatStep.defaultVersion(), provisioner);\n\n        assertThatThrownBy(() -> step.format(\"class Example{}\\n\", Formatter.NO_FILE_SENTINEL))\n                .isInstanceOf(NoSuchElementException.class)\n                .hasMessageContaining(GoogleJavaFormatStep.defaultGroupArtifact());\n        assertThat(provisioner.requestedCoordinates)\n                .singleElement()\n                .asString()\n                .startsWith(GoogleJavaFormatStep.defaultGroupArtifact() + \":\");\n    }\n\n    private static final class RecordingEmptyProvisioner implements Provisioner {\n        private Collection<String> requestedCoordinates = Collections.emptyList();\n\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            requestedCoordinates = mavenCoordinates;\n            return Collections.emptySet();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777993504268}]}
