\"{\\n\")\n                .contains(\"\\\"name\\\": \\\"Ada\\\"\")\n                .contains(\"\\\"numbers\\\": [\")\n                .endsWith(\"\\n\"));\n    }\n\n    @Test\n    void formatsJsonArrayWithDefaultOrgJsonFormatter() throws Exception {\n        FormatterStep step = JsonSimpleStep.create(2, PROVISIONER);\n\n        Optional<String> result = formatWithRuntimeClassLoadingSupport(step, \"[{\\\"id\\\":1},{\\\"id\\\":2}]\");\n\n        result.ifPresent(formatted -> assertThat(formatted)\n                .startsWith(\"[\\n\")\n                .contains(\"\\\"id\\\": 1\")\n                .contains(\"\\\"id\\\": 2\")\n                .endsWith(\"\\n\"));\n    }\n\n    private static Optional<String> formatWithRuntimeClassLoadingSupport(FormatterStep step, String input) throws Exception {\n        try {\n            return Optional.of(step.format(input, Formatter.NO_FILE_SENTINEL));\n        } catch (Error error) {\n            if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return Optional.empty();\n            }\n            throw error;\n        }\n    }\n\n    private static final class CopiedJsonJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            assertThat(mavenCoordinates.iterator().next()).startsWith(\"org.json:json:\");\n\n            Path dependencyDirectory = jsonDependencyDirectory();\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Col