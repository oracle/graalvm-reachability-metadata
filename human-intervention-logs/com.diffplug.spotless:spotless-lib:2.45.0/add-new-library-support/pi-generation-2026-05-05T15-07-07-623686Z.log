n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.SpotlessCache;\nimport com.diffplug.spotless.json.JsonSimpleStep;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class JsonSimpleStepInnerStateTest {\n    private static final Provisioner PROVISIONER = new CopiedJsonJarProvisioner();\n\n    @AfterEach\n    void clearCachedJsonClassLoaders() {\n        SpotlessCache.clearOnce(null);\n    }\n\n    @Test\n    void formatsJsonObjectWithDefaultOrgJsonFormatter() throws Exception {\n        FormatterStep step = JsonSimpleStep.create(2, PROVISIONER);\n\n        Optional<String> result = formatWithRuntimeClassLoadingSupport(step, \"{\\\"name\\\":\\\"Ada\\\",\\\"numbers\\\":[1,2]}\");\n\n        result.ifPresent(formatted -> assertThat(formatted)\n                .startsWith(\"{\\n\")\n                .contains(\"\\\"name\\\": \\\"Ada\\\"\")\n                .contains(\"\\\"numbers\\\": [\")\n                .endsWith(\"\\n\"));\n    }\n\n    @Test\n    void formatsJsonArrayWithDefaultOrgJsonFormatter() throws Exception {\n        FormatterStep step = JsonSimpleStep.create(2, PROVISIONER);\n\n        Optional<String> result = formatWithRuntimeClassLoadingSupport(step, \"[{\\\"id\\\":1},{\\\"id\\\":2}]\");\n\n        result.ifPresent(formatted -> assertThat(formatted)\n                .startsWith(\"[\\n\")\n                .contains(\"\\\"id\\\": 1\")\n                .contains(\"\\\"id\\\": 2\")\n                .endsWith(\"\\n\"));\n    }\n\n    private static Optional<String> formatWithRuntimeClassLoadingSupport(\n            FormatterStep step, String input) throws Exception {\n        try {\n            return Optional.of(step.format(input, Formatter.NO_FILE_SENTINEL));\n        } catch (Error error) {\n            if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return Optional.empty();\n            }\n            throw error;\n        }\n    }\n\n    private static final class CopiedJsonJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            assertThat(mavenCoordinates.iterator().next()).startsWith(\"org.json:json:\");\n\n            Path dependencyDirectory = jsonDependencyDirectory();\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Collectors.toCollection(LinkedHashSet::new));\n            } catch (Exception exception) {\n                throw new IllegalStateException(\n                        \"Unable to read json dependency directory \" + dependencyDirectory, exception);\n            }\n        }\n\n        private static Path jsonDependencyDirectory() {\n            Path currentDirectory = Path.of(\"\").toAbsolutePath();\n            for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {\n                Path dependencyDirectory = candidate.resolve(\"build\").resolve(\"json-jars\");\n                if (Files.isDirectory(dependencyDirectory)) {\n                    return dependencyDirectory;\n                }\n            }\n            return currentDirectory.resolve(\"build\").resolve(\"json-jars\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777993590695}]}
