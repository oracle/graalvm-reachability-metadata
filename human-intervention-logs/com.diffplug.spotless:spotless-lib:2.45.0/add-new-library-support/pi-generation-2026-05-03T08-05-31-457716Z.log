      @Test
      void formatsWithFallbackFormatterApisBeforeGlueFormatterWasAvailable() throws Exception {
          try {
              Provisioner provisioner = classpathProvisioner();
  
              assertFallbackFormatsOrFailsOnUnsupportedJavaVersion(KtfmtStep.create("0.31", provisioner, null, null));
              assertFallbackFormatsOrFailsOnUnsupportedJavaVersion(KtfmtStep.create("0.31", provisioner, Style.GOOGLE, null));
              assertFallbackFormatsOrFailsOnUnsupportedJavaVersion(KtfmtStep.create("0.18", provisioner, Style.DROPBOX, null));
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static KtfmtFormattingOptions formattingOptions() {
          KtfmtFormattingOptions options = new KtfmtFormattingOptions();
          options.setMaxWidth(100);
          options.setBlockIndent(4);
          options.setContinuationIndent(4);
          options.setRemoveUnusedImport(true);
          return options;
      }
  
      private static void assertFormats(FormatterStep formatterStep) throws Exception {
          String formatted = formatterStep.format(KOTLIN_SOURCE, new File("Sample.kt"));
  
          assertThat(formatted).contains("fun main()");
          assertThat(formatted).contains("println");
      }
  
      private static void assertFallbackFormatsOrFailsOnUnsupportedJavaVersion(FormatterStep formatterStep) throws Exception {
          try {
              assertFormats(formatterStep);
          } catch (IllegalArgumentException exception) {
              assertThat(exception)
                      .hasMessage(System.getProperty("java.version"));
              assertThat(Arrays.stream(exception.getStackTrace()).map(StackTraceElement::getClassName))
                      .contains("org.jetbrains.kotlin.com.intellij.util.lang.JavaVersion");
          }
      }
  
