hSet;\nimport java.util.Properties;\nimport java.util.Set;\n\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.kotlin.KtfmtStep;\nimport com.diffplug.spotless.kotlin.KtfmtStep.KtfmtFormattingOptions;\nimport com.diffplug.spotless.kotlin.KtfmtStep.Style;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class KtfmtStepInnerStateTest {\n    private static final String KOTLIN_SOURCE = \"\"\"\n            package sample\n            fun main(){println(\"hello\")}\n            \"\"\";\n\n    @Test\n    void createsModernFormatterForEveryStyleAndOptionsConstructorShape() throws Exception {\n        try {\n            Provisioner provisioner = classpathProvisioner();\n\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, null, null));\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, Style.GOOGLE, null));\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, null, formattingOptions()));\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, Style.KOTLINLANG, formattingOptions()));\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void formatsWithFallbackFormatterApisBeforeGlueFormatterWasAvailable() throws Exception {\n        try {\n            Provisioner provisioner = classpathProvisioner();\n\n            assertFormats(KtfmtStep.create(\"0.31\", provisioner, Style.GOOGLE, null));\n            assertFormats(KtfmtStep.create(\"0.18\", provisioner, Style.DROPBOX, null));\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static KtfmtFormattingOptions formattingOptions() {\n        KtfmtFormattingOptions options = new KtfmtFormattingOptions();\n        options.setMaxWidth(100);\n        options.setBlockIndent(4);\n        options.setContinuationIndent(4);\n        options.setRemoveUnusedImport(true);\n        return options;\n    }\n\n    private static void assertFormats(FormatterStep formatterStep) throws Exception {\n        String formatted = formatterStep.format(KOTLIN_SOURCE, new File(\"Sample.kt\"));\n\n        assertThat(formatted).contains(\"fun main()\");\n        assertThat(formatted).contains(\"println\");\n    }\n\n    private static Provisioner classpathProvisioner() throws IOException {\n        Properties classpaths = new Properties();\n        try (InputStream inputStream = KtfmtStepInnerStateTest.class.getResourceAsStream(\"/ktfmt-classpaths.properties\")) {\n            assertThat(inputStream).isNotNull();\n            classpaths.load(inputStream);\n        }\n        return (boolean withTransitives, Collection<String> mavenCoordinates) -> {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n\n            String coordinate = mavenCoordinates.iterator().next();\n            assertThat(coordinate).startsWith(\"com.facebook:ktfmt:\");\n            String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);\n            String classpath = classpaths.getProperty(version);\n            assertThat(classpath).as(\"classpath for ktfmt %s\", version).isNotBlank();\n\n            Set<File> jars = new LinkedHashSet<>();\n            Arrays.stream(classpath.split(File.pathSeparator))\n                    .map(File::new)\n                    .forEach(jars::add);\n            assertThat(jars).allMatch(File::isFile);\n            return jars;\n        };\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1021, "output": 1218, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 32447, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777795405259, "responseId": "resp_09c626eb68df21040169f7014dbbcc81a2bb936e8028e0a4bf"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_KSVNanaqYG7fkJdKka8tHa75|fc_09c626eb68df21040169f70154e01481a29378aedbf51bfbb2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4074 bytes to tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/KtfmtStepInnerStateTest.java"}], "isError": false, "timestamp": 1777795415830}]}
