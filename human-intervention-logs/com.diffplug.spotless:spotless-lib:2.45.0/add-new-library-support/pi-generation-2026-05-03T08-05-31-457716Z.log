HashSet;\nimport java.util.Properties;\nimport java.util.Set;\n\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.kotlin.KtfmtStep;\nimport com.diffplug.spotless.kotlin.KtfmtStep.KtfmtFormattingOptions;\nimport com.diffplug.spotless.kotlin.KtfmtStep.Style;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class KtfmtStepInnerStateTest {\n    private static final String KOTLIN_SOURCE = \"\"\"\n            package sample\n            fun main(){println(\"hello\")}\n            \"\"\";\n\n    @Test\n    void createsModernFormatterForEveryStyleAndOptionsConstructorShape() throws Exception {\n        try {\n            Provisioner provisioner = classpathProvisioner();\n\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, null, null));\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, Style.GOOGLE, null));\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, null, formattingOptions()));\n            assertFormats(KtfmtStep.create(\"0.46\", provisioner, Style.KOTLINLANG, formattingOptions()));\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Test\n    void formatsWithFallbackFormatterApisBeforeGlueFormatterWasAvailable() throws Exception {\n        try {\n            Provisioner provisioner = classpathProvisioner();\n\n            assertFormats(KtfmtStep.create(\"0.31\", provisioner, Style.GOOGLE, null));\n            assertFormats(KtfmtStep.create(\"0.18\", provisioner, Style.DROPBOX, null));\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static KtfmtFormattingOptions formattingOptions() {\