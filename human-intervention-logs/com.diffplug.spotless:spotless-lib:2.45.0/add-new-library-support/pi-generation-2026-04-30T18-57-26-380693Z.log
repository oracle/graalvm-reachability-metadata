[tool-call] delta {"path":"tests/src/com.diffplug.spotless/spotless-lib/2.45.0/build.gradle","edits":[{"oldText":"Provider<Directory> ktfmtFixtureResources = layout.buildDirectory.dir(\"generated/ktfmt-fixture-resources\")\nProvider<Directory> jsonSimpleFixtureResources = layout.buildDirectory.dir(\"generated/json-simple-fixture-resources\")\n","newText":"Provider<Directory> ktfmtFixtureResources = layout.buildDirectory.dir(\"generated/ktfmt-fixture-resources\")\nProvider<Directory> jsonSimpleFixtureResources = layout.buildDirectory.dir(\"generated/json-simple-fixture-resources\")\nProvider<Directory> googleJavaFormatFixtureResources = layout.buildDirectory.dir(\"generated/google-java-format-fixture-resources\")\n"},{"oldText":"tasks.register(\"generateJsonSimpleFixtureJar\") {\n    outputs.dir(jsonSimpleFixtureResources)\n\n    doLast {\n        File outputDir = jsonSimpleFixtureResources.get().asFile\n        delete(outputDir)\n\n        createJsonSimpleFixture(outputDir)\n    }\n}\n","newText":"tasks.register(\"generateJsonSimpleFixtureJar\") {\n    outputs.dir(jsonSimpleFixtureResources)\n\n    doLast {\n        File outputDir = jsonSimpleFixtureResources.get().asFile\n        delete(outputDir)\n\n        createJsonSimpleFixture(outputDir)\n    }\n}\n\ntasks.register(\"generateGoogleJavaFormatFixtureJar\") {\n    outputs.dir(googleJavaFormatFixtureResources)\n\n    doLast {\n        File outputDir = googleJavaFormatFixtureResources.get().asFile\n        delete(outputDir)\n\n        createGoogleJavaFormatFixture(outputDir)\n    }\n}\n"},{"oldText":"void createJsonSimpleFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"org/json/JSONObject.java\": \"\"\"\n            package org.json;\n\n            public class JSONObject {\n                private final String input;\n\n                public JSONObject(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"object:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\",\n        \"org/json/JSONArray.java\": \"\"\"\n            package org.json;\n\n            public class JSONArray {\n                private final String input;\n\n                public JSONArray(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"array:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"json-simple-fixtures\", \"org-json\", \"org-json-fixture.jar\", sources)\n}\n","newText":"void createJsonSimpleFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"org/json/JSONObject.java\": \"\"\"\n            package org.json;\n\n            public class JSONObject {\n                private final String input;\n\n                public JSONObject(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"object:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\",\n        \"org/json/JSONArray.java\": \"\"\"\n            package org.json;\n\n            public class JSONArray {\n                private final String input;\n\n                public JSONArray(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"array:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"json-simple-fixtures\", \"org-json\", \"org-json-fixture.jar\", sources)\n}\n\nvoid createGoogleJavaFormatFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"com/diffplug/spotless/glue/java/GoogleJavaFormatFo