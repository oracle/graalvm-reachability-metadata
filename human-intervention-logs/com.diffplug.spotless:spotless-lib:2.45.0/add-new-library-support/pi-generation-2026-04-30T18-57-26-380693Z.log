sAfterFormatting) {\n                    this.style = style;\n                    this.maxWidth = maxWidth;\n                    this.blockIndent = blockIndent;\n                    this.continuationIndent = continuationIndent;\n                    this.removeUnusedImports = removeUnusedImports;\n                    this.debuggingPrintOpsAfterFormatting = debuggingPrintOpsAfterFormatting;\n                }\n\n                public Style getStyle() {\n                    return style;\n                }\n\n                public int getMaxWidth() {\n                    return maxWidth;\n                }\n\n                public int getBlockIndent() {\n                    return blockIndent;\n                }\n\n                public int getContinuationIndent() {\n                    return continuationIndent;\n                }\n\n                public boolean getRemoveUnusedImports() {\n                    return removeUnusedImports;\n                }\n\n                public boolean getDebuggingPrintOpsAfterFormatting() {\n                    return debuggingPrintOpsAfterFormatting;\n                }\n\n                public FormattingOptions copy(Style style, int maxWidth, int blockIndent, int continuationIndent,\n                        boolean removeUnusedImports, boolean debuggingPrintOpsAfterFormatting) {\n                    return new FormattingOptions(style, maxWidth, blockIndent, continuationIndent, removeUnusedImports,\n                            debuggingPrintOpsAfterFormatting);\n                }\n            }\n            \"\"\",\n        \"com/facebook/ktfmt/format/Formatter.java\": \"\"\"\n            package com.facebook.ktfmt.format;\n\n            public class Formatter {\n                public static final FormattingOptions DEFAULT_FORMAT = new FormattingOptions();\n                public static final FormattingOptions DROPBOX_FORMAT = new FormattingOptions();\n                public static final FormattingOptions GOOGLE_FORMAT = new FormattingOptions();\n                public static final FormattingOptions KOTLINLANG_FORMAT = new FormattingOptions();\n\n                public static String format(String input) {\n                    return \\\"${prefix}-default:\\\" + input;\n                }\n\n                public static String format(FormattingOptions options, String input) {\n                    return \\\"${prefix}:\\\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, version, \"ktfmt-${version}.jar\", sources)\n}\n\nvoid createOldKtfmtFixture(File outputDir, String version, String prefix, boolean formatterFields) {\n    String fields = formatterFields ? \"\"\"\n                public static final FormattingOptions DEFAULT_FORMAT = new FormattingOptions();\n                public static final FormattingOptions DROPBOX_FORMAT = new FormattingOptions();\n                public static final FormattingOptions GOOGLE_FORMAT = new FormattingOptions();\n                public static final FormattingOptions KOTLINLANG_FORMAT = new FormattingOptions();\n        \"\"\" : \"\"\n    Map<String, String> sources = [\n        \"com/facebook/ktfmt/FormattingOptions.java\": \"\"\"\n            package com.facebook.ktfmt;\n\n            public class FormattingOptions {\n                public static class Companion {\n                    public Companion(Object marker) {}\n\n                    public FormattingOptions dropboxStyle() {\n                        return new FormattingOptions();\n                    }\n                }\n            }\n            \"\"\",\n        \"com/facebook/ktfmt/FormatterKt.java\": \"\"\"\n            package com.facebook.ktfmt;\n\n            public class FormatterKt {\n                ${fields}\n                public static String format(String input) {\n                    return \\\"${prefix}-default:\\\" + input;\n                }\n\n                public static String format(FormattingOptions options, String input) {\n                    return \\\"${prefix}-options:\\\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, version, \"ktfmt-${version}.jar\", sources)\n}\n\nvoid createJsonSimpleFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"org/json/JSONObject.java\": \"\"\"\n            package org.json;\n\n            public class JSONObject {\n                private final String input;\n\n                public JSONObject(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"object:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\",\n        \"org/json/JSONArray.java\": \"\"\"\n            package org.json;\n\n            public class JSONArray {\n                private final String input;\n\n                public JSONArray(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"array:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"json-simple-fixtures\", \"org-json\", \"org-json-fixture.jar\", sources)\n}\n\nvoid createFixtureJar(File outputDir, String version, String jarName, Map<String, String> sources) {\n    createFixtureJar(outputDir, \"ktfmt-fixtures\", version, jarName, sources)\n}\n\nvoid createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources) {\n    File workDir = new File(outputDir, \"work/${version}\")\n    File sourceDir = new File(workDir, \"src\")\n    File classesDir = new File(workDir, \"classes\")\n    sources.each { relativePath, source ->\n        File sourceFile = new File(sourceDir, relativePath)\n        sourceFile.parentFile.mkdirs()\n        sourceFile.text = source.stripIndent()\n    }\n    classesDir.mkdirs()\n    ant.javac(srcdir: sourceDir, destdir: classesDir, includeantruntime: false, source: \"8\", target: \"8\")\n\n    File resourceDir = new File(outputDir, \"${resourceRoot}/${version}\")\n    resourceDir.mkdirs()\n    ant.jar(destfile: new File(resourceDir, jarName), basedir: classesDir)\n\n    File indexFile = new File(outputDir, \"${resourceRoot}/${version}.classpath\")\n    indexFile.parentFile.mkdirs()\n    indexFile.text = \"${resourceRoot}/${version}/${jarName}\\n\"\n\n    delete(workDir)\n}\n\nsourceSets {\n    test {\n        resources.srcDir(ktfmtFixtureResources)\n        resources.srcDir(jsonSimpleFixtureResources)\n    }\n}\n\ntasks.named(\"processTestResources\") {\n    dependsOn(tasks.named(\"generateKtfmtFixtureJars\"))\n    dependsOn(tasks.named(\"generateJsonSimpleFixtureJar\"))\n}\n\ndependencies {\n    testImplementation \"com.diffplug.spotless:spotless-lib:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'org.slf4j:slf4j-api:2.0.17'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('-H:IncludeResources=(ktfmt-fixtures|json-simple-fixtures)/.*')\n        }\n    }\n\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777575280425}]}
