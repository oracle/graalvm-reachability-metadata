      ]
      createFixtureJar(outputDir, "json-simple-fixtures", "org-json", "org-json-fixture.jar", sources)
  }
  
  void createGoogleJavaFormatFixture(File outputDir) {
      Map<String, String> sources = [
          "com/diffplug/spotless/glue/java/GoogleJavaFormatFormatterFunc.java": """
              package com.diffplug.spotless.glue.java;
  
              import com.diffplug.spotless.FormatterFunc;
  
              public class GoogleJavaFormatFormatterFunc implements FormatterFunc {
                  private final String version;
                  private final String style;
                  private final boolean reflowLongStrings;
                  private final boolean reorderImports;
                  private final boolean formatJavadoc;
  
                  public GoogleJavaFormatFormatterFunc(String version, String style, boolean reflowLongStrings,
                          boolean reorderImports, boolean formatJavadoc) {
                      this.version = version;
                      this.style = style;
                      this.reflowLongStrings = reflowLongStrings;
                      this.reorderImports = reorderImports;
                      this.formatJavadoc = formatJavadoc;
                  }
  
                  public String apply(String input) {
                      return "format:" + version + ":" + style + ":" + reflowLongStrings + ":" + reorderImports + ":"
                              + formatJavadoc + ":" + input;
                  }
              }
              """,
          "com/diffplug/spotless/glue/java/GoogleJavaFormatRemoveUnusedImporterFormatterFunc.java": """
              package com.diffplug.spotless.glue.java;
  
              import com.diffplug.spotless.FormatterFunc;
  
              public class GoogleJavaFormatRemoveUnusedImporterFormatterFunc implements FormatterFunc {
                  private final String version;
  
                  public GoogleJavaFormatRemoveUnusedImporterFormatterFunc(String version) {
                      this.version = version;
                  }
  
                  public String apply(String input) {
                      return "remove-unused-imports:" + version + ":" + input;
                  }
              }
              """
      ]
      createFixtureJar(outputDir, "google-java-format-fixtures", "current", "google-java-format-fixture.jar", sources,
              sourceSets.test.compileClasspath.asPath)
  }
  
  void createFixtureJar(File outputDir, String version, String jarName, Map<String, String> sources) {
      createFixtureJar(outputDir, "ktfmt-fixtures", version, jarName, sources)
  }
  
  void createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources) {
      createFixtureJar(outputDir, resourceRoot, version, jarName, sources, null)
  }
  
  void createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources,
          String classpath) {
      File workDir = new File(outputDir, "work/${version}")
      File sourceDir = new File(workDir, "src")
      File classesDir = new File(workDir, "classes")
      sources.each { relativePath, source ->
          File sourceFile = new File(sourceDir, relativePath)
          sourceFile.parentFile.mkdirs()
          sourceFile.text = source.stripIndent()
      }
      classesDir.mkdirs()
      Map<String, Object> javacArguments = [srcdir: sourceDir, destdir: classesDir, includeantruntime: false, source: "8", target: "8"]
      if (classpath != null) {
          javacArguments.classpath = classpath
      }
      ant.javac(javacArguments)
  
      File resourceDir = new File(outputDir, "${resourceRoot}/${version}")
      resourceDir.mkdirs()
      ant.jar(destfile: new File(resourceDir, jarName), basedir: classesDir)
  
      File indexFile = new File(outputDir, "${resourceRoot}/${version}.classpath")
      indexFile.parentFile.mkdirs()
      indexFile.text = "${resourceRoot}/${version}/${jarName}\n"
  
      delete(workDir)
  }
  
  sourceSets {
      test {
          resources.srcDir(ktfmtFixtureResources)
          resources.srcDir(jsonSimpleFixtureResources)
          resources.srcDir(googleJavaFormatFixtureResources)
      }
  }
  
  tasks.named("processTestResources") {
      dependsOn(tasks.named("generateKtfmtFixtureJars"))
      dependsOn(tasks.named("generateJsonSimpleFixtureJar"))
      dependsOn(tasks.named("generateGoogleJavaFormatFixtureJar"))
  }
  
  dependencies {
      testImplementation "com.diffplug.spotless:spotless-lib:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testImplementation 'org.slf4j:slf4j-api:2.0.17'
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.add('-H:IncludeResources=(ktfmt-fixtures|json-simple-fixtures|google-java-format-fixtures)/.*')
          }
      }
  
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
