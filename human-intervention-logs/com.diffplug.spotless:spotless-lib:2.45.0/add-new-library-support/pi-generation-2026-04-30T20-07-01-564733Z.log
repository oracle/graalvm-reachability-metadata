asFile\n        delete(outputDir)\n\n        createJsonPatchFixture(outputDir)\n    }\n}\n\ntasks.register(\"generateGsonFixtureJar\") {\n    outputs.dir(gsonFixtureResources)\n\n    doLast {\n        File outputDir = gsonFixtureResources.get().asFile\n        delete(outputDir)\n\n        createGsonFixture(outputDir)\n    }\n}\n\ntasks.register(\"generateJacksonJsonFixtureJar\") {\n    outputs.dir(jacksonJsonFixtureResources)\n\n    doLast {\n        File outputDir = jacksonJsonFixtureResources.get().asFile\n        delete(outputDir)\n\n        createJacksonJsonFixture(outputDir)\n    }\n}\n\ntasks.register(\"generateGoogleJavaFormatFixtureJar\") {\n    outputs.dir(googleJavaFormatFixtureResources)\n\n    doLast {\n        File outputDir = googleJavaFormatFixtureResources.get().asFile\n        delete(outputDir)\n\n        createGoogleJavaFormatFixture(outputDir)\n    }\n}\n\ntasks.register(\"generatePalantirJavaFormatFixtureJar\") {\n    outputs.dir(palantirJavaFormatFixtureResources)\n\n    doLast {\n        File outputDir = palantirJavaFormatFixtureResources.get().asFile\n        delete(outputDir)\n\n        createPalantirJavaFormatFixture(outputDir)\n    }\n}\n\ntasks.register(\"generateCleanthatFixtureJar\") {\n    outputs.dir(cleanthatFixtureResources)\n\n    doLast {\n        File outputDir = cleanthatFixtureResources.get().asFile\n        delete(outputDir)\n\n        createCleanthatFixture(outputDir)\n    }\n}\n\ntasks.register(\"generateFreshMarkFixtureJar\") {\n    outputs.dir(freshMarkFixtureResources)\n\n    doLast {\n        File outputDir = freshMarkFixtureResources.get().asFile\n        delete(outputDir)\n\n        createFreshMarkFixture(outputDir)\n    }\n}\n\ntasks.register(\"generateAntlr4FormatterFixtureJar\") {\n    outputs.dir(antlr4FormatterFixtureResources)\n\n    doLast {\n        File outputDir = antlr4FormatterFixtureResources.get().asFile\n        delete(outputDir)\n\n        createAntlr4FormatterFixture(outputDir)\n    }\n}\n\ntasks.regist