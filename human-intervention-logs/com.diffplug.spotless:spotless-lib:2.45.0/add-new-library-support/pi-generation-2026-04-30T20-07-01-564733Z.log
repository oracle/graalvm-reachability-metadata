\n                public int getContinuationIndent() {\n                    return continuationIndent;\n                }\n\n                public boolean getRemoveUnusedImports() {\n                    return removeUnusedImports;\n                }\n\n                public boolean getDebuggingPrintOpsAfterFormatting() {\n                    return debuggingPrintOpsAfterFormatting;\n                }\n\n                public FormattingOptions copy(Style style, int maxWidth, int blockIndent, int continuationIndent,\n                        boolean removeUnusedImports, boolean debuggingPrintOpsAfterFormatting) {\n                    return new FormattingOptions(style, maxWidth, blockIndent, continuationIndent, removeUnusedImports,\n                            debuggingPrintOpsAfterFormatting);\n                }\n            }\n            \"\"\",\n        \"com/facebook/ktfmt/format/Formatter.java\": \"\"\"\n            package com.facebook.ktfmt.format;\n\n            public class Formatter {\n                public static final FormattingOptions DEFAULT_FORMAT = new FormattingOptions();\n                public static final FormattingOptions DROPBOX_FORMAT = new FormattingOptions();\n                public static final FormattingOptions GOOGLE_FORMAT = new FormattingOptions();\n                public static final FormattingOptions KOTLINLANG_FORMAT = new FormattingOptions();\n\n                public static String format(String input) {\n                    return \\\"${prefix}-default:\\\" + input;\n                }\n\n                public static String format(FormattingOptions options, String input) {\n                    return \\\"${prefix}:\\\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, version, \"ktfmt-${version}.jar\", sources)\n}\n\nvoid createOldKtfmtFixture(File outputDir, String version, String prefix, boolean formatterFields) {\n    String fields = formatterFields ? \"\"\"\n                public static final FormattingOptions DEFAULT_FORMAT = new FormattingOptions();\n                public static final FormattingOptions DROPBOX_FORMAT = new FormattingOptions();\n                public static final FormattingOptions GOOGLE_FORMAT = new FormattingOptions();\n                public static final FormattingOptions KOTLINLANG_FORMAT = new FormattingOptions();\n        \"\"\" : \"\"\n    Map<String, String> sources = [\n        \"com/facebook/ktfmt/FormattingOptions.java\": \"\"\"\n            package com.facebook.ktfmt;\n\n            public class FormattingOptions {\n                public static class Companion {\n                    public Companion(Object marker) {}\n\n                    public FormattingOptions dropboxStyle() {\n                        return new FormattingOptions();\n                    }\n                }\n            }\n            \"\"\",\n        \"com/facebook/ktfmt/FormatterKt.java\": \"\"\"\n            package com.facebook.ktfmt;\n\n            public class FormatterKt {\n                ${fields}\n                public static String format(String input) {\n                    return \\\"${prefix}-default:\\\" + input;\n                }\n\n                public static String format(FormattingOptions options, String input) {\n                    return \\\"${prefix}-options:\\\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, version, \"ktfmt-${version}.jar\", sources)\n}\n\nvoid createJsonSimpleFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"org/json/JSONObject.java\": \"\"\"\n            package org.json;\n\n            public class JSONObject {\n                private final String input;\n\n                public JSONObject(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"object:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\",\n        \"org/json/JSONArray.java\": \"\"\"\n            package org.json;\n\n            public class JSONArray {\n                private final String input;\n\n                public JSONArray(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"array:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"json-simple-fixtures\", \"org-json\", \"org-json-fixture.jar\", sources)\n}\n\nvoid createJsonPatchFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"com/diffplug/spotless/glue/json/JsonPatchFormatterFunc.java\": \"\"\"\n            package com.diffplug.spotless.glue.json;\n\n            import java.util.List;\n            import java.util.Map;\n\n            import com.diffplug.spotless.FormatterFunc;\n\n            public class JsonPatchFormatterFunc implements FormatterFunc {\n                private final List<Map<String, Object>> patch;\n                private final String patchString;\n\n                public JsonPatchFormatterFunc(List<Map<String, Object>> patch) {\n                    this.patch = patch;\n                    this.patchString = null;\n                }\n\n                public JsonPatchFormatterFunc(String patchString) {\n                    this.patch = null;\n                    this.patchString = patchString;\n                }\n\n                public String apply(String input) {\n                    if (patch != null) {\n                        return \"patch-list:\" + patch + \":\" + input;\n                    }\n                    return \"patch-string:\" + patchString + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"json-patch-fixtures\", \"current\", \"json-patch-fixture.jar\", sources,\n            sourceSets.test.compileClasspath.asPath)\n}\n\nvoid createGsonFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"com/diffplug/spotless/glue/gson/GsonFormatterFunc.java\": \"\"\"\n            package com.diffplug.spotless.glue.gson;\n\n            import com.diffplug.spotless.FormatterFunc;\n            import com.diffplug.spotless.json.gson.GsonConfig;\n\n            public class GsonFormatterFunc implements FormatterFunc {\n                private final GsonConfig config;\n\n                public GsonFormatterFunc(GsonConfig config) {\n                    this.config = config;\n                }\n\n                public String apply(String input) {\n                    return \"gson:\" + config.isSortByKeys() + \":\" + config.isEscapeHtml() + \":\"\n                            + config.getIndentSpaces() + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"gson-fixtures\", \"current\", \"gson-fixture.jar\", sources,\n            sourceSets.test.compileClasspath.asPath)\n}\n\nvoid createJacksonJsonFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"com/diffplug/spotless/glue/json/JacksonJsonFormatterFunc.java\": \"\"\"\n            package com.diffplug.spotless.glue.json;\n\n            import com.diffplug.spotless.FormatterFunc;\n            import com.diffplug.spotless.json.JacksonJsonConfig;\n\n            public class JacksonJsonFormatterFunc implements FormatterFunc {\n                private final JacksonJsonConfig config;\n\n                public JacksonJsonFormatterFunc(JacksonJsonConfig config) {\n                    this.config = config;\n                }\n\n                public String apply(String input) {\n                    return \"jackson-json:\" + config.getFeatureToToggle() + \":\"\n                            + config.getJsonFeatureToToggle() + \":\" + config.isSpaceBeforeSeparator() + \":\"\n                            + input;\n           