  void createModernKtfmtFixture(File outputDir, String version, String prefix) {
      Map<String, String> sources = [
          "com/facebook/ktfmt/format/FormattingOptions.java": """
              package com.facebook.ktfmt.format;
  
              public class FormattingOptions {
                  public enum Style {
                      DEFAULT
                  }
  
                  private final Style style;
                  private final int maxWidth;
                  private final int blockIndent;
                  private final int continuationIndent;
                  private final boolean removeUnusedImports;
                  private final boolean debuggingPrintOpsAfterFormatting;
  
                  public FormattingOptions() {
                      this(Style.DEFAULT, 100, 4, 4, true, false);
                  }
  
                  public FormattingOptions(Style style, int maxWidth, int blockIndent, int continuationIndent,
                          boolean removeUnusedImports, boolean debuggingPrintOpsAfterFormatting) {
                      this.style = style;
                      this.maxWidth = maxWidth;
                      this.blockIndent = blockIndent;
                      this.continuationIndent = continuationIndent;
                      this.removeUnusedImports = removeUnusedImports;
                      this.debuggingPrintOpsAfterFormatting = debuggingPrintOpsAfterFormatting;
                  }
  
                  public Style getStyle() {
