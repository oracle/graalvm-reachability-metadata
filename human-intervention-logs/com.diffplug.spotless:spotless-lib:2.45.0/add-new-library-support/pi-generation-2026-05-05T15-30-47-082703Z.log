 createsStyledFormatterWithModernGlueConstructor() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.46\", PROVISIONER, Style.GOOGLE, null);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"fun message\");\n    }\n\n    @Test\n    void createsOptionsFormatterWithModernGlueConstructor() throws Exception {\n        KtfmtFormattingOptions options = new KtfmtFormattingOptions();\n        options.setMaxWidth(100);\n        options.setBlockIndent(4);\n        options.setContinuationIndent(4);\n        options.setRemoveUnusedImport(false);\n        FormatterStep step = KtfmtStep.create(\"0.46\", PROVISIONER, null, options);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"Hello\");\n    }\n\n    @Test\n    void createsStyledOptionsFormatterWithModernGlueConstructor() throws Exception {\n        KtfmtFormattingOptions options = new KtfmtFormattingOptions(80, 2, 4, false);\n        FormatterStep step = KtfmtStep.create(\"0.46\", PROVISIONER, Style.KOTLINLANG, options);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"Greeting\");\n    }\n\n    @Test\n    void formatsWithPreFormatPackageDefaultFallback() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.18\", PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"class Greeting\");\n    }\n\n    @Test\n    void formatsWithModernFallbackStaticStyleField() throws Exception {\n        FormatterStep step = KtfmtStep.create(\"0.31\", PROVISIONER, Style.DROPBOX, null);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step);\n\n        assertThat(formatted).contains(\"fun message\");\n    }\n\n    @Test\n    void formatsWithLegacyFallbackCompanionStyleFactory() throws Exception {\n        Formatte