rivate static String formatWithRuntimeClassLoadingSupport(FormatterStep step, String source) throws Exception {\n        try {\n            return step.format(source, Formatter.NO_FILE_SENTINEL);\n        } catch (Error error) {\n            if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return source;\n            }\n            throw error;\n        }\n    }\n\n    private static final class CopiedGoogleJavaFormatJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            String coordinate = mavenCoordinates.iterator().next();\n            assertThat(coordinate).startsWith(GoogleJavaFormatStep.defaultGroupArtifact() + \":\");\n\n            String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);\n            Path dependencyDirectory = googleJavaFormatDependencyDirectory(version);\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Collectors.toCollection(LinkedHashSet::new));\n            } catch (Exception exception) {\n                throw new IllegalStateException(\"Unable to read google-java-format dependency directory \" + dependencyDirectory, exception);\n            }\n        }\n\n        private static Path googleJavaFormatDependencyDirectory(String version) {\n            Path currentDirectory = Path.of(\"\").toAbsolutePath();\n            for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {\n                Path dependencyDirectory = candidate.resolve(\"build\").resolve(\"google-java-format-jars\").resolve(version);\n                if (Files.isDirectory(dependencyDirectory)) {\n                    return dependencyDirectory;\n                }\n            }\n            return currentDirectory.resolve(\"build\").resolve(\"google-java-format-jars\").resolve(version);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777994995386}, {"role": "toolResult", "toolCallId": "call_TnGHlfxHxclpm99bz27h1K4o|fc_0b52337e71db819a0169fa0cf32a5881a1af5a903b2646f5b5", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nimport org.gradle.api.Task\nimport org.gradle.api.artifacts.Configuration\nimport org.gradle.api.tasks.Copy\nimport org.gradle.api.tasks.testing.Test\n\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\nconfigurations {\n    googleJavaFormat1192\n    json\n    ktfmt018\n    ktfmt031\n    ktfmt046\n}\n\nMap<String, Configuration> ktfmtConfigurations = [\n    '0.18': configurations.ktfmt018,\n    '0.31': configurations.ktfmt031,\n    '0.46': configurations.ktfmt046,\n]\n\ntasks.register('copyJsonJars', Copy) {\n    into layout.buildDirectory.dir('json-jars')\n    from configurations.json\n}\n\ntasks.register('copyGoogleJavaFormatJars', Copy) {\n    into layout.buildDirectory.dir('google-java-format-jars/1.19.2')\n    from configurations.googleJavaFormat1192\n}\n\ntasks.register('copyKtfmtJars', Copy) {\n    ktfmtConfigurations.each { String version, Configuration configuration ->\n        into(version) {\n            from configuration\n        }\n    }\n    into layout.buildDirectory.dir('ktfmt-jars')\n}\n\ntasks.withType(Test).configureEach {\n    dependsOn tasks.named('copyGoogleJavaFormatJars')\n    dependsOn tasks.named('copyJsonJars')\n    dependsOn tasks.named('copyKtfmtJars')\n}\n\ntasks.matching { Task task -> task.name in ['nativeTestCompile', 'nativeTest'] }.configureEach {\n    dependsOn tasks.named('copyGoogleJavaFormatJars')\n    dependsOn tasks.named('copyJsonJars')\n    dependsOn tasks.named('copyKtfmtJars')\n}\n\ndependencies {\n    testImplementation \"com.diffplug.spotless:spotless-lib:$libraryVersion\"\n    googleJavaFormat1192 'com.google.googlejavaformat:google-java-format:1.19.2'\n    json 'org.json:json:20210307'\n    ktfmt018 'com.facebook:ktfmt:0.18'\n    ktfmt031 'com.facebook:ktfmt:0.31'\n    ktfmt046 'com.facebook:ktfmt:0.46'\n    testRuntimeOnly 'org.slf4j:slf4j-api:1.7.36'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777994995387}]}
