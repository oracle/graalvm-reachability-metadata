  import java.io.File;
  import java.util.Collection;
  import java.util.Collections;
  import java.util.NoSuchElementException;
  import java.util.Set;
  
  import com.diffplug.spotless.Formatter;
  import com.diffplug.spotless.FormatterStep;
  import com.diffplug.spotless.Provisioner;
  import com.diffplug.spotless.java.GoogleJavaFormatStep;
  
  import org.junit.jupiter.api.Test;
  
  public class ModuleHelperTest {
      @Test
      void googleJavaFormatInitializationOpensRequiredJdkCompilerPackages() {
          RecordingEmptyProvisioner provisioner = new RecordingEmptyProvisioner();
          FormatterStep step = GoogleJavaFormatStep.create(GoogleJavaFormatStep.defaultVersion(), provisioner);
  
          assertThatThrownBy(() -> step.format("class Example{}\n", Formatter.NO_FILE_SENTINEL))
                  .isInstanceOf(NoSuchElementException.class)
                  .hasMessageContaining(GoogleJavaFormatStep.defaultGroupArtifact());
          assertThat(provisioner.requestedCoordinates)
                  .singleElement()
                  .asString()
                  .startsWith(GoogleJavaFormatStep.defaultGroupArtifact() + ":");
      }
  
      private static final class RecordingEmptyProvisioner implements Provisioner {
          private Collection<String> requestedCoordinates = Collections.emptyList();
  
          @Override
          public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {
              assertThat(withTransitives).isTrue();
              requestedCoordinates = mavenCoordinates;
              return Collections.emptySet();
          }
      }
  }
