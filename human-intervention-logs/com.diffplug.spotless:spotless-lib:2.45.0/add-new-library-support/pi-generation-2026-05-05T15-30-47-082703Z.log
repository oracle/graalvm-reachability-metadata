[tool-call] delta {"path":"tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/GoogleJavaFormatStepInnerStateTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.Comparator;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\nimport java.util.stream.Collectors;\nimport java.util.stream.Stream;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.SpotlessCache;\nimport com.diffplug.spotless.java.GoogleJavaFormatStep;\nimport com.diffplug.spotless.java.RemoveUnusedImportsStep;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class GoogleJavaFormatStepInnerStateTest {\n    private static final String UNFORMATTED_JAVA_SOURCE = \"\"\"\n            package demo;\n            import java.util.List;\n            class Example{List<String> names(){return java.util.List.of(\"one\");}}\n            \"\"\";\n    private static final String JAVA_SOURCE_WITH_UNUSED_IMPORT = \"\"\"\n            package demo;\n            import java.util.List;\n            import java.util.Set;\n            class Example {\n              List<String> names;\n            }\n            \"\"\";\n    private static final Provisioner PROVISIONER = new CopiedGoogleJavaFormatJarProvisioner();\n\n    @AfterEach\n    void clearCachedGoogleJavaFormatClassLoaders() {\n        SpotlessCache.clearOnce(null);\n    }\n\n    @Test\n    void createsFullFormatterThroughGoogleJavaFormatGlue() throws Exception {\n        FormatterStep step = GoogleJavaFormatStep.create(GoogleJavaFormatStep.defaultVersion(), PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step, UNFORMATTED_JAVA_SOURCE);\n\n        assertThat(formatted).contains(\"class Example {\");\n        assertThat(formatted).contains(\"List<String> names() {\");\n    }\n\n    @Test\n    void createsRemoveUnusedImportsOnlyFormatterThroughGoogleJavaFormatGlue() throws Exception {\n        FormatterStep step = RemoveUnusedImportsStep.create(PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step, JAVA_SOURCE_WITH_UNUSED_IMPORT);\n\n        assertThat(formatted).contains(\"import java.util.List;\");\n        assertThat(formatted).doesNotContain(\"import java.util.Set;\");\n    }\n\n    private static String formatWithRuntimeClassLoadingSupport(FormatterStep step, String source) throws Exception {\n        try {\n            return step.format(source, Formatter.NO_FILE_SENTINEL);\n        } catch (Error error) {\n            if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return source;\n            }\n            throw error;\n        }\n    }\n\n    private static final class CopiedGoogleJavaFormatJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            String coordinate = mavenCoordinates.iterator().next();\n            assertThat(coordinate).startsWith(GoogleJavaFormatStep.defaultGroupArtifact() + \":\");\n\n            String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);\n            Path dependencyDirectory = googleJavaFormatDependencyDirectory(version);\n            assertThat(dependencyDirectory).isDirectory();\n            try