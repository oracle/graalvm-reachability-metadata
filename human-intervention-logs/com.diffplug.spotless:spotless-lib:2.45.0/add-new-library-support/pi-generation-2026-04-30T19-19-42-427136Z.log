  void createModernKtfmtFixture(File outputDir, String version, String prefix) {
      Map<String, String> sources = [
          "com/facebook/ktfmt/format/FormattingOptions.java": """
              package com.facebook.ktfmt.format;
  
              public class FormattingOptions {
                  public enum Style {
                      DEFAULT
                  }
  
                  private final Style style;
                  private final int maxWidth;
                  private final int blockIndent;
                  private final int continuationIndent;
                  private final boolean removeUnusedImports;
                  private final boolean debuggingPrintOpsAfterFormatting;
  
                  public FormattingOptions() {
                      this(Style.DEFAULT, 100, 4, 4, true, false);
                  }
  
                  public FormattingOptions(Style style, int maxWidth, int blockIndent, int continuationIndent,
                          boolean removeUnusedImports, boolean debuggingPrintOpsAfterFormatting) {
                      this.style = style;
                      this.maxWidth = maxWidth;
                      this.blockIndent = blockIndent;
                      this.continuationIndent = continuationIndent;
                      this.removeUnusedImports = removeUnusedImports;
                      this.debuggingPrintOpsAfterFormatting = debuggingPrintOpsAfterFormatting;
                  }
  
                  public Style getStyle() {
                      return style;
                  }
  
                  public int getMaxWidth() {
                      return maxWidth;
                  }
  
                  public int getBlockIndent() {
                      return blockIndent;
                  }
  
                  public int getContinuationIndent() {
                      return continuationIndent;
                  }
  
                  public boolean getRemoveUnusedImports() {
                      return removeUnusedImports;
                  }
  
                  public boolean getDebuggingPrintOpsAfterFormatting() {
                      return debuggingPrintOpsAfterFormatting;
                  }
  
                  public FormattingOptions copy(Style style, int maxWidth, int blockIndent, int continuationIndent,
                          boolean removeUnusedImports, boolean debuggingPrintOpsAfterFormatting) {
                      return new FormattingOptions(style, maxWidth, blockIndent, continuationIndent, removeUnusedImports,
                              debuggingPrintOpsAfterFormatting);
                  }
              }
              """,
          "com/facebook/ktfmt/format/Formatter.java": """
              package com.facebook.ktfmt.format;
  
              public class Formatter {
                  public static final FormattingOptions DEFAULT_FORMAT = new FormattingOptions();
                  public static final FormattingOptions DROPBOX_FORMAT = new FormattingOptions();
                  public static final FormattingOptions GOOGLE_FORMAT = new FormattingOptions();
                  public static final FormattingOptions KOTLINLANG_FORMAT = new FormattingOptions();
  
                  public static String format(String input) {
                      return \"${prefix}-default:\" + input;
                  }
  
                  public static String format(FormattingOptions options, String input) {
                      return \"${prefix}:\" + input;
                  }
              }
              """
      ]
      createFixtureJar(outputDir, version, "ktfmt-${version}.jar", sources)
  }
  
