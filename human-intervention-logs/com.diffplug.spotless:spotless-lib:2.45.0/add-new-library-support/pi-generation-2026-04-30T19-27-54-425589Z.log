  void createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources,
          String classpath) {
      File workDir = new File(outputDir, "work/${version}")
      File sourceDir = new File(workDir, "src")
      File classesDir = new File(workDir, "classes")
      sources.each { relativePath, source ->
          File sourceFile = new File(sourceDir, relativePath)
          sourceFile.parentFile.mkdirs()
          sourceFile.text = source.stripIndent()
      }
      classesDir.mkdirs()
      Map<String, Object> javacArguments = [srcdir: sourceDir, destdir: classesDir, includeantruntime: false, source: "8", target: "8"]
      if (classpath != null) {
          javacArguments.classpath = classpath
      }
      ant.javac(javacArguments)
  
      File resourceDir = new File(outputDir, "${resourceRoot}/${version}")
      resourceDir.mkdirs()
      ant.jar(destfile: new File(resourceDir, jarName), basedir: classesDir)
  
      File indexFile = new File(outputDir, "${resourceRoot}/${version}.classpath")
      indexFile.parentFile.mkdirs()
      indexFile.text = "${resourceRoot}/${version}/${jarName}\n"
  
      delete(workDir)
  }
  
