ions {\n                public enum Style {\n                    DEFAULT\n                }\n\n                private final Style style;\n                private final int maxWidth;\n                private final int blockIndent;\n                private final int continuationIndent;\n                private final boolean removeUnusedImports;\n                private final boolean debuggingPrintOpsAfterFormatting;\n\n                public FormattingOptions() {\n                    this(Style.DEFAULT, 100, 4, 4, true, false);\n                }\n\n                public FormattingOptions(Style style, int maxWidth, int blockIndent, int continuationIndent,\n                        boolean removeUnusedImports, boolean debuggingPrintOpsAfterFormatting) {\n                    this.style = style;\n                    this.maxWidth = maxWidth;\n                    this.blockIndent = blockIndent;\n                    this.continuationIndent = continuationIndent;\n                    this.removeUnusedImports = removeUnusedImports;\n                    this.debuggingPrintOpsAfterFormatting = debuggingPrintOpsAfterFormatting;\n                }\n\n                public Style getStyle() {\n                    return style;\n                }\n\n                public int getMaxWidth() {\n                    return maxWidth;\n                }\n\n                public int getBlockIndent() {\n                    return blockIndent;\n                }\n\n                public int getContinuationIndent() {\n                    return continuationIndent;\n                }\n\n                public boolean getRemoveUnusedImports() {\n                    return removeUnusedImports;\n                }\n\n                public boolean getDebuggingPrintOpsAfterFormatting() {\n                    return debuggingPrintOpsAfterFormatting;\n                }\n\n                public FormattingOptions copy(Style style, int maxWidth, int blockIndent, int continuationIndent,\n                        boolean removeUnusedImports, boolean debuggingPrintOpsAfterFormatting) {\n                    return new FormattingOptions(style, maxWidth, blockIndent, continuationIndent, removeUnusedImports,\n                            debuggingPrintOpsAfterFormatting);\n                }\n            }\n            \"\"\",\n        \"com/facebook/ktfmt/format/Formatter.java\": \"\"\"\n            package com.facebook.ktfmt.format;\n\n            public class Formatter {\n                public static final FormattingOptions DEFAULT_FORMAT = new FormattingOptions();\n                public static final FormattingOptions DROPBOX_FORMAT = new FormattingOptions();\n                public static final FormattingOptions GOOGLE_FORMAT = new FormattingOptions();\n                public static final FormattingOptions KOTLINLANG_FORMAT = new FormattingOptions();\n\n                public static String format(String input) {\n                    return \\\"${prefix}-default:\\\" + input;\n                }\n\n                public static String format(FormattingOptions options, String input) {\n                    return \\\"${prefix}:\\\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, version, \"ktfmt-${version}.jar\", sources)\n}\n\nvoid createOldKtfmtFixture(File outputDir, String version, String prefix, boolean formatterFields) {\n    String fields = formatterFields ? \"\"\"\n                public static final FormattingOptions DEFAULT_FORMAT = new FormattingOptions();\n                public static final FormattingOptions DROPBOX_FORMAT = new FormattingOptions();\n                public static final FormattingOptions GOOGLE_FORMAT = new FormattingOptions();\n                public static final FormattingOptions KOTLINLANG_FORMAT = new FormattingOptions();\n        \"\"\" : \"\"\n    Map<String, String> sources = [\n        \"com/facebook/ktfmt/FormattingOptions.java\": \"\"\"\n            package com.facebook.ktfmt;\n\n            public class FormattingOptions {\n                public static class Companion {\n                    public Companion(Object marker) {}\n\n                    public FormattingOptions dropboxStyle() {\n                        return new FormattingOptions();\n                    }\n                }\n            }\n            \"\"\",\n        \"com/facebook/ktfmt/FormatterKt.java\": \"\"\"\n            package com.facebook.ktfmt;\n\n            public class FormatterKt {\n                ${fields}\n                public static String format(String input) {\n                    return \\\"${prefix}-default:\\\" + input;\n                }\n\n                public static String format(FormattingOptions options, String input) {\n                    return \\\"${prefix}-options:\\\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, version, \"ktfmt-${version}.jar\", sources)\n}\n\nvoid createJsonSimpleFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"org/json/JSONObject.java\": \"\"\"\n            package org.json;\n\n            public class JSONObject {\n                private final String input;\n\n                public JSONObject(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"object:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\",\n        \"org/json/JSONArray.java\": \"\"\"\n            package org.json;\n\n            public class JSONArray {\n                private final String input;\n\n                public JSONArray(String input) {\n                    this.input = input;\n                }\n\n                public String toString(int indentFactor) {\n                    return \"array:\" + indentFactor + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"json-simple-fixtures\", \"org-json\", \"org-json-fixture.jar\", sources)\n}\n\nvoid createCleanthatFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"com/diffplug/spotless/glue/java/JavaCleanthatRefactorerFunc.java\": \"\"\"\n            package com.diffplug.spotless.glue.java;\n\n            import java.util.List;\n\n            public class JavaCleanthatRefactorerFunc {\n                private final String sourceJdkVersion;\n                private final List<String> included;\n                private final List<String> excluded;\n                private final boolean includeDraft;\n\n                public JavaCleanthatRefactorerFunc(String sourceJdkVersion, List<String> included,\n                        List<String> excluded, boolean includeDraft) {\n                    this.sourceJdkVersion = sourceJdkVersion;\n                    this.included = included;\n                    this.excluded = excluded;\n                    this.includeDraft = includeDraft;\n                }\n\n                public String apply(String input) {\n                    return \"cleanthat:\" + sourceJdkVersion + \":\" + included + \":\" + excluded + \":\"\n                            + includeDraft + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"cleanthat-fixtures\", \"current\", \"cleanthat-fixture.jar\", sources)\n}\n\nvoid createGoogleJavaFormatFixture(File outputDir) {\n    Map<String, String> sources = [\n        \"com/diffplug/spotless/glue/java/GoogleJavaFormatFormatterFunc.java\": \"\"\"\n            package com.diffplug.spotless.glue.java;\n\n            import com.diffplug.spotless.FormatterFunc;\n\n            public class GoogleJavaFormatFormatterFunc implements FormatterFunc {\n                private final String version;\n                private final String style;\n                private final boolean reflowLongStrings;\n                private final boolean reorderImports;\n                private final boolean formatJavadoc;\n\n                public GoogleJavaFormatFormatterFunc(String version, String style, boolean reflowLongStrings,\n                        boolean reorderImports, boolean formatJavadoc) {\n                    this.version = version;\n                    this.style = style;\n                    this.reflowLongStrings = reflowLongStrings;\n                    this.reorderImports = reorderImports;\n                    this.formatJavadoc = formatJavadoc;\n                }\n\n                public String apply(String input) {\n                    return \"format:\" + version + \":\" + style + \":\" + reflowLongStrings + \":\" + reorderImports + \":\"\n                            + formatJavadoc + \":\" + input;\n                }\n            }\n            \"\"\",\n        \"com/diffplug/spotless/glue/java/GoogleJavaFormatRemoveUnusedImporterFormatterFunc.java\": \"\"\"\n            package com.diffplug.spotless.glue.java;\n\n            import com.diffplug.spotless.FormatterFunc;\n\n            public class GoogleJavaFormatRemoveUnusedImporterFormatterFunc implements FormatterFunc {\n                private final String version;\n\n                public GoogleJavaFormatRemoveUnusedImporterFormatterFunc(String version) {\n                    this.version = version;\n                }\n\n                public String apply(String input) {\n                    return \"remove-unused-imports:\" + version + \":\" + input;\n                }\n            }\n            \"\"\"\n    ]\n    createFixtureJar(outputDir, \"google-java-format-fixtures\", \"current\", \"google-java-format-fixture.jar\", sources,\n            sourceSets.test.compileClasspath.asPath)\n}\n\nvoid createFixtureJar(File outputDir, String version, String jarName, Map<String, String> sources) {\n    createFixtureJar(outputDir, \"ktfmt-fixtures\", version, jarName, sources)\n}\n\nvoid createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources) {\n    createFixtureJar(outputDir, resourceRoot, version, jarName, sources, null)\n}\n\nvoid createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources,\n        String classpath) {\n    File workDir = new File(outputDir, \"work/${version}\")\n    File sourceDir = new File(workDir, \"src\")\n    File classesDir = new File(workDir, \"classes\")\n    sources.each { relativePath, source ->\n        File sourceFile = new File(sourceDir, relativePath)\n        sourceFile.parentFile.mkdirs()\n        sourceFile.text = source.stripIndent()\n    }\n    classesDir.mkdirs()\n    Map<String, Object> javacArguments = [srcdir: sourceDir, destdir: classesDir, includeantruntime: false, source: \"8\", target: \"8\"]\n    if (classpath != null) {\n        javacArguments.classpath = classpath\n    }\n    ant.javac(javacArguments)\n\n    File resourceDir = new File(outputDir, \"${resourceRoot}/${version}\")\n    resourceDir.mkdirs()\n    ant.jar(destfile: new File(resourceDir, jarName), basedir: classesDir)\n\n    File indexFile = new File(outputDir, \"${resourceRoot}/${version}.classpath\")\n    indexFile.parentFile.mkdirs()\n    indexFile.text = \"${resourceRoot}/${version}/${jarName}\\n\"\n\n    delete(workDir)\n}\n\nsourceSets {\n    test {\n        resources.srcDir(ktfmtFixtureResources)\n        resources.srcDir(jsonSimpleFixtureResources)\n        resources.srcDir(googleJavaFormatFixtureResources)\n        resources.srcDir(cleanthatFixtureResources)\n    }\n}\n\ntasks.named(\"processTestResources\") {\n    dependsOn(tasks.named(\"generateKtfmtFixtureJars\"))\n    dependsOn(tasks.named(\"generateJsonSimpleFixtureJar\"))\n    dependsOn(tasks.named(\"generateGoogleJavaFormatFixtureJar\"))\n    dependsOn(tasks.named(\"generateCleanthatFixtureJar\"))\n}\n\ndependencies {\n    testImplementation \"com.diffplug.spotless:spotless-lib:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'org.slf4j:slf4j-api:2.0.17'\n}\n\ngraalvmNative {\n    binaries {\n        test {\n            buildArgs.add('-H:IncludeResources=(ktfmt-fixtures|json-simple-fixtures|google-java-format-fixtures|cleanthat-fixtures)/.*')\n        }\n    }\n\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777576246687}, {"role": "toolResult", "toolCallId": "call_zfCpsFUaRVWjq1kiN6mfPhzf|fc_0539d8a9506c05340169f3a935e39081908fa00b768fea40b8", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.BufferedReader;\nimport java.io.File;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.io.InputStreamReader;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.StandardCopyOption;\nimport java.util.Collection;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.json.JsonSimpleStep;\n\npublic class JsonSimpleStepInnerStateTest {\n    private static final String OBJECT_INPUT = \"{\\\"name\\\":\\\"spotless\\\"}\";\n    private static final String ARRAY_INPUT = \"[\\\"spotless\\\",\\\"json\\\"]\";\n\n    @Test\n    void formatsJsonObjectsAndArraysThroughProvisionedJsonImplementation() throws Exception {\n        final FormatterStep step = JsonSimpleStep.create(2, new FixtureProvisioner());\n\n        assertThat(step.format(OBJECT_INPUT, Formatter.NO_FILE_SENTINEL)).isEqualTo(\"object:2:\" + OBJECT_INPUT + \"\\n\");\n        assertThat(step.format(ARRAY_INPUT, Formatter.NO_FILE_SENTINEL)).isEqualTo(\"array:2:\" + ARRAY_INPUT + \"\\n\");\n    }\n\n    private static final class FixtureProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            return extractFixtureJars();\n        }\n\n        private static Set<File> extractFixtureJars() {\n            try {\n                final Set<File> files = new LinkedHashSet<>();\n                try (InputStream inputStream = resource(\"json-simple-fixtures/org-json.classpath\");\n                        BufferedReader reader = new BufferedReader(new InputStreamReader(inputStream, StandardCharsets.UTF_8))) {\n                    String jarResource;\n                    while ((jarResource = reader.readLine()) != null) {\n                        if (!jarResource.isBlank()) {\n                            files.add(extractResource(jarResource).toFile());\n                        }\n                    }\n                }\n                return files;\n            } catch (IOException e) {\n                throw new IllegalStateException(\"Unable to extract JSON fixture jars\", e);\n            }\n        }\n\n        private static Path extractResource(String resourceName) throws IOException {\n            final Path resourcePath = Path.of(resourceName);\n            final Path targetDirectory = Files.createTempDirectory(\"json-simple-fixture-\");\n            final Path target = targetDirectory.resolve(resourcePath.getFileName().toString());\n            try (InputStream inputStream = resource(resourceName)) {\n                Files.copy(inputStream, target, StandardCopyOption.REPLACE_EXISTING);\n            }\n            target.toFile().deleteOnExit();\n            targetDirectory.toFile().deleteOnExit();\n            return target;\n        }\n\n        private static InputStream resource(String resourceName) {\n            final InputStream inputStream = JsonSimpleStepInnerStateTest.class.getClassLoader().getResourceAsStream(resourceName);\n            if (inputStream == null) {\n                throw new IllegalArgumentException(\"Missing test resource: \" + resourceName);\n            }\n            return inputStream;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777576246688}, {"role": "toolResult", "toolCallId": "call_aAfarJRaOP7dxbzBI1PxRpNw|fc_0539d8a9506c05340169f3a935e39881908b51627b776059d1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.File;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.List;\nimport java.util.Objects;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.diffplug.spotless.FormatExceptionPolicy;\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.LineEnding;\n\npublic class FormatterTest {\n    @Test\n    void serializesAndDeserializesFormatterConfiguration() throws Exception {\n        final Path rootDir = Files.createTempDirectory(\"spotless-formatter-\");\n        rootDir.toFile().deleteOnExit();\n        final Formatter formatter = Formatter.builder()\n                .name(\"configured formatter\")\n                .lineEndingsPolicy(LineEnding.UNIX.createPolicy())\n                .encoding(StandardCharsets.UTF_8)\n                .rootDir(rootDir)\n                .steps(List.of(new AppendSuffixStep(\"!\")))\n                .exceptionPolicy(FormatExceptionPolicy.failOnlyOnError())\n                .build();\n\n        final byte[] serialized = serialize(formatter);\n        final Formatter restored = deserialize(serialized);\n\n        assertThat(restored.getName()).isEqualTo(formatter.getName());\n        assertThat(restored.getLineEndingsPolicy()).isEqualTo(formatter.getLineEndingsPolicy());\n        assertThat(restored.getEncoding()).isEqualTo(formatter.getEncoding());\n        assertThat(restored.getRootDir()).isEqualTo(formatter.getRootDir());\n        assertThat(restored.getSteps()).isEqualTo(formatter.getSteps());\n        assertThat(restored.getExceptionPolicy()).isEqualTo(formatter.getExceptionPolicy());\n        assertThat(restored.compute(\"value\", Formatter.NO_FILE_SENTINEL)).isEqualTo(\"value!\");\n    }\n\n    private static byte[] serialize(Formatter formatter) throws Exception {\n        final ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(formatter);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Formatter deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (Formatter) inputStream.readObject();\n        }\n    }\n\n    private static final class AppendSuffixStep implements FormatterStep {\n        private static final long serialVersionUID = 1L;\n\n        private final String suffix;\n\n        private AppendSuffixStep(String suffix) {\n            this.suffix = Objects.requireNonNull(suffix, \"suffix\");\n        }\n\n        @Override\n        public String getName() {\n            return \"append suffix\";\n        }\n\n        @Override\n        public String format(String rawUnix, File file) {\n            return rawUnix + suffix;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (other == null || getClass() != other.getClass()) {\n                return false;\n            }\n            final AppendSuffixStep that = (AppendSuffixStep) other;\n            return suffix.equals(that.suffix);\n        }\n\n        @Override\n        public int hashCode() {\n            return suffix.hashCode();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777576246688}, {"role": "toolResult", "toolCallId": "call_caDXsEAvlADsdugXzJBeDxic|fc_0539d8a9506c05340169f3a935e3a081908a56fab387451cb7", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/jovan/Work/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/3825-b3518cd0/local_repositories/source_context/com.diffplug.spotless/spotless-lib/2.45.0/main/extracted/com/diffplug/spotless/json/JsonPatchStep.java'"}], "details": {}, "isError": true, "timestamp": 1777576246689}]}
