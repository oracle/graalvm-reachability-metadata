[tool-call] delta {"path":"tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/ModuleHelperTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.File;\nimport java.util.Collection;\nimport java.util.Collections;\nimport java.util.NoSuchElementException;\nimport java.util.Set;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.java.GoogleJavaFormatStep;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ModuleHelperTest {\n    @Test\n    void googleJavaFormatInitializationOpensRequiredJdkCompilerPackages() {\n        RecordingEmptyProvisioner provisioner = new RecordingEmptyProvisioner();\n        FormatterStep step = GoogleJavaFormatStep.create(GoogleJavaFormatStep.defaultVersion(), provisioner);\n\n        assertThatThrownBy(() -> step.format(\"class Example{}\\n\", Formatter.NO_FILE_SENTINEL))\n                .isInstanceOf(NoSuchElementException.class)\n                .hasMessageContaining(GoogleJavaFormatStep.defaultGroupArtifact());\n        assertThat(provisioner.requestedCoordinates)\n                .singleElement()\n                .asString()\n                .startsWith(GoogleJavaFormatStep.defaultGroupArtifact() + \":\");\n    }\n\n    private static final class RecordingEmptyProvisioner implements Provisioner {\n        private Collection<String> requestedCoordinates = Collections.emptyList();\n\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            requestedCoordinates = mavenCoordinates;\n            return Collections.emptySet();\n        }\n    }\n}\n"}
