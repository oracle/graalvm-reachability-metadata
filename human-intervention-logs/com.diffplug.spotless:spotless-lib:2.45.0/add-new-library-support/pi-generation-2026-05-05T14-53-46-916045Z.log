  import org.gradle.api.Task
  import org.gradle.api.artifacts.Configuration
  import org.gradle.api.tasks.Copy
  import org.gradle.api.tasks.testing.Test
  
  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  configurations {
      ktfmt018
      ktfmt031
      ktfmt046
  }
  
  Map<String, Configuration> ktfmtConfigurations = [
      '0.18': configurations.ktfmt018,
      '0.31': configurations.ktfmt031,
      '0.46': configurations.ktfmt046,
  ]
  
  tasks.register('copyKtfmtJars', Copy) {
      ktfmtConfigurations.each { String version, Configuration configuration ->
          into(version) {
              from configuration
          }
      }
      into layout.buildDirectory.dir('ktfmt-jars')
  }
  
  tasks.withType(Test).configureEach {
      dependsOn tasks.named('copyKtfmtJars')
  }
  
  tasks.matching { Task task -> task.name in ['nativeTestCompile', 'nativeTest'] }.configureEach {
      dependsOn tasks.named('copyKtfmtJars')
  }
  
  dependencies {
      testImplementation "com.diffplug.spotless:spotless-lib:$libraryVersion"
      ktfmt018 'com.facebook:ktfmt:0.18'
      ktfmt031 'com.facebook:ktfmt:0.31'
      ktfmt046 'com.facebook:ktfmt:0.46'
      testRuntimeOnly 'org.slf4j:slf4j-api:1.7.36'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
