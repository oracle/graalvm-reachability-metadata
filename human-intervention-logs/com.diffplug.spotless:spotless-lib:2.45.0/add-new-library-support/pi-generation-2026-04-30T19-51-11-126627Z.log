              final InputStream inputStream = JsonSimpleStepInnerStateTest.class.getClassLoader().getResourceAsStream(resourceName);
              if (inputStream == null) {
                  throw new IllegalArgumentException("Missing test resource: " + resourceName);
              }
              return inputStream;
          }
      }
  }
