UuhFVYb9b99|fc_08701a54876117250169f39dc7cdd881a19b97cc0e59ef79a9", "name": "write", "arguments": {"path": "tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/KtfmtStepInnerStateTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.BufferedReader;\nimport java.io.File;\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.io.InputStreamReader;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.StandardCopyOption;\nimport java.util.Collection;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\n\nimport org.junit.jupiter.api.Test;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.kotlin.KtfmtStep;\nimport com.diffplug.spotless.kotlin.KtfmtStep.KtfmtFormattingOptions;\nimport com.diffplug.spotless.kotlin.KtfmtStep.Style;\n\npublic class KtfmtStepInnerStateTest {\n    private static final String SOURCE = \"fun main(){println(\\\"hi\\\")}\";\n\n    private final Provisioner provisioner = new FixtureProvisioner();\n\n    @Test\n    void createsModernFormatterWithDefaultStyle() throws Exception {\n        assertThat(format(\"0.46\", null, null)).isEqualTo(\"modern:\" + SOURCE);\n    }\n\n    @Test\n    void createsModernFormatterWithExplicitStyle() throws Exception {\n        assertThat(format(\"0.46\", Style.GOOGLE, null)).isEqualTo(\"modern:\" + SOURCE);\n    }\n\n    @Test\n    void createsModernFormatterWithFormattingOptions() throws Exception {\n        final KtfmtFormattingOptions options = options();\n\n        assertThat(format(\"0.46\", null, options)).isEqualTo(\"modern:\" + SOURCE);\n    }\n\n    @Test\n    void createsModernFormatterWithStyleAndFormattingOptions() throws Exception {\n        final KtfmtFormattingOptions options = options();\n\n        assertThat(format(\"0.46\", Style.KOTLINLANG, options)).isEqualTo(\"modern:\" + SOURCE);\n    }\n\n    @Test\n    void formatsWithFallbackDefaultMethodFromBothLegacyFormatterPackages() throws Exception {\n        assertThat(format(\"0.31\", Style.DEFAULT, null)).isEqualTo(\"format-default:\" + SOURCE);\n        assertThat(format(\"0.30\", Style.DEFAULT, null)).isEqualTo(\"old-default:\" + SOURCE);\n    }\n\n    @Test\n    void formatsWithFallbackFormattingOptionFieldsFromBothLegacyFormatterPackages() throws Exception {\n        assertThat(format(\"0.31\", Style.DROPBOX, null)).isEqualTo(\"format-options:\" + SOURCE);\n        assertThat(format(\"0.30\", Style.DROPBOX, null)).isEqualTo(\"old-options:\" + SOURCE);\n    }\n\n    @Test\n    void formatsWithFallbackCompanionOptionsBeforePublicFieldsWereAvailable() throws Exception {\n        assertThat(format(\"0.18\", Style.DROPBOX, null)).isEqualTo(\"pre-field-options:\" + SOURCE);\n    }\n\n    private String format(String version, Style style, KtfmtFormattingOptions options) throws Exception {\n        final FormatterStep step = KtfmtStep.create(version, provisioner, style, options);\n        return step.format(SOURCE, Formatter.NO_FILE_SENTINEL);\n    }\n\n    private static KtfmtFormattingOptions options() {\n        final KtfmtFormattingOptions options = new KtfmtFormattingOptions();\n        options.setMaxWidth(120);\n        options.setBlockIndent(2);\n        options.setContinuationIndent(4);\n        options.setRemoveUnusedImport(true);\n        return options;\n    }\n\n    private static final class FixtureProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            final Set<File> files = new LinkedHashSet<>();\n            for (String mavenCoordinate : mavenCoordinates) {\n                files.addAll(extractFixtureJars(versionFrom(mavenCoordinate)));\n            }\n            return files;\n        }\n\n        private static String versionFrom(String mavenCoordinate) {\n            final int versionSeparator = mavenCoordinate.lastIndexOf(':');\n            if (versionSeparator < 0 || versionSeparator == mavenCoordinate.length() - 1) {\n                throw new IllegalArgumentException(\"Expected Maven coordinate with a version: \" + mavenCoordinate);\n            }\n            return mavenCoordinate.substring(versionSeparator + 1);\n        }\n\n        private static Set<File> extractFixtureJars(String version) {\n            try {\n                final Set<File> files = new LinkedHashSet<>();\n                final String indexResource = \"ktfmt-fixtures/\" + version + \".classpath\";\n                try (InputStream inputStream = resource(indexResource);\n                        BufferedReader reader = new BufferedReader(new InputStreamReader(inputStream, StandardCharsets.UTF_8))) {\n                    String jarResource;\n                    while ((jarResource = reader.readLine()) != null) {\n                        if (!jarResource.isBlank()) {\n                            files.add(extractResource(jarResource).toFile());\n                        }\n                    }\n                }\n                return files;\n            } catch (IOException e) {\n                throw new IllegalStateException(\"Unable to extract ktfmt fixture jars for version \" + version, e);\n            }\n        }\n\n        private static Path extractResource(String resourceName) throws IOException {\n            final Path resourcePath = Path.of(resourceName);\n            final Path targetDirectory = Files.createTempDirectory(\"ktfmt-fixture-\");\n            final Path target = targetDirectory.resolve(resourcePath.getFileName().toString());\n            try (InputStream inputStream = resource(resourceName)) {\n                Files.copy(inputStream, target, StandardCopyOption.REPLACE_EXISTING);\n            }\n            target.toFile().deleteOnExit();\n            targetDirectory.toFile().deleteOnExit();\n            return target;\n        }\n\n        private static InputStream resource(String resourceName) {\n            final InputStream inputStream = KtfmtStepInnerStateTest.class.getClassLoader().getResourceAsStream(resourceName);\n            if (inputStream == null) {\n                throw new IllegalArgumentException(\"Missing test resource: \" + resourceName);\n            }\n            return inputStream;\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/KtfmtStepInnerStateTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage com_diffplug_spotless.spotless_lib;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.BufferedReader;\\nimport java.io.File;\\nimport java.io.IOException;\\nimport java.io.InputStream;\\nimport java.io.InputStreamReader;\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.nio.file.StandardCopyOption;\\nimport java.util.Collection;\\nimport java.util.LinkedHashSet;\\nimport java.util.Set;\\n\\nimport org.junit.jupiter.api.Test;\\n\\nimport com.diffplug.spotless.Formatter;\\nimport com.diffplug.spotless.FormatterStep;\\nimport com.diffplug.spotless.Provisioner;\\nimport com.diffplug.spotless.kotlin.KtfmtStep;\\nimport com.diffplug.spotless.kotlin.KtfmtStep.KtfmtFormattingOptions;\\nimport com.diffplug.spotless.kotlin.KtfmtStep.Style;\\n\\npublic class KtfmtStepInnerStateTest {\\n    private static final String SOURCE = \\\"fun main(){println(\\\\\\\"hi\\\\\\\")}\\\";\\n\\n    private final Provisioner provisioner = new FixtureProvisioner();\\n\\n    @Test\\n    void createsModernFormatterWithDefaultStyle() throws Exception {\\n        assertThat(format(\\\"0.46\\\", null, null)).isEqualTo(\\\"modern:\\\" + SOURCE);\\n    }\\n\\n    @Test\\n    void createsModernFormatterWithExplicitStyle() throws Exception {\\n        assertThat(format(\\\"0.46\\\", Style.GOOGLE, null)).isEqualTo(\\\"modern:\\\" + SOURCE);\\n    }\\n\\n    @Test\\n    void createsModernFormatterWithFormattingOptions() throws Exception {\\n        final KtfmtFormattingOptions options = options();\\n\\n        assertThat(format(\\\"0.46\\\", null, options)).isEqualTo(\\\"modern:\\\" + SOURCE);\\n    }\\n\\n    @Test\\n    void createsModernFormatterWithStyleAndFormattingOptions() throws Exception {\\n        final KtfmtFormattingOptions options = options();\\n\\n        assertThat(format(\\\"0.46\\\", Style.KOTLINLANG, options)).isEqualTo(\\\"modern:\\\" + SOURCE);\\n    }\\n\\n    @Test\\n    void formatsWithFallbackDefaultMethodFromBothLegacyFormatterPackages() throws Exception {\\n        assertThat(format(\\\"0.31\\\", Style.DEFAULT, null)).isEqualTo(\\\"format-default:\\\" + SOURCE);\\n        assertThat(format(\\\"0.30\\\", Style.DEFAULT, null)).isEqualTo(\\\"old-default:\\\" + SOURCE);\\n    }\\n\\n    @Test\\n    void formatsWithFallbackFormattingOptionFieldsFromBothLegacyFormatterPackages() throws Exception {\\n        assertThat(format(\\\"0.31\\\", Style.DROPBOX, null)).isEqualTo(\\\"format-options:\\\" + SOURCE);\\n        assertThat(format(\\\"0.30\\\", Style.DROPBOX, null)).isEqualTo(\\\"old-options:\\\" + SOURCE);\\n    }\\n\\n    @Test\\n    void formatsWithFallbackCompanionOptionsBeforePublicFieldsWereAvailable() throws Exception {\\n        assertThat(format(\\\"0.18\\\", Style.DROPBOX, null)).isEqualTo(\\\"pre-field-options:\\\" + SOURCE);\\n    }\\n\\n    private String format(String version, Style style, KtfmtFormattingOptions options) throws Exception {\\n        final FormatterStep step = KtfmtStep.create(version, provisioner, style, options);\\n        return step.format(SOURCE, Formatter.NO_FILE_SENTINEL);\\n    }\\n\\n    private static KtfmtFormattingOptions options() {\\n        final KtfmtFormattingOptions options = new KtfmtFormattingOptions();\\n        options.setMaxWidth(120);\\n        options.setBlockIndent(2);\\n        options.setContinuationIndent(4);\\n        options.setRemoveUnusedImport(true);\\n        return options;\\n    }\\n\\n    private static final class FixtureProvisioner implements Provisioner {\\n        @Override\\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\\n            final Set<File> files = new LinkedHashSet<>();\\n            for (String mavenCoordinate : mavenCoordinates) {\\n                files.addAll(extractFixtureJars(versionFrom(mavenCoordinate)));\\n            }\\n            return files;\\n        }\\n\\n        private static String versionFrom(String mavenCoordinate) {\\n            final int versionSeparator = mavenCoordinate.lastIndexOf(':');\\n            if (versionSeparator < 0 || versionSeparator == mavenCoordinate.length() - 1) {\\n                throw new IllegalArgumentException(\\\"Expected Maven coordinate with a version: \\\" + mavenCoordinate);\\n            }\\n            return mavenCoordinate.substring(versionSeparator + 1);\\n        }\\n\\n        private static Set<File> extractFixtureJars(String version) {\\n            try {\\n                final Set<File> files = new LinkedHashSet<>();\\n                final String indexResource = \\\"ktfmt-fixtures/\\\" + version + \\\".classpath\\\";\\n                try (InputStream inputStream = resource(indexResource);\\n                        BufferedReader reader = new BufferedReader(new InputStreamReader(inputStream, StandardCharsets.UTF_8))) {\\n                    String jarResource;\\n                    while ((jarResource = reader.readLine()) != null) {\\n                        if (!jarResource.isBlank()) {\\n                            files.add(extractResource(jarResource).toFile());\\n                        }\\n                    }\\n                }\\n                return files;\\n            } catch (IOException e) {\\n                throw new IllegalStateException(\\\"Unable to extract ktfmt fixture jars for version \\\" + version, e);\\n            }\\n        }\\n\\n        private static Path extractResource(String resourceName) throws IOException {\\n            final Path resourcePath = Path.of(resourceName);\\n            final Path targetDirectory = Files.createTempDirectory(\\\"ktfmt-fixture-\\\");\\n            final Path target = targetDirectory.resolve(resourcePath.getFileName().toString());\\n            try (InputStream inputStream = resource(resourceName)) {\\n                Files.copy(inputStream, target, StandardCopyOption.REPLACE_EXISTING);\\n            }\\n            target.toFile().deleteOnExit();\\n            targetDirectory.toFile().deleteOnExit();\\n            return target;\\n        }\\n\\n        private static InputStream resource(String resourceName) {\\n            final InputStream inputStream = KtfmtStepInnerStateTest.class.getClassLoader().getResourceAsStream(resourceName);\\n            if (inputStream == null) {\\n                throw new IllegalArgumentException(\\\"Missing test resource: \\\" + resourceName);\\n            }\\n            return inputStream;\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2843, "output": 3474, "cacheRead": 48640, "cacheWrite": 0, "totalTokens": 54957, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777573288904, "respo