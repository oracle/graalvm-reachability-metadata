      Map<String, String> sources = [
          "com/diffplug/spotless/glue/ktlint/KtlintFormatterFunc.java": """
              package com.diffplug.spotless.glue.ktlint;
  
              import java.io.File;
              import java.util.Map;
  
              import com.diffplug.spotless.FileSignature;
              import com.diffplug.spotless.FormatterFunc;
  
              public class KtlintFormatterFunc implements FormatterFunc.NeedsFile {
                  private final String version;
                  private final FileSignature editorConfigPath;
                  private final Map<String, Object> editorConfigOverride;
  
                  public KtlintFormatterFunc(String version, FileSignature editorConfigPath,
                          Map<String, Object> editorConfigOverride) {
                      this.version = version;
                      this.editorConfigPath = editorConfigPath;
                      this.editorConfigOverride = editorConfigOverride;
                  }
  
                  public String applyWithFile(String input, File file) {
                      String editorConfigName = editorConfigPath == null
                              ? "no-editor-config"
                              : editorConfigPath.getOnlyFile().getName();
                      return "ktlint:" + version + ":" + editorConfigName + ":" + editorConfigOverride + ":"
                              + file.getName() + ":" + input;
                  }
              }
              """
      ]
      createFixtureJar(outputDir, "ktlint-fixtures", "current", "ktlint-fixture.jar", sources,
              sourceSets.test.compileClasspath.asPath)
  }
  
