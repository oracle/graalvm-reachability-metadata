  void createSortPomFixture(File outputDir) {
      Map<String, String> sources = [
          "com/diffplug/spotless/glue/pom/SortPomFormatterFunc.java": """
              package com.diffplug.spotless.glue.pom;
  
              import com.diffplug.spotless.FormatterFunc;
              import com.diffplug.spotless.pom.SortPomCfg;
  
              public class SortPomFormatterFunc implements FormatterFunc {
                  private final SortPomCfg config;
  
                  public SortPomFormatterFunc(SortPomCfg config) {
                      this.config = config;
                  }
  
                  public String apply(String input) {
                      return "sortpom:" + config.encoding + ":" + config.keepBlankLines + ":"
                              + config.nrOfIndentSpace + ":" + config.sortProperties + ":" + config.sortModules
                              + ":" + input;
                  }
              }
              """
      ]
      createFixtureJar(outputDir, "sortpom-fixtures", "current", "sortpom-fixture.jar", sources,
              sourceSets.test.compileClasspath.asPath)
  }
  
  void createScalaFmtFixture(File outputDir) {
      Map<String, String> sources = [
          "com/diffplug/spotless/glue/scalafmt/ScalafmtFormatterFunc.java": """
              package com.diffplug.spotless.glue.scalafmt;
  
              import com.diffplug.spotless.FileSignature;
              import com.diffplug.spotless.FormatterFunc;
  
              public class ScalafmtFormatterFunc implements FormatterFunc {
                  private final FileSignature configSignature;
  
                  public ScalafmtFormatterFunc(FileSignature configSignature) {
                      this.configSignature = configSignature;
                  }
  
                  public String apply(String input) {
                      String configName = configSignature.files().isEmpty()
                              ? "no-config"
                              : configSignature.getOnlyFile().getName();
                      return "scalafmt:" + configName + ":" + input;
                  }
              }
              """
      ]
      createFixtureJar(outputDir, "scalafmt-fixtures", "current", "scalafmt-fixture.jar", sources,
              sourceSets.test.compileClasspath.asPath)
  }
  
  void createFixtureJar(File outputDir, String version, String jarName, Map<String, String> sources) {
      createFixtureJar(outputDir, "ktfmt-fixtures", version, jarName, sources)
  }
  
  void createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources) {
      createFixtureJar(outputDir, resourceRoot, version, jarName, sources, null)
  }
  
  void createFixtureJar(File outputDir, String resourceRoot, String version, String jarName, Map<String, String> sources,
          String classpath) {
      File workDir = new File(outputDir, "work/${version}")
      File sourceDir = new File(workDir, "src")
      File classesDir = new File(workDir, "classes")
      sources.each { relativePath, source ->
          File sourceFile = new File(sourceDir, relativePath)
          sourceFile.parentFile.mkdirs()
          sourceFile.text = source.stripIndent()
      }
      classesDir.mkdirs()
      Map<String, Object> javacArguments = [srcdir: sourceDir, destdir: classesDir, includeantruntime: false, source: "8", target: "8"]
      if (classpath != null) {
          javacArguments.classpath = classpath
      }
      ant.javac(javacArguments)
  
      File resourceDir = new File(outputDir, "${resourceRoot}/${version}")
      resourceDir.mkdirs()
      ant.jar(destfile: new File(resourceDir, jarName), basedir: classesDir)
  
      File indexFile = new File(outputDir, "${resourceRoot}/${version}.classpath")
      indexFile.parentFile.mkdirs()
      indexFile.text = "${resourceRoot}/${version}/${jarName}\n"
  
      delete(workDir)
  }
  
