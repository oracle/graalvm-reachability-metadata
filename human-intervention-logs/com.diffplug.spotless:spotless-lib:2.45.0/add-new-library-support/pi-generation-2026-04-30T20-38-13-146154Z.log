              public class DiktatFormatterFunc implements FormatterFunc.NeedsFile {
                  private final String versionDiktat;
                  private final File configFile;
                  private final boolean isScript;
  
                  public DiktatFormatterFunc(String versionDiktat, File configFile, boolean isScript) {
                      this.versionDiktat = versionDiktat;
                      this.configFile = configFile;
                      this.isScript = isScript;
                  }
  
                  public String applyWithFile(String input, File file) {
                      String configName = configFile == null ? "no-config" : configFile.getName();
                      return "diktat:" + versionDiktat + ":" + configName + ":" + isScript + ":" + file.getName()
                              + ":" + input;
                  }
              }
              """
      ]
      createFixtureJar(outputDir, "diktat-fixtures", "current", "diktat-fixture.jar", sources,
              sourceSets.test.compileClasspath.asPath)
