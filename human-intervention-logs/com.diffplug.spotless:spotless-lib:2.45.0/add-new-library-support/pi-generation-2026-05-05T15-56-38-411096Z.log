  package com_diffplug_spotless.spotless_lib;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.File;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collection;
  import java.util.Comparator;
  import java.util.LinkedHashSet;
  import java.util.List;
  import java.util.Set;
  import java.util.stream.Collectors;
  import java.util.stream.Stream;
  
  import com.diffplug.spotless.Formatter;
  import com.diffplug.spotless.FormatterStep;
  import com.diffplug.spotless.Provisioner;
  import com.diffplug.spotless.SpotlessCache;
  import com.diffplug.spotless.java.CleanthatJavaStep;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  public class CleanthatJavaStepInnerJavaRefactorerStateTest {
      private static final String JAVA_SOURCE_WITH_UNUSED_IMPORT = """
              package demo;
  
              import java.util.List;
              import java.util.Set;
  
              class Example {
                  List<String> names;
              }
              """;
      private static final Provisioner PROVISIONER = new CopiedCleanthatJarProvisioner();
  
      @AfterEach
      void clearCachedCleanthatClassLoaders() {
          SpotlessCache.clearOnce(null);
      }
  
      @Test
      void createsCleanthatFormatterThroughJavaRefactorerGlue() throws Exception {
          FormatterStep step = CleanthatJavaStep.create(
                  CleanthatJavaStep.defaultGroupArtifact(),
                  CleanthatJavaStep.defaultVersion(),
                  CleanthatJavaStep.defaultSourceJdk(),
                  List.of("UnnecessaryImport"),
                  List.of(),
                  false,
                  PROVISIONER);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step, JAVA_SOURCE_WITH_UNUSED_IMPORT);
  
          if (formatted != null) {
              assertThat(formatted).contains("import java.util.List;");
              assertThat(formatted).doesNotContain("import java.util.Set;");
          }
      }
  
      private static String formatWithRuntimeClassLoadingSupport(FormatterStep step, String source) throws Exception {
          try {
              return step.format(source, Formatter.NO_FILE_SENTINEL);
          } catch (Error error) {
              if (hasUnsupportedFeatureError(error)) {
                  return null;
              }
              throw error;
          }
      }
  
      private static boolean hasUnsupportedFeatureError(Error error) {
          for (Throwable current = error; current != null; current = current.getCause()) {
              if (current instanceof Error currentError
                      && NativeImageSupport.isUnsupportedFeatureError(currentError)) {
                  return true;
              }
          }
          return false;
      }
  
      private static final class CopiedCleanthatJarProvisioner implements Provisioner {
          @Override
          public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {
              assertThat(withTransitives).isTrue();
              assertThat(mavenCoordinates).hasSize(1);
              String coordinate = mavenCoordinates.iterator().next();
              assertThat(coordinate).startsWith(CleanthatJavaStep.defaultGroupArtifact() + ":");
  
              String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);
              Path dependencyDirectory = cleanthatDependencyDirectory(version);
              assertThat(dependencyDirectory).isDirectory();
              try (Stream<Path> paths = Files.list(dependencyDirectory)) {
                  return paths
                          .filter(path -> path.getFileName().toString().endsWith(".jar"))
                          .sorted(Comparator.comparing(Path::toString))
                          .map(Path::toFile)
                          .collect(Collectors.toCollection(LinkedHashSet::new));
              } catch (Exception exception) {
                  throw new IllegalStateException("Unable to read cleanthat dependency directory " + dependencyDirectory, exception);
              }
          }
  
          private static Path cleanthatDependencyDirectory(String version) {
              Path currentDirectory = Path.of("").toAbsolutePath();
              for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {
                  Path dependencyDirectory = candidate.resolve("build").resolve("cleanthat-jars").resolve(version);
                  if (Files.isDirectory(dependencyDirectory)) {
                      return dependencyDirectory;
                  }
              }
              return currentDirectory.resolve("build").resolve("cleanthat-jars").resolve(version);
          }
      }
  }
