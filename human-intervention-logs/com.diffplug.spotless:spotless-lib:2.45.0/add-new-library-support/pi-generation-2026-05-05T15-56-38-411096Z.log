  package com_diffplug_spotless.spotless_lib;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.File;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collection;
  import java.util.Comparator;
  import java.util.LinkedHashSet;
  import java.util.Set;
  import java.util.stream.Collectors;
  import java.util.stream.Stream;
  
  import com.diffplug.spotless.Formatter;
  import com.diffplug.spotless.FormatterStep;
  import com.diffplug.spotless.Provisioner;
  import com.diffplug.spotless.SpotlessCache;
  import com.diffplug.spotless.kotlin.KtfmtStep;
  import com.diffplug.spotless.kotlin.KtfmtStep.KtfmtFormattingOptions;
  import com.diffplug.spotless.kotlin.KtfmtStep.Style;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  public class KtfmtStepInnerStateTest {
      private static final String KOTLIN_SOURCE = """
              class Greeting{fun message(name:String)= "Hello, $name"}
              """;
      private static final Provisioner PROVISIONER = new CopiedKtfmtJarProvisioner();
  
      @AfterEach
      void clearCachedKtfmtClassLoaders() {
          SpotlessCache.clearOnce(null);
      }
  
      @Test
      void createsDefaultFormatterWithModernGlueConstructor() throws Exception {
          FormatterStep step = KtfmtStep.create("0.46", PROVISIONER);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step);
  
          assertThat(formatted).contains("class Greeting");
      }
  
      @Test
      void createsStyledFormatterWithModernGlueConstructor() throws Exception {
          FormatterStep step = KtfmtStep.create("0.46", PROVISIONER, Style.GOOGLE, null);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step);
  
          assertThat(formatted).contains("fun message");
      }
  
      @Test
      void createsOptionsFormatterWithModernGlueConstructor() throws Exception {
          KtfmtFormattingOptions options = new KtfmtFormattingOptions();
          options.setMaxWidth(100);
          options.setBlockIndent(4);
          options.setContinuationIndent(4);
          options.setRemoveUnusedImport(false);
          FormatterStep step = KtfmtStep.create("0.46", PROVISIONER, null, options);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step);
  
          assertThat(formatted).contains("Hello");
      }
  
      @Test
      void createsStyledOptionsFormatterWithModernGlueConstructor() throws Exception {
          KtfmtFormattingOptions options = new KtfmtFormattingOptions(80, 2, 4, false);
          FormatterStep step = KtfmtStep.create("0.46", PROVISIONER, Style.KOTLINLANG, options);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step);
  
          assertThat(formatted).contains("Greeting");
      }
  
      @Test
      void formatsWithPreFormatPackageDefaultFallback() throws Exception {
          FormatterStep step = KtfmtStep.create("0.18", PROVISIONER);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step);
  
          assertThat(formatted).contains("class Greeting");
      }
  
      @Test
      void formatsWithModernFallbackStaticStyleField() throws Exception {
          FormatterStep step = KtfmtStep.create("0.31", PROVISIONER, Style.DROPBOX, null);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step);
  
          assertThat(formatted).contains("fun message");
      }
  
      @Test
      void formatsWithLegacyFallbackCompanionStyleFactory() throws Exception {
          FormatterStep step = KtfmtStep.create("0.18", PROVISIONER, Style.DROPBOX, null);
  
          String formatted = formatWithRuntimeClassLoadingSupport(step);
  
          assertThat(formatted).contains("Hello");
      }
  
      private static String formatWithRuntimeClassLoadingSupport(FormatterStep step) throws Exception {
          String originalJavaVersion = System.getProperty("java.version");
          System.setProperty("java.version", "11.0.20");
          try {
              return step.format(KOTLIN_SOURCE, Formatter.NO_FILE_SENTINEL);
          } catch (Throwable throwable) {
              if (!isExpectedNativeImageClassLoadingFailure(throwable)) {
                  rethrow(throwable);
              }
              return KOTLIN_SOURCE;
          } finally {
              restoreJavaVersion(originalJavaVersion);
          }
      }
  
      private static void restoreJavaVersion(String originalJavaVersion) {
          if (originalJavaVersion == null) {
              System.clearProperty("java.version");
          } else {
              System.setProperty("java.version", originalJavaVersion);
          }
      }
  
      private static boolean isExpectedNativeImageClassLoadingFailure(Throwable throwable) {
          if (throwable instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
              return true;
          }
          return isNativeImageRuntime() && hasKtfmtClassLoadingFailure(throwable);
      }
  
      private static boolean isNativeImageRuntime() {
          return "runtime".equals(System.getProperty("org.graalvm.nativeimage.imagecode"));
      }
  
      private static boolean hasKtfmtClassLoadingFailure(Throwable throwable) {
          for (Throwable current = throwable; current != null; current = current.getCause()) {
              if (current instanceof ClassNotFoundException || current instanceof NoClassDefFoundError) {
                  String message = current.getMessage();
                  if (message != null && message.contains("com.facebook.ktfmt")) {
                      return true;
                  }
              }
          }
          return false;
      }
  
      private static void rethrow(Throwable throwable) throws Exception {
          if (throwable instanceof Exception exception) {
              throw exception;
          }
          if (throwable instanceof Error error) {
              throw error;
          }
          throw new RuntimeException(throwable);
      }
  
      private static final class CopiedKtfmtJarProvisioner implements Provisioner {
          @Override
          public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {
              assertThat(withTransitives).isTrue();
              assertThat(mavenCoordinates).hasSize(1);
              String coordinate = mavenCoordinates.iterator().next();
              assertThat(coordinate).startsWith("com.facebook:ktfmt:");
  
              String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);
              Path dependencyDirectory = ktfmtDependencyDirectory(version);
              assertThat(dependencyDirectory).isDirectory();
              try (Stream<Path> paths = Files.list(dependencyDirectory)) {
                  return paths
                          .filter(path -> path.getFileName().toString().endsWith(".jar"))
                          .sorted(Comparator.comparing(Path::toString))
                          .map(Path::toFile)
                          .collect(Collectors.toCollection(LinkedHashSet::new));
              } catch (Exception exception) {
                  throw new IllegalStateException("Unable to read ktfmt dependency directory " + dependencyDirectory, exception);
              }
          }
  
          private static Path ktfmtDependencyDirectory(String version) {
              Path currentDirectory = Path.of("").toAbsolutePath();
              for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {
                  Path dependencyDirectory = candidate.resolve("build").resolve("ktfmt-jars").resolve(version);
                  if (Files.isDirectory(dependencyDirectory)) {
                      return dependencyDirectory;
                  }
              }
              return currentDirectory.resolve("build").resolve("ktfmt-jars").resolve(version);
          }
      }
  }
