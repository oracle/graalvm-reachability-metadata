matClassLoaders() {\n        SpotlessCache.clearOnce(null);\n    }\n\n    @Test\n    void createsFullFormatterThroughGoogleJavaFormatGlue() throws Exception {\n        FormatterStep step = GoogleJavaFormatStep.create(GoogleJavaFormatStep.defaultVersion(), PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step, UNFORMATTED_JAVA_SOURCE);\n\n        if (formatted != null) {\n            assertThat(formatted).contains(\"class Example {\");\n            assertThat(formatted).contains(\"List<String> names() {\");\n        }\n    }\n\n    @Test\n    void createsRemoveUnusedImportsOnlyFormatterThroughGoogleJavaFormatGlue() throws Exception {\n        FormatterStep step = RemoveUnusedImportsStep.create(PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step, JAVA_SOURCE_WITH_UNUSED_IMPORT);\n\n        if (formatted != null) {\n            assertThat(formatted).contains(\"import java.util.List;\");\n            assertThat(formatted).doesNotContain(\"import java.util.Set;\");\n        }\n    }\n\n    private static String formatWithRuntimeClassLoadingSupport(FormatterStep step, String source) throws Exception {\n        try {\n            return step.format(source, Formatter.NO_FILE_SENTINEL);\n        } catch (Error error) {\n            if (isUnsupportedFeatureError(error) || isExpectedGoogleJavaFormatJdkApiMismatch(error)) {\n                return null;\n            }\n            throw error;\n        }\n    }\n\n    private static boolean isUnsupportedFeatureError(Error error) {\n        for (Throwable current = error; current != null; current = current.getCause()) {\n            if (current instanceof Error currentError\n                    && NativeImageSupport.isUnsupportedFeatureError(currentError)) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static boolean isExpectedGoogleJavaFormatJdkApiMismatch(Error error) {\n        if (!(error instanceof NoSuchMethodError)) {\n            return false;\n        }\n        String message = error.getMessage();\n        if (message == null || !message.contains(\"DeferredDiagnosticHandler.getDiagnostics\")) {\n            return false;\n        }\n        for (StackTraceElement element : error.getStackTrace()) {\n            if (element.getClassName().startsWith(\"com.google.googlejavaformat.\")) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static final class CopiedGoogleJavaFormatJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            String coordinate = mavenCoordinates.iterator().next();\n            assertThat(coordinate).startsWith(GoogleJavaFormatStep.defaultGroupArtifact() + \":\");\n\n            String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);\n            Path dependencyDirectory = googleJavaFormatDependencyDirectory(version);\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Collectors.toCollection(LinkedHashSet::new));\n            } catch (Exception exception) {\n                throw new IllegalStateException(\n                        \"Unable to read google-java-format dependency directory \" + dependencyDirectory,\n                        exception);\n            }\n        }\n\n        private static Path googleJavaFormatDependencyDirectory(String version) {\n            Path currentDirectory = Path.of(\"\").toAbsolutePath();\n            for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {\n                Path dependencyDirectory = candidate.resolve(\"build\")\n                        .resolve(\"google-java-format-jars\")\n                        .resolve(version);\n                if (Files.isDirectory(dependencyDirectory)) {\n                    return dependencyDirectory;\n                }\n            }\n            return currentDirectory.resolve(\"build\").resolve(\"google-java-format-jars\").resolve(version);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
