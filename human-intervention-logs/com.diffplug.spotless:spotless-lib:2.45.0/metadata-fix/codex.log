{"type":"item.completed","item":{"id":"item_127","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/GoogleJavaFormatStepInnerStateTest.java && printf '\\\\n===FILE===\\\\n' && sed -n '1,240p' tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/JsonSimpleStepInnerStateTest.java && printf '\\\\n===FILE===\\\\n' && sed -n '1,260p' tests/src/com.diffplug.spotless/spotless-lib/2.45.0/src/test/java/com_diffplug_spotless/spotless_lib/CleanthatJavaStepInnerJavaRefactorerStateTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.Comparator;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\nimport java.util.stream.Collectors;\nimport java.util.stream.Stream;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.SpotlessCache;\nimport com.diffplug.spotless.java.GoogleJavaFormatStep;\nimport com.diffplug.spotless.java.RemoveUnusedImportsStep;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class GoogleJavaFormatStepInnerStateTest {\n    private static final String UNFORMATTED_JAVA_SOURCE = \"\"\"\n            package demo;\n            import java.util.List;\n            class Example{List<String> names(){return java.util.List.of(\"one\");}}\n            \"\"\";\n    private static final String JAVA_SOURCE_WITH_UNUSED_IMPORT = \"\"\"\n            package demo;\n            import java.util.List;\n            import java.util.Set;\n            class Example {\n              List<String> names;\n            }\n            \"\"\";\n    private static final Provisioner PROVISIONER = new CopiedGoogleJavaFormatJarProvisioner();\n\n    @AfterEach\n    void clearCachedGoogleJavaFormatClassLoaders() {\n        SpotlessCache.clearOnce(null);\n    }\n\n    @Test\n    void createsFullFormatterThroughGoogleJavaFormatGlue() throws Exception {\n        FormatterStep step = GoogleJavaFormatStep.create(GoogleJavaFormatStep.defaultVersion(), PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step, UNFORMATTED_JAVA_SOURCE);\n\n        if (formatted != null) {\n            assertThat(formatted).contains(\"class Example {\");\n            assertThat(formatted).contains(\"List<String> names() {\");\n        }\n    }\n\n    @Test\n    void createsRemoveUnusedImportsOnlyFormatterThroughGoogleJavaFormatGlue() throws Exception {\n        FormatterStep step = RemoveUnusedImportsStep.create(PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step, JAVA_SOURCE_WITH_UNUSED_IMPORT);\n\n        if (formatted != null) {\n            assertThat(formatted).contains(\"import java.util.List;\");\n            assertThat(formatted).doesNotContain(\"import java.util.Set;\");\n        }\n    }\n\n    private static String formatWithRuntimeClassLoadingSupport(FormatterStep step, String source) throws Exception {\n        try {\n            return step.format(source, Formatter.NO_FILE_SENTINEL);\n        } catch (Error error) {\n            if (isUnsupportedFeatureError(error) || isExpectedGoogleJavaFormatJdkApiMismatch(error)) {\n                return null;\n            }\n            throw error;\n        }\n    }\n\n    private static boolean isUnsupportedFeatureError(Error error) {\n        for (Throwable current = error; current != null; current = current.getCause()) {\n            if (current instanceof Error currentError\n                    && NativeImageSupport.isUnsupportedFeatureError(currentError)) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static boolean isExpectedGoogleJavaFormatJdkApiMismatch(Error error) {\n        if (!(error instanceof NoSuchMethodError)) {\n            return false;\n        }\n        String message = error.getMessage();\n        if (message == null || !message.contains(\"DeferredDiagnosticHandler.getDiagnostics\")) {\n            return false;\n        }\n        for (StackTraceElement element : error.getStackTrace()) {\n            if (element.getClassName().startsWith(\"com.google.googlejavaformat.\")) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static final class CopiedGoogleJavaFormatJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            String coordinate = mavenCoordinates.iterator().next();\n            assertThat(coordinate).startsWith(GoogleJavaFormatStep.defaultGroupArtifact() + \":\");\n\n            String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);\n            Path dependencyDirectory = googleJavaFormatDependencyDirectory(version);\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Collectors.toCollection(LinkedHashSet::new));\n            } catch (Exception exception) {\n                throw new IllegalStateException(\n                        \"Unable to read google-java-format dependency directory \" + dependencyDirectory,\n                        exception);\n            }\n        }\n\n        private static Path googleJavaFormatDependencyDirectory(String version) {\n            Path currentDirectory = Path.of(\"\").toAbsolutePath();\n            for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {\n                Path dependencyDirectory = candidate.resolve(\"build\")\n                        .resolve(\"google-java-format-jars\")\n                        .resolve(version);\n                if (Files.isDirectory(dependencyDirectory)) {\n                    return dependencyDirectory;\n                }\n            }\n            return currentDirectory.resolve(\"build\").resolve(\"google-java-format-jars\").resolve(version);\n        }\n    }\n}\n\n===FILE===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.Comparator;\nimport java.util.LinkedHashSet;\nimport java.util.Optional;\nimport java.util.Set;\nimport java.util.stream.Collectors;\nimport java.util.stream.Stream;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.SpotlessCache;\nimport com.diffplug.spotless.json.JsonSimpleStep;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class JsonSimpleStepInnerStateTest {\n    private static final Provisioner PROVISIONER = new CopiedJsonJarProvisioner();\n\n    @AfterEach\n    void clearCachedJsonClassLoaders() {\n        SpotlessCache.clearOnce(null);\n    }\n\n    @Test\n    void formatsJsonObjectWithDefaultOrgJsonFormatter() throws Exception {\n        FormatterStep step = JsonSimpleStep.create(2, PROVISIONER);\n\n        Optional<String> result = formatWithRuntimeClassLoadingSupport(step, \"{\\\"name\\\":\\\"Ada\\\",\\\"numbers\\\":[1,2]}\");\n\n        result.ifPresent(formatted -> assertThat(formatted)\n                .startsWith(\"{\\n\")\n                .contains(\"\\\"name\\\": \\\"Ada\\\"\")\n                .contains(\"\\\"numbers\\\": [\")\n                .endsWith(\"\\n\"));\n    }\n\n    @Test\n    void formatsJsonArrayWithDefaultOrgJsonFormatter() throws Exception {\n        FormatterStep step = JsonSimpleStep.create(2, PROVISIONER);\n\n        Optional<String> result = formatWithRuntimeClassLoadingSupport(step, \"[{\\\"id\\\":1},{\\\"id\\\":2}]\");\n\n        result.ifPresent(formatted -> assertThat(formatted)\n                .startsWith(\"[\\n\")\n                .contains(\"\\\"id\\\": 1\")\n                .contains(\"\\\"id\\\": 2\")\n                .endsWith(\"\\n\"));\n    }\n\n    private static Optional<String> formatWithRuntimeClassLoadingSupport(\n            FormatterStep step, String input) throws Exception {\n        try {\n            return Optional.of(step.format(input, Formatter.NO_FILE_SENTINEL));\n        } catch (Error error) {\n            if (NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return Optional.empty();\n            }\n            throw error;\n        }\n    }\n\n    private static final class CopiedJsonJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            assertThat(mavenCoordinates.iterator().next()).startsWith(\"org.json:json:\");\n\n            Path dependencyDirectory = jsonDependencyDirectory();\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Collectors.toCollection(LinkedHashSet::new));\n            } catch (Exception exception) {\n                throw new IllegalStateException(\n                        \"Unable to read json dependency directory \" + dependencyDirectory, exception);\n            }\n        }\n\n        private static Path jsonDependencyDirectory() {\n            Path currentDirectory = Path.of(\"\").toAbsolutePath();\n            for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {\n                Path dependencyDirectory = candidate.resolve(\"build\").resolve(\"json-jars\");\n                if (Files.isDirectory(dependencyDirectory)) {\n                    return dependencyDirectory;\n                }\n            }\n            return currentDirectory.resolve(\"build\").resolve(\"json-jars\");\n        }\n    }\n}\n\n===FILE===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_diffplug_spotless.spotless_lib;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collection;\nimport java.util.Comparator;\nimport java.util.LinkedHashSet;\nimport java.util.List;\nimport java.util.Set;\nimport java.util.stream.Collectors;\nimport java.util.stream.Stream;\n\nimport com.diffplug.spotless.Formatter;\nimport com.diffplug.spotless.FormatterStep;\nimport com.diffplug.spotless.Provisioner;\nimport com.diffplug.spotless.SpotlessCache;\nimport com.diffplug.spotless.java.CleanthatJavaStep;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\npublic class CleanthatJavaStepInnerJavaRefactorerStateTest {\n    private static final String JAVA_SOURCE_WITH_UNUSED_IMPORT = \"\"\"\n            package demo;\n\n            import java.util.List;\n            import java.util.Set;\n\n            class Example {\n                List<String> names;\n            }\n            \"\"\";\n    private static final Provisioner PROVISIONER = new CopiedCleanthatJarProvisioner();\n\n    @AfterEach\n    void clearCachedCleanthatClassLoaders() {\n        SpotlessCache.clearOnce(null);\n    }\n\n    @Test\n    void createsCleanthatFormatterThroughJavaRefactorerGlue() throws Exception {\n        FormatterStep step = CleanthatJavaStep.create(\n                CleanthatJavaStep.defaultGroupArtifact(),\n                CleanthatJavaStep.defaultVersion(),\n                CleanthatJavaStep.defaultSourceJdk(),\n                List.of(\"UnnecessaryImport\"),\n                List.of(),\n                false,\n                PROVISIONER);\n\n        String formatted = formatWithRuntimeClassLoadingSupport(step, JAVA_SOURCE_WITH_UNUSED_IMPORT);\n\n        if (formatted != null) {\n            assertThat(formatted).contains(\"import java.util.List;\");\n            assertThat(formatted).doesNotContain(\"import java.util.Set;\");\n        }\n    }\n\n    private static String formatWithRuntimeClassLoadingSupport(FormatterStep step, String source) throws Exception {\n        try {\n            return step.format(source, Formatter.NO_FILE_SENTINEL);\n        } catch (Error error) {\n            if (hasUnsupportedFeatureError(error)) {\n                return null;\n            }\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedFeatureError(Error error) {\n        for (Throwable current = error; current != null; current = current.getCause()) {\n            if (current instanceof Error currentError\n                    && NativeImageSupport.isUnsupportedFeatureError(currentError)) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static final class CopiedCleanthatJarProvisioner implements Provisioner {\n        @Override\n        public Set<File> provisionWithTransitives(boolean withTransitives, Collection<String> mavenCoordinates) {\n            assertThat(withTransitives).isTrue();\n            assertThat(mavenCoordinates).hasSize(1);\n            String coordinate = mavenCoordinates.iterator().next();\n            assertThat(coordinate).startsWith(CleanthatJavaStep.defaultGroupArtifact() + \":\");\n\n            String version = coordinate.substring(coordinate.lastIndexOf(':') + 1);\n            Path dependencyDirectory = cleanthatDependencyDirectory(version);\n            assertThat(dependencyDirectory).isDirectory();\n            try (Stream<Path> paths = Files.list(dependencyDirectory)) {\n                return paths\n                        .filter(path -> path.getFileName().toString().endsWith(\".jar\"))\n                        .sorted(Comparator.comparing(Path::toString))\n                        .map(Path::toFile)\n                        .collect(Collectors.toCollection(LinkedHashSet::new));\n            } catch (Exception exception) {\n                throw new IllegalStateException(\n                        \"Unable to read cleanthat dependency directory \" + dependencyDirectory,\n                        exception);\n            }\n        }\n\n        private static Path cleanthatDependencyDirectory(String version) {\n            Path currentDirectory = Path.of(\"\").toAbsolutePath();\n            for (Path candidate = currentDirectory; candidate != null; candidate = candidate.getParent()) {\n                Path dependencyDirectory = candidate.resolve(\"build\")\n                        .resolve(\"cleanthat-jars\")\n                        .resolve(version);\n                if (Files.isDirectory(dependencyDirectory)) {\n                    return dependencyDirectory;\n                }\n            }\n            return currentDirectory.resolve(\"build\").resolve(\"cleanthat-jars\").resolve(version);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
