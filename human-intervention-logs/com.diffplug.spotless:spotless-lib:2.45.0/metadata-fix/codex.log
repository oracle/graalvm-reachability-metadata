{"type":"item.started","item":{"id":"item_153","type":"command_execution","command":"/usr/bin/bash -lc \"cat > /tmp/LoadAllJarClasses.java <<'EOF'\nimport java.io.IOException;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.ArrayList;\nimport java.util.Enumeration;\nimport java.util.List;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarFile;\n\npublic class LoadAllJarClasses {\n    public static void main(String[] args) throws Exception {\n        if (args.length == 0) {\n            throw new IllegalArgumentException(\\\"Expected jar files or directories\\\");\n        }\n        List<Path> jars = new ArrayList<>();\n        for (String arg : args) {\n            Path path = Path.of(arg);\n            if (Files.isDirectory(path)) {\n                try (var stream = Files.list(path)) {\n                    stream.filter(p -> p.getFileName().toString().endsWith(\\\".jar\\\")).sorted().forEach(jars::add);\n                }\n            } else {\n                jars.add(path);\n            }\n        }\n        URL[] urls = jars.stream().map(path -> {\n            try {\n                return path.toUri().toURL();\n            } catch (Exception e) {\n                throw new RuntimeException(e);\n            }\n        }).toArray(URL[]::new);\n        int loaded = 0;\n        int failed = 0;\n        try (URLClassLoader loader = new URLClassLoader(urls, ClassLoader.getPlatformClassLoader())) {\n            for (Path jar : jars) {\n                try (JarFile jarFile = new JarFile(jar.toFile())) {\n                    Enumeration<JarEntry> entries = jarFile.entries();\n                    while (entries.hasMoreElements()) {\n                        JarEntry entry = entries.nextElement();\n                        if (entry.isDirectory()) {\n                            continue;\n                        }\n                        String name = entry.getName();\n                        if (\"'!name.endsWith(\".class\") || name.equals(\"module-info.class\") || name.startsWith(\"META-INF/versions/\")) {\n                            continue;\n                        }\n                        String className = name.substring(0, name.length() - 6).replace('\"'/', '.');\n                        try {\n                            Class.forName(className, false, loader);\n                            loaded++;\n                        } catch (Throwable t) {\n                            failed++;\n                            System.err.println(\\\"FAILED \\\" + className + \\\" :: \\\" + t);\n                        }\n                    }\n                }\n            }\n        }\n        System.out.println(\\\"Loaded=\\\" + loaded + \\\" Failed=\\\" + failed);\n    }\n}\nEOF\njavac /tmp/LoadAllJarClasses.java\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
