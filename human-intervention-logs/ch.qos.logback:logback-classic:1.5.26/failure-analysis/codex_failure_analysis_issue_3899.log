est/java/ch_qos_logback/logback_classic/Logback_classicTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage ch_qos_logback.logback_classic;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.File;\\nimport java.io.IOException;\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.util.Comparator;\\nimport java.util.List;\\n\\nimport ch.qos.logback.classic.AsyncAppender;\\nimport ch.qos.logback.classic.Level;\\nimport ch.qos.logback.classic.Logger;\\nimport ch.qos.logback.classic.LoggerContext;\\nimport ch.qos.logback.classic.encoder.PatternLayoutEncoder;\\nimport ch.qos.logback.classic.filter.ThresholdFilter;\\nimport ch.qos.logback.classic.joran.JoranConfigurator;\\nimport ch.qos.logback.classic.spi.ILoggingEvent;\\nimport ch.qos.logback.core.OutputStreamAppender;\\nimport ch.qos.logback.core.read.ListAppender;\\nimport org.junit.jupiter.api.AfterEach;\\nimport org.junit.jupiter.api.BeforeEach;\\nimport org.junit.jupiter.api.Test;\\nimport org.slf4j.MDC;\\nimport org.slf4j.Marker;\\nimport org.slf4j.MarkerFactory;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class Logback_classicTest {\\n\\n    private LoggerContext context;\\n    private Path tempDir;\\n\\n    @BeforeEach\\n    void setUp() throws IOException {\\n        context = new LoggerContext();\\n        context.setName(\\\"logback-classic-test-\\\" + System.nanoTime());\\n        context.start();\\n        tempDir = Files.createTempDirectory(\\\"logback-classic-test\\\");\\n    }\\n\\n    @AfterEach\\n    void tearDown() throws IOException {\\n        MDC.clear();\\n        if (context != null) {\\n            context.stop();\\n        }\\n        if (tempDir != null) {\\n            try (var paths = Files.walk(tempDir)) {\\n                paths.sorted(Comparator.reverseOrder())\\n                        .map(Path::toFile)\\n                        .forEach(File::delete);\\n            }\\n        }\\n    }\\n\\n    @Test\\n    void patternLayoutEncoderFormatsLevelLoggerMarkerMdcAndThrowable() {\\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\\n        PatternLayoutEncoder encoder = patternEncoder(\\\"%level|%logger{0}|%marker|%X{requestId}|%msg|%ex{short}%n\\\");\\n        OutputStreamAppender<ILoggingEvent> appender = outputStreamAppender(\\\"pattern\\\", encoder, outputStream);\\n        Logger logger = logger(\\\"pattern.formatting\\\", appender);\\n        Marker marker = MarkerFactory.getMarker(\\\"SECURITY\\\");\\n\\n        MDC.put(\\\"requestId\\\", \\\"request-42\\\");\\n        logger.error(marker, \\\"login failed\\\", new IllegalStateException(\\\"denied\\\"));\\n\\n        String logLine = outputStream.toString(StandardCharsets.UTF_8);\\n        assertThat(logLine)\\n                .contains(\\\"ERROR|formatting|SECURITY|request-42|login failed|java.lang.IllegalStateException: denied\\\")\\n                .contains(\\\"at \\\")\\n                .doesNotContain(\\\"PARSER_ERROR\\\");\\n    }\\n\\n    @Test\\n    void thresholdFilterDeniesEventsBelowConfiguredLevel() {\\n        ThresholdFilter filter = new ThresholdFilter();\\n        filter.setContext(context);\\n        filter.setLevel(\\\"INFO\\\");\\n        filter.start();\\n        ListAppender<ILoggingEvent> appender = listAppender(\\\"threshold\\\");\\n        appender.addFilter(filter);\\n        Logger logger = logger(\\\"threshold.filter\\\", appender);\\n        logger.setLevel(Level.TRACE);\\n\\n        logger.debug(\\\"debug is below threshold\\\");\\n        logger.info(\\\"info is accepted\\\");\\n        logger.warn(\\\"warn is accepted\\\");\\n\\n        assertThat(appender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"info is accepted\\\", \\\"warn is accepted\\\");\\n    }\\n\\n    @Test\\n    void loggerHierarchyUsesInheritedLevelsAndAdditivity() {\\n        ListAppender<ILoggingEvent> parentAppender = listAppender(\\\"parent\\\");\\n        ListAppender<ILoggingEvent> childAppender = listAppender(\\\"child\\\");\\n        Logger parent = logger(\\\"application.service\\\", parentAppender);\\n        Logger child = context.getLogger(\\\"application.service.worker\\\");\\n        child.addAppender(childAppender);\\n        parent.setLevel(Level.WARN);\\n\\n        child.info(\\\"inherited level rejects this message\\\");\\n        child.warn(\\\"inherited level accepts this message\\\");\\n\\n        assertThat(childAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\");\\n        assertThat(parentAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\");\\n\\n        child.setAdditive(false);\\n        child.error(\\\"only the child appender sees this message\\\");\\n\\n        assertThat(childAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\", \\\"only the child appender sees this message\\\");\\n        assertThat(parentAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\");\\n    }\\n\\n    @Test\\n    void asyncAppenderForwardsQueuedEventsBeforeStop() {\\n        ListAppender<ILoggingEvent> delegate = listAppender(\\\"delegate\\\");\\n        AsyncAppender asyncAppender = new AsyncAppender();\\n        asyncAppender.setContext(context);\\n        asyncAppender.setName(\\\"async\\\");\\n        asyncAppender.setQueueSize(32);\\n        asyncAppender.setDiscardingThreshold(0);\\n        asyncAppender.addAppender(delegate);\\n        asyncAppender.start();\\n        Logger logger = logger(\\\"async.forwarding\\\", asyncAppender);\\n\\n        for (int index = 0; index < 12; index++) {\\n            logger.info(\\\"queued-{}\\\", index);\\n        }\\n        asyncAppender.stop();\\n\\n        assertThat(delegate.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\n                        \\\"queued-0\\\",\\n                        \\\"queued-1\\\",\\n                        \\\"queued-2\\\",\\n                        \\\"queued-3\\\",\\n                        \\\"queued-4\\\",\\n                        \\\"queued-5\\\",\\n                        \\\"queued-6\\\",\\n                        \\\"queued-7\\\",\\n                        \\\"queued-8\\\",\\n                        \\\"queued-9\\\",\\n                        \\\"queued-10\\\",\\n                        \\\"queued-11\\\");\\n    }\\n\\n    @Test\\n    void joranConfiguratorCreatesFileAppenderWithContextProperty() throws Exception {\\n        Path logFile = tempDir.resolve(\\\"joran-file.log\\\");\\n        context.putProperty(\\\"LOG_FILE\\\", logFile.toString());\\n        JoranConfigurator configurator = new JoranConfigurator();\\n        configurator.setContext(context);\\n\\n        configurator.doConfigure(new ByteArrayInputStream(fileAppenderConfiguration().getBytes(StandardCharsets.UTF_8)));\\n        Logger logger = context.getLogger(\\\"configured.file\\\");\\n        logger.info(\\\"from XML configuration\\\");\\n        context.stop();\\n\\n        assertThat(Files.readString(logFile, StandardCharsets.UTF_8))\\n                .contains(\\\"INFO|configured.file|from XML configuration\\\");\\n    }\\n\\n    @Test\\n    void siftingAppenderRoutesEventsByMdcValue() throws Exception {\\n        context.putProperty(\\\"LOG_DIR\\\", tempDir.toString());\\n        JoranConfigurator configurator = new JoranConfigurator();\\n        configurator.setContext(context);\\n\\n        configurator.doConfigure(new ByteArrayInputStream(siftingAppenderConfiguration().getBytes(StandardCharsets.UTF_8)));\\n        Logger logger = context.getLogger(\\\"configured.sifting\\\");\\n        logger.setLevel(Level.INFO);\\n        MDC.put(\\\"tenant\\\", \\\"alpha\\\");\\n        logger.info(\\\"alpha event\\\");\\n        MDC.put(\\\"tenant\\\", \\\"beta\\\");\\n        logger.info(\\\"beta event\\\");\\n        MDC.remove(\\\"tenant\\\");\\n        logger.info(\\\"default event\\\");\\n        context.stop();\\n\\n        assertThat(Files.readString(tempDir.resolve(\\\"alpha.log\\\"), StandardCharsets.UTF_8)).contains(\\\"alpha|alpha event\\\");\\n        assertThat(Files.readString(tempDir.resolve(\\\"beta.log\\\"), StandardCharsets.UTF_8)).contains(\\\"beta|beta event\\\");\\n        assertThat(Files.readString(tempDir.resolve(\\\"unknown.log\\\"), StandardCharsets.UTF_8)).contains(\\\"unknown|default event\\\");\\n    }\\n\\n    @Test\\n    void sequenceNumberAndCallerDataAreAvailableOnLoggingEvents() {\\n        ListAppender<ILoggingEvent> appender = listAppender(\\\"events\\\");\\n        Logger logger = logger(\\\"event.details\\\", appender);\\n\\n        logger.info(\\\"first\\\");\\n        logger.info(\\\"second\\\");\\n\\n        List<ILoggingEvent> events = appender.list;\\n        assertThat(events).hasSize(2);\\n        assertThat(events.get(1).getSequenceNumber()).isGreaterThan(events.get(0).getSequenceNumber());\\n        assertThat(events.get(0).getCallerData())\\n                .extracting(StackTraceElement::getMethodName)\\n                .contains(\\\"sequenceNumberAndCallerDataAreAvailableOnLoggingEvents\\\");\\n    }\\n\\n    private Logger logger(String name, ch.qos.logback.core.Appender<ILoggingEvent> appender) {\\n        Logger logger = context.getLogger(name);\\n        logger.setAdditive(false);\\n        logger.setLevel(Level.TRACE);\\n        logger.addAppender(appender);\\n        return logger;\\n    }\\n\\n    private PatternLayoutEncoder patternEncoder(String pattern) {\\n        PatternLayoutEncoder encoder = new PatternLayoutEncoder();\\n        encoder.setContext(context);\\n        encoder.setCharset(StandardCharsets.UTF_8);\\n        encoder.setPattern(pattern);\\n        encoder.start();\\n        return encoder;\\n    }\\n\\n    private OutputStreamAppender<ILoggingEvent> outputStreamAppender(\\n            String name, PatternLayoutEncoder encoder, ByteArrayOutputStream outputStream) {\\n        OutputStreamAppender<ILoggingEvent> appender = new OutputStreamAppender<>();\\n        appender.setContext(context);\\n        appender.setName(name);\\n        appender.setEncoder(encoder);\\n        appender.setOutputStream(outputStream);\\n        appender.start();\\n        return appender;\\n    }\\n\\n    private ListAppender<ILoggingEvent> listAppender(String name) {\\n        ListAppender<ILoggingEvent> appender = new ListAppender<>();\\n        appender.setContext(context);\\n        appender.setName(name);\\n        appender.start();\\n        return appender;\\n    }\\n\\n    private static String fileAppenderConfiguration() {\\n        return \\\"\\\"\\\"\\n                <configuration>\\n                    <appender name=\\\"FILE\\\" class=\\\"ch.qos.logback.core.FileAppender\\\">\\n                        <file>${LOG_FILE}</file>\\n                        <append>false</append>\\n                        <encoder class=\\\"ch.qos.logback.classic.encoder.PatternLayoutEncoder\\\">\\n                            <pattern>%level|%logger|%msg%n</pattern>\\n                        </encoder>\\n                    </appender>\\n                    <logger name=\\\"configured.file\\\" level=\\\"INFO\\\" additivity=\\\"false\\\">\\n                        <appender-ref ref=\\\"FILE\\\"/>\\n                    </logger>\\n                </configuration>\\n                \\\"\\\"\\\";\\n    }\\n\\n    private static String siftingAppenderConfiguration() {\\n        return \\\"\\\"\\\"\\n                <configuration>\\n                    <appender name=\\\"SIFT\\\" class=\\\"ch.qos.logback.classic.sift.SiftingAppender\\\">\\n                        <discriminator class=\\\"ch.qos.logback.classic.sift.MDCBasedDiscriminator\\\">\\n                            <key>tenant</key>\\n                            <defaultValue>unknown</defaultValue>\\n                        </discriminator>\\n                        <sift>\\n                            <appender name=\\\"FILE-${tenant}\\\" class=\\\"ch.qos.logback.core.FileAppender\\\">\\n                                <file>${LOG_DIR}/${tenant}.log</file>\\n                                <append>false</append>\\n                                <encoder class=\\\"ch.qos.logback.classic.encoder.PatternLayoutEncoder\\\">\\n                                    <pattern>%X{tenant:-unknown}|%msg%n</pattern>\\n                                </encoder>\\n                            </appender>\\n                        </sift>\\n                    </appender>\\n                    <logger name=\\\"configured.sifting\\\" level=\\\"INFO\\\" additivity=\\\"false\\\">\\n                        <appender-ref ref=\\\"SIFT\\\"/>\\n                    </logger>\\n                </configuration>\\n                \\\"\\\"\\\";\\n    }\\n}\\n\"}, \"partialJson\": \"{\\\"path\\\":\\\"tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/ch_qos_logback/logback_classic/Logback_classicTest.java\\\",\\\"content\\\":\\\"/*\\\\n * Copyright and related rights waived via CC0\\\\n *\\\\n * You should have received a copy of the CC0 legalcode along with this\\\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\\\n */\\\\npackage ch_qos_logback.logback_classic;\\\\n\\\\nimport java.io.ByteArrayInputStream;\\\\nimport java.io.ByteArrayOutputStream;\\\\nimport java.io.File;\\\\nimport java.io.IOException;\\\\nimport java.nio.charset.StandardCharsets;\\\\nimport java.nio.file.Files;\\\\nimport java.nio.file.Path;\\\\nimport java.util.Comparator;\\\\nimport java.util.List;\\\\n\\\\nimport ch.qos.logback.classic.AsyncAppender;\\\\nimport ch.qos.logback.classic.Level;\\\\nimport ch.qos.logback.classic.Logger;\\\\nimport ch.qos.logback.classic.LoggerContext;\\\\nimport ch.qos.logback.classic.encoder.PatternLayoutEncoder;\\\\nimport ch.qos.logback.classic.filter.ThresholdFilter;\\\\nimport ch.qos.logback.classic.joran.JoranConfigurator;\\\\nimport ch.qos.logback.classic.spi.ILoggingEvent;\\\\nimport ch.qos.logback.core.OutputStreamAppender;\\\\nimport ch.qos.logback.core.read.ListAppender;\\\\nimport org.junit.jupiter.api.AfterEach;\\\\nimport org.junit.jupiter.api.BeforeEach;\\\\nimport org.junit.jupiter.api.Test;\\\\nimport org.slf4j.MDC;\\\\nimport org.slf4j.Marker;\\\\nimport org.slf4j.MarkerFactory;\\\\n\\\\nimport static org.assertj.core.api.Assertions.assertThat;\\\\n\\\\npublic class Logback_classicTest {\\\\n\\\\n    private LoggerContext context;\\\\n    private Path tempDir;\\\\n\\\\n    @BeforeEach\\\\n    void setUp() throws IOException {\\\\n        context = new LoggerContext();\\\\n        context.setName(\\\\\\\"logback-classic-test-\\\\\\\" + System.nanoTime());\\\\n        context.start();\\\\n        tempDir = Files.createTempDirectory(\\\\\\\"logback-classic-test\\\\\\\");\\\\n    }\\\\n\\\\n    @AfterEach\\\\n    void tearDown() throws IOException {\\\\n        MDC.clear();\\\\n        if (context != null) {\\\\n            context.stop();\\\\n        }\\\\n        if (tempDir != null) {\\\\n            try (var paths = Files.walk(tempDir)) {\\\\n                paths.sorted(Comparator.reverseOrder())\\\\n                        .map(Path::toFile)\\\\n                        .forEach(File::delete);\\\\n            }\\\\n        }\\\\n    }\\\\n\\\\n    @Test\\\\n    void patternLayoutEncoderFormatsLevelLoggerMarkerMdcAndThrowable() {\\\\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\\\\n        PatternLayoutEncoder encoder = patternEncoder(\\\\\\\"%level|%logger{0}|%marker|%X{requestId}|%msg|%ex{short}%n\\\\\\\");\\\\n        OutputStreamAppender<ILoggingEvent> appender = outputStreamAppender(\\\\\\\"pattern\\\\\\\", encoder, outputStream);\\\\n        Logger logger = logger(\\\\\\\"pattern.formatting\\\\\\\", appender);\\\\n        Marker marker = MarkerFactory.getMarker(\\\\\\\"SECURITY\\\\\\\");\\\\n\\\\n        MDC.put(\\\\\\\"requestId\\\\\\\", \\\\\\\"request-42\\\\\\\");\\\\n        logger.error(marker, \\\\\\\"login failed\\\\\\\", new IllegalStateException(\\\\\\\"denied\\\\\\\"));\\\\n\\\\n        String logLine = outputStream.toString(StandardCharsets.UTF_8);\\\\n        assertThat(logLine)\\\\n                .contains(\\\\\\\"ERROR|formatting|SECURITY|request-42|login failed|java.lang.IllegalStateException: denied\\\\\\\")\\\\n                .contains(\\\\\\\"at \\\\\\\")\\\\n                .doesNotContain(\\\\\\\"PARSER_ERROR\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void thresholdFilterDeniesEventsBelowConfiguredLevel() {\\\\n        ThresholdFilter filter = new ThresholdFilter();\\\\n        filter.setContext(context);\\\\n        filter.setLevel(\\\\\\\"INFO\\\\\\\");\\\\n        filter.start();\\\\n        ListAppender<ILoggingEvent> appender = listAppender(\\\\\\\"threshold\\\\\\\");\\\\n        appender.addFilter(filter);\\\\n        Logger logger = logger(\\\\\\\"threshold.filter\\\\\\\", appender);\\\\n        logger.setLevel(Level.TRACE);\\\\n\\\\n        logger.debug(\\\\\\\"debug is below threshold\\\\\\\");\\\\n        logger.info(\\\\\\\"info is accepted\\\\\\\");\\\\n        logger.warn(\\\\\\\"warn is accepted\\\\\\\");\\\\n\\\\n        assertThat(appender.list)\\\\n                .extracting(ILoggingEvent::getFormattedMessage)\\\\n                .containsExactly(\\\\\\\"info is accepted\\\\\\\", \\\\\\\"warn is accepted\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void loggerHierarchyUsesInheritedLevelsAndAdditivity() {\\\\n        ListAppender<ILoggingEvent> parentAppender = listAppender(\\\\\\\"parent\\\\\\\");\\\\n        ListAppender<ILoggingEvent> childAppender = listAppender(\\\\\\\"child\\\\\\\");\\\\n        Logger parent = logger(\\\\\\\"application.service\\\\\\\", parentAppender);\\\\n        Logger child = context.getLogger(\\\\\\\"application.service.worker\\\\\\\");\\\\n        child.addAppender(childAppender);\\\\n        parent.setLevel(Level.WARN);\\\\n\\\\n        child.info(\\\\\\\"inherited level rejects this message\\\\\\\");\\\\n        child.warn(\\\\\\\"inherited level accepts this message\\\\\\\");\\\\n\\\\n        assertThat(childAppender.list)\\\\n                .extracting(ILoggingEvent::getFormattedMessage)\\\\n                .containsExactly(\\\\\\\"inherited level accepts this message\\\\\\\");\\\\n        assertThat(parentAppender.list)\\\\n                .extracting(ILoggingEvent::getFormattedMessage)\\\\n                .containsExactly(\\\\\\\"inherited level accepts this message\\\\\\\");\\\\n\\\\n        child.setAdditive(false);\\\\n        child.error(\\\\\\\"only the child appender sees this message\\\\\\\");\\\\n\\\\n        assertThat(childAppender.list)\\\\n                .extracting(ILoggingEvent::getFormattedMessage)\\\\n                .containsExactly(\\\\\\\"inherited level accepts this message\\\\\\\", \\\\\\\"only the child appender sees this message\\\\\\\");\\\\n        assertThat(parentAppender.list)\\\\n                .extracting(ILoggingEvent::getFormattedMessage)\\\\n                .containsExactly(\\\\\\\"inherited level accepts this message\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void asyncAppenderForwardsQueuedEventsBeforeStop() {\\\\n        ListAppender<ILoggingEvent> delegate = listAppender(\\\\\\\"delegate\\\\\\\");\\\\n        AsyncAppender asyncAppender = new AsyncAppender();\\\\n        asyncAppender.setContext(context);\\\\n        asyncAppender.setName(\\\\\\\"async\\\\\\\");\\\\n        asyncAppender.setQueueSize(32);\\\\n        asyncAppender.setDiscardingThreshold(0);\\\\n        asyncAppender.addAppender(delegate);\\\\n        asyncAppender.start();\\\\n        Logger logger = logger(\\\\\\\"async.forwarding\\\\\\\", asyncAppender);\\\\n\\\\n        for (int index = 0; index < 12; index++) {\\\\n            logger.info(\\\\\\\"queued-{}\\\\\\\", index);\\\\n        }\\\\n        asyncAppender.stop();\\\\n\\\\n        assertThat(delegate.list)\\\\n                .extracting(ILoggingEvent::getFormattedMessage)\\\\n                .containsExactly(\\\\n                        \\\\\\\"queued-0\\\\\\\",\\\\n                        \\\\\\\"queued-1\\\\\\\",\\\\n                        \\\\\\\"queued-2\\\\\\\",\\\\n                        \\\\\\\"queued-3\\\\\\\",\\\\n                        \\\\\\\"queued-4\\\\\\\",\\\\n                        \\\\\\\"queued-5\\\\\\\",\\\\n                        \\\\\\\"queued-6\\\\\\\",\\\\n                        \\\\\\\"queued-7\\\\\\\",\\\\n                        \\\\\\\"queued-8\\\\\\\",\\\\n                        \\\\\\\"queued-9\\\\\\\",\\\\n                        \\\\\\\"queued-10\\\\\\\",\\\\n                        \\\\\\\"queued-11\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void joranConfiguratorCreatesFileAppenderWithContextProperty() throws Exception {\\\\n        Path logFile = tempDir.resolve(\\\\\\\"joran-file.log\\\\\\\");\\\\n        context.putProperty(\\\\\\\"LOG_FILE\\\\\\\", logFile.toString());\\\\n        JoranConfigurator configurator = new JoranConfigurator();\\\\n        configurator.setContext(context);\\\\n\\\\n        configurator.doConfigure(new ByteArrayInputStream(fileAppenderConfiguration().getBytes(StandardCharsets.UTF_8)));\\\\n        Logger logger = context.getLogger(\\\\\\\"configured.file\\\\\\\");\\\\n        logger.info(\\\\\\\"from XML configuration\\\\\\\");\\\\n        context.stop();\\\\n\\\\n        assertThat(Files.readString(logFile, StandardCharsets.UTF_8))\\\\n                .contains(\\\\\\\"INFO|configured.file|from XML configuration\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void siftingAppenderRoutesEventsByMdcValue() throws Exception {\\\\n        context.putProperty(\\\\\\\"LOG_DIR\\\\\\\", tempDir.toString());\\\\n        JoranConfigurator configurator = new JoranConfigurator();\\\\n        configurator.setContext(context);\\\\n\\\\n        configurator.doConfigure(new ByteArrayInputStream(siftingAppenderConfiguration().getBytes(StandardCharsets.UTF_8)));\\\\n        Logger logger = context.getLogger(\\\\\\\"configured.sifting\\\\\\\");\\\\n        logger.setLevel(Level.INFO);\\\\n        MDC.put(\\\\\\\"tenant\\\\\\\", \\\\\\\"alpha\\\\\\\");\\\\n        logger.info(\\\\\\\"alpha event\\\\\\\");\\\\n        MDC.put(\\\\\\\"tenant\\\\\\\", \\\\\\\"beta\\\\\\\");\\\\n        logger.info(\\\\\\\"beta event\\\\\\\");\\\\n        MDC.remove(\\\\\\\"tenant\\\\\\\");\\\\n        logger.info(\\\\\\\"default event\\\\\\\");\\\\n        context.stop();\\\\n\\\\n        assertThat(Files.readString(tempDir.resolve(\\\\\\\"alpha.log\\\\\\\"), StandardCharsets.UTF_8)).contains(\\\\\\\"alpha|alpha event\\\\\\\");\\\\n        assertThat(Files.readString(tempDir.resolve(\\\\\\\"beta.log\\\\\\\"), StandardCharsets.UTF_8)).contains(\\\\\\\"beta|beta event\\\\\\\");\\\\n        assertThat(Files.readString(tempDir.resolve(\\\\\\\"unknown.log\\\\\\\"), StandardCharsets.UTF_8)).contains(\\\\\\\"unknown|default event\\\\\\\");\\\\n    }\\\\n\\\\n    @Test\\\\n    void sequenceNumberAndCallerDataAreAvailableOnLoggingEvents() {\\\\n        ListAppender<ILoggingEvent> appender = listAppender(\\\\\\\"events\\\\\\\");\\\\n        Logger logger = logger(\\\\\\\"event.details\\\\\\\", appender);\\\\n\\\\n        logger.info(\\\\\\\"first\\\\\\\");\\\\n        logger.info(\\\\\\\"second\\\\\\\");\\\\n\\\\n        List<ILoggingEvent> events = appender.list;\\\\n        assertThat(events).hasSize(2);\\\\n        assertThat(events.get(1).getSequenceNumber()).isGreaterThan(events.get(0).getSequenceNumber());\\\\n        assertThat(events.get(0).getCallerData())\\\\n                .extracting(StackTraceElement::getMethodName)\\\\n                .contains(\\\\\\\"sequenceNumberAndCallerDataAreAvailableOnLoggingEvents\\\\\\\");\\\\n    }\\\\n\\\\n    private Logger logger(String name, ch.qos.logback.core.Appender<ILoggingEvent> appender) {\\\\n        Logger logger = context.getLogger(name);\\\\n        logger.setAdditive(false);\\\\n        logger.setLevel(Level.TRACE);\\\\n        logger.addAppender(appender);\\\\n        return logger;\\\\n    }\\\\n\\\\n    private PatternLayoutEncoder patternEncoder(String pattern) {\\\\n        PatternLayoutEncoder encoder = new PatternLayoutEncoder();\\\\n        encoder.setContext(context);\\\\n        encoder.setCharset(StandardCharsets.UTF_8);\\\\n        encoder.setPattern(pattern);\\\\n        encoder.start();\\\\n        return encoder;\\\\n    }\\\\n\\\\n    private OutputStreamAppender<ILoggingEvent> outputStreamAppender(\\\\n            String name, PatternLayoutEncoder encoder, ByteArrayOutputStream outputStream) {\\\\n        OutputStreamAppender<ILoggingEvent> appender = new OutputStreamAppender<>();\\\\n        appender.setContext(context);\\\\n        appender.setName(name);\\\\n        appender.setEncoder(encoder);\\\\n        appender.setOutputStream(outputStream);\\\\n        appender.start();\\\\n        return appender;\\\\n    }\\\\n\\\\n    private ListAppender<ILoggingEvent> listAppender(String name) {\\\\n        ListAppender<ILoggingEvent> appender = new ListAppender<>();\\\\n        appender.setContext(context);\\\\n        appender.setName(name);\\\\n        appender.start();\\\\n        return appender;\\\\n    }\\\\n\\\\n    private static String fileAppenderConfiguration() {\\\\n        return \\\\\\\"\\\\\\\"\\\\\\\"\\\\n                <configuration>\\\\n                    <appender name=\\\\\\\"FILE\\\\\\\" class=\\\\\\\"ch.qos.logback.core.FileAppender\\\\\\\">\\\\n                        <file>${LOG_FILE}</file>\\\\n                        <append>false</append>\\\\n                        <encoder class=\\\\\\\"ch.qos.logback.classic.encoder.PatternLayoutEncoder\\\\\\\">\\\\n                            <pattern>%level|%logger|%msg%n</pattern>\\\\n                        </encoder>\\\\n                    </appender>\\\\n                    <logger name=\\\\\\\"configured.file\\\\\\\" level=\\\\\\\"INFO\\\\\\\" additivity=\\\\\\\"false\\\\\\\">\\\\n                        <appender-ref ref=\\\\\\\"FILE\\\\\\\"/>\\\\n                    </logger>\\\\n                </configuration>\\\\n                \\\\\\\"\\\\\\\"\\\\\\\";\\\\n    }\\\\n\\\\n    private static String siftingAppenderConfiguration() {\\\\n        return \\\\\\\"\\\\\\\"\\\\\\\"\\\\n                <configuration>\\\\n                    <appender name=\\\\\\\"SIFT\\\\\\\" class=\\\\\\\"ch.qos.logback.classic.sift.SiftingAppender\\\\\\\">\\\\n                        <discriminator class=\\\\\\\"ch.qos.logback.classic.sift.MDCBasedDiscriminator\\\\\\\">\\\\n                            <key>tenant</key>\\\\n                            <defaultValue>unknown</defaultValue>\\\\n                        </discriminator>\\\\n                        <sift>\\\\n                            <appender name=\\\\\\\"FILE-${tenant}\\\\\\\" class=\\\\\\\"ch.qos.logback.core.FileAppender\\\\\\\">\\\\n                                <file>${LOG_DIR}/${tenant}.log</file>\\\\n                                <append>false</append>\\\\n                                <encoder class=\\\\\\\"ch.qos.logback.classic.encoder.PatternLayoutEncoder\\\\\\\">\\\\n                                    <pattern>%X{tenant:-unknown}|%msg%n</pattern>\\\\n                                </encoder>\\\\n                            </appender>\\\\n                        </sift>\\\\n                    </appender>\\\\n                    <logger name=\\\\\\\"configured.sifting\\\\\\\" level=\\\\\\\"INFO\\\\\\\" additivity=\\\\\\\"false\\\\\\\">\\\\n                        <appender-ref ref=\\\\\\\"SIFT\\\\\\\"/>\\\\n                    </logger>\\\\n                </configuration>\\\\n                \\\\\\\"\\\\\\\"\\\\\\\";\\\\n    }\\\\n}\\\\n\\\"}\"}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 1496, \"output\": 3017, \"cacheRead\": 13312, \"cacheWrite\": 0, \"totalTokens\": 17825, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777643784190, \"responseId\": \"resp_06d5011f764ac9750169f4b108e1988195a23182e02d75fab7\"}}\nhuman-intervention-logs/ch.qos.logback:logback-classic:1.5.26/add-new-library-support/pi-generation-2026-05-01T13-58-03-761462Z.log:1275:[tool-exec] start id=call_CeKLCfCPojJuTIYEil6Dc5wV|fc_06d5011f764ac9750169f4b10ad97481959fd1e3b8bc55285d name=write args={\"path\": \"tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/ch_qos_logback/logback_classic/Logback_classicTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage ch_qos_logback.logback_classic;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.File;\\nimport java.io.IOException;\\nimport java.nio.charset.StandardCharsets;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.util.Comparator;\\nimport java.util.List;\\n\\nimport ch.qos.logback.classic.AsyncAppender;\\nimport ch.qos.logback.classic.Level;\\nimport ch.qos.logback.classic.Logger;\\nimport ch.qos.logback.classic.LoggerContext;\\nimport ch.qos.logback.classic.encoder.PatternLayoutEncoder;\\nimport ch.qos.logback.classic.filter.ThresholdFilter;\\nimport ch.qos.logback.classic.joran.JoranConfigurator;\\nimport ch.qos.logback.classic.spi.ILoggingEvent;\\nimport ch.qos.logback.core.OutputStreamAppender;\\nimport ch.qos.logback.core.read.ListAppender;\\nimport org.junit.jupiter.api.AfterEach;\\nimport org.junit.jupiter.api.BeforeEach;\\nimport org.junit.jupiter.api.Test;\\nimport org.slf4j.MDC;\\nimport org.slf4j.Marker;\\nimport org.slf4j.MarkerFactory;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class Logback_classicTest {\\n\\n    private LoggerContext context;\\n    private Path tempDir;\\n\\n    @BeforeEach\\n    void setUp() throws IOException {\\n        context = new LoggerContext();\\n        context.setName(\\\"logback-classic-test-\\\" + System.nanoTime());\\n        context.start();\\n        tempDir = Files.createTempDirectory(\\\"logback-classic-test\\\");\\n    }\\n\\n    @AfterEach\\n    void tearDown() throws IOException {\\n        MDC.clear();\\n        if (context != null) {\\n            context.stop();\\n        }\\n        if (tempDir != null) {\\n            try (var paths = Files.walk(tempDir)) {\\n                paths.sorted(Comparator.reverseOrder())\\n                        .map(Path::toFile)\\n                        .forEach(File::delete);\\n            }\\n        }\\n    }\\n\\n    @Test\\n    void patternLayoutEncoderFormatsLevelLoggerMarkerMdcAndThrowable() {\\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\\n        PatternLayoutEncoder encoder = patternEncoder(\\\"%level|%logger{0}|%marker|%X{requestId}|%msg|%ex{short}%n\\\");\\n        OutputStreamAppender<ILoggingEvent> appender = outputStreamAppender(\\\"pattern\\\", encoder, outputStream);\\n        Logger logger = logger(\\\"pattern.formatting\\\", appender);\\n        Marker marker = MarkerFactory.getMarker(\\\"SECURITY\\\");\\n\\n        MDC.put(\\\"requestId\\\", \\\"request-42\\\");\\n        logger.error(marker, \\\"login failed\\\", new IllegalStateException(\\\"denied\\\"));\\n\\n        String logLine = outputStream.toString(StandardCharsets.UTF_8);\\n        assertThat(logLine)\\n                .contains(\\\"ERROR|formatting|SECURITY|request-42|login failed|java.lang.IllegalStateException: denied\\\")\\n                .contains(\\\"at \\\")\\n                .doesNotContain(\\\"PARSER_ERROR\\\");\\n    }\\n\\n    @Test\\n    void thresholdFilterDeniesEventsBelowConfiguredLevel() {\\n        ThresholdFilter filter = new ThresholdFilter();\\n        filter.setContext(context);\\n        filter.setLevel(\\\"INFO\\\");\\n        filter.start();\\n        ListAppender<ILoggingEvent> appender = listAppender(\\\"threshold\\\");\\n        appender.addFilter(filter);\\n        Logger logger = logger(\\\"threshold.filter\\\", appender);\\n        logger.setLevel(Level.TRACE);\\n\\n        logger.debug(\\\"debug is below threshold\\\");\\n        logger.info(\\\"info is accepted\\\");\\n        logger.warn(\\\"warn is accepted\\\");\\n\\n        assertThat(appender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"info is accepted\\\", \\\"warn is accepted\\\");\\n    }\\n\\n    @Test\\n    void loggerHierarchyUsesInheritedLevelsAndAdditivity() {\\n        ListAppender<ILoggingEvent> parentAppender = listAppender(\\\"parent\\\");\\n        ListAppender<ILoggingEvent> childAppender = listAppender(\\\"child\\\");\\n        Logger parent = logger(\\\"application.service\\\", parentAppender);\\n        Logger child = context.getLogger(\\\"application.service.worker\\\");\\n        child.addAppender(childAppender);\\n        parent.setLevel(Level.WARN);\\n\\n        child.info(\\\"inherited level rejects this message\\\");\\n        child.warn(\\\"inherited level accepts this message\\\");\\n\\n        assertThat(childAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\");\\n        assertThat(parentAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\");\\n\\n        child.setAdditive(false);\\n        child.error(\\\"only the child appender sees this message\\\");\\n\\n        assertThat(childAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\", \\\"only the child appender sees this message\\\");\\n        assertThat(parentAppender.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\\"inherited level accepts this message\\\");\\n    }\\n\\n    @Test\\n    void asyncAppenderForwardsQueuedEventsBeforeStop() {\\n        ListAppender<ILoggingEvent> delegate = listAppender(\\\"delegate\\\");\\n        AsyncAppender asyncAppender = new AsyncAppender();\\n        asyncAppender.setContext(context);\\n        asyncAppender.setName(\\\"async\\\");\\n        asyncAppender.setQueueSize(32);\\n        asyncAppender.setDiscardingThreshold(0);\\n        asyncAppender.addAppender(delegate);\\n        asyncAppender.start();\\n        Logger logger = logger(\\\"async.forwarding\\\", asyncAppender);\\n\\n        for (int index = 0; index < 12; index++) {\\n            logger.info(\\\"queued-{}\\\", index);\\n        }\\n        asyncAppender.stop();\\n\\n        assertThat(delegate.list)\\n                .extracting(ILoggingEvent::getFormattedMessage)\\n                .containsExactly(\\n                        \\\"queued-0\\\",\\n                        \\\"queued-1\\\",\\n                        \\\"queued-2\\\",\\n                        \\\"queued-3\\\",\\n                        \\\"queued-4\\\",\\n                        \\\"queued-5\\\",\\n                        \\\"queued-6\\\",\\n                        \\\"queued-7\\\",\\n                        \\\"queued-8\\\",\\n                        \\\"queued-9\\\",\\n                        \\\"queued-10\\\",\\n                        \\\"queued-11\\\");\\n    }\\n\\n    @Test\\n    void joranConfiguratorCreatesFileAppenderWithContextProperty() throws Exception {\\n        Path logFile = tempDir.resolve(\\\"joran-file.log\\\");\\n        context.putProperty(\\\"LOG_FILE\\\", logFile.toString());\\n        JoranConfigurator configurator = new JoranConfigurator();\\n        configurator.setContext(context);\\n\\n        configurator.doConfigure(new ByteArrayInputStream(fileAppenderConfiguration().getBytes(StandardCharsets.UTF_8)));\\n        Logger logger = context.getLogger(\\\"configured.file\\\");\\n        logger.info(\\\"from XML configuration\\\");\\n        context.stop();\\n\\n        assertThat(Files.readString(logFile, StandardCharsets.UTF_8))\\n                .contains(\\\"INFO|configured.file|from XML configuration\\\");\\n    }\\n\\n    @Test\\n    void siftingAppenderRoutesEventsByMdcValue() throws Exception {\\n        context.putProperty(\\\"LOG_DIR\\\", tempDir.toString());\\n        JoranConfigurator configurator = new JoranConfigurator();\\n        configurator.setContext(context);\\n\\n        configurator.doConfigure(new ByteArrayInputStream(siftingAppenderConfiguration().getBytes(StandardCharsets.UTF_8)));\\n        Logger logger = context.getLogger(\\\"configured.sifting\\\");\\n        logger.setLevel(Level.INFO);\\n        MDC.put(\\\"tenant\\\", \\\"alpha\\\");\\n        logger.info(\\\"alpha event\\\");\\n        MDC.put(\\\"tenant\\\", \\\"beta\\\");\\n        logger.info(\\\"beta event\\\");\\n        MDC.remove(\\\"tenant\\\");\\n        logger.info(\\\"default event\\\");\\n        context.stop();\\n\\n        assertThat(Files.readString(tempDir.resolve(\\\"alpha.log\\\"), StandardCharsets.UTF_8)).contains(\\\"alpha|alpha event\\\");\\n        assertThat(Files.readString(tempDir.resolve(\\\"beta.log\\\"), StandardCharsets.UTF_8)).contains(\\\"beta|beta event\\\");\\n        assertThat(Files.readString(tempDir.resolve(\\\"unknown.log\\\"), StandardCharsets.UTF_8)).contains(\\\"unknown|default event\\\");\\n    }\\n\\n    @Test\\n    void sequenceNumberAndCallerDataAreAvailableOnLoggingEvents() {\\n        ListAppender<ILoggingEvent> appender = listAppender(\\\"events\\\");\\n        Logger logger = logger(\\\"event.details\\\", appender);\\n\\n        logger.info(\\\"first\\\");\\n        logger.info(\\\"second\\\");\\n\\n        List<ILoggingEvent> events = appender.list;\\n        assertThat(events).hasSize(2);\\n        assertThat(events.get(1).getSequenceNumber()).isGreaterThan(events.get(0).getSequenceNumber());\\n        assertThat(events.get(0).getCallerData())\\n                .extracting(StackTraceElement::getMethodName)\\n                .contains(\\\"sequenceNumberAndCallerDataAreAvailableOnLoggingEvents\\\");\\n    }\\n\\n    private Logger logger(String name, ch.qos.logback.core.Appender<ILoggingEvent> appender) {\\n        Logger logger = context.getLogger(name);\\n        logger.setAdditive(false);\\n        logger.setLevel(Level.TRACE);\\n        logger.addAppender(appender);\\n        return logger;\\n    }\\n\\n    private PatternLayoutEncoder patternEncoder(String pattern) {\\n        PatternLayoutEncoder encoder = new PatternLayoutEncoder();\\n        encoder.setContext(context);\\n        encoder.setCharset(StandardCharsets.UTF_8);\\n        encoder.setPattern(pattern);\\n        encoder.start();\\n        return encoder;\\n    }\\n\\n    private OutputStreamAppender<ILoggingEvent> outputStreamAppender(\\n            String name, PatternLayoutEncoder encoder, ByteArrayOutputStream outputStream) {\\n        OutputStreamAppender<ILoggingEvent> appender = new OutputStreamAppender<>();\\n        appender.setContext(context);\\n        appender.setName(name);\\n        appender.setEncoder(encoder);\\n        appender.setOutputStream(outputStream);\\n        appender.start();\\n        return appender;\\n    }\\n\\n    private ListAppender<ILoggingEvent> listAppender(String name) {\\n        ListAppender<ILoggingEvent> appender = new ListAppender<>();\\n        appender.setContext(context);\\n        appender.setName(name);\\n        appender.start();\\n        return appender;\\n    }\\n\\n    private static String fileAppenderConfiguration() {\\n        return \\\"\\\"\\\"\\n                <configuration>\\n                    <appender name=\\\"FILE\\\" class=\\\"ch.qos.logback.core.FileAppender\\\">\\n                        <file>${LOG_FILE}</file>\\n                        <append>false</append>\\n                        <encoder class=\\\"ch.qos.logback.classic.encoder.PatternLayoutEncoder\\\">\\n                            <pattern>%level|%logger|%msg%n</pattern>\\n                        </encoder>\\n                    </appender>\\n                    <logger name=\\\"configured.file\\\" level=\\\"INFO\\\" additivity=\\\"false\\\">\\n                        <appender-ref ref=\\\"FILE\\\"/>\\n                    </logger>\\n                </configuration>\\n                \\\"\\\"\\\";\\n    }\\n\\n    private static String siftingAppenderConfiguration() {\\n        return \\\"\\\"\\\"\\n                <configuration>\\n                    <appender name=\\\"SIFT\\\" class=\\\"ch.qos.logback.classic.sift.SiftingAppender\\\">\\n                        <discriminator class=\\\"ch.qos.logback.classic.sift.MDCBasedDiscriminator\\\">\\n                            <key>tenant</key>\\n                            <defaultValue>unknown</defaultValue>\\n                        </discriminator>\\n                        <sift>\\n                            <appender name=\\\"FILE-${tenant}\\\" class=\\\"ch.qos.logback.core.FileAppender\\\">\\n                                <file>${LOG_DIR}/${tenant}.log</file>\\n                                <append>false</append>\\n                                <encoder class=\\\"ch.qos.logback.classic.encoder.PatternLayoutEncoder\\\">\\n                                    <pattern>%X{tenant:-unknown}|%msg%n</pattern>\\n                                </encoder>\\n                            </appender>\\n                        </sift>\\n                    </appender>\\n                    <logger name=\\\"configured.sifting\\\" level=\\\"INFO\\\" additivity=\\\"false\\\">\\n                        <appender-ref ref=\\\"SIFT\\\"/>\\n                    </logger>\\n                </configuration>\\n                \\\"\\\"\\\";\\n    }\\n}\\n\"}\nhuman-intervention-logs/ch.qos.logback:logback-classic:1.5.26/add-new-library-support/pi-generation-2026-05-01T13-58-03-761462Z.log:1280:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_06d5011f764ac9750169f4b109715c8195b37fd6461efc8915\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp9LEKNQHTm1Ao_U5tMRnh3GcsswvkiKm2uib89BYXmvUlN9n2pct7CX_SbeBBJyLYRBsHd_cF6H7ZMdetv32dEpazPOKdV-HOtV8kpEWfthcHtabbm6BW8fIkmpk3m7uCXADUUk5Ij017FLyDLm3Fd3rrjy6U4CU2uCh4QvsdocZaHEeC-be7Z5FFUpyL7wt_R2z6N9F1R83fnfBwRHfQpL11dQLdshD01cDEPsVa08Aelg2ut_gvW6EJz4yLWqdtNqeYJNsHrh2S4Stk-2bCy_tetUkR1hojgvZbCVZAL5UTiwxXhUTmBX1vJ_8usa62ha_M0pDP-bqM_R0onyG-PyxFN7cek1Aiwd7xY5ePIdGvLsAe0d46d0bfI_7nqo6cPSrFlW94igEDduahdVPgG_t3xyFojofIX_Qirn1QdM4F8x-5JhhTMqb5jOJmmf9RFFtSc170YIOtt2mKFCmyFN5o6tnWhWEKXOQsDu6AO4_u2jFCW6ZzEs3atiakWLj2j4qV1qWpXa-EklyE7DyusUaoJPboxVAJ0XFstrii6wFJvjMEtJEOW3NLltajU2vkob72zri46zbMVOj8RAYW8Vx1H11I3vyWk4vGp_bj8AnGUgx3DOZZtZheEH5Hv6G5pnrX9YB74RXX06o5FgnJ6e-kKHTfjK4nfLPxohaE_Qtd6XJmcf4jTQQX3mil4gSvniGu6hYdgr70aYQYAs-wMgkeeiXEWQAkS2DomzK7lU7j8ATgQ2sjpR9To20QSycBRGb7Ilpt0jRFPqwz3k3uwUpT1CRCyWBzRG7qiK5ZV_SU95iMWUf0RbVvhkRa4flI_ZVXwTVmpshstqnu9ck4d1bYBPMIxVIBbQRvlSVLmIcf2fIj40P6MKwaepfpYTYtiHYe7-2bmKtQC2gahbVn2bQSIQxU44