f507de41e78f016a0473bea7a481968e565eded5b8b5b3", "name": "write", "arguments": {"path": "tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/ContextSelectorStaticBinderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.graalvm.logback;\n\nimport ch.qos.logback.classic.ClassicConstants;\nimport ch.qos.logback.classic.LoggerContext;\nimport ch.qos.logback.classic.selector.ContextSelector;\nimport ch.qos.logback.classic.selector.DefaultContextSelector;\nimport ch.qos.logback.classic.util.ContextSelectorStaticBinder;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ContextSelectorStaticBinderTest {\n\n  @Test\n  void shouldInstantiateConfiguredContextSelectorDynamically() throws Exception {\n    String previousContextSelector = System.getProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR);\n    LoggerContext context = new LoggerContext();\n    context.setName(\"dynamic-context-selector-test\");\n\n    try {\n      System.setProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR, DefaultContextSelector.class.getName());\n\n      ContextSelectorStaticBinder binder = new ContextSelectorStaticBinder();\n      binder.init(context, new Object());\n\n      ContextSelector selector = binder.getContextSelector();\n      assertThat(selector).isInstanceOf(DefaultContextSelector.class);\n      assertThat(selector.getLoggerContext()).isSameAs(context);\n      assertThat(selector.getContextNames()).containsExactly(context.getName());\n    } finally {\n      restoreContextSelector(previousContextSelector);\n      context.stop();\n    }\n  }\n\n  private void restoreContextSelector(String previousContextSelector) {\n    if (previousContextSelector == null) {\n      System.clearProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR);\n    } else {\n      System.setProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR, previousContextSelector);\n    }\n  }\n}\n"}, "partialJson": "{\"path\":\"tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/ContextSelectorStaticBinderTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org.graalvm.logback;\\n\\nimport ch.qos.logback.classic.ClassicConstants;\\nimport ch.qos.logback.classic.LoggerContext;\\nimport ch.qos.logback.classic.selector.ContextSelector;\\nimport ch.qos.logback.classic.selector.DefaultContextSelector;\\nimport ch.qos.logback.classic.util.ContextSelectorStaticBinder;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ContextSelectorStaticBinderTest {\\n\\n  @Test\\n  void shouldInstantiateConfiguredContextSelectorDynamically() throws Exception {\\n    String previousContextSelector = System.getProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR);\\n    LoggerContext context = new LoggerContext();\\n    context.setName(\\\"dynamic-context-selector-test\\\");\\n\\n    try {\\n      System.setProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR, DefaultContextSelector.class.getName());\\n\\n      ContextSelectorStaticBinder binder = new ContextSelectorStaticBinder();\\n      binder.init(context, new Object());\\n\\n      ContextSelector selector = binder.getContextSelector();\\n      assertThat(selector).isInstanceOf(DefaultContextSelector.class);\\n      assertThat(selector.getLoggerContext()).isSameAs(context);\\n      assertThat(selector.getContextNames()).containsExactly(context.getName());\\n    } finally {\\n      restoreContextSelector(previousContextSelector);\\n      context.stop();\\n    }\\n  }\\n\\n  private void restoreContextSelector(String previousContextSelector) {\\n    if (previousContextSelector == null) {\\n      System.clearProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR);\\n    } else {\\n      System.setProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR, previousContextSelector);\\n    }\\n  }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1415, "output": 1101, "cacheRead": 29184, "cacheWrite": 0, "totalTokens": 31700, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778676659227, "responseId": "resp_0b27f507de41e78f016a0473b3d6dc8196808fdeb73e0eed96"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_YCk1BHxGh9VGw2X4OsbaMVHI|fc_0b27f507de41e78f016a0473bea7a481968e565eded5b8b5b3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1875 bytes to tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/ContextSelectorStaticBinderTest.java"}], "isError": false, "timestamp": 1778676673423}]}
