stem.clearProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR);\n    } else {\n      System.setProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR, previousContextSelector);\n    }\n  }\n}\n"}
