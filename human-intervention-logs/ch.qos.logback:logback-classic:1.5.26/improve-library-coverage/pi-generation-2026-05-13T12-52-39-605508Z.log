s(context);\n      assertThat(selector.getContextNames()).containsExactly(context.getName());\n    } finally {\n      restoreContextSelector(previousContextSelector);\n      context.stop();\n    }\n  }\n\n  private void restoreContextSelector(String previousContextSelector) {\n    if (previousContextSelector == null) {\n      System.clearProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR);\n    } else {\n      System.setProperty(ClassicConstants.LOGBACK_CONTEXT_SELECTOR, previousContextSelector);\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1778676679275}, {"role": "toolResult", "toolCallId": "call_l7cHisxEWw3tpwwQmjNXVb6q|fc_0b27f507de41e78f016a0473c6e9dc8196a5658981e8f8574f", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"rules\": [\n    {\n      \"includeClasses\": \"ch.qos.logback.**\"\n    },\n    {\n      \"includeClasses\": \"org.slf4j.LoggerFactory\"\n    },\n    {\n      \"includeClasses\": \"org.graalvm.logback.LogbackTests\"\n    },\n    {\n      \"includeClasses\": \"org.graalvm.logback.ContextInitializerTest\"\n    },\n    {\n      \"includeClasses\": \"org.graalvm.logback.ContextSelectorStaticBinderTest\"\n    }\n  ]\n}\n"}], "isError": false, "timestamp": 1778676679276}]}
