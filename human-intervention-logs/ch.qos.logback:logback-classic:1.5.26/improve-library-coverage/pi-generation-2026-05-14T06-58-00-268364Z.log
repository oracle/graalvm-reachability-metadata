k.LoggingEventVOTest\",\n+\t\t\t\tvalue: \"ch.qos.logback.classic.spi.LoggingEventVO\")\n \t}\n }\n \ndiff --git a/tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/LoggingEventVOTest.java b/tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/LoggingEventVOTest.java\nnew file mode 100644\nindex 0000000000..a807ff410d\n--- /dev/null\n+++ b/tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/LoggingEventVOTest.java\n@@ -0,0 +1,67 @@\n+/*\n+ * Copyright and related rights waived via CC0\n+ *\n+ * You should have received a copy of the CC0 legalcode along with this\n+ * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n+ */\n+package org.graalvm.logback;\n+\n+import java.io.ByteArrayInputStream;\n+import java.io.ByteArrayOutputStream;\n+import java.io.ObjectInputStream;\n+import java.io.ObjectOutputStream;\n+import java.util.HashMap;\n+import java.util.Map;\n+\n+import ch.qos.logback.classic.Level;\n+import ch.qos.logback.classic.Logger;\n+import ch.qos.logback.classic.LoggerContext;\n+import ch.qos.logback.classic.spi.LoggingEvent;\n+import ch.qos.logback.classic.spi.LoggingEventVO;\n+import org.junit.jupiter.api.Test;\n+\n+import static org.assertj.core.api.Assertions.assertThat;\n+\n+public class LoggingEventVOTest {\n+\n+  @Test\n+  void serializesAndDeserializesLoggingEventValueObjectArguments() throws Exception {\n+    LoggerContext context = new LoggerContext();\n+    try {\n+      Logger logger = context.getLogger(LoggingEventVOTest.class);\n+      Object[] arguments = {new StringBuilder(\"first\"), null};\n+      LoggingEvent event = new LoggingEvent(Logger.class.getName(), logger, Level.INFO, \"payload {} {}\", null,\n+              arguments);\n+      Map<String, String> mdcProperties = new HashMap<>();\n+      mdcProperties.put(\"requestId\", \"native-image-test\");\n+      event.setMDCPropertyMap(mdcProperties);\n+\n+      LoggingEventVO eventVO = LoggingEventVO.build(event);\n+\n+      byte[] serializedEvent = serialize(eventVO);\n+      LoggingEventVO deserializedEvent = deserialize(serializedEvent);\n+\n+      assertThat(deserializedEvent.getLevel()).isEqualTo(Level.INFO);\n+      assertThat(deserializedEvent.getMessage()).isEqualTo(\"payload {} {}\");\n+      assertThat(deserializedEvent.getArgumentArray()).containsExactly(\"first\", null);\n+      assertThat(deserializedEvent.getFormattedMessage()).isEqualTo(\"payload first null\");\n+      assertThat(deserializedEvent.getMDCPropertyMap()).containsEntry(\"requestId\", \"native-image-test\");\n+    } finally {\n+      context.stop();\n+    }\n+  }\n+\n+  private byte[] serialize(LoggingEventVO eventVO) throws Exception {\n+    ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();\n+    try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteArrayOutputStream)) {\n+      objectOutputStream.writeObject(eventVO);\n+    }\n+    return byteArrayOutputStream.toByteArray();\n+  }\n+\n+  private LoggingEventVO deserialize(byte[] serializedEvent) throws Exception {\n+    try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serializedEvent))) {\n+      return (LoggingEventVO) objectInputStream.readObject();\n+    }\n+  }\n+}\n"}], "isError": false, "timestamp": 1778741866570}]}
