loggerContext.stop();\\n    }\\n  }\\n\\n  private static void writeSerializedModel(Path serializedModel) throws Exception {\\n    ConfigurationModel configurationModel = new ConfigurationModel();\\n    configurationModel.setTag(\\\"configuration\\\");\\n    RootLoggerModel rootLoggerModel = new RootLoggerModel();\\n    rootLoggerModel.setTag(\\\"root\\\");\\n    rootLoggerModel.setLevel(Level.DEBUG.levelStr);\\n    configurationModel.addSubModel(rootLoggerModel);\\n\\n    try (OutputStream fileOutputStream = Files.newOutputStream(serializedModel);\\n        ObjectOutputStream objectOutputStream = new ObjectOutputStream(fileOutputStream)) {\\n      objectOutputStream.writeObject(configurationModel);\\n    }\\n  }\\n\\n  private static void restoreSystemProperty(String key, String value) {\\n    if (value == null) {\\n      System.clearProperty(key);\\n    } else {\\n      System.setProperty(key, value);\\n    }\\n  }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1641, "output": 897, "cacheRead": 36352, "cacheWrite": 0, "totalTokens": 38890, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778744805567, "responseId": "resp_06ef62d83d7eb8ea016a057de65d60819284c9b8f8161160ab"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_zN45gJRwaRDRIwQyOZSonbO3|fc_06ef62d83d7eb8ea016a057de9d2a081929931eed251524f68", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3143 bytes to tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/SerializedModelConfiguratorTest.java"}], "isError": false, "timestamp": 1778744814050}]}
