3nTd4fSWahKGaUTC-Hk6owZY-nelP-Mmm16-fM7mQ4OGFMK0O\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_A60Ao7h92QUmd8d1L4vviMDq|fc_0e34206673968c4a016a0581a380b0819fa51bcadaee7efc81", "name": "write", "arguments": {"path": "tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/SocketReceiverTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.graalvm.logback;\n\nimport java.io.ObjectOutputStream;\nimport java.net.InetAddress;\nimport java.net.InetSocketAddress;\nimport java.net.ServerSocket;\nimport java.net.Socket;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport javax.net.SocketFactory;\n\nimport ch.qos.logback.classic.Level;\nimport ch.qos.logback.classic.Logger;\nimport ch.qos.logback.classic.LoggerContext;\nimport ch.qos.logback.classic.net.SocketReceiver;\nimport ch.qos.logback.classic.spi.ILoggingEvent;\nimport ch.qos.logback.classic.spi.LoggingEvent;\nimport ch.qos.logback.classic.spi.LoggingEventVO;\nimport ch.qos.logback.classic.util.LogbackMDCAdapter;\nimport ch.qos.logback.core.AppenderBase;\nimport ch.qos.logback.core.net.SocketConnector;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SocketReceiverTest {\n\n  private static final int SOCKET_TIMEOUT_MILLIS = 5_000;\n\n  @Test\n  void dispatchesSerializedLoggingEventFromRemoteSocket() throws Exception {\n    LoggerContext loggerContext = new LoggerContext();\n    loggerContext.setName(\"socket-receiver-test\");\n    loggerContext.setMDCAdapter(new LogbackMDCAdapter());\n\n    OneShotSocketReceiver receiver = null;\n    CapturingAppender appender = new CapturingAppender();\n    try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress());\n        Socket writerSocket = new Socket()) {\n      serverSocket.setSoTimeout(SOCKET_TIMEOUT_MILLIS);\n      writerSocket.connect(new InetSocketAddress(InetAddress.getLoopbackAddress(), serverSocket.getLocalPort()),\n          SOCKET_TIMEOUT_MILLIS);\n\n      try (Socket receiverSocket = serverSocket.accept()) {\n        Logger remoteLogger = loggerContext.getLogger(\"org.graalvm.logback.SocketReceiverTest.remote\");\n        remoteLogger.setAdditive(false);\n        remoteLogger.setLevel(Level.INFO);\n        appender.setContext(loggerContext);\n        appender.start();\n        remoteLogger.addAppender(appender);\n\n        receiver = new OneShotSocketReceiver(receiverSocket);\n        receiver.setContext(loggerContext);\n        receiver.setRemoteHost(InetAddress.getLoopbackAddress().getHostAddress());\n        receiver.setPort(serverSocket.getLocalPort());\n        receiver.setReconnectionDelay(1);\n        receiver.setAcceptConnectionTimeout(SOCKET_TIMEOUT_MILLIS);\n        receiver.start();\n\n        LoggingEventVO loggingEvent = createLoggingEvent(remoteLogger, \"message from socket receiver\");\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(writerSocket.getOutputStream())) {\n          outputStream.writeObject(loggingEvent);\n          outputStream.flush();\n        }\n\n        ILoggingEvent receivedEvent = appender.awaitEvent();\n        assertThat(receivedEvent.getFormattedMessage()).isEqualTo(\"message from socket receiver\");\n      }\n    } finally {\n      if (receiver != null) {\n        receiver.stop();\n      }\n      appender.stop();\n      loggerContext.stop();\n    }\n  }\n\n  private static LoggingEventVO createLoggingEvent(Logger logger, String message) {\n    LoggingEvent loggingEvent = new LoggingEvent(SocketReceiverTest.class.getName(), logger, Level.INFO, message, null,\n        null);\n    return LoggingEventVO.build(loggingEvent);\n  }\n\n  private static final class OneShotSocketReceiver extends SocketReceiver {\n\n    private final AtomicReference<Socket> socketReference;\n\n    OneShotSocketReceiver(Socket socket) {\n      socketReference = new AtomicReference<>(socket);\n    }\n\n    @Override\n    protected SocketConnector newConnector(InetAddress address, int port, int initialDelay, int retryDelay) {\n      return new SocketConnector() {\n        @Override\n        public Socket call() {\n          return socketReference.getAndSet(null);\n        }\n\n        @Override\n        public void setExceptionHandler(ExceptionHandler exceptionHandler) {\n        }\n\n        @Override\n        public void setSocketFactory(SocketFactory socketFactory) {\n        }\n      };\n    }\n  }\n\n  private static final class CapturingAppender extends AppenderBase<ILoggingEvent> {\n\n    private final CountDownLatch eventReceived = new CountDownLatch(1);\n    private final AtomicReference<ILoggingEvent> eventReference = new AtomicReference<>();\n\n    @Override\n    protected void append(ILoggingEvent eventObject) {\n      eventReference.set(eventObject);\n      eventReceived.countDown();\n    }\n\n    ILoggingEvent awaitEvent() throws InterruptedException {\n      assertThat(eventReceived.await(SOCKET_TIMEOUT_MILLIS, TimeUnit.MILLISECONDS)).isTrue();\n      return eventReference.get();\n    }\n  }\n}\n"}, "partialJson": "{\"path\":\"tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/SocketReceiverTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org.graalvm.logback;\\n\\nimport java.io.ObjectOutputStream;\\nimport java.net.InetAddress;\\nimport java.net.InetSocketAddress;\\nimport java.net.ServerSocket;\\nimport java.net.Socket;\\nimport java.util.concurrent.CountDownLatch;\\nimport java.util.concurrent.TimeUnit;\\nimport java.util.concurrent.atomic.AtomicReference;\\n\\nimport javax.net.SocketFactory;\\n\\nimport ch.qos.logback.classic.Level;\\nimport ch.qos.logback.classic.Logger;\\nimport ch.qos.logback.classic.LoggerContext;\\nimport ch.qos.logback.classic.net.SocketReceiver;\\nimport ch.qos.logback.classic.spi.ILoggingEvent;\\nimport ch.qos.logback.classic.spi.LoggingEvent;\\nimport ch.qos.logback.classic.spi.LoggingEventVO;\\nimport ch.qos.logback.classic.util.LogbackMDCAdapter;\\nimport ch.qos.logback.core.AppenderBase;\\nimport ch.qos.logback.core.net.SocketConnector;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class SocketReceiverTest {\\n\\n  private static final int SOCKET_TIMEOUT_MILLIS = 5_000;\\n\\n  @Test\\n  void dispatchesSerializedLoggingEventFromRemoteSocket() throws Exception {\\n    LoggerContext loggerContext = new LoggerContext();\\n    loggerContext.setName(\\\"socket-receiver-test\\\");\\n    loggerContext.setMDCAdapter(new LogbackMDCAdapter());\\n\\n    OneShotSocketReceiver receiver = null;\\n    CapturingAppender appender = new CapturingAppender();\\n    try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress());\\n        Socket writerSocket = new Socket()) {\\n      serverSocket.setSoTimeout(SOCKET_TIMEOUT_MILLIS);\\n      writerSocket.connect(new InetSocketAddress(InetAddress.getLoopbackAddress(), serverSocket.getLocalPort()),\\n          SOCKET_TIMEOUT_MILLIS);\\n\\n      try (Socket receiverSocket = serverSocket.accept()) {\\n        Logger remoteLogger = loggerContext.getLogger(\\\"org.graalvm.logback.SocketReceiverTest.remote\\\");\\n        remoteLogger.setAdditive(false);\\n        remoteLogger.setLevel(Level.INFO);\\n        appender.setContext(loggerContext);\\n        appender.start();\\n        remoteLogger.addAppender(appender);\\n\\n        receiver = new OneShotSocketReceiver(receiverSocket);\\n        receiver.setContext(loggerContext);\\n        receiver.setRemoteHost(InetAddress.getLoopbackAddress().getHostAddress());\\n        receiver.setPort(serverSocket.getLocalPort());\\n        receiver.setReconnectionDelay(1);\\n        receiver.setAcceptConnectionTimeout(SOCKET_TIMEOUT_MILLIS);\\n        receiver.start();\\n\\n        LoggingEventVO loggingEvent = createLoggingEvent(remoteLogger, \\\"message from socket receiver\\\");\\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(writerSocket.getOutputStream())) {\\n          outputStream.writeObject(loggingEvent);\\n          outputStream.flush();\\n        }\\n\\n        ILoggingEvent receivedEvent = appender.awaitEvent();\\n        assertThat(receivedEvent.getFormattedMessage()).isEqualTo(\\\"message from socket receiver\\\");\\n      }\\n    } finally {\\n      if (receiver != null) {\\n        receiver.stop();\\n      }\\n      appender.stop();\\n      loggerContext.stop();\\n    }\\n  }\\n\\n  private static LoggingEventVO createLoggingEvent(Logger logger, String message) {\\n    LoggingEvent loggingEvent = new LoggingEvent(SocketReceiverTest.class.getName(), logger, Level.INFO, message, null,\\n        null);\\n    return LoggingEventVO.build(loggingEvent);\\n  }\\n\\n  private static final class OneShotSocketReceiver extends SocketReceiver {\\n\\n    private final AtomicReference<Socket> socketReference;\\n\\n    OneShotSocketReceiver(Socket socket) {\\n      socketReference = new AtomicReference<>(socket);\\n    }\\n\\n    @Override\\n    protected SocketConnector newConnector(InetAddress address, int port, int initialDelay, int retryDelay) {\\n      return new SocketConnector() {\\n        @Override\\n        public Socket call() {\\n          return socketReference.getAndSet(null);\\n        }\\n\\n        @Override\\n        public void setExceptionHandler(ExceptionHandler exceptionHandler) {\\n        }\\n\\n        @Override\\n        public void setSocketFactory(SocketFactory socketFactory) {\\n        }\\n      };\\n    }\\n  }\\n\\n  private static final class CapturingAppender extends AppenderBase<ILoggingEvent> {\\n\\n    private final CountDownLatch eventReceived = new CountDownLatch(1);\\n    private final AtomicReference<ILoggingEvent> eventReference = new AtomicReference<>();\\n\\n    @Override\\n    protected void append(ILoggingEvent eventObject) {\\n      eventReference.set(eventObject);\\n      eventReceived.countDown();\\n    }\\n\\n    ILoggingEvent awaitEvent() throws InterruptedException {\\n      assertThat(eventReceived.await(SOCKET_TIMEOUT_MILLIS, TimeUnit.MILLISECONDS)).isTrue();\\n      return eventReference.get();\\n    }\\n  }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1977, "output": 2411, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 28452, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778745743449, "responseId": "resp_0e34206673968c4a016a05819056d8819fbce5600033456b10"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_A60Ao7h92QUmd8d1L4vviMDq|fc_0e34206673968c4a016a0581a380b0819fa51bcadaee7efc81", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4860 bytes to tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/SocketReceiverTest.java"}], "isError": false, "timestamp": 1778745771272}]}
