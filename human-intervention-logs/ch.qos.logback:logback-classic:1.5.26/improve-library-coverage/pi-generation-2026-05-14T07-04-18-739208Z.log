  package org.graalvm.logback;
  
  import ch.qos.logback.classic.Level;
  import ch.qos.logback.classic.Logger;
  import ch.qos.logback.classic.LoggerContext;
  import ch.qos.logback.classic.spi.LoggingEvent;
  import ch.qos.logback.classic.spi.StackTraceElementProxy;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PackagingDataCalculatorTest {
  
    @Test
    void calculatesPackagingDataAfterContextClassLoaderMiss() {
      ClassLoader originalContextClassLoader = Thread.currentThread().getContextClassLoader();
      Thread.currentThread().setContextClassLoader(ClassLoader.getPlatformClassLoader());
      LoggerContext context = new LoggerContext();
      try {
        context.setPackagingDataEnabled(true);
        Logger logger = context.getLogger(PackagingDataCalculatorTest.class);
        Throwable throwable = throwableWithLogbackFrame();
  
        LoggingEvent event = new LoggingEvent(Logger.class.getName(), logger, Level.ERROR, "test failure", throwable,
                null);
  
        StackTraceElementProxy firstFrame = event.getThrowableProxy().getStackTraceElementProxyArray()[0];
        assertThat(firstFrame.getStackTraceElement().getClassName()).isEqualTo(Logger.class.getName());
        assertThat(firstFrame.getClassPackagingData()).isNotNull();
        assertThat(firstFrame.getClassPackagingData().isExact()).isFalse();
        assertThat(firstFrame.getClassPackagingData().getCodeLocation()).isNotNull();
        assertThat(firstFrame.getClassPackagingData().getVersion()).isNotNull();
      } finally {
        context.stop();
        Thread.currentThread().setContextClassLoader(originalContextClassLoader);
      }
    }
  
    private Throwable throwableWithLogbackFrame() {
      Throwable throwable = new IllegalStateException("simulated logback exception");
      throwable.setStackTrace(new StackTraceElement[] {
          new StackTraceElement(Logger.class.getName(), "error", "Logger.java", 42)
      });
      return throwable;
    }
  }
