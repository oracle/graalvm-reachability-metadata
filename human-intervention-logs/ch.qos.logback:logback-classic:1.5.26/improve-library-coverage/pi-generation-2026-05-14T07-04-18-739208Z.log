  package org.graalvm.logback;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.HashMap;
  import java.util.Map;
  
  import ch.qos.logback.classic.Level;
  import ch.qos.logback.classic.Logger;
  import ch.qos.logback.classic.LoggerContext;
  import ch.qos.logback.classic.spi.LoggingEvent;
  import ch.qos.logback.classic.spi.LoggingEventVO;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LoggingEventVOTest {
  
    @Test
    void serializesAndDeserializesLoggingEventValueObjectArguments() throws Exception {
      LoggerContext context = new LoggerContext();
      try {
        Logger logger = context.getLogger(LoggingEventVOTest.class);
        Object[] arguments = {new StringBuilder("first"), null};
        LoggingEvent event = new LoggingEvent(Logger.class.getName(), logger, Level.INFO, "payload {} {}", null,
                arguments);
        Map<String, String> mdcProperties = new HashMap<>();
        mdcProperties.put("requestId", "native-image-test");
        event.setMDCPropertyMap(mdcProperties);
  
        LoggingEventVO eventVO = LoggingEventVO.build(event);
  
        byte[] serializedEvent = serialize(eventVO);
        LoggingEventVO deserializedEvent = deserialize(serializedEvent);
  
        assertThat(deserializedEvent.getLevel()).isEqualTo(Level.INFO);
        assertThat(deserializedEvent.getMessage()).isEqualTo("payload {} {}");
        assertThat(deserializedEvent.getArgumentArray()).containsExactly("first", null);
        assertThat(deserializedEvent.getFormattedMessage()).isEqualTo("payload first null");
        assertThat(deserializedEvent.getMDCPropertyMap()).containsEntry("requestId", "native-image-test");
      } finally {
        context.stop();
      }
    }
  
    private byte[] serialize(LoggingEventVO eventVO) throws Exception {
      ByteArrayOutputStream byteArrayOutputStream = new ByteArrayOutputStream();
      try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(byteArrayOutputStream)) {
        objectOutputStream.writeObject(eventVO);
      }
      return byteArrayOutputStream.toByteArray();
    }
  
    private LoggingEventVO deserialize(byte[] serializedEvent) throws Exception {
      try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serializedEvent))) {
        return (LoggingEventVO) objectInputStream.readObject();
      }
    }
  }
