/1.5.26/src/test/java/org/graalvm/logback/SocketReceiverTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.graalvm.logback;\n\nimport java.io.ObjectOutputStream;\nimport java.net.InetAddress;\nimport java.net.ServerSocket;\nimport java.net.Socket;\nimport java.time.Duration;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.Future;\nimport java.util.concurrent.TimeUnit;\n\nimport ch.qos.logback.classic.Level;\nimport ch.qos.logback.classic.Logger;\nimport ch.qos.logback.classic.LoggerContext;\nimport ch.qos.logback.classic.net.SocketReceiver;\nimport ch.qos.logback.classic.spi.ILoggingEvent;\nimport ch.qos.logback.classic.spi.LoggingEvent;\nimport ch.qos.logback.classic.spi.LoggingEventVO;\nimport ch.qos.logback.classic.util.LogbackMDCAdapter;\nimport ch.qos.logback.core.read.ListAppender;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SocketReceiverTest {\n\n  @Test\n  void shouldReceiveSerializedLoggingEventFromRemoteServerAndDispatchToContextLogger() throws Exception {\n    LoggerContext context = new LoggerContext();\n    context.setName(\"socket-receiver-test\");\n    context.setMDCAdapter(new LogbackMDCAdapter());\n    ExecutorService serverExecutor = Executors.newSingleThreadExecutor();\n\n    try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\n      ListAppender<ILoggingEvent> appender = createListAppender(context);\n      Logger logger = createLogger(context, appender);\n      LoggingEventVO remoteEvent = createEventVO(logger);\n      Future<?> serverFuture = serverExecutor.submit(() -> writeEvent(serverSocket, remoteEvent));\n\n      SocketReceiver receiver = createReceiver(context, serverSocket.getInetAddress(), serverSocket.getLocalPort());\n      try {\n        receiver.start();\n\n        waitForEvent(appender, Duration.ofSeconds(5));\n        serverFuture.get(5, TimeUnit.SECONDS);\n      } finally {\n        receiver.stop();\n      }\n\n      assertThat(appender.list).singleElement()\n          .satisfies(event -> {\n            assertThat(event.getLoggerName()).isEqualTo(logger.getName());\n            assertThat(event.getLevel()).isEqualTo(Level.INFO);\n            assertThat(event.getFormattedMessage()).isEqualTo(\"socket-receiver message\");\n          });\n    } finally {\n      context.stop();\n      serverExecutor.shutdownNow();\n      serverExecutor.awaitTermination(5, TimeUnit.SECONDS);\n    }\n  }\n\n  private void writeEvent(ServerSocket serverSocket, LoggingEventVO remoteEvent) throws Exception {\n    try (Socket socket = serverSocket.accept();\n        ObjectOutputStream objectOutputStream = new ObjectOutputStream(socket.getOutputStream())) {\n      objectOutputStream.writeObject(remoteEvent);\n      objectOutputStream.flush();\n      socket.shutdownOutput();\n    }\n  }\n\n  private SocketReceiver createReceiver(LoggerContext context, InetAddress remoteAddress, int remotePort) {\n    SocketReceiver receiver = new SocketReceiver();\n    receiver.setContext(context);\n    receiver.setRemoteHost(remoteAddress.getHostAddress());\n    receiver.setPort(remotePort);\n    receiver.setReconnectionDelay(100);\n    receiver.setAcceptConnectionTimeout(2_000);\n    return receiver;\n  }\n\n  private ListAppender<ILoggingEvent> createListAppender(LoggerContext context) {\n    ListAppender<ILoggingEvent> appender = new ListAppender<>();\n    appender.setContext(context);\n    appender.start();\n    return appender;\n  }\n\n  private Logger createLogger(LoggerContext context, ListAppender<ILoggingEvent> appender) {\n    Logger logger = context.getLogger(\"org.graalvm.logback.SocketReceiverTest.remote\");\n    logger.setLevel(Level.DEBUG);\n    logger.setAdditive(false);\n    logger.addAppender(appender);\n    return logger;\n  }\n\n  private LoggingEventVO createEventVO(Logger logger) {\n    LoggingEvent event = new LoggingEvent(SocketReceiverTest.class.getName(), logger, Level.INFO,\n        \"socket-receiver message\", null, null);\n    return LoggingEventVO.build(event);\n  }\n\n  private void waitForEvent(ListAppender<ILoggingEvent> appender, Duration timeout) throws InterruptedException {\n    long deadline = System.nanoTime() + timeout.toNanos();\n    while (appender.list.isEmpty() && System.nanoTime() < deadline) {\n      Thread.sleep(10);\n    }\n    assertThat(appender.list).isNotEmpty();\n  }\n}\n"}, "partialJson": "{\"path\":\"tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/SocketReceiverTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org.graalvm.logback;\\n\\nimport java.io.ObjectOutputStream;\\nimport java.net.InetAddress;\\nimport java.net.ServerSocket;\\nimport java.net.Socket;\\nimport java.time.Duration;\\nimport java.util.concurrent.ExecutorService;\\nimport java.util.concurrent.Executors;\\nimport java.util.concurrent.Future;\\nimport java.util.concurrent.TimeUnit;\\n\\nimport ch.qos.logback.classic.Level;\\nimport ch.qos.logback.classic.Logger;\\nimport ch.qos.logback.classic.LoggerContext;\\nimport ch.qos.logback.classic.net.SocketReceiver;\\nimport ch.qos.logback.classic.spi.ILoggingEvent;\\nimport ch.qos.logback.classic.spi.LoggingEvent;\\nimport ch.qos.logback.classic.spi.LoggingEventVO;\\nimport ch.qos.logback.classic.util.LogbackMDCAdapter;\\nimport ch.qos.logback.core.read.ListAppender;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class SocketReceiverTest {\\n\\n  @Test\\n  void shouldReceiveSerializedLoggingEventFromRemoteServerAndDispatchToContextLogger() throws Exception {\\n    LoggerContext context = new LoggerContext();\\n    context.setName(\\\"socket-receiver-test\\\");\\n    context.setMDCAdapter(new LogbackMDCAdapter());\\n    ExecutorService serverExecutor = Executors.newSingleThreadExecutor();\\n\\n    try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\\n      ListAppender<ILoggingEvent> appender = createListAppender(context);\\n      Logger logger = createLogger(context, appender);\\n      LoggingEventVO remoteEvent = createEventVO(logger);\\n      Future<?> serverFuture = serverExecutor.submit(() -> writeEvent(serverSocket, remoteEvent));\\n\\n      SocketReceiver receiver = createReceiver(context, serverSocket.getInetAddress(), serverSocket.getLocalPort());\\n      try {\\n        receiver.start();\\n\\n        waitForEvent(appender, Duration.ofSeconds(5));\\n        serverFuture.get(5, TimeUnit.SECONDS);\\n      } finally {\\n        receiver.stop();\\n      }\\n\\n      assertThat(appender.list).singleElement()\\n          .satisfies(event -> {\\n            assertThat(event.getLoggerName()).isEqualTo(logger.getName());\\n            assertThat(event.getLevel()).isEqualTo(Level.INFO);\\n            assertThat(event.getFormattedMessage()).isEqualTo(\\\"socket-receiver message\\\");\\n          });\\n    } finally {\\n      context.stop();\\n      serverExecutor.shutdownNow();\\n      serverExecutor.awaitTermination(5, TimeUnit.SECONDS);\\n    }\\n  }\\n\\n  private void writeEvent(ServerSocket serverSocket, LoggingEventVO remoteEvent) throws Exception {\\n    try (Socket socket = serverSocket.accept();\\n        ObjectOutputStream objectOutputStream = new ObjectOutputStream(socket.getOutputStream())) {\\n      objectOutputStream.writeObject(remoteEvent);\\n      objectOutputStream.flush();\\n      socket.shutdownOutput();\\n    }\\n  }\\n\\n  private SocketReceiver createReceiver(LoggerContext context, InetAddress remoteAddress, int remotePort) {\\n    SocketReceiver receiver = new SocketReceiver();\\n    receiver.setContext(context);\\n    receiver.setRemoteHost(remoteAddress.getHostAddress());\\n    receiver.setPort(remotePort);\\n    receiver.setReconnectionDelay(100);\\n    receiver.setAcceptConnectionTimeout(2_000);\\n    return receiver;\\n  }\\n\\n  private ListAppender<ILoggingEvent> createListAppender(LoggerContext context) {\\n    ListAppender<ILoggingEvent> appender = new ListAppender<>();\\n    appender.setContext(context);\\n    appender.start();\\n    return appender;\\n  }\\n\\n  private Logger createLogger(LoggerContext context, ListAppender<ILoggingEvent> appender) {\\n    Logger logger = context.getLogger(\\\"org.graalvm.logback.SocketReceiverTest.remote\\\");\\n    logger.setLevel(Level.DEBUG);\\n    logger.setAdditive(false);\\n    logger.addAppender(appender);\\n    return logger;\\n  }\\n\\n  private LoggingEventVO createEventVO(Logger logger) {\\n    LoggingEvent event = new LoggingEvent(SocketReceiverTest.class.getName(), logger, Level.INFO,\\n        \\\"socket-receiver message\\\", null, null);\\n    return LoggingEventVO.build(event);\\n  }\\n\\n  private void waitForEvent(ListAppender<ILoggingEvent> appender, Duration timeout) throws InterruptedException {\\n    long deadline = System.nanoTime() + timeout.toNanos();\\n    while (appender.list.isEmpty() && System.nanoTime() < deadline) {\\n      Thread.sleep(10);\\n    }\\n    assertThat(appender.list).isNotEmpty();\\n  }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 644, "output": 1900, "cacheRead": 37376, "cacheWrite": 0, "totalTokens": 39920, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778677881363, "responseId": "resp_04b3c1216c2c36b6016a047879f0c881a08a6c823314767f1d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Zz63JpOPTaUkDIijsRRBV