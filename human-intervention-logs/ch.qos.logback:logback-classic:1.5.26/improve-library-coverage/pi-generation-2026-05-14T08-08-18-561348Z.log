ort ch.qos.logback.classic.util.LogbackMDCAdapter;\nimport ch.qos.logback.core.AppenderBase;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RemoteAppenderStreamClientTest {\n\n  private static final int SOCKET_TIMEOUT_MILLIS = 5_000;\n\n  @Test\n  void serverSocketReceiverDispatchesSerializedRemoteEvent() throws Exception {\n    LoggerContext loggerContext = new LoggerContext();\n    loggerContext.setName(\"remote-appender-stream-client-test\");\n    loggerContext.setMDCAdapter(new LogbackMDCAdapter());\n\n    CapturingAppender appender = new CapturingAppender();\n    CapturingServerSocketReceiver receiver = new CapturingServerSocketReceiver();\n    try {\n      Logger remoteLogger = loggerContext.getLogger(\"org.graalvm.logback.RemoteAppenderStreamClientTest.remote\");\n      remoteLogger.setAdditive(false);\n      remoteLogger.setLevel(Level.INFO);\n      appender.setContext(loggerContext);\n      appender.start();\n      remoteLogger.addAppender(appender);\n\n      receiver.setContext(loggerContext);\n      receiver.setAddress(InetAddress.getLoopbackAddress().getHostAddress());\n      receiver.setPort(0);\n      receiver.start();\n\n      try (Socket socket = new Socket()) {\n        socket.connect(receiver.getSocketAddress(), SOCKET_TIMEOUT_MILLIS);\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(socket.getOutputStream())) {\n          outputStream.writeObject(createLoggingEvent(remoteLogger, \"message from remote appender stream client\"));\n          outputStream.flush();\n        }\n      }\n\n      ILoggingEvent receivedEvent = appender.awaitEvent();\n      assertThat(receivedEvent.getFormattedMessage()).isEqualTo(\"message from remote appender stream client\");\n    } finally {\n      receiver.stop();\n      appender.stop();\n      loggerContext.stop();\n    }\n  }\n\n  private static LoggingEventVO createLoggingEvent(Logger logger, String message) {\n    LoggingEvent loggingEvent = new LoggingEvent(RemoteAppenderStreamClientTest.class.getName(), logger, Level.INFO,\n        message, null, null);\n    return LoggingEventVO.build(loggingEvent);\n  }\n\n  private static final class CapturingServerSocketReceiver extends ServerSocketReceiver {\n\n    private final CapturingServerSocketFactory serverSocketFactory = new CapturingServerSocketFactory();\n\n    @Override\n    protected ServerSocketFactory getServerSocketFactory() {\n      return serverSocketFactory;\n    }\n\n    java.net.SocketAddress getSocketAddress() {\n      return serverSocketFactory.getSocketAddress();\n    }\n  }\n\n  private static final class CapturingServerSocketFactory extends ServerSocketFactory {\n\n    private final ServerSocketFactory delegate = ServerSocketFactory.getDefault();\n    private final AtomicReference<ServerSocket> serverSocketReference = new AtomicReference<>();\n\n    @Override\n    public ServerSocket createServerSocket(int port) throws java.io.IOException {\n      return capture(delegate.createServerSocket(port));\n    }\n\n    @Override\n    public ServerSocket createServerSocket(int port, int backlog) throws java.io.IOException {\n      return capture(delegate.createServerSocket(port, backlog));\n    }\n\n    @Override\n    public ServerSocket createServerSocket(int port, int backlog, InetAddress ifAddress) throws java.io.IOException {\n      return capture(delegate.createServerSocket(port, backlog, ifAddress));\n    }\n\n    java.net.SocketAddress getSocketAddress() {\n      ServerSocket serverSocket = serverSocketReference.get();\n      assertThat(serverSocket).isNotNull();\n      return serverSocket.getLocalSocketAddress();\n    }\n\n    private ServerSocket capture(ServerSocket serverSocket) {\n      serverSocketReference.set(serverSocket);\n      return serverSocket;\n    }\n  }\n\n  private static final class CapturingAppender extends AppenderBase<ILoggingEvent> {\n\n    private final CountDownLatch eventReceived = new CountDownLatch(1);\n    private final AtomicReference<ILoggingEvent> eventReference = new AtomicReference<>();\n\n    @Override\n    protected void append(ILoggingEvent eventObject) {\n      eventReference.set(eventObject);\n      eventReceived.countDown();\n    }\n\n    ILoggingEvent awaitEvent() throws InterruptedException {\n      assertThat(eventReceived.await(SOCKET_TIMEOUT_MILLIS, TimeUnit.MILLISECONDS)).isTrue();\n      return eventReference.get();\n    }\n  }\n}\n"}, "partialJson": "{\"path\":\"tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/RemoteAppenderStreamClientTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org.graalvm.logback;\\n\\nimport java.io.ObjectOutputStream;\\nimport java.net.InetAddress;\\nimport java.net.ServerSocket;\\nimport java.net.Socket;\\nimport java.util.concurrent.CountDownLatch;\\nimport java.util.concurrent.TimeUnit;\\nimport java.util.concurrent.atomic.AtomicReference;\\n\\nimport javax.net.ServerSocketFactory;\\n\\nimport ch.qos.logback.classic.Level;\\nimport ch.qos.logback.classic.Logger;\\nimport ch.qos.logback.classic.LoggerContext;\\nimport ch.qos.logback.classic.net.server.ServerSocketReceiver;\\nimport ch.qos.logback.classic.spi.ILoggingEvent;\\nimport ch.qos.logback.classic.spi.LoggingEvent;\\nimport ch.qos.logback.classic.spi.LoggingEventVO;\\nimport ch.qos.logback.classic.util.LogbackMDCAdapter;\\nimport ch.qos.logback.core.AppenderBase;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class RemoteAppenderStreamClientTest {\\n\\n  private static final int SOCKET_TIMEOUT_MILLIS = 5_000;\\n\\n  @Test\\n  void serverSocketReceiverDispatchesSerializedRemoteEvent() throws Exception {\\n    LoggerContext loggerContext = new LoggerContext();\\n    loggerContext.setName(\\\"remote-appender-stream-client-test\\\");\\n    loggerContext.setMDCAdapter(new LogbackMDCAdapter());\\n\\n    CapturingAppender appender = new CapturingAppender();\\n    CapturingServerSocketReceiver receiver = new CapturingServerSocketReceiver();\\n    try {\\n      Logger remoteLogger = loggerContext.getLogger(\\\"org.graalvm.logback.RemoteAppenderStreamClientTest.remote\\\");\\n      remoteLogger.setAdditive(false);\\n      remoteLogger.setLevel(Level.INFO);\\n      appender.setContext(loggerContext);\\n      appender.start();\\n      remoteLogger.addAppender(appender);\\n\\n      receiver.setContext(loggerContext);\\n      receiver.setAddress(InetAddress.getLoopbackAddress().getHostAddress());\\n      receiver.setPort(0);\\n      receiver.start();\\n\\n      try (Socket socket = new Socket()) {\\n        socket.connect(receiver.getSocketAddress(), SOCKET_TIMEOUT_MILLIS);\\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(socket.getOutputStream())) {\\n          outputStream.writeObject(createLoggingEvent(remoteLogger, \\\"message from remote appender stream client\\\"));\\n          outputStream.flush();\\n        }\\n      }\\n\\n      ILoggingEvent receivedEvent = appender.awaitEvent();\\n      assertThat(receivedEvent.getFormattedMessage()).isEqualTo(\\\"message from remote appender stream client\\\");\\n    } finally {\\n      receiver.stop();\\n      appender.stop();\\n      loggerContext.stop();\\n    }\\n  }\\n\\n  private static LoggingEventVO createLoggingEvent(Logger logger, String message) {\\n    LoggingEvent loggingEvent = new LoggingEvent(RemoteAppenderStreamClientTest.class.getName(), logger, Level.INFO,\\n        message, null, null);\\n    return LoggingEventVO.build(loggingEvent);\\n  }\\n\\n  private static final class CapturingServerSocketReceiver extends ServerSocketReceiver {\\n\\n    private final CapturingServerSocketFactory serverSocketFactory = new CapturingServerSocketFactory();\\n\\n    @Override\\n    protected ServerSocketFactory getServerSocketFactory() {\\n      return serverSocketFactory;\\n    }\\n\\n    java.net.SocketAddress getSocketAddress() {\\n      return serverSocketFactory.getSocketAddress();\\n    }\\n  }\\n\\n  private static final class CapturingServerSocketFactory extends ServerSocketFactory {\\n\\n    private final ServerSocketFactory delegate = ServerSocketFactory.getDefault();\\n    private final AtomicReference<ServerSocket> serverSocketReference = new AtomicReference<>();\\n\\n    @Override\\n    public ServerSocket createServerSocket(int port) throws java.io.IOException {\\n      return capture(delegate.createServerSocket(port));\\n    }\\n\\n    @Override\\n    public ServerSocket createServerSocket(int port, int backlog) throws java.io.IOException {\\n      return capture(delegate.createServerSocket(port, backlog));\\n    }\\n\\n    @Override\\n    public ServerSocket createServerSocket(int port, int backlog, InetAddress ifAddress) throws java.io.IOException {\\n      return capture(delegate.createServerSocket(port, backlog, ifAddress));\\n    }\\n\\n    java.net.SocketAddress getSocketAddress() {\\n      ServerSocket serverSocket = serverSocketReference.get();\\n      assertThat(serverSocket).isNotNull();\\n      return serverSocket.getLocalSocketAddress();\\n    }\\n\\n    private ServerSocket capture(ServerSocket serverSocket) {\\n      serverSocketReference.set(serverSocket);\\n      return serverSocket;\\n    }\\n  }\\n\\n  private static final class CapturingAppender extends AppenderBase<ILoggingEvent> {\\n\\n    private final CountDownLatch eventReceived = new CountDownLatch(1);\\n    private final AtomicReference<ILoggingEvent> eventReference = new AtomicReference<>();\\n\\n    @Override\\n    protected void append(ILoggingEvent eventObject) {\\n      eventReference.set(eventObject);\\n      eventReceived.countDown();\\n    }\\n\\n    ILoggingEvent awaitEvent() throws InterruptedException {\\n      assertThat(eventReceived.await(SOCKET_TIMEOUT_MILLIS, TimeUnit.MILLISECONDS)).isTrue();\\n      return eventReference.get();\\n    }\\n  }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 4468, "output": 2319, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 30851, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778746033414, "responseId": "resp_05bbd23cbd80a707016a0582b23b288196ad5908d1a7b7a723"}}
[tool-exec] start id=call_6YClpdVuLEVwCUIbxZjsk1ve|fc_05bbd23cbd80a707016a0582c6fe6c8196a207bc20616764a7 name=write args={"path": "tests/src/ch.qos.logback/logback-classic/1.5.26/src/test/java/org/graalvm/logback/RemoteAppenderStreamClientTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.graalvm.logback;\n\nimport java.io.ObjectOutputStream;\nimport java.net.InetAddress;\nimport java.net.ServerSocket;\nimport java.net.Socket;\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport javax.net.ServerSocketFactory;\n\nimport ch.qos.logback.classic.Level;\nimport ch.qos.logback.classic.Logger;\nimport ch.qos.logback.classic.LoggerContext;\nimport ch.qos.logback.classic.net.server.ServerSocketReceiver;\nimport ch.qos.logback.classic.spi.ILoggingEvent;\nimport ch.qos.logback.classic.spi.LoggingEvent;\nimport ch.qos.logback.classic.spi.LoggingEventVO;\nimport ch.qos.logback.classic.util.LogbackMDCAdapter;\nimport ch.qos.logback.core.AppenderBase;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RemoteAppenderStreamClientTest {\n\n  private static final int SOCKET_TIMEOUT_MILLIS = 5_000;\n\n  @Test\n  void serverSocketReceiverDispatchesSerializedRemoteEvent() throws Exception {\n    LoggerContext loggerContext = new LoggerContext();\n    loggerContext.setName(\"remote-appender-stream-client-test\");\n    loggerContext.setMDCAdapter(new LogbackMDCAdapter());\n\n    CapturingAppender appender = new CapturingAppender();\n    CapturingServerSocketReceiver receiver = new CapturingServerSocketReceiver();\n    try {\n      Logger remoteLogger = loggerContext.getLogger(\"org.graalvm.logback.RemoteAppenderStreamClientTest.remote\");\n      remoteLogger.setAdditive(false);\n      remoteLogger.setLevel(Level.INFO);\n      appender.setContext(loggerContext);\n      appender.start();\n      remoteLogger.addAppender(appender);\n\n      receiver.setContext(loggerContext);\n      receiver.setAddress(InetAddress.getLoopbackAddress().getHostAddress());\n      receiver.setPort(0);\n      receiver.start();\n\n      try (Socket socket = new Socket()) {\n        socket.connect(receiver.getSocketAddress(), SOCKET_TIMEOUT_MILLIS);\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(socket.getOutputStream())) {\n          outputStream.writeObject(createLoggingEvent(remoteLogger, \"message from remote appender stream client\"));\n          outputStream.flush();\n        }\n      }\n\n      ILoggingEvent receivedEvent = appender.awaitEvent();\n      assertThat(receivedEvent.getFormattedMessage()).isEqualTo(\"message from remote appender stream client\");\n    } finally {\n      receiver.stop();\n      appender.stop();\n      loggerContext.stop();\n    }\n  }\n\n  private static LoggingEventVO createLoggingEvent(Logger logger, String message) {\n    LoggingEvent loggingEvent = new LoggingEvent(RemoteAppenderStreamClientTest.class.getName(), logger, Level.INFO,\n        message, null, null);\n    return LoggingEventVO.build(loggingEvent);\n  }\n\n  private static final class CapturingServerSocketReceiver extends ServerSocketReceiver {\n\n    private final CapturingServerSocketFactory serverSocketFactory = new CapturingServerSocketFactory();\n\n    @Override\n    protected ServerSocketFactory getServerSocketFactory() {\n      return serverSocketFactory;\n    }\n\n    java.net.SocketAddress getSocketAddress() {\n      return serverSocketFactory.getSocketAddress();\n    }\n  }\n\n  private static final class CapturingServerSocketFactory extends ServerSocketFactory {\n\n    private final ServerSocketFactory delegate = ServerSocketFactory.getDefault();\n    private final AtomicReference<ServerSocket> serverSocketReference = new AtomicReference<>();\n\n    @Override\n    public ServerSocket createServerSocket(int port) throws java.io.IOException {\n      return capture(delegate.createServerSocket(port));\n    }\n\n    @Override\n    public ServerSocket createServerSocket(int port, int backlog) throws java.io.IOException {\n      return capture(delegate.createServerSocket(port, backlog));\n    }\n\n    @Override\n    public ServerSocket createServerSocket(int port, int backlog, InetAddress ifAddress) throws java.io.IOException {\n      return capture(delegate.createServerSocket(port, backlog, ifAddress));\n    }\n\n    java.net.SocketAddress getSocketAddress() {\n      ServerSocket serverSocket = serverSocketReference.get();\n      assertThat(serverSocket).isNotNull();\n      return serverSocket.getLocalSocketAddress();\n    }\n\n    private ServerSocket capture(ServerSocket serverSocket) {\n      serverSocketReference.set(serverSocket);\n      return serverSocket;\n    }\n  }\n\n  private static final class CapturingAppender extends AppenderBase<ILoggingEvent> {\n\n    private final CountDownLatch eventReceived = new CountDownLatch(1);\n    private final AtomicReference<ILoggingEvent> eventReference = new AtomicReference<>();\n\n    @Override\n    protected void append(ILoggingEvent eventObject) {\n      eventReference.set(eventObject);\n      eventReceived.countDown();\n    }\n\n    ILoggingEvent awaitEvent() throws InterruptedException {\n      assertThat(eventReceived.await(SOCKET_TIMEOUT_MILLIS, TimeUnit.MILLISECONDS)).isTrue();\n      return eventReference.get();\n    }\n  }\n}\n"}
