       * Gets the listener queue depth.
       * <p>
       * This represents the number of connected clients whose connections have not
       * yet been accepted.
       * 
       * @return queue depth
       * @see java.net.ServerSocket
       */
      public int getBacklog() {
          return backlog;
      }
  
      /**
