fromJar, or - for none\")\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:60:    public void setAgentAllowedPackages(String agentAllowedPackages) {\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:61:        this.agentAllowedPackages = agentAllowedPackages;\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:67:        return agentAllowedPackages;\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:92:        if (agentAllowedPackages == null || agentAllowedPackages.isBlank() || agentAllowedPackages.equals(\"-\")) {\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:96:        String normalizedValue = agentAllowedPackages.trim();\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:101:        List<String> packageList = Arrays.stream(agentAllowedPackages.split(\",\"))\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:106:            throw new IllegalArgumentException(\"--agentAllowedPackages=fromJar must be used on its own\");\ntests/tck-build-logic/src/main/java/org/graalvm/internal/tck/GenerateMetadataTask.java:112:        return agentAllowedPackages != null && agentAllowedPackages.trim().equals(FROM_JAR);\ntests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:741:// gradle generateMetadata -Pcoordinates=<maven-coordinates> [or --coordinates=<maven-coordinates>] --agentAllowedPackages=<comma-separated list of packages|fromJar|->\ntests/tck-build-logic/src/main/groovy/org.graalvm.internal.tck-harness.gradle:742:tasks.register(\"generateMetadata\", GenerateMetadataTask.class) { task ->\n","exit_code":0,"status":"completed"}}
