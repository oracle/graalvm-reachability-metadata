{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,220p' tests/src/cglib/cglib/3.3.0/src/test/java/cglib/cglib/MethodProxyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MethodProxyTest {\n    @Test\n    void findsMethodProxyForEnhancedMethod() {\n        LookupResult result = invokeLookupProxy();\n\n        assertThat(result.isUnsupportedNativeImageDynamicClassLoading() || result.message() != null).isTrue();\n        if (result.message() != null) {\n            assertThat(result.message()).isEqualTo(\"found base Ada\");\n            assertThat(result.foundProxy()).isNotNull();\n            assertThat(result.foundProxy().getSignature().getName()).isEqualTo(\"message\");\n        }\n    }\n\n    private static LookupResult invokeLookupProxy() {\n        try {\n            LookupInterceptor interceptor = new LookupInterceptor();\n            Enhancer enhancer = new Enhancer();\n            enhancer.setSuperclass(MessageService.class);\n            enhancer.setCallback(interceptor);\n            MessageService service = (MessageService) enhancer.create();\n            return LookupResult.invoked(service.message(\"Ada\"), interceptor.foundProxy());\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return LookupResult.unsupportedNativeImageDynamicClassLoading();\n        } catch (RuntimeException exception) {\n            if (hasUnsupportedNativeImageDynamicClassLoadingError(exception)) {\n                return LookupResult.unsupportedNativeImageDynamicClassLoading();\n            }\n            throw exception;\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedNativeImageDynamicClassLoadingError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class MessageService {\n        public String message(String name) {\n            return \"base \" + name;\n        }\n    }\n\n    private static final class LookupInterceptor implements MethodInterceptor {\n        private MethodProxy foundProxy;\n\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) throws Throwable {\n            if (\"message\".equals(method.getName())) {\n                foundProxy = MethodProxy.find(object.getClass(), proxy.getSignature());\n                return \"found \" + foundProxy.invokeSuper(object, arguments);\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n\n        private MethodProxy foundProxy() {\n            return foundProxy;\n        }\n    }\n\n    private static final class LookupResult {\n        private final String message;\n        private final MethodProxy foundProxy;\n        private final boolean unsupportedNativeImageDynamicClassLoading;\n\n        private LookupResult(\n                String message,\n                MethodProxy foundProxy,\n                boolean unsupportedNativeImageDynamicClassLoading\n        ) {\n            this.message = message;\n            this.foundProxy = foundProxy;\n            this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;\n        }\n\n        private static LookupResult invoked(String message, MethodProxy foundProxy) {\n            return new LookupResult(message, foundProxy, false);\n        }\n\n        private static LookupResult unsupportedNativeImageDynamicClassLoading() {\n            return new LookupResult(null, null, true);\n        }\n\n        private String message() {\n            return message;\n        }\n\n        private MethodProxy foundProxy() {\n            return foundProxy;\n        }\n\n        private boolean isUnsupportedNativeImageDynamicClassLoading() {\n            return unsupportedNativeImageDynamicClassLoading;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
