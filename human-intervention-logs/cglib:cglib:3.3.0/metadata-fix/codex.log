{"type":"item.completed","item":{"id":"item_225","type":"command_execution","command":"/usr/bin/zsh -lc \"sed -n '1,220p' /tmp/cglib-probe/CglibProbe.java\"","aggregated_output":"package cglibprobe;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\n\npublic final class CglibProbe {\n    private CglibProbe() {\n    }\n\n    public static void main(String[] args) throws Throwable {\n        exerciseEnhancer();\n        exerciseMethodProxy();\n    }\n\n    private static void exerciseEnhancer() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(GreetingTarget.class);\n        enhancer.setCallback(new GreetingInterceptor());\n        GreetingTarget proxy = (GreetingTarget) enhancer.create();\n        proxy.greet(\"Ada\");\n    }\n\n    private static void exerciseMethodProxy() {\n        LookupInterceptor interceptor = new LookupInterceptor();\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(MessageTarget.class);\n        enhancer.setCallback(interceptor);\n        MessageTarget service = (MessageTarget) enhancer.create();\n        service.message(\"Ada\");\n        if (interceptor.foundProxy == null) {\n            throw new IllegalStateException(\"MethodProxy was not resolved\");\n        }\n    }\n\n    private static final class GreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(Object object, Method method, Object[] arguments, MethodProxy proxy) throws Throwable {\n            if (\"greet\".equals(method.getName())) {\n                return \"intercepted \" + proxy.invokeSuper(object, arguments);\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n    }\n\n    private static final class LookupInterceptor implements MethodInterceptor {\n        private MethodProxy foundProxy;\n\n        @Override\n        public Object intercept(Object object, Method method, Object[] arguments, MethodProxy proxy) throws Throwable {\n            if (\"message\".equals(method.getName())) {\n                foundProxy = MethodProxy.find(object.getClass(), proxy.getSignature());\n                return \"found \" + foundProxy.invokeSuper(object, arguments);\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
