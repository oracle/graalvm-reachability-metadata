 static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ReflectUtilsTest {\\n    private static final String GENERATED_CLASS_NAME = \\\"cglib.cglib.ReflectUtilsGenerated\\\";\\n    private static final String GENERATED_CLASS_INTERNAL_NAME = GENERATED_CLASS_NAME.replace('.', '/');\\n\\n    @Test\\n    void findsConstructorsAndMethodsFromStringDescriptors() {\\n        Constructor<?> bytesConstructor = ReflectUtils.findConstructor(\\\"java.lang.String(byte[])\\\");\\n        Method substringMethod = ReflectUtils.findMethod(\\\"String.substring(int)\\\");\\n\\n        assertThat(bytesConstructor.getDeclaringClass()).isEqualTo(String.class);\\n        assertThat(bytesConstructor.getParameterTypes()).containsExactly(byte[].class);\\n        assertThat(substringMethod.getDeclaringClass()).isEqualTo(String.class);\\n        assertThat(substringMethod.getParameterTypes()).containsExactly(int.class);\\n    }\\n\\n    @Test\\n    void createsInstancesFromDeclaredConstructors() {\\n        Constructor<?> constructor = ReflectUtils.getConstructor(ConstructedValue.class, new Class[] { String.class });\\n\\n        ConstructedValue value = (ConstructedValue) ReflectUtils.newInstance(constructor, new Object[] { \\\"created\\\" });\\n\\n        assertThat(value.value()).isEqualTo(\\\"created\\\");\\n    }\\n\\n    @Test\\n    void findsDeclaredMethodsAcrossTheClassHierarchy() throws NoSuchMethodException {\\n        Method method = ReflectUtils.findDeclaredMethod(MethodChild.class, \\\"describe\\\", new Class[] { String.class });\\n\\n        assertThat(method.getDeclaringClass()).isEqualTo(MethodParent.class);\\n        assertThat(method.getName()).isEqualTo(\\\"describe\\\");\\n    }\\n\\n    @Test\\n    void collectsDeclaredMethodsFromClassesAndInterfaces() {\\n        List<Method> methods = ReflectUtils.addAllMethods(MethodChild.class, new ArrayList<>());\\n\\n        assertThat(methods)\\n                .extracting(Method::getName)\\n                .contains(\\\"childOnly\\\", \\\"describe\\\", \\\"fromInterface\\\", \\\"toString\\\");\\n    }\\n\\n    @Test\\n    void findsTheSingleMethodDeclaredByAnInterface() {\\n        Method method = ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);\\n\\n        assertThat(method.getName()).isEqualTo(\\\"newInstance\\\");\\n        assertThat(method.getReturnType()).isEqualTo(ConstructedValue.class);\\n    }\\n\\n    @Test\\n    void definesClassAndInitializesIt() throws Exception {\\n        try {\\n            Class<?> generatedClass = ReflectUtils.defineClass(\\n                    GENERATED_CLASS_NAME,\\n                    createGeneratedClassBytes(),\\n                    ReflectUtilsTest.class.getClassLoader());\\n\\n            assertThat(generatedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);\\n        } catch (InvocationTargetException exception) {\\n            rethrowUnlessUnsupportedFeatureError(exception.getCause());\\n        } catch (Error error) {\\n            rethrowUnlessUnsupportedFeatureError(error);\\n        }\\n    }\\n\\n    private static byte[] createGeneratedClassBytes() {\\n        ClassWriter classWriter = new ClassWriter(0);\\n        classWriter.visit(\\n                Opcodes.V1_8,\\n                Opcodes.ACC_PUBLIC,\\n                GENERATED_CLASS_INTERNAL_NAME,\\n                null,\\n                \\\"java/lang/Object\\\",\\n                null);\\n        MethodVisitor constructor = classWriter.visitMethod(Opcodes.ACC_PUBLIC, \\\"<init>\\\", \\\"()V\\\", null, null);\\n        constructor.visitCode();\\n        constructor.visitVarInsn(Opcodes.ALOAD, 0);\\n        constructor.visitMethodInsn(Opcodes.INVOKESPECIAL, \\\"java/lang/Object\\\", \\\"<init>\\\", \\\"()V\\\", false);\\n        constructor.visitInsn(Opcodes.RETURN);\\n        constructor.visitMaxs(1, 1);\\n        constructor.visitEnd();\\n        classWriter.visitEnd();\\n        return classWriter.toByteArray();\\n    }\\n\\n    private static void rethrowUnless