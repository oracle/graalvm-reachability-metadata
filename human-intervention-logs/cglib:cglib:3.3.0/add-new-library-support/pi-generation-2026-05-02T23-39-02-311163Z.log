tUtils.newInstance(\n                ConstructorTarget.class,\n                new Class[]{String.class},\n                new Object[]{\"created by cglib\"}\n        );\n\n        assertThat(target.message()).isEqualTo(\"created by cglib\");\n    }\n\n    @Test\n    void declaredMethodLookupWalksSuperclasses() throws NoSuchMethodException {\n        Method method = ReflectUtils.findDeclaredMethod(\n                ChildMethodContainer.class,\n                \"inheritedMessage\",\n                new Class[]{String.class}\n        );\n\n        assertThat(method.getDeclaringClass()).isEqualTo(ParentMethodContainer.class);\n        assertThat(method.getName()).isEqualTo(\"inheritedMessage\");\n    }\n\n    @Test\n    void methodCollectionIncludesClassHierarchyAndSingleInterfaceMethod() {\n        List<Method> methods = ReflectUtils.addAllMethods(ChildMethodContainer.class, new ArrayList<Method>());\n        Method interfaceMethod = ReflectUtils.findInterfaceMethod(SingleOperation.class);\n\n        assertThat(methods).extracting(Method::getName).contains(\"localMessage\", \"inheritedMessage\");\n        assertThat(interfaceMethod.getName()).isEqualTo(\"apply\");\n    }\n\n    @Test\n    void defineClassDefinesAndInitializesGeneratedBytecode() throws Exception {\n        Class<?> generatedClass = defineGeneratedClass();\n\n        assertThat(generatedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);\n        assertThat(generatedClass.getClassLoader()).isInstanceOf(DefiningClassLoader.class);\n    }\n\n    private static Class<?> defineGeneratedClass() throws Exception {\n        DefiningClassLoader loader = new DefiningClassLoader(ReflectUtilsTest.class.getClassLoader());\n        try {\n            return ReflectUtils.defineClass(GENERATED_CLASS_NAME, generatedClassBytes(), loader);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return Object.class;\n        } catch (Exception exception) {\n            Throwable cause = exception.getCause();\n            if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return Object.class;\n            }\n            throw exception;\n        }\n    }\n\n    private static byte[] generatedClassBytes() throws IOException {\n        String internalName = GENERATED_CLASS_NAME.replace('.', '/');\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(bytes);\n        output.writeInt(0xCAFEBABE);\n        output.writeShort(0);\n        output.writeShort(52);\n        output.writeShort(10);\n        output.writeByte(10);\n        output.writeShort(2);\n        output.writeShort(3);\n        output.writeByte(7);\n        output.writeShort(4);\n        output.writeByte(12);\n        output.writeShort(5);\n        output.writeShort(6);\n        output.writeByte(1);\n        output.writeUTF(\"java/lang/Object\");\n        output.writeByte(1);\n        output.writeUTF(\"<init>\");\n        output.writeByte(1);\n        output.writeUTF(\"()V\");\n        output.writeByte(7);\n        output.writeShort(8);\n        output.writeByte(1);\n        output.writeUTF(internalName);\n        output.writeByte(1);\n        output.writeUTF(\"Code\");\n        output.writeShort(0x0021);\n        output.writeShort(7);\n        output.writeShort(2);\n        output.writeShort(0);\n        output.writeShort(0);\n        output.writeShort(1);\n        output.writeShort(0x0001);\n        output.writeShort(5);\n        output.writeShort(6);\n        output.writeShort(1);\n        output.writeShort(9);\n        output.writeInt(17);\n        output.writeShort(1);\n        output.writeShort(1);\n        output.writeInt(5);\n        output.writeByte(0x2A);\n        output.writeByte(0xB7);\n        output.writeShort(1);\n        output.writeByte(0xB1);\n        output.writeShort(0);\n        output.writeShort(0);\n        output.writeShort(0);\n        output.flush();\n        return bytes.toByteArray();\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static final class ConstructorTarget {\n        private final String message;\n\n        public ConstructorTarget(String message) {\n            this.message = message;\n        }\n\n        public String message() {\n            return message;\n        }\n    }\n\n    public static class ParentMethodContainer {\n        public String inheritedMessage(String value) {\n            return \"parent \" + value;\n        }\n    }\n\n    public static final class ChildMethodContainer extends ParentMethodContainer {\n        public String localMessage() {\n            return \"child\";\n        }\n    }\n\n    public interface SingleOperation {\n        String apply(String value);\n    }\n\n    private static final class DefiningClassLoader extends ClassLoader {\n        private DefiningClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1287, "output": 2059, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 34066, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777765023868, "responseId": "resp_00e5e720f1c4bb700169f68aa098a8819d94ade40a8bd55de6"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2b9Yl621xYSNcFAPuLjc0nZL|fc_00e5e720f1c4bb700169f68aa6d508819da0c519f843a9e102", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6687 bytes to tests/src/cglib/cglib/3.3.0/src/test/java/cglib/cglib/ReflectUtilsTest.java"}], "isError": false, "timestamp": 1777765040148}]}
