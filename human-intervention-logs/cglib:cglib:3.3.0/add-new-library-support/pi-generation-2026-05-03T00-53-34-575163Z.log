[tool-call] delta {"path":"tests/src/cglib/cglib/3.3.0/src/test/java/cglib/cglib/AddDelegateTransformerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport net.sf.cglib.transform.impl.AddDelegateTransformer;\nimport org.junit.jupiter.api.Test;\nimport org.objectweb.asm.ClassReader;\nimport org.objectweb.asm.ClassVisitor;\nimport org.objectweb.asm.ClassWriter;\nimport org.objectweb.asm.MethodVisitor;\nimport org.objectweb.asm.Opcodes;\nimport org.objectweb.asm.Type;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AddDelegateTransformerTest {\n    private static final String GENERATED_CLASS_NAME = \"cglib.cglib.AddDelegateTransformerGeneratedType\";\n\n    @Test\n    void addsDelegateInterfaceAndMethodsToVisitedClass() {\n        ClassWriter writer = new ClassWriter(ClassWriter.COMPUTE_MAXS);\n        AddDelegateTransformer transformer = new AddDelegateTransformer(\n                new Class[]{DelegatedOperations.class},\n                DelegatedOperationsDelegate.class\n        );\n        transformer.setTarget(writer);\n\n        transformer.begin_class(\n                Opcodes.V1_8,\n                Opcodes.ACC_PUBLIC,\n                GENERATED_CLASS_NAME,\n                Type.getType(Object.class),\n                new Type[]{Type.getType(ExistingMarker.class)},\n                \"AddDelegateTransformerGeneratedType.java\"\n        );\n        transformer.end_class();\n\n        GeneratedClassDescription description = GeneratedClassDescription.from(writer.toByteArray());\n\n        assertThat(description.interfaces()).containsExactlyInAnyOrder(\n                Type.getInternalName(ExistingMarker.class),\n                Type.getInternalName(DelegatedOperations.class)\n        );\n        assertThat(description.methodDescriptors()).contains(\n                \"message(Ljava/lang/String;)Ljava/lang/String;\",\n                \"length(Ljava/lang/String;)I\"\n        );\n    }\n\n    public interface ExistingMarker {\n    }\n\n    public interface DelegatedOperations {\n        String message(String value);\n\n        int length(String value);\n    }\n\n    public static final class DelegatedOperationsDelegate {\n        private final Object owner;\n\n        public DelegatedOperationsDelegate(Object owner) {\n            this.owner = owner;\n        }\n\n        public String message(String value) {\n            return owner.getClass().getSimpleName() + \":\" + value;\n        }\n\n        public int length(String value) {\n            return value.length();\n        }\n    }\n\n    private static final class GeneratedClassDescription {\n        private final List<String> interfaces;\n        private final List<String> methodDescriptors;\n\n        private GeneratedClassDescription(List<String> interfaces, List<String> methodDescriptors) {\n            this.interfaces = interfaces;\n            this.methodDescriptors = methodDescriptors;\n        }\n\n        private static GeneratedClassDescription from(byte[] bytecode) {\n            List<String> interfaces = new ArrayList<>();\n            List<String> methodDescriptors = new ArrayList<>();\n            ClassReader reader = new ClassReader(bytecode);\n            reader.accept(new ClassVisitor(Opcodes.ASM7) {\n                @Override\n                public void visit(\n                        int version,\n                        int access,\n                        String name,\n                        String signature,\n                        String superName,\n                        String[] visitedInterfaces\n                ) {\n                    for (String visitedInterface : visitedInterfaces) {\n                        interfaces.add(visitedInterface);\n                    }\n                }\n\n                @Override\n                public MethodVisitor visitMethod(\n                        int access,\n                        String name,\n                        String descriptor,\n                        String signature,\n                        String[] exceptions\n                ) {\n                    methodDescriptors.add(name + descriptor);\n                    return super.visitMethod(access, name, descriptor, signature, exceptions);\n                }\n            }, 0);\n            return new GeneratedClassDescription(interfaces, methodDescriptors);\n        }\n\n        private List<String> interfaces() {\n            return interfaces;\n        }\n\n        private List<String> methodDescriptors() {\n            return methodDescriptors;\n        }\n    }\n}\n"}
