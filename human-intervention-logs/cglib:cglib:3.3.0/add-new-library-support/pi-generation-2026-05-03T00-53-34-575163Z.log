  package cglib.cglib;
  
  import java.lang.reflect.Method;
  
  import net.sf.cglib.proxy.Callback;
  import net.sf.cglib.proxy.Enhancer;
  import net.sf.cglib.proxy.Factory;
  import net.sf.cglib.proxy.MethodInterceptor;
  import net.sf.cglib.proxy.MethodProxy;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class EnhancerTest {
      @Test
      void createsCachedFactoryProxyAndRegistersCallbacks() {
          ProxyCreationResult result = createGreetingProxy();
  
          assertThat(result.isUnsupportedNativeImageDynamicClassLoading() || result.proxy() != null).isTrue();
          if (result.proxy() != null) {
              GreetingService proxy = result.proxy();
              Class<?> proxyType = proxy.getClass();
              Callback replacementCallback = new ReplacementGreetingInterceptor();
  
              assertThat(proxy.greet("Ada")).isEqualTo("intercepted hello Ada");
              assertThat(Enhancer.isEnhanced(proxyType)).isTrue();
  
              Enhancer.registerCallbacks(proxyType, new Callback[]{replacementCallback});
              Enhancer.registerStaticCallbacks(proxyType, new Callback[]{replacementCallback});
              Enhancer.registerCallbacks(proxyType, null);
              Enhancer.registerStaticCallbacks(proxyType, null);
  
              GreetingService secondProxy = (GreetingService) ((Factory) proxy).newInstance(
                      new Callback[]{replacementCallback}
              );
  
              assertThat(secondProxy.greet("Grace")).isEqualTo("registered Grace");
          }
      }
  
      private static ProxyCreationResult createGreetingProxy() {
          try {
              Enhancer enhancer = new Enhancer();
              enhancer.setSuperclass(GreetingService.class);
              enhancer.setCallback(new PrefixingGreetingInterceptor());
              return ProxyCreationResult.created((GreetingService) enhancer.create());
          } catch (Error error) {
              rethrowIfNotNativeImageDynamicClassLoadingError(error);
              return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();
          } catch (RuntimeException exception) {
              if (hasUnsupportedNativeImageDynamicClassLoadingError(exception)) {
                  return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();
              }
              throw exception;
          }
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {
          if (!hasUnsupportedNativeImageDynamicClassLoadingError(error)) {
              throw error;
          }
      }
  
      private static boolean hasUnsupportedNativeImageDynamicClassLoadingError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      public static class GreetingService {
          public String greet(String name) {
              return "hello " + name;
          }
      }
  
      private static final class PrefixingGreetingInterceptor implements MethodInterceptor {
          @Override
          public Object intercept(
                  Object object,
                  Method method,
                  Object[] arguments,
                  MethodProxy proxy
          ) throws Throwable {
              if ("greet".equals(method.getName())) {
                  return "intercepted " + proxy.invokeSuper(object, arguments);
              }
              return proxy.invokeSuper(object, arguments);
          }
      }
  
      private static final class ReplacementGreetingInterceptor implements MethodInterceptor {
          @Override
          public Object intercept(
                  Object object,
                  Method method,
                  Object[] arguments,
                  MethodProxy proxy
          ) {
              if ("greet".equals(method.getName())) {
                  return "registered " + arguments[0];
              }
              return object.getClass().getName();
          }
      }
  
      private static final class ProxyCreationResult {
          private final GreetingService proxy;
          private final boolean unsupportedNativeImageDynamicClassLoading;
  
          private ProxyCreationResult(GreetingService proxy, boolean unsupportedNativeImageDynamicClassLoading) {
              this.proxy = proxy;
              this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;
          }
  
          private static ProxyCreationResult created(GreetingService proxy) {
              return new ProxyCreationResult(proxy, false);
          }
  
          private static ProxyCreationResult unsupportedNativeImageDynamicClassLoading() {
              return new ProxyCreationResult(null, true);
          }
  
          private GreetingService proxy() {
              return proxy;
          }
  
          private boolean isUnsupportedNativeImageDynamicClassLoading() {
              return unsupportedNativeImageDynamicClassLoading;
          }
      }
  }
