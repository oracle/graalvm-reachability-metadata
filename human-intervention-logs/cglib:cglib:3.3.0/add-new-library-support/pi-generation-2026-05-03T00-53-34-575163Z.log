  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AbstractClassLoaderTest {
      private static final String RELOADED_CLASS_NAME = "cglib.cglib.ReloadedTypeForAbstractClassLoaderFixture";
  
      @Test
      void delegatesRejectedClassNamesToParentLoader() throws ClassNotFoundException {
          ClassLoader parentLoader = AbstractClassLoaderTest.class.getClassLoader();
          TestingClassLoader loader = new TestingClassLoader(parentLoader, parentLoader, className -> false);
  
          Class<?> loadedClass = loader.loadClass(String.class.getName());
  
          assertThat(loadedClass).isSameAs(String.class);
      }
  
      @Test
      void readsAcceptedClassBytesFromConfiguredClassPath() throws IOException, ClassNotFoundException {
          ClassLoader parentLoader = AbstractClassLoaderTest.class.getClassLoader();
          ClassLoader classPath = new ByteArrayClassPath(RELOADED_CLASS_NAME, generatedClassBytes());
          TestingClassLoader loader = new TestingClassLoader(
                  parentLoader,
                  classPath,
                  RELOADED_CLASS_NAME::equals
          );
  
          ClassLoadingResult result = loadReloadedClass(loader);
  
          assertThat(result.isUnsupportedNativeImageDynamicClassLoading()
                  || result.loadedClass() != null).isTrue();
          if (result.loadedClass() != null) {
              Class<?> loadedClass = result.loadedClass();
              assertThat(loadedClass.getName()).isEqualTo(RELOADED_CLASS_NAME);
              assertThat(loadedClass.getClassLoader()).isSameAs(loader);
              assertThat(loader.loadClass(RELOADED_CLASS_NAME)).isSameAs(loadedClass);
          }
      }
  
      private static ClassLoadingResult loadReloadedClass(TestingClassLoader loader) throws ClassNotFoundException {
          try {
              return ClassLoadingResult.loaded(loader.loadClass(RELOADED_CLASS_NAME));
          } catch (Error error) {
              rethrowIfNotNativeImageDynamicClassLoadingError(error);
              return ClassLoadingResult.unsupportedNativeImageDynamicClassLoading();
          }
      }
  
      private static byte[] generatedClassBytes() throws IOException {
          String internalName = RELOADED_CLASS_NAME.replace('.', '/');
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          DataOutputStream output = new DataOutputStream(bytes);
          output.writeInt(0xCAFEBABE);
          output.writeShort(0);
          output.writeShort(52);
          output.writeShort(10);
          output.writeByte(10);
          output.writeShort(2);
          output.writeShort(3);
          output.writeByte(7);
          output.writeShort(4);
          output.writeByte(12);
          output.writeShort(5);
          output.writeShort(6);
          output.writeByte(1);
          output.writeUTF("java/lang/Object");
          output.writeByte(1);
          output.writeUTF("<init>");
          output.writeByte(1);
          output.writeUTF("()V");
          output.writeByte(7);
          output.writeShort(8);
          output.writeByte(1);
          output.writeUTF(internalName);
          output.writeByte(1);
          output.writeUTF("Code");
          output.writeShort(0x0021);
          output.writeShort(7);
          output.writeShort(2);
          output.writeShort(0);
          output.writeShort(0);
          output.writeShort(1);
          output.writeShort(0x0001);
          output.writeShort(5);
          output.writeShort(6);
          output.writeShort(1);
          output.writeShort(9);
          output.writeInt(17);
          output.writeShort(1);
          output.writeShort(1);
          output.writeInt(5);
          output.writeByte(0x2A);
          output.writeByte(0xB7);
          output.writeShort(1);
          output.writeByte(0xB1);
          output.writeShort(0);
          output.writeShort(0);
          output.writeShort(0);
          output.flush();
          return bytes.toByteArray();
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static final class ByteArrayClassPath extends ClassLoader {
          private final String resourceName;
          private final byte[] classBytes;
  
          private ByteArrayClassPath(String className, byte[] classBytes) {
              super(null);
              this.resourceName = className.replace('.', '/') + ".class";
              this.classBytes = classBytes.clone();
          }
  
          @Override
          public InputStream getResourceAsStream(String name) {
              if (resourceName.equals(name)) {
                  return new ByteArrayInputStream(classBytes);
              }
              return super.getResourceAsStream(name);
          }
      }
  
      private static final class TestingClassLoader extends AbstractClassLoader {
          private TestingClassLoader(ClassLoader parent, ClassLoader classPath, ClassFilter filter) {
              super(parent, classPath, filter);
          }
      }
  
      private static final class ClassLoadingResult {
          private final Class<?> loadedClass;
          private final boolean unsupportedNativeImageDynamicClassLoading;
  
          private ClassLoadingResult(Class<?> loadedClass, boolean unsupportedNativeImageDynamicClassLoading) {
              this.loadedClass = loadedClass;
              this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;
          }
  
          private static ClassLoadingResult loaded(Class<?> loadedClass) {
              return new ClassLoadingResult(loadedClass, false);
          }
  
          private static ClassLoadingResult unsupportedNativeImageDynamicClassLoading() {
              return new ClassLoadingResult(null, true);
          }
  
          private Class<?> loadedClass() {
              return loadedClass;
          }
  
          private boolean isUnsupportedNativeImageDynamicClassLoading() {
              return unsupportedNativeImageDynamicClassLoading;
          }
      }
  }
