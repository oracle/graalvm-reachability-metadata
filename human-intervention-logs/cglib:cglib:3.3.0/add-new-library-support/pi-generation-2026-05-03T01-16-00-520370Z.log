  package cglib.cglib;
  
  import java.io.ByteArrayOutputStream;
  import java.io.DataOutputStream;
  import java.io.IOException;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.Method;
  import java.security.ProtectionDomain;
  import java.util.ArrayList;
  import java.util.Arrays;
  import java.util.List;
  
  import net.sf.cglib.core.ReflectUtils;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ReflectUtilsTest {
      private static final String GENERATED_CLASS_NAME = "cglib.cglib.ReflectUtilsTestGeneratedType";
      private static final String GENERATED_UNSAFE_CLASS_NAME = "cglib.cglib.ReflectUtilsTestUnsafeGeneratedType";
  
      @Test
      void descriptorLookupsResolveQualifiedSimpleAndPrimitiveArrayTypes() {
          Constructor<?> localConstructor = ReflectUtils.findConstructor(
                  "cglib.cglib.ReflectUtilsTest$ConstructorTarget(java.lang.String)"
          );
          Constructor<?> stringConstructor = ReflectUtils.findConstructor("String(byte[])");
          Method arraysToString = ReflectUtils.findMethod("java.util.Arrays.toString(int[])");
  
          assertThat(localConstructor.getDeclaringClass()).isEqualTo(ConstructorTarget.class);
          assertThat(stringConstructor.getDeclaringClass()).isEqualTo(String.class);
          assertThat(arraysToString.getDeclaringClass()).isEqualTo(Arrays.class);
          assertThat(arraysToString.getParameterTypes()).containsExactly(int[].class);
      }
  
      @Test
      void newInstanceUsesDeclaredConstructorWithArguments() {
          ConstructorTarget target = (ConstructorTarget) ReflectUtils.newInstance(
                  ConstructorTarget.class,
                  new Class[]{String.class},
                  new Object[]{"created by cglib"}
          );
  
          assertThat(target.message()).isEqualTo("created by cglib");
      }
  
      @Test
      void declaredMethodLookupWalksSuperclasses() throws NoSuchMethodException {
          Method method = ReflectUtils.findDeclaredMethod(
                  ChildMethodContainer.class,
                  "inheritedMessage",
                  new Class[]{String.class}
          );
  
          assertThat(method.getDeclaringClass()).isEqualTo(ParentMethodContainer.class);
          assertThat(method.getName()).isEqualTo("inheritedMessage");
      }
  
      @Test
      void methodCollectionIncludesClassHierarchyAndSingleInterfaceMethod() {
          List<Method> methods = ReflectUtils.addAllMethods(
                  ChildMethodContainer.class,
                  new ArrayList<Method>()
          );
          Method interfaceMethod = ReflectUtils.findInterfaceMethod(SingleOperation.class);
  
          assertThat(methods).extracting(Method::getName).contains("localMessage", "inheritedMessage");
          assertThat(interfaceMethod.getName()).isEqualTo("apply");
      }
  
      @Test
      void defineClassDefinesAndInitializesGeneratedBytecode() throws Exception {
          DefinedClassResult result = defineGeneratedClass();
  
          assertDefinedByTestLoader(result, GENERATED_CLASS_NAME);
      }
  
      @Test
      void defineClassUsesUnsafeMethodWhenClassLoaderDefineClassIsUnavailable() throws Exception {
          DefinedClassResult result = defineGeneratedClassWithUnsafeFallback();
  
          assertDefinedByTestLoader(result, GENERATED_UNSAFE_CLASS_NAME);
      }
  
      private static void assertDefinedByTestLoader(DefinedClassResult result, String expectedClassName) {
          assertThat(result.isUnsupportedNativeImageDynamicClassLoading()
                  || result.definedClass() != null).isTrue();
          if (result.definedClass() != null) {
              assertThat(result.definedClass().getName()).isEqualTo(expectedClassName);
              assertThat(result.definedClass().getClassLoader()).isInstanceOf(DefiningClassLoader.class);
          }
      }
  
      private static DefinedClassResult defineGeneratedClass() throws Exception {
          DefiningClassLoader loader = new DefiningClassLoader(ReflectUtilsTest.class.getClassLoader());
          return defineGeneratedClass(GENERATED_CLASS_NAME, loader);
      }
  
      private static DefinedClassResult defineGeneratedClassWithUnsafeFallback() throws Exception {
          FieldPatch defineClass = FieldPatch.save("DEFINE_CLASS");
          FieldPatch defineClassUnsafe = FieldPatch.save("DEFINE_CLASS_UNSAFE");
          try {
              defineClass.set(null);
              defineClassUnsafe.set(UnsafeDefineClassBridge.defineClassMethod());
              DefiningClassLoader loader = new DefiningClassLoader(ReflectUtilsTest.class.getClassLoader());
              return defineGeneratedClass(GENERATED_UNSAFE_CLASS_NAME, loader);
          } finally {
              defineClassUnsafe.restore();
              defineClass.restore();
          }
      }
  
      private static DefinedClassResult defineGeneratedClass(
              String className,
              DefiningClassLoader loader
      ) throws Exception {
          try {
              Class<?> definedClass = ReflectUtils.defineClass(className, generatedClassBytes(className), loader);
              return DefinedClassResult.defined(definedClass);
          } catch (Error error) {
              rethrowIfNotNativeImageDynamicClassLoadingError(error);
              return DefinedClassResult.unsupportedNativeImageDynamicClassLoading();
          } catch (Exception exception) {
              if (hasUnsupportedNativeImageDynamicClassLoadingError(exception)) {
                  return DefinedClassResult.unsupportedNativeImageDynamicClassLoading();
              }
              throw exception;
          }
      }
  
      private static byte[] generatedClassBytes(String className) throws IOException {
          String internalName = className.replace('.', '/');
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          DataOutputStream output = new DataOutputStream(bytes);
          output.writeInt(0xCAFEBABE);
          output.writeShort(0);
          output.writeShort(52);
          output.writeShort(10);
          output.writeByte(10);
          output.writeShort(2);
          output.writeShort(3);
          output.writeByte(7);
          output.writeShort(4);
          output.writeByte(12);
          output.writeShort(5);
          output.writeShort(6);
          output.writeByte(1);
          output.writeUTF("java/lang/Object");
          output.writeByte(1);
          output.writeUTF("<init>");
          output.writeByte(1);
          output.writeUTF("()V");
          output.writeByte(7);
          output.writeShort(8);
          output.writeByte(1);
          output.writeUTF(internalName);
          output.writeByte(1);
          output.writeUTF("Code");
          output.writeShort(0x0021);
          output.writeShort(7);
          output.writeShort(2);
          output.writeShort(0);
          output.writeShort(0);
          output.writeShort(1);
          output.writeShort(0x0001);
          output.writeShort(5);
          output.writeShort(6);
          output.writeShort(1);
          output.writeShort(9);
          output.writeInt(17);
          output.writeShort(1);
          output.writeShort(1);
          output.writeInt(5);
          output.writeByte(0x2A);
          output.writeByte(0xB7);
          output.writeShort(1);
          output.writeByte(0xB1);
          output.writeShort(0);
          output.writeShort(0);
          output.writeShort(0);
          output.flush();
          return bytes.toByteArray();
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static boolean hasUnsupportedNativeImageDynamicClassLoadingError(Throwable throwable) {
          Throwable current = throwable;
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static final class FieldPatch {
          private final Field field;
          private final Object originalValue;
  
          private FieldPatch(Field field, Object originalValue) {
              this.field = field;
              this.originalValue = originalValue;
          }
  
          private static FieldPatch save(String fieldName) throws ReflectiveOperationException {
              Field field = ReflectUtils.class.getDeclaredField(fieldName);
              field.setAccessible(true);
              return new FieldPatch(field, field.get(null));
          }
  
          private void set(Object value) throws IllegalAccessException {
              field.set(null, value);
          }
  
          private void restore() throws IllegalAccessException {
              set(originalValue);
          }
      }
  
      public static final class UnsafeDefineClassBridge {
          public static Method defineClassMethod() throws NoSuchMethodException {
              return UnsafeDefineClassBridge.class.getMethod(
                      "defineClass",
                      String.class,
                      byte[].class,
                      Integer.TYPE,
                      Integer.TYPE,
                      ClassLoader.class,
                      ProtectionDomain.class
              );
          }
  
          public static Class<?> defineClass(
                  String className,
                  byte[] bytecode,
                  int offset,
                  int length,
                  ClassLoader loader,
                  ProtectionDomain protectionDomain
          ) {
              return ((DefiningClassLoader) loader).define(className, bytecode, offset, length, protectionDomain);
          }
      }
  
      private static final class DefinedClassResult {
          private final Class<?> definedClass;
          private final boolean unsupportedNativeImageDynamicClassLoading;
  
          private DefinedClassResult(Class<?> definedClass, boolean unsupportedNativeImageDynamicClassLoading) {
              this.definedClass = definedClass;
              this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;
          }
  
          private static DefinedClassResult defined(Class<?> definedClass) {
              return new DefinedClassResult(definedClass, false);
          }
  
          private static DefinedClassResult unsupportedNativeImageDynamicClassLoading() {
              return new DefinedClassResult(null, true);
          }
  
          private Class<?> definedClass() {
              return definedClass;
          }
  
          private boolean isUnsupportedNativeImageDynamicClassLoading() {
              return unsupportedNativeImageDynamicClassLoading;
          }
      }
  
      public static final class ConstructorTarget {
          private final String message;
  
          public ConstructorTarget(String message) {
              this.message = message;
          }
  
          public String message() {
              return message;
          }
      }
  
      public static class ParentMethodContainer {
          public String inheritedMessage(String value) {
              return "parent " + value;
          }
      }
  
      public static final class ChildMethodContainer extends ParentMethodContainer {
          public String localMessage() {
              return "child";
          }
      }
  
      public interface SingleOperation {
          String apply(String value);
      }
  
      private static final class DefiningClassLoader extends ClassLoader {
          private DefiningClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          private Class<?> define(
                  String className,
                  byte[] bytecode,
                  int offset,
                  int length,
                  ProtectionDomain protectionDomain
          ) {
              return defineClass(className, bytecode, offset, length, protectionDomain);
          }
      }
  }
