[tool-call] delta {"path":"tests/src/cglib/cglib/3.3.0/src/test/java/cglib/cglib/MethodProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MethodProxyTest {\n    @Test\n    void findsMethodProxyForEnhancedMethod() {\n        ProxyCreationResult result = createLookupProxy();\n\n        assertThat(result.isUnsupportedNativeImageDynamicClassLoading() || result.service() != null).isTrue();\n        if (result.service() != null) {\n            assertThat(result.service().message(\"Ada\")).isEqualTo(\"found base Ada\");\n            assertThat(result.interceptor().foundProxy()).isNotNull();\n            assertThat(result.interceptor().foundProxy().getSignature().getName()).isEqualTo(\"message\");\n        }\n    }\n\n    private static ProxyCreationResult createLookupProxy() {\n        try {\n            LookupInterceptor interceptor = new LookupInterceptor();\n            Enhancer enhancer = new Enhancer();\n            enhancer.setSuperclass(MessageService.class);\n            enhancer.setCallback(interceptor);\n            return ProxyCreationResult.created((MessageService) enhancer.create(), interceptor);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();\n        } catch (RuntimeException exception) {\n            if (hasUnsupportedNativeImageDynamicClassLoadingError(exception)) {\n                return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();\n            }\n            throw exception;\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedNativeImageDynamicClassLoadingError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class MessageService {\n        public String message(String name) {\n            return \"base \" + name;\n        }\n    }\n\n    private static final class LookupInterceptor implements MethodInterceptor {\n        private MethodProxy foundProxy;\n\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) throws Throwable {\n            if (\"message\".equals(method.getName())) {\n                foundProxy = MethodProxy.find(object.getClass(), proxy.getSignature());\n                return \"found \" + foundProxy.invokeSuper(object, arguments);\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n\n        private MethodProxy foundProxy() {\n            return foundProxy;\n        }\n    }\n\n    private static final class ProxyCreationResult {\n        private final MessageService service;\n        private final LookupInterceptor interceptor;\n        private final boolean unsupportedNativeImageDynamicClassLoading;\n\n        private ProxyCreationResult(\n                MessageService service,\n                LookupInterceptor interceptor,\n                boolean unsupportedNativeImageDynamicClassLoading\n        ) {\n            this.service = service;\n            this.interceptor = interceptor;\n            this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;\n        }\n\n        private static ProxyCreationResult created(MessageService service, LookupInterceptor interceptor) {\n            return new ProxyCreationResult(service, interceptor, false);\n        }\n\n        private static ProxyCreationResult unsupportedNativeImageDynamicClassLoading() {\n            return new ProxyCreationResult(null, null, true);\n        }\n\n        private MessageService service() {\n            return service;\n        }\n\n        private LookupInterceptor interceptor() {\n            return interceptor;\n        }\n\n        private boolean isUnsupportedNativeImageDynamicClassLoading() {\n            return unsupportedNativeImageDynamicClassLoading;\n        }\n    }\n}\n"}
