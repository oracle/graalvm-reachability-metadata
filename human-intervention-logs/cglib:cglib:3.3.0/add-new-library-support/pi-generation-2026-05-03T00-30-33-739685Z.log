xt", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.Method;\nimport java.security.ProtectionDomain;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport net.sf.cglib.core.ReflectUtils;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectUtilsTest {\n    private static final String GENERATED_CLASS_NAME = \"cglib.cglib.ReflectUtilsTestGeneratedType\";\n    private static final String GENERATED_UNSAFE_CLASS_NAME = \"cglib.cglib.ReflectUtilsTestUnsafeGeneratedType\";\n\n    @Test\n    void descriptorLookupsResolveQualifiedSimpleAndPrimitiveArrayTypes() {\n        Constructor<?> localConstructor = ReflectUtils.findConstructor(\n                \"cglib.cglib.ReflectUtilsTest$ConstructorTarget(java.lang.String)\"\n        );\n        Constructor<?> stringConstructor = ReflectUtils.findConstructor(\"String(byte[])\");\n        Method arraysToString = ReflectUtils.findMethod(\"java.util.Arrays.toString(int[])\");\n\n        assertThat(localConstructor.getDeclaringClass()).isEqualTo(ConstructorTarget.class);\n        assertThat(stringConstructor.getDeclaringClass()).isEqualTo(String.class);\n        assertThat(arraysToString.getDeclaringClass()).isEqualTo(Arrays.class);\n        assertThat(arraysToString.getParameterTypes()).containsExactly(int[].class);\n    }\n\n    @Test\n    void newInstanceUsesDeclaredConstructorWithArguments() {\n        ConstructorTarget target = (ConstructorTarget) ReflectUtils.newInstance(\n                ConstructorTarget.class,\n                new Class[]{String.class},\n                new Object[]{\"created by cglib\"}\n        );\n\n        assertThat(target.message()).isEqualTo(\"created by cglib\");\n    }\n\n    @Test\n    void declaredMethodLookupWalksSuperclasses() throws NoSuchMethodException {\n        Method method = ReflectUtils.findDeclaredMethod(\n                ChildMethodContainer.class,\n                \"inheritedMessage\",\n                new Class[]{String.class}\n        );\n\n        assertThat(method.getDeclaringClass()).isEqualTo(ParentMethodContainer.class);\n        assertThat(method.getName()).isEqualTo(\"inheritedMessage\");\n    }\n\n    @Test\n    void methodCollectionIncludesClassHierarchyAndSingleInterfaceMethod() {\n        List<Method> methods = ReflectUtils.addAllMethods(\n                ChildMethodContainer.class,\n                new ArrayList<Method>()\n        );\n        Method interfaceMethod = ReflectUtils.findInterfaceMethod(SingleOperation.class);\n\n        assertThat(methods).extracting(Method::getName).contains(\"localMessage\", \"inheritedMessage\");\n        assertThat(interfaceMethod.getName()).isEqualTo(\"apply\");\n    }\n\n    @Test\n    void defineClassDefinesAndInitializesGeneratedBytecode() throws Exception {\n        DefinedClassResult result = defineGeneratedClass();\n\n        assertDefinedByTestLoader(result, GENERATED_CLASS_NAME);\n    }\n\n    @Test\n    void defineClassUsesUnsafeMethodWhenClassLoaderDefineClassIsUnavailable() throws Exception {\n        DefinedClassResult result = defineGeneratedClassWithUnsafeFallback();\n\n        assertDefinedByTestLoader(result, GENERATED_UNSAFE_CLASS_NAME);\n    }\n\n    private static void assertDefinedByTestLoader(DefinedClassResult result, String expectedClassName) {\n        assertThat(result.isUnsupportedNativeImageDynamicClassLoading()\n                || result.definedClass() != null).isTrue();\n        if (result.definedClass() != null) {\n            assertThat(result.definedClass().getName()).isEqualTo(expectedClassName);\n            assertThat(result.definedClass().getClassLoader()).isInstanceOf(DefiningClassLoader.class);\n        }\n    }\n\n    private static DefinedClassResult defineGeneratedClass() throws Exception {\n        DefiningClassLoader loader = new DefiningClassLoader(ReflectUtilsTest.class.getClassLoader());\n        return defineGeneratedClass(GENERATED_CLASS_NAME, loader);\n    }\n\n    private static DefinedClassResult defineGeneratedClassWithUnsafeFallback() throws Exception {\n        FieldPatch defineClass = FieldPatch.save(\"DEFINE_CLASS\");\n        FieldPatch defineClassUnsafe = FieldPatch.save(\"DEFINE_CLASS_UNSAFE\");\n        try {\n            defineClass.set(null);\n            defineClassUnsafe.set(UnsafeDefineClassBridge.defineClassMethod());\n            DefiningClassLoader loader = new DefiningClassLoader(ReflectUtilsTest.class.getClassLoader());\n            return defineGeneratedClass(GENERATED_UNSAFE_CLASS_NAME, loader);\n        } finally {\n            defineClassUnsafe.restore();\n            defineClass.restore();\n        }\n    }\n\n    private static DefinedClassResult defineGeneratedClass(\n            String className,\n            DefiningClassLoader loader\n    ) throws Exception {\n        try {\n            Class<?> definedClass = ReflectUtils.defineClass(className, generatedClassBytes(className), loader);\n            return DefinedClassResult.defined(definedClass);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return DefinedClassResult.unsupportedNativeImageDynamicClassLoading();\n        } catch (Exception exception) {\n            if (hasUnsupportedNativeImageDynamicClassLoadingError(exception)) {\n                return DefinedClassResult.unsupportedNativeImageDynamicClassLoading();\n            }\n            throw exception;\n        }\n    }\n\n    private static byte[] generatedClassBytes(String className) throws IOException {\n        String internalName = className.replace('.', '/');\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(bytes);\n        output.writeInt(0xCAFEBABE);\n        output.writeShort(0);\n        output.writeShort(52);\n        output.writeShort(10);\n        output.writeByte(10);\n        output.writeShort(2);\n        output.writeShort(3);\n        output.writeByte(7);\n        output.writeShort(4);\n        output.writeByte(12);\n        output.writeShort(5);\n        output.writeShort(6);\n        output.writeByte(1);\n        output.writeUTF(\"java/lang/Object\");\n        output.writeByte(1);\n        output.writeUTF(\"<init>\");\n        output.writeByte(1);\n        output.writeUTF(\"()V\");\n        output.writeByte(7);\n        output.writeShort(8);\n        output.writeByte(1);\n        output.writeUTF(internalName);\n        output.writeByte(1);\n        output.writeUTF(\"Code\");\n        output.writeShort(0x0021);\n        output.writeShort(7);\n        output.writeShort(2);\n        output.writeShort(0);\n        output.writeShort(0);\n        output.writeShort(1);\n        output.writeShort(0x0001);\n        output.writeShort(5);\n        output.writeShort(6);\n        output.writeShort(1);\n        output.writeShort(9);\n        output.writeInt(17);\n        output.writeShort(1);\n        output.writeShort(1);\n        output.writeInt(5);\n        output.writeByte(0x2A);\n        output.writeByte(0xB7);\n        output.writeShort(1);\n        output.writeByte(0xB1);\n        output.writeShort(0);\n        output.writeShort(0);\n        output.writeShort(0);\n        output.flush();\n        return bytes.toByteArray();\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedNativeImageDynamicClassLoadingError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static final class FieldPatch {\n        private final Field field;\n        private final Object originalValue;\n\n        private FieldPatch(Field field, Object originalValue) {\n            this.field = field;\n            this.originalValue = originalValue;\n        }\n\n        private static FieldPatch save(String fieldName) throws ReflectiveOperationException {\n            Field field = ReflectUtils.class.getDeclaredField(fieldName);\n\n[109 more lines in file. Use offset=221 to continue.]"}], "isError": false, "timestamp": 1777768134612}, {"role": "toolResult", "toolCallId": "call_BqSbiSL2d0o8T2gfW0ZjQ8iN|fc_095d48dd3c7cec6c0169f696c639ac8192b957fba47f383007", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Callback;\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.Factory;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnhancerTest {\n    @Test\n    void createsCachedFactoryProxyAndRegistersCallbacks() {\n        ProxyCreationResult result = createGreetingProxy();\n\n        assertThat(result.isUnsupportedNativeImageDynamicClassLoading() || result.proxy() != null).isTrue();\n        if (result.proxy() != null) {\n            GreetingService proxy = result.proxy();\n            Class<?> proxyType = proxy.getClass();\n            Callback replacementCallback = new ReplacementGreetingInterceptor();\n\n            assertThat(proxy.greet(\"Ada\")).isEqualTo(\"intercepted hello Ada\");\n            assertThat(Enhancer.isEnhanced(proxyType)).isTrue();\n\n            Enhancer.registerCallbacks(proxyType, new Callback[]{replacementCallback});\n            Enhancer.registerStaticCallbacks(proxyType, new Callback[]{replacementCallback});\n            Enhancer.registerCallbacks(proxyType, null);\n            Enhancer.registerStaticCallbacks(proxyType, null);\n\n            GreetingService secondProxy = (GreetingService) ((Factory) proxy).newInstance(\n                    new Callback[]{replacementCallback}\n            );\n\n            assertThat(secondProxy.greet(\"Grace\")).isEqualTo(\"registered Grace\");\n        }\n    }\n\n    private static ProxyCreationResult createGreetingProxy() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(GreetingService.class);\n        enhancer.setCallback(new PrefixingGreetingInterceptor());\n        try {\n            return ProxyCreationResult.created((GreetingService) enhancer.create());\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();\n        } catch (RuntimeException exception) {\n            if (hasUnsupportedNativeImageDynamicClassLoadingError(exception)) {\n                return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();\n            }\n            throw exception;\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static boolean hasUnsupportedNativeImageDynamicClassLoadingError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    private static final class PrefixingGreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) throws Throwable {\n            if (\"greet\".equals(method.getName())) {\n                return \"intercepted \" + proxy.invokeSuper(object, arguments);\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n    }\n\n    private static final class ReplacementGreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) {\n            if (\"greet\".equals(method.getName())) {\n                return \"registered \" + arguments[0];\n            }\n            return object.getClass().getName();\n        }\n    }\n\n    private static final class ProxyCreationResult {\n        private final GreetingService proxy;\n        private final boolean unsupportedNativeImageDynamicClassLoading;\n\n        private ProxyCreationResult(GreetingService proxy, boolean unsupportedNativeImageDynamicClassLoading) {\n            this.proxy = proxy;\n            this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;\n        }\n\n        private static ProxyCreationResult created(GreetingService proxy) {\n            return new ProxyCreationResult(proxy, false);\n        }\n\n        private static ProxyCreationResult unsupportedNativeImageDynamicClassLoading() {\n            return new ProxyCreationResult(null, true);\n        }\n\n        private GreetingService proxy() {\n            return proxy;\n        }\n\n        private boolean isUnsupportedNativeImageDynamicClassLoading() {\n            return unsupportedNativeImageDynamicClassLoading;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777768134612}, {"role": "toolResult", "toolCallId": "call_FPbMDOEsMP7zfWfaydSqhCjF|fc_095d48dd3c7cec6c0169f696c639b481929031a95c4d420d7a", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"reflection\": [\n    {\n      \"condition\": {\n        \"typeReached\": \"cglib.cglib.ReflectUtilsTest\"\n      },\n      \"type\": \"java.lang.String\",\n      \"methods\": [\n        {\n          \"name\": \"<init>\",\n          \"parameterTypes\": [\n            \"byte[]\"\n          ]\n        }\n      ]\n    },\n    {\n      \"condition\": {\n        \"typeReached\": \"cglib.cglib.ReflectUtilsTest\"\n      },\n      \"type\": \"cglib.cglib.ReflectUtilsTest$ConstructorTarget\",\n      \"methods\": [\n        {\n          \"name\": \"<init>\",\n          \"parameterTypes\": [\n            \"java.lang.String\"\n          ]\n        }\n      ]\n    },\n    {\n      \"condition\": {\n        \"typeReached\": \"cglib.cglib.ReflectUtilsTest\"\n      },\n      \"type\": \"cglib.cglib.ReflectUtilsTest$ChildMethodContainer\",\n      \"allDeclaredMethods\": true\n    },\n    {\n      \"condition\": {\n        \"typeReached\": \"cglib.cglib.ReflectUtilsTest\"\n      },\n      \"type\": \"cglib.cglib.ReflectUtilsTest$ParentMethodContainer\",\n      \"allDeclaredMethods\": true\n    },\n    {\n      \"condition\": {\n        \"typeReached\": \"cglib.cglib.Ref