edClassName) {\n        assertThat(result.isUnsupportedNativeImageDynamicClassLoading()\n                || result.definedClass() != null).isTrue();\n        if (result.definedClass() != null) {\n            assertThat(result.definedClass().getName()).isEqualTo(expectedClassName);\n            assertThat(result.definedClass().getClassLoader()).isInstanceOf(DefiningClassLoader.class);\n        }\n    }\n\n    private static DefinedClassResult defineGeneratedClass() throws Exception {\n        DefiningClassLoader loader = new DefiningClassLoader(ReflectUtilsTest.class.getClassLoader());\n        return defineGeneratedClass(GENERATED_CLASS_NAME, loader);\n    }\n\n    private static DefinedClassResult defineGeneratedClassWithUnsafeFallback() throws Exception {\n        FieldPatch defineClass = FieldPatch.save(\"DEFINE_CLASS\");\n        FieldPatch defineClassUnsafe = FieldPatch.save(\"DEFINE_CLASS_UNSAFE\");\n        try {\n            defineClass.set(null);\n            defineClassUnsafe.set(UnsafeDefineClassBridge.defineClassMethod());\n            DefiningClassLoader loader = new DefiningClassLoader(ReflectUtilsTest.class.getClassLoader());\n            return defineGeneratedClass(GENERATED_UNSAFE_CLASS_NAME, loader);\n        } finally {\n            defineClassUnsafe.restore();\n            defineClass.restore();\n        }\n    }\n\n    private static DefinedClassResult defineGeneratedClass(\n            String className,\n            DefiningClassLoader loader\n    ) throws Exception {\n        try {\n            Class<?> definedClass = ReflectUtils.defineClass(className, generatedClassBytes(className), loader);\n            return DefinedClassResult.defined(definedClass);\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return DefinedClassResult.unsupportedNativeImageDynamicClassLoading();\n        } catch (Exception exception) {\n            if (hasUnsupportedNativeImageDynamicClassLoadingError(