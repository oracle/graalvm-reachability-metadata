  package cglib.cglib;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.util.ArrayList;
  import java.util.Base64;
  import java.util.List;
  
  import net.sf.cglib.core.ReflectUtils;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class NetSfCglibCoreReflectUtilsTest {
      private static final String GENERATED_CLASS_NAME =
              "org_apache_extras_beanshell.bsh.BshClassLoaderGeneratedFixture";
      private static final String GENERATED_CLASS_BYTES = """
              yv66vgAAADQADQoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClWBwAI
              AQA+b3JnX2FwYWNoZV9leHRyYXNfYmVhbnNoZWxsL2JzaC9Cc2hDbGFzc0xvYWRlckdlbmVyYXRlZEZp
              eHR1cmUBAARDb2RlAQAPTGluZU51bWJlclRhYmxlAQAKU291cmNlRmlsZQEAI0JzaENsYXNzTG9hZGVy
              R2VuZXJhdGVkRml4dHVyZS5qYXZhACEABwACAAAAAAABAAEABQAGAAEACQAAAB0AAQABAAAABSq3AAGx
              AAAAAQAKAAAABgABAAAAAwABAAsAAAACAAw=
              """;
  
      @Test
      void resolvesConstructorsAndMethodsFromDescriptorStrings() {
          Constructor<?> qualifiedConstructor = ReflectUtils.findConstructor("java.lang.String(java.lang.String)");
          Constructor<?> packageResolvedConstructor = ReflectUtils.findConstructor("String(String)");
          Method arrayMethod = ReflectUtils.findMethod(
                  "cglib.cglib.NetSfCglibCoreReflectUtilsTest.acceptIntArray(int[])");
  
          assertThat(qualifiedConstructor.getDeclaringClass()).isEqualTo(String.class);
          assertThat(qualifiedConstructor.getParameterTypes()).containsExactly(String.class);
          assertThat(packageResolvedConstructor.getDeclaringClass()).isEqualTo(String.class);
          assertThat(packageResolvedConstructor.getParameterTypes()).containsExactly(String.class);
          assertThat(arrayMethod.getName()).isEqualTo("acceptIntArray");
          assertThat(arrayMethod.getParameterTypes()).containsExactly(int[].class);
      }
  
      @Test
      void createsInstancesWithDeclaredConstructors() {
          PrivateConstructed instance = (PrivateConstructed) ReflectUtils.newInstance(
                  PrivateConstructed.class,
                  new Class[] {String.class},
                  new Object[] {"created"});
  
          assertThat(instance.value()).isEqualTo("created");
      }
  
      @Test
      void findsInheritedDeclaredMethodsAndEnumeratesMethods() throws NoSuchMethodException {
          Method inheritedMethod = ReflectUtils.findDeclaredMethod(
                  ChildFixture.class,
                  "hiddenMessage",
                  new Class[0]);
          List<Method> methods = ReflectUtils.addAllMethods(ChildFixture.class, new ArrayList<>());
  
          assertThat(inheritedMethod.getDeclaringClass()).isEqualTo(ParentFixture.class);
          assertThat(inheritedMethod.getName()).isEqualTo("hiddenMessage");
          assertThat(methods)
                  .extracting(Method::getName)
                  .contains("childMessage", "hiddenMessage", "implementedMessage");
      }
  
      @Test
      void findsTheSingleMethodDeclaredByAnInterface() {
          Method method = ReflectUtils.findInterfaceMethod(SingleMethodFactory.class);
  
          assertThat(method.getName()).isEqualTo("newInstance");
          assertThat(method.getParameterTypes()).isEmpty();
          assertThat(method.getReturnType()).isEqualTo(ParentFixture.class);
      }
  
      @Test
      void definesClassBytesWithReflectUtils() throws Exception {
          byte[] classBytes = Base64.getMimeDecoder().decode(GENERATED_CLASS_BYTES);
  
          try {
              Class<?> generatedClass = ReflectUtils.defineClass(
                      GENERATED_CLASS_NAME,
                      classBytes,
                      NetSfCglibCoreReflectUtilsTest.class.getClassLoader());
  
              assertThat(generatedClass.getName()).isEqualTo(GENERATED_CLASS_NAME);
              assertThat(generatedClass.getClassLoader())
                      .isEqualTo(NetSfCglibCoreReflectUtilsTest.class.getClassLoader());
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      public static void acceptIntArray(int[] values) {
          assertThat(values).isNotNull();
      }
  
      public interface SingleMethodFactory {
          ParentFixture newInstance();
      }
  
      public interface FixtureInterface {
          String implementedMessage();
      }
  
      public static class ParentFixture {
          private String hiddenMessage() {
              return "parent";
          }
      }
  
      public static class ChildFixture extends ParentFixture implements FixtureInterface {
          public String childMessage() {
              return "child";
          }
  
          @Override
          public String implementedMessage() {
              return "implemented";
          }
      }
  
      public static class PrivateConstructed {
          private final String value;
  
          private PrivateConstructed(String value) {
              this.value = value;
          }
  
          public String value() {
              return value;
          }
      }
  }
