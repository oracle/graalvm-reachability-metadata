8193bf8cfc6357a993ff", "name": "write", "arguments": {"path": "tests/src/cglib/cglib/3.3.0/src/test/java/cglib/cglib/EnhancerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Callback;\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.Factory;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnhancerTest {\n    @Test\n    void createsCachedFactoryProxyAndRegistersCallbacks() {\n        ProxyCreationResult result = createGreetingProxy();\n\n        assertThat(result.isUnsupportedNativeImageDynamicClassLoading() || result.proxy() != null).isTrue();\n        if (result.proxy() != null) {\n            GreetingService proxy = result.proxy();\n            Class<?> proxyType = proxy.getClass();\n            Callback replacementCallback = new ReplacementGreetingInterceptor();\n\n            assertThat(proxy.greet(\"Ada\")).isEqualTo(\"intercepted hello Ada\");\n            assertThat(Enhancer.isEnhanced(proxyType)).isTrue();\n\n            Enhancer.registerCallbacks(proxyType, new Callback[]{replacementCallback});\n            Enhancer.registerStaticCallbacks(proxyType, new Callback[]{replacementCallback});\n            Enhancer.registerCallbacks(proxyType, null);\n            Enhancer.registerStaticCallbacks(proxyType, null);\n\n            GreetingService secondProxy = (GreetingService) ((Factory) proxy).newInstance(\n                    new Callback[]{replacementCallback}\n            );\n\n            assertThat(secondProxy.greet(\"Grace\")).isEqualTo(\"registered Grace\");\n        }\n    }\n\n    private static ProxyCreationResult createGreetingProxy() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(GreetingService.class);\n        enhancer.setCallback(new PrefixingGreetingInterceptor());\n        try {\n            return ProxyCreationResult.created((GreetingService) enhancer.create());\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    private static final class PrefixingGreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) throws Throwable {\n            if (\"greet\".equals(method.getName())) {\n                return \"intercepted \" + proxy.invokeSuper(object, arguments);\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n    }\n\n    private static final class ReplacementGreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) {\n            if (\"greet\".equals(method.getName())) {\n                return \"registered \" + arguments[0];\n            }\n            return object.getClass().getName();\n        }\n    }\n\n    private static final class ProxyCreationResult {\n        private final GreetingService proxy;\n        private final boolean unsupportedNativeImageDynamicClassLoading;\n\n        private ProxyCreationResult(GreetingService proxy, boolean unsupportedNativeImageDynamicClassLoading) {\n            this.proxy = proxy;\n            this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;\n        }\n\n        private static ProxyCreationResult created(GreetingService proxy) {\n            return new ProxyCreationResult(proxy, false);\n        }\n\n        private static ProxyCreationResult unsupportedNativeImageDynamicClassLoading() {\n            return new ProxyCreationResult(null, true);\n        }\n\n        private GreetingService proxy() {\n            return proxy;\n        }\n\n        private boolean isUnsupportedNativeImageDynamicClassLoading() {\n            return unsupportedNativeImageDynamicClassLoading;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1874, "output": 1838, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 35456, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777767159485, "responseId": "resp_0ac6ee654f6d39610169f692f8494881938d9715c2a93ae20c"}}
[tool-exec] start id=call_UvEfSM9DX986Ttc0wH0ZyzXl|fc_0ac6ee654f6d39610169f69303d6008193bf8cfc6357a993ff name=write args={"path": "tests/src/cglib/cglib/3.3.0/src/test/java/cglib/cglib/EnhancerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage cglib.cglib;\n\nimport java.lang.reflect.Method;\n\nimport net.sf.cglib.proxy.Callback;\nimport net.sf.cglib.proxy.Enhancer;\nimport net.sf.cglib.proxy.Factory;\nimport net.sf.cglib.proxy.MethodInterceptor;\nimport net.sf.cglib.proxy.MethodProxy;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class EnhancerTest {\n    @Test\n    void createsCachedFactoryProxyAndRegistersCallbacks() {\n        ProxyCreationResult result = createGreetingProxy();\n\n        assertThat(result.isUnsupportedNativeImageDynamicClassLoading() || result.proxy() != null).isTrue();\n        if (result.proxy() != null) {\n            GreetingService proxy = result.proxy();\n            Class<?> proxyType = proxy.getClass();\n            Callback replacementCallback = new ReplacementGreetingInterceptor();\n\n            assertThat(proxy.greet(\"Ada\")).isEqualTo(\"intercepted hello Ada\");\n            assertThat(Enhancer.isEnhanced(proxyType)).isTrue();\n\n            Enhancer.registerCallbacks(proxyType, new Callback[]{replacementCallback});\n            Enhancer.registerStaticCallbacks(proxyType, new Callback[]{replacementCallback});\n            Enhancer.registerCallbacks(proxyType, null);\n            Enhancer.registerStaticCallbacks(proxyType, null);\n\n            GreetingService secondProxy = (GreetingService) ((Factory) proxy).newInstance(\n                    new Callback[]{replacementCallback}\n            );\n\n            assertThat(secondProxy.greet(\"Grace\")).isEqualTo(\"registered Grace\");\n        }\n    }\n\n    private static ProxyCreationResult createGreetingProxy() {\n        Enhancer enhancer = new Enhancer();\n        enhancer.setSuperclass(GreetingService.class);\n        enhancer.setCallback(new PrefixingGreetingInterceptor());\n        try {\n            return ProxyCreationResult.created((GreetingService) enhancer.create());\n        } catch (Error error) {\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\n            return ProxyCreationResult.unsupportedNativeImageDynamicClassLoading();\n        }\n    }\n\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static class GreetingService {\n        public String greet(String name) {\n            return \"hello \" + name;\n        }\n    }\n\n    private static final class PrefixingGreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) throws Throwable {\n            if (\"greet\".equals(method.getName())) {\n                return \"intercepted \" + proxy.invokeSuper(object, arguments);\n            }\n            return proxy.invokeSuper(object, arguments);\n        }\n    }\n\n    private static final class ReplacementGreetingInterceptor implements MethodInterceptor {\n        @Override\n        public Object intercept(\n                Object object,\n                Method method,\n                Object[] arguments,\n                MethodProxy proxy\n        ) {\n            if (\"greet\".equals(method.getName())) {\n                return \"registered \" + arguments[0];\n            }\n            return object.getClass().getName();\n        }\n    }\n\n    private static final class ProxyCreationResult {\n        private final GreetingService proxy;\n        private final boolean unsupportedNativeImageDynamicClassLoading;\n\n        private ProxyCreationResult(GreetingService proxy, boolean unsupportedNativeImageDynamicClassLoading) {\n            this.proxy = proxy;\n            this.unsupportedNativeImageDynamicClassLoading = unsupportedNativeImageDynamicClassLoading;\n        }\n\n        private static ProxyCreationResult created(GreetingService proxy) {\n            return new ProxyCreationResult(proxy, false);\n        }\n\n        private static ProxyCreationResult unsupportedNativeImageDynamicClassLoading() {\n            return new ProxyCreationResult(null, true);\n        }\n\n        private GreetingService proxy() {\n            return proxy;\n        }\n\n        private boolean isUnsupportedNativeImageDynamicClassLoading() {\n            return unsupportedNativeImageDynamicClassLoading;\n        }\n    }\n}\n"}
