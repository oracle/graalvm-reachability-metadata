    </parent>

    <artifactId>jandex</artifactId>
    <packaging>bundle</packaging>

    <name>Jandex: Core</name>

    <dependencies>
        <dependency>
            <groupId>org.apache.ant</groupId>
            <artifactId>ant</artifactId>
            <scope>provided</scope>
            <optional>true</optional>
