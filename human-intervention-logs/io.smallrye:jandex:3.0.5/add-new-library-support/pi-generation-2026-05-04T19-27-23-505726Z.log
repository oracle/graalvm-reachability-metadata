  package io_smallrye.jandex;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.jboss.jandex.ArrayType;
  import org.jboss.jandex.ClassType;
  import org.jboss.jandex.DotName;
  import org.jboss.jandex.JandexReflection;
  import org.junit.jupiter.api.Test;
  
  public class JandexReflectionTest {
      @Test
      void loadsRawClassType() {
          DotName stringName = DotName.createSimple(String.class);
          ClassType stringType = ClassType.create(stringName);
  
          Class<?> loadedType = JandexReflection.loadRawType(stringType);
  
          assertThat(loadedType).isEqualTo(String.class);
      }
  
      @Test
      void createsArrayClassForJandexArrayType() {
          DotName stringName = DotName.createSimple(String.class);
          ClassType stringType = ClassType.create(stringName);
          ArrayType stringMatrixType = ArrayType.create(stringType, 2);
  
          Class<?> loadedType = JandexReflection.loadRawType(stringMatrixType);
  
          assertThat(loadedType).isEqualTo(String[][].class);
      }
  }
