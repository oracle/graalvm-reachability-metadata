[tool-call] delta {"path":"tests/src/io.smallrye/jandex/3.0.5/src/test/java/io_smallrye/jandex/JandexReflectionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_smallrye.jandex;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.jboss.jandex.ArrayType;\nimport org.jboss.jandex.ClassType;\nimport org.jboss.jandex.DotName;\nimport org.jboss.jandex.JandexReflection;\nimport org.junit.jupiter.api.Test;\n\npublic class JandexReflectionTest {\n    @Test\n    void loadsRawClassType() {\n        DotName stringName = DotName.createSimple(String.class);\n        ClassType stringType = ClassType.create(stringName);\n\n        Class<?> loadedType = JandexReflection.loadRawType(stringType);\n\n        assertThat(loadedType).isEqualTo(String.class);\n    }\n\n    @Test\n    void createsArrayClassForJandexArrayType() {\n        DotName stringName = DotName.createSimple(String.class);\n        ClassType stringType = ClassType.create(stringName);\n        ArrayType stringMatrixType = ArrayType.create(stringType, 2);\n\n        Class<?> loadedType = JandexReflection.loadRawType(stringMatrixType);\n\n        assertThat(loadedType).isEqualTo(String[][].class);\n    }\n}\n"}
