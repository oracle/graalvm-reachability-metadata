   *     &lt;/list&gt;
   *   &lt;/property&gt;
   *   &lt;property name="mappings"&gt;
   *     &lt;props&gt;
   *       &lt;prop key="*.do"&gt;strutsWrappingController&lt;/prop&gt;
   *     &lt;/props&gt;
   *   &lt;/property&gt;
