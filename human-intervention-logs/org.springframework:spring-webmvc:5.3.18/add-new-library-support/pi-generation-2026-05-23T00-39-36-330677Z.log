  	public void setOrder(int order) {
  		this.order = order;
  	}
  
  	@Override
  	public int getOrder() {
  		return this.order;
  	}
  
  	/**
  	 * Eagerly initialize Locales if necessary.
  	 * @see #setLocalesToInitialize
