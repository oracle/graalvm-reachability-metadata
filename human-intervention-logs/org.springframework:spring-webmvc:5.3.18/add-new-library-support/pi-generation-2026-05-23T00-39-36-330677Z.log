  	public void setCache(boolean cache) {
  		this.cacheLimit = (cache ? DEFAULT_CACHE_LIMIT : 0);
  	}
  
  	/**
  	 * Return if caching is enabled.
  	 */
  	public boolean isCache() {
  		return (this.cacheLimit > 0);
  	}
  
