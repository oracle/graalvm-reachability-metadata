  		String mediaType = transformer.getOutputProperty(OutputKeys.MEDIA_TYPE);
  		String encoding = transformer.getOutputProperty(OutputKeys.ENCODING);
  		if (StringUtils.hasText(mediaType)) {
  			contentType = mediaType;
  		}
