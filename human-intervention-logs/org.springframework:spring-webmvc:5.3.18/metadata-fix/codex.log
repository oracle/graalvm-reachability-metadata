edOperationException(\"Annotated types are not used by this test\");\n        }\n\n        private List<Bean<?>> getBeans() {\n            return beans;\n        }\n\n        private List<Throwable> getDefinitionErrors() {\n            return definitionErrors;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
