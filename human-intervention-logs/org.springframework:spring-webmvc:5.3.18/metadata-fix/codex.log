eClassesMarkerFile.parentFile.mkdirs()\n        generatedNativeImageClassesMarkerFile.text = \"generated\"\n    }\n}\n\ntasks.named(\"nativeTestCompile\") {\n    dependsOn(\"generatePredefinedNativeImageClasses\")\n}\n\ntasks.named(\"test\") {\n    dependsOn(\"generatePredefinedXsltTranslet\")\n    doFirst {\n        delete(fileTree(compiledTestClassesDir) {\n            include \"org/springframework/cglib/**/*.class\"\n            include \"org_springframework/spring_webmvc/**/\\$\\$*.class\"\n            include \"org_springframework/spring_webmvc/*\\$\\$*.class\"\n        })\n    }\n}\n\ntasks.named(\"nativeTraceImage\") {\n    dependsOn(\"generatePredefinedNativeImageClasses\")\n}\n\ngraalvmNative {\n    binaries {\n        all {\n            buildArgs.addAll(nativeAccessArgs)\n        }\n    }\n\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
