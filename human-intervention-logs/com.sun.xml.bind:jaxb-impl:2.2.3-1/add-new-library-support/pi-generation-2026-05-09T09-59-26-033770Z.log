ssertThat(copy.extensions.get(0).getTextContent()).isEqualTo(\"high\");\n        assertThat(copy.extensions.get(1).getTagName()).isEqualTo(\"tag\");\n        assertThat(copy.extensions.get(1).getAttribute(\"code\")).isEqualTo(\"blue\");\n\n        Document document = DocumentBuilderFactory.newInstance().newDocumentBuilder().newDocument();\n        Element marker = document.createElement(\"marker\");\n        marker.setAttribute(\"source\", \"dom\");\n        marker.setTextContent(\"preserved\");\n        MessageEnvelope envelope = new MessageEnvelope();\n        envelope.body = \"Outbound message\";\n        envelope.extensions.add(marker);\n\n        String xml = marshal(context, envelope);\n\n        assertThat(xml).contains(\"<body>Outbound message</body>\");\n        assertThat(xml).contains(\"<marker source=\\\"dom\\\">preserved</marker>\");\n    }\n\n    @Test\n    void updatesDomWithBinder() throws Exception {"}, {"oldText": "    @XmlRootElement(name = \"settings\")\n    @XmlAccessorType(XmlAccessType.FIELD)\n    public static class Settings {", "newText": "    @XmlRootElement(name = \"message\")\n    @XmlAccessorType(XmlAccessType.FIELD)\n    @XmlType(propOrder = {\"body\", \"extensions\"})\n    public static class MessageEnvelope {\n        public String body;\n\n        @XmlAnyElement\n        public List<Element> extensions = new ArrayList<>();\n    }\n\n    @XmlRootElement(name = \"settings\")\n    @XmlAccessorType(XmlAccessType.FIELD)\n    public static class Settings {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3610, "output": 1770, "cacheRead": 12288, "cacheWrite": 0, "totalTokens": 17668, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778320727609, "responseId": "resp_039c84ebf5172c490169ff0557fb5c819fafc0ef1c27c78e23"}}
