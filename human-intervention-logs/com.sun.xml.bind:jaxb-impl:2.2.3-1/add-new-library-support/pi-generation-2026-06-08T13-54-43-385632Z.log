  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "com.sun.xml.bind:jaxb-impl:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.withType(Test).configureEach {
      systemProperty "com.sun.xml.bind.v2.bytecode.ClassTailor.noOptimize", "true"
  }
  
  tasks.named("nativeTest") {
      runtimeArgs.add("-Dcom.sun.xml.bind.v2.bytecode.ClassTailor.noOptimize=true")
  }
  
  graalvmNative {
      binaries {
          test {
              buildArgs.addAll([
                      "-Dcom.sun.xml.bind.v2.bytecode.ClassTailor.noOptimize=true",
                      "--initialize-at-build-time=org.xml.sax.helpers.LocatorImpl"
              ])
          }
      }
  
  
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
