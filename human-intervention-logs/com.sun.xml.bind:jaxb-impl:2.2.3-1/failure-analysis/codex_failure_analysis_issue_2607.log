n./tests/src/io.fabric8/kubernetes-model-node/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-batch/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-gatewayapi/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/org.glassfish/javax.annotation/3.1/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/org.apache.maven.resolver/maven-resolver-transport-file/2.0.13/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-scheduling/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-autoscaling/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-coordination/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/zjsonpatch/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-networking/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/org.glassfish/javax.annotation/10.0-b28/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-common/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/org.apache.maven.resolver/maven-resolver-util/1.9.25/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-model-apps/7.5.2/build.gradle:23:                userCodeFilterPath = \\\"user-code-filter.json\\\"\\n./tests/src/io.fabric8/kubernetes-m