              if ( isNotEmpty( name ) )
              {
                  append( sb, name, 0 );
              }
              else
              {
                  append( sb, id, 0 );
              }
          }
          append( sb, getValue( plugin, "description" ), 1 );
          append( sb, "", 0 );
  
