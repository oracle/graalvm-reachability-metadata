tResult\\nimport groovy.lang.Writable\\nimport org.junit.jupiter.api.Test\\nimport org.junit.jupiter.api.io.TempDir\\n\\nimport java.nio.charset.StandardCharsets\\nimport java.nio.file.Files\\nimport java.nio.file.Path\\nimport java.util.regex.Pattern\\n\\nimport static org.assertj.core.api.Assertions.assertThat\\n\\npublic class Groovy_nioTest {\\n    @TempDir\\n    Path tempDir\\n\\n    @Test\\n    void readsTextByLineAndSplitsUsingPathExtensions() {\\n        Path file = tempDir.resolve('records.txt')\\n        file.write('alpha:1\\\\nβeta:2\\\\ngamma:3', 'UTF-8')\\n\\n        List<String> numberedLines = []\\n        Object lastLine = file.eachLine('UTF-8', 5) { String line, Integer number ->\\n            numberedLines << \\\"${number}:${line}\\\".toString()\\n            line\\n        }\\n\\n        List<List<String>> splitWithRegex = []\\n        file.splitEachLine(/:/, 'UTF-8') { List<String> parts ->\\n            splitWithRegex << parts\\n        }\\n        List<List<String>> splitWithPattern = []\\n        file.splitEachLine(Pattern.compile(':'), 'UTF-8') { List<String> parts ->\\n            splitWithPattern << parts\\n        }\\n\\n        assertThat(file.text).isEqualTo('alpha:1\\\\nβeta:2\\\\ngamma:3')\\n        assertThat(file.getText('UTF-8')).isEqualTo('alpha:1\\\\nβeta:2\\\\ngamma:3')\\n        assertThat(file.readLines()).containsExactly('alpha:1', 'βeta:2', 'gamma:3')\\n        assertThat(file.readLines('UTF-8')).containsExactly('alpha:1', 'βeta:2', 'gamma:3')\\n        assertThat(numberedLines).containsExactly('5:alpha:1', '6:βeta:2', '7:gamma:3')\\n        assertThat(lastLine).isEqualTo('gamma:3')\\n        assertThat(splitWithRegex).containsExactly(['alpha', '1'], ['βeta', '2'], ['gamma', '3'])\\n        assertThat(splitWithPattern).containsExactly(['alpha', '1'], ['βeta', '2'], ['gamma', '3'])\\n        assertThat(file.size()).isEqualTo(Files.size(file))\\n    }\\n\\n    @Test\\n    void writesAppendsAndCopiesTextAndBytes() {\\n        Path file = tempDir.resolve('append.txt')\\n\\n        file.text = 'start'\\n        file << '-leftShift'\\n        file.append(new StringReader('-reader'), 'UTF-8')\\n        StringWriter sourceWriter = new StringWriter()\\n        sourceWriter.write('-writer')\\n        file.append(sourceWriter, 'UTF-8')\\n        file.append('-object', 'UTF-8')\\n        file.append('-bytes'.getBytes(StandardCharsets.UTF_8))\\n        file.append(new ByteArrayInputStream('-stream'.getBytes(StandardCharsets.UTF_8)))\\n\\n        assertThat(new String(file.bytes, StandardCharsets.UTF_8))\\n                .isEqualTo('start-leftShift-reader-writer-object-bytes-stream')\\n        assertThat(new String(file.getBytes(), StandardCharsets.UTF_8))\\n                .isEqualTo('start-leftShift-reader-writer-object-bytes-stream')\\n\\n        Path copied = tempDir.resolve('copied.txt')\\n        copied.bytes = file.readBytes()\\n        assertThat(copied.getText('UTF-8')).isEqualTo(file.getText('UTF-8'))\\n    }\\n\\n    @Test\\n    void usesReadersWritersPrintWritersAndWritableViews() {\\n        Path file = tempDir.resolve('writers.txt')\\n\\n        file.withWriter('UTF-8') { BufferedWriter writer ->\\n            writer.write('one')\\n            writer.newLine()\\n        }\\n        file.withWriterAppend('UTF-8') { BufferedWriter writer ->\\n            writer.write('two')\\n            writer.newLine()\\n        }\\n        file.withPrintWriter('UTF-8') { PrintWriter writer ->\\n            writer.println('three')\\n        }\\n\\n        String firstLine = file.withReader('UTF-8') { BufferedReader reader ->\\n            reader.readLine()\\n        }\\n        StringWriter writableTarget = new StringWriter()\\n        Writable writable = file as Writable\\n        writable.writeTo(writableTarget)\\n        StringWriter encodedWritableTarget = new StringWriter()\\n        file.asWritable('UTF-8').writeTo(encodedWritableTarget)\\n\\n        assertThat(firstLine).isEqualTo('one')\\n        assertThat(file.readLines('UTF-8')).containsExactly('one', 'two', 'three')\\n        assertThat(writableTarget.toString().readLines()).containsExactly('one', 'two', 'three')\\n        assertThat(encodedWritableTarget.toString().readLines()).containsExactly('one', 'two', 'three')\\n    }\\n\\n    @Test\\n    void usesBinaryAndDataStreamHelpers() {\\n        Path file = tempDir.resolve('data.bin')\\n\\n        file.withOutputStream { OutputStream output ->\\n            output.write([1, 2, 3] as byte[])\\n        }\\n        file.withDataOutputStream { DataOutputStream output ->\\n            output.writeInt(0x01020304)\\n            output.writeUTF('groovy-nio')\\n        }\\n\\n        List<Byte> bytes = []\\n        file.eachByte { byte value ->\\n            bytes << value\\n        }\\n        List<Integer> chunkSizes = []\\n        file.eachByte(5) { byte[] buffer, Integer size ->\\n            chunkSizes << size\\n            assertThat(size).isBetween(1, 5)\\n            assertThat(buffer.length).isGreaterThanOrEqualTo(size)\\n        }\\n        List<Object> dataValues = file.withDataInputStream { DataInputStream input ->\\n            [input.readInt(), input.readUTF()]\\n        }\\n        Integer firstByte = file.withInputStream { InputStream input ->\\n            input.read()\\n        }\\n\\n        assertThat(dataValues).containsExactly(0x01020304, 'groovy-nio')\\n        assertThat(firstByte).isEqualTo(1)\\n        assertThat(bytes).isEqualTo(file.readBytes().collect { byte value -> value })\\n        assertThat(chunkSizes.sum()).isEqualTo(file.size() as Integer)\\n    }\\n\\n    @Test\\n    void filtersLinesIntoWritableAndWriterTargets() {\\n        Path file = tempDir.resolve('filter.txt')\\n        file.write('apple\\\\napricot\\\\nbanana\\\\navocado\\\\n', 'UTF-8')\\n\\n        StringWriter directWriter = new StringWriter()\\n        file.filterLine(directWriter, 'UTF-8') { String line ->\\n            line.startsWith('a')\\n        }\\n        StringWriter writableWriter = new StringWriter()\\n        file.filterLine('UTF-8') { String line ->\\n            line.endsWith('t') || line.endsWith('a')\\n        }.writeTo(writableWriter)\\n\\n        assertThat(directWriter.toString().readLines()).containsExactly('apple', 'apricot', 'avocado')\\n        assertThat(writableWriter.toString().readLines()).containsExactly('apricot', 'banana')\\n    }\\n\\n    @Test\\n    void createsParentDirectoriesTraversesAndMatchesFiles() {\\n        Path alpha = tempDir.resolve('root/alpha/a.txt').createParentDirectories()\\n        Path beta = tempDir.resolve('root/beta/b.log').createParentDirectories()\\n        Path skip = tempDir.resolve('root/skip/ignored.txt').createParentDirectories()\\n        alpha.text = 'a'\\n        beta.text = 'b'\\n        skip.text = 'skip'\\n        Path root = tempDir.resolve('root')\\n\\n        List<String> directDirectories = []\\n        root.eachDir { Path path ->\\n            directDirectories << path.fileName.toString()\\n        }\\n        List<String> recursiveDirectories = []\\n        root.eachDirRecurse { Path path ->\\n            recursiveDirectories << root.relativize(path).toString().replace('\\\\\\\\', '/')\\n        }\\n        List<String> recursiveFiles = []\\n        root.eachFileRecurse(FileType.FILES) { Path path ->\\n            recursiveFiles << root.relativize(path).toString().replace('\\\\\\\\', '/')\\n        }\\n        List<String> matchedTextFiles = []\\n        root.resolve('alpha').eachFileMatch(FileType.FILES, ~/.*\\\\.txt/) { Path path ->\\n            matchedTextFiles << path.fileName.toString()\\n        }\\n        List<String> traversedTextFiles = []\\n        root.traverse(\\n                type: FileType.FILES,\\n                nameFilter: ~/.*\\\\.txt/,\\n                preDir: { Path path ->\\n                    path.fileName.toString() == 'skip' ? FileVisitResult.SKIP_SUBTREE : FileVisitResult.CONTINUE\\n                },\\n                sort: { Path left, Path right -> left.fileName.toString() <=> right.fileName.toString() }\\n        ) { Path path ->\\n            traversedTextFiles << root.relativize(path).toString().replace('\\\\\\\\', '/')\\n        }\\n\\n        assertThat(directDirectories).containsExactlyInAnyOrder('alpha', 'beta', 'skip')\\n        assertThat(recursiveDirectories).containsExactlyInAnyOrder('alpha', 'beta', 'skip')\\n        assertThat(recursiveFiles).containsExactlyInAnyOrder('alpha/a.txt', 'beta/b.log', 'skip/ignored.txt')\\n        assertThat(matchedTextFiles).containsExactly('a.txt')\\n        assertThat(traversedTextFiles).containsExactly('alpha/a.txt')\\n    }\\n\\n    @Test\\n    void iteratesDirectFilesRenamesAndDeletesDirectories() {\\n        Path root = tempDir.resolve('operations')\\n        Files.createDirectories(root)\\n        Path source = root.resolve('source.txt')\\n        Path target = root.resolve('target.txt')\\n        Path nested = root.resolve('nested/child.txt').createParentDirectories()\\n        source.text = 'source'\\n        nested.text = 'child'\\n\\n        List<String> directFiles = []\\n        root.eachFile(FileType.FILES) { Path path ->\\n            directFiles << path.fileName.toString()\\n        }\\n        List<String> directTextFiles = []\\n        root.eachFileMatch(~/.*\\\\.txt/) { Path path ->\\n            directTextFiles << path.fileName.toString()\\n        }\\n        boolean renamed = source.renameTo(target.toUri())\\n        Path stringTarget = root.resolve('string-target.txt')\\n        boolean renamedWithString = target.renameTo(stringTarget.toString())\\n        boolean deleted = root.deleteDir()\\n\\n        assertThat(directFiles).containsExactly('source.txt')\\n        assertThat(directTextFiles).containsExactly('source.txt')\\n        assertThat(renamed).isTrue()\\n        assertThat(renamedWithString).isTrue()\\n        assertThat(deleted).isTrue()\\n        assertThat(Files.exists(root)).isFalse()\\n    }\\n}\\n\"}\n1663:[tool-call] end id=call_MGsAVjoJoTjijcWeVgSFfWFH|fc_0fa22a67994186750169ffe5ff6400819e9348d983590930e1 name=write args={\"path\": \"tests/src/org.apache.groovy/groovy-nio/4.0.24/src/test/groovy/org_apache_groovy/groovy_nio/Groovy_nioTest.groovy\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_groovy.groovy_nio\\n\\nimport groovy.io.FileType\\nimport groovy.io.FileVisitResult\\nimport groovy.lang.Writable\\nimport org.junit.jupiter.api.Test\\nimport org.junit.jupiter.api.io.TempDir\\n\\nimport java.nio.charset.StandardCharsets\\nimport java.nio.file.Files\\nimport java.nio.file.Path\\nimport java.util.regex.Pattern\\n\\nimport static org.assertj.core.api.Assertions.assertThat\\n\\npublic class Groovy_nioTest {\\n    @TempDir\\n    Path tempDir\\n\\n    @Test\\n    void readsTextByLineAndSplitsUsingPathExtensions() {\\n        Path file = tempDir.resolve('records.txt')\\n        file.write('alpha:1\\\\nβeta:2\\\\ngamma:3', 'UTF-8')\\n\\n        List<String> numberedLines = []\\n        Object lastLine = file.eachLine('UTF-8', 5) { String line, Integer number ->\\n            numberedLines << \\\"${number}:${line}\\\".toString()\\n            line\\n        }\\n\\n        List<List<String>> splitWithRegex = []\\n        file.splitEachLine(/:/, 'UTF-8') { List<String> parts ->\\n            splitWithRegex << parts\\n        }\\n        List<List<String>> splitWithPattern = []\\n        file.splitEachLine(Pattern.compile(':'), 'UTF-8') { List<String> parts ->\\n            splitWithPattern << parts\\n        }\\n\\n        assertThat(file.text).isEqualTo('alpha:1\\\\nβeta:2\\\\ngamma:3')\\n        assertThat(file.getText('UTF-8')).isEqualTo('alpha:1\\\\nβeta:2\\\\ngamma:3')\\n        assertThat(file.readLines()).containsExactly('alpha:1', 'βeta:2', 'gamma:3')\\n        assertThat(file.readLines('UTF-8')).containsExactly('alpha:1', 'βeta:2', 'gamma:3')\\n        assertThat(numberedLines).containsExactly('5:alpha:1', '6:βeta:2', '7:gamma:3')\\n        assertThat(lastLine).isEqualTo('gamma:3')\\n        assertThat(splitWithRegex).containsExactly(['alpha', '1'], ['βeta', '2'], ['gamma', '3'])\\n        assertThat(splitWithPattern).containsExactly(['alpha', '1'], ['βeta', '2'], ['gamma', '3'])\\n        assertThat(file.size()).isEqualTo(Files.size(file))\\n    }\\n\\n    @Test\\n    void writesAppendsAndCopiesTextAndBytes() {\\n        Path file = tempDir.resolve('append.txt')\\n\\n        file.text = 'start'\\n        file << '-leftShift'\\n        file.append(new StringReader('-reader'), 'UTF-8')\\n        StringWriter sourceWriter = new StringWriter()\\n        sourceWriter.write('-writer')\\n        file.append(sourceWriter, 'UTF-8')\\n        file.append('-object', 'UTF-8')\\n        file.append('-bytes'.getBytes(StandardCharsets.UTF_8))\\n        file.append(new ByteArrayInputStream('-stream'.getBytes(StandardCharsets.UTF_8)))\\n\\n        assertThat(new String(file.bytes, StandardCharsets.UTF_8))\\n                .isEqualTo('start-leftShift-reader-writer-object-bytes-stream')\\n        assertThat(new String(file.getBytes(), StandardCharsets.UTF_8))\\n                .isEqualTo('start-leftShift-reader-writer-object-bytes-stream')\\n\\n        Path copied = tempDir.resolve('copied.txt')\\n        copied.bytes = file.readBytes()\\n        assertThat(copied.getText('UTF-8')).isEqualTo(file.getText('UTF-8'))\\n    }\\n\\n    @Test\\n    void usesReadersWritersPrintWritersAndWritableViews() {\\n        Path file = tempDir.resolve('writers.txt')\\n\\n        file.withWriter('UTF-8') { BufferedWriter writer ->\\n            writer.write('one')\\n            writer.newLine()\\n        }\\n        file.withWriterAppend('UTF-8') { BufferedWriter writer ->\\n            writer.write('two')\\n            writer.newLine()\\n        }\\n        file.withPrintWriter('UTF-8') { PrintWriter writer ->\\n            writer.println('three')\\n        }\\n\\n        String firstLine = file.withReader('UTF-8') { BufferedReader reader ->\\n            reader.readLine()\\n        }\\n        StringWriter writableTarget = new StringWriter()\\n        Writable writable = file as Writable\\n        writable.writeTo(writableTarget)\\n        StringWriter encodedWritableTarget = new StringWriter()\\n        file.asWritable('UTF-8').writeTo(encodedWritableTarget)\\n\\n        assertThat(firstLine).isEqualTo('one')\\n        assertThat(file.readLines('UTF-8')).containsExactly('one', 'two', 'three')\\n        assertThat(writableTarget.toString().readLines()).containsExactly('one', 'two', 'three')\\n        assertThat(encodedWritableTarget.toString().readLines()).containsExactly('one', 'two', 'three')\\n    }\\n\\n    @Test\\n    void usesBinaryAndDataStreamHelpers() {\\n        Path file = tempDir.resolve('data.bin')\\n\\n        file.withOutputStream { OutputStream output ->\\n            output.write([1, 2, 3] as byte[])\\n        }\\n        file.withDataOutputStream { DataOutputStream output ->\\n            output.writeInt(0x01020304)\\n            output.writeUTF('groovy-nio')\\n        }\\n\\n        List<Byte> bytes = []\\n        file.eachByte { byte value ->\\n            bytes << value\\n        }\\n        List<Integer> chunkSizes = []\\n        file.eachByte(5) { byte[] buffer, Integer size ->\\n            chunkSizes << size\\n            assertThat(size).isBetween(1, 5)\\n            assertThat(buffer.length).isGreaterThanOrEqualTo(size)\\n        }\\n        List<Object> dataValues = file.withDataInputStream { DataInputStream input ->\\n            [input.readInt(), input.readUTF()]\\n        }\\n        Integer firstByte = file.withInputStream { InputStream input ->\\n            input.read()\\n        }\\n\\n        assertThat(dataValues).containsExactly(0x01020304, 'groovy-nio')\\n        assertThat(firstByte).isEqualTo(1)\\n        assertThat(bytes).isEqualTo(file.readBytes().collect { byte value -> value })\\n        assertThat(chunkSizes.sum()).isEqualTo(file.size() as Integer)\\n    }\\n\\n    @Test\\n    void filtersLinesIntoWritableAndWriterTargets() {\\n        Path file = tempDir.resolve('filter.txt')\\n        file.write('apple\\\\napricot\\\\nbanana\\\\navocado\\\\n', 'UTF-8')\\n\\n        StringWriter directWriter = new StringWriter()\\n        file.filterLine(directWriter, 'UTF-8') { String line ->\\n            line.startsWith('a')\\n        }\\n        StringWriter writableWriter = new StringWriter()\\n        file.filterLine('UTF-8') { String line ->\\n            line.endsWith('t') || line.endsWith('a')\\n        }.writeTo(writableWriter)\\n\\n        assertThat(directWriter.toString().readLines()).containsExactly('apple', 'apricot', 'avocado')\\n        assertThat(writableWriter.toString().readLines()).containsExactly('apricot', 'banana')\\n    }\\n\\n    @Test\\n    void createsParentDirectoriesTraversesAndMatchesFiles() {\\n        Path alpha = tempDir.resolve('root/alpha/a.txt').createParentDirectories()\\n        Path beta = tempDir.resolve('root/beta/b.log').createParentDirectories()\\n        Path skip = tempDir.resolve('root/skip/ignored.txt').createParentDirectories()\\n        alpha.text = 'a'\\n        beta.text = 'b'\\n        skip.text = 'skip'\\n        Path root = tempDir.resolve('root')\\n\\n        List<String> directDirectories = []\\n        root.eachDir { Path path ->\\n            directDirectories << path.fileName.toString()\\n        }\\n        List<String> recursiveDirectories = []\\n        root.eachDirRecurse { Path path ->\\n            recursiveDirectories << root.relativize(path).toString().replace('\\\\\\\\', '/')\\n        }\\n        List<String> recursiveFiles = []\\n        root.eachFileRecurse(FileType.FILES) { Path path ->\\n            recursiveFiles << root.relativize(path).toString().replace('\\\\\\\\', '/')\\n        }\\n        List<String> matchedTextFiles = []\\n        root.resolve('alpha').eachFileMatch(FileType.FILES, ~/.*\\\\.txt/) { Path path ->\\n            matchedTextFiles << path.fileName.toString()\\n        }\\n        List<String> traversedTextFiles = []\\n        root.traverse(\\n                type: FileType.FILES,\\n                nameFilter: ~/.*\\\\.txt/,\\n                preDir: { Path path ->\\n                    path.fileName.toString() == 'skip' ? FileVisitResult.SKIP_SUBTREE : FileVisitResult.CONTINUE\\n                },\\n                sort: { Path left, Path right -> left.fileName.toString() <=> right.fileName.toString() }\\n        ) { Path path ->\\n            traversedTextFiles << root.relativize(path).toString().replace('\\\\\\\\', '/')\\n        }\\n\\n        assertThat(directDirectories).containsExactlyInAnyOrder('alpha', 'beta', 'skip')\\n        assertThat(recursiveDirectories).containsExactlyInAnyOrder('alpha', 'beta', 'skip')\\n        assertThat(recursiveFiles).containsExactlyInAnyOrder('alpha/a.txt', 'beta/b.log', 'skip/ignored.txt')\\n        assertThat(matchedTextFiles).containsExactly('a.txt')\\n        assertThat(traversedTextFiles).containsExactly('alpha/a.txt')\\n    }\\n\\n    @Test\\n    void iteratesDirectFilesRenamesAndDeletesDirectories() {\\n        Path root = tempDir.resolve('operations')\\n        Files.createDirectories(root)\\n        Path source = root.resolve('source.txt')\\n        Path target = root.resolve('target.txt')\\n        Path nested = root.resolve('nested/child.txt').createParentDirectories()\\n        source.text = 'source'\\n        nested.text = 'child'\\n\\n        List<String> directFiles = []\\n        root.eachFile(FileType.FILES) { Path path ->\\n            directFiles << path.fileName.toString()\\n        }\\n        List<String> directTextFiles = []\\n        root.eachFileMatch(~/.*\\\\.txt/) { Path path ->\\n            directTextFiles << path.fileName.toString()\\n        }\\n        boolean renamed = source.renameTo(target.toUri())\\n        Path stringTarget = root.resolve('string-target.txt')\\n        boolean renamedWithString = target.renameTo(stringTarget.toString())\\n        boolean deleted = root.deleteDir()\\n\\n        assertThat(directFiles).containsExactly('source.txt')\\n        assertThat(directTextFiles).containsExactly('source.txt')\\n        assertThat(renamed).isTrue()\\n        assertThat(renamedWithString).isTrue()\\n        assertThat(deleted).isTrue()\\n        assertThat(Files.exists(root)).isFalse()\\n    }\\n}\\n\"}\n1664:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0fa22a67994186750169ffe5f692b4819e80b35e99e1a1d1d4\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABp_-X_6p6AHmJqrOXbITCae0Nk1aA_7Qh7xUgO3S1lLtSDnPlHblIakziLtbHHAgt3nTDKVXE4pcoeA7IQcsi9nb206vZkAGKpjEuCSbLUPmYuCY1AFHWs1yvGcIS3a4OPPnnL_wtLbbB2ltC0Q7fa3S8_nxvcX2LXUrlLopMOvYU4UIXCXPZ63LM6gETYCjSoRjOch9DBw6u59kkisExelcfmipxNAslRRuy8ip8zeQuILS-cAn6MD5Gieo7G2XyhCdsXlxfyY6BQXu4Roywmem28PxpD42kBp09Z1SCMoegew6NvnU7POLcdsYf6_-QLhyVYwT3io5coBFfanqRZ5FkO19jTGNHEHj20vf9OWSGdYdXZjJCcF5CnY_yrTHiiHWv5Yutw502Ic4LqF7F2LvzQzR3OSseu-OONcgqZvW8bTPwwG_Om1zKMlFbORYwSR_Tmb7ZgpIOsaTqlhBCACIQiZvb3FXgqRVdpG2e3rS4zp3wPruiDcdJQnLrFopMJ022k5j7-F-SV9kwYPojQdwlEnYXcJRd6ItnqeO1i7Q2BOMQKaeWTFvzIvBHpliEFAtwDZweTfByCU69t66acTMZmmnhW9DtsKlov_LW8no8K4YaiL7idjyfZ6k97MJa5CCRtfDzZmEY1jRaowP_sSlKuScly7nm7gscEte3QwJ6QVvEYsw14VjjU5Rq-MUVXlDMCahfcnme7a9Pd6Qh0OOwljuGbzGz7FHor6yc1Ir_MVdS4vutZnubNZS6SLvjI679HDmOPHySSlmaS9Y8djAwc8aJhy4ym-kygX4Af5ycY5bNopNB0gyDSHiGqgorSWwljPgt7Nr-4MD9AgOYTd4lSOtdw0iWbVDxBmiIuF0KceROXSDX_Kpl_Eck29QS2SkzD0p2qrtVUIzJhtr95DD2W8LJ7Gc9jtN5v5BapaQe8WfiInEdqxakjR2Rovs8WcCnID80SxzRfkXPtIyJrAAdidNvpAmXA1T3iqa3xYt_41BnuiF4jqUbSnyegpLQk0icwi1udgGJcuu37UiRzi6ssluguOvNVEG3du6Lv9FoLUezG9MpwQG3k9MsRKo1ddmAwabTENyXBunoIGU9xO7s8