.apache.groovy/groovy-nio/4.0.24/src/test/groovy/org_apache_groovy/groovy_nio/Groovy_nioTest.groovy\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_apache_groovy.groovy_nio\\n\\nimport groovy.io.FileType\\nimport groovy.lang.Writable\\nimport org.junit.jupiter.api.Test\\nimport org.junit.jupiter.api.io.TempDir\\n\\nimport java.nio.file.Files\\nimport java.nio.file.Path\\n\\nimport static java.nio.charset.StandardCharsets.UTF_8\\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals\\nimport static org.junit.jupiter.api.Assertions.assertEquals\\nimport static org.junit.jupiter.api.Assertions.assertFalse\\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf\\nimport static org.junit.jupiter.api.Assertions.assertSame\\nimport static org.junit.jupiter.api.Assertions.assertTrue\\n\\npublic class Groovy_nioTest {\\n    @Test\\n    void readsWritesAndTransformsTextUsingPathExtensionMethods(@TempDir Path tempDir) {\\n        Path file = tempDir.resolve('sample.txt')\\n\\n        file.text = 'alpha\\\\nbeta\\\\ngamma\\\\n'\\n\\n        assertEquals('alpha\\\\nbeta\\\\ngamma\\\\n', file.text)\\n        assertEquals(['alpha', 'beta', 'gamma'], file.readLines())\\n        assertEquals(17L, file.size())\\n\\n        List<String> numberedLines = []\\n        String eachLineResult = file.eachLine(10) { String line, int number ->\\n            numberedLines << \\\"${number}:${line}\\\".toString()\\n            'finished'\\n        }\\n        assertEquals('finished', eachLineResult)\\n        assertEquals(['10:alpha', '11:beta', '12:gamma'], numberedLines)\\n\\n        Path csv = tempDir.resolve('data.csv')\\n        csv.write('name|value\\\\none|1\\\\ntwo|2\\\\n', 'UTF-8')\\n        List<List<String>> rows = []\\n        csv.splitEachLine('\\\\\\\\|', 'UTF-8') { String[] parts ->\\n            rows << parts.toList()\\n        }\\n        assertEquals([['name', 'value'], ['one', '1'], ['two', '2']], rows)\\n\\n        StringWriter filtered = new StringWriter()\\n        file.filterLine(filtered, 'UTF-8') { String line -> line.startsWith('g') }\\n        assertTrue(filtered.toString().contains('gamma'))\\n        assertFalse(filtered.toString().contains('alpha'))\\n\\n        Writable writable = file.filterLine { String line -> line.contains('a') }\\n        StringWriter writableTarget = new StringWriter()\\n        assertSame(writableTarget, writable.writeTo(writableTarget))\\n        assertTrue(writableTarget.toString().contains('alpha'))\\n        assertTrue(writableTarget.toString().contains('gamma'))\\n    }\\n\\n    @Test\\n    void appendsAndStreamsBinaryContentUsingPathExtensionMethods(@TempDir Path tempDir) {\\n        Path bytes = tempDir.resolve('bytes.bin')\\n\\n        bytes.bytes = [1, 2, 3] as byte[]\\n        assertArrayEquals([1, 2, 3] as byte[], bytes.bytes)\\n        assertArrayEquals([1, 2, 3] as byte[], bytes.readBytes())\\n\\n        bytes << ([4, 5] as byte[])\\n        bytes << new ByteArrayInputStream([6, 7] as byte[])\\n        assertArrayEquals([1, 2, 3, 4, 5, 6, 7] as byte[], bytes.bytes)\\n\\n        List<Integer> values = []\\n        bytes.eachByte { int value -> values << value }\\n        assertEquals([1, 2, 3, 4, 5, 6, 7], values)\\n\\n        List<String> chunks = []\\n        bytes.eachByte(3) { byte[] buffer, int count ->\\n            chunks << Arrays.toString(Arrays.copyOf(buffer, count))\\n        }\\n        assertEquals(['[1, 2, 3]', '[4, 5, 6]', '[7]'], chunks)\\n\\n        Path copied = tempDir.resolve('copied.bin')\\n        copied.withOutputStream { OutputStream output -> output.write(bytes.bytes) }\\n        int firstByte = copied.withInputStream { InputStream input -> input.read() }\\n        assertEquals(1, firstByte)\\n\\n        Path data = tempDir.resolve('data.bin')\\n        data.withDataOutputStream { DataOutputStream output ->\\n            output.writeInt(123456)\\n            output.writeUTF('groovy-nio')\\n        }\\n        Map<String, Object> decoded = data.withDataInputStream { DataInputStream input ->\\n            [number: input.readInt(), label: input.readUTF()]\\n        }\\n        assertEquals([number: 123456, label: 'groovy-nio'], decoded)\\n    }\\n\\n    @Test\\n    void createsReadersWritersAndPrintWritersForPaths(@TempDir Path tempDir) {\\n        Path file = tempDir.resolve('io.txt')\\n\\n        file.withWriter('UTF-8') { Writer writer -> writer.write('first') }\\n        file.withWriterAppend('UTF-8') { Writer writer -> writer.write('\\\\nsecond') }\\n        assertEquals(['first', 'second'], file.readLines('UTF-8'))\\n\\n        String content = file.withReader('UTF-8') { Reader reader -> reader.text }\\n        assertEquals('first\\\\nsecond', content)\\n\\n        file.withPrintWriter('UTF-8') { PrintWriter writer ->\\n            writer.println('printed')\\n            writer.print('tail')\\n        }\\n        assertEquals('printed\\\\ntail', file.getText('UTF-8').replace('\\\\r\\\\n', '\\\\n'))\\n\\n        BufferedWriter writer = file.newWriter('UTF-8', true)\\n        try {\\n            writer.write('\\\\nnew-writer')\\n        } finally {\\n            writer.close()\\n        }\\n        BufferedReader reader = file.newReader('UTF-8')\\n        try {\\n            assertEquals('printed', reader.readLine())\\n        } finally {\\n            reader.close()\\n        }\\n        assertTrue(file.getText('UTF-8').contains('new-writer'))\\n    }\\n\\n    @Test\\n    void traversesAndMatchesDirectoryContentsUsingPathExtensionMethods(@TempDir Path tempDir) {\\n        Path root = tempDir.resolve('root')\\n        Path child = root.resolve('child')\\n        Path other = root.resolve('other')\\n        Files.createDirectories(child)\\n        Files.createDirectories(other)\\n        child.resolve('alpha.txt').text = 'alpha'\\n        child.resolve('skip.log').text = 'skip'\\n        other.resolve('beta.txt').text = 'beta'\\n        root.resolve('top.txt').text = 'top'\\n\\n        List<String> immediateFiles = []\\n        root.eachFile(FileType.FILES) { Path path -> immediateFiles << path.fileName.toString() }\\n        assertEquals(['top.txt'], immediateFiles.sort())\\n\\n        List<String> immediateDirs = []\\n        root.eachDir { Path path -> immediateDirs << path.fileName.toString() }\\n        assertEquals(['child', 'other'], immediateDirs.sort())\\n\\n        List<String> recursiveFiles = []\\n        root.eachFileRecurse(FileType.FILES) { Path path -> recursiveFiles << root.relativize(path).toString() }\\n        assertEquals(['child/alpha.txt', 'child/skip.log', 'other/beta.txt', 'top.txt'], normalizeAndSort(recursiveFiles))\\n\\n        List<String> recursiveDirs = []\\n        root.eachDirRecurse { Path path -> recursiveDirs << root.relativize(path).toString() }\\n        assertEquals(['child', 'other'], normalizeAndSort(recursiveDirs))\\n\\n        List<String> matchedFiles = []\\n        child.eachFileMatch(FileType.FILES, ~/.*\\\\.txt/) { Path path -> matchedFiles << path.fileName.toString() }\\n        assertEquals(['alpha.txt'], matchedFiles)\\n\\n        List<String> matchedDirs = []\\n        root.eachDirMatch(~/o.*/) { Path path -> matchedDirs << path.fileName.toString() }\\n        assertEquals(['other'], matchedDirs)\\n\\n        List<String> traversed = []\\n        root.traverse(type: FileType.FILES, nameFilter: ~/.*\\\\.txt/) { Path path ->\\n            traversed << root.relativize(path).toString()\\n        }\\n        assertEquals(['child/alpha.txt', 'other/beta.txt', 'top.txt'], normalizeAndSort(traversed))\\n    }\\n\\n    @Test\\n    void managesDirectoriesRenamesAndWritablePathDelegation(@TempDir Path tempDir) {\\n        Path nested = tempDir.resolve('parents/child/file.txt')\\n        assertSame(nested, nested.createParentDirectories()