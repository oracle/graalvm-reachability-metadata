\t        assertArrayEquals([1, 2, 3, 4, 5, 6, 7] as byte[], NioExtensions.getBytes(bytes))\n    72\t\n    73\t        List<Integer> values = []\n    74\t        NioExtensions.eachByte(bytes) { value -> values << ((Number) value).intValue() }\n    75\t        assertEquals([1, 2, 3, 4, 5, 6, 7], values)\n    76\t\n    77\t        List<String> chunks = []\n    78\t        NioExtensions.eachByte(bytes, 3) { buffer, count ->\n    79\t            chunks << Arrays.toString(Arrays.copyOf(buffer, count))\n    80\t        }\n    81\t        assertEquals(['[1, 2, 3]', '[4, 5, 6]', '[7]'], chunks)\n    82\t\n    83\t        Path copied = tempDir.resolve('copied.bin')\n    84\t        NioExtensions.withOutputStream(copied) { copiedOutput -> copiedOutput.write(NioExtensions.getBytes(bytes)) }\n    85\t        int firstByte = NioExtensions.withInputStream(copied) { copiedInput -> copiedInput.read() }\n    86\t        assertEquals(1, firstByte)\n    87\t\n    88\t        Path data = tempDir.resolve('data.bin')\n    89\t        NioExtensions.withDataOutputStream(data) { dataOutput ->\n    90\t            dataOutput.writeInt(123456)\n    91\t            dataOutput.writeUTF('groovy-nio')\n    92\t        }\n    93\t        Map<String, Object> decoded = NioExtensions.withDataInputStream(data) { dataInput ->\n    94\t            [number: dataInput.readInt(), label: dataInput.readUTF()]\n    95\t        }\n    96\t        assertEquals([number: 123456, label: 'groovy-nio'], decoded)\n    97\t    }\n    98\t\n    99\t    @Test\n   100\t    void createsReadersWritersAndPrintWritersForPaths(@TempDir Path tempDir) {\n   101\t        Path file = tempDir.resolve('io.txt')\n   102\t\n   103\t        NioExtensions.withWriter(file, 'UTF-8') { firstWriter -> firstWriter.write('first') }\n   104\t        NioExtensions.withWriterAppend(file, 'UTF-8') { secondWriter -> secondWriter.write('\\nsecond') }\n   105\t        assertEquals(['first', 'second'], NioExtensions.readLines(file, 'UTF-8'))\n   106\t\n   107\t        String content = NioExtensions.withReader(file, 'UTF-8') { contentReader -> contentReader.text }\n   108\t        assertEquals('first\\nsecond', content)\n   109\t\n   110\t        NioExtensions.withPrintWriter(file, 'UTF-8') { printWriter ->\n   111\t            printWriter.println('printed')\n   112\t            printWriter.print('tail')\n   113\t        }\n   114\t        assertEquals('printed\\ntail', NioExtensions.getText(file, 'UTF-8').replace('\\r\\n', '\\n'))\n   115\t\n   116\t        BufferedWriter bufferedWriter = NioExtensions.newWriter(file, 'UTF-8', true)\n   117\t        try {\n   118\t            bufferedWriter.write('\\nnew-writer')\n   119\t        } finally {\n   120\t            bufferedWriter.close()\n   121\t        }\n   122\t        BufferedReader bufferedReader = NioExtensions.newReader(file, 'UTF-8')\n   123\t        try {\n   124\t            assertEquals('printed', bufferedReader.readLine())\n   125\t        } finally {\n   126\t            bufferedReader.close()\n   127\t        }\n   128\t        assertTrue(NioExtensions.getText(file, 'UTF-8').contains('new-writer'))\n   129\t    }\n   130\t\n   131\t    @Test\n   132\t    void traversesAndMatchesDirectoryContentsUsingPathExtensionMethods(@TempDir Path tempDir) {\n   133\t        Path root = tempDir.resolve('root')\n   134\t        Path child = root.resolve('child')\n   135\t        Path other = root.resolve('other')\n   136\t        Files.createDirectories(child)\n   137\t        Files.createDirectories(other)\n   138\t        NioExtensions.setText(child.resolve('alpha.txt'), 'alpha')\n   139\t        NioExtensions.setText(child.resolve('skip.log'), 'skip')\n   140\t        NioExtensions.setText(other.resolve('beta.txt'), 'beta')\n   141\t        NioExtensions.setText(root.resolve('top.txt'), 'top')\n   142\t\n   143\t        List<String> immediateFiles = []\n   144\t        NioExtensions.eachFile(root, FileType.FILES) { immediateFile -> immediateFiles << immediateFile.fileName.toString() }\n   145\t        assertEquals(['top.txt'], immediateFiles.sort())\n   146\t\n   147\t        List<String> immediateDirs = []\n   148\t        NioExtensions.eachDir(root) { immediateDir -> immediateDirs << immediateDir.fileName.toString() }\n   149\t        assertEquals(['child', 'other'], immediateDirs.sort())\n   150\t\n   151\t        List<String> recursiveFiles = []\n   152\t        NioExtensions.eachFileRecurse(root, FileType.FILES) { recursiveFile ->\n   153\t            recursiveFiles << root.relativize(recursiveFile).toString()\n   154\t        }\n   155\t        List<String> expectedRecursiveFiles = ['child/alpha.txt', 'child/skip.log', 'other/beta.txt', 'top.txt']\n   156\t        assertEquals(expectedRecursiveFiles, normalizeAndSort(recursiveFiles))\n   157\t\n   158\t        List<String> matchedFiles = []\n   159\t        NioExtensions.eachFileMatch(child, FileType.FILES, ~/.*\\.txt/) { matchedFile ->\n   160\t            matchedFiles << matchedFile.fileName.toString()\n   161\t        }\n   162\t        assertEquals(['alpha.txt'], matchedFiles)\n   163\t\n   164\t        List<String> traversed = []\n   165\t        NioExtensions.traverse(root, [type: FileType.FILES, nameFilter: ~/.*\\.txt/]) { traversedFile ->\n   166\t            traversed << root.relativize(traversedFile).toString()\n   167\t        }\n   168\t        assertEquals(['child/alpha.txt', 'other/beta.txt', 'top.txt'], normalizeAndSort(traversed))\n   169\t    }\n   170\t\n   171\t    @Test\n   172\t    void managesDirectoriesAndRenamesUsingPathExtensionMethods(@TempDir Path tempDir) {\n   173\t        Path nested = tempDir.resolve('parents/child/file.txt')\n   174\t        assertSame(nested, NioExtensions.createParentDirectories(nested))\n   175\t        NioExtensions.setText(nested, 'created')\n   176\t        assertTrue(Files.isDirectory(nested.parent))\n   177\t        assertEquals('created', NioExtensions.getText(nested))\n   178\t\n   179\t        Path original = tempDir.resolve('original.txt')\n   180\t        Path renamed = tempDir.resolve('renamed.txt')\n   181\t        NioExtensions.setText(original, 'rename me')\n   182\t        assertTrue(NioExtensions.renameTo(original, renamed.toString()))\n   183\t        assertFalse(Files.exists(original))\n   184\t        assertEquals('rename me', NioExtensions.getText(renamed))\n   185\t\n   186\t        Path deleteRoot = tempDir.resolve('delete-me')\n   187\t        Files.createDirectories(deleteRoot.resolve('nested'))\n   188\t        NioExtensions.setText(deleteRoot.resolve('nested/file.txt'), 'remove')\n   189\t        assertTrue(NioExtensions.deleteDir(deleteRoot))\n   190\t        assertFalse(Files.exists(deleteRoot))\n   191\t        assertTrue(NioExtensions.deleteDir(tempDir.resolve('missing')))\n   192\t        assertFalse(NioExtensions.deleteDir(renamed))\n   193\t    }\n   194\t\n   195\t    private static List<String> normalizeAndSort(List<String> values) {\n   196\t        values.collect { pathText -> pathText.replace(File.separator, '/') }.sort()\n   197\t    }\n   198\t}\n","exit_code":0,"status":"completed"}}
