\n\\nimport java.io.BufferedInputStream\\nimport java.io.BufferedOutputStream\\nimport java.io.DataInputStream\\nimport java.io.DataOutputStream\\nimport java.io.PrintWriter\\nimport java.nio.file.Path\\n\\nimport static org.junit.jupiter.api.Assertions.assertArrayEquals\\nimport static org.junit.jupiter.api.Assertions.assertEquals\\nimport static org.junit.jupiter.api.Assertions.assertTrue\\n\\npublic class StreamFactoryExtensionsTest {\\n    @Test\\n    void createsStandaloneBinaryStreamsForPaths(@TempDir Path tempDir) {\\n        Path binary = tempDir.resolve('binary.dat')\\n        byte[] expectedBytes = [10, 20, 30, 40] as byte[]\\n\\n        BufferedOutputStream output = NioExtensions.newOutputStream(binary)\\n        try {\\n            output.write(expectedBytes)\\n        } finally {\\n            output.close()\\n        }\\n\\n        byte[] actualBytes = new byte[expectedBytes.length]\\n        BufferedInputStream input = NioExtensions.newInputStream(binary)\\n        try {\\n            assertEquals(expectedBytes.length, input.read(actualBytes))\\n            assertEquals(-1, input.read())\\n        } finally {\\n            input.close()\\n        }\\n        assertArrayEquals(expectedBytes, actualBytes)\\n    }\\n\\n    @Test\\n    void createsStandaloneDataStreamsForPaths(@TempDir Path tempDir) {\\n        Path data = tempDir.resolve('typed-values.dat')\\n\\n        DataOutputStream dataOutput = NioExtensions.newDataOutputStream(data)\\n        try {\\n            dataOutput.writeBoolean(true)\\n            dataOutput.writeLong(987654321L)\\n            dataOutput.writeUTF('stream factory')\\n        } finally {\\n            dataOutput.close()\\n        }\\n\\n        DataInputStream dataInput = NioExtensions.newDataInputStream(data)\\n        try {\\n            assertTrue(dataInput.readBoolean())\\n            assertEquals(987654321L, dataInput.readLong())\\n            assertEquals('stream factory', dataInput.readUTF())\\n        } finally {\\n            dataInput.close()\\n        }\\n    }\\n\\n    @Test\\n    void createsStandalonePrintWritersForPaths(@TempDir Path tempDir) {\\n        Path text = tempDir.resolve('print-writer.txt')\\n\\n        PrintWriter printWriter = NioExtensions.newPrintWriter(text, 'UTF-8')\\n        try {\\n            printWriter.println('printed')\\n            printWriter.print('tail')\\n        } finally {\\n            printWriter.close()\\n        }\\n\\n        assertEquals('printed\\\\ntail', NioExtensions.getText(text, 'UTF-8').replace('\\\\r\\\\n', '\\\\n'))\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 562, \"output\": 1233, \"cacheRead\": 66048, \"cacheWrite\": 0, \"totalTokens\": 67843, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1779512879007, \"responseId\": \"resp_002e273752b5cc99016a113630e75481949fcae200b9756653\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_TjoS8l9vsrttD7C7RNop1Lyo|fc_002e273752b5cc99016a113639492c8194a4bf58312cf22cac\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 2783 bytes to tests/src/org.apache.groovy/groovy-nio/4.0.24/src/test/groovy/org_apache_groovy/groovy_nio/StreamFactoryExtensionsTest.groovy\"}], \"isError\": false, \"timestamp\": 1779512893066}]}\n 28657\t[recv] {\"type\": \"turn_start\"}\n 28658\t[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"assistant\", \"content\": [], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"totalTokens\": 0, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"stop\", \"timestamp\": 1779512893073}}\n 28659\t[assistant-event] thinking_start\n 28660\t[thinking] **Finalizing plans**\n 2866