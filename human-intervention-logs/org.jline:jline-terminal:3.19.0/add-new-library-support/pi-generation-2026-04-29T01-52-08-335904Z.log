rrent();\n                    consoleOutput = true;\n                } catch (Exception e) {\n                    Log.debug(\"ExecPty.current(): \", e);\n\n[46 more lines in file. Use offset=561 to continue.]"}], "isError": false, "timestamp": 1777427459881}]}
