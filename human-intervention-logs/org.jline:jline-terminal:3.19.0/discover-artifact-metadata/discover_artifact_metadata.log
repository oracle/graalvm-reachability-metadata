                            <configuration>
                                <executable>gpg</executable>
                                <gpgArguments>
                                    <arg>--pinentry-mode</arg>
                                    <arg>loopback</arg>
                                </gpgArguments>
                                <passphrase>${gpg.passphrase}</passphrase>
