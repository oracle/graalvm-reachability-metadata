                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.8.1</version>
                    <configuration>
                        <showWarnings>true</showWarnings>
                        <compilerArgs>
                            <arg>-Xlint:all,-options</arg>
                            <arg>-Werror</arg>
                            <arg>-profile</arg>
                            <arg>compact1</arg>
                        </compilerArgs>
                        <fork>true</fork>
                    </configuration>
                </plugin>

