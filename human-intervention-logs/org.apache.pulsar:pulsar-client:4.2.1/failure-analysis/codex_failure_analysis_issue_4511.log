: \\n155:         @Override\\n156:         public DnsResolverConfig maxTtl(int maxTtl) {\\n157:             this.maxTtl = maxTtl;\\n158:             return this;\\n159:         }\\n160: \\n161:         @Override\\n162:         public DnsResolverConfig negativeTtl(int negativeTtl) {\\n163:             this.negativeTtl = negativeTtl;\\n164:             return this;\\n165:         }\\n166: \\n167:         @Override\\n168:         public DnsResolverConfig queryTimeoutMillis(long queryTimeoutMillis) {\\n169:             this.queryTimeoutMillis = queryTimeoutMillis;\\n170:             return this;\\n171:         }\\n172: \\n173:         @Override\\n174:         public DnsResolverConfig traceEnabled(boolean traceEnabled) {\\n175:             this.traceEnabled = traceEnabled;\\n176:             return this;\\n177:         }\\n178: \\n179:         @Override\\n180:         public DnsResolverConfig tcpFallbackEnabled(boolean tcpFallbackEnabled) {\\n181:             this.tcpFallbackEnabled = tcpFallbackEnabled;\\n182:             return this;\\n183:         }\\n184: \\n185:         @Override\\n186:         public DnsResolverConfig tcpFallbackOnTimeoutEnabled(boolean tcpFallbackOnTimeoutEnabled) {\\n187:             this.tcpFallbackOnTimeoutEnabled = tcpFallbackOnTimeoutEnabled;\\n188:             return this;\\n189:         }\\n190: \\n191:         @Override\\n192:         public DnsResolverConfig ndots(int ndots) {\\n193:             this.ndots = ndots;\\n194:             return this;\\n195:         }\\n196: \\n197:         @Override\\n198:         public DnsResolverConfig searchDomains(Iterable<String> searchDomains) {\\n199:             this.searchDomains = Lists.newArrayList(searchDomains);\\n200:             return this;\\n201:         }\\n202:     }\\n203: \\n204:     @Override\\n205:     public PulsarClientSharedResourcesBuilder resourceTypes(\\n206:             PulsarClientSharedResources.SharedResource... sharedResource) {\\n207:         if (shareConfigured) {\\n208:             throw new IllegalStateException(\\\"Cannot set resourceTypes when shareConfigured() has already been called\\\");\\n209:         }\\n210:         return resourceTypes(List.of(sharedResource));\\n211:     }\\n212: \\n213:     @Override\\n214:     public PulsarClientSharedResourcesBuilder resourceTypes(\\n215:             Collection<PulsarClientSharedResources.SharedResource> sharedResource) {\\n216:         if (shareConfigured) {\\n217:             throw new IllegalStateException(\\\"Cannot set resourceTypes when shareConfigured() has already been called\\\");\\n218:         }\\n219:         sharedResources.addAll(sharedResource);\\n220:         return this;\\n221:     }\\n222: \\n223:     @Override\\n224:     public PulsarClientSharedResourcesBuilder shareConfigured() {\\n225:         if (!sharedResources.isEmpty()) {\\n226:             throw new IllegalStateException(\\\"Cannot use shareConfigured() when resourceTypes has already been set\\\");\\n227:         }\\n228:         shareConfigured = true;\\n229:         return this;\\n230:     }\\n231: \\n232:     @SuppressWarnings(\\\"unchecked\\\")\\n233:     private <T extends ResourceConfig> T getOrCreateConfig(PulsarClientSharedResources.SharedResource sharedResource) {\\n234:         return (T) resourceConfigs.computeIfAbsent(sharedResource, k -> {\\n235:             switch (sharedResource.getType()) {\\n236:                 case EventLoopGroup:\\n237:                     return new EventLoopResourceConfig();\\n238:                 case DnsResolver:\\n239:                     return new DnsResolverResourceConfig();\\n240:                 case ThreadPool:\\n241:                     return new ThreadPoolResourceConfig();\\n242:                 case Timer:\\n243:                     return new TimerResourceConfig();\\n244:                 default:\\n245:                     throw new IllegalArgumentException(\\\"Unknown resource type: \\\" + sharedResource.getType());\\n246:             }\\n247:         });\\n248:     }\\n249: \\n250:     @Override\\n251:     public PulsarClientSharedResourcesBuilder configureThreadPool(\\n252:             PulsarClientSharedResources.SharedResource sharedResource, Consumer<ThreadPoolConfig<?>> configurer) {\\n253:         if (sharedResource.getType() != PulsarClientSharedResources.SharedResourceType.ThreadPool) {\\n254:             throw new IllegalArgumentException(\\\"The shared resource \\\" + sharedResource + \\\" doesn't support thread pool\\\"\\n255:                     + \\\" configuration\\\");\\n256:         }\\n257:         configurer.accept(getOrCreateConfig(sharedResource));\\n258:         return this;\\n259:     }\\n--- pulsar-client-api/src/main/java/org/apache/pulsar/client/api/PulsarClientSharedResources.java\\n1: /*\\n2:  * Licensed to the Apache Software Foundation (ASF) under one\\n3:  * or more contributor license agreements.  See the NOTICE file\\n4:  * distributed with this work for additional information\\n5:  * regarding copyright ownership.  The ASF licenses this file\\n6:  * to you under the Apache License, Version 2.0 (the\\n7:  * \\\"License\\\"); you may not use this file except in compliance\\n8:  * with the License.  You may obtain a copy of the License at\\n9:  *\\n10:  *   http://www.apache.org/licenses/LICENSE-2.0\\n11:  *\\n12:  * Unless required by applicable law or agreed to in writing,\\n13:  * software distributed under the License is distributed on an\\n14:  * \\\"AS IS\\\" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY\\n15:  * KIND, either express or implied.  See the License for the\\n16:  * specific language governing permissions and limitations\\n17:  * under the License.\\n18:  */\\n19: package org.apache.pulsar.client.api;\\n20: \\n21: import java.util.Set;\\n22: import org.apache.pulsar.client.internal.DefaultImplementation;\\n23: \\n24: /**\\n25:  * Manages shared resources across multiple PulsarClient instances to optimize resource utilization.\\n26:  * This interface provides access to common resources such as thread pools and DNS resolver/cache\\n27:  * that can be shared between multiple PulsarClient instances.\\n28:  *\\n29:  * This allows creating a large number of PulsarClient instances in a single JVM without wasting resources.\\n30:  * Sharing the DNS resolver and cache will help reduce the number of DNS lookups performed by the clients\\n31:  * and improve latency and reduce load on the DNS servers.\\n32:  *\\n33:  * <p>Key features:\\n34:  * <ul>\\n35:  *   <li>Thread pool sharing for various Pulsar operations (IO, timer, lookup, etc.)</li>\\n36:  *   <li>Shared DNS resolver and cache</li>\\n37:  *   <li>Resource lifecycle management</li>\\n38:  * </ul>\\n39:  *\\n40:  * <p>Usage example:\\n41:  * <pre>{@code\\n42:  * // To share all possible resources across multiple PulsarClient instances\\n43:  * PulsarClientSharedResources sharedResources = PulsarClientSharedResources.builder()\\n44:  *     .build();\\n45:  * // Use these resources with multiple PulsarClient instances\\n46:  * PulsarClient client1 = PulsarClient.builder().sharedResources(sharedResources).build();\\n47:  * PulsarClient client2 = PulsarClient.builder().sharedResources(sharedResources).build();\\n48:  * client1.close();\\n49:  * client2.close();\\n50:  * sharedResources.close();\\n51:  * }</pre>\\n52:  *\\n53:  * <p>The instance should be created using the {@link PulsarClientSharedResourcesBuilder},\\n54:  * which can be obtained via the {@link #builder()} method.\\n55:  *\\n56:  * @see PulsarClientSharedResourcesBuilder\\n57:  * @see SharedResource\\n58:  */\\n59: public interface PulsarClientSharedResources extends AutoCloseable {\\n60:     enum SharedResource {\\n61:         // pulsar-io threadpool\\n62:         EventLoopGroup(SharedResourceType.EventLoopGroup),\\n63:         // pulsar-external-listener threadpool\\n64:         ListenerExecutor(SharedResourceType.ThreadPool),\\n65:         // pulsar-timer threadpool\\n66:         Timer(SharedResourceType.Timer),\\n67:         // pulsar-client-internal threadpool\\n68:         InternalExecutor(SharedResourceType.ThreadPool),\\n69:         // pulsar-client-scheduled threadpool\\n70:         ScheduledExecutor(SharedResourceType.ThreadPool),\\n71:         // pulsar-lookup threadpool\\n72:         LookupExecutor(SharedResourceType.ThreadPool),\\n73:         // DNS resolver and cache that must be shared together with eventLoopGroup\\n74:         DnsResolver(SharedResourceType.DnsResolver);\\n75: \\n76:         private final SharedResourceType type;\\n77: \\n78:         SharedResource(SharedResourceType type) {\\n79:             this.type = type;\\n80:         }\\n81: \\n82:         public SharedResourceType getType() {\\n83:             return type;\\n84:         }\\n85:     }\\n86: \\n87:     enum SharedResourceType {\\n88:         EventLoopGroup,\\n89:         ThreadPool,\\n90:         Timer,\\n91:         DnsResolver;\\n92:     }\\n93: \\n94:     /**\\n95:      * Checks if a resource type is contained in the shared resources instance.\\n96:      *\\n97:      * @param sharedResource the type of resource to check\\n98:      * @return true if the resource type is contained in this instance, false otherwise\\n99:      */\\n100:     boolean contains(SharedResource sharedResource);\\n101: \\n102:     /**\\n103:      * Gets all resource types contained in this shared resources instance.\\n104:      *\\n105:      * @return set of resource types available in this instance\\n106:      */\\n107:     Set<SharedResource> getSharedResources();\\n108: \\n109:     /**\\n110:      * Creates a new builder for constructing instances of {@link PulsarClientSharedResources}.\\n111:      *\\n112:      * @return a new {@link PulsarClientSharedResourcesBuilder} which can be used to configure\\n113:      *         and build shared resources for use across multiple PulsarClient instances.\\n114:      */\\n115:     static PulsarClientSharedResourcesBuilder builder() {\\n116:         return DefaultImplementation.getDefaultImplementation().newSharedResourcesBuilder();\\n117:     }\\n118: \\n119:     /**\\n120:      * Closes this instance of PulsarClientSharedResources and releases all associated resources.\\n121:      * All PulsarClient instances using these shared resources must be closed before calling this method.\\n122:      *\\n123:      * @throws PulsarClientException if there is an error while closing the shared resources\\n124:      */\\n125:     @Override\\n126:     void close() throws PulsarClientException;\\n127: }\\n--- pulsar-client/src/main/java/org/apache/pulsar/client/impl/PulsarClientImplementationBindingImpl.java\\n1: /*\\n2:  * Licensed to the Apache Software Foundation (ASF) under one\\n3:  * or more contributor license agreements.  See the NOTICE file\\n4:  * distributed with this work for additional information\\n5:  * regarding copyright ownership.  The ASF licenses this file\\n6:  * to you under the Apache License, Version 2.0 (the\\n7:  * \\\"License\\\"); you may not use this file except in compliance\\n8:  * with the License.  You may obtain a copy of the License at\\n9:  *\\n10:  *   http://www.apache.org/licenses/LICENSE-2.0\\n11:  *\\n12:  * Unless required by applicable law or agreed to in writing,\\n13:  * software distributed under the License is distributed on an\\n14:  * \\\"AS IS\\\" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY\\n15:  * KIND, either express or implied.  See the License for the\\n16:  * specific language governing permissions and limitations\\n17:  * under the License.\\n18:  */\\n19: package org.apache.pulsar.client.impl;\\n20: \\n21: import java.io.IOException;\\n22: import java.nio.ByteBuffer;\\n23: import java.nio.charset.Charset;\\n24: import java.sql.Time;\\n25: import java.sql.Timestamp;\\n26: import java.time.Instant;\\n27: import java.time.LocalDate;\\n28: import java.time.LocalDateTime;\\n29: import java.time.LocalTime;\\n30: import java.util.Date;\\n31: import java.util.Map;\\n32: import java.util.function