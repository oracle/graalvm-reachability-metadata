his.sharedResources = EnumSet.allOf(SharedResource.class);\\n63:             } else {\\n64:                 this.sharedResources = Set.copyOf(sharedResources);\\n65:             }\\n66:         }\\n67:         this.ioEventLoopGroup = this.sharedResources.contains(SharedResource.EventLoopGroup)\\n68:                 ? createEventLoopGroupWithResourceConfig(\\n69:                 getResourceConfig(resourceConfigs, SharedResource.EventLoopGroup))\\n70:                 : null;\\n71:         this.externalExecutorProvider = this.sharedResources.contains(SharedResource.ListenerExecutor)\\n72:                 ? createExternalExecutorProviderWithResourceConfig(\\n73:                 getResourceConfig(resourceConfigs, SharedResource.ListenerExecutor))\\n74:                 : null;\\n75:         this.internalExecutorProvider = this.sharedResources.contains(SharedResource.InternalExecutor)\\n76:                 ? createInternalExecutorProviderWithResourceConfig(\\n77:                 getResourceConfig(resourceConfigs, SharedResource.InternalExecutor))\\n78:                 : null;\\n79:         this.scheduledExecutorProvider = this.sharedResources.contains(SharedResource.ScheduledExecutor)\\n80:                 ? createScheduledExecutorProviderWithResourceConfig(\\n81:                 getResourceConfig(resourceConfigs, SharedResource.ScheduledExecutor))\\n82:                 : null;\\n83:         this.lookupExecutorProvider = this.sharedResources.contains(SharedResource.LookupExecutor)\\n84:                 ? createLookupExecutorProviderWithResourceConfig(\\n85:                 getResourceConfig(resourceConfigs, SharedResource.LookupExecutor))\\n86:                 : null;\\n87:         this.timer = this.sharedResources.contains(SharedResource.Timer)\\n88:                 ? createTimer(getResourceConfig(resourceConfigs, SharedResource.Timer))\\n89:                 : null;\\n90:         this.dnsResolverGroup = this.sharedResources.contains(SharedResource.DnsResolver)\\n91:      