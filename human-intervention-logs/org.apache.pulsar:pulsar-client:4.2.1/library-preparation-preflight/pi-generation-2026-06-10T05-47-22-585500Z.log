  metadata/org.springframework.boot/spring-boot-amqp/index.json:24:    "description" : "Spring Boot AMQP provides auto-configuration and support classes for AMQP 1.0 messaging in Spring Boot applications. It configures ProtonJ2-backed connection factories, AMQP clients, Jackson message conversion, connection properties, Docker Compose integration, and Testcontainers connection details.",
