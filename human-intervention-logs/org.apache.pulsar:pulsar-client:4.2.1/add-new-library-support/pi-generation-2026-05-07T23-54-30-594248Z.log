(SharedResource.class);\n63:             } else {\n64:                 this.sharedResources = Set.copyOf(sharedResources);\n65:             }\n66:         }\n67:         this.ioEventLoopGroup = this.sharedResources.contains(SharedResource.EventLoopGroup)\n68:                 ? createEventLoopGroupWithResourceConfig(\n69:                 getResourceConfig(resourceConfigs, SharedResource.EventLoopGroup))\n70:                 : null;\n71:         this.externalExecutorProvider = this.sharedResources.contains(SharedResource.ListenerExecutor)\n72:                 ? createExternalExecutorProviderWithResourceConfig(\n73:                 getResourceConfig(resourceConfigs, SharedResource.ListenerExecutor))\n74:                 : null;\n75:         this.internalExecutorProvider = this.sharedResources.contains(SharedResource.InternalExecutor)\n76:                 ? createInternalExecutorProviderWithResourceConfig(\n77:                 getResourceConfig(resourceConfigs, SharedResource.InternalExecutor))\n78:                 : null;\n79:         this.scheduledExecutorProvider = this.sharedResources.contains(SharedResource.ScheduledExecutor)\n80:                 ? createScheduledExecutorProviderWithResourceConfig(\n81:                 getResourceConfig(resourceConfigs, SharedResource.ScheduledExecutor))\n82:                 : null;\n83:         this.lookupExecutorProvider = this.sharedResources.contains(SharedResource.LookupExecutor)\n84:                 ? createLookupExecutorProviderWithResourceConfig(\n85:                 getResourceConfig(resourceConfigs, SharedResource.LookupExecutor))\n86:                 : null;\n87:         this.timer = this.sharedResources.contains(SharedResource.Timer)\n88:                 ? createTimer(getResourceConfig(resourceConfigs, SharedResource.Timer))\n89:                 : null;\n90:         this.dnsResolverGroup = this.sharedResources.contains(SharedResource.DnsResolver)\n91:                 ? createDnsResolverGroupWithResourceConfig(\n92:                 getResourceConfig(resourceConfigs, SharedResource.DnsResolver))\n93:                 : null;\n94:     }\n95: \n96:     @SuppressWarnings(\"unchecked\")\n97:     private <T extends PulsarClientSharedResourcesBuilderImpl.ResourceConfig> T getResourceConfig(\n98:             Map<SharedResource, PulsarClientSharedResourcesBuilderImpl.ResourceConfig> resourceConfigs,\n99:             SharedResource resource) {\n100:         return (T) resourceConfigs.get(resource);\n101:     }\n102: \n103:     @Override\n104:     public boolean contains(SharedResource sharedResource) {\n105:         return sharedResources.contains(sharedResource);\n106:     }\n107: \n108:     public Set<SharedResource> getSharedResources() {\n109:         return sharedResources;\n110:     }\n111: \n112:     @Override\n113:     public void close() throws PulsarClientException {\n114:         if (externalExecutorProvider != null) {\n115:             externalExecutorProvider.shutdownNow();\n116:         }\n117:         if (internalExecutorProvider != null) {\n118:             internalExecutorProvider.shutdownNow();\n119:         }\n120:         if (scheduledExecutorProvider != null) {\n121:             scheduledExecutorProvider.shutdownNow();\n122:         }\n123:         if (lookupExecutorProvider != null) {\n124:             lookupExecutorProvider.shutdownNow();\n125:         }\n126:         if (dnsResolverGroup != null) {\n127:             dnsResolverGroup.close();\n128:         }\n129:         if (timer != null) {\n130:             timer.stop();\n131:         }\n132:         if (ioEventLoopGroup != null) {\n133:             EventLoopUtil.shutdownGracefully(ioEventLoopGroup);\n134:         }\n135:     }\n136: \n137:     public void applyTo(PulsarClientImpl.PulsarClientImplBuilder instanceBuilder) {\n138:         if (externalExecutorProvider != null) {\n139:             instanceBuilder.externalExecutorProvider(externalExecutorProvider);\n140:         }\n141:         if (internalExecutorProvider != null) {\n142:             instanceBuilder.internalExecutorProvider(internalExecutorProvider);\n143:         }\n144:         if (scheduledExecutorProvider != null) {\n145:             instanceBuilder.scheduledExecutorProvider(scheduledExecutorProvider);\n146:         }\n147:         if (lookupExecutorProvider != null) {\n148:             instanceBuilder.lookupExecutorProvider(lookupExecutorProvider);\n149:         }\n150:         if (dnsResolverGroup != null) {\n151:             instanceBuilder.dnsResolverGroup(dnsResolverGroup);\n152:         }\n153:         if (timer != null) {\n154:             instanceBuilder.timer(timer);\n155:         }\n156:         if (ioEventLoopGroup != null) {\n157:             instanceBuilder.eventLoopGroup(ioEventLoopGroup);\n158:         }\n159:     }\n160: }\n"}], "isError": false, "timestamp": 1778198170399}}
