  174:         public DnsResolverConfig traceEnabled(boolean traceEnabled) {
  175:             this.traceEnabled = traceEnabled;
  176:             return this;
  177:         }
  178: 
  179:         @Override
  180:         public DnsResolverConfig tcpFallbackEnabled(boolean tcpFallbackEnabled) {
  181:             this.tcpFallbackEnabled = tcpFallbackEnabled;
  182:             return this;
  183:         }
  184: 
  185:         @Override
  186:         public DnsResolverConfig tcpFallbackOnTimeoutEnabled(boolean tcpFallbackOnTimeoutEnabled) {
  187:             this.tcpFallbackOnTimeoutEnabled = tcpFallbackOnTimeoutEnabled;
  188:             return this;
  189:         }
  190: 
  191:         @Override
  192:         public DnsResolverConfig ndots(int ndots) {
  193:             this.ndots = ndots;
  194:             return this;
  195:         }
  196: 
  197:         @Override
  198:         public DnsResolverConfig searchDomains(Iterable<String> searchDomains) {
  199:             this.searchDomains = Lists.newArrayList(searchDomains);
  200:             return this;
  201:         }
  202:     }
  203: 
  204:     @Override
  205:     public PulsarClientSharedResourcesBuilder resourceTypes(
  206:             PulsarClientSharedResources.SharedResource... sharedResource) {
  207:         if (shareConfigured) {
  208:             throw new IllegalStateException("Cannot set resourceTypes when shareConfigured() has already been called");
  209:         }
  210:         return resourceTypes(List.of(sharedResource));
  211:     }
  212: 
  213:     @Override
  214:     public PulsarClientSharedResourcesBuilder resourceTypes(
  215:             Collection<PulsarClientSharedResources.SharedResource> sharedResource) {
  216:         if (shareConfigured) {
  217:             throw new IllegalStateException("Cannot set resourceTypes when shareConfigured() has already been called");
  218:         }
  219:         sharedResources.addAll(sharedResource);
  220:         return this;
  221:     }
  222: 
  223:     @Override
  224:     public PulsarClientSharedResourcesBuilder shareConfigured() {
  225:         if (!sharedResources.isEmpty()) {
  226:             throw new IllegalStateException("Cannot use shareConfigured() when resourceTypes has already been set");
  227:         }
  228:         shareConfigured = true;
  229:         return this;
  230:     }
  231: 
  232:     @SuppressWarnings("unchecked")
  233:     private <T extends ResourceConfig> T getOrCreateConfig(PulsarClientSharedResources.SharedResource sharedResource) {
  234:         return (T) resourceConfigs.computeIfAbsent(sharedResource, k -> {
  235:             switch (sharedResource.getType()) {
  236:                 case EventLoopGroup:
  237:                     return new EventLoopResourceConfig();
  238:                 case DnsResolver:
  239:                     return new DnsResolverResourceConfig();
  240:                 case ThreadPool:
  241:                     return new ThreadPoolResourceConfig();
  242:                 case Timer:
  243:                     return new TimerResourceConfig();
  244:                 default:
  245:                     throw new IllegalArgumentException("Unknown resource type: " + sharedResource.getType());
  246:             }
  247:         });
  248:     }
  249: 
  250:     @Override
  251:     public PulsarClientSharedResourcesBuilder configureThreadPool(
  252:             PulsarClientSharedResources.SharedResource sharedResource, Consumer<ThreadPoolConfig<?>> configurer) {
  253:         if (sharedResource.getType() != PulsarClientSharedResources.SharedResourceType.ThreadPool) {
  254:             throw new IllegalArgumentException("The shared resource " + sharedResource + " doesn't support thread pool"
  255:                     + " configuration");
  256:         }
  257:         configurer.accept(getOrCreateConfig(sharedResource));
  258:         return this;
  259:     }
