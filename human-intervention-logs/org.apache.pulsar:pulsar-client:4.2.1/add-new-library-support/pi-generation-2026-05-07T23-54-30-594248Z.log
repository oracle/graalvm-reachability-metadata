cked\")\n93: public final class PulsarClientImplementationBindingImpl implements PulsarClientImplementationBinding {\n94: \n95:     public <T> SchemaDefinitionBuilder<T> newSchemaDefinitionBuilder() {\n96:         return new SchemaDefinitionBuilderImpl();\n97:     }\n98: \n99:     public ClientBuilder newClientBuilder() {\n100:         return new ClientBuilderImpl();\n101:     }\n102: \n103:     public MessageId newMessageId(long ledgerId, long entryId, int partitionIndex) {\n104:         return new MessageIdImpl(ledgerId, entryId, partitionIndex);\n105:     }\n106: \n107:     public MessageId newMessageIdFromByteArray(byte[] data) throws IOException {\n108:         return MessageIdImpl.fromByteArray(data);\n109:     }\n110: \n111:     public MessageId newMessageIdFromByteArrayWithTopic(byte[] data, String topicName) throws IOException {\n112:         return MessageIdImpl.fromByteArrayWithTopic(data, topicName);\n113:     }\n114: \n115:     public Authentication newAuthenticationToken(String token) {\n116:         return new AuthenticationToken(token);\n117:     }\n118: \n119:     public Authentication newAuthenticationToken(Supplier<String> supplier) {\n120:         return new AuthenticationToken(supplier);\n121:     }\n122: \n123:     public Authentication newAuthenticationTLS(String certFilePath, String keyFilePath) {\n124:         return new AuthenticationTls(certFilePath, keyFilePath);\n125:     }\n126: \n127:     public Authentication createAuthentication(String authPluginClassName, String authParamsString)\n128:             throws PulsarClientException.UnsupportedAuthenticationException {\n129:         return AuthenticationUtil.create(authPluginClassName, authParamsString);\n130:     }\n131: \n132:     public Authentication createAuthentication(String authPluginClassName, Map<String, String> authParams)\n133:             throws PulsarClientException.UnsupportedAuthenticationException {\n134:         return AuthenticationUtil.create(authPluginClassName, authParams);\n135:     }\n136: \n137:     public Schema<byte[]> newBytesSchema() {\n138:         return new BytesSchema();\n139:     }\n140: \n141:     public Schema<String> newStringSchema() {\n142:         return new StringSchema();\n143:     }\n144: \n145:     public Schema<String> newStringSchema(Charset charset) {\n146:         return new StringSchema(charset);\n147:     }\n148: \n149:     public Schema<Byte> newByteSchema() {\n150:         return new ByteSchema();\n151:     }\n152: \n153:     public Schema<Short> newShortSchema() {\n154:         return new ShortSchema();\n155:     }\n156: \n157:     public Schema<Integer> newIntSchema() {\n158:         return new IntSchema();\n159:     }\n160: \n161:     public Schema<Long> newLongSchema() {\n162:         return new LongSchema();\n163:     }\n164: \n165:     public Schema<Boolean> newBooleanSchema() {\n166:         return new BooleanSchema();\n167:     }\n168: \n169:     public Schema<ByteBuffer> newByteBufferSchema() {\n170:         return new ByteBufferSchema();\n171:     }\n172: \n173:     public Schema<Float> newFloatSchema() {\n174:         return new FloatSchema();\n175:     }\n176: \n177:     public Schema<Double> newDoubleSchema() {\n178:         return new DoubleSchema();\n179:     }\n180: \n181:     public Schema<Date> newDateSchema() {\n182:         return DateSchema.of();\n183:     }\n184: \n185:     public Schema<Time> newTimeSchema() {\n186:         return TimeSchema.of();\n187:     }\n188: \n189:     public Schema<Timestamp> newTimestampSchema() {\n190:         return TimestampSchema.of();\n191:     }\n192: \n193:     public Schema<Instant> newInstantSchema() {\n194:         return InstantSchema.of();\n195:     }\n196: \n197:     public Schema<LocalDate> newLocalDateSchema() {\n198:         return LocalDateSchema.of();\n199:     }\n200: \n201:     public Schema<LocalTime> newLocalTimeSchema() {\n202:         return LocalTimeSchema.of();\n203:     }\n204: \n205:     public Schema<LocalDateTime> newLocalDateTimeSchema() {\n206:         return LocalDateTimeSchema.of();\n207:     }\n208: \n209:     public <T> Schema<T> newAvroSchema(SchemaDefinition schemaDefinition) {\n210:         return AvroSchema.of(schemaDefinition);\n211:     }\n212: \n213:     public <T extends com.google.protobuf.Message> Schema<T> newProtobufSchema(\n214:             SchemaDefinition schemaDefinition) {\n215:         return ProtobufSchema.of(schemaDefinition);\n216:     }\n217: \n218:     public <T extends com.google.protobuf.Message> Schema<T> newProtobufNativeSchema(\n219:             SchemaDefinition schemaDefinition) {\n220:         return ProtobufNativeSchema.of(schemaDefinition);\n221:     }\n222: \n223:     public <T> Schema<T> newJSONSchema(SchemaDefinition schemaDefinition) {\n224:         return JSONSchema.of(schemaDefinition);\n225:     }\n226: \n227:     public Schema<GenericRecord> newAutoConsumeSchema() {\n228:         return new AutoConsumeSchema();\n229:     }\n230: \n231:     public Schema<byte[]> newAutoProduceSchema() {\n232:         return new AutoProduceBytesSchema();\n233:     }\n234: \n235:     public Schema<byte[]> newAutoProduceSchema(Schema<?> schema) {\n236:         return new AutoProduceBytesSchema(schema);\n237:     }\n238: \n239:     public Schema<byte[]> newAutoProduceValidatedAvroSchema(Object schema) {\n240:         return new NativeAvroBytesSchema(schema);\n241:     }\n242: \n243:     public Schema<KeyValue<byte[], byte[]>> newKeyValueBytesSchema() {\n244:         return KeyValueSchemaImpl.kvBytes();\n245:     }\n246: \n247:     public <K, V> Schema<KeyValue<K, V>> newKeyValueSchema(Schema<K> keySchema, Schema<V> valueSchema,\n248:                                                     KeyValueEncodingType keyValueEncodingType) {\n249:         return KeyValueSchemaImpl.of(keySchema, valueSchema, keyValueEncodingType);\n250:     }\n251: \n252:     public <K, V> Schema<KeyValue<K, V>> newKeyValueSchema(Class<K> key, Class<V> value, SchemaType type) {\n253:      