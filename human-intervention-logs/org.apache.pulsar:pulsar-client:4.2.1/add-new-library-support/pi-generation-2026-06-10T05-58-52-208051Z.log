[tool-call] delta {"path":"tests/src/org.apache.pulsar/pulsar-client/4.2.1/src/test/java/org_apache_pulsar/pulsar_client/PulsarClientTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pulsar.pulsar_client;\n\nimport org.apache.pulsar.client.api.Consumer;\nimport org.apache.pulsar.client.api.Message;\nimport org.apache.pulsar.client.api.MessageId;\nimport org.apache.pulsar.client.api.Producer;\nimport org.apache.pulsar.client.api.PulsarClient;\nimport org.apache.pulsar.client.api.Reader;\nimport org.apache.pulsar.client.api.Schema;\nimport org.apache.pulsar.client.api.SubscriptionInitialPosition;\nimport org.apache.pulsar.client.api.SubscriptionType;\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\nimport org.testcontainers.containers.GenericContainer;\nimport org.testcontainers.containers.wait.strategy.Wait;\nimport org.testcontainers.utility.DockerImageName;\n\nimport java.nio.charset.StandardCharsets;\nimport java.time.Duration;\nimport java.util.UUID;\nimport java.util.concurrent.TimeUnit;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PulsarClientTest {\n    private static final int BROKER_PORT = 6650;\n    private static final int HTTP_PORT = 8080;\n    private static final Duration STARTUP_TIMEOUT = Duration.ofSeconds(120);\n    private static final GenericContainer<?> PULSAR = new GenericContainer<>(\n            DockerImageName.parse(\"apachepulsar/pulsar:4.2.1\"))\n            .withExposedPorts(BROKER_PORT, HTTP_PORT)\n            .withCommand(\"bin/pulsar\", \"standalone\")\n            .waitingFor(Wait.forLogMessage(\".*messaging service is ready.*\", 1)\n                    .withStartupTimeout(STARTUP_TIMEOUT));\n\n    @BeforeAll\n    static void startPulsar() {\n        PULSAR.start();\n    }\n\n    @AfterAll\n    static void stopPulsar() {\n        PULSAR.stop();\n    }\n\n    @Test\n    void sendsReceivesAndAcknowledgesBytesMessages() throws Exception {\n        String topic = uniqueTopic(\"bytes\");\n        String subscription = \"sub-\" + UUID.randomUUID();\n        byte[] payload = \"native-image-pulsar-client\".getBytes(StandardCharsets.UTF_8);\n\n        try (PulsarClient client = newClient();\n                Consumer<byte[]> consumer = client.newConsumer(Schema.BYTES)\n                        .topic(topic)\n                        .subscriptionName(subscription)\n                        .subscriptionType(SubscriptionType.Exclusive)\n                        .subscriptionInitialPosition(SubscriptionInitialPosition.Earliest)\n                        .subscribe();\n                Producer<byte[]> producer = client.newProducer(Schema.BYTES)\n                        .topic(topic)\n                        .producerName(\"producer-\" + UUID.randomUUID())\n                        .create()) {\n            MessageId messageId = producer.newMessage()\n                    .key(\"sample-key\")\n                    .property(\"source\", \"reachability-test\")\n                    .value(payload)\n                    .send();\n\n            Message<byte[]> message = consumer.receive(10, TimeUnit.SECONDS);\n            assertThat(message).isNotNull();\n            assertThat(message.getMessageId()).isEqualTo(messageId);\n            assertThat(message.getKey()).isEqualTo(\"sample-key\");\n            assertThat(message.getProperty(\"source\")).isEqualTo(\"reachability-test\");\n            assertThat(message.getValue()).isEqualTo(payload);\n            assertThat(MessageId.fromByteArray(messageId.toByteArray())).isEqualTo(messageId);\n\n            consumer.acknowledge(message);\n            assertThat(consumer.receive(1, TimeUnit.SECONDS)).isNull();\n        }\n    }\n\n    @Test\n    void readsJsonSchemaMessagesFromEarliestPosition() throws Exception {\n        String topic = uniqueTopic(\"json\");\n        Order first = new Order(\"order-1\", 2);\n        Order second = new Order(\"order-2\", 5);\n\n        try (PulsarClient client = newClient();\n                Producer<Order> producer = client.newProducer(Schema.JSON(Order.class))\n                        .topic(topic)\n                        .producerName(\"json-producer-\" + UUID.randomUUID())\n                        .create()) {\n            MessageId firstMessageId = producer.send(first);\n            producer.send(second);\n            producer.flush();\n\n            try (Reader<Order> reader = client.newReader(Schema.JSON(Order.class))\n                    .topic(topic)\n                    .readerName(\"reader-\" + UUID.randomUUID())\n                    .startMessageId(MessageId.earliest)\n                    .create()) {\n                Message<Order> firstRead = reader.readNext(10, TimeUnit.SECONDS);\n                assertThat(firstRead).isNotNull();\n                assertThat(firstRead.getMessageId()).isEqualTo(firstMessageId);\n                assertThat(firstRead.getValue()).isEqualTo(first);\n\n                Message<Order> secondRead = reader.readNext(10, TimeUnit.SECONDS);\n                assertThat(secondRead).isNotNull();\n                assertThat(secondRead.getValue()).isEqualTo(second);\n            }\n        }\n    }\n\n    @Test\n    void supportsPartitionedProducerAndConsumerBuilders() throws Exception {\n        String topic = uniqueTopic(\"partitioned-builder\");\n        String subscription = \"sub-\" + UUID.randomUUID();\n\n        try (PulsarClient client = newClient();\n                Consumer<String> consumer = client.newConsumer(Schema.STRING)\n                        .topic(topic)\n                        .subscriptionName(subscription)\n                        .subscriptionType(SubscriptionType.Shared)\n                        .subscriptionInitialPosition(SubscriptionInitialPosition.Earliest)\n                        .receiverQueueSize(16)\n                        .subscribe();\n                Producer<String> producer = client.newProducer(Schema.STRING)\n                        .topic(topic)\n                        .producerName(\"string-producer-\" + UUID.randomUUID())\n                        .enableBatching(false)\n                        .sendTimeout(10, TimeUnit.SECONDS)\n                        .create()) {\n            MessageId id = producer.send(\"builder-path\");\n\n            Message<String> message = consumer.receive(10, TimeUnit.SECONDS);\n            assertThat(message).isNotNull();\n            assertThat(message.getMessageId()).isEqualTo(id);\n            assertThat(message.getValue()).isEqualTo(\"builder-path\");\n            consumer.acknowledge(message);\n        }\n    }\n\n    private static PulsarClient newClient() throws Exception {\n        return PulsarClient.builder()\n                .serviceUrl(serviceUrl())\n                .connectionTimeout(10, TimeUnit.SECONDS)\n                .operationTimeout(10, TimeUnit.SECONDS)\n                .build();\n    }\n\n    private static String serviceUrl() {\n        return \"pulsar://%s:%d\".formatted(PULSAR.getHost(), PULSAR.getMappedPort(BROKER_PORT));\n    }\n\n    private static String uniqueTopic(String suffix) {\n        return \"persistent://public/default/test-\" + suffix + \"-\" + UUID.randomUUID();\n    }\n\n    public static final class Order {\n        private String id;\n        private int quantity;\n\n        public Order() {\n        }\n\n        public Order(String id, int quantity) {\n            this.id = id;\n            this.quantity = quantity;\n        }\n\n        public String getId() {\n            return id;\n        }\n\n        public void setId(String id) {\n            this.id = id;\n        }\n\n        public int getQuantity() {\n            return quantity;\n        }\n\n        public void setQuantity(int quantity) {\n            this.quantity = quantity;\n        }\n\n        @Override\n        public boolean equals(Object other) {\n            if (this == other) {\n                return true;\n            }\n            if (!(other instanceof Order order)) {\n                return false;\n            }\n            return quantity == order.quantity && id.equals(order.id);\n        }\n\n        @Override\n        public int hashCode() {\n            int result = id.hashCode();\n            result = 31 * result + quantity;\n            return result;\n        }\n    }\n}\n"}
