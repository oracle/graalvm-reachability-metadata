alTo(\\\"pong\\\")\\n\\n      val createdResponse: HttpResponse = await(http.singleRequest(HttpRequest(\\n        method = HttpMethods.POST,\\n        uri = s\\\"http://127.0.0.1:$port/created/42\\\")))\\n      assertThat(createdResponse.status).isEqualTo(StatusCodes.Created)\\n      assertThat(createdResponse.headers.find(_.is(\\\"x-created-id\\\")).map(_.value()).get).isEqualTo(\\\"42\\\")\\n      await(createdResponse.discardEntityBytes().future())\\n    } finally {\\n      await(binding.unbind())\\n      await(http.shutdownAllConnectionPools())\\n    }\\n  }\\n\\n  private def responseText(response: HttpResponse)(implicit\\n    executionContext: ExecutionContextExecutor,\\n    materializer: Materializer): String =\\n    await(Unmarshal(response.entity).to[String])\\n\\n  private def withActorSystem(test: ActorSystem => Unit): Unit = {\\n    val system: ActorSystem = ActorSystem(\\\"akka-http-3-reachability-test\\\")\\n    try {\\n      test(system)\\n    } finally {\\n      Await.result(system.terminate(), timeout)\\n    }\\n\\n[5 more lines in file. Use offset=221 to continue.]\"}], \"isError\": false, \"timestamp\": 1781088972435}}\n2378:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0a16af25f7d842d7016a2942caf744819783c20d2f47a9e546\\\",\\\"type\\\":\\\"reasoning\\\",\\\"content\\\":[],\\\"encrypted_content\\\":\\\"gAAAAABqKULLaBw8t7DwIUfZLiSTvKmcAxEPTycDW1Ofh3fc_8muWti3g9HY96dZzBFKUrBlROFpO6FollQ96E3I_hX36e0BLasotsxrKhnsp5zm8Se1teWAmYWxEGcB67aa6bWfOuLl639-y5IkQB1MUYST9qEu3WaO_FCHDwv_9GSmSb760Pc8r-nH2sjAgIaRgykaQiDnH9WdQG0lHliWzZXawIGSNytdHXI8bFrsQm6vWx-mD0FxcdkXAd9u1QaAylGusxUXEgwEG2a-sAmqoyupgA3vll7M444Xojv6ZySZ0ae2rVBXSoteM8qLoqUNYiO8aycNHgFrH8-4zaARxSm9vUvHRthmTmIbwQPT997GTklsFAOYM4sNGpbpyL1Z43u8j-2KXoQ7qsgdgMP43EZ2HmxhzirRT6XBI88qDZi7sLsuFuMy3RjnuYnVv34iApZUqRqD5emS7GpMXjoZ36Pg8P1Gi4nRhPwAx0QvWmX6BLYMV5yi8JRgxxhJmCTTFOnEOKowmbFkh