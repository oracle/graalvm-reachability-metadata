on>\r\n          </execution>\r\n          <execution>\r\n            <id>site-docs</id>\r\n            <phase>pre-site</phase>\r\n            <goals>\r\n              <goal>xdoc</goal>\r\n            </goals>\r\n          </execution>\r\n          <execution>\r\n            <id>standard</id>\r\n            <goals>\r\n              <goal>java</goal>\r\n              <goal>xpp3-reader</goal>\r\n              <goal>xpp3-writer</goal>\r\n            </goals>\r\n          </execution>\r\n        </executions>\r\n        <configuration>\r\n          <version>1.1.0</version>\r\n          <models>\r\n            <model>src/main/mdo/git-settings.mdo</model>\r\n          </models>\r\n        </configuration>\r\n      </plugin>\r\n    </plugins>\r\n  </build>\r\n</project>\r\n\n"}], "isError": false, "timestamp": 1781050599920}]}
