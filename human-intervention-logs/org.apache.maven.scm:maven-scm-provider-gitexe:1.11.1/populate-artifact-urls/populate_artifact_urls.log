            <configuration>
              <notimestamp>true</notimestamp>
              <linksource>true</linksource>
              <groups>
                <group>
                  <title>API + Test</title>
                  <packages>org.apache.maven.scm*</packages>
                </group>
                <group>
                  <title>Client</title>
                  <packages>org.apache.maven.scm.client*</packages>
