de along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcutil_jdk15on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.math.BigInteger;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.oer.OEROptional;\nimport org.junit.jupiter.api.Test;\n\npublic class OEROptionalAnonymous1Test {\n    @Test\n    void getObjectInvokesPublicGetInstanceFactory() {\n        ASN1Integer encodedValue = new ASN1Integer(BigInteger.valueOf(42));\n        OEROptional optional = OEROptional.getInstance(encodedValue);\n\n        OptionalValue decodedValue = optional.getObject(OptionalValue.class);\n\n        assertThat(optional.isDefined()).isTrue();\n        assertThat(decodedValue.source()).isSameAs(encodedValue);\n    }\n\n    public static final class OptionalValue {\n        private final Object source;\n\n        private OptionalValue(Object source) {\n            this.source = source;\n        }\n\n        public static OptionalValue getInstance(Object source) {\n            return new OptionalValue(source);\n        }\n\n        Object source() {\n            return source;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 562, "output": 1404, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 14766, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778103290965, "responseId": "resp_08698cc12b0e00360169fbb3fb7b0481919bda9c629d195d39"}}
