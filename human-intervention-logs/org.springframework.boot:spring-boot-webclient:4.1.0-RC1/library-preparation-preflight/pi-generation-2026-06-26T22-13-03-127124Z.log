  		@Order(0)
  		WebClientCodecCustomizer exchangeStrategiesCustomizer(ObjectProvider<CodecCustomizer> codecCustomizers) {
  			return new WebClientCodecCustomizer(codecCustomizers.orderedStream().toList());
  		}
  
  	}
  
  }
