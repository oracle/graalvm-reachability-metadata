                  } catch (Exception e) {
                      subscription.onError(e);
                  }
              }
  
              @Override
              void request(RedisSubscription<?> subscription, long n) {
  
                  if (Operators.request(RedisSubscription.DEMAND, subscription, n)) {
  
                      onDataAvailable(subscription);
  
