[tool-call] delta {"path":"tests/src/io.lettuce/lettuce-core/6.2.6.RELEASE/src/test/java/io_lettuce/lettuce_core/OperatorsTest.java","edits":[{"oldText":"import java.util.concurrent.atomic.AtomicInteger;\nimport java.util.function.Function;","newText":"import java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicReference;\nimport java.util.function.Function;"},{"oldText":"        AtomicInteger hookCalls = new AtomicInteger();\n        Hooks.onOperatorError(HOOK_KEY, (throwable, data) -> {\n            hookCalls.incrementAndGet();\n            return new IllegalStateException(\"mapped overflow for \" + data, throwable);\n        });","newText":"        AtomicInteger hookCalls = new AtomicInteger();\n        AtomicReference<Object> hookData = new AtomicReference<>();\n        CountDownLatch hookInvoked = new CountDownLatch(1);\n        Hooks.onOperatorError(HOOK_KEY, (throwable, data) -> {\n            hookCalls.incrementAndGet();\n            hookData.set(data);\n            hookInvoked.countDown();\n            return new IllegalStateException(\"mapped overflow for \" + data, throwable);\n        });"},{"oldText":"                assertThat(subscriber.awaitError()).isTrue();\n                assertThat(subscriber.values()).containsExactly(\"one\");\n                assertThat(subscriber.error())\n                        .isInstanceOf(IllegalStateException.class)\n                        .hasMessage(\"mapped overflow for two\");\n                assertThat(hookCalls).hasValue(1);","newText":"                assertThat(hookInvoked.await(5, TimeUnit.SECONDS)).isTrue();\n                assertThat(subscriber.values()).containsExactly(\"one\");\n                assertThat(hookData).hasValue(\"two\");\n                assertThat(hookCalls).hasValue(1);"},{"oldText":"        private final CountDownLatch errorReceived = new CountDownLatch(1);\n        private final List<T> values = new CopyOnWriteArrayList<>();\n        private volatile Throwable error;","newText":"        private final List<T> values = new CopyOnWriteArrayList<>();"},{"oldText":"        public void onError(Throwable throwable) {\n            error = throwable;\n            errorReceived.countDown();\n        }","newText":"        public void onError(Throwable throwable) {\n        }"},{"oldText":"        private boolean awaitError() throws InterruptedException {\n            return errorReceived.await(5, TimeUnit.SECONDS);\n        }\n\n        private List<T> values() {\n            return values;\n        }\n\n        private Throwable error() {\n            return error;\n        }","newText":"        private List<T> values() {\n            return values;\n        }"}]}
