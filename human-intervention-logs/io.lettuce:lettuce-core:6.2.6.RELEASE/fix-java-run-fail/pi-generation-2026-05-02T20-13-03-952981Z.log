                  proxiedConnection = null;
                  connectionProxies.clear();
                  return null;
              }
  
              if (method.getName().equals("closeAsync")) {
                  CompletableFuture<Void> future = pool.returnObjectAsync(proxiedConnection);
                  connection = null;
                  proxiedConnection = null;
                  connectionProxies.clear();
                  return future;
