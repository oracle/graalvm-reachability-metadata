          return this.parent == null ? that.parent == null : this.parent.equals(that.parent);
      }
  
      @Override
      public int hashCode() {
  
          if (this.hashCode == 0) {
              this.hashCode = super.hashCode() + 31 * parent.hashCode();
          }
  
          return this.hashCode;
      }
  
  }
