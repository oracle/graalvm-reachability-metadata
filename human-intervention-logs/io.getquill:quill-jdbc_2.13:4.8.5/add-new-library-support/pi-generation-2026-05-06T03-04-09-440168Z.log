    assertThat(context.run(notes.sortBy(_.id)).asJava).containsExactly(\n      GeneratedNote(firstId, \"first note\"),\n      GeneratedNote(secondId, \"second note\")\n    )\n  }\n\n  private def createPeopleTable(): Unit = {"},{"oldText":"  private def createOrganizationTables(): Unit = {\n    requireSuccessfulProbe(\n      \"\"\"\n        |create table departments (\n        |  id int primary key,\n        |  name varchar(64) not null\n        |)\n        |\"\"\".stripMargin\n    )\n    requireSuccessfulProbe(\n      \"\"\"\n        |create table employees (\n        |  id int primary key,\n        |  department_id int not null,\n        |  name varchar(64) not null,\n        |  constraint employees_department foreign key (department_id) references departments(id)\n        |)\n        |\"\"\".stripMargin\n    )\n  }\n\n  private def requireSuccessfulProbe(sql: String): Unit = {","newText":"  private def createOrganizationTables(): Unit = {\n    requireSuccessfulProbe(\n      \"\"\"\n        |create table departments (\n        |  id int primary key,\n        |  name varchar(64) not null\n        |)\n        |\"\"\".stripMargin\n    )\n    requireSuccessfulProbe(\n      \"\"\"\n        |create table employees (\n        |  id int primary key,\n        |  department_id int not null,\n        |  name varchar(64) not null,\n        |  constraint employees_department foreign key (department_id) references departments(id)\n        |)\n        |\"\"\".stripMargin\n    )\n  }\n\n  private def createGeneratedNotesTable(): Unit = {\n    requireSuccessfulProbe(\n      \"\"\"\n        |create table generated_notes (\n        |  id bigint generated by default as identity primary key,\n        |  body varchar(128) not null\n        |)\n        |\"\"\".stripMargin\n    )\n  }\n\n  private def requireSuccessfulProbe(sql: String): Unit = {"},{"oldText":"  final case class Contact(id: Int, email: Email)\n\n  private def newDataSource(): CloseableH2DataSource = {","newText":"  final