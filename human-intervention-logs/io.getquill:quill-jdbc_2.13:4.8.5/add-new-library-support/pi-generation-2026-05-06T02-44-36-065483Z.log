  +
  +    assertThat(updated).isEqualTo(1L)
  +    assertThat(deleted).isEqualTo(1L)
  +    assertThat(context.run(people.sortBy(_.id)).asJava).containsExactly(
  +      Person(1, "Ada", 36, Some("countess")),
  +      Person(2, "Grace", 38, Some("compiler"))
  +    )
