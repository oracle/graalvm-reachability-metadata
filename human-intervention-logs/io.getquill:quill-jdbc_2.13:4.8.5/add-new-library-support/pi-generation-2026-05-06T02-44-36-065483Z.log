      assertEquals(Success("value-4"), TryMonad.flatMap(Success(4))(value => Success(s"value-$value")))
      assertEquals(Failure(boom), TryMonad.error[Int](boom))
      assertEquals(Failure(boom), TryMonad.eval(throw boom))
  
