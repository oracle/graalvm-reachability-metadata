{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/usr/bin/bash -lc \"nl -ba tests/src/com.querydsl/querydsl-core/5.0.0/src/test/java/com_querydsl/querydsl_core/ConstructorExpressionTest.java | sed -n '1,220p'\"","aggregated_output":"     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage com_querydsl.querydsl_core;\n     8\t\n     9\timport static org.assertj.core.api.Assertions.assertThat;\n    10\t\n    11\timport com.querydsl.core.types.ConstructorExpression;\n    12\timport com.querydsl.core.types.Projections;\n    13\timport com.querydsl.core.types.dsl.Expressions;\n    14\t\n    15\timport java.io.ByteArrayInputStream;\n    16\timport java.io.ByteArrayOutputStream;\n    17\timport java.io.IOException;\n    18\timport java.io.ObjectInputStream;\n    19\timport java.io.ObjectOutputStream;\n    20\timport java.util.Collections;\n    21\t\n    22\timport org.junit.jupiter.api.Test;\n    23\t\n    24\tpublic class ConstructorExpressionTest {\n    25\t\n    26\t    @Test\n    27\t    void newInstanceInvokesMatchingConstructorAndAppliesPrimitiveDefaults() {\n    28\t        ConstructorExpression<ProjectedCustomer> projection = customerProjection();\n    29\t\n    30\t        ProjectedCustomer customer = projection.newInstance(\"Ada\", null);\n    31\t\n    32\t        assertThat(customer.getName()).isEqualTo(\"Ada\");\n    33\t        assertThat(customer.getAge()).isZero();\n    34\t    }\n    35\t\n    36\t    @Test\n    37\t    void deserializedExpressionRestoresTransientConstructorState() throws Exception {\n    38\t        ConstructorExpression<DefaultCustomer> projection = Projections.constructor(\n    39\t                DefaultCustomer.class,\n    40\t                new Class<?>[0],\n    41\t                Collections.emptyList());\n    42\t\n    43\t        ConstructorExpression<?> restored = (ConstructorExpression<?>) roundTrip(projection);\n    44\t        DefaultCustomer customer = (DefaultCustomer) restored.newInstance();\n    45\t\n    46\t        assertThat(restored.getType()).isEqualTo(DefaultCustomer.class);\n    47\t        assertThat(customer.getName()).isEqualTo(\"default-name\");\n    48\t    }\n    49\t\n    50\t    private static ConstructorExpression<ProjectedCustomer> customerProjection() {\n    51\t        return Projections.constructor(\n    52\t                ProjectedCustomer.class,\n    53\t                new Class<?>[] {String.class, int.class},\n    54\t                Expressions.stringPath(\"name\"),\n    55\t                Expressions.numberPath(Integer.class, \"age\"));\n    56\t    }\n    57\t\n    58\t    private static Object roundTrip(Object value) throws IOException, ClassNotFoundException {\n    59\t        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n    60\t        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n    61\t            output.writeObject(value);\n    62\t        }\n    63\t        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n    64\t            return input.readObject();\n    65\t        }\n    66\t    }\n    67\t\n    68\t    public static class DefaultCustomer {\n    69\t\n    70\t        private final String name;\n    71\t\n    72\t        public DefaultCustomer() {\n    73\t            name = \"default-name\";\n    74\t        }\n    75\t\n    76\t        public String getName() {\n    77\t            return name;\n    78\t        }\n    79\t    }\n    80\t\n    81\t    public static class ProjectedCustomer {\n    82\t\n    83\t        private final String name;\n    84\t\n    85\t        private final int age;\n    86\t\n    87\t        public ProjectedCustomer(String name, int age) {\n    88\t            this.name = name;\n    89\t            this.age = age;\n    90\t        }\n    91\t\n    92\t        public String getName() {\n    93\t            return name;\n    94\t        }\n    95\t\n    96\t        public int getAge() {\n    97\t            return age;\n    98\t        }\n    99\t    }\n   100\t}\n","exit_code":0,"status":"completed"}}
