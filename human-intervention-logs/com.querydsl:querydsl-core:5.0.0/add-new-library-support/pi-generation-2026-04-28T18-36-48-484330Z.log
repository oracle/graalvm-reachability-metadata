ctReinitializesTransientConstructorState() throws Throwable {\n        ConstructorExpression<PersonName> projection = personNameProjection();\n\n        invokeReadObject(projection);\n\n        assertThat(projection.newInstance(\"Grace\", \"Hopper\"))\n                .isEqualTo(new PersonName(\"Grace\", \"Hopper\"));\n    }\n\n    private static ConstructorExpression<PersonName> personNameProjection() {\n        return Projections.constructor(\n                PersonName.class,\n                Expressions.stringPath(\"firstName\"),\n                Expressions.stringPath(\"lastName\"));\n    }\n\n    private static void invokeReadObject(ConstructorExpression<?> projection) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(ConstructorExpression.class, MethodHandles.lookup());\n        MethodHandle readObject = lookup.findSpecial(\n                ConstructorExpression.class,\n                \"readObject\",\n                MethodType.methodType(void.class, ObjectInputStream.class),\n                ConstructorExpression.class);\n        readObject.invoke(projection, new StubObjectInputStream());\n    }\n\n    public static final class PersonName {\n        private final String firstName;\n        private final String lastName;\n\n        public PersonName(String firstName, String lastName) {\n            this.firstName = firstName;\n            this.lastName = lastName;\n        }\n\n        @Override\n        public boolean equals(Object o) {\n            if (this == o) {\n                return true;\n            }\n            if (!(o instanceof PersonName)) {\n                return false;\n            }\n            PersonName personName = (PersonName) o;\n            return Objects.equals(firstName, personName.firstName) && Objects.equals(lastName, personName.lastName);\n        }\n\n        @Override\n        public int hashCode() {\n            return Objects.hash(firstName, lastName);\n        }\n    }\n\n    private static final class StubObjectInputStream extends ObjectInputStream {\n        StubObjectInputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return null;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 303, "output": 1764, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 26131, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777401349457, "responseId": "resp_0fa9692bfdd62b680169f0fe05f4848190aabe0e82b7e85e48"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_6CS827YfoeHJFOkyu3q4t6Fo|fc_0fa9692bfdd62b680169f0fe13e270819094a5c36f1b8120c1", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3273 bytes to tests/src/com.querydsl/querydsl-core/5.0.0/src/test/java/com_querydsl/querydsl_core/ConstructorExpressionTest.java"}], "isError": false, "timestamp": 1777401368162}]}
