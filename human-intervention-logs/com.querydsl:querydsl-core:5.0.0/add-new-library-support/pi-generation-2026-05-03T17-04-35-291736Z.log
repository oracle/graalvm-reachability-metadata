  package com_querydsl.querydsl_core;
  
  import com.querydsl.core.types.PathMetadata;
  import com.querydsl.core.types.PathMetadataFactory;
  import com.querydsl.core.types.PathType;
  import com.querydsl.core.types.dsl.BeanPath;
  import com.querydsl.core.types.dsl.CollectionPath;
  import com.querydsl.core.types.dsl.EntityPathBase;
  import com.querydsl.core.types.dsl.Expressions;
  import com.querydsl.core.types.dsl.PathBuilder;
  import com.querydsl.core.types.dsl.PathInits;
  import com.querydsl.core.types.dsl.SimpleExpression;
  import com.querydsl.core.types.dsl.StringPath;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CollectionPathBaseTest {
  
      @Test
      void typedQueryTypeUsesPathInitsConstructor() {
          CollectionPath<String, EntityPathBase<String>> path = collectionPath(
                  "typedWithPathInits", EntityPathBase.class);
  
          EntityPathBase<String> element = path.any();
  
          assertThat(element.getType()).isEqualTo(String.class);
          assertThat(element.getMetadata().getPathType()).isEqualTo(PathType.COLLECTION_ANY);
      }
  
      @Test
      void typedQueryTypeFallsBackToConstructorWithoutPathInits() {
          CollectionPath<String, PathBuilder<String>> path = collectionPath(
                  "typedWithoutPathInits", PathBuilder.class);
  
          PathBuilder<String> element = path.any();
  
          assertThat(element.getType()).isEqualTo(String.class);
          assertThat(element.getMetadata().getPathType()).isEqualTo(PathType.COLLECTION_ANY);
      }
  
      @Test
      void untypedQueryTypeUsesPathInitsConstructor() {
          CollectionPath<String, PathInitsAwareStringPath> path = collectionPath(
                  "untypedWithPathInits", PathInitsAwareStringPath.class);
  
          PathInitsAwareStringPath element = path.any();
  
          assertThat(element.getType()).isEqualTo(String.class);
          assertThat(element.getMetadata().getPathType()).isEqualTo(PathType.COLLECTION_ANY);
          assertThat(element.getPathInits()).isSameAs(PathInits.DIRECT);
      }
  
      @Test
      void untypedQueryTypeFallsBackToConstructorWithoutPathInits() {
          CollectionPath<String, StringPath> path = collectionPath("untypedWithoutPathInits", StringPath.class);
  
          StringPath element = path.any();
  
          assertThat(element.getType()).isEqualTo(String.class);
          assertThat(element.getMetadata().getPathType()).isEqualTo(PathType.COLLECTION_ANY);
      }
  
      private static <Q extends SimpleExpression<? super String>> CollectionPath<String, Q> collectionPath(
              String variable, Class<?> queryType) {
          PathMetadata metadata = PathMetadataFactory.forVariable(variable);
          return Expressions.collectionPath(String.class, queryType(queryType), metadata);
      }
  
      @SuppressWarnings("unchecked")
      private static <Q extends SimpleExpression<? super String>> Class<Q> queryType(Class<?> queryType) {
          return (Class<Q>) queryType;
      }
  
  }
  
  final class PathInitsAwareStringPath extends BeanPath<String> {
  
      private final PathInits pathInits;
  
      PathInitsAwareStringPath(PathMetadata metadata, PathInits pathInits) {
          super(String.class, metadata, pathInits);
          this.pathInits = pathInits;
      }
  
      PathInits getPathInits() {
          return pathInits;
      }
  }
