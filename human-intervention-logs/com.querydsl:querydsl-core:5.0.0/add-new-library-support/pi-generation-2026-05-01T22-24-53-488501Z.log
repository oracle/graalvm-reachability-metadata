e.getMetadata().getParent()).isSameAs(path);\n        assertThat(value.getMetadata().getElement()).isSameAs(key);\n        assertThat(value.getMetadata().getPathType()).isEqualTo(PathType.MAPVALUE);\n    }\n\n    private static PathMetadata metadata(String variable) {\n        return PathMetadataFactory.forVariable(variable);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <Q> Class<Q> queryType(Class<?> type) {\n        return (Class<Q>) type;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1527, "output": 1662, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 18549, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777674229422, "responseId": "resp_05142d7621c314dd0169f527f5c11c81959c3ea56a3026da0d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2DG5adHvNjThygoXZD29Hjml|fc_05142d7621c314dd0169f527ffc0d4819593e10a40d9fe14b3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3255 bytes to tests/src/com.querydsl/querydsl-core/5.0.0/src/test/java/com_querydsl/querydsl_core/MapPathTest.java"}], "isError": false, "timestamp": 1777674244270}]}
