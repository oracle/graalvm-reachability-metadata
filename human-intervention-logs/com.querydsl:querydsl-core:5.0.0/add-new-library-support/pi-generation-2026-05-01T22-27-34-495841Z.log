core.util.ArrayUtils;\n\nimport org.junit.jupiter.api.Test;\n\npublic class ArrayUtilsTest {\n\n    @Test\n    void combinesFirstTwoValuesWithTypedRestArray() {\n        String[] result = ArrayUtils.combine(String.class, \"alpha\", \"beta\", new String[] {\"gamma\", \"delta\"});\n\n        assertThat(result)\n                .isInstanceOf(String[].class)\n                .containsExactly(\"alpha\", \"beta\", \"gamma\", \"delta\");\n    }\n\n    @Test\n    void combinesFirstValueWithTypedRestArray() {\n        String[] result = ArrayUtils.combine(String.class, \"alpha\", new String[] {\"beta\", \"gamma\"});\n\n        assertThat(result)\n                .isInstanceOf(String[].class)\n                .containsExactly(\"alpha\", \"beta\", \"gamma\");\n    }\n\n    @Test\n    void subarrayPreservesComponentTypeWhenRangeContainsValues() {\n        Number[] result = ArrayUtils.subarray(new Integer[] {1, 2, 3, 4}, 1, 3);\n\n        assertThat(result)\n                .isInstanceOf(Integer[].class)\n                .containsExactly(2, 3);\n    }\n\n    @Test\n    void subarrayPreservesComponentTypeForEmptyRange() {\n        Object[] result = ArrayUtils.subarray(new String[] {\"alpha\", \"beta\"}, 2, 2);\n\n        assertThat(result)\n                .isInstanceOf(String[].class)\n                .isEmpty();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1274, "output": 1106, "cacheRead": 16896, "cacheWrite": 0, "totalTokens": 19276, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777674416250, "responseId": "resp_0da19e993197927e0169f528b0989081a1a61c50be95cbda3e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_sucjmeL9sQHCfBlhreH2QaIi|fc_0da19e993197927e0169f528b9b8bc81a1972e747fcbd874a5", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1577 bytes to tests/src/com.querydsl/querydsl-core/5.0.0/src/test/java