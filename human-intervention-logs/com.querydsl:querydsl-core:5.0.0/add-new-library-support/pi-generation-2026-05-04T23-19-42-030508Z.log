return pathMixin.getMetadata();\n    }\n\n    @Override\n    public Path<?> getRoot() {\n        return pathMixin.getRoot();\n    }\n\n    @Override\n    public AnnotatedElement getAnnotatedElement() {\n        return pathMixin.getAnnotatedElement();\n    }\n}\n"}], "isError": false, "timestamp": 1777936633378}}
