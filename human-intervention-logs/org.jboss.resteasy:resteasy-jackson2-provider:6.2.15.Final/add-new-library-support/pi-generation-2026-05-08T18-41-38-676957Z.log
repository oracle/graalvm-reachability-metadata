  ./metadata/org.jboss.resteasy/resteasy-jackson2-provider/index.json:9:    "description" : "RESTEasy Jackson 2 Provider integrates Jackson 2 JSON processing with RESTEasy's Jakarta REST runtime by supplying message body readers, writers, exception mapping, JSONP support, and related provider services. It lets RESTEasy applications serialize and deserialize request and response entities with Jackson modules and annotations while participating in RESTEasy provider selection and tracing.",
  ./metadata/io.dropwizard.metrics/metrics-json/index.json:9:    "description" : "Metrics JSON provides Jackson integration for Dropwizard Metrics. It serializes metric registries, gauges, counters, histograms, meters, timers, and health-check results into JSON-friendly structures.",
  ./metadata/com.fasterxml.jackson.datatype/jackson-datatype-jdk8/index.json:9:    "description" : "Jackson Datatype JDK8 is an add-on module for Jackson Databind that adds serialization and deserialization support for Java 8 types such as Optional, OptionalInt, OptionalLong, and OptionalDouble. It lets ObjectMapper handle those JDK 8 container types through Jackson's standard module registration mechanism.",
  ./metadata/com.fasterxml.jackson.datatype/jackson-datatype-jsr310/index.json:9:    "description" : "Jackson Datatype JSR310 is an add-on module for Jackson that adds serialization and deserialization support for Java 8 Date and Time API types. It lets ObjectMapper handle java.time classes such as LocalDate, LocalDateTime, OffsetDateTime, and Instant using Jackson's standard module registration mechanism.",
