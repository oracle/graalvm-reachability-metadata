      boolean enabled =
          DbConfig.isSqlCommenterEnabled(
              openTelemetry,
              "jdbc",
              ConfigPropertiesUtil.getBoolean(
                  "otel.instrumentation.jdbc.experimental.sqlcommenter.enabled",
                  ConfigPropertiesUtil.getBoolean(
                      "otel.instrumentation.common.db.experimental.sqlcommenter.enabled", false)));
