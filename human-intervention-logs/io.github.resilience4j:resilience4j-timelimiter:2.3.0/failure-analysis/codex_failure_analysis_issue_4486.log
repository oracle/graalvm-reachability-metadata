    public TimeLimiterConfig build() {\\r\\n            TimeLimiterConfig config = new TimeLimiterConfig();\\r\\n            config.timeoutDuration = timeoutDuration;\\r\\n            config.cancelRunningFuture = cancelRunningFuture;\\r\\n            return config;\\r\\n        }\\r\\n\\r\\n        /**\\r\\n         * Configures the thread execution timeout Default value is 1 second.\\r\\n         *\\r\\n         * @param timeoutDuration the timeout Duration\\r\\n         * @return the TimeLimiterConfig.Builder\\r\\n         */\\r\\n        public Builder timeoutDuration(final Duration timeoutDuration) {\\r\\n            this.timeoutDuration = checkTimeoutDuration(timeoutDuration);\\r\\n            return this;\\r\\n        }\\r\\n\\r\\n        /**\\r\\n         * Configures whether cancel is called on the running future Defaults to TRUE\\r\\n         *\\r\\n         * @param cancelRunningFuture to cancel or not\\r\\n         * @return the TimeLimiterConfig.Builder\\r\\n         */\\r\\n        public Builder cancelRunningFuture(final boolean cancelRunningFuture) {\\r\\n            this.cancelRunningFuture = cancelRunningFuture;\\r\\n            return this;\\r\\n        }\\r\\n\\r\\n    }\\r\\n}\\r\\n\\n\"}], \"isError\": false, \"timestamp\": 1778189163794}}\n2332:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"**Inspecting TimeLimiter methods**\\n\\nI need to examine the public methods of the TimeLimiter. Understanding these methods is crucial for ensuring that I’m using the TimeLimiter effectively. It looks like I should check the documentation or code to get a clear view of what each method does and how to best utilize them in my tasks. This will help me avoid any potential pitfalls later on. Alright, let's dive into it!\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0f593d492f4fd13a0169fd0366fbf4819c940ea5459d29f906\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAA