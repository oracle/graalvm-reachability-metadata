a:54:        Path metadataDir = tckExtension.getMetadataDir(coordinates);\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/AbstractSubprojectTask.java:86:        Path metadataDir = tckExtension.getMetadataDir(coordinates);\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/SingleCoordinateTask.java:23:        List<String> coords = resolveCoordinates();\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/ComputeAndPullAllowedDockerImagesTask.java:84:            matching = tck.getMatchingCoordinates(filter);\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/CoordinatesAwareTask.java:54:    protected List<String> resolveCoordinates() {\ntests/tck-build-logic/src/main/groovy/org/graalvm/internal/tck/harness/tasks/CoordinatesAwareTask.java:74:            return tckExtension.getMatchingCoordinates(filter);\n","exit_code":0,"status":"completed"}}
