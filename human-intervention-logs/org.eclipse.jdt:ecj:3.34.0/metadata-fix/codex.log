raalvm/internal/tck/TestedVersionUpdaterTaskTests.java:329:    private TestTestedVersionUpdaterTask createTask() {\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/TestedVersionUpdaterTaskTests.java:334:                .create(\"addTestedVersion\", TestTestedVersionUpdaterTask.class);\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/TestedVersionUpdaterTaskTests.java:430:    abstract static class TestTestedVersionUpdaterTask extends TestedVersionUpdaterTask {\ntests/tck-build-logic/src/test/java/org/graalvm/internal/tck/TestedVersionUpdaterTaskTests.java:432:        public TestTestedVersionUpdaterTask() {\n","exit_code":0,"status":"completed"}}
