        </exclusions>
      </dependency>
      <dependency>
        <groupId>org.apache.activemq</groupId>
        <artifactId>artemis-unit-test-support</artifactId>
        <version>2.34.0</version>
        <scope>test</scope>
      </dependency>
    </dependencies>
  </project>
