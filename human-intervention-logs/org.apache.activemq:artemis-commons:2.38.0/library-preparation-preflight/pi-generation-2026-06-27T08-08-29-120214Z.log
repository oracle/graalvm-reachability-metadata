           if (sr == null) {
              sr = new SecureRandom();
           }
        }
  
        @Override
        public String decode(String secret) throws Exception {
           throw new IllegalArgumentException("Algorithm doesn't support decoding");
        }
  
        public byte[] getSalt() {
           byte[] salt = new byte[this.saltLength];
           sr.nextBytes(salt);
           return salt;
