os = new ObjectOutputStream(baos)) {\n         oos.writeObject(serializableObject);\n         return java.util.Base64.getEncoder().encodeToString(baos.toByteArray());\n      } catch (Exception e) {\n         ActiveMQUtilLogger.LOGGER.failedToSerializeObject(e);\n         return null;\n      }\n   }\n\n   public static String encodeBytes(final byte[] s) {\n      return encodeBytes(s, false);\n   }\n\n   public static String encodeBytes(final byte[] s, boolean urlSafe) {\n      if (urlSafe) {\n         return java.util.Base64.getUrlEncoder().encodeToString(s);\n      } else {\n         return java.util.Base64.getEncoder().encodeToString(s);\n      }\n   }\n\n   public static byte[] decode(final String s) {\n      return decode(s, false);\n   }\n\n   public static byte[] decode(final String s, boolean urlSafe) {\n      if (urlSafe) {\n         return java.util.Base64.getUrlDecoder().decode(s);\n      } else {\n         return java.util.Base64.getDecoder().decode(s);\n      }\n   }\n}\n"}], "isError": false, "timestamp": 1782527077542}, {"role": "toolResult", "toolCallId": "call_KzRJ7RPiYrrjQFtfpBFjdtEm|fc_0342a615a614d157016a3f346517c08197a8286116fd2032b7", "toolName": "bash", "content": [{"type": "text", "text": "   <dependencies>\n\n      <!-- Johnzon and JSON is meant to be referenced only here on this package (commons)\n           and we should not leak any dependencies to JSON or Johnzon in any of our packages.\n           Any other references would be meant for tests. -->\n      <dependency>\n         <groupId>org.apache.johnzon</groupId>\n         <artifactId>johnzon-core</artifactId>\n         <scope>compile</scope>\n         <optional>true</optional>\n      </dependency>\n      <dependency>\n         <groupId>jakarta.json</groupId>\n         <artifactId>jakarta.json-api</artifactId>\n         <scope>compile</scope>\n         <optional>true</optional>\n         <!-- License: EPL 2.0 -->\n      </dependency>\n      <!-- ^^ these dependencies are shaded on this JAR -->\n\n      <!-- logging -->\n      <dependency>\n         <groupId>org.apache.activemq</groupId>\n         <artifactId>artemis-log-annotation-processor</artifactId>\n         <version>${project.version}</version>\n         <scope>provided</scope>\n         <!-- Superfluous, except for osgi manifest handling -->\n         <optional>true</optional>\n      </dependency>\n      <dependency>\n         <groupId>org.slf4j</groupId>\n         <artifactId>slf4j-api</artifactId>\n         <!-- License: MIT -->\n      </dependency>\n      <dependency>\n         <groupId>org.apache.logging.log4j</groupId>\n         <artifactId>log4j-slf4j2-impl</artifactId>\n         <scope>test</scope>\n      </dependency>\n      <dependency>\n         <groupId>io.netty</groupId>\n         <artifactId>netty-buffer</artifactId>\n      </dependency>\n      <dependency>\n         <groupId>io.netty</groupId>\n         <artifactId>netty-common</artifactId>\n      </dependency>\n      <dependency>\n         <groupId>commons-beanutils</groupId>\n         <artifactId>commons-beanutils</artifactId>\n      </dependency>\n      <dependency>\n         <groupId>org.junit.jupiter</groupId>\n         <artifactId>junit-jupiter-api</artifactId>\n         <scope>test</scope>\n      </dependency>\n      <dependency>\n         <groupId>org.junit.jupiter</groupId>\n         <artifactId>junit-jupiter-engine</artifactId>\n         <scope>test</scope>\n      </dependency>\n      <dependency>\n         <groupId>org.apache.activemq</groupId>\n         <artifactId>artemis-unit-test-support</artifactId>\n         <version>${project.version}</version>\n         <scope>test</scope>\n      </dependency>\n   </dependencies>\n\n   <profiles>\n      <profile>\n         <id>release</id>\n         <properties>\n            <skipCommonsJavadocGeneration>${maven.javadoc.skip}</skipCommonsJavadocGeneration>\n         </properties>\n      </profile>\n   </profiles>\n\n   <build>\n      <pluginManagement>\n         <plugins>\n            <plugin>\n               <groupId>org.apache.maven.plugins</groupId>\n               <artifactId>maven-javadoc-plugin</artifactId>\n               <configuration>\n                  <useStandardDocletOptions>true</useStandardDocletOptions>\n                  <minmemory>128m</minmemory>\n                  <maxmemory>512m</maxmemory>\n                  <noindex>true</noindex>\n                  <notimestamp>true</notimestamp>\n                  <sourceFileIncludes>\n                     <sourceFileInclude>**/org/apache/activemq/artemis/api/**/*.java</sourceFileInclude>\n                  </sourceFileIncludes>\n               </configuration>\n            </plugin>\n         </plugins>\n      </pluginManagement>\n\n      <plugins>\n         <plugin>\n            <groupId>org.apache.maven.plugins</groupId>\n            <artifactId>maven-shade-plugin</artifactId>\n            <executions>\n               <execution>\n                  <phase>package</phase>\n                  <goals>\n                     <goal>shade</goal>\n                  </goals>\n                  <configuration>\n                     <createDependencyReducedPom>true</createDependencyReducedPom>\n                     <filters>\n                        <filter>\n                           <artifact>*:*</artifact>\n                           <excludes>\n                              <exclude>META-INF/services/*</exclude>\n                           </excludes>\n                        </filter>\n                     </filters>\n                     <relocations>\n                        <relocation>\n                           <pattern>javax.json</pattern>\n"}], "isError": false, "timestamp": 1782527077548}]}
