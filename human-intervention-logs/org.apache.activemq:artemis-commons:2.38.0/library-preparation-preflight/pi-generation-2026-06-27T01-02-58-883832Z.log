      </dependency>
      <dependency>
        <groupId>org.junit.jupiter</groupId>
        <artifactId>junit-jupiter-api</artifactId>
        <version>5.11.2</version>
        <scope>test</scope>
        <exclusions>
          <exclusion>
            <artifactId>opentest4j</artifactId>
            <groupId>org.opentest4j</groupId>
