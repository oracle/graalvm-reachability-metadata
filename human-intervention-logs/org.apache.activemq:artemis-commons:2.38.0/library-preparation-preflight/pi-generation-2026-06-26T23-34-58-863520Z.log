     public static final String IGNORE_COMMENTS_PROPERTY = "IGNORE_COMMENTS";
     public static final String IGNORE_ELEMENT_CONTENT_WHITESPACE_PROPERTY = "IGNORE_ELEMENT_CONTENT_WHITESPACE";
  
