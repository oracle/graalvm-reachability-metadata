ache.org/POM/4.0.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd\">\n   <modelVersion>4.0.0</modelVersion>\n\n   <parent>\n      <groupId>org.apache.activemq</groupId>\n      <artifactId>artemis-pom</artifactId>\n      <version>2.38.0</version>\n      <relativePath>../artemis-pom/pom.xml</relativePath>\n   </parent>\n\n   <artifactId>artemis-commons</artifactId>\n   <packaging>jar</packaging>\n   <name>ActiveMQ Artemis Commons</name>\n\n   <properties>\n      <skipCommonsJavadocGeneration>true</skipCommonsJavadocGeneration>\n   </properties>\n\n   <dependencies>\n\n      <!-- Johnzon and JSON is meant to be referenced only here on this package (commons)\n           and we should not leak any dependencies to JSON or Johnzon in any of our packages.\n           Any other references would be meant for tests. -->\n      <dependency>\n         <groupId>org.apache.johnzon</groupId>\n         <artifactId>johnzon-core</artifactId>\n         <scope>compile</scope>\n         <optional>true</optional>\n      </dependency>\n      <dependency>\n         <groupId>jakarta.json</groupId>\n         <artifactId>jakarta.json-api</artifactId>\n         <scope>compile</scope>\n         <optional>true</optional>\n         <!-- License: EPL 2.0 -->\n      </dependency>\n      <!-- ^^ these dependencies are shaded on this JAR -->\n\n      <!-- logging -->\n      <dependency>\n         <groupId>org.apache.activemq</groupId>\n         <artifactId>artemis-log-annotation-processor</artifactId>\n         <version>${project.version}</version>\n         <scope>provided</scope>\n         <!-- Superfluous, except for osgi manifest handling -->\n         <optional>true</optional>\n      </dependency>\n      <dependency>\n         <groupId>org.slf4j</groupId>\n         <artifactId>slf4j-api</artifactId>\n         <!-- License: MIT -->\n      </dependency>\n      <dependency>\n         <groupId>org.apache.logging.log4j</groupId>\n         <artifactId>log4j-slf4j2-impl</artifactId>\n         <scope>test</scope>\n      </dependency>\n      <dependency>\n         <groupId>io.netty</groupId>\n         <artifactId>netty-buffer</artifactId>\n      </dependency>\n      <dependency>\n         <groupId>io.netty</groupId>\n         <artifactId>netty-common</artifactId>\n      </dependency>\n      <dependency>\n         <groupId>commons-beanutils</groupId>\n         <artifactId>commons-beanutils</artifactId>\n      </dependency>\n      <dependency>\n         <groupId>org.junit.jupiter</groupId>\n         <artifactId>junit-jupiter-api</artifactId>\n         <scope>test</scope>\n      </dependency>\n      <dependency>\n         <groupId>org.junit.jupiter</groupId>\n         <artifactId>junit-jupiter-engine</artifactId>\n         <scope>test</scope>\n      </dependency>\n      <dependency>\n         <groupId>org.apache.activemq</groupId>\n         <artifactId>artemis-unit-test-support</artifactId>\n         <version>${project.version}</version>\n         <scope>test</scope>\n      </dependency>\n   </dependencies>\n\n   <profiles>\n      <profile>\n         <id>release</id>\n         <properties>\n            <skipCommonsJavadocGeneration>${maven.javadoc.skip}</skipCommonsJavadocGeneration>\n         </properties>\n      </profile>\n   </profiles>\n\n   <build>\n      <pluginManagement>\n         <plugins>\n            <plugin>\n               <groupId>org.apache.maven.plugins</groupId>\n               <artifactId>maven-javadoc-plugin</artifactId>\n               <configuration>\n                  <useStandardDocletOptions>true</useStandardDocletOptions>\n                  <minmemory>128m</minmemory>\n                  <maxmemory>512m</maxmemory>\n                  <noindex>true</noindex>\n                  <notimestamp>true</notimestamp>\n                  <sourceFileIncludes>\n                     <sourceFileInclude>**/org/apache/activemq/artemis/api/**/*.java</sourceFileInclude>\n                  </sourceFileIncludes>\n               </configuration>\n            </plugin>\n         </plugins>\n      </pluginManagement>\n\n      <plugins>\n         <plugin>\n            <groupId>org.apache.maven.plugins</groupId>\n            <artifactId>maven-shade-plugin</artifactId>\n            <executions>\n               <execution>\n                  <phase>package</phase>\n                  <goals>\n                     <goal>shade</goal>\n                  </goals>\n                  <configuration>\n                     <createDependencyReducedPom>true</createDependencyReducedPom>\n                     <filters>\n                        <filter>\n                           <artifact>*:*</artifact>\n                           <excludes>\n                              <exclude>META-INF/services/*</exclude>\n                           </excludes>\n                        </filter>\n                     </filters>\n                     <relocations>\n                        <relocation>\n                           <pattern>javax.json</pattern>\n                           <shadedPattern>org.apache.activemq.artemis.commons.shaded.json</shadedPattern>\n                        </relocation>\n                        <relocation>\n                           <pattern>org.apache.johnzon</pattern>\n                           <shadedPattern>org.apache.activemq.artemis.commons.shaded.johnzon</shadedPattern>\n                        </relocation>\n                     </relocations>\n                     <artifactSet>\n                        <includes>\n                           <include>org.apache.johnzon:johnzon-core</include>\n                           <include>jakarta.json:jakarta.json-api</include>\n                        </includes>\n                     </artifactSet>\n                  </configuration>\n               </execution>\n            </executions>\n         </plugin>\n         <plugin>\n            <groupId>org.apache.maven.plugins</groupId>\n            <artifactId>maven-javadoc-plugin</artifactId>\n            <executions>\n               <execution>\n                  <id>javadocs</id>\n                  <goals>\n                     <goal>jar</goal>\n                  </goals>\n                  <configuration>\n                     <skip>${skipCommonsJavadocGeneration}</skip>\n                  </configuration>\n               </execution>\n            </executions>\n         </plugin>\n      </plugins>\n   </build>\n\n\n</project>\n"}], "isError": false, "timestamp": 1782543031031}, {"role": "toolResult", "toolCallId": "call_bJeMn4TIsHRczFaDnxiAqjZQ|fc_08b55d453b157a0d016a3f72b6a3788195bb97a0c09b1f1cda", "toolName": "bash", "content": [{"type": "text", "text": "/*\n * Licensed to the Apache Software Foundation (ASF) under one or more\n * contributor license agreements. See the NOTICE file distributed with\n * this work for additional information regarding copyright ownership.\n * The ASF licenses this file to You under the Apache License, Version 2.0\n * (the \"License\"); you may not use this file except in compliance with\n * the License. You may obtain a copy of the License at\n *\n *     http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing, software\n * distributed under the License is distributed on an \"AS IS\" BASIS,\n * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n * See the License for the specific language governing permissions and\n * limitations under the License.\n */\npackage org.apache.activemq.artemis.utils;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\n\nimport org.apache.activemq.artemis.logs.ActiveMQUtilLogger;\n\npublic class Base64 {\n\n   public static String encodeObject(final Serializable serializableObject) {\n      try (ByteArrayOutputStream baos = new ByteArrayOutputStream();\n           ObjectOutputStream oos = new ObjectOutputStream(baos)) {\n         oos.writeObject(serializableObject);\n         return java.util.Base64.getEncoder().encodeToString(baos.toByteArray());\n      } catch (Exception e) {\n         ActiveMQUtilLogger.LOGGER.failedToSerializeObject(e);\n         return null;\n      }\n   }\n\n   public static String encodeBytes(final byte[] s) {\n      return encodeBytes(s, false);\n   }\n\n   public static String encodeBytes(final byte[] s, boolean urlSafe) {\n      if (urlSafe) {\n         return java.util.Base64.getUrlEncoder().encodeToString(s);\n      } else {\n         return java.util.Base64.getEncoder().encodeToString(s);\n      }\n   }\n\n   public static byte[] decode(final String s) {\n      return decode(s, false);\n   }\n\n   public static byte[] decode(final String s, boolean urlSafe) {\n      if (urlSafe) {\n         return java.util.Base64.getUrlDecoder().decode(s);\n      } else {\n         return java.util.Base64.getDecoder().decode(s);\n      }\n   }\n}\n"}], "isError": false, "timestamp": 1782543031031}]}
