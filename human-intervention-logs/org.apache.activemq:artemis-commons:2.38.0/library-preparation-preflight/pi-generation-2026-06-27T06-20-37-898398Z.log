ue</createDependencyReducedPom>\r\n              <filters>\r\n                <filter>\r\n                  <artifact>*:*</artifact>\r\n                  <excludes>\r\n                    <exclude>META-INF/services/*</exclude>\r\n                  </excludes>\r\n                </filter>\r\n              </filters>\r\n              <relocations>\r\n                <relocation>\r\n                  <pattern>javax.json</pattern>\r\n                  <shadedPattern>org.apache.activemq.artemis.commons.shaded.json</shadedPattern>\r\n                </relocation>\r\n                <relocation>\r\n                  <pattern>org.apache.johnzon</pattern>\r\n                  <shadedPattern>org.apache.activemq.artemis.commons.shaded.johnzon</shadedPattern>\r\n                </relocation>\r\n              </relocations>\r\n              <artifactSet>\r\n                <includes>\r\n                  <include>org.apache.johnzon:johnzon-core</include>\r\n                  <include>jakarta.json:jakarta.json-api</include>\r\n                </includes>\r\n              </artifactSet>\r\n            </configuration>\r\n          </execution>\r\n        </executions>\r\n      </plugin>\r\n      <plugin>\r\n        <artifactId>maven-javadoc-plugin</artifactId>\r\n        <executions>\r\n          <execution>\r\n            <id>javadocs</id>\r\n            <goals>\r\n              <goal>jar</goal>\r\n            </goals>\r\n            <configuration>\r\n              <skip>${skipCommonsJavadocGeneration}</skip>\r\n            </configuration>\r\n          </execution>\r\n        </executions>\r\n      </plugin>\r\n    </plugins>\r\n  </build>\r\n  <profiles>\r\n    <profile>\r\n      <id>release</id>\r\n      <properties>\r\n        <skipCommonsJavadocGeneration>${maven.javadoc.skip}</skipCommonsJavadocGeneration>\r\n      </properties>\r\n    </profile>\r\n  </profiles>\r\n  <dependencies>\r\n    <dependency>\r\n      <groupId>org.apache.activemq</groupId>\r\n      <artifactId>ar