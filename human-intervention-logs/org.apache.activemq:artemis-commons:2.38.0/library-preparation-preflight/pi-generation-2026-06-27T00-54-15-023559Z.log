n                </relocation>\r\n              </relocations>\r\n              <artifactSet>\r\n                <includes>\r\n                  <include>org.apache.johnzon:johnzon-core</include>\r\n                  <include>jakarta.json:jakarta.json-api</include>\r\n                </includes>\r\n              </artifactSet>\r\n            </configuration>\r\n          </execution>\r\n        </executions>\r\n      </plugin>\r\n      <plugin>\r\n        <artifactId>maven-javadoc-plugin</artifactId>\r\n        <executions>\r\n          <execution>\r\n            <id>javadocs</id>\r\n            <goals>\r\n              <goal>jar</goal>\r\n            </goals>\r\n            <configuration>\r\n              <skip>${skipCommonsJavadocGeneration}</skip>\r\n            </configuration>\r\n          </execution>\r\n        </executions>\r\n      </plugin>\r\n    </plugins>\r\n  </build>\r\n  <profiles>\r\n    <profile>\r\n      <id>release</id>\r\n      <properties>\r\n        <skipCommonsJavadocGeneration>${maven.javadoc.skip}</skipCommonsJavadocGeneration>\r\n      </properties>\r\n    </profile>\r\n  </profiles>\r\n  <dependencies>\r\n    <dependency>\r\n      <groupId>org.apache.activemq</groupId>\r\n      <artifactId>artemis-log-annotation-processor</artifactId>\r\n      <version>2.38.0</version>\r\n      <scope>provided</scope>\r\n      <optional>true</optional>\r\n    </dependency>\r\n    <dependency>\r\n      <groupId>org.slf4j</groupId>\r\n      <artifactId>slf4j-api</artifactId>\r\n      <version>2.0.16</version>\r\n      <scope>compile</scope>\r\n    </dependency>\r\n    <dependency>\r\n      <groupId>org.apache.logging.log4j</groupId>\r\n      <artifactId>log4j-slf4j2-impl</artifactId>\r\n      <version>2.24.1</version>\r\n      <scope>test</scope>\r\n      <exclusions>\r\n        <exclusion>\r\n          <artifactId>log4j-api</artifactId>\r\n          <groupId>org.apache.logging.log4j</groupId>\r\n        </exclusion>\r\n        <exclusion>\r\n          <ar