[tool-call] delta {"path":"tests/src/org.msgpack/msgpack/0.6.10/src/test/java/org_msgpack/msgpack/DefaultBuildContextTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_msgpack.msgpack;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.msgpack.MessagePack;\nimport org.msgpack.annotation.Message;\n\npublic class DefaultBuildContextTest {\n    @Test\n    void serializesAndDeserializesPrivateFieldsWithGeneratedTemplate() throws Exception {\n        try {\n            final MessagePack messagePack = new MessagePack();\n            final PrivateFieldMessage original = new PrivateFieldMessage(17, \"generated-template\");\n\n            final byte[] bytes = messagePack.write(original);\n            final PrivateFieldMessage restored = messagePack.read(bytes, PrivateFieldMessage.class);\n\n            assertThat(restored.getId()).isEqualTo(original.getId());\n            assertThat(restored.getName()).isEqualTo(original.getName());\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    @Message\n    public static final class PrivateFieldMessage {\n        private int id;\n        private String name;\n\n        public PrivateFieldMessage() {\n        }\n\n        public PrivateFieldMessage(int id, String name) {\n            this.id = id;\n            this.name = name;\n        }\n\n        public int getId() {\n            return this.id;\n        }\n\n        public String getName() {\n            return this.name;\n        }\n    }\n}\n"}
