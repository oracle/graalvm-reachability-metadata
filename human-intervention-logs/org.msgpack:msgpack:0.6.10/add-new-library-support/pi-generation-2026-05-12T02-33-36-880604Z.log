       * @throws IOException
       */
      public <T> void write(OutputStream out, T v) throws IOException {
          Packer pk = createPacker(out);
          if (v == null) {
              pk.writeNil();
          } else {
              @SuppressWarnings("unchecked")
              Template<T> tmpl = registry.lookup(v.getClass());
              tmpl.write(pk, v);
          }
      }
  
