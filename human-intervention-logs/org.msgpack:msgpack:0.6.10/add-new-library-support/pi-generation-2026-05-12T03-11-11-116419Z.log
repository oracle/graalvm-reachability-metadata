      public <T> Value unconvert(T v) throws IOException {
          Unconverter pk = new Unconverter(this);
          if (v == null) {
              pk.writeNil();
          } else {
              @SuppressWarnings("unchecked")
              Template<T> tmpl = registry.lookup(v.getClass());
              tmpl.write(pk, v);
          }
          return pk.getResult();
      }
  
