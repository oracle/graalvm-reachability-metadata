  package org_msgpack.msgpack;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.fail;
  
  import java.nio.file.Path;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.msgpack.util.TemplatePrecompiler;
  
  public class TemplatePrecompilerTest {
      @TempDir
      Path tempDir;
  
      @Test
      void saveTemplatesLoadsMatchedPlatformClassNameBeforeFailingClassResolution() throws Exception {
          final String previousDestination = System.getProperty(TemplatePrecompiler.DEST);
          final String previousJavaHome = System.getProperty("java.home");
          System.setProperty(TemplatePrecompiler.DEST, tempDir.toString());
          ensureJavaHomeForCompilerFileManager();
          try {
              TemplatePrecompiler.saveTemplates(new String[] {
                      "java.lang./modules/java\\x2Ebase/java/lang/Runnable"
              });
              fail("Expected matched module path to be rejected as a Java class name");
          } catch (ClassNotFoundException exception) {
              assertThat(exception)
                      .hasMessageContaining("java.lang./modules/java.base/java/lang/Runnable");
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          } finally {
              restoreProperty(TemplatePrecompiler.DEST, previousDestination);
              restoreProperty("java.home", previousJavaHome);
          }
      }
  
      private static void ensureJavaHomeForCompilerFileManager() {
          if (System.getProperty("java.home") == null) {
              final String javaHome = System.getenv("JAVA_HOME");
              assertThat(javaHome).isNotBlank();
              System.setProperty("java.home", javaHome);
          }
      }
  
      private static void restoreProperty(final String key, final String previousValue) {
          if (previousValue == null) {
              System.clearProperty(key);
          } else {
              System.setProperty(key, previousValue);
          }
      }
  
      private static void rethrowUnlessUnsupportedFeatureError(final Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
