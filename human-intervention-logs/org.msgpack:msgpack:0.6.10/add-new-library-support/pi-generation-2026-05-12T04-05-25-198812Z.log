  package org_msgpack.msgpack;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.fail;
  
  import java.nio.file.Path;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.msgpack.template.builder.TemplateBuildException;
  import org.msgpack.util.TemplatePrecompiler;
  
  public class TemplatePrecompilerTest {
      @TempDir
      Path tempDir;
  
      @Test
      void saveTemplatesLoadsMatchedPlatformClassNameBeforeTemplateValidation() throws Exception {
          final String previousDestination = System.getProperty(TemplatePrecompiler.DEST);
          System.setProperty(TemplatePrecompiler.DEST, tempDir.toString());
          try {
              TemplatePrecompiler.saveTemplates(new String[] { "java.lang.Runnable" });
              fail("Expected template validation to reject the loaded interface");
          } catch (TemplateBuildException exception) {
              assertThat(exception)
                      .hasMessageContaining("Cannot build template for interface: java.lang.Runnable");
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          } finally {
              restoreDestination(previousDestination);
          }
      }
  
      private static void restoreDestination(final String previousDestination) {
          if (previousDestination == null) {
              System.clearProperty(TemplatePrecompiler.DEST);
          } else {
              System.setProperty(TemplatePrecompiler.DEST, previousDestination);
          }
      }
  
      private static void rethrowUnlessUnsupportedFeatureError(final Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  }
