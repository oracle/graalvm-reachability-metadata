[tool-call] delta {"path":"tests/src/org.msgpack/msgpack/0.6.10/src/test/java/org_msgpack/msgpack/TemplatePrecompilerTest.java","edits":[{"oldText":"import org.msgpack.template.builder.TemplateBuildException;\nimport org.msgpack.util.TemplatePrecompiler;\n","newText":"import org.msgpack.util.TemplatePrecompiler;\n"},{"oldText":"    void saveTemplatesLoadsMatchedPlatformClassNameBeforeTemplateValidation() throws Exception {\n        final String previousDestination = System.getProperty(TemplatePrecompiler.DEST);\n        System.setProperty(TemplatePrecompiler.DEST, tempDir.toString());\n        try {\n            TemplatePrecompiler.saveTemplates(new String[] { \"java.lang.Runnable\" });\n            fail(\"Expected template validation to reject the loaded interface\");\n        } catch (TemplateBuildException exception) {\n            assertThat(exception)\n                    .hasMessageContaining(\"Cannot build template for interface: java.lang.Runnable\");\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        } finally {\n            restoreDestination(previousDestination);\n        }\n    }\n","newText":"    void saveTemplatesLoadsMatchedPlatformClassNameBeforeFailingClassResolution() throws Exception {\n        final String previousDestination = System.getProperty(TemplatePrecompiler.DEST);\n        System.setProperty(TemplatePrecompiler.DEST, tempDir.toString());\n        try {\n            TemplatePrecompiler.saveTemplates(new String[] { \"java.lang./modules/java\\\\x2Ebase/java/lang/Runnable\" });\n            fail(\"Expected matched module path to be rejected as a Java class name\");\n        } catch (ClassNotFoundException exception) {\n            assertThat(exception)\n                    .hasMessageContaining(\"java.lang./modules/java.base/java/lang/Runnable\");\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        } finally {\n            restoreDestination(previousDestination);\n        }\n    }\n"}]}
