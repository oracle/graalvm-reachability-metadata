      @SuppressWarnings("nls")
      public Object readObject() {
          if (inputStream == null) {
              return null;
          }
          if (saxHandler == null) {
              saxHandler = new SAXHandler();
              try {
                  SAXParserFactory.newInstance().newSAXParser().parse(
                          inputStream, saxHandler);
              } catch (Exception e) {
