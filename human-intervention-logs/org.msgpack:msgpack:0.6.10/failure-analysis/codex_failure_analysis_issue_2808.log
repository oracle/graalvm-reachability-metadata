T\\\")\\n\\n// gradle check\\nspotless {\\n    json {\\n        target(\\n                tck.metadataRoot.map { it.toString() + '/**/*.json' }.get(),\\n                tck.testRoot.map { it.toString() + '/**/*.json' }.get(),\\n                tck.repoRoot.map { it.toString() + '/stats/**/*.json' }.get()\\n        )\\n        targetExclude(\\n                tck.testRoot.map { it.toString() + '/**/build/**/*.json' }.get(),\\n                tck.repoRoot.map { it.toString() + '/.github/**/*.json' }.get()\\n        )\\n        gson()\\n                .indentWithSpaces(2)\\n                .sortByKeys()\\n                .version(\\\"2.9.0\\\")\\n    }\\n    String[] noHeaderDirs = [\\n            'native-build-tools/**', // external repository\\n            'docs/**',     // only .md files\\n            'metadata/**', // only .json files\\n            '**/build/**', // not relevant\\n            '**/.gradle/**', // not relevant\\n            'gradle/wrapper/**', // not relevant\\n            'tests/src/**/generated/**/*.java',\\n            'gradle/header.java',\\n            'gradle/header.sh',\\n    ]\\n\\n    java {\\n        target('**/*.java')\\n        targetExclude(*noHeaderDirs);\\n        // Place header before package/import/module\\n        licenseHeaderFile(\\\"$rootDir/gradle/header.java\\\", \\\"package |import |module \\\")\\n    }\\n\\n    groovy {\\n        target('**/*.groovy')\\n        targetExclude(*noHeaderDirs)\\n        // Place header before package/import\\n        licenseHeaderFile(\\\"$rootDir/gradle/header.java\\\", \\\"package |import \\\")\\n    }\\n    groovyGradle {\\n        // Build scripts (*.gradle)\\n        target('**/*.gradle')\\n        targetExclude(*noHeaderDirs)\\n        // Insert header at file start (works for any Gradle script layout)\\n        licenseHeaderFile(\\\"$rootDir/gradle/header.java\\\", \\\"(?m)^(import\\\\\\\\b|plugins\\\\\\\\b|buildscript\\\\\\\\b|apply\\\\\\\\b|rootProject\\\\\\\\b|pluginManagement\\\\\\\\b|dependencyResolutionManagement\\\\\\\\b)\\\")\\n    }\\n    format('shell') {\\n        target('**/*.sh')\\n        targetExclude(*noHeaderDirs)\\n        // Ensure header appears after shebang if present, else at the very top.\\n        def shHeader = file(\\\"$rootDir/gradle/header.sh\\\").text\\n        // If file starts with a shebang and is missing the header, insert it after the shebang\\n        replaceRegex('insert-license-after-shebang',\\n                     '(?s)\\\\\\\\A(#![^\\\\\\\\n]*\\\\\\\\n)(?:[ \\\\\\\\t]*\\\\\\\\n)*(?!# Copyright and related rights waived via CC0\\\\\\\\n)',\\n                     '$1' + shHeader + \\\"\\\\n\\\")\\n        // If file has no shebang and is missing the header, insert it at the start\\n        replaceRegex('insert-license-at-start',\\n                     '(?s)\\\\\\\\A(?!#!)(?!# Copyright and related rights waived via CC0\\\\\\\\n)',\\n                     shHeader + \\\"\\\\n\\\")\\n    }\\n    format('python') {\\n        target('**/*.py')\\n        targetExclude(*noHeaderDirs, '**/.venv/**', 'forge/local_repositories/**')\\n        // Ensure header appears after shebang if present, else at the very top.\\n        def pyHeader = file(\\\"$rootDir/gradle/header.sh\\\").text\\n        replaceRegex('insert-license-after-shebang',\\n                     '(?s)\\\\\\\\A(#![^\\\\\\\\n]*\\\\\\\\n)(?:[ \\\\\\\\t]*\\\\\\\\n)*(?!# Copyright and related rights waived via CC0\\\\\\\\n)',\\n                     '$1' + pyHeader + \\\"\\\\n\\\")\\n        replaceRegex('insert-license-at-start',\\n                     '(?s)\\\\\\\\A(?!#!)(?!# Copyright and related rights waived via CC0\\\\\\\\n)',\\n                     pyHeader + \\\"\\\\n\\\")\\n    }\\n}\\n\\n// gradle package\\ntasks.register('package', Zip) { task ->\\n    String outputFileName = \\\"graalvm-reachability-metadata-${project.version}.zip\\\"\\n    task.setDescription(\\\"Packages current repository to 'build/${outputFileName}'\\\")\\n    task.setGroup(PublishingPlugin.PUBLISH_TASK_GROUP)\\n    task.archiveFileName = outputFileName\\n    task.destinationDirectory = layout.buildDirectory\\n\\n    from(tck.metadataRoot)\\n}\\n\\ntasks.register('test') { t ->\\n    t.setDescription(\\\"Aggregates tests configured by the TCK harness\\\")\\n    t.setGroup(\\\"verification\\\")\\n}\\n\\n// Apply the harness after creating the 'test' aggregator to avoid missing property,\\n// and without applying the 'java' plugin to avoid task name conflicts.\\napply plugin: \\\"org.graalvm.internal.tck-harness\\\"\\n\\ntasks.named(\\\"check\\\").configure {\\n    dependsOn(\\\"validateLibraryStats\\\")\\n    dependsOn(\\\"checkDocLinks\\\")\\n}\\n\\nstatic List<Map> testInfraCommands(String gradleCmd, String target) {\\n    def taskNames = [\\n            \\\"validateIndexFiles\\\",\\n            \\\"checkstyle\\\",\\n            \\\"spotlessCheck\\\",\\n            \\\"checkMetadataFiles\\\",\\n            \\\"fetchExistingLibrariesWithNewerVersions\\\",\\n            \\\"test\\\",\\n            \\\"jacocoTestReport\\\",\\n            \\\"listLibraryJars\\\",\\n            \\\"generateDynamicAccessReport\\\",\\n            \\\"generateDynamicAccessCoverageReport\\\",\\n            \\\"generateLibraryStats\\\",\\n            \\\"listCoordinates\\\",\\n            \\\"generateDependencyGraph\\\",\\n            \\\"splitTestOnlyMetadata\\\"\\n    ]\\n    return taskNames.collect { name ->\\n        [name: name, args: [gradleCmd, name, \\\"-Pcoordinates=${target}\\\"]]\\n    }\\n}\\n\\nList<String> resolveConcreteCoordinates(String coordinateFilter) {\\n    List<String> matchingCoordinates\\n    if (CoordinateUtils.isFractionalBatch(coordinateFilter)) {\\n        int[] fraction = CoordinateUtils.parseFraction(coordinateFilter)\\n        List<String> allCoordinates = tck.getMatchingCoordinatesStrict(\\\"all\\\")\\n        matchingCoordinates = CoordinateUtils.computeBatchedCoordinates(allCoordinates, fraction[0], fraction[1])\\n    } else {\\n        matchingCoordinates = tck.getMatchingCoordinates(coordinateFilter)\\n    }\\n    return matchingCoordinates.findAll { !it.startsWith(\\\"samples:\\\") }\\n}\\n\\nString resolveSelectedNativeImageMode() {\\n    return NativeImageConfigUtils.resolveSelectedMode(\\n            System.getenv(\\\"GVM_TCK_NATIVE_IMAGE_MODE\\\"),\\n            project.findProperty(\\\"tck.nativeImageMode\\\")?.toString()\\n    )\\n}\\n\\nvoid printTestInfraReproducer(String gradleCmd, String coordinate, int parallelism) {\\n    String nativeImageMode = resolveSelectedNativeImageMode()\\n    TestInfraLoggingUtils.batchReproducerLines(\\n            \\\"testInfra\\\",\\n            gradleCmd,\\n            nativeImageMode,\\n            coordinate,\\n            parallelism\\n    ).each { println(it) }\\n}\\n\\ntasks.register('testInfra') { t ->\\n    t.group = \\\"verification\\\"\\n    t.setDescription(\\\"\\\"\\\"Runs clean and pullAllowedDockerImages, then runs (${testInfraCommands('', '').collect { it.name }.join(', ')}) concurrently with isolated logs for a single coordinate.\\n                        Options: -Pcoordinate or -Pcoordinates to specify the target; -Pparallelism to control the number of concurrent tasks.\\\"\\\"\\\")\\n\\n    doLast {\\n        def coordinateProp = ((project.findProperty('coordinate') ?: project.findProperty('coordinates')) ?: '').toString().trim()\\n        if (coordinateProp.isEmpty()) {\\n            throw new GradleException(\\\"Missing -Pcoordinate=<group:artifact:version|k/n|all> (or -Pcoordinates).\\\")\\n        }\\n\\n        def gradleCmd = System.getProperty(\\\"os.name\\\").toLowerCase().contains(\\\"windows\\\") ? \\\"gradlew.bat\\\" : \\\"./gradlew\\\"\\n        int parallelism = parsePositiveIntProp('parallelism', 4)\\n        println(\\\"Using parallelism=${parallelism} for testInfra.\\\")\\n\\n        List<String> concreteCoordinates = resolveConcreteCoordinates(coordinateProp)\\n        if (concreteCoordinates.isEmpty()) {\\n            throw new GradleException(\\\"No matching coordinates found for '${coordinateProp}'.\\\")\\n        }\\n        concreteCoordinates.each { coordinate ->\\n            printTestInfraReproducer(gradleCmd, coordinate, parallelism)\\n        }\\n\\n        def logsDir = layout.buildDirectory.dir(\\\"command-logs\\\").get().asFile\\n        logsDir.mkdirs()\\n\\n        // Helper to run pull + command set for a given target (artifact or coordinates)\\n        def runPhaseForCoordinate = { String coordinate ->\\n            // Clean project before pulling Docker images for this coordinate\\n            // Note: 'clean' deletes the build/ directory, so log to a temporary location outside build/,\\n            // then move/copy the log into build/ afterwards.\\n            def tmpCleanLogsDir = new File(project.rootDir, \\\".tmp-command-logs-clean\\\")\\n            tmpCleanLogsDir.mkdirs()\\n            def fileSuffix = sanitizeFileName(coordinate)\\n            def tmpCleanLogFile = new File(tmpCleanLogsDir, \\\"clean-${fileSuffix}.log\\\")\\n            try {\\n                runGradleTaskAndCheck(\\n                        [gradleCmd, \\\"clean\\\", \\\"-Pcoordinates=${coordinate}\\\"],\\n                        \\\"clean (${coordinate})\\\",\\n                        tmpCleanLogFile\\n                )\\n            } finally {\\n                // After clean, move/copy the log into the build folder (clean wipes build/)\\n                def cleanLogsDir = layout.buildDirectory.dir(\\\"command-logs-clean\\\").get().asFile\\n                cleanLogsDir.mkdirs()\\n                def cleanLogFile = new File(cleanLogsDir, \\\"clean-${fileSuffix}.log\\\")\\n                try {\\n                    Files.move(tmpCleanLogFile.toPath(), cleanLogFile.toPath(), StandardCopyOption.REPLACE_EXISTING)\\n                } catch (Throwable ignored) {\\n                    if (tmpCleanLogFile?.exists()) {\\n                        cleanLogFile.text = tmpCleanLogFile.text\\n                    }\\n                }\\n            }\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_5\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,240p' settings.gradle\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_5\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,240p' settings.gradle\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npluginManagement {\\n    includeBuild(\\\"tests/tck-build-logic\\\")\\n    repositories {\\n        mavenLocal()\\n        gradlePluginPortal()\\n    }\\n}\\n\\nrootProject.name = \\\"reachability-metadata\\\"\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_6\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc './gradlew tasks --all'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_6\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc './gradlew tasks --all'\",\"aggregated_output\":\"> Task :tck-build-logic:extractPluginRequests UP-TO-DATE\\n> Task :tck-build-logic:generatePluginAdapters UP-TO-DATE\\n> Task :tck-build-logic:compileJava UP-TO-DATE\\n> Task :tck-build-logic:compileGroovy UP-TO-DATE\\n> Task :tck-build-logic:compileGroovyPlugins UP-TO-DATE\\n> Task :tck-build-logic:pluginDescriptors UP-TO-DATE\\n> Task :tck-build-logic:processResources UP-TO-DATE\\n> Task :tck-build-logic:classes UP-TO-DATE\\n> Task :tck-build-logic:jar UP-TO-DATE\\n\\n> Configure project :\\nGraalVM Reachability Metadata TCK\\n---------------------------------\\n\\n> Task :tasks\\n\\n------------------------------------------------------------\\nTasks runnable from root project 'reachability-metadata'\\n------------------------------------------------------------\\n\\nBuild tasks\\n-----------\\nassemble - Assembles the outputs of this project.\\nbuild - Assembles and tests this project.\\nclean - Deletes the build directory.\\ncompileTestJava - Compiles sources (javac) for all subprojects\\nnativeTestCompile - Compiles native tests (nativeTestCompile) for all subprojects\\nnativeTraceImage - Builds trace-enabled native tests for matching coordinates\\ntckClean - Cleans all matching subprojects (TCK)\\n\\nBuild Setup tasks\\n-----------------\\ninit - Initializes a new Gradle build.\\nupdateDaemonJvm - Generates or updates the Gradle Daemon JVM criteria.\\nwrapper - Generates Gradle wrapper files.\\n\\nHelp tasks\\n----------\\nartifactTransforms - Displays the Artifact Transforms that can be executed in root project 'reachability-metadata'.\\nbuildEnvironment - Displays all buildscript dependencies declared in root project 'reachability-metadata'.\\ndependencies - Displays all dependencies declared in root project 'reachability-metadata'.\\ndependencyInsight - Displays the insight into a specific dependency in root project 'reachability-metadata'.\\nhelp - Displays a help message.\\njavaToolchains - Displays the detected java toolchains.\\noutgoingVariants - Displays the outgoing variants of root project 'reachability-metadata'.\\nprojects - Displays the sub-projects of root project 'reachability-metadata'.\\nproperties - Displays the properties of root project 'reachability-metadata'.\\nresolvableConfigurations - Displays the configurations that can be resolved in root project 'reachability-metadata'.\\ntasks - Displays the tasks runnable from root project 'reachability-metadata'.\\n\\nMetadata tasks\\n--------------\\naddLibraryAsLatestMetadataIndexJson - Marks given coordinates as latest in metadata/group/artifact/index.json\\naddLibraryMetadataIndexJson - Adds given coordinates to metadata/group/artifact/index.json without changing the latest entry\\naddTestedVersion - Updates list of tested versions.\\nanalyzeExternalLibraryDynamicAccess - Resolves an external Maven coordinate and reports preserve/track dynamic-access totals\\ncheckAllowedDockerImages - Returns list of allowed docker images\\ncheckMetadataFiles - Checks content of metadata files for matching coordinates\\ncontribute - Generates metadata and prepares pull request for contibuting on metadata repository based on provided tests.\\ndiscoverArtifactMetadata - Uses a coding agent command to discover artifact metadata for a single coordinate and stores it under build/.\\nextractLibraryTestParams - Extracts TEST_PATH, LATEST_VERSION and TEST_COORDINATES for given coordinates (group:artifact[:version]). Writes them into GITHUB_ENV.\\nfetchExistingLibrariesWithNewerVersions - Returns list of all libraries coordinates\\nfixTestNativeImageRun - Fix test that fails Native Image run for new library version.\\ngenerateAffectedSpringTestMatrix - Computes GA changes from git diff, scans Spring AOT for impacted tests, and emits a ready-to-use GitHub Actions matrix.\\ngenerateChangedCoordinatesMatrix - Returns matrix definition populated with coordinates of changed libraries\\ngenerateChangedCoordinatesOnlyMatrix - Returns a coordinate-only matrix definition populated with changed coordinates\\ngenerateChangedIndexFileCoordinatesList - Returns a list of changed coordinates for validation based on git diff\\ngenerateChangedMetadataTestMatrix - Returns matrix definition populated with changed coordinates and batched tested versions from metadata index files\\ngenerateDependencyGraph - Prints deps.dev dependency graph for matching coordinates\\ngenerateDynamicAccessCoverageReport - Generates a per-class dynamic-access coverage report for matching coordinates\\ngenerateDynamicAccessReport - Builds native tests and prints generated dynamic-access JSON report files for matching coordinates\\ngenerateInfrastructureChangedCoordinatesMatrix - Returns matrix definition populated with pre-selected coordinates when test infrastructure has changed\\ngenerateLibraryStats - Generates local library stats and updates stats/<group>/<artifact>/<metadata-version>/stats.json\\ngenerateMatrixBatchedCoordinates - Returns matrix definition populated with fractional batch coordinates (k/n)\\ngenerateMatrixMatchingCoordinates - Returns matrix definition populated with all matching coordinates\\ngenerateMetadata - Generates metadata based on provided tests.\\ngenerateNewLibraryVersionCompatibilityMatrix - Returns matrix definition populated with newer library versions and CI environments\\ngenerateReadmeBadgeSummary - Generates current README metrics data, coverage Markdown, and updates README metrics history\\nlistCoordinates - Lists all matching GAV coordinates (one per line) honoring -Pcoordinates filter; use -PstrictCoordinates=true for strict matching\\nlistLibraryJars - Lists resolved tested-library JARs for matching coordinates (one per line)\\nmergeNativeTraceMetadata - Merges runtime metadata trace output directories with native-image-utils generate\\npopulateArtifactURLs - Uses a coding agent command to fill source-code-url, repository-url, test-code-url, documentation-url, description, and language in matching metadata index entries.\\npullAllowedDockerImages - Computes and pulls allowed docker images required by matching coordinates\\nscaffold - Creates a metadata and test scaffold for the given coordindates\\nsplitTestOnlyMetadata - Moves test-only entries from library reachability metadata into test resources metadata.\\n\\nPublishing tasks\\n----------------\\npackage - Packages current repository to 'build/graalvm-reachability-metadata-1.0.0-SNAPSHOT.zip'\\n\\nVerification tasks\\n------------------\\ncheck - Runs all checks.\\ncheckDocLinks - Verifies that every repo-local link in Markdown documentation resolves\\ncheckstyle - Runs checkstyle on all subprojects\\ndiff - Tests GraalVM Reflection Metadata that was changed between 'baseCommit' and 'newCommit'\\njacocoTestReport - Generates JaCoCo coverage reports for all subprojects (runs tests first)\\njavaTest - Runs JVM tests (Gradle 'test') for all subprojects\\nrunNativeTraceImage - Runs trace-enabled native tests once for matching coordinates\\nspotlessApply - Applies code formatting steps to sourcecode in-place.\\nspotlessCheck - Checks that sourcecode satisfies formatting steps.\\nspotlessDiagnose\\ntckTest - Runs Native Image tests for all matching coordinates (TCK)\\ntest - Aggregates tests configured by the TCK harness\\ntestAllInfra - Determines one artifact coordinate via generateInfrastructureChangedCoordinatesMatrix (or uses -Pcoordinate/-Pcoordinates if provided), then runs testInfra for that coordinate and also for 1/64. Options: -Pparallelism to control concurrency.\\ntestInfra - Runs clean and pullAllowedDockerImages, then runs (validateIndexFiles, checkstyle, spotlessCheck, checkMetadataFiles, fetchExistingLibrariesWithNewerVersions, test, jacocoTestReport, listLibraryJars, generateDynamicAccessReport, generateDynamicAccessCoverageReport, generateLibraryStats, listCoordinates, generateDependencyGraph, splitTestOnlyMetadata) concurrently with isolated logs for a single coordinate.\\n                        Options: -Pcoordinate or -Pcoordinates to specify the target; -Pparallelism to control the number of concurrent tasks.\\nvalidateIndexFiles - Checks content of index.json files for matching coordinates or files\\nvalidateLibraryStats - Validates exploded stats/*.json files against the committed JSON schema\\n\\nOther tasks\\n-----------\\nprepareKotlinBuildScriptModel\\nspotlessGroovy\\nspotlessGroovyApply\\nspotlessGroovyCheck\\nspotlessGroovyDiagnose\\nspotlessGroovyGradle\\nspotlessGroovyGradleApply\\nspotlessGroovyGradleCheck\\nspotlessGroovyGradleDiagnose\\nspotlessInternalRegisterDependencies\\nspotlessJava\\nspotlessJavaA