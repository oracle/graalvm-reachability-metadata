    39\t            \"Linux\", \"Mac\", \"Darwin\", \"Solaris\", \"SunOS\", \"FreeBSD\");\n    40\t\n    41\t    @Test\n    42\t    void loadsJniTerminalProviderThroughPublicServiceApi() throws Exception {\n    43\t        TerminalProvider provider = TerminalProvider.load(\"jni\");\n    44\t\n    45\t        assertThat(provider).isInstanceOf(JniTerminalProvider.class);\n    46\t        assertThat(provider.name()).isEqualTo(\"jni\");\n    47\t        assertThat(provider).hasToString(\"TerminalProvider[jni]\");\n    48\t\n    49\t        for (SystemStream stream : SystemStream.values()) {\n    50\t            assertThat(provider.systemStreamWidth(stream)).isGreaterThanOrEqualTo(-1);\n    51\t            assertThat(provider.isSystemStream(stream)).isIn(true, false);\n    52\t        }\n    53\t    }\n    54\t\n    55\t    @Test\n    56\t    void openCreatesConfiguredNativePtyOnSupportedPosixPlatforms() throws Exception {\n    57\t        assumeFutureDefaultsPtySupport();\n    58\t\n    59\t        TerminalProvider provider = TerminalProvider.load(\"jni\");\n    60\t        Attributes attributes = attributesForPty();\n    61\t        Size requestedSize = new Size(81, 27);\n    62\t\n    63\t        if (isSupportedPosixOperatingSystem()) {\n    64\t            try (Pty pty = ((JniTerminalProvider) provider).open(attributes, requestedSize)) {\n    65\t                assertThat(pty).isInstanceOf(JniNativePty.class);\n    66\t                assertThat(pty.getProvider()).isSameAs(provider);\n    67\t                assertThat(pty.getSystemStream()).isNull();\n    68\t\n    69\t                JniNativePty nativePty = (JniNativePty) pty;\n    70\t                assertThat(nativePty.getMaster()).isGreaterThan(0);\n    71\t                assertThat(nativePty.getSlave()).isGreaterThan(0);\n    72\t                assertThat(nativePty.getSlaveOut()).isEqualTo(nativePty.getSlave());\n    73\t                assertThat(nativePty.getMasterFD()).isNotNull();\n    74\t                assertThat(nativePty.getSlaveFD()).isNotNull();\n    75\t                assertThat(nativePty.getSlaveOutFD()).isSameAs(nativePty.getSlaveFD());\n    76\t                assertThat(nativePty.getName()).isNotBlank();\n    77\t                assertThat(nativePty).hasToString(\"NativePty[\" + nativePty.getName() + \"]\");\n    78\t\n    79\t                assertThat(nativePty.getSize()).isEqualTo(requestedSize);\n    80\t                Size resized = new Size(100, 31);\n    81\t                nativePty.setSize(resized);\n    82\t                assertThat(nativePty.getSize()).isEqualTo(resized);\n    83\t\n    84\t                Attributes actualAttributes = nativePty.getAttr();\n    85\t                assertThat(actualAttributes.getLocalFlag(Attributes.LocalFlag.ECHO)).isFalse();\n    86\t                assertThat(actualAttributes.getLocalFlag(Attributes.LocalFlag.ICANON)).isTrue();\n    87\t                assertThat(actualAttributes.getInputFlag(Attributes.InputFlag.ICRNL)).isTrue();\n    88\t                assertThat(actualAttributes.getControlChar(Attributes.ControlChar.VERASE)).isEqualTo(127);\n    89\t            }\n    90\t        } else {\n    91\t            assertThatThrownBy(() -> ((JniTerminalProvider) provider).open(attributes, requestedSize))\n    92\t                    .isInstanceOf(UnsupportedOperationException.class);\n    93\t        }\n    94\t    }\n    95\t\n    96\t    @Test\n    97\t    void nativePtyExposesConnectedMasterAndSlaveStreams() throws Exception {\n    98\t        assumeFutureDefaultsPtySupport();\n    99\t\n   100\t        TerminalProvider provider = TerminalProvider.load(\"jni\");\n   101\t        Attributes attributes = attributesForPty();\n   102\t        Size requestedSize = new Size(80, 24);\n   103\t\n   104\t        if (isSupportedPosixOperatingSystem()) {\n   105\t            try (Pty pty = ((JniTerminalProvider) provider).open(attributes, requestedSize)) {\n   106\t                byte[] payload = \"jni-pty-payload\".getBytes(StandardCharsets.UTF_8);\n   107\t                InputStream masterInput = pty.getMasterInput();\n   108\t                OutputStream slaveOutput = pty.getSlaveOutput();\n   109\t                ExecutorService executor = newDaemonSingleThreadExecutor(\"jni-pty-reader\");\n   110\t                Future<byte[]> readFromMaster = executor.submit(() -> readExactly(masterInput, payload.length));\n   111\t\n   112\t                try {\n   113\t                    slaveOutput.write(payload);\n   114\t                    slaveOutput.flush();\n   115\t\n   116\t                    assertThat(readFromMaster.get(5, TimeUnit.SECONDS)).containsExactly(payload);\n   117\t                } finally {\n   118\t                    readFromMaster.cancel(true);\n   119\t                    executor.shutdownNow();\n   120\t                    assertThat(executor.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n   121\t                }\n   122\t            }\n   123\t        } else {\n   124\t            assertThatThrownBy(() -> ((JniTerminalProvider) provider).open(attributes, requestedSize))\n   125\t                    .isInstanceOf(UnsupportedOperationException.class);\n   126\t        }\n   127\t    }\n   128\t\n   129\t    @Test\n   130\t    void nativePtyAppliesAttributeChangesAfterOpen() throws Exception {\n   131\t        assumeFutureDefaultsPtySupport();\n   132\t\n   133\t        TerminalProvider provider = TerminalProvider.load(\"jni\");\n   134\t        Attributes attributes = attributesForPty();\n   135\t        Size requestedSize = new Size(80, 24);\n   136\t\n   137\t        if (isSupportedPosixOperatingSystem()) {\n   138\t            try (Pty pty = ((JniTerminalProvider) provider).open(attributes, requestedSize)) {\n   139\t                Attributes updatedAttributes = new Attributes(pty.getAttr());\n   140\t                updatedAttributes.setLocalFlag(Attributes.LocalFlag.ECHO, true);\n   141\t                updatedAttributes.setLocalFlag(Attributes.LocalFlag.ICANON, false);\n   142\t                updatedAttributes.setInputFlag(Attributes.InputFlag.ICRNL, false);\n   143\t                updatedAttributes.setControlChar(Attributes.ControlChar.VMIN, 0);\n   144\t                updatedAttributes.setControlChar(Attributes.ControlChar.VTIME, 1);\n   145\t\n   146\t                pty.setAttr(updatedAttributes);\n   147\t\n   148\t                Attributes actualAttributes = pty.getAttr();\n   149\t                assertThat(actualAttributes.getLocalFlag(Attributes.LocalFlag.ECHO)).isTrue();\n   150\t                assertThat(actualAttributes.getLocalFlag(Attributes.LocalFlag.ICANON)).isFalse();\n   151\t                assertThat(actualAttributes.getInputFlag(Attributes.InputFlag.ICRNL)).isFalse();\n   152\t                assertThat(actualAttributes.getControlChar(Attributes.ControlChar.VMIN)).isZero();\n   153\t                assertThat(actualAttributes.getControlChar(Attributes.ControlChar.VTIME)).isEqualTo(1);\n   154\t            }\n   155\t        } else {\n   156\t            assertThatThrownBy(() -> ((JniTerminalProvider) provider).open(attributes, requestedSize))\n   157\t                    .isInstanceOf(UnsupportedOperationException.class);\n   158\t        }\n   159\t    }\n   160\t\n   161\t    @Test\n   162\t    void terminalBuilderCreatesJniBackedTerminalForExplicitStreams() throws Exception {\n   163\t        assumeFutureDefaultsPtySupport();\n   164\t\n   165\t        if (isSupportedPosixOperatingSystem()) {\n   166\t            ByteArrayOutputStream output = new ByteArrayOutputStream();\n   167\t            try (Terminal terminal = buildTerminal(output)) {\n   168\t                assertThat(terminal.getName()).isEqualTo(\"jni-test-terminal\");\n   169\t                assertThat(terminal.getType()).isEqualTo(\"xterm-256color\");\n   170\t                assertThat(terminal.encoding()).isEqualTo(StandardCharsets.UTF_8);\n   171\t                assertThat(terminal).isInstanceOf(TerminalExt.class);\n   172\t\n   173\t                TerminalExt terminalExt = (TerminalExt) terminal;\n   174\t                assertThat(terminalExt.getProvider().name()).isEqualTo(\"jni\");\n   175\t                assertThat(terminalExt.getSystemStream()).isNull();\n   176\t\n   177\t                assertThat(terminal.getSize()).isEqualTo(new Size(90, 33));\n   178\t                terminal.setSize(new Size(91, 34));\n   179\t                assertThat(terminal.getWidth()).isEqualTo(91);\n   180\t                assertThat(terminal.getHeight()).isEqualTo(34);\n   181\t\n   182\t                assertThat(terminal.echo()).isFalse();\n   183\t                assertThat(terminal.canPauseResume()).isTrue();\n   184\t                assertThat(terminal.paused()).isTrue();\n   185\t                terminal.pause();\n   186\t                assertThat(terminal.paused()).isTrue();\n   187\t                assertThat(terminal.reader()).isNotNull();\n   188\t                assertThat(terminal.writer()).isNotNull();\n   189\t                assertThat(output.size()).isZero();\n   190\t            }\n   191\t        } else {\n   192\t            assertThatThrownBy(() -> buildTerminal(new ByteArrayOutputStream()))\n   193\t                    .isInstanceOf(UnsupportedOperationException.class);\n   194\t        }\n   195\t    }\n   196\t\n   197\t    private static ExecutorService newDaemonSingleThreadExecutor(String threadName) {\n   198\t        return Executors.newSingleThreadExecutor(runnable -> {\n   199\t            Thread thread = new Thread(runnable, threadName);\n   200\t            thread.setDaemon(true);\n   201\t            return thread;\n   202\t        });\n   203\t    }\n   204\t\n   205\t    private static byte[] readExactly(InputStream input, int length) throws Exception {\n   206\t        byte[] buffer = new byte[length];\n   207\t        int offset = 0;\n   208\t        while (offset < length) {\n   209\t            int read = input.read(buffer, offset, length - offset);\n   210\t            if (read < 0) {\n   211\t                throw new EOFException(\"Expected \" + length + \" bytes, read \" + offset);\n   212\t            }\n   213\t            offset += read;\n   214\t        }\n   215\t        return buffer;\n   216\t    }\n   217\t\n   218\t    private static Terminal buildTerminal(ByteArrayOutputStream output) throws Exception {\n   219\t        return TerminalBuilder.builder()\n   220\t                .provider(\"jni\")\n   221\t                .system(false)\n   222\t                .name(\"jni-test-terminal\")\n   223\t                .type(\"xterm-256color\")\n   224\t                .encoding(StandardCharsets.UTF_8)\n   225\t                .streams(new ByteArrayInputStream(new byte[0]), output)\n   226\t                .attributes(attributesForPty())\n   227\t                .size(new Size(90, 33))\n   228\t                .nativeSignals(false)\n   229\t                .paused(true)\n   230\t                .build();\n   231\t    }\n   232\t\n   233\t    private static Attributes attributesForPty() {\n   234\t        Attributes attributes = new Attributes();\n   235\t        attributes.setLocalFlag(Attributes.LocalFlag.ECHO, false);\n   236\t        attributes.setLocalFlag(Attributes.LocalFlag.ICANON, true);\n   237\t        attributes.setInputFlag(Attributes.InputFlag.ICRNL, true);\n   238\t        attributes.setOutputFlag(Attributes.OutputFlag.OPOST, true);\n   239\t        attributes.setControlFlag(Attributes.ControlFlag.CREAD, true);\n   240\t        attributes.setControlChar(Attributes.ControlChar.VERASE, 127);\n   241\t        attributes.setControlChar(Attributes.ControlChar.VMIN, 1);\n   242\t        return attributes;\n   243\t    }\n   244\t\n   245\t    private static boolean isSupportedPosixOperatingSystem() {\n   246\t        String osName = System.getProperty(\"os.name\", \"\");\n   247\t        return SUPPORTED_POSIX_OS_PREFIXES.stream().anyMatch(osName::startsWith);\n   248\t    }\n   249