  package com_typesafe_akka.akka_protobuf_v3_3
  
  import java.lang.invoke.MethodHandle
  import java.lang.invoke.MethodHandles
  import java.lang.invoke.MethodType.methodType
  
  import org.assertj.core.api.Assertions.assertThat
  
  import org.junit.jupiter.api.Test
  
  class UnsafeUtilTest {
    @Test
    def initializesAndroidUnsafeChecksAndAllocatesWithoutConstructor(): Unit = {
      val unsafeUtilClass: Class[?] = Class.forName(
        UnsafeUtilTest.UnsafeUtilClassName,
        true,
        getClass.getClassLoader
      )
      val lookup: MethodHandles.Lookup = MethodHandles.privateLookupIn(
        unsafeUtilClass,
        MethodHandles.lookup()
      )
  
      val isAndroid64: MethodHandle = lookup.findStatic(
        unsafeUtilClass,
        "isAndroid64",
        methodType(classOf[Boolean])
      )
      assertThat(isAndroid64.invoke().asInstanceOf[Boolean]).isTrue()
  
      val allocateInstance: MethodHandle = lookup.findStatic(
        unsafeUtilClass,
        "allocateInstance",
        methodType(classOf[Object], classOf[Class[?]])
      )
      val instance: ConstructorGuardedType = allocateInstance
        .invoke(classOf[ConstructorGuardedType])
        .asInstanceOf[ConstructorGuardedType]
  
      assertThat(instance.constructorValue).isZero()
    }
  }
  
  object UnsafeUtilTest {
    private val UnsafeUtilClassName: String = "akka.protobufv3.internal.UnsafeUtil"
  
    final class ConstructorGuardedType private () {
      private val guardedValue: Int = 42
      throw new AssertionError("Unsafe allocation must not invoke constructors")
  
      def constructorValue: Int = guardedValue
