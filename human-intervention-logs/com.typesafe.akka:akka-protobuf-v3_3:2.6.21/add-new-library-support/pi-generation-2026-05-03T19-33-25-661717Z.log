  package com_typesafe_akka.akka_protobuf_v3_3
  
  import java.lang.invoke.MethodHandle
  import java.lang.invoke.MethodHandles
  import java.lang.invoke.MethodType.methodType
  
  import akka.protobufv3.internal.ListValue
  import akka.protobufv3.internal.Value
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  class DescriptorMessageInfoFactoryTest {
    @Test
    def buildsMessageInfoForOneofAndRepeatedMessageFields(): Unit = {
      val factoryClass: Class[?] = Class.forName(
        DescriptorMessageInfoFactoryTest.FactoryClassName,
        true,
        getClass.getClassLoader
      )
      val messageInfoClass: Class[?] = Class.forName(
        DescriptorMessageInfoFactoryTest.MessageInfoClassName,
        true,
        getClass.getClassLoader
      )
      val lookup: MethodHandles.Lookup = MethodHandles.privateLookupIn(
        factoryClass,
        MethodHandles.lookup()
      )
  
      val getInstance: MethodHandle = lookup.findStatic(
        factoryClass,
        "getInstance",
        methodType(factoryClass)
      )
      val messageInfoFor: MethodHandle = lookup.findVirtual(
        factoryClass,
        "messageInfoFor",
        methodType(messageInfoClass, classOf[Class[?]])
      )
  
      val factory: Object = getInstance.invoke().asInstanceOf[Object]
      val valueInfo: Object = messageInfoFor.invoke(factory, classOf[Value]).asInstanceOf[Object]
      val listValueInfo: Object = messageInfoFor.invoke(factory, classOf[ListValue]).asInstanceOf[Object]
  
      assertThat(valueInfo).isNotNull()
      assertThat(listValueInfo).isNotNull()
    }
  }
  
  object DescriptorMessageInfoFactoryTest {
    private val FactoryClassName: String = "akka.protobufv3.internal.DescriptorMessageInfoFactory"
    private val MessageInfoClassName: String = "akka.protobufv3.internal.MessageInfo"
  }
