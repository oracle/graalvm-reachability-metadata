ssageLite.Builder = new SerializedFormModernBuilder().mergeFrom(payload())\\n\\n  override def getDefaultInstanceForType: MessageLite = SerializedFormModernLiteMessage.DEFAULT_INSTANCE\\n}\\n\\nobject SerializedFormModernLiteMessage {\\n  @static val DEFAULT_INSTANCE: SerializedFormModernLiteMessage = new SerializedFormModernLiteMessage(Array.emptyByteArray)\\n}\\n\\nfinal class SerializedFormLegacyLiteMessage(bytes: Array[Byte]) extends SerializedFormBaseLiteMessage(bytes) {\\n  override def newBuilderForType(): MessageLite.Builder = new SerializedFormLegacyBuilder()\\n\\n  override def toBuilder(): MessageLite.Builder = new SerializedFormLegacyBuilder().mergeFrom(payload())\\n\\n  override def getDefaultInstanceForType: MessageLite = SerializedFormLegacyLiteMessage.defaultInstance\\n}\\n\\nobject SerializedFormLegacyLiteMessage {\\n  @static val defaultInstance: SerializedFormLegacyLiteMessage = new SerializedFormLegacyLiteMessage(Array.emptyByteArray)\\n}\\n\\nabstract class SerializedFormBaseBuilder extends MessageLite.Builder {\\n  private var bytes: Array[Byte] = Array.emptyByteArray\\n\\n  override def clear(): MessageLite.Builder = {\\n    bytes = Array.emptyByteArray\\n    this\\n  }\\n\\n  override def build(): MessageLite = buildPartial()\\n\\n  override def clone(): MessageLite.Builder = {\\n    val cloned: SerializedFormBaseBuilder = newBuilder()\\n    cloned.bytes = Arrays.copyOf(bytes, bytes.length)\\n    cloned\\n  }\\n\\n  override def mergeFrom(input: CodedInputStream): MessageLite.Builder = {\\n    mergeFrom(input, ExtensionRegistryLite.getEmptyRegistry)\\n  }\\n\\n  override def mergeFrom(input: CodedInputStream, extensionRegistry: ExtensionRegistryLite): MessageLite.Builder = {\\n    val output: ByteArrayOutputStream = new ByteArrayOutputStream()\\n    while (!input.isAtEnd) {\\n      output.write(input.readRawByte().toInt)\\n    }\\n    mergeFrom(output.toByteArray)\\n  }\\n\\n  override def mergeFrom(data: ByteString): MessageLite.Builder = me