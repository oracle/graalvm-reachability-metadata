ustedAltsForTesting()\n    78\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n    79\t                .build();\n    80\t        ChannelCredentials googleDefaultCredentials = GoogleDefaultChannelCredentials.newBuilder()\n    81\t                .callCredentials(callCredentials)\n    82\t                .altsCallCredentials(new SuccessfulCallCredentials())\n    83\t                .build();\n    84\t        ChannelCredentials computeEngineCredentials = ComputeEngineChannelCredentials.create();\n    85\t\n    86\t        assertThat(altsCredentials).isNotNull();\n    87\t        assertThat(altsCredentials.withoutBearerTokens()).isNotNull();\n    88\t        assertThat(configuredAltsCredentials).isNotNull();\n    89\t        assertThat(configuredAltsCredentials.withoutBearerTokens()).isNotNull();\n    90\t        assertThat(altsServerCredentials).isNotNull();\n    91\t        assertThat(configuredServerCredentials).isNotNull();\n    92\t        assertThat(googleDefaultCredentials).isNotNull();\n    93\t        assertThat(googleDefaultCredentials.withoutBearerTokens()).isNotNull();\n    94\t        assertThat(GoogleDefaultChannelCredentials.create()).isNotNull();\n    95\t        assertThat(computeEngineCredentials).isNotNull();\n    96\t        assertThat(computeEngineCredentials.withoutBearerTokens()).isNotNull();\n    97\t    }\n    98\t\n    99\t    @Test\n   100\t    void altsContextExposesTestPeerAndLocalIdentity() {\n   101\t        AltsContext context = AltsContext.createTestInstance(\n   102\t                \"peer@example.iam.gserviceaccount.com\",\n   103\t                \"local@example.iam.gserviceaccount.com\");\n   104\t\n   105\t        assertThat(context.getPeerServiceAccount()).isEqualTo(\"peer@example.iam.gserviceaccount.com\");\n   106\t        assertThat(context.getLocalServiceAccount()).isEqualTo(\"local@example.iam.gserviceaccount.com\");\n   107\t        assertThat(context.getSecurityLevel()).isEqualTo(AltsContext.SecurityLevel.