c.alts.ComputeEngineChannelBuilder;\n    43\timport io.grpc.alts.ComputeEngineChannelCredentials;\n    44\timport io.grpc.alts.GoogleDefaultChannelBuilder;\n    45\timport io.grpc.alts.GoogleDefaultChannelCredentials;\n    46\timport java.io.ByteArrayInputStream;\n    47\timport java.io.File;\n    48\timport java.io.IOException;\n    49\timport java.io.InputStream;\n    50\timport java.nio.charset.StandardCharsets;\n    51\timport java.util.ArrayList;\n    52\timport java.util.List;\n    53\timport java.util.concurrent.Executor;\n    54\timport java.util.concurrent.TimeUnit;\n    55\timport org.junit.jupiter.api.Test;\n    56\t\n    57\tpublic class Grpc_altsTest {\n    58\t    private static final MethodDescriptor<String, String> UNARY_METHOD = MethodDescriptor.<String, String>newBuilder()\n    59\t            .setType(MethodDescriptor.MethodType.UNARY)\n    60\t            .setFullMethodName(MethodDescriptor.generateFullMethodName(\"alts.TestService\", \"Echo\"))\n    61\t            .setRequestMarshaller(new StringMarshaller())\n    62\t            .setResponseMarshaller(new StringMarshaller())\n    63\t            .build();\n    64\t\n    65\t    @Test\n    66\t    void createsAllCredentialVariants() {\n    67\t        CallCredentials callCredentials = new SuccessfulCallCredentials();\n    68\t\n    69\t        ChannelCredentials altsCredentials = AltsChannelCredentials.create();\n    70\t        ChannelCredentials configuredAltsCredentials = AltsChannelCredentials.newBuilder()\n    71\t                .addTargetServiceAccount(\"target@example.iam.gserviceaccount.com\")\n    72\t                .enableUntrustedAltsForTesting()\n    73\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n    74\t                .build();\n    75\t        ServerCredentials altsServerCredentials = AltsServerCredentials.create();\n    76\t        ServerCredentials configuredServerCredentials = AltsServerCredentials.newBuilder()\n    77\t                .enableUntrustedAltsForTesting()\n    78\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n    79\t                .build();\n    80\t        ChannelCredentials googleDefaultCredentials = GoogleDefaultChannelCredentials.newBuilder()\n    81\t                .callCredentials(callCredentials)\n    82\t                .altsCallCredentials(new SuccessfulCallCredentials())\n    83\t                .build();\n    84\t        ChannelCredentials computeEngineCredentials = ComputeEngineChannelCredentials.create();\n    85\t\n    86\t        assertThat(altsCredentials).isNotNull();\n    87\t        assertThat(altsCredentials.withoutBearerTokens()).isNotNull();\n    88\t        assertThat(configuredAltsCredentials).isNotNull();\n    89\t        assertThat(configuredAltsCredentials.withoutBearerTokens()).isNotNull();\n    90\t        assertThat(altsServerCredentials).isNotNull();\n    91\t        assertThat(configuredServerCredentials).isNotNull();\n    92\t        assertThat(googleDefaultCredentials).isNotNull();\n    93\t        assertThat(googleDefaultCredentials.withoutBearerTokens()).isNotNull();\n    94\t        assertThat(GoogleDefaultChannelCredentials.create()).isNotNull();\n    95\t        assertThat(computeEngineCredentials).isNotNull();\n    96\t        assertThat(computeEngineCredentials.withoutBearerTokens()).isNotNull();\n    97\t    }\n    98\t\n    99\t    @Test\n   100\t    void altsContextExposesTestPeerAndLocalIdentity() {\n   101\t        AltsContext context = AltsContext.createTestInstance(\n   102\t                \"peer@example.iam.gserviceaccount.com\",\n   103\t                \"local@example.iam.gserviceaccount.com\");\n   104\t\n   105\t        assertThat(context.getPeerServiceAccount()).isEqualTo(\"peer@example.iam.gserviceaccount.com\");\n   106\t        assertThat(context.getLocalServiceAccount()).isEqualTo(\"local@example.iam.gserviceaccount.com\");\n   107\t        assertThat(context.getSecurityLevel()).isEqualTo(AltsContext.SecurityLevel.INTEGRITY_AND_PRIVACY);\n   108\t        assertThat(AltsContext.SecurityLevel.valueOf(\"INTEGRITY_AND_PRIVACY\"))\n   109\t                .isEqualTo(AltsContext.SecurityLevel.INTEGRITY_AND_PRIVACY);\n   110\t        assertThat(AltsContext.SecurityLevel.values()).contains(\n   111\t                AltsContext.SecurityLevel.UNKNOWN,\n   112\t                AltsContext.SecurityLevel.SECURITY_NONE,\n   113\t                AltsContext.SecurityLevel.INTEGRITY_ONLY,\n   114\t                AltsContext.SecurityLevel.INTEGRITY_AND_PRIVACY);\n   115\t    }\n   116\t\n   117\t    @Test\n   118\t    void altsContextUtilitiesRejectCallsWithoutAltsAttributes() {\n   119\t        ServerCall<String, String> serverCall = new PlainServerCall();\n   120\t        ClientCall<String, String> clientCall = new PlainClientCall();\n   121\t\n   122\t        assertThat(AltsContextUtil.check(Attributes.EMPTY)).isFalse();\n   123\t        assertThat(AltsContextUtil.check(serverCall)).isFalse();\n   124\t        assertThat(AltsContextUtil.check(clientCall)).isFalse();\n   125\t        assertThatThrownBy(() -> AltsContextUtil.createFrom(Attributes.EMPTY))\n   126\t                .isInstanceOf(IllegalArgumentException.class)\n   127\t                .hasMessageContaining(\"No ALTS context information found\");\n   128\t        assertThatThrownBy(() -> AltsContextUtil.createFrom(serverCall))\n   129\t                .isInstanceOf(IllegalArgumentException.class)\n   130\t                .hasMessageContaining(\"No ALTS context information found\");\n   131\t        assertThatThrownBy(() -> AltsContextUtil.createFrom(clientCall))\n   132\t                .isInstanceOf(IllegalArgumentException.class)\n   133\t                .hasMessageContaining(\"No ALTS context information found\");\n   134\t\n   135\t        Status authorizationStatus = AuthorizationUtil.clientAuthorizationCheck(\n   136\t                serverCall,\n   137\t                List.of(\"peer@example.iam.gserviceaccount.com\"));\n   138\t        assertThat(authorizationStatus.getCode()).isEqualTo(Status.Code.PERMISSION_DENIED);\n   139\t        assertThat(authorizationStatus.getDescription()).contains(\"Peer ALTS AuthContext not found\");\n   140\t    }\n   141\t\n   142\t    @Test\n   143\t    void altsServerBuilderStartsWithConfiguredForwardedOptions() throws IOException, InterruptedException {\n   144\t        Server server = AltsServerBuilder.forPort(0)\n   145\t                .enableUntrustedAltsForTesting()\n   146\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n   147\t                .directExecutor()\n   148\t                .handshakeTimeout(1, TimeUnit.SECONDS)\n   149\t                .compressorRegistry(CompressorRegistry.getDefaultInstance())\n   150\t                .decompressorRegistry(DecompressorRegistry.getDefaultInstance())\n   151\t                .addTransportFilter(new ServerTransportFilter())\n   152\t                .build();\n   153\t\n   154\t        try {\n   155\t            server.start();\n   156\t            assertThat(server.getPort()).isGreaterThan(0);\n   157\t        } finally {\n   158\t            shutdownServer(server);\n   159\t        }\n   160\t    }\n   161\t\n   162\t    @Test\n   163\t    void altsServerBuilderRejectsTlsConfiguration() {\n   164\t        AltsServerBuilder builder = AltsServerBuilder.forPort(0);\n   165\t\n   166\t        assertThatThrownBy(() -> builder.useTransportSecurity(new File(\"cert.pem\"), new File(\"key.pem\")))\n   167\t                .isInstanceOf(UnsupportedOperationException.class)\n   168\t                .hasMessageContaining(\"ALTS\");\n   169\t    }\n   170\t\n   171\t    @Test\n   172\t    void altsServerBuilderRegistersBindableServices() throws IOException, InterruptedException {\n   173\t        Server server = AltsServerBuilder.forPort(0)\n   174\t                .enableUntrustedAltsForTesting()\n   175\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n   176\t                