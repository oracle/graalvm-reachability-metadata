   138\t        assertThat(authorizationStatus.getCode()).isEqualTo(Status.Code.PERMISSION_DENIED);\n   139\t        assertThat(authorizationStatus.getDescription()).contains(\"Peer ALTS AuthContext not found\");\n   140\t    }\n   141\t\n   142\t    @Test\n   143\t    void altsServerBuilderStartsWithConfiguredForwardedOptions() throws IOException, InterruptedException {\n   144\t        Server server = AltsServerBuilder.forPort(0)\n   145\t                .enableUntrustedAltsForTesting()\n   146\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n   147\t                .directExecutor()\n   148\t                .handshakeTimeout(1, TimeUnit.SECONDS)\n   149\t                .compressorRegistry(CompressorRegistry.getDefaultInstance())\n   150\t                .decompressorRegistry(DecompressorRegistry.getDefaultInstance())\n   151\t                .addTransportFilter(new ServerTransportFilter() {\n   152\t                })\n   153\t                .build();\n   154\t\n   155\t        try {\n   156\t            server.start();\n   157\t            assertThat(server.getPort()).isGreaterThan(0);\n   158\t        } finally {\n   159\t            shutdownServer(server);\n   160\t        }\n   161\t    }\n   162\t\n   163\t    @Test\n   164\t    void altsServerBuilderRejectsTlsConfiguration() {\n   165\t        AltsServerBuilder builder = AltsServerBuilder.forPort(0);\n   166\t\n   167\t        assertThatThrownBy(() -> builder.useTransportSecurity(new File(\"cert.pem\"), new File(\"key.pem\")))\n   168\t                .isInstanceOf(UnsupportedOperationException.class)\n   169\t                .hasMessageContaining(\"ALTS\");\n   170\t    }\n   171\t\n   172\t    @Test\n   173\t    void altsServerBuilderRegistersBindableServices() throws IOException, InterruptedException {\n   174\t        Server server = AltsServerBuilder.forPort(0)\n   175\t                .enableUntrustedAltsForTesting()\n   176\t                .setHandshakerAddressForTesting(\"127.0.