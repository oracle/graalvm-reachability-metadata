erMethodDefinition<String, String>) service.getMethod(\n   216\t                    UNARY_METHOD.getFullMethodName());\n   217\t            RecordingServerCall call = new RecordingServerCall();\n   218\t\n   219\t            method.getServerCallHandler().startCall(call, new Metadata());\n   220\t\n   221\t            assertThat(call.getMessages()).containsExactly(\"response\");\n   222\t            assertThat(call.getStatus().getCode()).isEqualTo(Status.Code.OK);\n   223\t        } finally {\n   224\t            shutdownServer(server);\n   225\t        }\n   226\t    }\n   227\t\n   228\t    @Test\n   229\t    void altsChannelBuilderProducesBoundedRpcFailureWhenHandshakeCannotComplete() throws InterruptedException {\n   230\t        ManagedChannel channel = AltsChannelBuilder.forAddress(\"127.0.0.1\", 1)\n   231\t                .addTargetServiceAccount(\"target@example.iam.gserviceaccount.com\")\n   232\t                .enableUntrustedAltsForTesting()\n   233\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n   234\t                .directExecutor()\n   235\t                .build();\n   236\t\n   237\t        try {\n   238\t            assertThatThrownBy(() -> ClientCalls.blockingUnaryCall(\n   239\t                    channel,\n   240\t                    UNARY_METHOD,\n   241\t                    CallOptions.DEFAULT.withDeadlineAfter(2, TimeUnit.SECONDS),\n   242\t                    \"request\"))\n   243\t                    .isInstanceOf(StatusRuntimeException.class)\n   244\t                    .satisfies(error -> assertThat(((StatusRuntimeException) error).getStatus().getCode())\n   245\t                            .isNotEqualTo(Status.Code.OK));\n   246\t        } finally {\n   247\t            shutdownChannel(channel);\n   248\t        }\n   249\t    }\n   250\t\n   251\t    @Test\n   252\t    void googleDefaultAndComputeEngineBuildersCreateManagedChannels() throws InterruptedException {\n   253\t        ManagedChannel googleDefaultChannel = null;\n   254\t        ManagedChannel computeEngineChannel = null;\n   255\t        try {\n   256\t            googleDefaultChannel = GoogleDefaultChannelBuilder.forAddress(\"127.0.0.1\", 1)\n   257\t                    .directExecutor()\n   258\t                    .build();\n   259\t            computeEngineChannel = ComputeEngineChannelBuilder.forTarget(\"dns:///localhost:1\")\n   260\t                    .directExecutor()\n","exit_code":0,"status":"completed"}}
