getMethod(\n   215\t                    UNARY_METHOD.getFullMethodName());\n   216\t            RecordingServerCall call = new RecordingServerCall();\n   217\t\n   218\t            method.getServerCallHandler().startCall(call, new Metadata());\n   219\t\n   220\t            assertThat(call.getMessages()).containsExactly(\"intercepted:response\");\n   221\t            assertThat(call.getStatus().getCode()).isEqualTo(Status.Code.OK);\n   222\t        } finally {\n   223\t            shutdownServer(server);\n   224\t        }\n   225\t    }\n   226\t\n   227\t    @Test\n   228\t    void altsChannelBuilderProducesBoundedRpcFailureWhenHandshakeCannotComplete() throws InterruptedException {\n   229\t        ManagedChannel channel = AltsChannelBuilder.forAddress(\"127.0.0.1\", 1)\n   230\t                .addTargetServiceAccount(\"target@example.iam.gserviceaccount.com\")\n   231\t                .enableUntrustedAltsForTesting()\n   232\t                .setHandshakerAddressForTesting(\"127.0.0.1:1\")\n   233\t                .directExecutor()\n   234\t                .build();\n   235\t\n   236\t        try {\n   237\t            assertThatThrownBy(() -> ClientCalls.blockingUnaryCall(\n   238\t                    channel,\n   239\t                    UNARY_METHOD,\n   240\t                    CallOptions.DEFAULT.withDeadlineAfter(2, TimeUnit.SECONDS),\n   241\t                    \"request\"))\n   242\t                    .isInstanceOf(StatusRuntimeException.class)\n   243\t                    .satisfies(error -> assertThat(((StatusRuntimeException) error).getStatus().getCode())\n   244\t                            .isNotEqualTo(Status.Code.OK));\n   245\t        } finally {\n   246\t            shutdownChannel(channel);\n   247\t        }\n   248\t    }\n   249\t\n   250\t    @Test\n   251\t    void googleDefaultAndComputeEngineBuildersCreateManagedChannels() throws InterruptedException {\n   252\t        ManagedChannel googleDefaultChannel = null;\n   253\t        ManagedChannel computeEngineChannel = null;\n   254\t        try {\n   255\t            googleDefaultChannel = GoogleDefaultChannelBuilder.forAddress(\"127.0.0.1\", 1)\n   256\t                    .directExecutor()\n   257\t                    .build();\n   258\t            computeEngineChannel = ComputeEngineChannelBuilder.forTarget(\"dns:///localhost:1\")\n   259\t                    .directExecutor()\n   260\t                    .build();\n   261\t\n   262\t            assertThat(googleDefaultChannel).isNotNull();\n   263\t            assertThat(computeEngineChannel).isNotNull();\n   264\t        } finally {\n   265\t            shutdownChannelIfCreated(googleDefaultChannel);\n   266\t            shutdownChannelIfCreated(computeEngineChannel);\n   267\t        }\n   268\t    }\n   269\t\n   270\t    private static void shutdownServer(Server server) throws InterruptedException {\n   271\t        server.shutdownNow();\n   272\t        assertThat(server.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n   273\t    }\n   274\t\n   275\t    private static void shutdownChannel(ManagedChannel channel) throws InterruptedException {\n   276\t        channel.shutdownNow();\n   277\t        assertThat(channel.awaitTermination(5, TimeUnit.SECONDS)).isTrue();\n   278\t    }\n   279\t\n   280\t    private static void shutdownChannelIfCreated(ManagedChannel channel) throws InterruptedException {\n   281\t        if (channel != null) {\n   282\t            shutdownChannel(channel);\n   283\t        }\n   284\t    }\n   285\t\n   286\t    private static final class SuccessfulCallCredentials extends CallCredentials {\n   287\t        @Override\n   288\t        public void applyRequestMetadata(RequestInfo requestInfo, Executor executor, MetadataApplier applier) {\n   289\t            executor.execute(() -> applier.apply(new Metadata()));\n   290\t        }\n   291\t    }\n   292\t\n   293\t    private static final class StringMarshaller implements MethodDescriptor.Marshaller<String> {\n