rk. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n     6\\t */\\n     7\\tpackage io_grpc.grpc_alts;\\n     8\\t\\n     9\\timport static org.assertj.core.api.Assertions.assertThat;\\n    10\\timport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n    11\\t\\n    12\\timport io.grpc.Attributes;\\n    13\\timport io.grpc.BindableService;\\n    14\\timport io.grpc.CallCredentials;\\n    15\\timport io.grpc.CallOptions;\\n    16\\timport io.grpc.ChannelCredentials;\\n    17\\timport io.grpc.ClientCall;\\n    18\\timport io.grpc.ClientCalls;\\n    19\\timport io.grpc.CompressorRegistry;\\n    20\\timport io.grpc.DecompressorRegistry;\\n    21\\timport io.grpc.ForwardingServerCall;\\n    22\\timport io.grpc.ManagedChannel;\\n    23\\timport io.grpc.Metadata;\\n    24\\timport io.grpc.MethodDescriptor;\\n    25\\timport io.grpc.Server;\\n    26\\timport io.grpc.ServerCall;\\n    27\\timport io.grpc.ServerCallHandler;\\n    28\\timport io.grpc.ServerCredentials;\\n    29\\timport io.grpc.ServerInterceptor;\\n    30\\timport io.grpc.ServerMethodDefinition;\\n    31\\timport io.grpc.ServerServiceDefinition;\\n    32\\timport io.grpc.ServerTransportFilter;\\n    33\\timport io.grpc.Status;\\n    34\\timport io.grpc.StatusRuntimeException;\\n    35\\timport io.grpc.alts.AltsChannelBuilder;\\n    36\\timport io.grpc.alts.AltsChannelCredentials;\\n    37\\timport io.grpc.alts.AltsContext;\\n    38\\timport io.grpc.alts.AltsContextUtil;\\n    39\\timport io.grpc.alts.AltsServerBuilder;\\n    40\\timport io.grpc.alts.AltsServerCredentials;\\n    41\\timport io.grpc.alts.AuthorizationUtil;\\n    42\\timport io.grpc.alts.ComputeEngineChannelBuilder;\\n    43\\timport io.grpc.alts.ComputeEngineChannelCredentials;\\n    44\\timport io.grpc.alts.GoogleDefaultChannelBuilder;\\n    45\\timport io.grpc.alts.GoogleDefaultChannelCredentials;\\n    46\\timport java.io.ByteArrayInputStream;\\n    47\\timport java.io.File;\\n    48\\timport java.io.IOException