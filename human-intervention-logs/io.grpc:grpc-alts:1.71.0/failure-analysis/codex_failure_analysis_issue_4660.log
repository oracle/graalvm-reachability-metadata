xInterceptor)\\\\n   202\\\\t                .addService(new EchoBindableService())\\\\n   203\\\\t                .build();\\\\n   204\\\\t\\\\n   205\\\\t        try {\\\\n   206\\\\t            server.start();\\\\n   207\\\\t\\\\n   208\\\\t            ServerServiceDefinition service = server.getServices().stream()\\\\n   209\\\\t                    .filter(serviceDefinition -> \\\\\\\"alts.TestService\\\\\\\".equals(\\\\n   210\\\\t                            serviceDefinition.getServiceDescriptor().getName()))\\\\n   211\\\\t                    .findFirst()\\\\n   212\\\\t                    .orElseThrow();\\\\n   213\\\\t            @SuppressWarnings(\\\\\\\"unchecked\\\\\\\")\\\\n   214\\\\t            ServerMethodDefinition<String, String> method = (ServerMethodDefinition<String, String>) service.getMethod(\\\\n   215\\\\t                    UNARY_METHOD.getFullMethodName());\\\\n   216\\\\t            RecordingServerCall call = new RecordingServerCall();\\\\n   217\\\\t\\\\n   218\\\\t            method.getServerCallHandler().startCall(call, new Metadata());\\\\n   219\\\\t\\\\n   220\\\\t            assertThat(call.getMessages()).containsExactly(\\\\\\\"intercepted:response\\\\\\\");\\\\n   221\\\\t            assertThat(call.getStatus().getCode()).isEqualTo(Status.Code.OK);\\\\n   222\\\\t        } finally {\\\\n   223\\\\t            shutdownServer(server);\\\\n   224\\\\t        }\\\\n   225\\\\t    }\\\\n   226\\\\t\\\\n   227\\\\t    @Test\\\\n   228\\\\t    void altsChannelBuilderProducesBoundedRpcFailureWhenHandshakeCannotComplete() throws InterruptedException {\\\\n   229\\\\t        ManagedChannel channel = AltsChannelBuilder.forAddress(\\\\\\\"127.0.0.1\\\\\\\", 1)\\\\n   230\\\\t                .addTargetServiceAccount(\\\\\\\"target@example.iam.gserviceaccount.com\\\\\\\")\\\\n   231\\\\t                .enableUntrustedAltsForTesting()\\\\n   232\\\\t                .setHandshakerAddressForTesting(\\\\\\\"127.0.0.1:1\\\\\\\")\\\\n   233\\\\t   