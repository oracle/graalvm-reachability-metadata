                .callCredentials(callCredentials)\\n    82\\t                .altsCallCredentials(new SuccessfulCallCredentials())\\n    83\\t                .build();\\n    84\\t        ChannelCredentials computeEngineCredentials = ComputeEngineChannelCredentials.create();\\n    85\\t\\n    86\\t        assertThat(altsCredentials).isNotNull();\\n    87\\t        assertThat(altsCredentials.withoutBearerTokens()).isNotNull();\\n    88\\t        assertThat(configuredAltsCredentials).isNotNull();\\n    89\\t        assertThat(configuredAltsCredentials.withoutBearerTokens()).isNotNull();\\n    90\\t        assertThat(altsServerCredentials).isNotNull();\\n    91\\t        assertThat(configuredServerCredentials).isNotNull();\\n    92\\t        assertThat(googleDefaultCredentials).isNotNull();\\n    93\\t        assertThat(googleDefaultCredentials.withoutBearerTokens()).isNotNull();\\n    94\\t        assertThat(GoogleDefaultChannelCredentials.create()).isNotNull();\\n    95\\t        assertThat(computeEngineCredentials).isNotNull();\\n    96\\t        assertThat(computeEngineCredentials.withoutBearerTokens()).isNotNull();\\n    97\\t    }\\n    98\\t\\n    99\\t    @Test\\n   100\\t    void altsContextExposesTestPeerAndLocalIdentity() {\\n   101\\t        AltsContext context = AltsContext.createTestInstance(\\n   102\\t                \\\"peer@example.iam.gserviceaccount.com\\\",\\n   103\\t                \\\"local@example.iam.gserviceaccount.com\\\");\\n   104\\t\\n   105\\t        assertThat(context.getPeerServiceAccount()).isEqualTo(\\\"peer@example.iam.gserviceaccount.com\\\");\\n   106\\t        assertThat(context.getLocalServiceAccount()).isEqualTo(\\\"local@example.iam.gserviceaccount.com\\\");\\n   107\\t        assertThat(context.getSecurityLevel()).isEqualTo(AltsContext.SecurityLevel.INTEGRITY_AND_PRIVACY);\\n   108\\t        assertThat(AltsContext.SecurityLevel.valueOf(\\\"INTEGRITY_AND_PRIVACY\\\"))\\n   109\\t                .isEqualTo(AltsContext.SecurityLevel.INTEGRITY_AND_PRIVACY);\\n   110\\t        assertThat(AltsContext.SecurityLevel.values()).contains(\\n   111\\t                AltsContext.SecurityLevel.UNKNOWN,\\n   112\\t                AltsContext.SecurityLevel.SECURITY_NONE,\\n   113\\t                AltsContext.SecurityLevel.INTEGRITY_ONLY,\\n   114\\t                AltsContext.SecurityLevel.INTEGRITY_AND_PRIVACY);\\n   115\\t    }\\n   116\\t\\n   117\\t    @Test\\n   118\\t    void altsContextUtilitiesRejectCallsWithoutAltsAttributes() {\\n   119\\t        ServerCall<String, String> serverCall = new PlainServerCall();\\n   120\\t        ClientCall<String, String> clientCall = new PlainClientCall();\\n   121\\t\\n   122\\t        assertThat(AltsContextUtil.check(Attributes.EMPTY)).isFalse();\\n   123\\t        assertThat(AltsContextUtil.check(serverCall)).isFalse();\\n   124\\t        assertThat(AltsContextUtil.check(clientCall)).isFalse();\\n   125\\t        assertThatThrownBy(() -> AltsContextUtil.createFrom(Attributes.EMPTY))\\n   126\\t                .isInstanceOf(IllegalArgumentException.class)\\n   127\\t                .hasMessageContaining(\\\"No ALTS context information found\\\");\\n   128\\t        assertThatThrownBy(() -> AltsContextUtil.createFrom(serverCall))\\n   129\\t                .isInstanceOf(IllegalArgumentException.class)\\n   130\\t                .hasMessageContaining(\\\"No ALTS context information found\\\");\\n   131\\t        assertThatThrownBy(() -> AltsContextUtil.createFrom(clientCall))\\n   132\\t                .isInstanceOf(IllegalArgumentException.class)\\n   133\\t                .hasMessageContaining(\\\"No ALTS context information found\\\");\\n   134\\t\\n   135\\t        Status authorizationStatus = AuthorizationUtil.clientAuthorizationCheck(\\n   136\\t                serverCall,\\n   137\\t                List.of(\\\"peer@example.iam.gserviceaccount.com\\\"));\\n   138\\t        assertThat(authorizationStatus.getCode()).isEqualTo(Status.Code.PERMISSION_DENIED);\\n   139\\t        assertThat(authorizationStatus.getDescription()).contains(\\\"Peer ALTS AuthContext not found\\\");\\n   140\\t    }\\n   141\\t\\n   142\\t    @Test\\n   143\\t    void altsServerBuilderStartsWithConfiguredForwardedOptions() throws IOException, InterruptedException {\\n   144\\t        Server server = AltsServerBuilder.forPort(0)\\n   145\\t                .enableUntrustedAltsForTesting()\\n   146\\t                .setHandshakerAddressForTesting(\\\"127.0.0.1:1\\\")\\n   147\\t                .directExecutor()\\n   148\\t                .handshakeTimeout(1, TimeUnit.SECONDS)\\n   149\\t                .compressorRegistry(CompressorRegistry.getDefaultInstance())\\n   150\\t                .decompressorRegistry(DecompressorRegistry.getDefaultInstance())\\n   151\\t                .addTransportFilter(new ServerTransportFilter())\\n   152\\t                .build();\\n   153\\t\\n   154\\t        try {\\n   155\\t            server.start();\\n   156\\t            assertThat(server.getPort()).isGreaterThan(0);\\n   157\\t        } finally {\\n   158\\t            shutdownServer(server);\\n   159\\t        }\\n   160\\t    }\\n   161\\t\\n   162\\t    @Test\\n   163\\t    void altsServerBuilderRejectsTlsConfiguration() {\\n   164\\t        AltsServerBuilder builder = AltsServerBuilder.forPort(0);\\n   165\\t\\n   166\\t        assertThatThrownBy(() -> builder.useTransportSecurity(new File(\\\"cert.pem\\\"), new File(\\\"key.pem\\\")))\\n   167\\t                .isInstanceOf(UnsupportedOperationException.class)\\n   168\\t                .hasMessageContaining(\\\"ALTS\\\");\\n   169\\t    }\\n   170\\t\\n   171\\t    @Test\\n   172\\t    void altsServerBuilderRegistersBindableServices() throws IOException, InterruptedException {\\n   173\\t        Server server = AltsServerBuilder.forPort(0)\\n   174\\t                .enableUntrustedAltsForTesting()\\n   175\\t                .setHandshakerAddressForTesting(\\\"127.0.0.1:1\\\")\\n   176\\t                .directExecutor()\\n   177\\t                .addService(new EchoBindableService())\\n   178\\t                .build();\\n   179\\t\\n   180\\t        try {\\n   181\\t            server.start();\\n   182\\t\\n   183\\t            ServerServiceDefinition service = server.getServices().stream()\\n   184\\t                    .filter(serviceDefinition -> \\\"alts.TestService\\\".equals(\\n   185\\t                            serviceDefinition.getServiceDescriptor().getName()))\\n   186\\t                    .findFirst()\\n   187\\t                    .orElseThrow();\\n   188\\t            assertThat(service.getMethod(UNARY_METHOD.getFullMethodName())).isNotNull();\\n   189\\t        } finally {\\n   190\\t            shutdownServer(server);\\n   191\\t        }\\n   192\\t    }\\n   193\\t\\n   194\\t    @Test\\n   195\\t    void altsServerBuilderAppliesInterceptorsToRegisteredServices() throws IOException, InterruptedException {\\n   196\\t        ServerInterceptor responsePrefixInterceptor = new ResponsePrefixingInterceptor();\\n   197\\t        Server server = AltsServerBuilder.forPort(0)\\n   198\\t                .enableUntrustedAltsForTesting()\\n   199\\t                .setHandshakerAddressForTesting(\\\"127.0.0.1:1\\\")\\n   200\\t                .directExecutor()\\n   201\\t                .intercept(responsePrefixInterceptor)\\n   202\\t                .addService(new EchoBindableService())\\n   203\\t                .build();\\n   204\\t\\n   205\\t        try {\\n   206\\t            server.start();\\n   207\\t\\n   208\\t            ServerServiceDefinition service = server.getServices().stream()\\n   209\\t                    .filter(serviceDefinition -> \\\"alts.TestService\\\".equals(\\n   210\\t                            serviceDefinition.getServiceDescriptor().getName()))\\n   211\\t                    .findFirst()\\n   212\\t                    .orElseThrow();\\n   213\\t            @SuppressWarnings(\\\"unchecked\\\")\\n   214\\t            ServerMethodDefinition<String, String> method = (ServerMethodDefinition<String, String>) service.getMethod(\\n   215\\t                    UNARY_METHOD.getFullMethodName());\\n   216\\t            RecordingServerCall call = new RecordingServerCall();\\n   217\\t\\n   218\\t            method.getServerCallHandler().startCall(call, new Metadata());\\n   219\\t\\n   220\\t            assertThat(call.getMessages()).containsExactly(\\\"intercepted:response\\\");\\n   221\\t            assertThat(call.getStatus().getCode()).isEqualTo(Status.Code.OK);\\n   222\\t        } finally {\\n   223\\t            shutdownServer(server);\\n   224\\t        }\\n   225\\t    }\\n   226\\t\\n   227\\t    @Test\\n   228\\t    void altsChannelBuilderProducesBoundedRpcFailureWhenHandshakeCannotComplete() throws InterruptedException {\\n   229\\t        ManagedChannel channel = AltsChannelBuilder.forAddress(\\\"127.0.0.1\\\", 1)\\n   230\\t                .addTargetServiceAccount(\\\"target@example.iam.gserviceaccount.com\\\")\\n   231\\t                .enableUntrustedAltsForTesting()\\n   232\\t                .setHandshakerAddressForTesting(\\\"127.0.0.1:1\\\")\\n   233\\t                .directExecutor()\\n   234\\t                .build();\\n   235\\t\\n   236\\t        try {\\n   237\\t            assertThatThrownBy(() -> ClientCalls.blockingUnaryCall(\\n   238\\t                    channel,\\n   239\\t                    UNARY_METHOD,\\n   240\\t                    CallOptions.DEFAULT.withDeadlineAfter(2, TimeUnit.SECONDS),\\n   241\\t                    \\\"request\\\"))\\n   242\\t                    .isInstanceOf(StatusRuntimeException.class)\\n   243\\t                    .satisfies(error -> assertThat(((StatusRuntimeException) error).getStatus().getCode())\\n   244\\t                            .isNotEqualTo(Status.Code.OK));\\n   245\\t        } finally {\\n   246\\t            shutdownChannel(channel);\\n   247\\t        }\\n   248\\t    }\\n   249\\t\\n   250\\t    @Test\\