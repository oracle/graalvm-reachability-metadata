his\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport java.util\nimport java.util.concurrent.atomic.AtomicBoolean\n\nimport javax.naming.Context\nimport javax.naming.NamingException\nimport javax.naming.spi.InitialContextFactory\nimport javax.naming.spi.InitialContextFactoryBuilder\nimport javax.naming.spi.NamingManager\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nimport com.typesafe.config.Config\nimport com.typesafe.config.ConfigFactory\nimport org.apache.pekko.actor.ActorSystem\nimport org.apache.pekko.io.Dns\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.Timeout\n\n@Timeout(20)\nfinal class DnsSettingsTest {\n  @Test\n  def defaultNameServersFallBackToJdkResolverConfigurationReflection(): Unit = {\n    FailingJndiDnsLookup.install()\n\n    withActorSystem(\"dns-settings-default-nameservers\") { system: ActorSystem =>\n      val dnsManagerName: String = Dns(system).manager.path.name\n\n      assertThat(dnsManagerName).isEqualTo(\"IO-DNS\")\n    }\n  }\n\n  private def withActorSystem(namePrefix: String)(body: ActorSystem => Unit): Unit = {\n    val config: Config = ConfigFactory.parseString(\"\"\"\n      pekko.loglevel = \"OFF\"\n      pekko.io.dns.resolver = async-dns\n      pekko.io.dns.async-dns {\n        nameservers = default\n        resolve-timeout = 1s\n        cache-cleanup-interval = 60s\n      }\n      \"\"\")\n    val systemName: String = s\"$namePrefix-${System.nanoTime()}\"\n    val system: ActorSystem = ActorSystem(systemName, config)\n    try {\n      body(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n\nobject FailingJndiDnsLookup {\n  private val installed: AtomicBoolean = new AtomicBoolean(false)\n\n  def install(): Unit = {\n    if (installed.compareAndSet(false, true)) {\n      try {\n        NamingManager.setInitialContextFactoryBuilder(new InitialContextFactoryBuilder {\n          override def createInitialContextFactory(environment: util.Hashtable[_, _]): InitialContextFactory =\n            new InitialContextFactory {\n              override def getInitialContext(environment: util.Hashtable[_, _]): Context =\n                throw new NamingException(\"Force Pekko DNS settings to use the ResolverConfiguration fallback\")\n            }\n        })\n      } catch {\n        case _: IllegalStateException => installed.set(true)\n      }\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1713, "output": 1117, "cacheRead": 47104, "cacheWrite": 0, "totalTokens": 49934, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778065767991, "responseId": "resp_010a55ec37af26c80169fb21689d308193bc8e68e2b670b3ba"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_w0HCL16NAgs9MzrTw0CJabfu|fc_010a55ec37af26c80169fb216eca30819382fcb7d4bf9befed", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2581 bytes to tests/src/org.apache.pekko/pekko-actor_2.13/1.1.5/src/test/scala/org_apache_pekko/pekko_actor_2_13/DnsSettingsTest.scala"}], "isError": false, "timestamp": 1778065779148}]}
