  package org_apache_pekko.pekko_actor_2_13
  
  import org.apache.pekko.util.LineNumbers
  import org.apache.pekko.util.LineNumbers.NoSourceInfo
  import org.apache.pekko.util.LineNumbers.SourceFile
  import org.apache.pekko.util.LineNumbers.SourceFileLines
  import org.apache.pekko.util.LineNumbers.UnknownSourceFormat
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  final class LineNumbersTest {
    @Test
    def ordinaryObjectReadsClassFileResourceFromClassLoader(): Unit = {
      val target: PlainLineNumberTarget = new PlainLineNumberTarget("ordinary-object")
  
      val source: LineNumbers.Result = LineNumbers(target)
  
      assertResolvedFromThisSource(source)
      assertThat(LineNumbers.prettyName(target)).contains("LineNumbersTest.scala")
    }
  
    @Test
    def serializableLambdaReadsImplementationClassResourceThroughSerializedLambda(): Unit = {
      val target: SerializableLineNumberThunk = () => "serializable-lambda"
  
      assertThat(target.value()).isEqualTo("serializable-lambda")
      val source: LineNumbers.Result = LineNumbers(target)
  
      assertResolvedFromThisSource(source)
    }
  
    private def assertResolvedFromThisSource(source: LineNumbers.Result): Unit = {
      source match {
        case SourceFile(filename) =>
          assertThat(filename).isEqualTo("LineNumbersTest.scala")
        case SourceFileLines(filename, from, to) =>
          assertThat(filename).isEqualTo("LineNumbersTest.scala")
          assertThat(from).isPositive()
          assertThat(to).isGreaterThanOrEqualTo(from)
        case NoSourceInfo =>
          throw new AssertionError("LineNumbers did not find class-file source information")
        case UnknownSourceFormat(explanation) =>
          throw new AssertionError(s"LineNumbers could not parse class-file source information: $explanation")
      }
    }
  }
  
  final class PlainLineNumberTarget(val name: String)
  
  trait SerializableLineNumberThunk extends Serializable {
    def value(): String
  }
