(\"reflect-args\") { system: ActorSystem =>\n      ReflectProbe.reset(expectedEvents = 1)\n\n      val props: Props = Props(classOf[ArgsReflectActor], \"created\", Int.box(7))\n      assertThat(props.actorClass()).isEqualTo(classOf[ArgsReflectActor])\n      val ref = system.actorOf(props, \"args\")\n\n      assertThat(ref.path.name).isEqualTo(\"args\")\n      ReflectProbe.awaitEvent(\"args:created:7\")\n    }\n  }\n\n  @Test\n  def actorSystemCreationInvokesCallerClassLookupWithoutThreadContextClassLoader(): Unit = {\n    val thread: Thread = Thread.currentThread()\n    val originalClassLoader: ClassLoader = thread.getContextClassLoader\n    thread.setContextClassLoader(null)\n    try {\n      withActorSystem(\"reflect-caller-class\") { system: ActorSystem =>\n        assertThat(system.name).startsWith(\"reflect-caller-class\")\n      }\n    } finally {\n      thread.setContextClassLoader(originalClassLoader)\n    }\n  }\n\n  private def withActorSystem(namePrefix: String)(body: ActorSystem => Unit): Unit = {\n    val systemName: String = s\"$namePrefix-${System.nanoTime()}\"\n    val system: ActorSystem = ActorSystem(systemName)\n    try {\n      body(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n\nobject ReflectProbe {\n  private val events: ConcurrentLinkedQueue[String] = new ConcurrentLinkedQueue[String]()\n  @volatile private var latch: CountDownLatch = new CountDownLatch(0)\n\n  def reset(expectedEvents: Int): Unit = {\n    events.clear()\n    latch = new CountDownLatch(expectedEvents)\n  }\n\n  def record(event: String): Unit = {\n    events.add(event)\n    latch.countDown()\n  }\n\n  def awaitEvent(event: String): Unit = {\n    assertThat(latch.await(5, TimeUnit.SECONDS)).isTrue()\n    assertThat(events.contains(event)).isTrue()\n  }\n}\n\nfinal class PublicNoArgReflectActor extends Actor {\n  ReflectProbe.record(\"public-no-arg\")\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n\nfinal class PrivateNoArgReflectActor private () extends Actor {\n  ReflectProbe.record(\"private-no-arg\")\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n\nfinal class ArgsReflectActor(message: String, count: Int) extends Actor {\n  ReflectProbe.record(s\"args:$message:$count\")\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n"}], "isError": false, "timestamp": 1778072060144}}
