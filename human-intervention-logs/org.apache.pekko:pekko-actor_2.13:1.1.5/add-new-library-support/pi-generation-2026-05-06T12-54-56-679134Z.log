opy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport java.util.concurrent.ConcurrentLinkedQueue\nimport java.util.concurrent.CountDownLatch\nimport java.util.concurrent.TimeUnit\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\nimport org.apache.pekko.actor.Actor\nimport org.apache.pekko.actor.ActorSystem\nimport org.apache.pekko.actor.Props\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.Timeout\n\n@Timeout(20)\nfinal class ReflectTest {\n  @Test\n  def publicNoArgActorIsCreatedWithReflectiveDefaultConstructor(): Unit = {\n    withActorSystem(\"reflect-public-no-arg\") { system: ActorSystem =>\n      ReflectProbe.reset(expectedEvents = 1)\n\n      val props: Props = Props(classOf[PublicNoArgReflectActor])\n      val ref = system.actorOf(props, \"public-no-arg\")\n\n      assertThat(ref.path.name).isEqualTo(\"public-no-arg\")\n      ReflectProbe.awaitEvent(\"public-no-arg\")\n    }\n  }\n\n  @Test\n  def privateNoArgActorIsCreatedAfterConstructorIsMadeAccessible(): Unit = {\n    withActorSystem(\"reflect-private-no-arg\") { system: ActorSystem =>\n      ReflectProbe.reset(expectedEvents = 1)\n\n      val props: Props = Props(classOf[PrivateNoArgReflectActor])\n      val ref = system.actorOf(props, \"private-no-arg\")\n\n      assertThat(ref.path.name).isEqualTo(\"private-no-arg\")\n      ReflectProbe.awaitEvent(\"private-no-arg\")\n    }\n  }\n\n  @Test\n  def constructorArgumentsAreMatchedAndInvokedReflectively(): Unit = {\n    withActorSystem(\"reflect-args\") { system: ActorSystem =>\n      ReflectProbe.reset(expectedEvents = 1)\n\n      val props: Props = Props(classOf[ArgsReflectActor], \"created\", Int.box(7))\n      assertThat(props.actorClass()).isEqualTo(classOf[ArgsReflectActor])\n      val ref = system.actorOf(props, \"args\")\n\n      assertThat(ref.path.name).isEqualTo(\"args\")\n      ReflectProbe.awaitEvent(\"args:created:7\")\n    }\n  }\n\n  @Test\n  def actorSystemCreationInvokesCallerClassLookupWithoutThreadContextClassLoader(): Unit = {\n    val thread: Thread = Thread.currentThread()\n    val originalClassLoader: ClassLoader = thread.getContextClassLoader\n    thread.setContextClassLoader(null)\n    try {\n      withActorSystem(\"reflect-caller-class\") { system: ActorSystem =>\n        assertThat(system.name).startsWith(\"reflect-caller-class\")\n      }\n    } finally {\n      thread.setContextClassLoader(originalClassLoader)\n    }\n  }\n\n  private def withActorSystem(namePrefix: String)(body: ActorSystem => Unit): Unit = {\n    val systemName: String = s\"$namePrefix-${System.nanoTime()}\"\n    val system: ActorSystem = ActorSystem(systemName)\n    try {\n      body(system)\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n\nobject ReflectProbe {\n  private val events: ConcurrentLinkedQueue[String] = new ConcurrentLinkedQueue[String]()\n  @volatile private var latch: CountDownLatch = new CountDownLatch(0)\n\n  def reset(expectedEvents: Int): Unit = {\n    events.clear()\n    latch = new CountDownLatch(expectedEvents)\n  }\n\n  def record(event: String): Unit = {\n    events.add(event)\n    latch.countDown()\n  }\n\n  def awaitEvent(event: String): Unit = {\n    assertThat(latch.await(5, TimeUnit.SECONDS)).isTrue()\n    assertThat(events.contains(event)).isTrue()\n  }\n}\n\nfinal class PublicNoArgReflectActor extends Actor {\n  ReflectProbe.record(\"public-no-arg\")\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n\nfinal class PrivateNoArgReflectActor private () extends Actor {\n  ReflectProbe.record(\"private-no-arg\")\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n\nfinal class ArgsReflectActor(message: String, count: Int) extends Actor {\n  ReflectProbe.record(s\"args:$message:$count\")\n\n  override def receive: Receive = Actor.emptyBehavior\n}\n"}], "isError": false, "timestamp": 1778072060144}, {"role": "toolResult", "toolCallId": "call_4Izmyp6zHkvYFEcRHPkRpytd|fc_03be5e5a361de8560169fb39fbd2d4819e8c92896ce2d54cc4", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport org.apache.pekko.util.LineNumbers\nimport org.apache.pekko.util.LineNumbers.NoSourceInfo\nimport org.apache.pekko.util.LineNumbers.SourceFile\nimport org.apache.pekko.util.LineNumbers.SourceFileLines\nimport org.apache.pekko.util.LineNumbers.UnknownSourceFormat\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nfinal class LineNumbersTest {\n  @Test\n  def ordinaryObjectReadsClassFileResourceFromClassLoader(): Unit = {\n    val target: PlainLineNumberTarget = new PlainLineNumberTarget(\"ordinary-object\")\n\n    val source: LineNumbers.Result = LineNumbers(target)\n\n    assertResolvedFromThisSource(source)\n    assertThat(LineNumbers.prettyName(target)).contains(\"LineNumbersTest.scala\")\n  }\n\n  @Test\n  def serializableLambdaReadsImplementationClassResourceThroughSerializedLambda(): Unit = {\n    val target: SerializableLineNumberThunk = () => \"serializable-lambda\"\n\n    assertThat(target.value()).isEqualTo(\"serializable-lambda\")\n    val source: LineNumbers.Result = LineNumbers(target)\n\n    assertResolvedFromThisSource(source)\n  }\n\n  private def assertResolvedFromThisSource(source: LineNumbers.Result): Unit = {\n    source match {\n      case SourceFile(filename) =>\n        assertThat(filename).isEqualTo(\"LineNumbersTest.scala\")\n      case SourceFileLines(filename, from, to) =>\n        assertThat(filename).isEqualTo(\"LineNumbersTest.scala\")\n        assertThat(from).isPositive()\n        assertThat(to).isGreaterThanOrEqualTo(from)\n      case NoSourceInfo =>\n        throw new AssertionError(\"LineNumbers did not find class-file source information\")\n      case UnknownSourceFormat(explanation) =>\n        throw new AssertionError(s\"LineNumbers could not parse class-file source information: $explanation\")\n    }\n  }\n}\n\nfinal class PlainLineNumberTarget(val name: String)\n\ntrait SerializableLineNumberThunk extends Serializable {\n  def value(): String\n}\n"}], "isError": false, "timestamp": 1778072060144}, {"role": "toolResult", "toolCallId": "call_rrMPuBBodDYZpV83KG3x4ZzT|fc_03be5e5a361de8560169fb39fbd2e0819e84e98c4e9ce366bb", "toolName": "read", "content": [{"type": "text", "text": "# Optional explicit tested library coordinates (format: group:artifact:version).\n# If omitted, fallback resolution in org.graalvm.internal.tck.gradle still uses\n# environment variable GVM_TCK_LC and then this property.\nlibrary.coordinates = org.apache.pekko:pekko-actor_2.13:1.1.5\nlibrary.version = 1.1.5\nmetadata.dir = org.apache.pekko/pekko-actor_2.13/1.1.5/\n"}], "isError": false, "timestamp": 1778072060147}, {"role": "toolResult", "toolCallId": "call_Wla1bvHMJojbzxVqRWpzLByh|fc_03be5e5a361de8560169fb39fbd2ec819ea3c24ba3e9667e8c", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"rules\" : [\n    {\n      \"excludeClasses\" : \"**\"\n    },\n    {\n      \"includeClasses\" : \"org.apache.pekko.**\"\n    },\n    {\n      \"includeClasses\" : \"org_apache_pekko.pekko_actor_2_13.**\"\n    }\n  ]\n}\n"}], "isError": false, "timestamp": 1778072060148}]}
