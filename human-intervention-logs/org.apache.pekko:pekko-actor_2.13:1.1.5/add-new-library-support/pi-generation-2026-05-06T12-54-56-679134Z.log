  package org_apache_pekko.pekko_actor_2_13
  
  import java.lang.reflect.Method
  
  import scala.annotation.nowarn
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.junit.jupiter.api.Timeout
  
  @Timeout(20)
  @nowarn("cat=deprecation")
  final class TypedActorInnerMethodCallTest {
    private type MethodCall = org.apache.pekko.actor.TypedActor.MethodCall
  
    @Test
    def invokesNoArgumentMethodWhenParametersAreNull(): Unit = {
      val target: MethodCallTarget = new MethodCallTarget
      val method: Method = classOf[MethodCallTarget].getMethod("noArgumentValue")
      val call: MethodCall = org.apache.pekko.actor.TypedActor.MethodCall(method, null)
  
      val result: AnyRef = call(target)
  
      assertThat(result).isEqualTo("no-argument")
    }
  
    @Test
    def invokesNoArgumentMethodWhenParametersAreEmpty(): Unit = {
      val target: MethodCallTarget = new MethodCallTarget
      val method: Method = classOf[MethodCallTarget].getMethod("emptyArgumentValue")
      val call: MethodCall = org.apache.pekko.actor.TypedActor.MethodCall(method, Array.empty[AnyRef])
  
      val result: AnyRef = call(target)
  
      assertThat(result).isEqualTo("empty-argument-array")
    }
  
    @Test
    def invokesMethodWithSuppliedParameters(): Unit = {
      val target: MethodCallTarget = new MethodCallTarget
      val method: Method = classOf[MethodCallTarget].getMethod("join", classOf[String], classOf[String])
      val call: MethodCall = org.apache.pekko.actor.TypedActor.MethodCall(method, Array[AnyRef]("left", "right"))
  
      val result: AnyRef = call(target)
  
      assertThat(result).isEqualTo("left:right")
    }
  }
  
  final class MethodCallTarget {
    def noArgumentValue(): String = "no-argument"
  
    def emptyArgumentValue(): String = "empty-argument-array"
  
    def join(first: String, second: String): String = s"$first:$second"
  }
