  plugins {
      id "org.graalvm.internal.tck"
      id "scala"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  sourceSets {
      callerClassShim {
          java.srcDir 'src/callerClassShim/java'
      }
  }
  
  tasks.named('compileCallerClassShimJava') {
      options.compilerArgs.addAll([
              '--patch-module',
              "jdk.unsupported=${file('src/callerClassShim/java').absolutePath}"
      ])
  }
  
  tasks.register('callerClassShimJar', Jar) {
      from sourceSets.callerClassShim.output
      archiveClassifier = 'caller-class-shim'
  }
  
  tasks.named('compileTestScala') {
      doLast {
          delete layout.buildDirectory.dir('classes/scala/test/sun').get().asFile
      }
  }
  
  tasks.named('test') {
      dependsOn tasks.named('callerClassShimJar')
      exclude 'sun/reflect/**'
      jvmArgs '--add-opens=java.base/sun.net.dns=ALL-UNNAMED'
      doFirst {
          jvmArgs '--patch-module', "jdk.unsupported=${tasks.named('callerClassShimJar').get().archiveFile.get().asFile.absolutePath}"
      }
  }
  
  dependencies {
      testImplementation "org.apache.pekko:pekko-actor_2.13:$libraryVersion"
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testImplementation 'org.scala-lang:scala-library:2.13.16'
      testImplementation 'org.scala-lang:scala-compiler:2.13.16'
  }
  
  java {
      toolchain {
          languageVersion = JavaLanguageVersion.of(21)
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          all {
              buildArgs.add('--add-opens=java.base/sun.net.dns=ALL-UNNAMED')
          }
      }
  }
