[tool-call] delta {"path":"tests/src/org.apache.pekko/pekko-actor_2.13/1.1.5/src/test/scala/org_apache_pekko/pekko_actor_2_13/VirtualThreadSupportTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport java.util.concurrent.Callable\nimport java.util.concurrent.ExecutorService\nimport java.util.concurrent.Future\nimport java.util.concurrent.ThreadFactory\nimport java.util.concurrent.TimeUnit\n\nimport com.typesafe.config.Config\nimport com.typesafe.config.ConfigFactory\nimport org.apache.pekko.dispatch.ExecutorServiceFactory\nimport org.apache.pekko.dispatch.MonitorableThreadFactory\nimport org.apache.pekko.dispatch.VirtualThreadExecutorConfigurator\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.Timeout\n\n@Timeout(15)\nfinal class VirtualThreadSupportTest {\n  @Test\n  def virtualThreadExecutorFactoryRunsEachTaskOnVirtualThread(): Unit = {\n    val config: Config = ConfigFactory.empty()\n    val configurator = new VirtualThreadExecutorConfigurator(config, null)\n    val threadFactory: ThreadFactory = MonitorableThreadFactory(\n      \"pekko-test\",\n      daemonic = true,\n      contextClassLoader = Some(Thread.currentThread().getContextClassLoader))\n    val executorFactory: ExecutorServiceFactory = configurator.createExecutorServiceFactory(\n      \"virtual-thread-support-test\",\n      threadFactory)\n    val executorService: ExecutorService = executorFactory.createExecutorService\n\n    try {\n      val isVirtualThread: Future[Boolean] = executorService.submit(new Callable[Boolean] {\n        override def call(): Boolean = Thread.currentThread().isVirtual\n      })\n      val threadName: Future[String] = executorService.submit(new Callable[String] {\n        override def call(): String = Thread.currentThread().getName\n      })\n\n      assertThat(isVirtualThread.get(5, TimeUnit.SECONDS)).isTrue()\n      assertThat(threadName.get(5, TimeUnit.SECONDS)).contains(\"pekko-test-virtual-thread-\")\n    } finally {\n      executorService.shutdown()\n      if (!executorService.awaitTermination(2, TimeUnit.SECONDS)) {\n        executorService.shutdownNow()\n        executorService.awaitTermination(2, TimeUnit.SECONDS)\n      }\n    }\n  }\n}\n"}
