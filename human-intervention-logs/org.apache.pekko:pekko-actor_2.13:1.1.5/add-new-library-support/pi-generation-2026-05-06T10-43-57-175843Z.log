[tool-call] delta {"path":"tests/src/org.apache.pekko/pekko-actor_2.13/1.1.5/src/test/scala/org_apache_pekko/pekko_actor_2_13/VirtualThreadSupportTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_pekko.pekko_actor_2_13\n\nimport java.util.concurrent.CountDownLatch\nimport java.util.concurrent.TimeUnit\nimport java.util.concurrent.atomic.AtomicBoolean\nimport java.util.concurrent.atomic.AtomicReference\n\nimport com.typesafe.config.Config\nimport com.typesafe.config.ConfigFactory\nimport org.apache.pekko.actor.Actor\nimport org.apache.pekko.actor.ActorSystem\nimport org.apache.pekko.actor.Props\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.Timeout\n\nimport scala.concurrent.Await\nimport scala.concurrent.duration.DurationInt\n\n@Timeout(15)\nfinal class VirtualThreadSupportTest {\n  @Test\n  def defaultDispatcherRunsActorsOnVirtualThreads(): Unit = {\n    val config: Config = ConfigFactory.parseString(\"\"\"\n      pekko.actor.default-dispatcher.executor = \"virtual-thread-executor\"\n      pekko.actor.default-dispatcher.throughput = 1\n      pekko.loglevel = \"WARNING\"\n      \"\"\").withFallback(ConfigFactory.load())\n    val system: ActorSystem = ActorSystem(\"virtual-thread-support-test\", config)\n    val completed: CountDownLatch = new CountDownLatch(1)\n    val ranOnVirtualThread: AtomicBoolean = new AtomicBoolean(false)\n    val threadName: AtomicReference[String] = new AtomicReference[String]()\n\n    try {\n      val actor = system.actorOf(Props(new VirtualThreadCaptureActor(ranOnVirtualThread, threadName, completed)))\n      actor ! \"capture-thread\"\n\n      assertThat(completed.await(5, TimeUnit.SECONDS)).isTrue()\n      assertThat(ranOnVirtualThread.get()).isTrue()\n      assertThat(threadName.get()).contains(\"virtual-thread\")\n    } finally {\n      Await.result(system.terminate(), 10.seconds)\n    }\n  }\n}\n\nfinal class VirtualThreadCaptureActor(\n    ranOnVirtualThread: AtomicBoolean,\n    threadName: AtomicReference[String],\n    completed: CountDownLatch)\n    extends Actor {\n  override def receive: Receive = {\n    case \"capture-thread\" =>\n      val currentThread: Thread = Thread.currentThread()\n      ranOnVirtualThread.set(currentThread.isVirtual)\n      threadName.set(currentThread.getName)\n      completed.countDown()\n  }\n}\n"}
