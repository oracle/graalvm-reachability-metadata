  package org_apache_pekko.pekko_actor_2_13
  
  import java.util.concurrent.Callable
  import java.util.concurrent.ExecutorService
  import java.util.concurrent.Future
  import java.util.concurrent.ThreadFactory
  import java.util.concurrent.TimeUnit
  
  import com.typesafe.config.Config
  import com.typesafe.config.ConfigFactory
  import org.apache.pekko.dispatch.ExecutorServiceFactory
  import org.apache.pekko.dispatch.MonitorableThreadFactory
  import org.apache.pekko.dispatch.VirtualThreadExecutorConfigurator
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.junit.jupiter.api.Timeout
  
  @Timeout(15)
  final class VirtualThreadSupportTest {
    @Test
    def virtualThreadExecutorFactoryRunsEachTaskOnVirtualThread(): Unit = {
      val config: Config = ConfigFactory.empty()
      val configurator: VirtualThreadExecutorConfigurator = new VirtualThreadExecutorConfigurator(config, null)
      val threadFactory: ThreadFactory = MonitorableThreadFactory(
        "pekko-test",
        daemonic = true,
        contextClassLoader = Some(Thread.currentThread().getContextClassLoader))
      val executorFactory: ExecutorServiceFactory = configurator.createExecutorServiceFactory(
        "virtual-thread-support-test",
        threadFactory)
      val executorService: ExecutorService = executorFactory.createExecutorService
  
      try {
        val isVirtualThread: Future[Boolean] = executorService.submit(new Callable[Boolean] {
          override def call(): Boolean = Thread.currentThread().isVirtual
        })
        val threadName: Future[String] = executorService.submit(new Callable[String] {
          override def call(): String = Thread.currentThread().getName
        })
  
        assertThat(isVirtualThread.get(5, TimeUnit.SECONDS)).isTrue()
        assertThat(threadName.get(5, TimeUnit.SECONDS)).contains("pekko-test-virtual-thread-")
      } finally {
        executorService.shutdown()
        if (!executorService.awaitTermination(2, TimeUnit.SECONDS)) {
          executorService.shutdownNow()
          executorService.awaitTermination(2, TimeUnit.SECONDS)
        }
      }
    }
  }
