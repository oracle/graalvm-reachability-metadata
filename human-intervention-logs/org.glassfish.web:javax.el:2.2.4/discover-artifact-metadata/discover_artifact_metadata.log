    </scm>

    <properties>
        <spec.version>2.2</spec.version>
        <extensionName>javax.el</extensionName>
        <bundle.symbolicName>org.glassfish.web.javax.el</bundle.symbolicName>
        <vendorName>Oracle Corporation</vendorName>
