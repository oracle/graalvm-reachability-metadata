[tool-call] delta {"path":"tests/src/org.glassfish.web/javax.el/2.2.4/src/test/java/org_glassfish_web/javax_el/ReflectionUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_web.javax_el;\n\nimport com.sun.el.util.ReflectionUtil;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionUtilTest {\n    @Test\n    void resolvesClassNamesAndArrayClassNames() throws Exception {\n        Class<?> resolvedClass = ReflectionUtil.forName(InvocationTargetBean.class.getName());\n        Class<?> resolvedArrayClass = ReflectionUtil.forName(InvocationTargetBean.class.getName() + \"[]\");\n\n        assertThat(resolvedClass).isSameAs(InvocationTargetBean.class);\n        assertThat(resolvedArrayClass).isSameAs(InvocationTargetBean[].class);\n    }\n\n    @Test\n    void findsPublicMethodByExplicitParameterTypes() {\n        Method method = ReflectionUtil.getMethod(new InvocationTargetBean(), \"join\", new Class<?>[] {String.class, int.class});\n\n        assertThat(method.getName()).isEqualTo(\"join\");\n        assertThat(method.getParameterTypes()).containsExactly(String.class, int.class);\n    }\n\n    @Test\n    void findsAndInvokesPublicMethodWithCoercedParameters() throws Exception {\n        InvocationTargetBean bean = new InvocationTargetBean();\n\n        Method method = ReflectionUtil.findMethod(bean, \"join\", new Object[] {\"item\", \"3\"});\n        Object result = ReflectionUtil.invokeMethod(bean, \"join\", new Object[] {\"item\", \"3\"});\n\n        assertThat(method.getName()).isEqualTo(\"join\");\n        assertThat(result).isEqualTo(\"item-3\");\n    }\n\n    public static class InvocationTargetBean {\n        public String join(String prefix, int value) {\n            return prefix + \"-\" + value;\n        }\n    }\n}\n"}
