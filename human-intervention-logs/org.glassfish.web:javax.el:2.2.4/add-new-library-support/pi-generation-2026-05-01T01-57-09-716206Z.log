laringClass()).isEqualTo(FunctionMapperImplInnerFunctionTest.class);\n        assertThat(restoredMethod.getName()).isEqualTo(\"join\");\n        assertThat(result).isEqualTo(\"left:right\");\n    }\n\n    public static String join(String left, String right) {\n        return left + \":\" + right;\n    }\n\n    private static FunctionMapperImpl roundTrip(FunctionMapperImpl mapper) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(mapper);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (FunctionMapperImpl) input.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1546, "output": 989, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25575, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777600573526, "responseId": "resp_09be389b8392cffb0169f4083dddf8819ca73d52faf9d62cda"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_SSADP4j71Lth5isJaFrCVpSS|fc_09be389b8392cffb0169f4084589dc819cbae879438afd86c3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1967 bytes to tests/src/org.glassfish.web/javax.el/2.2.4/src/test/java/org_glassfish_web/javax_el/FunctionMapperImplInnerFunctionTest.java"}], "isError": false, "timestamp": 1777600585198}]}
