Test;\n\nimport java.lang.reflect.Method;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ReflectionUtilTest {\n    @Test\n    void resolvesRegularAndArrayClassNames() throws Exception {\n        Class<?> regularType = ReflectionUtil.forName(\"java.lang.String\");\n        Class<?> arrayType = ReflectionUtil.forName(\"java.lang.String[]\");\n\n        assertThat(regularType).isEqualTo(String.class);\n        assertThat(arrayType).isEqualTo(String[].class);\n    }\n\n    @Test\n    void returnsPublicMethodForExplicitParameterTypes() {\n        Method method = ReflectionUtil.getMethod(new MethodTarget(), \"echo\", new Class<?>[] {String.class});\n\n        assertThat(method.getName()).isEqualTo(\"echo\");\n        assertThat(method.getParameterTypes()).containsExactly(String.class);\n    }\n\n    @Test\n    void findsAndInvokesPublicMethodByNameAndArgumentCount() {\n        Method method = ReflectionUtil.findMethod(new MethodTarget(), \"describe\", new Object[] {\"value\", 3});\n        Object result = ReflectionUtil.invokeMethod(new MethodTarget(), \"describe\", new Object[] {\"value\", 3});\n\n        assertThat(method.getName()).isEqualTo(\"describe\");\n        assertThat(result).isEqualTo(\"value:3\");\n    }\n\n    public static final class MethodTarget {\n        public String echo(String value) {\n            return value;\n        }\n\n        public String describe(String value, int count) {\n            return value + \":\" + count;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 432, "output": 1535, "cacheRead": 10240, "cacheWrite": 0, "totalTokens": 12207, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777757882083, "responseId": "resp_03da20097427de220169f66eba69b0819ea007a6fb5c088f9d"}}
