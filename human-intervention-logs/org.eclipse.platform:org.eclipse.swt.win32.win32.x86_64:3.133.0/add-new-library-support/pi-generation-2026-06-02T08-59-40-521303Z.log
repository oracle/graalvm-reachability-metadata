ad(composite);\n\n            assertThat(SWT_AWT.embeddedFrameClass).isEqualTo(Frame.class.getName());\n        } finally {\n            SWT_AWT.embeddedFrameClass = previousEmbeddedFrameClass;\n        }\n    }\n\n    private static Composite allocateEmbeddedComposite() throws Exception {\n        Field unsafeField = Unsafe.class.getDeclaredField(\"theUnsafe\");\n        unsafeField.setAccessible(true);\n        Unsafe unsafe = (Unsafe) unsafeField.get(null);\n        return (Composite) unsafe.allocateInstance(EmbeddedComposite.class);\n    }\n\n    private static void invokeNewFrameOnAwtThread(Composite composite) throws Exception {\n        try {\n            EventQueue.invokeAndWait(() -> {\n                try {\n                    Frame frame = SWT_AWT.new_Frame(composite);\n                    if (frame != null) {\n                        frame.dispose();\n                    }\n                } catch (Throwable expectedWhenNativeBridgeIsUnavailable) {\n                    // The dynamic-access sites are reached before the platform bridge is required.\n                }\n            });\n        } catch (InvocationTargetException e) {\n            throw new AssertionError(\"Unexpected AWT dispatch failure\", e.getCause());\n        }\n    }\n\n    public static class EmbeddedComposite extends Composite {\n        public EmbeddedComposite() {\n            super(null, SWT.NONE);\n        }\n\n        @Override\n        public int getStyle() {\n            return SWT.EMBEDDED;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1667, "output": 857, "cacheRead": 48128, "cacheWrite": 0, "totalTokens": 50652, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780391085663, "responseId": "resp_0253e81474ed6bf8016a1e9caeb1788194aa9fa6f8a6ca98c5"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_PXk8irKaz5WmYovuBrB41mcY|fc_