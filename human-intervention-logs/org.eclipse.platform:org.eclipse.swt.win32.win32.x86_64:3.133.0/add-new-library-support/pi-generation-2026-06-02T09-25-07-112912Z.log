  			if ((i == 0 || mapName) && load (path + SEPARATOR + mappedNames[i], message)) return;
  		}
  	}
  
  	/* Try loading library from java library path */
  	for (int i = 0; i < candidates; i++) {
  		if ((i == 0 || mapName) && load (libNames[i], message)) return;
  	}
  
