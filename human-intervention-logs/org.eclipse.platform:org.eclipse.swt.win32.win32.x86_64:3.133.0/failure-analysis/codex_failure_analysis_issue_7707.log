tem.setProperty(\\\"swt.library.path\\\", libraryPath.toString());\\n\\n            UnsatisfiedLinkError error = catchThrowableOfType(\\n                    () -> Library.loadLibrary(missingLibraryName),\\n                    UnsatisfiedLinkError.class);\\n\\n            assertThat(error)\\n                    .hasMessageContaining(\\\"Could not load SWT library\\\")\\n                    .hasMessageContaining(missingLibraryName);\\n        } finally {\\n            restoreProperty(\\\"swt.library.path\\\", previousLibraryPath);\\n        }\\n    }\\n\\n    private static boolean isWindowsX8664() {\\n        String osName = System.getProperty(\\\"os.name\\\", \\\"\\\");\\n        String osArch = System.getProperty(\\\"os.arch\\\", \\\"\\\");\\n        return osName.startsWith(\\\"Win\\\") && (\\\"amd64\\\".equals(osArch) || \\\"x86_64\\\".equals(osArch));\\n    }\\n\\n    private static void restoreProperty(String propertyName, String propertyValue) {\\n        if (propertyValue == null) {\\n            System.clearProperty(propertyName);\\n        } else {\\n            System.setProperty(propertyName, propertyValue);\\n        }\\n    }\\n}\\n\"}\nhuman-intervention-logs/org.eclipse.platform:org.eclipse.swt.win32.win32.x86_64:3.133.0/add-new-library-support/pi-generation-2026-06-02T09-25-07-112912Z.log:1322:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_07fe491e0040e871016a1ea15793208193b7fb01fddac878e3\\\",\\\"type\\\":\\\"reasoning\\\",\\\"encrypted_content\\\":\\\"gAAAAABqHqFfj_292gXnEFemqi4AiieIMLocfZTjiVp7v-Uk-rHvl_KK8l4RnVXa3Ie_XpyzugyXG6sDn7bCAvCx007-0UyjMYGdF18104VY820HloF3e_AKZ3tXLmhtrlXm6f5xPPMB_p6nt5MMDHputIYcEj0s_bEq6BczyCri9OtklJREG3eh60ZEelc6AtG5FLt0eKDwS0BdNieNEjoDz388E73-jPi0yVFYnocqJQ9kBjcU66IJ05_WH5uGoMfLdUeqEmnvUq0kDGmr3nTWNj9NvJQjk7jBBEJAT6Nazt_93Mbac7yJLle6mckwcY79mChXcoUw2uXXIb59b1EN5_e7E-LVuF46hk8zmJciwPMrpuv6-aW6