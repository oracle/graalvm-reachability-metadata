  package io_quarkus.quarkus_development_mode_spi;
  
  import java.io.Console;
  import java.lang.reflect.Field;
  
  import org.junit.jupiter.api.Test;
  
  import io.quarkus.dev.console.TerminalUtils;
  
  import sun.misc.Unsafe;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TerminalUtilsTest {
  
      @Test
      void nullConsoleIsNotTerminal() {
          assertThat(TerminalUtils.isTerminal(null)).isFalse();
      }
  
      @Test
      void allocatedConsoleExercisesTerminalProbe() throws Exception {
          Console console = (Console) unsafe().allocateInstance(Console.class);
  
          boolean terminal = TerminalUtils.isTerminal(console);
  
          if (Runtime.version().feature() < 22) {
              assertThat(terminal).isTrue();
          } else {
              assertThat(terminal).isEqualTo(System.console() != null);
          }
      }
  
      private static Unsafe unsafe() throws Exception {
          Field unsafeField = Unsafe.class.getDeclaredField("theUnsafe");
          unsafeField.setAccessible(true);
          return (Unsafe) unsafeField.get(null);
      }
  }
