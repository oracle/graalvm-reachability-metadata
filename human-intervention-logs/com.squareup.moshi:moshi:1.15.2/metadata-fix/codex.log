{"type":"item.completed","item":{"id":"item_43","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,260p' tests/src/com.squareup.moshi/moshi/1.15.2/src/test/kotlin/com_squareup_moshi/moshi/TypesTest.kt\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_squareup_moshi.moshi\n\nimport com.squareup.moshi.JsonAdapter\nimport com.squareup.moshi.JsonQualifier\nimport com.squareup.moshi.JsonReader\nimport com.squareup.moshi.JsonWriter\nimport com.squareup.moshi.Moshi\nimport com.squareup.moshi.Types\nimport java.lang.reflect.Type\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class TypesTest {\n    @Test\n    fun getRawTypeCreatesArrayClassForGenericArrayType(): Unit {\n        val arrayType: Type = Types.arrayOf(String::class.java)\n\n        val rawType: Class<*> = Types.getRawType(arrayType)\n\n        assertThat(rawType).isEqualTo(Array<String>::class.java)\n    }\n\n    @Test\n    @Suppress(\"DEPRECATION\")\n    fun getFieldJsonQualifierAnnotationsReturnsQualifierOnDeclaredField(): Unit {\n        val annotations: Set<out Annotation> = Types.getFieldJsonQualifierAnnotations(\n            FieldQualifierHolder::class.java,\n            \"qualifiedValue\",\n        )\n\n        assertThat(annotations).hasSize(1)\n        assertThat(annotations.single().annotationClass.java).isEqualTo(SampleQualifier::class.java)\n    }\n\n    @Test\n    fun adapterWithQualifierClassCreatesRuntimeQualifierImplementation(): Unit {\n        val moshi: Moshi = Moshi.Builder()\n            .add(QualifiedStringAdapterFactory)\n            .build()\n\n        val adapter: JsonAdapter<String> = moshi.adapter(\n            String::class.java,\n            SampleQualifier::class.java,\n        )\n\n        assertThat(adapter.fromJson(\"\\\"input\\\"\")).isEqualTo(\"qualified:input\")\n        assertThat(adapter.toJson(\"output\")).isEqualTo(\"\\\"qualified:output\\\"\")\n    }\n}\n\n@JsonQualifier\n@Retention(AnnotationRetention.RUNTIME)\n@Target(AnnotationTarget.FIELD, AnnotationTarget.VALUE_PARAMETER, AnnotationTarget.FUNCTION)\npublic annotation class SampleQualifier\n\npublic class FieldQualifierHolder(\n    @field:SampleQualifier\n    public val qualifiedValue: String,\n)\n\npublic object QualifiedStringAdapterFactory : JsonAdapter.Factory {\n    override fun create(\n        type: Type,\n        annotations: Set<Annotation>,\n        moshi: Moshi,\n    ): JsonAdapter<*>? {\n        val nextAnnotations: Set<out Annotation> = Types.nextAnnotations(\n            annotations,\n            SampleQualifier::class.java,\n        ) ?: return null\n        if (type != String::class.java || nextAnnotations.isNotEmpty()) {\n            return null\n        }\n        return QualifiedStringAdapter\n    }\n}\n\npublic object QualifiedStringAdapter : JsonAdapter<String>() {\n    override fun fromJson(reader: JsonReader): String {\n        return \"qualified:${reader.nextString()}\"\n    }\n\n    override fun toJson(writer: JsonWriter, value: String?): Unit {\n        writer.value(\"qualified:$value\")\n    }\n}\n","exit_code":0,"status":"completed"}}
