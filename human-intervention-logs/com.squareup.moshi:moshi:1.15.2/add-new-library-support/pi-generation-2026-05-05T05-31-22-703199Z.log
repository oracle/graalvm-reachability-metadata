Util\nimport java.lang.reflect.Type\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\npublic class UtilTest {\n    @Test\n    fun generatedAdapterUsesMoshiConstructorForPlainType(): Unit {\n        val moshi: Moshi = Moshi.Builder().build()\n        val adapter: JsonAdapter<PlainWithMoshi> = moshi.adapter(PlainWithMoshi::class.java)\n\n        assertThat(adapter.toJson(PlainWithMoshi(\"unused\"))).isEqualTo(\"\\\"plain-moshi\\\"\")\n    }\n\n    @Test\n    fun generatedAdapterFallsBackToNoArgumentConstructorForPlainType(): Unit {\n        val moshi: Moshi = Moshi.Builder().build()\n        val adapter: JsonAdapter<PlainWithoutMoshi> = moshi.adapter(PlainWithoutMoshi::class.java)\n\n        assertThat(adapter.toJson(PlainWithoutMoshi(\"unused\"))).isEqualTo(\"\\\"plain-no-args\\\"\")\n    }\n\n    @Test\n    fun generatedAdapterUsesMoshiAndTypeArrayConstructorForParameterizedType(): Unit {\n        val moshi: Moshi = Moshi.Builder().build()\n        val type: Type = Types.newParameterizedType(BoxWithMoshi::class.java, String::class.java)\n        val adapter: JsonAdapter<BoxWithMoshi<String>> = moshi.adapter(type)\n\n        assertThat(adapter.toJson(BoxWithMoshi(\"unused\"))).isEqualTo(\"\\\"box-moshi-java.lang.String\\\"\")\n    }\n\n    @Test\n    fun generatedAdapterFallsBackToTypeArrayConstructorForParameterizedType(): Unit {\n        val moshi: Moshi = Moshi.Builder().build()\n        val type: Type = Types.newParameterizedType(BoxWithoutMoshi::class.java, String::class.java)\n        val adapter: JsonAdapter<BoxWithoutMoshi<String>> = moshi.adapter(type)\n\n        assertThat(adapter.toJson(BoxWithoutMoshi(\"unused\"))).isEqualTo(\"\\\"box-types-java.lang.String\\\"\")\n    }\n\n    @Test\n    fun lookupDefaultsConstructorFindsKotlinDefaultsConstructor(): Unit {\n        val constructor = Util.lookupDefaultsConstructor(KotlinDefaultTarget::class.java)\n\n        assertThat(constructor.parameterTypes.last().name).isEqualTo(\"kotlin.jvm.internal.DefaultConstructorMarker\")\n    }\n}\n\n@JsonClass(generateAdapter = true)\npublic data class PlainWithMoshi(val value: String)\n\npublic class PlainWithMoshiJsonAdapter(private val moshi: Moshi) : JsonAdapter<PlainWithMoshi>() {\n    override fun fromJson(reader: JsonReader): PlainWithMoshi {\n        reader.skipValue()\n        return PlainWithMoshi(\"from-json\")\n    }\n\n    override fun toJson(writer: JsonWriter, value: PlainWithMoshi?): Unit {\n        writer.value(\"plain-moshi\")\n    }\n}\n\n@JsonClass(generateAdapter = true)\npublic data class PlainWithoutMoshi(val value: String)\n\npublic class PlainWithoutMoshiJsonAdapter : JsonAdapter<PlainWithoutMoshi>() {\n    override fun fromJson(reader: JsonReader): PlainWithoutMoshi {\n        reader.skipValue()\n        return PlainWithoutMoshi(\"from-json\")\n    }\n\n    override fun toJson(writer: JsonWriter, value: PlainWithoutMoshi?): Unit {\n        writer.value(\"plain-no-args\")\n    }\n}\n\n@JsonClass(generateAdapter = true)\npublic data class BoxWithMoshi<T>(val value: T)\n\npublic class BoxWithMoshiJsonAdapter<T>(\n    private val moshi: Moshi,\n    private val typeArguments: Array<Type>,\n) : JsonAdapter<BoxWithMoshi<T>>() {\n    override fun fromJson(reader: JsonReader): BoxWithMoshi<T> {\n        reader.skipValue()\n        throw UnsupportedOperationException(\"fromJson is not used by this coverage test\")\n    }\n\n    override fun toJson(writer: JsonWriter, value: BoxWithMoshi<T>?): Unit {\n        writer.value(\"box-moshi-${typeArguments.single().typeName}\")\n    }\n}\n\n@JsonClass(generateAdapter = true)\npublic data class BoxWithoutMoshi<T>(val value: T)\n\npublic class BoxWithoutMoshiJsonAdapter<T>(\n    private val typeArguments: Array<Type>,\n) : JsonAdapter<BoxWithoutMoshi<T>>() {\n    override fun fromJson(reader: JsonReader): BoxWithoutMoshi<T> {\n        reader.skipValue()\n        throw UnsupportedOperationException(\"fromJson is not used by this coverage test\