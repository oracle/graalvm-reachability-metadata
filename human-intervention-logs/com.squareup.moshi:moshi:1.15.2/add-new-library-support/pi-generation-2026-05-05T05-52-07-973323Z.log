  package com_squareup_moshi.moshi
  
  import com.squareup.moshi.JsonAdapter
  import com.squareup.moshi.JsonClass
  import com.squareup.moshi.JsonReader
  import com.squareup.moshi.JsonWriter
  import com.squareup.moshi.Moshi
  import com.squareup.moshi.Types
  import com.squareup.moshi.internal.Util
  import java.lang.reflect.Type
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class UtilTest {
      @Test
      fun generatedAdapterUsesMoshiConstructorForPlainType(): Unit {
          val moshi: Moshi = Moshi.Builder().build()
          val adapter: JsonAdapter<PlainWithMoshi> = moshi.adapter(PlainWithMoshi::class.java)
  
          assertThat(adapter.toJson(PlainWithMoshi("unused"))).isEqualTo("\"plain-moshi\"")
      }
  
      @Test
      fun generatedAdapterFallsBackToNoArgumentConstructorForPlainType(): Unit {
          val moshi: Moshi = Moshi.Builder().build()
          val adapter: JsonAdapter<PlainWithoutMoshi> = moshi.adapter(PlainWithoutMoshi::class.java)
  
          assertThat(adapter.toJson(PlainWithoutMoshi("unused"))).isEqualTo("\"plain-no-args\"")
      }
  
      @Test
      fun generatedAdapterUsesMoshiAndTypeArrayConstructorForParameterizedType(): Unit {
          val moshi: Moshi = Moshi.Builder().build()
          val type: Type = Types.newParameterizedType(BoxWithMoshi::class.java, String::class.java)
          val adapter: JsonAdapter<BoxWithMoshi<String>> = moshi.adapter(type)
  
          assertThat(adapter.toJson(BoxWithMoshi("unused")))
              .isEqualTo("\"box-moshi-java.lang.String\"")
      }
  
      @Test
      fun generatedAdapterFallsBackToTypeArrayConstructorForParameterizedType(): Unit {
          val moshi: Moshi = Moshi.Builder().build()
          val type: Type = Types.newParameterizedType(BoxWithoutMoshi::class.java, String::class.java)
          val adapter: JsonAdapter<BoxWithoutMoshi<String>> = moshi.adapter(type)
  
          assertThat(adapter.toJson(BoxWithoutMoshi("unused")))
              .isEqualTo("\"box-types-java.lang.String\"")
      }
  
      @Test
      fun lookupDefaultsConstructorFindsKotlinDefaultsConstructor(): Unit {
          val constructor = Util.lookupDefaultsConstructor(KotlinDefaultTarget::class.java)
  
          assertThat(constructor.parameterTypes.last().name)
              .isEqualTo("kotlin.jvm.internal.DefaultConstructorMarker")
      }
  }
  
  @JsonClass(generateAdapter = true)
  public data class PlainWithMoshi(val value: String)
  
  public class PlainWithMoshiJsonAdapter(private val moshi: Moshi) : JsonAdapter<PlainWithMoshi>() {
      override fun fromJson(reader: JsonReader): PlainWithMoshi {
          reader.skipValue()
          return PlainWithMoshi("from-json")
      }
  
      override fun toJson(writer: JsonWriter, value: PlainWithMoshi?): Unit {
          writer.value("plain-moshi")
      }
  }
  
  @JsonClass(generateAdapter = true)
  public data class PlainWithoutMoshi(val value: String)
  
  public class PlainWithoutMoshiJsonAdapter : JsonAdapter<PlainWithoutMoshi>() {
      override fun fromJson(reader: JsonReader): PlainWithoutMoshi {
          reader.skipValue()
          return PlainWithoutMoshi("from-json")
      }
  
      override fun toJson(writer: JsonWriter, value: PlainWithoutMoshi?): Unit {
          writer.value("plain-no-args")
      }
  }
  
  @JsonClass(generateAdapter = true)
  public data class BoxWithMoshi<T>(val value: T)
  
  public class BoxWithMoshiJsonAdapter<T>(
      private val moshi: Moshi,
      private val typeArguments: Array<Type>,
  ) : JsonAdapter<BoxWithMoshi<T>>() {
      override fun fromJson(reader: JsonReader): BoxWithMoshi<T> {
          reader.skipValue()
          throw UnsupportedOperationException("fromJson is not used by this coverage test")
      }
  
      override fun toJson(writer: JsonWriter, value: BoxWithMoshi<T>?): Unit {
          writer.value("box-moshi-${typeArguments.single().typeName}")
      }
  }
  
  @JsonClass(generateAdapter = true)
  public data class BoxWithoutMoshi<T>(val value: T)
  
  public class BoxWithoutMoshiJsonAdapter<T>(
      private val typeArguments: Array<Type>,
  ) : JsonAdapter<BoxWithoutMoshi<T>>() {
      override fun fromJson(reader: JsonReader): BoxWithoutMoshi<T> {
          reader.skipValue()
          throw UnsupportedOperationException("fromJson is not used by this coverage test")
