  package com_squareup_moshi.moshi
  
  import com.squareup.moshi.JsonAdapter
  import com.squareup.moshi.JsonQualifier
  import com.squareup.moshi.JsonReader
  import com.squareup.moshi.JsonWriter
  import com.squareup.moshi.Moshi
  import com.squareup.moshi.Types
  import java.lang.reflect.Type
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class TypesTest {
      @Test
      fun getRawTypeCreatesArrayClassForGenericArrayType(): Unit {
          val arrayType: Type = Types.arrayOf(String::class.java)
  
          val rawType: Class<*> = Types.getRawType(arrayType)
  
          assertThat(rawType).isEqualTo(Array<String>::class.java)
      }
  
      @Test
      @Suppress("DEPRECATION")
      fun getFieldJsonQualifierAnnotationsReturnsQualifierOnDeclaredField(): Unit {
          val annotations: Set<out Annotation> = Types.getFieldJsonQualifierAnnotations(
              FieldQualifierHolder::class.java,
              "qualifiedValue",
          )
  
          assertThat(annotations).hasSize(1)
          assertThat(annotations.single().annotationClass.java).isEqualTo(SampleQualifier::class.java)
      }
  
      @Test
      fun adapterWithQualifierClassCreatesRuntimeQualifierImplementation(): Unit {
          val moshi: Moshi = Moshi.Builder()
              .add(QualifiedStringAdapterFactory)
              .build()
  
          val adapter: JsonAdapter<String> = moshi.adapter(
              String::class.java,
              SampleQualifier::class.java,
          )
  
          assertThat(adapter.fromJson("\"input\"")).isEqualTo("qualified:input")
          assertThat(adapter.toJson("output")).isEqualTo("\"qualified:output\"")
      }
  }
  
  @JsonQualifier
  @Retention(AnnotationRetention.RUNTIME)
  @Target(AnnotationTarget.FIELD, AnnotationTarget.VALUE_PARAMETER, AnnotationTarget.FUNCTION)
  public annotation class SampleQualifier
  
  public class FieldQualifierHolder(
      @field:SampleQualifier
      public val qualifiedValue: String,
  )
  
  public object QualifiedStringAdapterFactory : JsonAdapter.Factory {
      override fun create(
          type: Type,
          annotations: Set<Annotation>,
          moshi: Moshi,
      ): JsonAdapter<*>? {
          val nextAnnotations: Set<out Annotation> = Types.nextAnnotations(
              annotations,
              SampleQualifier::class.java,
          ) ?: return null
          if (type != String::class.java || nextAnnotations.isNotEmpty()) {
              return null
          }
          return QualifiedStringAdapter
      }
  }
  
  public object QualifiedStringAdapter : JsonAdapter<String>() {
      override fun fromJson(reader: JsonReader): String {
          return "qualified:${reader.nextString()}"
      }
  
      override fun toJson(writer: JsonWriter, value: String?): Unit {
          writer.value("qualified:$value")
      }
  }
