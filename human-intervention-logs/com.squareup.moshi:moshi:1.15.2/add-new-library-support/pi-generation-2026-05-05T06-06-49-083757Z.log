  package com_squareup_moshi.moshi
  
  import com.squareup.moshi.JsonAdapter
  import com.squareup.moshi.Moshi
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  
  public class RecordJsonAdapterAnonymous1Test {
      @Test
      fun adapterCreatesRecordFromJsonObject(): Unit {
          val moshi: Moshi = Moshi.Builder().build()
          val adapter: JsonAdapter<PersonRecord> = moshi.adapter(PersonRecord::class.java)
  
          val person: PersonRecord? = adapter.fromJson("""{"name":"Ada","age":37}""")
  
          assertThat(person).isEqualTo(PersonRecord("Ada", 37))
          assertThat(adapter.toJson(PersonRecord("Grace", 85)))
              .isEqualTo("""{"name":"Grace","age":85}""")
      }
  }
  
  @JvmRecord
  public data class PersonRecord(
      public val name: String,
      public val age: Int,
  )
