vanov vjovanov   2896 May  5 07:25 gradlew.bat\ndrwxrwxr-x   3 vjovanov vjovanov   4096 May  5 08:07 human-intervention-logs\ndrwxrwxr-x 417 vjovanov vjovanov  20480 May  5 07:28 metadata\n-rw-rw-r--   1 vjovanov vjovanov    385 May  5 07:25 settings.gradle\ndrwxrwxr-x  11 vjovanov vjovanov   4096 May  5 07:25 skills\ndrwxrwxr-x 411 vjovanov vjovanov  20480 May  5 08:07 stats\ndrwxrwxr-x   5 vjovanov vjovanov   4096 May  5 07:25 tests\nrg: logs: IO error for operation on logs: No such file or directory (os error 2)\n","exit_code":1,"status":"failed"}}
