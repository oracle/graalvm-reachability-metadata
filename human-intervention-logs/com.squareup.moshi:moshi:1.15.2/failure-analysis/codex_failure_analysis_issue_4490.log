tring::class.java)\\n\\n        val rawType: Class<*> = Types.getRawType(arrayType)\\n\\n        assertThat(rawType).isEqualTo(Array<String>::class.java)\\n    }\\n\\n    @Test\\n    @Suppress(\\\"DEPRECATION\\\")\\n    fun getFieldJsonQualifierAnnotationsReturnsQualifierOnDeclaredField(): Unit {\\n        val annotations: Set<out Annotation> = Types.getFieldJsonQualifierAnnotations(\\n            FieldQualifierHolder::class.java,\\n            \\\"qualifiedValue\\\",\\n        )\\n\\n        assertThat(annotations).hasSize(1)\\n        assertThat(annotations.single().annotationClass.java).isEqualTo(SampleQualifier::class.java)\\n    }\\n\\n    @Test\\n    fun adapterWithQualifierClassCreatesRuntimeQualifierImplementation(): Unit {\\n        val moshi: Moshi = Moshi.Builder()\\n            .add(QualifiedStringAdapterFactory)\\n            .build()\\n\\n        val adapter: JsonAdapter<String> = moshi.adapter(\\n            String::class.java,\\n            SampleQualifier::class.java,\\n        )\\n\\n        assertThat(adapter.fromJson(\\\"\\\\\\\"input\\\\\\\"\\\")).isEqualTo(\\\"qualified:input\\\")\\n        assertThat(adapter.toJson(\\\"output\\\")).isEqualTo(\\\"\\\\\\\"qualified:output\\\\\\\"\\\")\\n    }\\n}\\n\\n@JsonQualifier\\n@Retention(AnnotationRetention.RUNTIME)\\n@Target(AnnotationTarget.FIELD, AnnotationTarget.VALUE_PARAMETER, AnnotationTarget.FUNCTION)\\npublic annotation class SampleQualifier\\n\\npublic class FieldQualifierHolder(\\n    @field:SampleQualifier\\n    public val qualifiedValue: String,\\n)\\n\\npublic object QualifiedStringAdapterFactory : JsonAdapter.Factory {\\n    override fun create(\\n        type: Type,\\n        annotations: Set<Annotation>,\\n        moshi: Moshi,\\n    ): JsonAdapter<*>? {\\n        val nextAnnotations: Set<out Annotation> = Types.nextAnnotations(\\n            annotations,\\n            SampleQualifier::class.java,\\n        ) ?: return null\\n        if (type != String::class.java || nextAnnotations.isNo