erage_snapshot,\n            reason=\"test_generation_failed\",\n        )\n\n    if run_metrics is None:\n        return None\n\n    strategy_name = run_metrics.get(\"strategy_name\")\n    if not strategy_name:\n        return None\n\n    strategy = load_strategy_by_name(strategy_name)\n","exit_code":0,"status":"completed"}}
