t info message\");\n   130\t\n   131\t    String loggedMessage = Files.readAllLines(Paths.get(filePath)).get(0);\n   132\t    assertThat(loggedMessage).isEqualTo(\"test info message\");\n   133\t  }\n   134\t\n   135\t  @Test\n   136\t  void testRollingFileAppender() throws Exception {\n   137\t    JoranConfigurator joranConfigurator = new JoranConfigurator();\n   138\t    joranConfigurator.setContext(context);\n   139\t\n   140\t    String filePath = tempDirPath + \"/rolling-log.txt\";\n   141\t    String filesTag = AppenderTags.ROLLING_FILE_TAG.formatted(filePath);\n   142\t    String configXml = AppenderTags.CONFIG_TAG.formatted(filesTag);\n   143\t    joranConfigurator.doConfigure(new ByteArrayInputStream(configXml.getBytes()));\n   144\t\n   145\t    Logger testLogger = context.getLogger(Logger.ROOT_LOGGER_NAME);\n   146\t    testLogger.info(\"test info message\");\n   147\t\n   148\t    String loggedMessage = Files.readAllLines(Paths.get(filePath)).get(0);\n   149\t    assertThat(loggedMessage).isEqualTo(\"test info message\");\n   150\t  }\n   151\t\n   152\t  @Test\n   153\t  void consoleAppenderPropertySetter() {\n   154\t    ConsoleAppender consoleAppender = new ConsoleAppender();\n   155\t    PropertySetter propertySetter = new PropertySetter(new BeanDescriptionCache(null), consoleAppender);\n   156\t    propertySetter.setProperty(\"withJansi\", \"true\");\n   157\t    assertThat(consoleAppender.isWithJansi()).isTrue();\n   158\t  }\n   159\t\n   160\t  @ParameterizedTest\n   161\t  @MethodSource(\"converterSource\")\n   162\t  void shouldRegisterConverter(String converterName, String pattern) {\n   163\t    PatternLayoutEncoder encoder = createEncoder(\"%\" + pattern + \" %n\");\n   164\t    ConsoleAppender<ILoggingEvent> consoleAppender = createConsoleAppender(encoder);\n   165\t    Logger logger = getLogger(consoleAppender);\n   166\t    logger.error(converterName, new IllegalArgumentException(\"test error\"));\n   167\t    assertThat(outputStreamCapto