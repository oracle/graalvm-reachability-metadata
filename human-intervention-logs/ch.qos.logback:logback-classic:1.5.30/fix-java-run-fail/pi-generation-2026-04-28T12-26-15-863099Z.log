      40	    //
      41	    // Retrieving version information by self-declared properties solves the issue of collapsed
      42	    // MANIFEST.MF files as encountered in fat-jars.
      43	    //
      44	    // this code further assumes that the properties file is located in the same package as the aClass
      45	    // parameter.
      46	    static String getVersionBySelfDeclaredProperties(Class<?> aClass, String moduleName) {
      47	        Properties props = new Properties();
      48	        // example propertiesFileName: logback-core-version.properties
      49	        //
      50	        String propertiesFileName = moduleName + "-version.properties";
      51	        String propertyKey = moduleName+"-version";
      52	        try (InputStream is = aClass.getResourceAsStream(propertiesFileName)) {
      53	            if (is != null) {
      54	                props.load(is);
      55	                return props.getProperty(propertyKey);
      56	            } else {
      57	                return null;
      58	            }
      59	        } catch (IOException e) {
      60	            return null;
      61	        }
      62	    }
      63	
      64	    /**
      65	     * Retrieves the version information for the "logback-classic" module based on its self-declared properties.
      66	     * The method looks for a properties file named "logback-classic-version.properties" within the classpath,
      67	     * reads its contents, and fetches the value associated with the "logback-classic-version" key.
      68	     *
      69	     * <p>Note that the Class.getResourceAsStream() method checks that the resource is open to the
      70	     * caller. This entails that the caller must be in the same module as the properties file.
      71	     * </p>
      72	     *
      73	     * @return the version string of the "logback-classic" module if found, or null if the properties file or version
      74	     *         key is not present or an error occurs while reading the properties file.
      75	     *
      76	     * @since 1.5.26
      77	     */
      78	    static public String getVersionBySelfDeclaredProperties() {
      79	        Properties props = new Properties();
      80	
      81	        try (InputStream is = ClassicConstants.class.getResourceAsStream(CLASSIC_MODULE_VERSION_PROPERTIES_FILE)) {
      82	            if (is != null) {
      83	                props.load(is);
      84	                return props.getProperty(CLASSIC_MODULE_VERSION_PROPERTY_KEY);
      85	            } else {
      86	                return null;
      87	            }
      88	        } catch (IOException e) {
      89	            return null;
      90	        }
