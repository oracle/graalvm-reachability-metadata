[tool-call] delta {"path":"tests/src/ch.qos.logback/logback-classic/1.5.30/src/test/java/org/graalvm/logback/LoggingEventTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org.graalvm.logback;\n\nimport ch.qos.logback.classic.spi.LoggingEvent;\nimport org.junit.jupiter.api.Test;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LoggingEventTest {\n\n  @Test\n  void derivesThreadNameForUnnamedCurrentThread() {\n    Thread currentThread = Thread.currentThread();\n    String originalName = currentThread.getName();\n\n    try {\n      currentThread.setName(\"\");\n\n      LoggingEvent event = new LoggingEvent();\n\n      assertThat(event.getThreadName())\n          .startsWithAnyOf(LoggingEvent.REGULAR_UNNAMED_THREAD_PREFIX, LoggingEvent.VIRTUAL_THREAD_NAME_PREFIX);\n    } finally {\n      currentThread.setName(originalName);\n    }\n  }\n}\n"}
