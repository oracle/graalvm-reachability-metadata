onfigurator configurator = new SerializedModelConfigurator();\n    configurator.setContext(loggerContext);\n    Configurator.ExecutionStatus status = configurator.configure(loggerContext);\n\n    assertThat(status).isEqualTo(Configurator.ExecutionStatus.DO_NOT_INVOKE_NEXT_IF_ANY);\n    assertThat(loggerContext.getStatusManager().getCopyOfStatusList())\n            .extracting(Status::getMessage)\n            .contains(\"Empty model. Abandoning.\");\n  }\n\n  @AfterEach\n  void tearDown() {\n    System.clearProperty(ClassicConstants.MODEL_CONFIG_FILE_PROPERTY);\n    loggerContext.stop();\n  }\n\n  private void writeSerializedNullModel(Path modelFile) throws Exception {\n    Files.createDirectories(modelFile.getParent());\n    try (ObjectOutputStream outputStream = new ObjectOutputStream(Files.newOutputStream(modelFile))) {\n      outputStream.writeObject(null);\n    }\n  }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 788, "output": 615, "cacheRead": 30720, "cacheWrite": 0, "totalTokens": 32123, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777378472405, "responseId": "resp_01c84e6ff85dec8f0169f0a4a92e9481919a8870b720c1d561"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_LO2YVaKS1FfP8QjkuShqCtdX|fc_01c84e6ff85dec8f0169f0a4abc4688191861847afdda2764d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2143 bytes to tests/src/ch.qos.logback/logback-classic/1.5.30/src/test/java/org/graalvm/logback/SerializedModelConfiguratorTest.java"}], "isError": false, "timestamp": 1777378477964}]}
