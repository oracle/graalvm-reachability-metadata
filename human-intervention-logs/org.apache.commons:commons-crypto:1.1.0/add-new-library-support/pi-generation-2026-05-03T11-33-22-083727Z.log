org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport org.apache.commons.crypto.utils.ReflectionUtils;\nimport org.junit.jupiter.api.Test;\n\npublic class ReflectionUtilsTest {\n\n    @Test\n    public void getClassByNameLoadsAvailableClassesAndCachesMissingClasses() throws Exception {\n        Class<?> loadedClass = ReflectionUtils.getClassByName(NoArgumentTarget.class.getName());\n\n        assertThat(loadedClass).isSameAs(NoArgumentTarget.class);\n        assertThatThrownBy(() -> ReflectionUtils.getClassByName(\"org_apache_commons.commons_crypto.DoesNotExist\"))\n                .isInstanceOf(ClassNotFoundException.class)\n                .hasMessageContaining(\"org_apache_commons.commons_crypto.DoesNotExist\");\n        assertThatThrownBy(() -> ReflectionUtils.getClassByName(\"org_apache_commons.commons_crypto.DoesNotExist\"))\n                .isInstanceOf(ClassNotFoundException.class);\n    }\n\n    @Test\n    public void newInstanceInvokesPrivateNoArgumentConstructor() {\n        NoArgumentTarget target = ReflectionUtils.newInstance(NoArgumentTarget.class);\n\n        assertThat(target.describe()).isEqualTo(\"created\");\n    }\n\n    @Test\n    public void newInstanceInvokesPrivateConstructorWithExactArgumentTypes() {\n        StringArgumentTarget target = ReflectionUtils.newInstance(StringArgumentTarget.class, \"commons\");\n\n        assertThat(target.describe()).isEqualTo(\"created:commons\");\n    }\n\n    public static class NoArgumentTarget {\n        private final String value;\n\n        private NoArgumentTarget() {\n            value = \"created\";\n        }\n\n        public String describe() {\n            return value;\n        }\n    }\n\n    public static class StringArgumentTarget {\n        private final String value;\n\n        private StringArgumentTarget(String value) {\n            this.value = value;\n        }\n\n        public String describe() {\n            return \"created:\" + value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 788, "output": 2180, "cacheRead": 36352, "cacheWrite": 0, "totalTokens": 39320, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777808076459, "responseId": "resp_094b4f2126bd08ff0169f732cd2d3081a1ac91ffde1aec0e7a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_2Qrcp1fCCiX2jcmepCbGWxDb|fc_094b4f2126bd08ff0169f732e6850481a18c87cb7f455f88bf", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2229 bytes to tests/src/org.apache.commons/commons-crypto/1.1.0/src/test/java/org_apache_commons/commons_crypto/ReflectionUtilsTest.java"}], "isError": false, "timestamp": 1777808104562}]}
