{"type":"item.started","item":{"id":"item_141","type":"command_execution","command":"/usr/bin/bash -lc \"python - <<'PY'\nimport zipfile, glob, os, re\nactor=glob.glob(os.path.expanduser('~/.gradle/caches/modules-2/files-2.1/com.typesafe.akka/akka-actor_3/2.6.21/*/akka-actor_3-2.6.21.jar'))[0]\nkeys=[\n'akka.version','akka.actor.guardian-supervisor-strategy','akka.actor.creation-timeout','akka.actor.unstarted-push-timeout','akka.actor.allow-java-serialization','akka.actor.serialize-messages','akka.actor.serialize-creators','akka.actor.no-serialization-verification-needed-class-prefix','akka.loglevel','akka.stdout-loglevel','akka.loggers','akka.loggers-dispatcher','akka.logging-filter','akka.logger-startup-timeout','akka.log-config-on-start','akka.log-dead-letters','akka.log-dead-letters-during-shutdown','akka.log-dead-letters-suspend-duration','akka.actor.debug.receive','akka.actor.debug.autoreceive','akka.actor.debug.lifecycle','akka.actor.debug.fsm','akka.actor.debug.event-stream','akka.actor.debug.unhandled','akka.actor.debug.router-misconfiguration','akka.home','akka.scheduler.implementation','akka.daemonic','akka.jvm-exit-on-fatal-error','akka.jvm-shutdown-hooks','akka.fail-mixed-versions','akka.coordinated-shutdown.terminate-actor-system','akka.coordinated-shutdown.run-by-actor-system-terminate','akka.actor.deployment.default.virtual-nodes-factor']\nwith zipfile.ZipFile(actor) as z:\n    text=z.read('reference.conf').decode()\nfor k in keys:\n    m=re.search(r'(?m)\"'^'\"\\\\s*'+re.escape(k.replace('akka.','').replace('.','\\\\.'))+r'\\\\s*=\\\\s*(.+)\"'$'\"', text)\n    print(k, '=>', m.group(1) if m else 'NOT_FOUND')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
