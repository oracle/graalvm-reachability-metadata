  			values.put("Minutes", "m");
  			values.put("Hours", "h");
  			values.put("Days", "d");
  			DURATION_SUFFIX = Collections.unmodifiableMap(values);
  		}
  
  		private static final String PERIOD_OF = "Period.of";
  
