  				String suffix = suffixMapping.get(type);
  				return (suffix != null) ? factoryValue + suffix : null;
  			}
  			return null;
  		}
  
  		Map<String, Object> getFieldValues() {
  			return this.fieldValues;
  		}
  
  	}
  
  }
