          private interface LabelsDefaultEntryHolder {
              MapEntryLite<String, Integer> defaultEntry =
                      MapEntryLite.newDefaultInstance(
                              WireFormat.FieldType.STRING, "", WireFormat.FieldType.INT32, 0);
          }
      }
  }
