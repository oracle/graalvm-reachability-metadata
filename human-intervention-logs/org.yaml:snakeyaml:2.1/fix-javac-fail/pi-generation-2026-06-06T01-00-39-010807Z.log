      standardTags.add(PAIRS);
      standardTags.add(OMAP);
      standardTags.add(BINARY);
      standardTags.add(INT);
      standardTags.add(FLOAT);
      standardTags.add(TIMESTAMP);
      standardTags.add(BOOL);
