figuration.DurationConverter;\\nimport io.quarkus.runtime.configuration.InetSocketAddressConverter;\\nimport io.quarkus.runtime.configuration.LocaleConverter;\\nimport io.quarkus.runtime.configuration.MemorySize;\\nimport io.quarkus.runtime.configuration.MemorySizeConverter;\\nimport io.quarkus.runtime.configuration.NameIterator;\\nimport io.quarkus.runtime.configuration.NormalizeRootHttpPathConverter;\\nimport io.quarkus.runtime.logging.InheritableLevel;\\nimport io.quarkus.runtime.logging.InheritableLevelConverter;\\nimport io.quarkus.runtime.logging.LevelConverter;\\nimport io.quarkus.runtime.types.GenericArrayTypeImpl;\\nimport io.quarkus.runtime.types.ParameterizedTypeImpl;\\nimport io.quarkus.runtime.types.WildcardTypeImpl;\\nimport io.quarkus.runtime.util.EnumerationUtil;\\nimport io.quarkus.runtime.util.HashUtil;\\nimport io.quarkus.runtime.util.StringUtil;\\n\\npublic class Quarkus_coreTest {\\n    @Test\\n    void launchModeReportsProfilesAndFeatureSupport() {\\n        LaunchMode originalMode = LaunchMode.current();\\n        try {\\n            assertThat(LaunchMode.NORMAL.getDefaultProfile()).isEqualTo(LaunchMode.PROD_PROFILE);\\n            assertThat(LaunchMode.NORMAL.getProfileKey()).isEqualTo(\\\"quarkus.profile\\\");\\n            assertThat(LaunchMode.NORMAL.isProduction()).isTrue();\\n            assertThat(LaunchMode.NORMAL.isDevOrTest()).isFalse();\\n            assertThat(LaunchMode.NORMAL.isDevServicesSupported()).isFalse();\\n            assertThat(LaunchMode.NORMAL.isLiveReloadSupported()).isFalse();\\n\\n            assertThat(LaunchMode.RUN.isProduction()).isTrue();\\n            assertThat(LaunchMode.RUN.isDevServicesSupported()).isTrue();\\n            assertThat(LaunchMode.RUN.isDevResourcesSupported()).isTrue();\\n            assertThat(LaunchMode.RUN.isLiveReloadSupported()).isFalse();\\n\\n            assertThat(LaunchMode.DEVELOPMENT.getDefaultProfile()).isEqualTo(LaunchMode.DEV_PROFILE);\\n            assertThat(LaunchMode.DEVELOPMENT.isDev()).isTrue();\\n            assertThat(LaunchMode.DEVELOPMENT.isDevOrTest()).isTrue();\\n            assertThat(LaunchMode.DEVELOPMENT.isLiveReloadSupported()).isTrue();\\n\\n            assertThat(LaunchMode.TEST.getDefaultProfile()).isEqualTo(LaunchMode.TEST_PROFILE);\\n            assertThat(LaunchMode.TEST.getProfileKey()).isEqualTo(\\\"quarkus.test.profile\\\");\\n            assertThat(LaunchMode.TEST.isDevOrTest()).isTrue();\\n\\n            LaunchMode.set(LaunchMode.TEST);\\n            assertThat(LaunchMode.current()).isSameAs(LaunchMode.TEST);\\n        } finally {\\n            LaunchMode.set(originalMode);\\n        }\\n    }\\n\\n    @Test\\n    void runtimeValueAndLifecycleEventsExposeRuntimeState() {\\n        RuntimeValue<String> runtimeValue = new RuntimeValue<>(\\\"started\\\");\\n\\n        assertThat(runtimeValue.getValue()).isEqualTo(\\\"started\\\");\\n        assertThat(new StartupEvent()).isNotNull();\\n        assertThat(new ShutdownEvent().isStandardShutdown()).isTrue();\\n        assertThatThrownBy(() -> new RuntimeValue<String>().getValue())\\n                .isInstanceOf(IllegalStateException.class)\\n                .hasMessageContaining(\\\"deployment time\\\");\\n    }\\n\\n    @Test\\n    void convertersParseCommonRuntimeConfigurationValues() {\\n        DurationConverter durationConverter = new DurationConverter();\\n        MemorySizeConverter memorySizeConverter = new MemorySizeConverter();\\n        NormalizeRootHttpPathConverter pathConverter = new NormalizeRootHttpPathConverter();\\n        CharsetConverter charsetConverter = new CharsetConverter();\\n        LocaleConverter localeConverter = new LocaleConverter();\\n\\n        assertThat(durationConverter.convert(\\\"15\\\")).isEqualTo(Duration.ofSeconds(15));\\n        assertThat(DurationConverter.parseDuration(\\\"2h\\\")).isEqualTo(Duration.ofHours(2));\\n        assertThat(DurationConverter.parseDuration(\\\"250ms\\\")).isEqualTo(Duration.ofMillis(250));\\n        assertThat(DurationConverter.parseDuration(\\\"1h30m\\\")).isEqualTo(Duration.ofMinutes(90));\\n        assertThat(DurationConverter.parseDuration(\\\"PT0.5S\\\")).isEqualTo(Duration.ofMillis(500));\\n        assertThat(DurationConverter.parseDuration(\\\"   \\\")).isNull();\\n        assertThatThrownBy(() -> DurationConverter.parseDuration(\\\"not-a-duration\\\"))\\n                .isInstanceOf(IllegalArgumentException.class);\\n\\n        assertThat(memorySizeConverter.convert(\\\"512\\\").asLongValue()).isEqualTo(512L);\\n        assertThat(memorySizeConverter.convert(\\\"3K\\\").asLongValue()).isEqualTo(3L * 1024L);\\n        assertThat(memorySizeConverter.convert(\\\"2m\\\").asLongValue()).isEqualTo(2L * 1024L * 1024L);\\n        assertThat(memorySizeConverter.convert(\\\"1G\\\"))\\n                .isEqualTo(new MemorySize(BigInteger.valueOf(1024L * 1024L * 1024L)));\\n        assertThat(memorySizeConverter.convert(\\\"  \\\")).isNull();\\n        assertThatThrownBy(() -> memorySizeConverter.convert(\\\"1.5M\\\"))\\n                .isInstanceOf(IllegalArgumentException.class)\\n                .hasMessageContaining(\\\"correct format\\\");\\n\\n        assertThat(pathConverter.convert(null)).isEqualTo(\\\"/\\\");\\n        assertThat(pathConverter.convert(\\\"api\\\")).isEqualTo(\\\"/api/\\\");\\n        assertThat(pathConverter.convert(\\\"/management\\\")).isEqualTo(\\\"/management/\\\");\\n        assertThat(pathConverter.convert(\\\"/metrics/\\\")).isEqualTo(\\\"/metrics/\\\");\\n\\n        assertThat(charsetConverter.convert(\\\" UTF-8 \\\")).isEqualTo(StandardCharsets.UTF_8);\\n        assertThat(charsetConverter.convert(\\\" \\\")).isNull();\\n        assertThat(localeConverter.convert(\\\"en_US\\\")).isEqualTo(Locale.US);\\n        assertThat(localeConverter.convert(\\\"all\\\")).isEqualTo(Locale.ROOT);\\n    }\\n\\n    @Test\\n    void inetSocketAddressConverterHandlesResolvedWildcardAndUnresolvedAddresses() {\\n        InetSocketAddressConverter converter = new InetSocketAddressConverter();\\n\\n        InetSocketAddress loopback = converter.convert(\\\"127.0.0.1:8080\\\");\\n        assertThat(loopback.isUnresolved()).isFalse();\\n        assertThat(loopback.getPort()).isEqualTo(8080);\\n        assertThat(loopback.getAddress().getHostAddress()).isEqualTo(\\\"127.0.0.1\\\");\\n\\n        InetSocketAddress unresolved = converter.convert(\\\"service.internal:9090\\\");\\n        assertThat(unresolved.isUnresolved()).isTrue();\\n        assertThat(unresolved.getHostString()).isEqualTo(\\\"service.internal\\\");\\n        assertThat(unresolved.getPort()).isEqualTo(9090);\\n\\n        InetSocketAddress wildcard = converter.convert(\\\":8181\\\");\\n        assertThat(wildcard.getPort()).isEqualTo(8181);\\n        assertThat(converter.convert(\\\"   \\\")).isNull();\\n    }\\n\\n    @Test\\n    void nameIteratorNavigatesQuotedAndEscapedConfigurationSegments() {\\n        NameIterator iterator = new NameIterator(\\\"quarkus.datasource.\\\\\\\"jdbc.url\\\\\\\".pool\\\\\\\\.size\\\");\\n\\n        assertThat(iterator.getPosition()).isEqualTo(-1);\\n        assertThat(iterator.getNextSegment()).isEqualTo(\\\"quarkus\\\");\\n        assertThat(iterator.nextSegmentEquals(\\\"quarkus\\\")).isTrue();\\n\\n        iterator.next();\\n        assertThat(iterator.getAllPreviousSegments()).isEqualTo(\\\"quarkus\\\");\\n        assertThat(iterator.getNextSegment()).isEqualTo(\\\"datasource\\\");\\n\\n        iterator.next();\\n        assertThat(iterator.getAllPreviousSegmentsWith(\\\"credentials\\\")).isEqualTo(\\\"quarkus.datasource.credentials\\\");\\n        assertThat(iterator.getNextSegment()).isEqualTo(\\\"jdbc.url\\\");\\n\\n        iterator.next();\\n        assertThat(iterator.getNextSegment()).isEqualTo(\\\"pool.size\\\");\\n        iterator.next();\\n        assertThat(iterator.hasNext()).isFalse();\\n        assertThat(iterator.toString()).endsWith(\\\"*\\\");\\n\\n        assertThat(iterator.getPreviousSegment(