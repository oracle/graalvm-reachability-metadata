rator.getPreviousSegment()).isEqualTo(\\\"pool\\\");\\n+\\n+        iterator.goToStart();\\n+        assertThat(iterator.hasPrevious()).isFalse();\\n+        assertThat(iterator.toString()).startsWith(\\\"*\\\");\\n+    }\\n+\\n+    @Test\\n+    void stringUtilitiesTransformCamelCaseAndSuffixes() {\\n+        assertThat(StringUtil.changePrefix(\\\"quarkus.http.port\\\", \\\"quarkus.\\\", \\\"app.\\\"))\\n+                .isEqualTo(\\\"app.http.port\\\");\\n+        assertThat(StringUtil.changePrefix(\\\"smallrye.http.port\\\", \\\"quarkus.\\\", \\\"app.\\\"))\\n+                .isEqualTo(\\\"smallrye.http.port\\\");\\n+\\n+        assertThat(StringUtil.toList(StringUtil.camelHumpsIterator(\\\"JBossXMLParser\\\")))\\n+                .containsExactly(\\\"JBoss\\\", \\\"XML\\\", \\\"Parser\\\");\\n+        assertThat(StringUtil.hyphenate(\\\"JBossXMLParser\\\"))\\n+                .isEqualTo(\\\"jboss-xml-parser\\\");\\n+        assertThat(StringUtil.join(Arrays.asList(\\\"one\\\", \\\"two\\\", \\\"three\\\").iterator()))\\n+                .isEqualTo(\\\"onetwothree\\\");\\n+        assertThat(StringUtil.withoutSuffix(List.of(\\\"quarkus\\\", \\\"core\\\", \\\"runtime\\\"), \\\"runtime\\\"))\\n+                .containsExactly(\\\"quarkus\\\", \\\"core\\\");\\n+        assertThat(StringUtil.withoutSuffix(List.of(\\\"quarkus\\\", \\\"core\\\"), \\\"runtime\\\"))\\n+                .containsExactly(\\\"quarkus\\\", \\\"core\\\");\\n+        assertThat(StringUtil.isNullOrEmpty(null)).isTrue();\\n+        assertThat(StringUtil.isNullOrEmpty(\\\"\\\")).isTrue();\\n+        assertThat(StringUtil.isNullOrEmpty(\\\"quarkus\\\")).isFalse();\\n+    }\\n+\\n+    @Test\\n+    void hashAndEnumerationUtilitiesProduceDeterministicValues() {\\n+        assertThat(HashUtil.sha1(\\\"quarkus\\\"))\\n+                .isEqualTo(\\\"3649aad2ce796d8c7430fc172dd568299332307a\\\");\\n+        assertThat(HashUtil.sha256(\\\"quarkus\\\"))\\n+                .isEqualTo(\\\"cd5334987afd076c96