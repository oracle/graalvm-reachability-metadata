\n                    .flatMap(_.lift(ix).collect { case ConstVal(const) => const })\\n                }\\n                def fromBody = statements.collectFirst { case ConstVal(v) => v }\\n                fromCtor.orElse(fromBody).flatMap { const => cls.unapply(const.value) }\\n              }\\n              case _ =>\\n                Option.empty[ValueType]\\n            }\\n          } yield Tuple3(TypeRepr.of[h], '{ ${ vof }.value: A }, constValue)) match {\\n            case Some((tpr, instance, value)) =>\\n              collect[tail](instance :: instances, values + (tpr -> value))\\n\\n            case None =>\\n              report.errorAndAbort(\\n                s\\\"Fails to check value entry ${htpr.show} for enum ${repr.show}\\\"\\n              )\\n          }\\n        }\\n\\n        case '[OtherHead[h, tail]] =>\\n          Expr.summon[Mirror.SumOf[h]] match {\\n            case Some(sum) =>\\n              sum.asTerm.tpe.asType match {\\n                case '[SumOf[a, t]] => collect[Tuple.Concat[t, tail]](instances, values)\\n                case _              => Left(s\\\"Invalid `Mirror.SumOf[${TypeRepr.of[h].show}]\\\")\\n              }\\n\\n            case None =>\\n              Left(s\\\"Missing `Mirror.SumOf[${TypeRepr.of[h].show}]`\\\")\\n          }\\n\\n        case '[EmptyTuple] => {\\n          val allowAlias = repr <:< TypeRepr.of[AllowAlias]\\n\\n          if (!allowAlias && values.values.toSet.size < values.size) {\\n            val details = values\\n              .map { case (sub, value) =>\\n                s\\\"${sub.show} = $value\\\"\\n              }\\n              .mkString(\\\", \\\")\\n\\n            Left(s\\\"Values value are not discriminated subtypes: ${details}\\\")\\n          } else {\\n            Right(Expr ofList instances.reverse)\\n          }\\n        }\\n      }\\n\\n    val result: Either[String, Expr[List[A]]] =\\n      Expr.summon[Mirror.SumOf[A]] match {\\n        case Some(sum) =>\\n          sum.asTerm.tpe.asType match {\\n            case '[SumOf[A, t]] =>\\n              collect[t](List.empty, Map.empty)\\n\\n            case _ =>\\n              Left(s\\\"Invalid `Mirror.SumOf[${repr.show}]`\\\")\\n\\n          }\\n\\n        case None =>\\n          Left(s\\\"Missing `Mirror.SumOf[${repr.show}]`\\\")\\n      }\\n\\n    result match {\\n      case Left(errorMsg) =>\\n        report.errorAndAbort(errorMsg)\\n\\n      case Right(instances) =>\\n        '{ IndexedSeq.empty ++ $instances }\\n    }\\n  }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1782474822121}}\nhuman-intervention-logs/com.beachape:enumeratum-macros_3:1.9.0/add-new-library-support/pi-generation-2026-06-26T11-56-42-071037Z.log:992:[recv] {\"type\": \"turn_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0034f1349302b464016a3e6843cb148197a165b624aa184312\\\",\\\"type\\\":\\\"reasoning\\\",\\\"content\\\":[],\\\"encrypted_content\\\":\\\"gAAAAABqPmhFcj1PEszdABoz-ROzYBEh7RUBDNvYg_wfYm35GL2K8iyiG35QKIyNf5vjg3GTccsG60QLgd9nikBQdITvMkgCeThoSBJXiSnquJw9F1YdJZtuYIL7o4QNBwXek1I7tSPi9wilrtI54johiR1z8NwpSxl2JDJD1p6_KFORDDR_OebMkmsTqHPWngfKFjUhQRQ9JEHrWlm6JRq5HvQXZMKMr4v-OUFTvpAzojlZd0hMoqVU3B68h3twLVbWR_v-VPWQJ1Hp-qcWcJYJm3SdFbMzGH9AHbRWKgzn8lw2aSANNFzUQABoCw2z5Z4Pr4N9Bi1_0u4rcTya-Oylt4F8jYdgVylxeiKG6eD7xu2EEwMcBP5r-fTsPW4nbyvcYJxCMiJyjqVKRaHqQctda55oXoyDmrzcbv3Ng-KyhY9-UddOpIuU9Rc1g1NY8cl6WQM5_zGGZFU7_3FdTv-RiIFwxkTbsAuKw2asLrDdc5f-P_ByPMwN9OKvHjmxN0xEhAMlqOJKDrxgsSAKf2kyEFWOcLfzcHMV_j8-wjunmQla3Keqszl_XjclSSF4X-VjW30kozbRpIaArx-G2GeMXlgor1hNitfdq0TLZQUjBJ468lPaZ-MHkNbrnFGA2Ro3bQcwElUa3L2OeP_oEohRUZ_2zfglWYMGCaONyJID26JtV-9uQgjMOFmpAw6hAkR-69hoKyG1VO3EuJdLLIr3YvZZx6Q3XlUOgi9Guw8aAFCTkF9CMeX2qMopdA1p0gPExKaD19pMDThBiUgOyHCMVoF7OEKk2Zf4IQ84oyCiyOIEx5Z5rFY2xqL4ece8mYRARGj5Pek7XYor4YlM8i213YtXuhTg-drfFRjXQm2oAAd9LQOukxvzm3Mu9uP3ODZnl_4gB6Q-Wa_uFcvVUhzocME-XxsPQYN-3jLg_QxXg4KXdosXleqrZ7hIQR063UBP3GNLnanWZsNX