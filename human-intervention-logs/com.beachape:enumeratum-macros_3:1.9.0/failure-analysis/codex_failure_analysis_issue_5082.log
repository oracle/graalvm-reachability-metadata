  assertEquals(Right(TicketPriority.Low), TicketPriority.withValueEither(1))\\n    assertEquals(None, TicketPriority.withValueOpt(42))\\n  }\\n\\n  @Test\\n  def intValueEnumFindValuesSupportsValuesDeclaredInEntryBodies(): Unit = {\\n    assertEquals(\\n      IndexedSeq(BodyBackedCode.Accepted, BodyBackedCode.Rejected),\\n      BodyBackedCode.values\\n    )\\n    assertEquals(\\n      Map(202 -> BodyBackedCode.Accepted, 409 -> BodyBackedCode.Rejected),\\n      BodyBackedCode.valuesToEntriesMap\\n    )\\n    assertSame(BodyBackedCode.Accepted, BodyBackedCode.withValue(202))\\n    assertEquals(Some(BodyBackedCode.Rejected), BodyBackedCode.withValueOpt(409))\\n  }\\n\\n  @Test\\n  def stringValueEnumFindValuesSupportsSealedAbstractEntryGroups(): Unit = {\\n    assertEquals(\\n      IndexedSeq(CalendarDay.Sunday, CalendarDay.Monday, CalendarDay.Saturday),\\n      CalendarDay.values\\n    )\\n    assertEquals(\\n      Map(\\\"Sun\\\" -> CalendarDay.Sunday, \\\"Mon\\\" -> CalendarDay.Monday, \\\"Sat\\\" -> CalendarDay.Saturday),\\n      CalendarDay.valuesToEntriesMap\\n    )\\n    assertSame(CalendarDay.Monday, CalendarDay.withValue(\\\"Mon\\\"))\\n    assertEquals(Some(CalendarDay.Saturday), CalendarDay.withValueOpt(\\\"Sat\\\"))\\n  }\\n}\\n\\nsealed abstract class TicketPriority(val value: Int) extends IntEnumEntry\\n\\nobject TicketPriority extends IntEnum[TicketPriority] {\\n  val values: IndexedSeq[TicketPriority] = findValues\\n\\n  case object Low extends TicketPriority(1)\\n  case object Normal extends TicketPriority(5)\\n  case object Urgent extends TicketPriority(9)\\n}\\n\\nsealed abstract class BodyBackedCode extends IntEnumEntry\\n\\nobject BodyBackedCode extends IntEnum[BodyBackedCode] {\\n  val values: IndexedSeq[BodyBackedCode] = findValues\\n\\n  case object Accepted extends BodyBackedCode {\\n    val value: Int = 202\\n  }\\n\\n  case object Rejected extends BodyBackedCode {\\n    val value: Int = 409\\n  }\\n}\\n\\nsealed trait CalendarDay extends StringEnumEntry\\n\\nobject CalendarDay extends StringEnum[CalendarDay] {\\n  sealed abstract class Weekend(val value: String) extends CalendarDay\\n  sealed abstract class Workday(val value: String) extends CalendarDay\\n\\n  case object Sunday extends Weekend(\\\"Sun\\\")\\n  case object Monday extends Workday(\\\"Mon\\\")\\n  case object Saturday extends Weekend(\\\"Sat\\\")\\n\\n  val values: IndexedSeq[CalendarDay] = findValues\\n}\"}], \"isError\": false, \"timestamp\": 1782421549558}]}\nhuman-intervention-logs/com.beachape:enumeratum-macros_3:1.9.0/add-new-library-support/pi-generation-2026-06-25T20-54-32-322606Z.log:330753:[tool-call] delta {\"path\":\"tests/src/com.beachape/enumeratum-macros_3/1.9.0/src/test/scala/com_beachape/enumeratum_macros_3/ValueEnumMacrosInnerValueOfFromExprTest.scala\",\"edits\":[{\"oldText\":\"import enumeratum.values.StringEnum\\nimport enumeratum.values.StringEnumEntry\\n\",\"newText\":\"\"},{\"oldText\":\"\\n  @Test\\n  def stringValueEnumFindValuesSupportsSealedAbstractEntryGroups(): Unit = {\\n    assertEquals(\\n      IndexedSeq(CalendarDay.Sunday, CalendarDay.Monday, CalendarDay.Saturday),\\n      CalendarDay.values\\n    )\\n    assertEquals(\\n      Map(\\\"Sun\\\" -> CalendarDay.Sunday, \\\"Mon\\\" -> CalendarDay.Monday, \\\"Sat\\\" -> CalendarDay.Saturday),\\n      CalendarDay.valuesToEntriesMap\\n    )\\n    assertSame(CalendarDay.Monday, CalendarDay.withValue(\\\"Mon\\\"))\\n    assertEquals(Some(CalendarDay.Saturday), CalendarDay.withValueOpt(\\\"Sat\\\"))\\n  }\\n\",\"newText\":\"\"},{\"oldText\":\"\\nsealed trait CalendarDay extends StringEnumEntry\\n\\nobject CalendarDay extends StringEnum[CalendarDay] {\\n  sealed abstract class Weekend(val value: String) extends CalendarDay\\n  sealed abstract class Workday(val value: String) extends CalendarDay\\n\\n  case object Sunday extends Weekend(\\\"Sun\\\")\\n  case object Monday extends Workday(\\\"Mon\\\")\\n  case object Saturday extends Weekend(\\\"Sat\\\")\\n\\n  val va