ic API could define those entries in the same scope? I wonder about the order of values—should it follow the source declaration? For top-level entries appearing before the companion, it would be first and second. But what happens if they come after the companion? Maybe the macro in companion expansion can access definitions later?\"}]}"}, {"type": "toolCall", "id": "call_ZrFb8YgPpM7FMvnRfGJZw5gR|fc_08901812d79efd2d016a3d998a4e548197a8e57695570a42e2", "name": "write", "arguments": {"path": "tests/src/com.beachape/enumeratum-macros_3/1.9.0/src/test/scala/com_beachape/enumeratum_macros_3/ValueEnumMacrosTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_beachape.enumeratum_macros_3\n\nimport enumeratum.values.IntEnum\nimport enumeratum.values.IntEnumEntry\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\n\nclass ValueEnumMacrosTest {\n  @Test\n  def intValueEnumFindValuesDiscoversTopLevelSingletonEntries(): Unit = {\n    assertEquals(\n      IndexedSeq(TopLevelHttpStatusAccepted, TopLevelHttpStatusConflict),\n      TopLevelHttpStatus.values\n    )\n    assertEquals(\n      Map(202 -> TopLevelHttpStatusAccepted, 409 -> TopLevelHttpStatusConflict),\n      TopLevelHttpStatus.valuesToEntriesMap\n    )\n    assertSame(TopLevelHttpStatusAccepted, TopLevelHttpStatus.withValue(202))\n    assertEquals(Some(TopLevelHttpStatusConflict), TopLevelHttpStatus.withValueOpt(409))\n    assertEquals(Right(TopLevelHttpStatusAccepted), TopLevelHttpStatus.withValueEither(202))\n    assertEquals(None, TopLevelHttpStatus.withValueOpt(500))\n  }\n}\n\nsealed abstract class TopLevelHttpStatus(val value: Int) extends IntEnumEntry\n\ncase object TopLevelHttpStatusAccepted extends TopLevelHttpStatus(202)\ncase object TopLevelHttpStatusConflict extends TopLevelHttpStatus(409)\n\nobject TopLevelHttpStatus extends IntEnum[TopLevelHttpStatus] {\n  val values: IndexedSeq[TopLevelHttpStatus] = findValues\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3036, "output": 1872, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 46892, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782421873993, "responseId": "resp_08901812d79efd2d016a3d99727758819796463d7e52d6d8e1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZrFb8YgPpM7FMvnRfGJZw5gR|fc_08901812d79efd2d016a3d998a4e548197a8e57695570a42e2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1518 bytes to tests/src/com.beachape/enumeratum-macros_3/1.9.0/src/test/scala/com_beachape/enumeratum_macros_3/ValueEnumMacrosTest.scala"}], "isError": false, "timestamp": 1782421901915}]}
