  package com_beachape.enumeratum_macros_3
  
  import enumeratum.ValueEnumMacros
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Assertions.assertSame
  import org.junit.jupiter.api.Test
  
  class ValueEnumMacrosTest {
    @Test
    def topLevelStringValueEntriesAreDiscoveredFromSingletonEntries(): Unit = {
      val entries: IndexedSeq[TopLevelArticleStatus] = TopLevelArticleStatus.values
  
      assertEquals(IndexedSeq(TopLevelDraft, TopLevelPublished), entries)
      assertEquals(IndexedSeq("draft", "published"), entries.map(_.value))
      assertSame(TopLevelDraft, entries.head)
    }
  
    @Test
    def scalaEnumIntValueEntriesAreDiscoveredFromSingletonCases(): Unit = {
      val entries: IndexedSeq[TrafficSignal] = TrafficSignal.values
  
      assertEquals(IndexedSeq(TrafficSignal.Stop, TrafficSignal.Caution, TrafficSignal.Go), entries)
      assertEquals(IndexedSeq(1, 2, 3), entries.map(_.value))
      assertSame(TrafficSignal.Stop, entries.head)
    }
  }
  
  inline def findTopLevelStringValueEntries[A]: IndexedSeq[A] =
    ${ ValueEnumMacros.findStringValueEntriesImpl[A] }
  
  inline def findTopLevelIntValueEntries[A]: IndexedSeq[A] =
    ${ ValueEnumMacros.findIntValueEntriesImpl[A] }
  
  sealed abstract class TopLevelArticleStatus(val value: String)
  
  case object TopLevelDraft extends TopLevelArticleStatus("draft")
  case object TopLevelPublished extends TopLevelArticleStatus("published")
  
  object TopLevelArticleStatus {
    val values: IndexedSeq[TopLevelArticleStatus] =
      findTopLevelStringValueEntries[TopLevelArticleStatus]
  }
  
  enum TrafficSignal(val value: Int) {
    case Stop extends TrafficSignal(1)
    case Caution extends TrafficSignal(2)
    case Go extends TrafficSignal(3)
  }
  
  object TrafficSignal {
    val values: IndexedSeq[TrafficSignal] = findTopLevelIntValueEntries[TrafficSignal]
  }
