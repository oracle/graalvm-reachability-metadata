[tool-call] delta {"path":"tests/src/com.beachape/enumeratum-macros_3/1.9.0/src/test/scala/com_beachape/enumeratum_macros_3/ValueEnumMacrosTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_beachape.enumeratum_macros_3\n\nimport dotty.tools.dotc.Driver\nimport dotty.tools.dotc.reporting.Reporter\nimport enumeratum.ValueEnumMacros\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Assertions.assertFalse\nimport org.junit.jupiter.api.Test\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\n\nclass ValueEnumMacrosTest {\n  @Test\n  def runtimeCompilationFindsPrecompiledIntValueEntries(): Unit = {\n    try {\n      val workDir: Path = Files.createTempDirectory(\"enumeratum-value-enum-macros\")\n      val outputDir: Path = Files.createDirectories(workDir.resolve(\"classes\"))\n      val source: Path = workDir.resolve(\"RuntimeValueEnumMacrosProbe.scala\")\n      Files.writeString(\n        source,\n        \"\"\"\n          |package com_beachape.enumeratum_macros_3.runtime_compilation\n          |\n          |import com_beachape.enumeratum_macros_3.HighPriority\n          |import com_beachape.enumeratum_macros_3.LowPriority\n          |import com_beachape.enumeratum_macros_3.MediumPriority\n          |import com_beachape.enumeratum_macros_3.Priority\n          |import com_beachape.enumeratum_macros_3.PriorityValues\n          |\n          |object RuntimeValueEnumMacrosProbe {\n          |  val values: IndexedSeq[Priority] = PriorityValues.values\n          |  val valueSum: Int = values.map(_.value).sum\n          |  val hasExpectedOrder: Boolean =\n          |    values == IndexedSeq(LowPriority, MediumPriority, HighPriority)\n          |}\n          |\"\"\".stripMargin,\n        StandardCharsets.UTF_8\n      )\n\n      val arguments: Array[String] = Array(\n        \"-classpath\",\n        System.getProperty(\"java.class.path\"),\n        \"-d\",\n        outputDir.toString,\n        \"-Yretain-trees\",\n        source.toString\n      )\n      val reporter: Reporter = Driver().process(arguments)\n\n      assertFalse(reporter.hasErrors(), reporter.summary)\n    } catch {\n      case error: Error =>\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n          throw error\n        }\n    }\n  }\n}\n\nobject PriorityValues {\n  inline def values: IndexedSeq[Priority] = ValueEnumMacroApi.findIntValues[Priority]\n}\n\nobject ValueEnumMacroApi {\n  inline def findIntValues[A]: IndexedSeq[A] = ${ ValueEnumMacros.findIntValueEntriesImpl[A] }\n}\n"}
[tool-call] end id=call_OpqCfojm4RxOqgJ55aRpE15C|fc_05c8c20709c6133c0169fb967390e48197a7687aa8747022c7 name=write args={"path": "tests/src/com.beachape/enumeratum-macros_3/1.9.0/src/test/scala/com_beachape/enumeratum_macros_3/ValueEnumMacrosTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_beachape.enumeratum_macros_3\n\nimport dotty.tools.dotc.Driver\nimport dotty.tools.dotc.reporting.Reporter\nimport enumeratum.ValueEnumMacros\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Assertions.assertFalse\nimport org.junit.jupiter.api.Test\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\n\nclass ValueEnumMacrosTest {\n  @Test\n  def runtimeCompilationFindsPrecompiledIntValueEntries(): Unit = {\n    try {\n      val workDir: Path = Files.createTempDirectory(\"enumeratum-value-enum-macros\")\n      val outputDir: Path = Files.createDirectories(workDir.resolve(\"classes\"))\n      val source: Path = workDir.resolve(\"RuntimeValueEnumMacrosProbe.scala\")\n      Files.writeString(\n        source,\n        \"\"\"\n          |package com_beachape.enumeratum_macros_3.runtime_compilation\n          |\n          |import com_beachape.enumeratum_macros_3.HighPriority\n          |import com_beachape.enumeratum_macros_3.LowPriority\n          |import com_beachape.enumeratum_macros_3.MediumPriority\n          |import com_beachape.enumeratum_macros_3.Priority\n          |import com_beachape.enumeratum_macros_3.PriorityValues\n          |\n          |object RuntimeValueEnumMacrosProbe {\n          |  val values: IndexedSeq[Priority] = PriorityValues.values\n          |  val valueSum: Int = values.map(_.value).sum\n          |  val hasExpectedOrder: Boolean =\n          |    values == IndexedSeq(LowPriority, MediumPriority, HighPriority)\n          |}\n          |\"\"\".stripMargin,\n        StandardCharsets.UTF_8\n      )\n\n      val arguments: Array[String] = Array(\n        \"-classpath\",\n        System.getProperty(\"java.class.path\"),\n        \"-d\",\n        outputDir.toString,\n        \"-Yretain-trees\",\n        source.toString\n      )\n      val reporter: Reporter = Driver().process(arguments)\n\n      assertFalse(reporter.hasErrors(), reporter.summary)\n    } catch {\n      case error: Error =>\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n          throw error\n        }\n    }\n  }\n}\n\nobject PriorityValues {\n  inline def values: IndexedSeq[Priority] = ValueEnumMacroApi.findIntValues[Priority]\n}\n\nobject ValueEnumMacroApi {\n  inline def findIntValues[A]: IndexedSeq[A] = ${ ValueEnumMacros.findIntValueEntriesImpl[A] }\n}\n"}
