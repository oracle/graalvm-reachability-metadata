  ./metadata/com.beachape/enumeratum_3/index.json:8:    "documentation-url" : "https://repo.maven.apache.org/maven2/com/beachape/enumeratum_3/$version$/enumeratum_3-$version$-javadoc.jar",
  ./metadata/com.beachape/enumeratum_3/index.json:9:    "description" : "Enumeratum is a type-safe, reflection-free enumeration library for Scala that provides richer enum entries and value enums than Scala's built-in Enumeration. This Scala 3 JVM artifact supplies the core enum APIs and compile-time macro support for discovering values, enabling exhaustive matching, primitive-backed value enums, and idiomatic enum definitions.",
  ./metadata/com.beachape/enumeratum_3/index.json:18:      "enumeratum"
