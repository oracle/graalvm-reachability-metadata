:class Enumeratum_3Test {\n./metadata/com.beachape/enumeratum-macros_3/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/com/beachape/enumeratum-macros_3/$version$/enumeratum-macros_3-$version$-sources.jar\",\n./metadata/com.beachape/enumeratum-macros_3/index.json:6:    \"repository-url\" : \"https://github.com/lloydmeta/enumeratum\",\n./metadata/com.beachape/enumeratum-macros_3/index.json:7:    \"test-code-url\" : \"https://github.com/lloydmeta/enumeratum/tree/enumeratum-$version$/macros/src/test\",\n./metadata/com.beachape/enumeratum-macros_3/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/com/beachape/enumeratum-macros_3/$version$/enumeratum-macros_3-$version$-javadoc.jar\",\n./metadata/com.beachape/enumeratum-macros_3/index.json:9:    \"description\" : \"enumeratum-macros_3 is the Scala 3 macro module for Enumeratum, a type-safe enumeration library for Scala with exhaustive pattern-match warnings and richer enum values than Scala's built-in Enumeration. It provides the compile-time macro implementations that discover enum entries and validate value enums, avoiding runtime reflection while keeping enum definitions concise.\",\n./metadata/com.beachape/enumeratum-macros_3/index.json:18:      \"enumeratum\"\n./metadata/com.beachape/enumeratum-circe_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/beachape/enumeratum-circe_3/$version$/enumeratum-circe_3-$version$-sources.jar\",\n./metadata/com.beachape/enumeratum-circe_3/index.json:6:    \"repository-url\" : \"https://github.com/lloydmeta/enumeratum\",\n./metadata/com.beachape/enumeratum-circe_3/index.json:7:    \"test-code-url\" : \"https://github.com/lloydmeta/enumeratum/tree/enumeratum-$version$/enumeratum-circe/src/test/scala\",\n./metadata/com.beachape/enumeratum-circe_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/beachape/enumeratum-circe_3/$version$/enumeratum-circe_3-$version$-javadoc.jar\",\n./metadata/com.beachape/enumeratum-circe_3/index.json:9:    \"description\" : \"Enumeratum is a type-safe, reflection-free enumeration library for Scala, and enumeratum-circe adds Circe encoders, decoders, and key codecs for its enum and value enum types. It lets Scala 3 JVM applications serialize and deserialize Enumeratum entries as JSON strings or primitive values while reusing Circe's standard type class APIs.\",\n./metadata/com.beachape/enumeratum-circe_3/index.json:18:      \"enumeratum\"\n./metadata/com.beachape/enumeratum_3/index.json:5:    \"source-code-url\" : \"https://repo.maven.apache.org/maven2/com/beachape/enumeratum_3/$version$/enumeratum_3-$version$-sources.jar\",\n./metadata/com.beachape/enumeratum_3/index.json:6:    \"repository-url\" : \"https://github.com/lloydmeta/enumeratum\",\n./metadata/com.beachape/enumeratum_3/index.json:7:    \"test-code-url\" : \"https://github.com/lloydmeta/enumeratum/tree/enumeratum-$version$/enumeratum-core/src/test\",\n./metadata/com.beachape/enumeratum_3/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/com/beachape/enumeratum_3/$version$/enumeratum_3-$version$-javadoc.jar\",\n./metadata/com.beachape/enumeratum_3/index.json:9:    \"description\" : \"Enumeratum is a type-safe, reflection-free enumeration library for Scala that provides richer enum entries and value enums than Scala's built-in Enumeration. This Scala 3 JVM artifact supplies the core enum APIs and compile-time macro support for discovering values, enabling exhaustive matching, primitive-backed value enums, and idiomatic enum definitions.\",\n./metadata/com.beachape/enumeratum_3/index.json:18:      \"enumeratum\"\n"}], "isError": false, "timestamp": 1778095619078}}
