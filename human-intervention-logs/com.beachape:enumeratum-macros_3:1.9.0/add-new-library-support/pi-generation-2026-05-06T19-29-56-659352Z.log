Impl }\n\n  private def reachesFieldGetImpl(using quotes: Quotes): Expr[Boolean] = {\n    import quotes.reflect.Ref\n    import quotes.reflect.Symbol\n    import quotes.reflect.report\n\n    val moduleSymbol: Symbol =\n      Symbol.requiredModule(\"com_beachape.enumeratum_macros_3.LowPriority\")\n    val singletonExpr: Expr[LowPriority.type] =\n      Ref(moduleSymbol).asExprOf[LowPriority.type]\n    val valueOfExpr: Expr[ValueOf[LowPriority.type]] =\n      '{ new ValueOf[LowPriority.type]($singletonExpr) }\n\n    val extractorClass: Class[?] =\n      Class.forName(\"enumeratum.ValueEnumMacros$ValueOfFromExpr\")\n    val constructor = extractorClass.getDeclaredConstructor(classOf[Type[?]])\n    constructor.setAccessible(true)\n    val extractor: Object = constructor.newInstance(Type.of[LowPriority.type])\n    val unapply = extractorClass.getDeclaredMethod(\n      \"unapply\",\n      classOf[Expr[?]],\n      classOf[Quotes]\n    )\n    unapply.setAccessible(true)\n    val extracted: Option[ValueOf[LowPriority.type]] = unapply\n      .invoke(extractor, valueOfExpr, quotes)\n      .asInstanceOf[Option[ValueOf[LowPriority.type]]]\n\n    if (extracted.exists(_.value == LowPriority)) {\n      Expr(true)\n    } else {\n      report.errorAndAbort(\"ValueEnumMacros did not extract the singleton module\")\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1778096288932}]}
