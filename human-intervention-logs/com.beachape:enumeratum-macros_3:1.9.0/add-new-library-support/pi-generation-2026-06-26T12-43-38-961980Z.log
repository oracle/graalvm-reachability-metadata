    case object One extends MacroStringCode("one")
    case object Two extends MacroStringCode("two")
  
    val values: IndexedSeq[MacroStringCode] = findMacroStringValueEntries[MacroStringCode]
  }
  
  sealed abstract class MacroAliasCode(val value: String) extends AllowAlias
  
