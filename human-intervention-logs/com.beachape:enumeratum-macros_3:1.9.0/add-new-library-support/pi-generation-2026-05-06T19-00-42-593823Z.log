  package com_beachape.enumeratum_macros_3
  
  import dotty.tools.dotc.Driver
  import org.graalvm.internal.tck.NativeImageSupport
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Assertions.assertFalse
  import org.junit.jupiter.api.Assertions.assertSame
  import org.junit.jupiter.api.Test
  
  import java.nio.charset.StandardCharsets
  import java.nio.file.Files
  import java.nio.file.Path
  
  class ValueEnumMacrosInnerValueOfFromExprTest {
    @Test
    def intValueEntriesMacroFindsTopLevelSingletonEntries(): Unit = {
      assertEquals(IndexedSeq(LowPriority, MediumPriority, HighPriority), PriorityValues.values)
      assertEquals(1, LowPriority.value)
      assertEquals(5, MediumPriority.value)
      assertEquals(10, HighPriority.value)
      assertSame(MediumPriority, PriorityValues.values(1))
    }
  
    @Test
    def runtimeCompilationExercisesValueOfFromExprForPrecompiledSingletons(): Unit = {
      try {
        val workDir: Path = Files.createTempDirectory("enumeratum-value-of-from-expr")
        val outputDir: Path = Files.createDirectories(workDir.resolve("classes"))
        val source: Path = workDir.resolve("RuntimePriorityValues.scala")
        Files.writeString(
          source,
          """
            |package com_beachape.enumeratum_macros_3.runtime_compilation
            |
            |import com_beachape.enumeratum_macros_3.Priority
            |import com_beachape.enumeratum_macros_3.ValueEnumMacroApi
            |
            |object RuntimePriorityValues {
            |  val values: IndexedSeq[Priority] = ValueEnumMacroApi.findIntValueEntries[Priority]
            |}
            |""".stripMargin,
          StandardCharsets.UTF_8
        )
  
        val arguments: Array[String] = Array(
          "-classpath",
          System.getProperty("java.class.path"),
          "-d",
          outputDir.toString,
          "-Yretain-trees",
          source.toString
        )
        val reporter = Driver().process(arguments)
  
        assertFalse(reporter.hasErrors(), reporter.summary())
      } catch {
        case error: Error =>
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
            throw error
          }
      }
    }
  }
  
  object PriorityValues {
    val values: IndexedSeq[Priority] = ValueEnumMacroApi.findIntValueEntries[Priority]
  }
