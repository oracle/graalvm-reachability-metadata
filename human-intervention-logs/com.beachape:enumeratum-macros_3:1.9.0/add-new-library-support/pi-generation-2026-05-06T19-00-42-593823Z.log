[tool-call] delta {"path":"tests/src/com.beachape/enumeratum-macros_3/1.9.0/src/test/scala/com_beachape/enumeratum_macros_3/ValueEnumMacrosInnerValueOfFromExprTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_beachape.enumeratum_macros_3\n\nimport enumeratum.ValueEnumMacros\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\n\nclass ValueEnumMacrosInnerValueOfFromExprTest {\n  @Test\n  def intValueEntriesMacroFindsTopLevelSingletonEntries(): Unit = {\n    assertEquals(IndexedSeq(LowPriority, MediumPriority, HighPriority), Priority.values)\n    assertEquals(1, LowPriority.value)\n    assertEquals(5, MediumPriority.value)\n    assertEquals(10, HighPriority.value)\n    assertSame(MediumPriority, Priority.values(1))\n  }\n}\n\nobject ValueEnumMacroApi {\n  inline def findIntValueEntries[A]: IndexedSeq[A] =\n    ${ ValueEnumMacros.findIntValueEntriesImpl[A] }\n}\n\nsealed abstract class Priority(val value: Int)\ncase object LowPriority extends Priority(1)\ncase object MediumPriority extends Priority(5)\ncase object HighPriority extends Priority(10)\n\nobject Priority {\n  val values: IndexedSeq[Priority] = ValueEnumMacroApi.findIntValueEntries[Priority]\n}\n"}
