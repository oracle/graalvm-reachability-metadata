obe {\n  inline def reachesReflection: Boolean = ${ reachesReflectionImpl }\n\n  private def reachesReflectionImpl(using quotes: Quotes): Expr[Boolean] = {\n    import quotes.reflect.report\n\n    val valueOfExpr: Expr[ValueOf[LowPriority.type]] =\n      '{ new ValueOf[LowPriority.type](LowPriority) }\n    val extracted = ValueOfFromExprBridge.unapply(\n      Type.of[LowPriority.type],\n      valueOfExpr,\n      quotes\n    )\n\n    if (extracted.exists(_.value == LowPriority)) {\n      Expr(true)\n    } else {\n      report.errorAndAbort(\"ValueOfFromExpr did not extract the singleton module\")\n    }\n  }\n}\n"}], "isError": false, "timestamp": 1778095297713}, {"role": "toolResult", "toolCallId": "call_yKqbNCtP9EB575mZuieiZojm|fc_068a23636d3995f20169fb94c0eb74819c98606af6a8756750", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_beachape.enumeratum_macros_3;\n\nimport enumeratum.ValueEnumMacros$ValueOfFromExpr;\nimport scala.Option;\nimport scala.ValueOf;\nimport scala.quoted.Expr;\nimport scala.quoted.Quotes;\nimport scala.quoted.Type;\n\nfinal class ValueOfFromExprBridge {\n    private ValueOfFromExprBridge() {\n    }\n\n    static <T> Option<ValueOf<T>> unapply(Type<T> type, Expr<ValueOf<T>> expr, Quotes quotes) {\n        return new ValueEnumMacros$ValueOfFromExpr<T>(type).unapply(expr, quotes);\n    }\n}\n"}], "isError": false, "timestamp": 1778095297714}, {"role": "toolResult", "toolCallId": "call_Atiet22RdvOSsqBvnRvQVaMQ|fc_068a23636d3995f20169fb94c0eb88819c9ba340740af8bdd3", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>