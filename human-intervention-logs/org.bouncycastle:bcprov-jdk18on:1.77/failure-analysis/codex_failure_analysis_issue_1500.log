tParams().getL());\\n        assertThat(restored.getAlgorithm()).isEqualTo(\\\"DH\\\");\\n        assertThat(restored.getFormat()).isEqualTo(\\\"X.509\\\");\\n        assertThat(restored.getEncoded()).isNotEmpty();\\n    }\\n\\n    private static BCDHPublicKey newBcDhPublicKey() throws Exception {\\n        DHParameter parameters = new DHParameter(P, G, 0);\\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\\n                PKCSObjectIdentifiers.dhKeyAgreement,\\n                parameters.toASN1Primitive());\\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(\\n                algorithmIdentifier,\\n                new ASN1Integer(PUBLIC_VALUE));\\n\\n        return new BCDHPublicKey(publicKeyInfo);\\n    }\\n\\n    private static byte[] serialize(DHPublicKey publicKey) throws Exception {\\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\\n            objectOutputStream.writeObject(publicKey);\\n        }\\n        return serialized.toByteArray();\\n    }\\n\\n    private static DHPublicKey deserialize(byte[] serialized) throws Exception {\\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\\n            return (DHPublicKey)objectInputStream.readObject();\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_59\",\"type\":\"agent_message\",\"text\":\"The failure is now about metadata shape, not missing coverage: the `BCDHPrivateKey` serialization entry is present, but its `BouncyCastleProvider` condition never becomes true because that test constructs the key directly from ASN.1 rather than through the provider. I’m keeping the reflective registrations conditional, but removing the runtime conditions from the serialization entries so the exercised key classes can deseri