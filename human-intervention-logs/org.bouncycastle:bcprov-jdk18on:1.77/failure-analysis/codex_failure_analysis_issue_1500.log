/bcprov_jdk18on/BCElGamalPublicKeyTest.java:86:        KeyFactory keyFactory = KeyFactory.getInstance(\\\"ElGamal\\\", new BouncyCastleProvider());\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n121:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_70\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDSAPublicKeyTest.java\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcprov_jdk18on;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.IOException;\\nimport java.io.ObjectInputStream;\\nimport java.io.ObjectOutputStream;\\nimport java.io.OutputStream;\\nimport java.lang.invoke.MethodHandle;\\nimport java.lang.invoke.MethodHandles;\\nimport java.lang.invoke.MethodType;\\nimport java.math.BigInteger;\\nimport java.security.GeneralSecurityException;\\nimport java.security.KeyFactory;\\nimport java.security.interfaces.DSAParams;\\nimport java.security.spec.DSAPublicKeySpec;\\n\\nimport org.bouncycastle.asn1.ASN1Integer;\\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPublicKey;\\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class BCDSAPublicKeyTest {\\n    private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);\\n    private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);\\n    private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);\\n    private static final BigInteger Y = BigInteger.valueOf(18L);\\n    private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);\\n    private static final BigInteger RESTORED_Q = TrackedBigInteger.trackedValueOf(23L);\\n    private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(14L);\\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\\n    private static final MethodHandle READ_OBJECT = findReadObject();\\n\\n    @Test\\n    public void javaSerializationRoundTripsDsaPublicKeyParameters() throws Exception {\\n        BCDSAPublicKey original = createPublicKeyWithParameters();\\n\\n        BCDSAPublicKey restored = deserialize(serialize(original), BCDSAPublicKey.class);\\n        DSAParams restoredParameters = restored.getParams();\\n\\n        assertThat(restored).isNotSameAs(original);\\n        assertThat(restored).isEqualTo(original);\\n        assertThat(restored.getAlgorithm()).isEqualTo(\\\"DSA\\\");\\n        assertThat(restored.getFormat()).isEqualTo(\\\"X.509\\\");\\n        assertThat(restored.getY()).isEqualTo(Y);\\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\\n        assertThat(restoredParameters).isNotNull();\\n        assertThat(restoredParameters.getP()).isEqualTo(P);\\n        assertThat(restoredParameters.getQ()).isEqualTo(Q);\\n        assertThat(restoredParameters.getG()).isEqualTo(G);\\n    }\\n\\n    @Test\\n    public void serializationHooksWriteAndRestoreDsaPublicKeyParameters() throws Throwable {\\n        BCDSAPublicKey original = createPublicKeyWithParameters();\\n\\n        byte[] writtenParameters = invokeWriteObject(original);\\n\\n        assertThat(readObjects(writtenParameters)).containsExactly(P, Q, G);\\n\\n        BCDSAPublicKey restored = createPublicKeyWithParameters();\\n        byte[] restoredParameterStream = writeObjects(RESTORED_P, RESTORED_Q, RESTORED_G);\\n\\n        try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {\\n            invokeReadObject(restored, inputStream);\\n        }\\n        DSAParams restoredParameters = restored.getParams();\\n\\n        assertThat(restored.getAlgorithm()).isEqualTo(\\\"DSA\\\");\\n        assertThat(restored.getFormat()).isEqualTo(\\\"X.509\\\");\\n        assertThat(restored.getY()).isEqualTo(Y);\\n        assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);\\n        assertThat(restoredParameters.getQ()).isEqualTo(RESTORED_Q);\\n        assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);\\n    }\\n\\n    @Test\\n    public void javaSerializationRoundTripsDsaPublicKeyWithoutParameters() throws Exception {\\n        BCDSAPublicKey original = createPublicKeyWithoutParameters();\\n\\n        BCDSAPublicKey restored = deserialize(serialize(original), BCDSAPublicKey.class);\\n\\n        assertThat(restored).isNotSameAs(original);\\n        assertThat(restored).isEqualTo(original);\\n        assertThat(restored.getAlgorithm()).isEqualTo(\\\"DSA\\\");\\n        assertThat(restored.getFormat()).isEqualTo(\\\"X.509\\\");\\n        assertThat(restored.getY()).isEqualTo(Y);\\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\\n        assertThat(restored.getParams()).isNull();\\n    }\\n\\n    private static BCDSAPublicKey createPublicKeyWithParameters() throws GeneralSecurityException {\\n        DSAPublicKeySpec keySpec = new DSAPublicKeySpec(Y, P, Q, G);\\n        KeyFactory keyFactory = KeyFactory.getInstance(\\\"DSA\\\", new BouncyCastleProvider());\\n\\n        return (BCDSAPublicKey) keyFactory.generatePublic(keySpec);\\n    }\\n\\n    private static BCDSAPublicKey createPublicKeyWithoutParameters() throws IOException {\\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(X9ObjectIdentifiers.id_dsa);\\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(Y));\\n\\n        return new BCDSAPublicKey(publicKeyInfo);\\n    }\\n\\n    private static byte[] serialize(Object object) throws IOException {\\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\\n            outputStream.writeObject(object);\\n        }\\n        return output.toByteArray();\\n    }\\n\\n    private static byte[] invokeWriteObject(BCDSAPublicKey publicKey) throws Throwable {\\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\\n        try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {\\n            WRITE_OBJECT.invokeExact(publicKey, outputStream);\\n        }\\n        return output.toByteArray();\\n    }\\n\\n    private static void invokeReadObject(BCDSAPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\\n        READ_OBJECT.invokeExact(publicKey, inputStream);\\n    }\\n\\n    private static byte[] writeObjects(Object firstObject, Object secondObject, Object thirdObject) throws IOException {\\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\\n            outputStream.writeObject(firstObject);\\n            outputStream.writeObject(secondObject);\\n            outputStream.writeObject(thirdObject);\\n        }\\n        return output.toByteArray();\\n    }\\n\\n    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\\n            return new Object[] {inputStream.readObject(), inputStream.readObject(), inputStream.readObject()};\\n        }\\n    }\\n\\n    private static <T> T deserialize(byte[] bytes, Class<T> type) throws IOException, ClassNotFoundException {\\n        try (ObjectInputStream inputStream = new ObjectInputStream(ne