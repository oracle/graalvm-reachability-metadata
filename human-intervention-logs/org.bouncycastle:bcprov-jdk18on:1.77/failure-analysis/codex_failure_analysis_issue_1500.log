Integer.valueOf(2L);\\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\\\"1234567890123456789012345678901234567890\\\");\\n\\n    @Test\\n    void serializesAndRestoresDhPrivateKeyParameters() throws Exception {\\n        BCDHPrivateKey original = newBcDhPrivateKey();\\n\\n        DHPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);\\n\\n        assertThat(restored).isInstanceOf(BCDHPrivateKey.class);\\n        assertThat(restored.getX()).isEqualTo(original.getX());\\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\\n        assertThat(restored.getParams().getL()).isEqualTo(original.getParams().getL());\\n        assertThat(restored.getAlgorithm()).isEqualTo(\\\"DH\\\");\\n        assertThat(restored.getFormat()).isEqualTo(\\\"PKCS#8\\\");\\n        assertThat(restored.getEncoded()).isNotEmpty();\\n    }\\n\\n    private static BCDHPrivateKey newBcDhPrivateKey() throws Exception {\\n        DHParameter parameters = new DHParameter(P, G, 0);\\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\\n                PKCSObjectIdentifiers.dhKeyAgreement,\\n                parameters.toASN1Primitive());\\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(PRIVATE_VALUE));\\n\\n        return new BCDHPrivateKey(privateKeyInfo);\\n    }\\n\\n    private static DHPrivateKey serializeAndDeserializeFromBouncyCastleFrame(BCDHPrivateKey privateKey) {\\n        CollectionStore<BCDHPrivateKey> store = new CollectionStore<>(List.of(privateKey));\\n        AtomicReference<DHPrivateKey> restored = new AtomicReference<>();\\n\\n        Collection<BCDHPrivateKey> matches = store.getMatches(new Selector<>() {\\n            @Override\\n            public boolean match(BCDHPrivateKey key) {\\n                try {\\n                    restored.set(deserialize(serialize(key)));\\n                    return true;\\n                }\\n                catch (Exception e) {\\n                    throw new IllegalStateException(\\\"DH private key serialization failed\\\", e);\\n                }\\n            }\\n\\n            @Override\\n            public Object clone() {\\n                return this;\\n            }\\n        });\\n\\n        assertThat(matches).containsExactly(privateKey);\\n        return restored.get();\\n    }\\n\\n    private static byte[] serialize(DHPrivateKey privateKey) throws Exception {\\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\\n            objectOutputStream.writeObject(privateKey);\\n        }\\n        return serialized.toByteArray();\\n    }\\n\\n    private static DHPrivateKey deserialize(byte[] serialized) throws Exception {\\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\\n            return (DHPrivateKey)objectInputStream.readObject();\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_58\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,180p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDHPublicKeyTest.java\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_58\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"sed -n '1,180p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDHPublicKeyTest.java\\\"\",\"aggregated_output\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creat