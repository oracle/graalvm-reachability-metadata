cycastle.pqc.jcajce.provider.cmce.BCCMCEPrivateKey;\\nimport org.bouncycastle.pqc.jcajce.spec.CMCEParameterSpec;\\nimport org.junit.jupiter.api.Test;\\n\\npublic class BCCMCEPrivateKeyTest {\\n    private static final int MCELIECE_348864_PRIVATE_KEY_SIZE = 6_492;\\n\\n    @Test\\n    public void objectSerializationWritesAndReadsEncodedCmcePrivateKey() throws Exception {\\n        BCCMCEPrivateKey privateKey = newCmcePrivateKey();\\n\\n        Object restoredObject = readObject(writeObject(privateKey));\\n\\n        assertThat(restoredObject).isInstanceOf(BCCMCEPrivateKey.class);\\n        BCCMCEPrivateKey restored = (BCCMCEPrivateKey)restoredObject;\\n        assertThat(restored).isNotSameAs(privateKey);\\n        assertCmcePrivateKey(restored, privateKey);\\n    }\\n\\n    private static BCCMCEPrivateKey newCmcePrivateKey() {\\n        byte[] privateKey = filledBytes(MCELIECE_348864_PRIVATE_KEY_SIZE, 0x23);\\n        CMCEPrivateKeyParameters keyParameters = new CMCEPrivateKeyParameters(\\n                CMCEParameters.mceliece348864r3,\\n                privateKey);\\n        return new BCCMCEPrivateKey(keyParameters);\\n    }\\n\\n    private static byte[] filledBytes(int length, int firstValue) {\\n        byte[] bytes = new byte[length];\\n        for (int index = 0; index < bytes.length; index++) {\\n            bytes[index] = (byte)(firstValue + index);\\n        }\\n        return bytes;\\n    }\\n\\n    private static void assertCmcePrivateKey(BCCMCEPrivateKey actual, BCCMCEPrivateKey expected) {\\n        assertThat(actual.getAlgorithm()).isEqualTo(\\\"MCELIECE348864\\\");\\n        assertThat(actual.getFormat()).isEqualTo(\\\"PKCS#8\\\");\\n        assertThat(actual.getParameterSpec()).isSameAs(CMCEParameterSpec.mceliece348864);\\n        assertThat(actual).isEqualTo(expected);\\n        assertThat(actual.hashCode()).isEqualTo(expected.hashCode());\\n        assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());\\n    }\\n\\n    private static byte[] writeObject(Object object) throws IOException {\\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\\n            outputStream.writeObject(object);\\n        }\\n        return output.toByteArray();\\n    }\\n\\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\\n            return inputStream.readObject();\\n        }\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_12\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'BCCMCEPrivateKey|BCCMCEPublicKey|serializable|pqc\\\\\\\\.jcajce\\\\\\\\.provider\\\\\\\\.cmce' metadata/org.bouncycastle/bcprov-jdk18on/1.77/reachability-metadata.json tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/resources/META-INF/native-image/reachability-metadata.json\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_12\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"rg -n 'BCCMCEPrivateKey|BCCMCEPublicKey|serializable|pqc\\\\\\\\.jcajce\\\\\\\\.provider\\\\\\\\.cmce' metadata/org.bouncycastle/bcprov-jdk18on/1.77/reachability-metadata.json tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/resources/META-INF/native-image/reachability-metadata.json\\\"\",\"aggregated_output\":\"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/resources/META-INF/native-image/reachability-metadata.json:8:      \\\"serializable\\\" : true\\ntests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/resources/META-INF/native-image/reachability-metadata.json:15:      \\\"serializable\\\" : true\\ntests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/resources/META-INF/native-image/reachability-metadata.