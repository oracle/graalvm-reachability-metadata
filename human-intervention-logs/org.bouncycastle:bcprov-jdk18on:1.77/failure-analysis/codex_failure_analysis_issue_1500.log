.ECDomainParameters;\\nimport org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PrivateKey;\\nimport org.bouncycastle.jce.spec.ECNamedCurveSpec;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.ObjectOutputStream;\\nimport java.math.BigInteger;\\nimport java.security.spec.ECPrivateKeySpec;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class BCDSTU4145PrivateKeyTest {\\n    private static final String DSTU4145_CURVE_OID = \\\"1.2.804.2.1.1.1.1.3.1.1.2.0\\\";\\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\\\"12345678901234567890\\\");\\n    private static final ECDomainParameters DSTU4145_PARAMETERS = DSTU4145NamedCurves.getByOID(\\n            new ASN1ObjectIdentifier(DSTU4145_CURVE_OID));\\n\\n    @Test\\n    void serializesDstuPrivateKeyEncodedForm() throws Exception {\\n        BCDSTU4145PrivateKey privateKey = newDstuPrivateKey();\\n        byte[] encoded = privateKey.getEncoded();\\n\\n        byte[] serialized = serialize(privateKey);\\n\\n        assertThat(privateKey.getAlgorithm()).isEqualTo(\\\"DSTU4145\\\");\\n        assertThat(privateKey.getFormat()).isEqualTo(\\\"PKCS#8\\\");\\n        assertThat(privateKey.getD()).isEqualTo(PRIVATE_VALUE);\\n        assertThat(privateKey.getParams().getOrder()).isEqualTo(DSTU4145_PARAMETERS.getN());\\n        assertThat(privateKey.getParams().getCofactor()).isEqualTo(DSTU4145_PARAMETERS.getH().intValue());\\n        assertThat(privateKey.getParams().getGenerator()).isNotNull();\\n        assertThat(encoded).isNotEmpty();\\n        assertThat(serialized).containsSequence(encoded);\\n        assertThat(privateKey.getBagAttributeKeys().hasMoreElements()).isFalse();\\n    }\\n\\n    private static BCDSTU4145PrivateKey newDstuPrivateKey() {\\n        ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(\\n                DSTU4145_CURVE_OID,\\n                DSTU4145_PARAMETERS.getCurve(),\\n                DSTU4145_PARAMETERS.getG(),\\n                DSTU4145_PARAMETERS.getN(),\\n                DSTU4145_PARAMETERS.getH(),\\n                DSTU4145_PARAMETERS.getSeed());\\n\\n        return new BCDSTU4145PrivateKey(new ECPrivateKeySpec(PRIVATE_VALUE, namedCurveSpec));\\n    }\\n\\n    private static byte[] serialize(BCDSTU4145PrivateKey privateKey) throws Exception {\\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\\n            objectOutputStream.writeObject(privateKey);\\n        }\\n        return serialized.toByteArray();\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_110\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"jq '.reflection[] | select(.serializable==true) | .type' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/build/natively-collected/runs/cycle-34/reachability-metadata.json\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_110\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc \\\"jq '.reflection[] | select(.serializable==true) | .type' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/build/natively-collected/runs/cycle-34/reachability-metadata.json\\\"\",\"aggregated_output\":\"\\\"java.lang.Number\\\"\\n\\\"java.lang.String\\\"\\n\\\"java.math.BigInteger\\\"\\n\\\"org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey\\\"\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_111\",\"type\":\"agent_message\",\"text\":\"The updated trace confirms `java.lang.String` is the only new serializable JDK type exposed so far. I’m adding it unconditionally beside the other serialization support entries and rerunning the native trace again.\"}}\n2026-06-08T00:59:00.573900Z ERROR codex_core::tools::router: error=apply_