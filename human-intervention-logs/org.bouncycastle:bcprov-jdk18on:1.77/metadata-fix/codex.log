GostPrivateKeyWithExplicitParameters() throws Exception {\n        GOST3410PrivateKey original = newGostPrivateKeyWithExplicitParameters();\n\n        GOST3410PrivateKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void customSerializationWritesAndReadsGostParameterObjects() throws Exception {\n        GOST3410PrivateKey original = newGostPrivateKey();\n        TrackingObjectOutputStream serialized = new TrackingObjectOutputStream();\n\n        serialized.writeObject(original);\n        serialized.close();\n        GOST3410PrivateKey restored = deserializeWithTracking(serialized.toByteArray());\n\n        assertThat(serialized.replacedObjects()).contains(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId(),\n                CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static GOST3410PrivateKey newGostPrivateKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        keyPairGenerator.initialize(\n                new GOST3410ParameterSpec(CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId()),\n                new SecureRandom(new byte[] {\n                        1, 2, 3, 4, 5\n                }));\n\n        return (GOST3410PrivateKey)keyPairGenerator.generateKeyPair().getPrivate();\n    }\n\n    private static GOST3410PrivateKey newGostPrivateKeyWithExplicitParameters() throws Exception {\n        GOST3410ParamSetParameters parameters = GOST3410NamedParameters.getByOID(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A);\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        PrivateKey privateKey = keyFactory.generatePrivate(new GOST3410PrivateKeySpec(\n                PRIVATE_VALUE,\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA()));\n\n        return (GOST3410PrivateKey)privateKey;\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(\n            GOST3410PrivateKey original,\n            GOST3410PrivateKey restored) {\n        assertThat(original).isInstanceOf(BCGOST3410PrivateKey.class);\n        assertThat(restored).isInstanceOf(BCGOST3410PrivateKey.class);\n        assertThat(restored.getX()).isEqualTo(original.getX());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        if (restored.getParameters().getPublicKeyParamSetOID() != null) {\n            assertThat(restored.getEncoded()).isNotEmpty();\n        }\n        assertThat(restored.getParameters().getPublicKeyParamSetOID())\n                .isEqualTo(original.getParameters().getPublicKeyParamSetOID());\n        assertThat(restored.getParameters().getDigestParamSetOID())\n                .isEqualTo(original.getParameters().getDigestParamSetOID());\n        assertThat(restored.getParameters().getEncryptionParamSetOID())\n                .isEqualTo(original.getParameters().getEncryptionParamSetOID());\n        assertThat(restored.getParameters().getPublicKeyParameters())\n                .isEqualTo(original.getParameters().getPublicKeyParameters());\n        assertThat(((BCGOST3410PrivateKey)restored).getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static byte[] serialize(GOST3410PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static GOST3410PrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (GOST3410PrivateKey)objectInputStream.readObject();\n        }\n    }\n\n    private static GOST3410PrivateKey deserializeWithTracking(byte[] serialized) throws Exception {\n        try (TrackingObjectInputStream objectInputStream = new TrackingObjectInputStream(serialized)) {\n            GOST3410PrivateKey restored = (GOST3410PrivateKey)objectInputStream.readObject();\n            assertThat(objectInputStream.resolvedObjects()).contains(\n                    CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId(),\n                    CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n            return restored;\n        }\n    }\n\n    private static final class TrackingObjectOutputStream extends ObjectOutputStream {\n        private final ByteArrayOutputStream serialized;\n        private final Set<Object> replacedObjects = new LinkedHashSet<>();\n\n        private TrackingObjectOutputStream() throws Exception {\n            this(new ByteArrayOutputStream());\n        }\n\n        private TrackingObjectOutputStream(ByteArrayOutputStream serialized) throws Exception {\n            super(serialized);\n            this.serialized = serialized;\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) {\n            replacedObjects.add(object);\n            return object;\n        }\n\n        private byte[] toByteArray() {\n            return serialized.toByteArray();\n        }\n\n        private Set<Object> replacedObjects() {\n            return replacedObjects;\n        }\n    }\n\n    private static final class TrackingObjectInputStream extends ObjectInputStream {\n        private final Set<Object> resolvedObjects = new LinkedHashSet<>();\n\n        private TrackingObjectInputStream(byte[] serialized) throws Exception {\n            super(new ByteArrayInputStream(serialized));\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) {\n            resolvedObjects.add(object);\n            return object;\n        }\n\n        private Set<Object> resolvedObjects() {\n            return resolvedObjects;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
