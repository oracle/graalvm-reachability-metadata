a126d9346e38c5\",\n            16);\n    private static final BigInteger G = new BigInteger(\n            \"678471b27a9cf44ee91a49c5147db1a9aaf244f05a434d6486931d2d14271b9e\"\n                    + \"35030b71fd73da179069b32e2935630e1c2062354d0da20a6c416e50be794ca4\",\n            16);\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"12345678901234567890\");\n    private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = new ASN1ObjectIdentifier(\n            \"1.2.840.113549.1.9.20\");\n    private static final DERUTF8String FRIENDLY_NAME = new DERUTF8String(\"jdk-dsa-private-key\");\n\n    @Test\n    void serializesAndRestoresExactJdkDsaPrivateKeyParameters() throws Exception {\n        TrackingObjectInputStream input = new TrackingObjectInputStream(serializedJdkDsaPrivateKey());\n        JDKDSAPrivateKey original = input.readJdkDsaPrivateKey();\n\n        assertThat(input.resolvedBigIntegers()).contains(PRIVATE_VALUE, P, Q, G);\n        assertRestoredKeyMatches(original);\n        assertThat(original.getClass()).isEqualTo(JDKDSAPrivateKey.class);\n\n        original.setBagAttribute(FRIENDLY_NAME_OID, FRIENDLY_NAME);\n        TrackingObjectOutputStream output = new TrackingObjectOutputStream();\n        output.writeObject(original);\n        output.close();\n\n        assertThat(output.replacedBigIntegers()).contains(PRIVATE_VALUE, P, Q, G);\n        JDKDSAPrivateKey restored = deserialize(output.toByteArray());\n\n        assertRestoredKeyMatches(restored);\n        assertThat(restored.getClass()).isEqualTo(JDKDSAPrivateKey.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertThat(restored.getBagAttribute(FRIENDLY_NAME_OID)).isEqualTo(FRIENDLY_NAME);\n    }\n\n    @Test\n    void signedObjectSerializesAndRestoresExactJdkDsaPrivateKey() throws Exception {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n        Signature signingSignature = Signature.getInstance(\"SHA1withDSA\", provider);\n\n        SignedObject signedObject = new SignedObject(original, original, signingSignature);\n        JDKDSAPrivateKey restored = (JDKDSAPrivateKey)signedObject.getObject();\n\n        assertThat(signedObject.verify(newDsaPublicKey(provider), Signature.getInstance(\"SHA1withDSA\", provider)))\n                .isTrue();\n        assertRestoredKeyMatches(restored);\n        assertThat(restored.getClass()).isEqualTo(JDKDSAPrivateKey.class);\n    }\n\n    @Test\n    void serializesAndRestoresExactJdkDsaPrivateKeyInsideObjectArray() throws Exception {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n\n        Object[] restored = (Object[])deserializeObject(serialize(new Object[] {\n                original\n        }));\n\n        assertRestoredKeyMatches((JDKDSAPrivateKey)restored[0]);\n        assertThat(restored[0].getClass()).isEqualTo(JDKDSAPrivateKey.class);\n    }\n\n    @Test\n    void serializesAndRestoresJdkDsaPrivateKeyWithStreamObjectSubstitution() throws Exception {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n        ReplacingBigIntegerObjectOutputStream output = new ReplacingBigIntegerObjectOutputStream();\n\n        output.writeObject(original);\n        output.close();\n\n        assertThat(output.replacedBigIntegers()).containsExactly(PRIVATE_VALUE, P, Q, G);\n\n        ResolvingBigIntegerObjectInputStream input = new ResolvingBigIntegerObjectInputStream(\n                output.toByteArray(),\n                output.replacedBigIntegers());\n        JDKDSAPrivateKey restored = input.readJdkDsaPrivateKey();\n\n        assertThat(input.resolvedReplacementCount()).isEqualTo(4);\n        assertRestoredKeyMatches(restored);\n        assertThat(restored.getClass()).isEqualTo(JDKDSAPrivateKey.class);\n    }\n\n    private static void assertRestoredKeyMatches(DSAPrivateKey restored) {\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParams().getP()).isEqualTo(P);\n        assertThat(restored.getParams().getQ()).isEqualTo(Q);\n        assertThat(restored.getParams().getG()).isEqualTo(G);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n    }\n\n    private static PublicKey newDsaPublicKey(BouncyCastleProvider provider) throws Exception {\n        BigInteger publicValue = G.modPow(PRIVATE_VALUE, P);\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", provider);\n        return keyFactory.generatePublic(new DSAPublicKeySpec(publicValue, P, Q, G));\n    }\n\n    private static byte[] serializedJdkDsaPrivateKey() throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(serialized);\n        output.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        output.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        output.writeByte(ObjectStreamConstants.TC_OBJECT);\n        output.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        output.writeUTF(JDKDSAPrivateKey.class.getName());\n        output.writeLong(ObjectStreamClass.lookup(JDKDSAPrivateKey.class).getSerialVersionUID());\n        output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n        output.writeShort(0);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        output.writeByte(ObjectStreamConstants.TC_NULL);\n        output.write(serializedObjectPayload(PRIVATE_VALUE));\n        output.write(serializedObjectPayload(P));\n        output.write(serializedObjectPayload(Q));\n        output.write(serializedObjectPayload(G));\n        output.write(serializedObjectPayload(new Hashtable<>()));\n        output.write(serializedObjectPayload(new Vector<>()));\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        return serialized.toByteArray();\n    }\n\n    private static byte[] serializedObjectPayload(Object value) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(value);\n        }\n        byte[] stream = serialized.toByteArray();\n        return Arrays.copyOfRange(stream, 4, stream.length);\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(value);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JDKDSAPrivateKey deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        return (JDKDSAPrivateKey)deserializeObject(serialized);\n    }\n\n    private static Object deserializeObject(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return objectInputStream.readObject();\n        }\n    }\n\n    private static XMSSNode newReplacementToken(BigInteger value) throws IOException {\n        try {\n            return (XMSSNode)deserializeObject(serializedXmssNode(value.toByteArray()));\n        }\n        catch (ClassNotFoundException e) {\n            throw new IOException(\"XMSS replacement token could not be deserialized\", e);\n        }\n    }\n\n    private static byte[] serializedXmssNode(byte[] value) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(serialized);\n        output.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        output.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        output.writeByte(ObjectStreamConstants.TC_OBJECT);\n        output.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        output.writeUTF(XMSSNode.class.getName());\n        output.writeLong(ObjectStreamClass.lookup(XMSSNode.class).getSerialVersionUID());\n        output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE);\n        output.writeShort(2);\n        output.writeByte('I');\n        output.writeUTF(\"height\");\n        output.writeByte('[');\n        output.writeUTF(\"value\");\n        output.writeByte(ObjectStreamConstants.TC_STRING);\n        output.writeUTF(\"[B\");\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        output.writeByte(ObjectStreamConstants.TC_NULL);\n        output.writeInt(0);\n        output.write(serializedObjectPayload(value));\n        return serialized.toByteArray();\n    }\n\n    private static final class TrackingObjectInputStream extends ObjectInputStream {\n        private final List<BigInteger> resolvedBigIntegers = new ArrayList<>();\n\n        private TrackingObjectInputStream(byte[] serialized) throws IOException {\n            super(new ByteArrayInputStream(serialized));\n            enableResolveObject(true);\n        }\n\n        private JDKDSAPrivateKey readJdkDsaPrivateKey() throws IOException, ClassNotFoundException {\n            return (JDKDSAPrivateKey)readObject();\n        }\n\n        private List<BigInteger> resolvedBigIntegers() {\n            return resolvedBigIntegers;\n        }\n\n        @Override\n        protected Object resolveObject(Object obj) throws IOException {\n            if (obj instanceof BigInteger) {\n                resolvedBigIntegers.add((BigInteger)obj);\n            }\n            return super.resolveObject(obj);\n        }\n    }\n\n    private static final class TrackingObjectOutputStream extends Object