{"type":"item.completed","item":{"id":"item_79","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDSTU4145PrivateKeyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.PrivateKey;\nimport java.security.spec.ECFieldFp;\nimport java.security.spec.ECParameterSpec;\nimport java.security.spec.ECPoint;\nimport java.security.spec.ECPrivateKeySpec;\nimport java.security.spec.EllipticCurve;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSTU4145PrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\n            \"11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF\",\n            16);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void javaSerializationRoundTripPreservesDstu4145PrivateKey() throws Exception {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        BCDSTU4145PrivateKey privateKey = new BCDSTU4145PrivateKey(\n                new ECPrivateKeySpec(PRIVATE_VALUE, parameters));\n\n        BCDSTU4145PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());\n    }\n\n    @Test\n    public void keyFactoryGeneratedPrivateKeySerializationUsesDstu4145Hooks() throws Exception {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSTU4145\", new BouncyCastleProvider());\n        PrivateKey privateKey = keyFactory.generatePrivate(new ECPrivateKeySpec(PRIVATE_VALUE, parameters));\n\n        BCDSTU4145PrivateKey restored = roundTrip((BCDSTU4145PrivateKey)privateKey);\n\n        assertThat(privateKey).isInstanceOf(BCDSTU4145PrivateKey.class);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedKey() throws Throwable {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        BCDSTU4145PrivateKey privateKey = new BCDSTU4145PrivateKey(\n                new ECPrivateKeySpec(PRIVATE_VALUE, parameters));\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);\n\n        byte[] encoded = privateKey.getEncoded();\n        assertThat((byte[])outputStream.writtenObject()).isEqualTo(encoded);\n\n        BCDSTU4145PrivateKey restored = new BCDSTU4145PrivateKey(\n                new ECPrivateKeySpec(BigInteger.ONE, parameters));\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(encoded);\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getEncoded()).isEqualTo(encoded);\n        assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());\n    }\n\n    private static BCDSTU4145PrivateKey roundTrip(BCDSTU4145PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {\n            return (BCDSTU4145PrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCDSTU4145PrivateKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSTU4145PrivateKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCDSTU4145PrivateKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSTU4145PrivateKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static ECParameterSpec createSecp256r1Parameters() {\n        BigInteger p = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF\", 16);\n        BigInteger a = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC\", 16);\n        BigInteger b = new BigInteger(\"5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B\", 16);\n        BigInteger gx = new BigInteger(\"6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296\", 16);\n        BigInteger gy = new BigInteger(\"4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5\", 16);\n        BigInteger n = new BigInteger(\"FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551\", 16);\n\n        return new ECParameterSpec(\n                new EllipticCurve(new ECFieldFp(p), a, b),\n                new ECPoint(gx, gy),\n                n,\n                1);\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private Object writtenObject;\n\n        private RecordingObjectOutputStream() throws Exception {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            writtenObject = object;\n        }\n\n        private Object writtenObject() {\n            return writtenObject;\n        }\n    }\n\n    private static final class ReplayingObjectInputStream extends ObjectInputStream {\n        private final Object object;\n\n        private ReplayingObjectInputStream(Object object) throws Exception {\n            super();\n            this.object = object;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return object;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
