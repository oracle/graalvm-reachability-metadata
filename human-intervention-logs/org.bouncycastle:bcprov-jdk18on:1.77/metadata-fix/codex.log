{"type":"item.completed","item":{"id":"item_143","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,140p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BaseSecretKeyFactoryTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jcajce.provider.symmetric.util.BaseSecretKeyFactory;\nimport org.bouncycastle.jcajce.spec.RawEncodedKeySpec;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.parallel.ResourceLock;\n\nimport java.security.Security;\nimport java.security.spec.InvalidKeySpecException;\nimport java.security.spec.KeySpec;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    private static final byte[] AES_128_KEY_BYTES = new byte[] {\n            0x00, 0x01, 0x02, 0x03,\n            0x04, 0x05, 0x06, 0x07,\n            0x08, 0x09, 0x0a, 0x0b,\n            0x0c, 0x0d, 0x0e, 0x0f\n    };\n\n    @Test\n    void exposesRequestedKeySpecFromBaseSecretKeyFactorySubclass() throws Exception {\n        TestableBaseSecretKeyFactory keyFactory = new TestableBaseSecretKeyFactory();\n        SecretKey secretKey = new SecretKeySpec(AES_128_KEY_BYTES, \"AES\");\n\n        KeySpec keySpec = keyFactory.getKeySpec(secretKey, RawEncodedKeySpec.class);\n\n        assertRawEncodedKeySpec(keySpec);\n    }\n\n    @Test\n    @ResourceLock(\"java.security.Security\")\n    void returnsRequestedKeySpecConstructedFromSecretKeyBytes() throws Exception {\n        boolean addedProvider = Security.getProvider(BouncyCastleProvider.PROVIDER_NAME) == null;\n        if (addedProvider) {\n            Security.addProvider(new BouncyCastleProvider());\n        }\n        try {\n            SecretKeyFactory keyFactory = SecretKeyFactory.getInstance(\n                    \"AES\", BouncyCastleProvider.PROVIDER_NAME);\n            SecretKey secretKey = keyFactory.generateSecret(\n                    new SecretKeySpec(AES_128_KEY_BYTES, \"AES\"));\n\n            KeySpec keySpec = keyFactory.getKeySpec(secretKey, RawEncodedKeySpec.class);\n\n            assertThat(keyFactory.getProvider().getName())\n                    .isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n            assertThat(secretKey.getAlgorithm()).isEqualTo(\"AES\");\n            assertRawEncodedKeySpec(keySpec);\n        } finally {\n            if (addedProvider) {\n                Security.removeProvider(BouncyCastleProvider.PROVIDER_NAME);\n            }\n        }\n    }\n\n    private static void assertRawEncodedKeySpec(KeySpec keySpec) {\n        assertThat(keySpec).isInstanceOf(RawEncodedKeySpec.class);\n        RawEncodedKeySpec rawEncodedKeySpec = (RawEncodedKeySpec)keySpec;\n        assertThat(rawEncodedKeySpec.getFormat()).isEqualTo(\"RAW\");\n        assertThat(rawEncodedKeySpec.getEncoded()).isEqualTo(AES_128_KEY_BYTES);\n    }\n\n    private static final class TestableBaseSecretKeyFactory extends BaseSecretKeyFactory {\n        private TestableBaseSecretKeyFactory() {\n            super(\"AES\", null);\n        }\n\n        private KeySpec getKeySpec(SecretKey key, Class<? extends KeySpec> keySpec)\n                throws InvalidKeySpecException {\n            return engineGetKeySpec(key, keySpec);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
