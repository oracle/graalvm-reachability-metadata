n    private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(14L);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void javaSerializationRoundTripsDsaPublicKeyParameters() throws Exception {\n        BCDSAPublicKey original = createPublicKeyWithParameters();\n\n        BCDSAPublicKey restored = deserialize(serialize(original), BCDSAPublicKey.class);\n        DSAParams restoredParameters = restored.getParams();\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restoredParameters).isNotNull();\n        assertThat(restoredParameters.getP()).isEqualTo(P);\n        assertThat(restoredParameters.getQ()).isEqualTo(Q);\n        assertThat(restoredParameters.getG()).isEqualTo(G);\n    }\n\n    @Test\n    public void serializationHooksWriteAndRestoreDsaPublicKeyParameters() throws Throwable {\n        BCDSAPublicKey original = createPublicKeyWithParameters();\n\n        byte[] writtenParameters = invokeWriteObject(original);\n\n        assertThat(readObjects(writtenParameters)).containsExactly(P, Q, G);\n\n        BCDSAPublicKey restored = createPublicKeyWithParameters();\n        byte[] restoredParameterStream = writeObjects(RESTORED_P, RESTORED_Q, RESTORED_G);\n\n        try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {\n            invokeReadObject(restored, inputStream);\n        }\n        DSAParams restoredParameters = restored.getParams();\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);\n        assertThat(restoredParameters.getQ()).isEqualTo(RESTORED_Q);\n        assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);\n    }\n\n    @Test\n    public void javaSerializationRoundTripsDsaPublicKeyWithoutParameters() throws Exception {\n        BCDSAPublicKey original = createPublicKeyWithoutParameters();\n\n        BCDSAPublicKey restored = deserialize(serialize(original), BCDSAPublicKey.class);\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restored.getParams()).isNull();\n    }\n\n    private static BCDSAPublicKey createPublicKeyWithParameters() throws GeneralSecurityException {\n        DSAPublicKeySpec keySpec = new DSAPublicKeySpec(Y, P, Q, G);\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", new BouncyCastleProvider());\n\n        return (BCDSAPublicKey) keyFactory.generatePublic(keySpec);\n    }\n\n    private static BCDSAPublicKey createPublicKeyWithoutParameters() throws IOException {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(X9ObjectIdentifiers.id_dsa);\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(Y));\n\n        return new BCDSAPublicKey(publicKeyInfo);\n    }\n\n    private static byte[] serialize(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static byte[] invokeWriteObject(BCDSAPublicKey publicKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {\n            WRITE_OBJECT.invokeExact(publicKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n\n    private static void invokeReadObject(BCDSAPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(publicKey, inputStream);\n    }\n\n    private static byte[] writeObjects(Object firstObject, Object secondObject, Object thirdObject) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(firstObject);\n            outputStream.writeObject(secondObject);\n            outputStream.writeObject(thirdObject);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return new Object[] {inputStream.readObject(), inputStream.readObject(), inputStream.readObject()};\n        }\n    }\n\n    private static <T> T deserialize(byte[] bytes, Class<T> type) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return type.cast(inputStream.readObject());\n        }\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSAPublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSAPublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class NoDefaultWriteObjectOutputStream extends ObjectOutputStream {\n        private NoDefaultWriteObjectOutputStream(OutputStream outputStream) throws IOException {\n            super(outputStream);\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n    }\n\n    private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {\n        private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n\n    private static final class TrackedBigInteger extends BigInteger {\n        private static final long serialVersionUID = 1L;\n\n        private TrackedBigInteger(long value) {\n            super(Long.toString(value));\n        }\n\n        private static TrackedBigInteger trackedValueOf(long value) {\n            return new TrackedBigInteger(value);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
