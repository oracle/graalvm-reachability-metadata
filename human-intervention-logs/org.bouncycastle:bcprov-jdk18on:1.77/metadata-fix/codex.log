BigInteger(\n            \"678471b27a9cf44ee91a49c5147db1a9aaf244f05a434d6486931d2d14271b9e\"\n                    + \"35030b71fd73da179069b32e2935630e1c2062354d0da20a6c416e50be794ca4\",\n            16);\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"12345678901234567890\");\n\n    @Test\n    void serializesAndRestoresDsaPrivateKeyParameters() throws Exception {\n        DSAPrivateKey original = newBcDsaPrivateKey();\n\n        DSAPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void signedObjectSerializesAndRestoresProviderGeneratedDsaPrivateKey() throws Exception {\n        KeyPair keyPair = newDsaKeyPair();\n        DSAPrivateKey original = (DSAPrivateKey)keyPair.getPrivate();\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n        Signature signingSignature = Signature.getInstance(\"SHA1withDSA\", provider);\n\n        SignedObject signedObject = new SignedObject(\n                (Serializable)original,\n                keyPair.getPrivate(),\n                signingSignature);\n        Signature verificationSignature = Signature.getInstance(\"SHA1withDSA\", provider);\n        DSAPrivateKey restored = (DSAPrivateKey)signedObject.getObject();\n\n        assertThat(signedObject.verify(keyPair.getPublic(), verificationSignature)).isTrue();\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static DSAPrivateKey newBcDsaPrivateKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", new BouncyCastleProvider());\n        PrivateKey privateKey = keyFactory.generatePrivate(new DSAPrivateKeySpec(PRIVATE_VALUE, P, Q, G));\n\n        return (DSAPrivateKey)privateKey;\n    }\n\n    private static KeyPair newDsaKeyPair() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"DSA\", new BouncyCastleProvider());\n        keyPairGenerator.initialize(new DSAParameterSpec(P, Q, G), new SecureRandom(new byte[] {\n                1, 2, 3, 4, 5\n        }));\n\n        return keyPairGenerator.generateKeyPair();\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(DSAPrivateKey original, DSAPrivateKey restored) {\n        assertThat(original).isInstanceOf(BCDSAPrivateKey.class);\n        assertThat(restored).isInstanceOf(BCDSAPrivateKey.class);\n        assertThat(restored.getX()).isEqualTo(original.getX());\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\n        assertThat(restored.getParams().getQ()).isEqualTo(original.getParams().getQ());\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n        assertThat(((BCDSAPrivateKey)restored).getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static DSAPrivateKey serializeAndDeserializeFromBouncyCastleFrame(DSAPrivateKey privateKey) {\n        CollectionStore<DSAPrivateKey> store = new CollectionStore<>(List.of(privateKey));\n        AtomicReference<DSAPrivateKey> restored = new AtomicReference<>();\n\n        Collection<DSAPrivateKey> matches = store.getMatches(new Selector<>() {\n            @Override\n            public boolean match(DSAPrivateKey key) {\n                try {\n                    restored.set(deserialize(serialize(key)));\n                    return true;\n                }\n                catch (Exception e) {\n                    throw new IllegalStateException(\"DSA private key serialization failed\", e);\n                }\n            }\n\n            @Override\n            public Object clone() {\n                return this;\n            }\n        });\n\n        assertThat(matches).containsExactly(privateKey);\n        return restored.get();\n    }\n\n    private static byte[] serialize(DSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static DSAPrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (DSAPrivateKey)objectInputStream.readObject();\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
