{"type":"item.completed","item":{"id":"item_29","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCCMCEPublicKeyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.cmce.CMCEParameters;\nimport org.bouncycastle.pqc.crypto.cmce.CMCEPublicKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.cmce.BCCMCEPublicKey;\nimport org.bouncycastle.pqc.jcajce.spec.CMCEParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCCMCEPublicKeyTest {\n    private static final int MCELIECE_348864_PUBLIC_KEY_SIZE = 261_120;\n\n    @Test\n    public void objectSerializationWritesAndReadsEncodedCmcePublicKey() throws Exception {\n        BCCMCEPublicKey publicKey = newCmcePublicKey();\n\n        Object restoredObject = readObject(writeObject(publicKey));\n\n        assertThat(restoredObject).isInstanceOf(BCCMCEPublicKey.class);\n        BCCMCEPublicKey restored = (BCCMCEPublicKey)restoredObject;\n        assertThat(restored).isNotSameAs(publicKey);\n        assertCmcePublicKey(restored, publicKey);\n    }\n\n    private static BCCMCEPublicKey newCmcePublicKey() {\n        byte[] publicKey = filledBytes(MCELIECE_348864_PUBLIC_KEY_SIZE, 0x51);\n        CMCEPublicKeyParameters keyParameters = new CMCEPublicKeyParameters(\n                CMCEParameters.mceliece348864r3,\n                publicKey);\n        return new BCCMCEPublicKey(keyParameters);\n    }\n\n    private static byte[] filledBytes(int length, int firstValue) {\n        byte[] bytes = new byte[length];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte)(firstValue + index);\n        }\n        return bytes;\n    }\n\n    private static void assertCmcePublicKey(BCCMCEPublicKey actual, BCCMCEPublicKey expected) {\n        assertThat(actual.getAlgorithm()).isEqualTo(\"MCELIECE348864\");\n        assertThat(actual.getFormat()).isEqualTo(\"X.509\");\n        assertThat(actual.getParameterSpec()).isSameAs(CMCEParameterSpec.mceliece348864);\n        assertThat(actual).isEqualTo(expected);\n        assertThat(actual.hashCode()).isEqualTo(expected.hashCode());\n        assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());\n    }\n\n    private static byte[] writeObject(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return inputStream.readObject();\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
