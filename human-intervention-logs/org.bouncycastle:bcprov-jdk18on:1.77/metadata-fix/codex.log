{"type":"item.completed","item":{"id":"item_159","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JCEDHPublicKeyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jce.provider.JCEDHPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamConstants;\nimport java.io.Serializable;\nimport java.math.BigInteger;\nimport java.nio.charset.StandardCharsets;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport javax.crypto.interfaces.DHPublicKey;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCEDHPublicKeyTest {\n    private static final BigInteger P = new BigInteger(\n            \"155251809230070893513091813125848175563133404943451431320235\"\n                    + \"119490296623994910210725866945387659164244291000768028886422\"\n                    + \"915080371891804634263272761303128298374438082089019628850917\"\n                    + \"0691316593175367469551763119843371637221007210577919\");\n    private static final BigInteger G = BigInteger.valueOf(2L);\n    private static final BigInteger PUBLIC_VALUE = new BigInteger(\"987654321098765432109876543210987654321\");\n    private static final int PUBLIC_VALUE_LENGTH = 32;\n\n    @Test\n    void serializesAndRestoresJceDhPublicKeyParameters() throws Exception {\n        JCEDHPublicKey restored = deserialize(serializedJceDhPublicKey());\n\n        assertThat(restored.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(restored.getParams().getP()).isEqualTo(P);\n        assertThat(restored.getParams().getG()).isEqualTo(G);\n        assertThat(restored.getParams().getL()).isEqualTo(PUBLIC_VALUE_LENGTH);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n\n        JCEDHPublicKey roundTripped = deserialize(serialize(restored));\n\n        assertThat(roundTripped.getY()).isEqualTo(restored.getY());\n        assertThat(roundTripped.getParams().getP()).isEqualTo(restored.getParams().getP());\n        assertThat(roundTripped.getParams().getG()).isEqualTo(restored.getParams().getG());\n        assertThat(roundTripped.getParams().getL()).isEqualTo(restored.getParams().getL());\n    }\n\n    @Test\n    void customSerializationWritesReplaceableDhPublicKeyValues() throws Exception {\n        JCEDHPublicKey publicKey = deserialize(serializedJceDhPublicKey());\n\n        byte[] serialized = serializeWithReplacement(publicKey);\n\n        assertThat(serialized).isNotEmpty();\n        assertThat(new String(serialized, StandardCharsets.ISO_8859_1))\n                .contains(\n                        \"987654321098765432109876543210987654321\",\n                        P.toString(),\n                        G.toString());\n    }\n\n    @Test\n    void customDeserializationReadsResolvableDhPublicKeyValues() throws Exception {\n        try (ResolvingObjectInputStream objectInputStream = new ResolvingObjectInputStream(\n                serializedJceDhPublicKey())) {\n            JCEDHPublicKey publicKey = objectInputStream.readJceDhPublicKey();\n\n            assertThat(publicKey.getY()).isEqualTo(PUBLIC_VALUE);\n            assertThat(objectInputStream.resolvedBigIntegers())\n                    .contains(PUBLIC_VALUE, P, G);\n        }\n    }\n\n    private static byte[] serializedJceDhPublicKey() throws IOException {\n        return serializedJceDhPublicKey(serializedObjectPayload(PUBLIC_VALUE));\n    }\n\n    private static byte[] serializedJceDhPublicKey(byte[] publicValuePayload) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(serialized);\n        output.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        output.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        output.writeByte(ObjectStreamConstants.TC_OBJECT);\n        output.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        output.writeUTF(JCEDHPublicKey.class.getName());\n        output.writeLong(ObjectStreamClass.lookup(JCEDHPublicKey.class).getSerialVersionUID());\n        output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n        output.writeShort(0);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        output.writeByte(ObjectStreamConstants.TC_NULL);\n        output.write(publicValuePayload);\n        output.write(serializedObjectPayload(P));\n        output.write(serializedObjectPayload(G));\n        output.writeByte(ObjectStreamConstants.TC_BLOCKDATA);\n        output.writeByte(Integer.BYTES);\n        output.writeInt(PUBLIC_VALUE_LENGTH);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        return serialized.toByteArray();\n    }\n\n    private static byte[] serializedObjectPayload(Object value) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(value);\n        }\n        byte[] stream = serialized.toByteArray();\n        return Arrays.copyOfRange(stream, 4, stream.length);\n    }\n\n    private static byte[] serialize(DHPublicKey publicKey) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static byte[] serializeWithReplacement(DHPublicKey publicKey) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ReplacingObjectOutputStream objectOutputStream = new ReplacingObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JCEDHPublicKey deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCEDHPublicKey)objectInputStream.readObject();\n        }\n    }\n\n    private static final class ResolvingObjectInputStream extends ObjectInputStream {\n        private final List<BigInteger> resolvedBigIntegers = new ArrayList<>();\n\n        ResolvingObjectInputStream(byte[] serialized) throws IOException {\n            super(new ByteArrayInputStream(serialized));\n            enableResolveObject(true);\n        }\n\n        JCEDHPublicKey readJceDhPublicKey() throws IOException, ClassNotFoundException {\n            return (JCEDHPublicKey)readObject();\n        }\n\n        List<BigInteger> resolvedBigIntegers() {\n            return resolvedBigIntegers;\n        }\n\n        @Override\n        protected Object resolveObject(Object value) throws IOException {\n            if (value instanceof BigInteger bigInteger) {\n                resolvedBigIntegers.add(bigInteger);\n            }\n            return value;\n        }\n    }\n\n    private static final class ReplacingObjectOutputStream extends ObjectOutputStream {\n        ReplacingObjectOutputStream(ByteArrayOutputStream output) throws IOException {\n            super(output);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object value) {\n            if (value instanceof BigInteger bigInteger) {\n                return new ReplacementValue(bigInteger.toString());\n            }\n            return value;\n        }\n    }\n\n    private record ReplacementValue(String label) implements Serializable {\n    }\n}\n","exit_code":0,"status":"completed"}}
