{"type":"item.completed","item":{"id":"item_126","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCGOST3410PublicKeyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;\nimport org.bouncycastle.asn1.cryptopro.GOST3410NamedParameters;\nimport org.bouncycastle.asn1.cryptopro.GOST3410ParamSetParameters;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PublicKey;\nimport org.bouncycastle.jce.interfaces.GOST3410PublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.bouncycastle.jce.spec.GOST3410PublicKeySpec;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.KeyPairGenerator;\nimport java.security.PublicKey;\nimport java.security.SecureRandom;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCGOST3410PublicKeyTest {\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"12345678901234567890\");\n\n    @Test\n    void serializesAndRestoresProviderGeneratedGostPublicKey() throws Exception {\n        BCGOST3410PublicKey original = newGostPublicKey();\n\n        BCGOST3410PublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void serializesAndRestoresGostPublicKeyWithExplicitParameters() throws Exception {\n        BCGOST3410PublicKey original = newGostPublicKeyWithExplicitParameters();\n\n        BCGOST3410PublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void serializesAndRestoresGostPublicKeyInsideObjectGraph() throws Exception {\n        BCGOST3410PublicKey original = newGostPublicKey();\n        GostPublicKeyHolder holder = new GostPublicKeyHolder(\"named-gost-key\", original);\n\n        GostPublicKeyHolder restored = deserializeHolder(serializeHolder(holder));\n\n        assertThat(restored.label).isEqualTo(holder.label);\n        assertRestoredKeyMatchesOriginal(original, restored.publicKey);\n    }\n\n    @Test\n    void serializesAndRestoresGostPublicKeyWithUnsharedSerialization() throws Exception {\n        BCGOST3410PublicKey original = newGostPublicKeyWithExplicitParameters();\n\n        BCGOST3410PublicKey restored = deserializeUnshared(serializeUnshared(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void customSerializationWritesAndReadsNamedGostParameterOids() throws Exception {\n        BCGOST3410PublicKey original = newGostPublicKey();\n        TrackingObjectOutputStream serialized = new TrackingObjectOutputStream();\n\n        serialized.writeObject(original);\n        serialized.close();\n        BCGOST3410PublicKey restored = deserializeWithTracking(\n                serialized.toByteArray(),\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId(),\n                CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n\n        assertThat(serialized.replacedObjects()).contains(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId(),\n                CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertThat(restored.getParameters().getPublicKeyParamSetOID())\n                .isEqualTo(CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId());\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void customSerializationWritesAndReadsExplicitGostParameterObjects() throws Exception {\n        BCGOST3410PublicKey original = newGostPublicKeyWithExplicitParameters();\n        TrackingObjectOutputStream serialized = new TrackingObjectOutputStream();\n\n        serialized.writeObject(original);\n        serialized.close();\n        GOST3410ParamSetParameters parameters = GOST3410NamedParameters.getByOID(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A);\n        BCGOST3410PublicKey restored = deserializeWithTracking(\n                serialized.toByteArray(),\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA(),\n                CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n\n        assertThat(serialized.replacedObjects()).contains(\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA(),\n                CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static BCGOST3410PublicKey newGostPublicKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        keyPairGenerator.initialize(\n                new GOST3410ParameterSpec(CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId()),\n                new SecureRandom(new byte[] {\n                        1, 2, 3, 4, 5\n                }));\n\n        return (BCGOST3410PublicKey)keyPairGenerator.generateKeyPair().getPublic();\n    }\n\n    private static BCGOST3410PublicKey newGostPublicKeyWithExplicitParameters() throws Exception {\n        GOST3410ParamSetParameters parameters = GOST3410NamedParameters.getByOID(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A);\n        BigInteger publicValue = parameters.getA().modPow(PRIVATE_VALUE, parameters.getP());\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        PublicKey publicKey = keyFactory.generatePublic(new GOST3410PublicKeySpec(\n                publicValue,\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA()));\n\n        return (BCGOST3410PublicKey)publicKey;\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(\n            GOST3410PublicKey original,\n            GOST3410PublicKey restored) {\n        assertThat(original).isInstanceOf(BCGOST3410PublicKey.class);\n        assertThat(restored).isInstanceOf(BCGOST3410PublicKey.class);\n        assertThat(restored.getY()).isEqualTo(original.getY());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        if (restored.getParameters().getPublicKeyParamSetOID() != null) {\n            assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        }\n        assertThat(restored.getParameters().getPublicKeyParamSetOID())\n                .isEqualTo(original.getParameters().getPublicKeyParamSetOID());\n        assertThat(restored.getParameters().getDigestParamSetOID())\n                .isEqualTo(original.getParameters().getDigestParamSetOID());\n        assertThat(restored.getParameters().getEncryptionParamSetOID())\n                .isEqualTo(original.getParameters().getEncryptionParamSetOID());\n        assertThat(restored.getParameters().getPublicKeyParameters())\n                .isEqualTo(original.getParameters().getPublicKeyParameters());\n    }\n\n    private static byte[] serialize(BCGOST3410PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static BCGOST3410PublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (BCGOST3410PublicKey)objectInputStream.readObject();\n        }\n    }\n\n    private static byte[] serializeUnshared(BCGOST3410PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeUnshared(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static BCGOST3410PublicKey deserializeUnshared(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (BCGOST3410PublicKey)objectInputStream.readUnshared();\n        }\n    }\n\n    private static byte[] serializeHolder(GostPublicKeyHolder holder) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(holder);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static GostPublicKeyHolder deserializeHolder(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (GostPublicKeyHolder)objectInputStream.readObject();\n        }\n    }\n\n    private static BCGOST3410PublicKey deserializeWithTracking(\n            byte[] serialized,\n            Object... e