er = new BouncyCastleProvider();\n\n            assertGeneratesBytesWithAlgorithm(provider, \"DEFAULT\");\n            assertGeneratesBytesWithAlgorithm(provider, \"NONCEANDIV\");\n        } finally {\n            Security.setProperty(RANDOM_SOURCE_PROPERTY, originalRandomSource);\n            Security.setProperty(STRONG_ALGORITHMS_PROPERTY, originalStrongAlgorithms);\n        }\n    }\n\n    private static void assertGeneratesBytesWithAlgorithm(Provider provider, String algorithm) throws Exception {\n        SecureRandom random = SecureRandom.getInstance(algorithm, provider);\n        byte[] generated = new byte[16];\n        random.nextBytes(generated);\n\n        assertThat(random.getAlgorithm()).isEqualTo(algorithm);\n        assertThat(random.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n        assertThat(generated).hasSize(16);\n    }\n\n    private static void configureInitialEntropySourceDiscovery() {\n        Security.setProperty(RANDOM_SOURCE_PROPERTY, INVALID_RANDOM_SOURCE_URL);\n        Security.setProperty(STRONG_ALGORITHMS_PROPERTY, UNAVAILABLE_STRONG_ALGORITHM);\n    }\n\n    public static class DRBGSecurityPropertiesExtension implements BeforeAllCallback {\n        @Override\n        public void beforeAll(ExtensionContext context) {\n            configureInitialEntropySourceDiscovery();\n        }\n    }\n\n    private static String requireSecurityProperty(String propertyName) {\n        String propertyValue = Security.getProperty(propertyName);\n        assertThat(propertyValue).isNotNull();\n        return propertyValue;\n    }\n}\n","exit_code":0,"status":"completed"}}
