  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jce.provider.JCEDHPrivateKey;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.DataOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.ObjectStreamConstants;
  import java.math.BigInteger;
  import java.util.Arrays;
  
  import javax.crypto.interfaces.DHPrivateKey;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JCEDHPrivateKeyTest {
      private static final BigInteger P = new BigInteger(
              "155251809230070893513091813125848175563133404943451431320235"
                      + "119490296623994910210725866945387659164244291000768028886422"
                      + "915080371891804634263272761303128298374438082089019628850917"
                      + "0691316593175367469551763119843371637221007210577919");
      private static final BigInteger G = BigInteger.valueOf(2L);
      private static final BigInteger PRIVATE_VALUE = new BigInteger("1234567890123456789012345678901234567890");
      private static final int PRIVATE_VALUE_LENGTH = 32;
  
      @Test
      void serializesAndRestoresJceDhPrivateKeyParameters() throws Exception {
          JCEDHPrivateKey restored = deserialize(serializedJceDhPrivateKey());
  
          assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getParams().getP()).isEqualTo(P);
          assertThat(restored.getParams().getG()).isEqualTo(G);
          assertThat(restored.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);
          assertThat(restored.getAlgorithm()).isEqualTo("DH");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getEncoded()).isNotEmpty();
  
          JCEDHPrivateKey roundTripped = deserialize(serialize(restored));
  
          assertThat(roundTripped.getX()).isEqualTo(restored.getX());
          assertThat(roundTripped.getParams().getP()).isEqualTo(restored.getParams().getP());
          assertThat(roundTripped.getParams().getG()).isEqualTo(restored.getParams().getG());
          assertThat(roundTripped.getParams().getL()).isEqualTo(restored.getParams().getL());
      }
  
      private static byte[] serializedJceDhPrivateKey() throws IOException {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          DataOutputStream output = new DataOutputStream(serialized);
          output.writeShort(ObjectStreamConstants.STREAM_MAGIC);
          output.writeShort(ObjectStreamConstants.STREAM_VERSION);
          output.writeByte(ObjectStreamConstants.TC_OBJECT);
          output.writeByte(ObjectStreamConstants.TC_CLASSDESC);
          output.writeUTF(JCEDHPrivateKey.class.getName());
          output.writeLong(ObjectStreamClass.lookup(JCEDHPrivateKey.class).getSerialVersionUID());
          output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);
          output.writeShort(0);
          output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);
          output.writeByte(ObjectStreamConstants.TC_NULL);
          output.write(serializedObjectPayload(PRIVATE_VALUE));
          output.write(serializedObjectPayload(P));
          output.write(serializedObjectPayload(G));
          output.writeByte(ObjectStreamConstants.TC_BLOCKDATA);
          output.writeByte(Integer.BYTES);
          output.writeInt(PRIVATE_VALUE_LENGTH);
          output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);
          return serialized.toByteArray();
      }
  
      private static byte[] serializedObjectPayload(Object value) throws IOException {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(value);
          }
          byte[] stream = serialized.toByteArray();
          return Arrays.copyOfRange(stream, 4, stream.length);
      }
  
      private static byte[] serialize(DHPrivateKey privateKey) throws IOException {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(privateKey);
          }
          return serialized.toByteArray();
      }
  
      private static JCEDHPrivateKey deserialize(byte[] serialized) throws IOException, ClassNotFoundException {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (JCEDHPrivateKey)objectInputStream.readObject();
          }
      }
  }
