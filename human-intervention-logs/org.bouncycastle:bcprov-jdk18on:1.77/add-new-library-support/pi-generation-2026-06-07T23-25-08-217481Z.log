  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jce.interfaces.ElGamalPrivateKey;
  import org.bouncycastle.jce.provider.JCEElGamalPrivateKey;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.DataOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.ObjectStreamConstants;
  import java.math.BigInteger;
  import java.util.Arrays;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JCEElGamalPrivateKeyTest {
      private static final BigInteger P = new BigInteger("104729");
      private static final BigInteger G = new BigInteger("2");
      private static final BigInteger X = new BigInteger("12345");
  
      @Test
      void serializesAndRestoresJceElGamalPrivateKeyParameters() throws Exception {
          JCEElGamalPrivateKey restored = deserialize(serializedJceElGamalPrivateKey());
  
          assertThat(restored.getX()).isEqualTo(X);
          assertThat(restored.getParameters().getP()).isEqualTo(P);
          assertThat(restored.getParameters().getG()).isEqualTo(G);
          assertThat(restored.getParams().getP()).isEqualTo(P);
          assertThat(restored.getParams().getG()).isEqualTo(G);
          assertThat(restored.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getEncoded()).isNotEmpty();
  
          JCEElGamalPrivateKey roundTripped = deserialize(serialize(restored));
  
          assertThat(roundTripped.getX()).isEqualTo(restored.getX());
          assertThat(roundTripped.getParameters().getP()).isEqualTo(restored.getParameters().getP());
          assertThat(roundTripped.getParameters().getG()).isEqualTo(restored.getParameters().getG());
      }
  
      private static byte[] serializedJceElGamalPrivateKey() throws IOException {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          DataOutputStream output = new DataOutputStream(serialized);
          output.writeShort(ObjectStreamConstants.STREAM_MAGIC);
          output.writeShort(ObjectStreamConstants.STREAM_VERSION);
          output.writeByte(ObjectStreamConstants.TC_OBJECT);
          output.writeByte(ObjectStreamConstants.TC_CLASSDESC);
          output.writeUTF(JCEElGamalPrivateKey.class.getName());
          output.writeLong(ObjectStreamClass.lookup(JCEElGamalPrivateKey.class).getSerialVersionUID());
          output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);
          output.writeShort(0);
          output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);
          output.writeByte(ObjectStreamConstants.TC_NULL);
          output.write(serializedObjectPayload(X));
          output.write(serializedObjectPayload(P));
          output.write(serializedObjectPayload(G));
          output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);
          return serialized.toByteArray();
      }
  
      private static byte[] serializedObjectPayload(Object value) throws IOException {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(value);
          }
          byte[] stream = serialized.toByteArray();
          return Arrays.copyOfRange(stream, 4, stream.length);
      }
  
      private static byte[] serialize(ElGamalPrivateKey privateKey) throws IOException {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(privateKey);
          }
          return serialized.toByteArray();
      }
  
      private static JCEElGamalPrivateKey deserialize(byte[] serialized) throws IOException, ClassNotFoundException {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (JCEElGamalPrivateKey)objectInputStream.readObject();
          }
      }
  }
