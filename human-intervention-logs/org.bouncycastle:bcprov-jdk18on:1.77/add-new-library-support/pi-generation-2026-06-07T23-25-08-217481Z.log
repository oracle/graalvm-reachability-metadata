\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPrivateKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;\nimport org.bouncycastle.jce.interfaces.ElGamalPrivateKey;\nimport org.bouncycastle.jce.interfaces.PKCS12BagAttributeCarrier;\nimport org.bouncycastle.util.CollectionStore;\nimport org.bouncycastle.util.Selector;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.Collection;\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCElGamalPrivateKeyTest {\n    private static final BigInteger P = new BigInteger(\"104729\");\n    private static final BigInteger G = new BigInteger(\"2\");\n    private static final BigInteger X = new BigInteger(\"12345\");\n    private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = new ASN1ObjectIdentifier(\"1.2.840.113549.1.9.20\");\n\n    @Test\n    void serializesAndRestoresElGamalPrivateKeyParameters() throws Exception {\n        ElGamalPrivateKey original = newBcElGamalPrivateKey();\n        ((PKCS12BagAttributeCarrier)original).setBagAttribute(FRIENDLY_NAME_OID, new DERUTF8String(\"elgamal-key\"));\n\n        ElGamalPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static ElGamalPrivateKey newBcElGamalPrivateKey() throws Exception {\n        AlgorithmIdentifier algorithm = new AlgorithmIdentifier(\n                OIWObjectIdentifiers.elGamalAlgorithm,\n                new ElGamalParameter(P, G));\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithm, new ASN1Integer(X));\n\n        return (ElGamalPrivateKey)new KeyFactorySpi().generatePrivate(privateKeyInfo);\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(ElGamalPrivateKey original, ElGamalPrivateKey restored) {\n        assertThat(original).isInstanceOf(BCElGamalPrivateKey.class);\n        assertThat(restored).isInstanceOf(BCElGamalPrivateKey.class);\n        assertThat(restored.getX()).isEqualTo(X).isEqualTo(original.getX());\n        assertThat(restored.getParameters().getP()).isEqualTo(P).isEqualTo(original.getParameters().getP());\n        assertThat(restored.getParameters().getG()).isEqualTo(G).isEqualTo(original.getParameters().getG());\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n        PKCS12BagAttributeCarrier restoredBagAttributes = (PKCS12BagAttributeCarrier)restored;\n        assertThat(restoredBagAttributes.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static ElGamalPrivateKey serializeAndDeserializeFromBouncyCastleFrame(ElGamalPrivateKey privateKey) {\n        CollectionStore<ElGamalPrivateKey> store = new CollectionStore<>(List.of(privateKey));\n        AtomicReference<ElGamalPrivateKey> restored = new AtomicReference<>();\n\n        Collection<ElGamalPrivateKey> matches = store.getMatches(new Selector<>() {\n            @Override\n            public boolean match(ElGamalPrivateKey key) {\n                try {\n                    restored.set(deserialize(serialize(key)));\n                    return true;\n                }\n                catch (Exception e) {\n                    throw new IllegalStateException(\"ElGamal private key serialization failed\", e);\n                }\n            }\n\n            @Override\n            public Object clone() {\n                return this;\n   