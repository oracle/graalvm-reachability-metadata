          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (JCEElGamalPrivateKey)objectInputStream.readObject();
          }
      }
  
      private static final class TrackingObjectInputStream extends ObjectInputStream {
          private final List<BigInteger> resolvedBigIntegers = new ArrayList<>();
  
          private TrackingObjectInputStream(byte[] serialized) throws IOException {
              super(new ByteArrayInputStream(serialized));
              enableResolveObject(true);
          }
  
          private JCEElGamalPrivateKey readJceElGamalPrivateKey() throws IOException, ClassNotFoundException {
              return (JCEElGamalPrivateKey)readObject();
          }
  
          private List<BigInteger> resolvedBigIntegers() {
              return resolvedBigIntegers;
          }
  
          @Override
          protected Object resolveObject(Object obj) throws IOException {
              if (obj instanceof BigInteger) {
                  resolvedBigIntegers.add((BigInteger)obj);
              }
              return super.resolveObject(obj);
          }
      }
  
      private static final class TrackingObjectOutputStream extends ObjectOutputStream {
          private final ByteArrayOutputStream serialized;
          private final List<BigInteger> replacedBigIntegers = new ArrayList<>();
  
          private TrackingObjectOutputStream() throws IOException {
              this(new ByteArrayOutputStream());
          }
  
          private TrackingObjectOutputStream(ByteArrayOutputStream serialized) throws IOException {
              super(serialized);
              this.serialized = serialized;
              enableReplaceObject(true);
          }
  
          private List<BigInteger> replacedBigIntegers() {
              return replacedBigIntegers;
          }
  
          private byte[] toByteArray() {
              return serialized.toByteArray();
          }
  
          @Override
          protected Object replaceObject(Object obj) throws IOException {
              if (obj instanceof BigInteger) {
                  replacedBigIntegers.add((BigInteger)obj);
              }
              return super.replaceObject(obj);
          }
      }
  }
