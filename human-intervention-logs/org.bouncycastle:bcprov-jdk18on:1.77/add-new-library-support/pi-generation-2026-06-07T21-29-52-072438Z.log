lder);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static GostPublicKeyHolder deserializeHolder(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (GostPublicKeyHolder)objectInputStream.readObject();\n        }\n    }\n\n    private static BCGOST3410PublicKey deserializeWithTracking("}, {"oldText": "    private static final class TrackingObjectOutputStream extends ObjectOutputStream {", "newText": "    private static final class GostPublicKeyHolder implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String label;\n        private final BCGOST3410PublicKey publicKey;\n\n        private GostPublicKeyHolder(String label, BCGOST3410PublicKey publicKey) {\n            this.label = label;\n            this.publicKey = publicKey;\n        }\n    }\n\n    private static final class TrackingObjectOutputStream extends ObjectOutputStream {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 648, "output": 2180, "cacheRead": 44544, "cacheWrite": 0, "totalTokens": 47372, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780868170299, "responseId": "resp_03dab8d6da908998016a25e44b24208197a0b91d22b26fdea2"}}
