ryptoProObjectIdentifiers;\nimport org.bouncycastle.asn1.cryptopro.GOST3410NamedParameters;\nimport org.bouncycastle.asn1.cryptopro.GOST3410ParamSetParameters;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PublicKey;\nimport org.bouncycastle.jce.interfaces.GOST3410PublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.bouncycastle.jce.spec.GOST3410PublicKeySpec;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.KeyPairGenerator;\nimport java.security.PublicKey;\nimport java.security.SecureRandom;\nimport java.util.LinkedHashSet;\nimport java.util.Set;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCGOST3410PublicKeyTest {\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"12345678901234567890\");\n\n    @Test\n    void serializesAndRestoresProviderGeneratedGostPublicKey() throws Exception {\n        GOST3410PublicKey original = newGostPublicKey();\n\n        GOST3410PublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void serializesAndRestoresGostPublicKeyWithExplicitParameters() throws Exception {\n        GOST3410PublicKey original = newGostPublicKeyWithExplicitParameters();\n\n        GOST3410PublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void customSerializationWritesAndReadsGostParameterObjects() throws Exception {\n        GOST3410PublicKey original = newGostPublicKeyWithExplicitParameters();\n        TrackingObjectOutputStream serialized = new TrackingObjectOutputStream();\n\n        serialized.writeObject(original);\n        serialized.close();\n        GOST3410PublicKey restored = deserializeWithTracking(serialized.toByteArray());\n\n        GOST3410ParamSetParameters parameters = GOST3410NamedParameters.getByOID(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A);\n        assertThat(serialized.replacedObjects()).contains(\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA(),\n                CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static GOST3410PublicKey newGostPublicKey() throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        keyPairGenerator.initialize(\n                new GOST3410ParameterSpec(CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId()),\n                new SecureRandom(new byte[] {\n                        1, 2, 3, 4, 5\n                }));\n\n        return (GOST3410PublicKey)keyPairGenerator.generateKeyPair().getPublic();\n    }\n\n    private static GOST3410PublicKey newGostPublicKeyWithExplicitParameters() throws Exception {\n        GOST3410ParamSetParameters parameters = GOST3410NamedParameters.getByOID(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A);\n        BigInteger publicValue = parameters.getA().modPow(PRIVATE_VALUE, parameters.getP());\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        PublicKey publicKey = keyFactory.generatePublic(new GOST3410PublicKeySpec(\n                publicValue,\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA()));\n\n        return (GOST3410PublicKey)publicKey;\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(\n            GOST3410PublicKey original,\n            GOST3410PublicKey restored) {\n        assertThat(original).isInstanceOf(BCGOST3410PublicKey.class);\n        assertThat(restored).isInstanceOf(BCGOST3410PublicKey.class);\n        assertThat(restored.getY()).isEqualTo(original.getY());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        if (restored.getParameters().getPublicKeyParamSetOID() != null) {\n            assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        }\n        assertThat(restored.getParameters().getPublicKeyParamSetOID())\n                .isEqualTo(original.getParameters().getPublicKeyParamSetOID());\n        assertThat(restored.getParameters().getDigestParamSetOID())\n                .isEqualTo(original.getParameters().getDigestParamSetOID());\n        assertThat(restored.getParameters().getEncryptionParamSetOID())\n                .isEqualTo(original.getParameters().getEncryptionParamSetOID());\n        assertThat(restored.getParameters().getPublicKeyParameters())\n                .isEqualTo(original.getParameters().getPublicKeyParameters());\n    }\n\n    private static byte[] serialize(GOST3410PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static GOST3410PublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (GOST3410PublicKey)objectInputStream.readObject();\n        }\n    }\n\n    private static GOST3410PublicKey deserializeWithTracking(byte[] serialized) throws Exception {\n        try (TrackingObjectInputStream objectInputStream = new TrackingObjectInputStream(serialized)) {\n            GOST3410PublicKey restored = (GOST3410PublicKey)objectInputStream.readObject();\n            GOST3410ParamSetParameters parameters = GOST3410NamedParameters.getByOID(\n                    CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A);\n            assertThat(objectInputStream.resolvedObjects()).contains(\n                    parameters.getP(),\n                    parameters.getQ(),\n                    parameters.getA(),\n                    CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n            return restored;\n        }\n    }\n\n    private static final class TrackingObjectOutputStream extends ObjectOutputStream {\n        private final ByteArrayOutputStream serialized;\n        private final Set<Object> replacedObjects = new LinkedHashSet<>();\n\n        private TrackingObjectOutputStream() throws Exception {\n            this(new ByteArrayOutputStream());\n        }\n\n        private TrackingObjectOutputStream(ByteArrayOutputStream serialized) throws Exception {\n            super(serialized);\n            this.serialized = serialized;\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) {\n            replacedObjects.add(object);\n            return object;\n        }\n\n        private byte[] toByteArray() {\n            return serialized.toByteArray();\n        }\n\n        private Set<Object> replacedObjects() {\n            return replacedObjects;\n        }\n    }\n\n    private static final class TrackingObjectInputStream extends ObjectInputStream {\n        private final Set<Object> resolvedObjects = new LinkedHashSet<>();\n\n        private TrackingObjectInputStream(byte[] serialized) throws Exception {\n            super(new ByteArrayInputStream(serialized));\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) {\n            resolvedObjects.add(object);\n            return object;\n        }\n\n        private Set<Object> resolvedObjects() {\n            return resolvedObjects;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780867915472}]}
