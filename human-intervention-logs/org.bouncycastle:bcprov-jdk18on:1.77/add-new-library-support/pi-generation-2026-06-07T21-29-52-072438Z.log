InputStream(new ByteArrayInputStream(serialized))) {\n            return (BCGOST3410PublicKey)objectInputStream.readObject();\n        }\n    }\n\n    private static byte[] serializeUnshared(BCGOST3410PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeUnshared(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static BCGOST3410PublicKey deserializeUnshared(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (BCGOST3410PublicKey)objectInputStream.readUnshared();\n        }\n    }\n\n    private static byte[] serializeHolder(GostPublicKeyHolder holder) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(holder);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static GostPublicKeyHolder deserializeHolder(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (GostPublicKeyHolder)objectInputStream.readObject();\n        }\n    }\n\n    private static BCGOST3410PublicKey deserializeWithTracking("},{"oldText":"    private static final class TrackingObjectOutputStream extends ObjectOutputStream {","newText":"    private static final class GostPublicKeyHolder implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String label;\n        private final BCGOST3410PublicKey publicKey;\n\n        private GostPublicKeyHolder(String label, BCGOST3410PublicKey publicKey) {\n            this.label = label;\n            this.publicKey = publicKey;\n        }\n    }\n\n    private static final class TrackingObjectOutputStream extends ObjectOutputStream {"}]}
