  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  import java.security.Provider;
  import java.security.Security;
  
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.x509.X509StreamParser;
  import org.junit.jupiter.api.Test;
  
  public class X509UtilTest {
      private static final String OBJECT_CLASS_NAME = Object.class.getName();
  
      @Test
      void loadsConfiguredImplementationWithProviderClassLoader() {
          Provider provider = new BouncyCastleProvider();
          provider.put("X509StreamParser.TESTOBJECT", OBJECT_CLASS_NAME);
  
          assertThatThrownBy(() -> X509StreamParser.getInstance("TESTOBJECT", provider))
              .isInstanceOf(ClassCastException.class);
      }
  
      @Test
      void loadsConfiguredImplementationWithClassForNameForBootstrapProvider() {
          Provider provider = findBootstrapLoadedProvider();
          String key = "X509StreamParser.TESTOBJECT";
          Object previousValue = provider.put(key, OBJECT_CLASS_NAME);
  
          try {
              assertThatThrownBy(() -> X509StreamParser.getInstance("TESTOBJECT", provider))
                  .isInstanceOf(ClassCastException.class);
          } finally {
              if (previousValue == null) {
                  provider.remove(key);
              } else {
                  provider.put(key, previousValue);
              }
          }
      }
  
      private static Provider findBootstrapLoadedProvider() {
          Provider[] providers = Security.getProviders();
          for (Provider provider : providers) {
              if (provider.getClass().getClassLoader() == null) {
                  return provider;
              }
          }
          throw new AssertionError("Expected a JDK provider loaded by the bootstrap class loader");
      }
  }
