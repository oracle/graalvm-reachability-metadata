[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JournaledAlgorithmTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.SecureRandom;\n\nimport org.bouncycastle.asn1.nist.NISTObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.crypto.util.JournaledAlgorithm;\nimport org.bouncycastle.crypto.util.JournalingSecureRandom;\nimport org.junit.jupiter.api.Test;\n\npublic class JournaledAlgorithmTest {\n    @Test\n    void serializesAndRestoresJournaledAlgorithmState() throws Exception {\n        JournalingSecureRandom journalingSecureRandom = new JournalingSecureRandom(new SecureRandom());\n        byte[] originalRandom = new byte[32];\n        journalingSecureRandom.nextBytes(originalRandom);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(NISTObjectIdentifiers.id_aes128_CBC);\n        JournaledAlgorithm original = new JournaledAlgorithm(algorithmIdentifier, journalingSecureRandom);\n\n        byte[] serialized = serialize(original);\n        JournaledAlgorithm restored = deserialize(serialized);\n\n        byte[] replayedRandom = new byte[originalRandom.length];\n        restored.getJournalingSecureRandom().nextBytes(replayedRandom);\n        assertThat(replayedRandom).isEqualTo(originalRandom);\n        assertThat(restored.getAlgorithmIdentifier()).isEqualTo(algorithmIdentifier);\n    }\n\n    private static byte[] serialize(JournaledAlgorithm journaledAlgorithm) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(serialized)) {\n            outputStream.writeObject(journaledAlgorithm);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JournaledAlgorithm deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JournaledAlgorithm)inputStream.readObject();\n        }\n    }\n}\n"}
