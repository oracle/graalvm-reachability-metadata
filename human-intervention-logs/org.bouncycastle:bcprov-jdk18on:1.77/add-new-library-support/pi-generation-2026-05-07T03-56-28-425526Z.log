      public String getAlgorithm()
      {
          return algorithm;
      }
  
      public String getFormat()
      {
          return "X.509";
      }
  
      public byte[] getEncoded()
      {
          ASN1Encodable        params;
          SubjectPublicKeyInfo info;
  
