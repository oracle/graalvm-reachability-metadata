      private void extractBytes(byte[] encKey, int offSet, BigInteger bI)
      {
          byte[] val = bI.toByteArray();
          if (val.length < 32)
          {
              byte[] tmp = new byte[32];
              System.arraycopy(val, 0, tmp, tmp.length - val.length, val.length);
              val = tmp;
          }
  
          for (int i = 0; i != 32; i++)
          {
              encKey[offSet + i] = val[val.length - 1 - i];
          }
      }
  
