nimport java.math.BigInteger;\nimport java.security.spec.ECFieldFp;\nimport java.security.spec.ECParameterSpec;\nimport java.security.spec.ECPoint;\nimport java.security.spec.ECPublicKeySpec;\nimport java.security.spec.EllipticCurve;\n\nimport org.bouncycastle.jce.provider.JCEECPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class JCEECPublicKeyTest {\n    private static final BigInteger PUBLIC_X = new BigInteger(\n            \"6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296\",\n            16);\n    private static final BigInteger PUBLIC_Y = new BigInteger(\n            \"4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5\",\n            16);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedEcPublicKey() throws Throwable {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        JCEECPublicKey publicKey = createPublicKey(parameters);\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        invokeWriteObject(publicKey, outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(publicKey.getEncoded(), \"EC\");\n        assertThat(outputStream.writtenBoolean()).isTrue();\n\n        JCEECPublicKey restored = createPublicKey(parameters);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                outputStream.writtenObjects(),\n                outputStream.writtenBoolean());\n\n        invokeReadObject(restored, inputStream);\n\n        assertPublicKey(restored, publicKey, parameters);\n    }\n\n    private static JCEECPublicKey createPublicKey(ECParameterSpec parameters) {\n        JCEECPublicKey publicKey = new JCEECPublicKey(\n                \"EC\",\n                new ECPublicKeySpec(new ECPoint(PUBLIC_X, PUBLIC_Y), parameters));\n        publicKey.setPointFormat(\"COMPRESSED\");\n        return publicKey;\n    }\n\n    private static void assertPublicKey(\n            JCEECPublicKey restored,\n            JCEECPublicKey publicKey,\n            ECParameterSpec parameters) {\n        assertThat(restored).isExactlyInstanceOf(JCEECPublicKey.class);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getW()).isEqualTo(new ECPoint(PUBLIC_X, PUBLIC_Y));\n        assertThat(restored.getQ()).isEqualTo(publicKey.getQ());\n        assertThat(restored.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertParameterSpec(restored.getParams(), parameters);\n    }\n\n    private static void invokeWriteObject(JCEECPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {\n        WRITE_OBJECT.invokeExact(publicKey, outputStream);\n    }\n\n    private static void invokeReadObject(JCEECPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(publicKey, inputStream);\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JCEECPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JCEECPublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JCEECPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JCEECPublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static void assertParameterSpec(ECParameterSpec actual, ECParameterSpec expected) {\n        assertThat(actual.getOrder()).isEqualTo(expected.getOrder());\n        assertThat(actual.getGenerator()).isEqualTo(expected.getGenerator());\n        assertThat(actual.getCofactor()).isEqualTo(expected.getCofactor());\n        assertThat(actual.getCurve().getField()).isEqualTo(expected.getCurve().getField());\n        assertThat(actual.getCurve().getA()).isEqualTo(expected.getCurve().getA());\n        assertThat(actual.getCurve().getB()).isEqualTo(expected.getCurve().getB());\n    }\n\n    private static ECParameterSpec createSecp256r1Parameters() {\n        BigInteger p = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF\", 16);\n        BigInteger a = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC\", 16);\n        BigInteger b = new BigInteger(\"5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B\", 16);\n        BigInteger n = new BigInteger(\"FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551\", 16);\n\n        return new ECParameterSpec(\n                new EllipticCurve(new ECFieldFp(p), a, b),\n                new ECPoint(PUBLIC_X, PUBLIC_Y),\n                n,\n                1);\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final Object[] objects = new Object[2];\n        private int objectCount;\n        private boolean booleanValue;\n\n        private RecordingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects[objectCount] = object;\n            objectCount++;\n       