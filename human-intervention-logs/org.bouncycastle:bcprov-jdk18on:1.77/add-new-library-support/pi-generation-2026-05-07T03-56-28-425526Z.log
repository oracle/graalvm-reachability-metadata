y createPublicKey(ECParameterSpec parameters) {\n        return new BCECPublicKey(\n                \"EC\",\n                new ECPublicKeySpec(new ECPoint(PUBLIC_X, PUBLIC_Y), parameters),\n                BouncyCastleProvider.CONFIGURATION);\n    }\n\n    private static byte[] readSerializedObject(byte[] serializedObject) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serializedObject))) {\n            return (byte[])inputStream.readObject();\n        }\n    }\n\n    private static void invokeWriteObject(BCECPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {\n        WRITE_OBJECT.invokeExact(publicKey, outputStream);\n    }\n\n    private static void invokeReadObject(BCECPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(publicKey, inputStream);\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCECPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCECPublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCECPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCECPublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    pr