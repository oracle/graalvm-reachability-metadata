  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.OutputStream;
  import java.io.Serializable;
  import java.math.BigInteger;
  import java.security.spec.ECFieldFp;
  import java.security.spec.ECParameterSpec;
  import java.security.spec.ECPoint;
  import java.security.spec.ECPrivateKeySpec;
  import java.security.spec.EllipticCurve;
  import java.util.Base64;
  
  import org.bouncycastle.jce.provider.JCEECPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class JCEECPrivateKeyTest {
      private static final BigInteger PRIVATE_VALUE = new BigInteger(
              "0102030405060708090A0B0C0D0E0F101112131415161718191A1B1C1D1E1F20",
              16);
  
      @Test
      public void javaSerializationRoundTripRestoresEcPrivateKey() throws Exception {
          ECParameterSpec parameters = createSecp256r1Parameters();
          JCEECPrivateKey privateKey = createPrivateKey(parameters);
  
          JCEECPrivateKey restored = roundTrip(privateKey);
  
          assertPrivateKey(restored, privateKey, parameters);
      }
  
      @Test
      public void serializationHooksWriteAndReadObjectPayloads() throws Exception {
          ECParameterSpec parameters = createSecp256r1Parameters();
          JCEECPrivateKey privateKey = createPrivateKey(parameters);
  
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          TransformingObjectOutputStream outputStream = new TransformingObjectOutputStream(bytes);
          try (outputStream) {
              outputStream.writeObject(privateKey);
          }
  
          assertThat(outputStream.encodedKeyWasReplaced()).isTrue();
  
          JCEECPrivateKey restored;
          ResolvingObjectInputStream inputStream = new ResolvingObjectInputStream(bytes.toByteArray());
          try (inputStream) {
              restored = (JCEECPrivateKey) inputStream.readObject();
          }
  
          assertThat(inputStream.encodedKeyWasResolved()).isTrue();
          assertPrivateKey(restored, privateKey, parameters);
      }
  
      private static JCEECPrivateKey createPrivateKey(ECParameterSpec parameters) {
          JCEECPrivateKey privateKey = new JCEECPrivateKey(
                  "EC",
                  new ECPrivateKeySpec(PRIVATE_VALUE, parameters));
          privateKey.setPointFormat("COMPRESSED");
          return privateKey;
      }
  
      private static void assertPrivateKey(
              JCEECPrivateKey restored,
              JCEECPrivateKey privateKey,
              ECParameterSpec parameters) {
          assertThat(restored).isExactlyInstanceOf(JCEECPrivateKey.class);
          assertThat(restored.getAlgorithm()).isEqualTo("EC");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getD()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertParameterSpec(restored.getParams(), parameters);
      }
  
      private static JCEECPrivateKey roundTrip(JCEECPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {
              outputStream.writeObject(privateKey);
          }
  
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return (JCEECPrivateKey) inputStream.readObject();
          }
      }
  
      private static void assertParameterSpec(ECParameterSpec actual, ECParameterSpec expected) {
          assertThat(actual.getOrder()).isEqualTo(expected.getOrder());
          assertThat(actual.getGenerator()).isEqualTo(expected.getGenerator());
          assertThat(actual.getCofactor()).isEqualTo(expected.getCofactor());
          assertThat(actual.getCurve().getField()).isEqualTo(expected.getCurve().getField());
          assertThat(actual.getCurve().getA()).isEqualTo(expected.getCurve().getA());
          assertThat(actual.getCurve().getB()).isEqualTo(expected.getCurve().getB());
      }
  
      private static final class TransformingObjectOutputStream extends ObjectOutputStream {
          private boolean encodedKeyWasReplaced;
  
          private TransformingObjectOutputStream(OutputStream outputStream) throws IOException {
              super(outputStream);
              enableReplaceObject(true);
          }
  
          private boolean encodedKeyWasReplaced() {
              return encodedKeyWasReplaced;
          }
  
          @Override
          protected Object replaceObject(Object object) {
              if (object instanceof byte[]) {
                  encodedKeyWasReplaced = true;
                  return new EncodedKey((byte[]) object);
              }
              return object;
          }
      }
  
      private static final class ResolvingObjectInputStream extends ObjectInputStream {
          private boolean encodedKeyWasResolved;
  
          private ResolvingObjectInputStream(byte[] bytes) throws IOException {
              super(new ByteArrayInputStream(bytes));
              enableResolveObject(true);
          }
  
          private boolean encodedKeyWasResolved() {
              return encodedKeyWasResolved;
          }
  
          @Override
          protected Object resolveObject(Object object) {
              if (object instanceof EncodedKey) {
                  encodedKeyWasResolved = true;
                  return ((EncodedKey) object).encoded();
              }
              return object;
          }
      }
  
      private static final class EncodedKey implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String encoded;
  
          private EncodedKey(byte[] encoded) {
              this.encoded = Base64.getEncoder().encodeToString(encoded);
          }
  
          private byte[] encoded() {
              return Base64.getDecoder().decode(encoded);
          }
      }
  
      private static ECParameterSpec createSecp256r1Parameters() {
          BigInteger p = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF", 16);
          BigInteger a = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC", 16);
          BigInteger b = new BigInteger("5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B", 16);
          BigInteger gx = new BigInteger("6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296", 16);
          BigInteger gy = new BigInteger("4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5", 16);
          BigInteger n = new BigInteger("FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551", 16);
  
          return new ECParameterSpec(
                  new EllipticCurve(new ECFieldFp(p), a, b),
                  new ECPoint(gx, gy),
                  n,
                  1);
      }
  }
