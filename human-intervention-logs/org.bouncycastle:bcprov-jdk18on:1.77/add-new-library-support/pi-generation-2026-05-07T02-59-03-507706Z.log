  import org.junit.jupiter.api.Test;
  
  public class BCElGamalPublicKeyTest {
      private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);
      private static final BigInteger G = TrackedBigInteger.trackedValueOf(5L);
      private static final BigInteger Y = BigInteger.valueOf(8L);
      private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);
      private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(2L);
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void javaSerializationRoundTripsElGamalPublicKeyParameters() throws Exception {
          BCElGamalPublicKey original = createPublicKey(P, G, Y);
  
          BCElGamalPublicKey restored = deserialize(serialize(original), BCElGamalPublicKey.class);
          ElGamalParameterSpec restoredParameters = restored.getParameters();
  
          assertThat(restored).isNotSameAs(original);
          assertThat(restored).isEqualTo(original);
          assertThat(restored.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(Y);
          assertThat(restoredParameters.getP()).isEqualTo(P);
          assertThat(restoredParameters.getG()).isEqualTo(G);
          assertThat(restored.getParams().getP()).isEqualTo(P);
          assertThat(restored.getParams().getG()).isEqualTo(G);
          assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());
      }
  
      @Test
      public void serializationHooksWriteAndRestoreElGamalPublicKeyParameters() throws Throwable {
          BCElGamalPublicKey original = createPublicKey(P, G, Y);
          byte[] writtenParameters = invokeWriteObject(original);
  
          assertThat(readObjects(writtenParameters)).containsExactly(P, G);
  
          BCElGamalPublicKey restored = createPublicKey(P, G, Y);
          byte[] restoredParameterStream = writeObjects(RESTORED_P, RESTORED_G);
  
          try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {
              invokeReadObject(restored, inputStream);
          }
          ElGamalParameterSpec restoredParameters = restored.getParameters();
  
          assertThat(restored.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(Y);
          assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);
          assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);
          assertThat(restored.getParams().getP()).isEqualTo(RESTORED_P);
          assertThat(restored.getParams().getG()).isEqualTo(RESTORED_G);
      }
  
      private static BCElGamalPublicKey createPublicKey(BigInteger p, BigInteger g, BigInteger y)
              throws GeneralSecurityException {
          DHPublicKeySpec keySpec = new DHPublicKeySpec(y, p, g);
          KeyFactory keyFactory = KeyFactory.getInstance("ElGamal", new BouncyCastleProvider());
  
          return (BCElGamalPublicKey)keyFactory.generatePublic(keySpec);
      }
  
      private static byte[] serialize(Object object) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(object);
          }
          return output.toByteArray();
      }
  
      private static byte[] invokeWriteObject(BCElGamalPublicKey publicKey) throws Throwable {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {
              WRITE_OBJECT.invokeExact(publicKey, outputStream);
          }
          return output.toByteArray();
      }
  
      private static void invokeReadObject(BCElGamalPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {
          READ_OBJECT.invokeExact(publicKey, inputStream);
      }
  
      private static byte[] writeObjects(Object firstObject, Object secondObject) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(firstObject);
              outputStream.writeObject(secondObject);
          }
          return output.toByteArray();
      }
  
      private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {
  
