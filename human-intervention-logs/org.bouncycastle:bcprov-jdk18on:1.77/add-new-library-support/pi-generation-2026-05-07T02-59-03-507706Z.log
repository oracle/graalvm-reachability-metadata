stle/bcprov-jdk18on/index.json:8:    \"documentation-url\" : \"https://repo.maven.apache.org/maven2/org/bouncycastle/bcprov-jdk18on/$version$/bcprov-jdk18on-$version$-javadoc.jar\",\n./metadata/org.bouncycastle/bcprov-jdk18on/index.json:9:    \"description\" : \"Bouncy Castle Provider is a Java cryptography provider and lightweight API implementation for JDK 1.8 and later. It supplies algorithms, encodings, key management, signatures, ciphers, message digests, and related primitives through Bouncy Castle APIs and the JCA/JCE provider interfaces.\",\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:5:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:17:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:29:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:41:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:53:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:65:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:77:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:89:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:101:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/or