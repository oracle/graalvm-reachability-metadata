  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.cmce.CMCEParameters;
  import org.bouncycastle.pqc.crypto.cmce.CMCEPublicKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.cmce.BCCMCEPublicKey;
  import org.bouncycastle.pqc.jcajce.spec.CMCEParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCCMCEPublicKeyTest {
      private static final int MCELIECE_348864_PUBLIC_KEY_SIZE = 261_120;
  
      @Test
      public void objectSerializationWritesAndReadsEncodedCmcePublicKey() throws Exception {
          BCCMCEPublicKey publicKey = newCmcePublicKey();
  
          Object restoredObject = readObject(writeObject(publicKey));
  
          assertThat(restoredObject).isInstanceOf(BCCMCEPublicKey.class);
          BCCMCEPublicKey restored = (BCCMCEPublicKey)restoredObject;
          assertThat(restored).isNotSameAs(publicKey);
          assertCmcePublicKey(restored, publicKey);
      }
  
      private static BCCMCEPublicKey newCmcePublicKey() {
          byte[] publicKey = filledBytes(MCELIECE_348864_PUBLIC_KEY_SIZE, 0x51);
          CMCEPublicKeyParameters keyParameters = new CMCEPublicKeyParameters(
                  CMCEParameters.mceliece348864r3,
                  publicKey);
          return new BCCMCEPublicKey(keyParameters);
      }
  
      private static byte[] filledBytes(int length, int firstValue) {
          byte[] bytes = new byte[length];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte)(firstValue + index);
          }
          return bytes;
      }
  
      private static void assertCmcePublicKey(BCCMCEPublicKey actual, BCCMCEPublicKey expected) {
          assertThat(actual.getAlgorithm()).isEqualTo("MCELIECE348864");
          assertThat(actual.getFormat()).isEqualTo("X.509");
          assertThat(actual.getParameterSpec()).isSameAs(CMCEParameterSpec.mceliece348864);
          assertThat(actual).isEqualTo(expected);
          assertThat(actual.hashCode()).isEqualTo(expected.hashCode());
          assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());
      }
  
      private static byte[] writeObject(Object object) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(object);
          }
          return output.toByteArray();
      }
  
      private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return inputStream.readObject();
          }
