          ECParameterSpec parameters = createSecp256r1Parameters();
          BCECPrivateKey privateKey = createPrivateKey(PRIVATE_VALUE, parameters);
          byte[] writtenObjectStream = invokeWriteObject(privateKey);
  
          byte[] encoded = privateKey.getEncoded();
          EncodedKey writtenKey = (EncodedKey)readObject(writtenObjectStream);
          assertThat(writtenKey.encoded()).isEqualTo(encoded);
  
          BCECPrivateKey restored = createPrivateKey(REPLACED_PRIVATE_VALUE, parameters);
          byte[] encodedObjectStream = writeObject(new EncodedKey(encoded));
  
          try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(encodedObjectStream)) {
              READ_OBJECT.invokeExact(restored, inputStream);
          }
  
          assertThat(restored.getAlgorithm()).isEqualTo("EC");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getEncoded()).isEqualTo(encoded);
          assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());
          assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());
      }
  
      private static BCECPrivateKey createPrivateKey(BigInteger privateValue, ECParameterSpec parameters) throws Exception {
          return new BCECPrivateKey(
                  "EC",
                  new ECPrivateKeySpec(privateValue, parameters),
                  BouncyCastleProvider.CONFIGURATION);
      }
  
      private static byte[] invokeWriteObject(BCECPrivateKey privateKey) throws Throwable {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {
              WRITE_OBJECT.invokeExact(privateKey, outputStream);
          }
          return output.toByteArray();
      }
  
      private static byte[] writeObject(Object object) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(object);
          }
          return output.toByteArray();
      }
  
      private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return inputStream.readObject();
          }
      }
  
      private static BCECPrivateKey roundTrip(BCECPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(privateKey);
          }
  
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {
              return (BCECPrivateKey)inputStream.readObject();
          }
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCECPrivateKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECPrivateKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCECPrivateKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECPrivateKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static ECParameterSpec createSecp256r1Parameters() {
          BigInteger p = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF", 16);
          BigInteger a = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC", 16);
          BigInteger b = new BigInteger("5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B", 16);
          BigInteger gx = new BigInteger("6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296", 16);
          BigInteger gy = new BigInteger("4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5", 16);
          BigInteger n = new BigInteger("FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551", 16);
  
          return new ECParameterSpec(
                  new EllipticCurve(new ECFieldFp(p), a, b),
                  new ECPoint(gx, gy),
                  n,
                  1);
      }
  
      private static final class NoDefaultWriteObjectOutputStream extends ObjectOutputStream {
          private NoDefaultWriteObjectOutputStream(OutputStream outputStream) throws IOException {
              super(outputStream);
              enableReplaceObject(true);
          }
  
          @Override
          public void defaultWriteObject() {
          }
  
          @Override
          protected Object replaceObject(Object object) {
              if (object instanceof byte[]) {
                  return new EncodedKey((byte[])object);
              }
              return object;
          }
      }
  
      private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {
          private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {
              super(new ByteArrayInputStream(bytes));
              enableResolveObject(true);
          }
  
