  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Provider;
  import java.security.spec.InvalidKeySpecException;
  import java.security.spec.KeySpec;
  
  import javax.crypto.SecretKey;
  import javax.crypto.SecretKeyFactory;
  import javax.crypto.spec.SecretKeySpec;
  
  import org.bouncycastle.jcajce.provider.symmetric.AES;
  import org.bouncycastle.jcajce.spec.RawEncodedKeySpec;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class BaseSecretKeyFactoryTest {
      private static final byte[] AES_KEY = {
          0x00, 0x01, 0x02, 0x03,
          0x04, 0x05, 0x06, 0x07,
          0x08, 0x09, 0x0a, 0x0b,
          0x0c, 0x0d, 0x0e, 0x0f
      };
  
      @Test
      public void getKeySpecConstructsCustomKeySpecFromEncodedSecretKey() throws Exception {
          Provider provider = new BouncyCastleProvider();
          SecretKeyFactory keyFactory = SecretKeyFactory.getInstance("AES", provider);
          SecretKeySpec secretKey = new SecretKeySpec(AES_KEY, "AES");
  
          RawEncodedKeySpec keySpec = (RawEncodedKeySpec)keyFactory.getKeySpec(secretKey, RawEncodedKeySpec.class);
  
          assertRawEncodedKeySpec(keySpec);
      }
  
      @Test
      public void inheritedEngineGetKeySpecConstructsRawEncodedKeySpec() throws Exception {
          AccessibleAesSecretKeyFactory keyFactory = new AccessibleAesSecretKeyFactory();
          SecretKeySpec secretKey = new SecretKeySpec(AES_KEY, "AES");
  
          RawEncodedKeySpec keySpec = (RawEncodedKeySpec)keyFactory.getKeySpec(secretKey, RawEncodedKeySpec.class);
  
          assertRawEncodedKeySpec(keySpec);
      }
  
      private static void assertRawEncodedKeySpec(RawEncodedKeySpec keySpec) {
          assertThat(keySpec.getFormat()).isEqualTo("RAW");
          assertThat(keySpec.getEncoded()).isEqualTo(AES_KEY);
          assertThat(keySpec.getEncoded()).isNotSameAs(AES_KEY);
      }
  
      public static final class AccessibleAesSecretKeyFactory extends AES.KeyFactory {
          KeySpec getKeySpec(SecretKey key, Class<?> keySpec) throws InvalidKeySpecException {
              return engineGetKeySpec(key, keySpec);
          }
      }
  }
