[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BaseSecretKeyFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.security.Provider;\nimport java.security.spec.KeySpec;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.DESedeKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    private static final byte[] AES_192_KEY_BYTES = new byte[] {\n            0x00, 0x01, 0x02, 0x03,\n            0x04, 0x05, 0x06, 0x07,\n            0x08, 0x09, 0x0a, 0x0b,\n            0x0c, 0x0d, 0x0e, 0x0f,\n            0x10, 0x11, 0x12, 0x13,\n            0x14, 0x15, 0x16, 0x17\n    };\n\n    @Test\n    void returnsRequestedKeySpecConstructedFromSecretKeyBytes() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        SecretKeyFactory keyFactory = SecretKeyFactory.getInstance(\"AES\", provider);\n        SecretKey secretKey = new SecretKeySpec(AES_192_KEY_BYTES, \"AES\");\n\n        KeySpec keySpec = keyFactory.getKeySpec(secretKey, DESedeKeySpec.class);\n\n        assertThat(keyFactory.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n        assertThat(keySpec).isInstanceOf(DESedeKeySpec.class);\n        assertThat(((DESedeKeySpec)keySpec).getKey()).isEqualTo(AES_192_KEY_BYTES);\n    }\n}\n"}
[tool-call] end id=call_KMq1PRUOoMgFdFM6RSnYqwfR|fc_0e9e485520242b14016a25f04f23608196ade71b9c6e1ba988 name=write args={"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BaseSecretKeyFactoryTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.security.Provider;\nimport java.security.spec.KeySpec;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.DESedeKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    private static final byte[] AES_192_KEY_BYTES = new byte[] {\n            0x00, 0x01, 0x02, 0x03,\n            0x04, 0x05, 0x06, 0x07,\n            0x08, 0x09, 0x0a, 0x0b,\n            0x0c, 0x0d, 0x0e, 0x0f,\n            0x10, 0x11, 0x12, 0x13,\n            0x14, 0x15, 0x16, 0x17\n    };\n\n    @Test\n    void returnsRequestedKeySpecConstructedFromSecretKeyBytes() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        SecretKeyFactory keyFactory = SecretKeyFactory.getInstance(\"AES\", provider);\n        SecretKey secretKey = new SecretKeySpec(AES_192_KEY_BYTES, \"AES\");\n\n        KeySpec keySpec = keyFactory.getKeySpec(secretKey, DESedeKeySpec.class);\n\n        assertThat(keyFactory.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n        assertThat(keySpec).isInstanceOf(DESedeKeySpec.class);\n        assertThat(((DESedeKeySpec)keySpec).getKey()).isEqualTo(AES_192_KEY_BYTES);\n    }\n}\n"}
