  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jcajce.spec.AEADParameterSpec;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.parallel.ResourceLock;
  
  import java.nio.charset.StandardCharsets;
  import java.security.Security;
  
  import javax.crypto.AEADBadTagException;
  import javax.crypto.Cipher;
  import javax.crypto.spec.SecretKeySpec;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class BaseBlockCipherInnerAEADGenericBlockCipherTest {
      private static final String AES_GCM_TRANSFORMATION = "AES/GCM/NoPadding";
      private static final String GCM_CIPHER_ALGORITHM = "GCM";
      private static final byte[] KEY_BYTES = new byte[] {
              0x00, 0x01, 0x02, 0x03,
              0x04, 0x05, 0x06, 0x07,
              0x08, 0x09, 0x0a, 0x0b,
              0x0c, 0x0d, 0x0e, 0x0f
      };
      private static final byte[] NONCE = new byte[] {
              0x10, 0x11, 0x12, 0x13,
              0x14, 0x15, 0x16, 0x17,
              0x18, 0x19, 0x1a, 0x1b
      };
      private static final byte[] ASSOCIATED_DATA =
              "authenticated header".getBytes(StandardCharsets.UTF_8);
      private static final byte[] PLAINTEXT =
              "message requiring authentication".getBytes(StandardCharsets.UTF_8);
  
      @Test
      @ResourceLock("java.security.Security")
      void throwsAeadBadTagExceptionForTamperedAesGcmTransformationCiphertext()
              throws Exception {
          assertTamperedCiphertextRejected(AES_GCM_TRANSFORMATION);
      }
  
      @Test
      @ResourceLock("java.security.Security")
      void throwsAeadBadTagExceptionForTamperedDirectGcmCiphertext()
              throws Exception {
          assertTamperedCiphertextRejected(GCM_CIPHER_ALGORITHM);
      }
  
      private static void assertTamperedCiphertextRejected(String transformation) throws Exception {
          boolean addedProvider = Security.getProvider(BouncyCastleProvider.PROVIDER_NAME) == null;
          if (addedProvider) {
              Security.addProvider(new BouncyCastleProvider());
          }
          try {
              SecretKeySpec key = new SecretKeySpec(KEY_BYTES, "AES");
              AEADParameterSpec parameters = new AEADParameterSpec(NONCE, 128);
              Cipher encryptionCipher = Cipher.getInstance(
                      transformation, BouncyCastleProvider.PROVIDER_NAME);
              assertThat(encryptionCipher.getProvider().getName())
                      .isEqualTo(BouncyCastleProvider.PROVIDER_NAME);
              encryptionCipher.init(Cipher.ENCRYPT_MODE, key, parameters);
              encryptionCipher.updateAAD(ASSOCIATED_DATA);
  
              byte[] ciphertext = encryptionCipher.doFinal(PLAINTEXT);
              byte[] tamperedCiphertext = ciphertext.clone();
              tamperedCiphertext[tamperedCiphertext.length - 1] ^= 0x01;
  
              Cipher decryptionCipher = Cipher.getInstance(
                      transformation, BouncyCastleProvider.PROVIDER_NAME);
              assertThat(decryptionCipher.getProvider().getName())
