  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jcajce.provider.symmetric.util.BaseSecretKeyFactory;
  import org.bouncycastle.jcajce.spec.RawEncodedKeySpec;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.parallel.ResourceLock;
  
  import java.security.Security;
  import java.security.spec.InvalidKeySpecException;
  import java.security.spec.KeySpec;
  
  import javax.crypto.SecretKey;
  import javax.crypto.SecretKeyFactory;
  import javax.crypto.spec.SecretKeySpec;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BaseSecretKeyFactoryTest {
      private static final byte[] AES_128_KEY_BYTES = new byte[] {
              0x00, 0x01, 0x02, 0x03,
              0x04, 0x05, 0x06, 0x07,
              0x08, 0x09, 0x0a, 0x0b,
              0x0c, 0x0d, 0x0e, 0x0f
      };
  
      @Test
      void exposesRequestedKeySpecFromBaseSecretKeyFactorySubclass() throws Exception {
          TestableBaseSecretKeyFactory keyFactory = new TestableBaseSecretKeyFactory();
          SecretKey secretKey = new SecretKeySpec(AES_128_KEY_BYTES, "AES");
  
          KeySpec keySpec = keyFactory.getKeySpec(secretKey, RawEncodedKeySpec.class);
  
          assertRawEncodedKeySpec(keySpec);
      }
  
      @Test
      @ResourceLock("java.security.Security")
      void returnsRequestedKeySpecConstructedFromSecretKeyBytes() throws Exception {
          boolean addedProvider = Security.getProvider(BouncyCastleProvider.PROVIDER_NAME) == null;
          if (addedProvider) {
              Security.addProvider(new BouncyCastleProvider());
          }
          try {
              SecretKeyFactory keyFactory = SecretKeyFactory.getInstance(
                      "AES", BouncyCastleProvider.PROVIDER_NAME);
              SecretKey secretKey = keyFactory.generateSecret(
                      new SecretKeySpec(AES_128_KEY_BYTES, "AES"));
  
              KeySpec keySpec = keyFactory.getKeySpec(secretKey, RawEncodedKeySpec.class);
  
              assertThat(keyFactory.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);
              assertThat(secretKey.getAlgorithm()).isEqualTo("AES");
              assertRawEncodedKeySpec(keySpec);
          } finally {
              if (addedProvider) {
                  Security.removeProvider(BouncyCastleProvider.PROVIDER_NAME);
              }
          }
      }
  
      private static void assertRawEncodedKeySpec(KeySpec keySpec) {
          assertThat(keySpec).isInstanceOf(RawEncodedKeySpec.class);
          RawEncodedKeySpec rawEncodedKeySpec = (RawEncodedKeySpec)keySpec;
          assertThat(rawEncodedKeySpec.getFormat()).isEqualTo("RAW");
          assertThat(rawEncodedKeySpec.getEncoded()).isEqualTo(AES_128_KEY_BYTES);
      }
  
      private static final class TestableBaseSecretKeyFactory extends BaseSecretKeyFactory {
          private TestableBaseSecretKeyFactory() {
              super("AES", null);
          }
  
          private KeySpec getKeySpec(SecretKey key, Class<? extends KeySpec> keySpec)
                  throws InvalidKeySpecException {
              return engineGetKeySpec(key, keySpec);
          }
      }
  }
