  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.ArrayList;
  import java.util.Arrays;
  import java.util.Enumeration;
  import java.util.Hashtable;
  import java.util.List;
  import java.util.Vector;
  
  import org.bouncycastle.asn1.ASN1Encodable;
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.DERUTF8String;
  import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;
  import org.junit.jupiter.api.Test;
  
  public class PKCS12BagAttributeCarrierImplTest {
      private static final ASN1ObjectIdentifier FRIENDLY_NAME = new ASN1ObjectIdentifier("1.2.840.113549.1.9.20");
      private static final ASN1ObjectIdentifier LOCAL_KEY_ID = new ASN1ObjectIdentifier("1.2.840.113549.1.9.21");
  
      @Test
      public void writeObjectAndReadObjectRoundTripEncodedBagAttributes() throws Exception {
          PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();
          original.setBagAttribute(FRIENDLY_NAME, new DERUTF8String("test-key"));
          original.setBagAttribute(LOCAL_KEY_ID, new DERUTF8String("local-id"));
  
          byte[] encodedCarrier = writeCarrier(original);
  
          PKCS12BagAttributeCarrierImpl restored = new PKCS12BagAttributeCarrierImpl();
          readCarrier(restored, encodedCarrier);
  
          assertThat(attributeText(restored, FRIENDLY_NAME)).isEqualTo("test-key");
          assertThat(attributeText(restored, LOCAL_KEY_ID)).isEqualTo("local-id");
          assertThat(attributeKeys(restored)).containsExactly(FRIENDLY_NAME, LOCAL_KEY_ID);
      }
  
      @Test
      public void writeObjectAndReadObjectPreserveEmptyBagAttributeTables() throws Exception {
          PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();
  
          RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();
          original.writeObject(outputStream);
  
          assertThat(outputStream.writtenObjects()).hasSize(2);
          assertThat(outputStream.writtenObjects().get(0)).isInstanceOf(Hashtable.class);
          assertThat(outputStream.writtenObjects().get(1)).isInstanceOf(Vector.class);
  
          PKCS12BagAttributeCarrierImpl restored = new PKCS12BagAttributeCarrierImpl();
          restored.readObject(new ReplayingObjectInputStream(outputStream.writtenObjects().toArray()));
  
          assertThat(attributeKeys(restored)).isEmpty();
          assertThat(restored.getBagAttribute(FRIENDLY_NAME)).isNull();
      }
  
      private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              carrier.writeObject(outputStream);
          }
          return output.toByteArray();
      }
  
      private static void readCarrier(PKCS12BagAttributeCarrierImpl carrier, byte[] bytes)
              throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              carrier.readObject(inputStream);
          }
      }
  
      private static String attributeText(PKCS12BagAttributeCarrierImpl carrier, ASN1ObjectIdentifier oid) {
          ASN1Encodable attribute = carrier.getBagAttribute(oid);
          assertThat(attribute).isInstanceOf(DERUTF8String.class);
          return ((DERUTF8String)attribute).getString();
      }
  
      private static List<ASN1ObjectIdentifier> attributeKeys(PKCS12BagAttributeCarrierImpl carrier) {
          List<ASN1ObjectIdentifier> keys = new ArrayList<>();
          Enumeration<?> keyEnumeration = carrier.getBagAttributeKeys();
          while (keyEnumeration.hasMoreElements()) {
              keys.add(ASN1ObjectIdentifier.getInstance(keyEnumeration.nextElement()));
          }
          return keys;
      }
  
      private static final class RecordingObjectOutputStream extends ObjectOutputStream {
          private final List<Object> objects = new ArrayList<>();
  
          private RecordingObjectOutputStream() throws IOException {
              super();
          }
  
          @Override
          protected void writeObjectOverride(Object object) {
              objects.add(object);
          }
  
          private List<Object> writtenObjects() {
              return objects;
          }
      }
  
      private static final class ReplayingObjectInputStream extends ObjectInputStream {
          private final List<Object> objects;
          private int index;
  
          private ReplayingObjectInputStream(Object... objects) throws IOException {
              super();
              this.objects = Arrays.asList(objects);
          }
  
          @Override
          protected Object readObjectOverride() {
              Object object = objects.get(index);
              index++;
              return object;
          }
      }
  }
