  import org.bouncycastle.jcajce.provider.asymmetric.edec.BCXDHPrivateKey;
  import org.bouncycastle.jcajce.provider.asymmetric.edec.KeyPairGeneratorSpi.X25519;
  import org.junit.jupiter.api.Test;
  
  public class BCXDHPrivateKeyTest {
      private static final byte[] PRIVATE_KEY_SEED = new byte[] {
          0x10, 0x11, 0x12, 0x13,
          0x14, 0x15, 0x16, 0x17,
          0x18, 0x19, 0x1A, 0x1B,
          0x1C, 0x1D, 0x1E, 0x1F,
          0x20, 0x21, 0x22, 0x23,
          0x24, 0x25, 0x26, 0x27,
          0x28, 0x29, 0x2A, 0x2B,
          0x2C, 0x2D, 0x2E, 0x2F
      };
      private static final byte[] RESTORED_PRIVATE_KEY_SEED = new byte[] {
          0x30, 0x31, 0x32, 0x33,
          0x34, 0x35, 0x36, 0x37,
          0x38, 0x39, 0x3A, 0x3B,
          0x3C, 0x3D, 0x3E, 0x3F,
          0x40, 0x41, 0x42, 0x43,
          0x44, 0x45, 0x46, 0x47,
          0x48, 0x49, 0x4A, 0x4B,
          0x4C, 0x4D, 0x4E, 0x4F
      };
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void objectSerializationWritesAndReadsEncodedXdhPrivateKey() throws Exception {
          BCXDHPrivateKey privateKey = generateX25519PrivateKey(PRIVATE_KEY_SEED);
  
          Object restoredObject = readObject(writeObject(privateKey));
  
          assertThat(restoredObject).isInstanceOf(BCXDHPrivateKey.class);
          BCXDHPrivateKey restored = (BCXDHPrivateKey)restoredObject;
          assertThat(restored).isNotSameAs(privateKey);
          assertXdhPrivateKey(restored, privateKey);
      }
  
      @Test
      public void serializationHooksWriteAndReadEncodedXdhPrivateKey() throws Throwable {
          BCXDHPrivateKey privateKey = generateX25519PrivateKey(PRIVATE_KEY_SEED);
          BCXDHPrivateKey restoredSource = generateX25519PrivateKey(RESTORED_PRIVATE_KEY_SEED);
  
          byte[] writtenObjectStream = invokeWriteObject(privateKey);
          assertThat(readResolvedObject(writtenObjectStream)).isEqualTo(privateKey.getEncoded());
  
          byte[] restoredKeyStream = writeEncodedKey(restoredSource.getEncoded());
          invokeReadObject(privateKey, new NoDefaultReadObjectInputStream(restoredKeyStream));
  
          assertXdhPrivateKey(privateKey, restoredSource);
      }
  
      private static BCXDHPrivateKey generateX25519PrivateKey(byte[] seed) {
          X25519 generator = new X25519();
          generator.initialize(255, new FixedSecureRandom(seed));
          KeyPair keyPair = generator.generateKeyPair();
          assertThat(keyPair.getPrivate()).isInstanceOf(BCXDHPrivateKey.class);
          return (BCXDHPrivateKey)keyPair.getPrivate();
      }
  
      private static void assertXdhPrivateKey(BCXDHPrivateKey actual, BCXDHPrivateKey expected) {
          assertThat(actual.getAlgorithm()).isEqualTo("X25519");
          assertThat(actual.getFormat()).isEqualTo("PKCS#8");
          assertThat(actual).isEqualTo(expected);
          assertThat(actual.hashCode()).isEqualTo(expected.hashCode());
          assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());
          assertThat(actual.getPublicKey().getEncoded()).isEqualTo(expected.getPublicKey().getEncoded());
      }
  
      private static byte[] writeObject(Object object) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(object);
          }
          return output.toByteArray();
      }
  
      private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return inputStream.readObject();
          }
      }
  
      private static byte[] invokeWriteObject(BCXDHPrivateKey privateKey) throws Throwable {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {
              WRITE_OBJECT.invokeExact(privateKey, outputStream);
          }
          return output.toByteArray();
      }
  
      private static void invokeReadObject(BCXDHPrivateKey privateKey, ObjectInputStream inputStream) throws Throwable {
          try (ObjectInputStream closeableInputStream = inputStream) {
              READ_OBJECT.invokeExact(privateKey, closeableInputStream);
          }
      }
  
      private static byte[] writeEncodedKey(byte[] encoded) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(new EncodedKey(encoded));
          }
          return output.toByteArray();
      }
  
      private static Object readResolvedObject(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ResolvingEncodedKeyObjectInputStream(bytes)) {
              return inputStream.readObject();
          }
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCXDHPrivateKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCXDHPrivateKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCXDHPrivateKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCXDHPrivateKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static final class NoDefaultWriteObjectOutputStream extends ObjectOutputStream {
          private NoDefaultWriteObjectOutputStream(OutputStream outputStream) throws IOException {
              super(outputStream);
              enableReplaceObject(true);
          }
  
          @Override
          public void defaultWriteObject() {
          }
  
          @Override
          protected Object replaceObject(Object object) {
              if (object instanceof byte[]) {
                  return new EncodedKey((byte[])object);
              }
              return object;
          }
      }
  
      private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {
          private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {
              super(new ByteArrayInputStream(bytes));
              enableResolveObject(true);
          }
  
          @Override
          public void defaultReadObject() {
          }
  
          @Override
          protected Object resolveObject(Object object) {
              if (object instanceof EncodedKey) {
                  return ((EncodedKey)object).encoded();
              }
              return object;
          }
      }
  
      private static final class ResolvingEncodedKeyObjectInputStream extends ObjectInputStream {
          private ResolvingEncodedKeyObjectInputStream(byte[] bytes) throws IOException {
              super(new ByteArrayInputStream(bytes));
              enableResolveObject(true);
          }
  
          @Override
          protected Object resolveObject(Object object) {
              if (object instanceof EncodedKey) {
                  return ((EncodedKey)object).encoded();
              }
              return object;
          }
      }
  
      private static final class EncodedKey implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String encoded;
  
          private EncodedKey(byte[] encoded) {
              this.encoded = Base64.getEncoder().encodeToString(encoded);
          }
  
          private byte[] encoded() {
              return Base64.getDecoder().decode(encoded);
          }
      }
  }
