  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import org.bouncycastle.pqc.crypto.bike.BIKEParameters;
  import org.bouncycastle.pqc.crypto.bike.BIKEPrivateKeyParameters;
  import org.bouncycastle.pqc.jcajce.provider.bike.BCBIKEPrivateKey;
  import org.bouncycastle.pqc.jcajce.spec.BIKEParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCBIKEPrivateKeyTest {
      @Test
      public void objectSerializationWritesAndReadsEncodedBikePrivateKey() throws Exception {
          BCBIKEPrivateKey privateKey = newBikePrivateKey();
  
          Object restoredObject = readObject(writeObject(privateKey));
  
          assertThat(restoredObject).isInstanceOf(BCBIKEPrivateKey.class);
          BCBIKEPrivateKey restored = (BCBIKEPrivateKey)restoredObject;
          assertThat(restored).isNotSameAs(privateKey);
          assertBikePrivateKey(restored, privateKey);
      }
  
      private static BCBIKEPrivateKey newBikePrivateKey() {
          BIKEParameters parameters = BIKEParameters.bike128;
          byte[] h0 = filledBytes(parameters.getRByte(), 0x11);
          byte[] h1 = filledBytes(parameters.getRByte(), 0x33);
          byte[] sigma = filledBytes(parameters.getLByte(), 0x55);
          BIKEPrivateKeyParameters keyParameters = new BIKEPrivateKeyParameters(parameters, h0, h1, sigma);
          return new BCBIKEPrivateKey(keyParameters);
      }
  
      private static byte[] filledBytes(int length, int firstValue) {
          byte[] bytes = new byte[length];
          for (int index = 0; index < bytes.length; index++) {
              bytes[index] = (byte)(firstValue + index);
          }
          return bytes;
      }
  
      private static void assertBikePrivateKey(BCBIKEPrivateKey actual, BCBIKEPrivateKey expected) {
          assertThat(actual.getAlgorithm()).isEqualTo("BIKE128");
          assertThat(actual.getFormat()).isEqualTo("PKCS#8");
          assertThat(actual.getParameterSpec()).isSameAs(BIKEParameterSpec.bike128);
          assertThat(actual).isEqualTo(expected);
          assertThat(actual.hashCode()).isEqualTo(expected.hashCode());
          assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());
      }
  
      private static byte[] writeObject(Object object) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(object);
          }
          return output.toByteArray();
      }
  
      private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return inputStream.readObject();
          }
      }
  }
