[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/X509UtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.InputStream;\nimport java.security.Provider;\nimport java.security.Security;\nimport java.util.Collection;\nimport java.util.Collections;\n\nimport org.bouncycastle.x509.X509StreamParser;\nimport org.bouncycastle.x509.X509StreamParserSpi;\nimport org.bouncycastle.x509.util.StreamParsingException;\nimport org.junit.jupiter.api.Test;\n\npublic class X509UtilTest {\n    private static final String PARSER_RESULT = \"parsed-by-test-spi\";\n\n    @Test\n    void loadsImplementationWithProviderClassLoader() throws Exception {\n        Provider provider = new TestProvider();\n\n        X509StreamParser parser = X509StreamParser.getInstance(\"test\", provider);\n        parser.init(new byte[] {1, 2, 3});\n\n        assertThat(parser.getProvider()).isSameAs(provider);\n        assertThat(parser.read()).isEqualTo(PARSER_RESULT);\n        assertThat(parser.readAll()).containsExactly(PARSER_RESULT);\n    }\n\n    @Test\n    void loadsImplementationWithClassForNameForBootstrapProvider() throws Exception {\n        Provider provider = findBootstrapLoadedProvider();\n        String key = \"X509StreamParser.TEST\";\n        Object previousValue = provider.put(key, TestStreamParserSpi.class.getName());\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(\"test\", provider);\n            parser.init(new byte[] {4, 5, 6});\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n            assertThat(parser.read()).isEqualTo(PARSER_RESULT);\n        } finally {\n            if (previousValue == null) {\n                provider.remove(key);\n            } else {\n                provider.put(key, previousValue);\n            }\n        }\n    }\n\n    private static Provider findBootstrapLoadedProvider() {\n        Provider[] providers = Security.getProviders();\n        for (Provider provider : providers) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n        throw new AssertionError(\"Expected at least one JDK security provider loaded by the bootstrap class loader\");\n    }\n\n    public static final class TestProvider extends Provider {\n        private static final long serialVersionUID = 1L;\n\n        TestProvider() {\n            super(\"X509UtilTestProvider\", \"1\", \"Provider for X509Util dynamic-access tests\");\n            put(\"X509StreamParser.TEST\", TestStreamParserSpi.class.getName());\n        }\n    }\n\n    public static final class TestStreamParserSpi extends X509StreamParserSpi {\n        private InputStream inputStream;\n\n        public TestStreamParserSpi() {\n        }\n\n        @Override\n        public void engineInit(InputStream in) {\n            inputStream = in;\n        }\n\n        @Override\n        public Object engineRead() throws StreamParsingException {\n            assertThat(inputStream).isNotNull();\n            return PARSER_RESULT;\n        }\n\n        @Override\n        public Collection engineReadAll() throws StreamParsingException {\n            assertThat(inputStream).isNotNull();\n            return Collections.singletonList(PARSER_RESULT);\n        }\n    }\n}\n"}
