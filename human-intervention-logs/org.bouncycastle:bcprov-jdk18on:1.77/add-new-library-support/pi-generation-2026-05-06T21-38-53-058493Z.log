[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/X509UtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.Provider;\nimport java.security.Security;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.x509.X509StreamParser;\nimport org.junit.jupiter.api.Test;\n\npublic class X509UtilTest {\n    @Test\n    void loadsBouncyCastleImplementationWithProviderClassLoader() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n\n        X509StreamParser parser = X509StreamParser.getInstance(\"CERTIFICATE\", provider);\n\n        assertThat(parser.getProvider()).isSameAs(provider);\n    }\n\n    @Test\n    void loadsBouncyCastleImplementationWithClassForNameForBootstrapProvider() throws Exception {\n        Provider provider = findBootstrapLoadedProvider();\n        String key = \"X509StreamParser.CERTIFICATE\";\n        Object previousValue = provider.put(key, \"org.bouncycastle.jce.provider.X509CertParser\");\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(\"CERTIFICATE\", provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n        } finally {\n            if (previousValue == null) {\n                provider.remove(key);\n            } else {\n                provider.put(key, previousValue);\n            }\n        }\n    }\n\n    private static Provider findBootstrapLoadedProvider() {\n        Provider[] providers = Security.getProviders();\n        for (Provider provider : providers) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n        throw new AssertionError(\"Expected a JDK provider loaded by the bootstrap class loader\");\n    }\n}\n"}
[tool-call] end id=call_me80NCGJRZ4ZYPGnP1c4JVKI|fc_0b25a9a30c2ae6be0169fbb58c898881a0b9454f9ac50066a1 name=write args={"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/X509UtilTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.Provider;\nimport java.security.Security;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.x509.X509StreamParser;\nimport org.junit.jupiter.api.Test;\n\npublic class X509UtilTest {\n    @Test\n    void loadsBouncyCastleImplementationWithProviderClassLoader() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n\n        X509StreamParser parser = X509StreamParser.getInstance(\"CERTIFICATE\", provider);\n\n        assertThat(parser.getProvider()).isSameAs(provider);\n    }\n\n    @Test\n    void loadsBouncyCastleImplementationWithClassForNameForBootstrapProvider() throws Exception {\n        Provider provider = findBootstrapLoadedProvider();\n        String key = \"X509StreamParser.CERTIFICATE\";\n        Object previousValue = provider.put(key, \"org.bouncycastle.jce.provider.X509CertParser\");\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(\"CERTIFICATE\", provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n        } finally {\n            if (previousValue == null) {\n                provider.remove(key);\n            } else {\n                provider.put(key, previousValue);\n            }\n        }\n    }\n\n    private static Provider findBootstrapLoadedProvider() {\n        Provider[] providers = Security.getProviders();\n        for (Provider provider : providers) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n        throw new AssertionError(\"Expected a JDK provider loaded by the bootstrap class loader\");\n    }\n}\n"}
