  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Provider;
  import java.security.Security;
  
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.provider.X509CertParser;
  import org.bouncycastle.x509.X509StreamParser;
  import org.junit.jupiter.api.Test;
  
  public class X509UtilTest {
      private static final String CERTIFICATE_PARSER_CLASS_NAME = X509CertParser.class.getName();
  
      @Test
      void loadsBouncyCastleImplementationWithProviderClassLoader() throws Exception {
          assertThat(new X509CertParser()).isInstanceOf(X509CertParser.class);
          Provider provider = new BouncyCastleProvider();
          provider.put("X509StreamParser.TESTCERTIFICATE", CERTIFICATE_PARSER_CLASS_NAME);
  
          X509StreamParser parser = X509StreamParser.getInstance("TESTCERTIFICATE", provider);
  
          assertThat(parser.getProvider()).isSameAs(provider);
      }
  
      @Test
      void loadsBouncyCastleImplementationWithClassForNameForBootstrapProvider() throws Exception {
          assertThat(new X509CertParser()).isInstanceOf(X509CertParser.class);
          Provider provider = findBootstrapLoadedProvider();
          String key = "X509StreamParser.TESTCERTIFICATE";
          Object previousValue = provider.put(key, CERTIFICATE_PARSER_CLASS_NAME);
  
          try {
              X509StreamParser parser = X509StreamParser.getInstance("TESTCERTIFICATE", provider);
  
