9StreamParser parser = X509StreamParser.getInstance(\"CERTIFICATE\", provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n        } finally {\n            if (previousValue == null) {\n                provider.remove(key);\n            } else {\n                provider.put(key, previousValue);\n            }\n        }\n    }\n\n    private static Provider findBootstrapLoadedProvider() {\n        Provider[] providers = Security.getProviders();\n        for (Provider provider : providers) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n        throw new AssertionError(\"Expected a JDK provider loaded by the bootstrap class loader\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 7808, "output": 1008, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 32368, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778103684451, "responseId": "resp_0b25a9a30c2ae6be0169fbb5854e1481a0bcd1b352087f1224"}}
