\n    }\n\n    @Test\n    void loadsConfiguredImplementationWithClassForNameForBootstrapProvider() {\n        Provider provider = findBootstrapLoadedProvider();\n        String key = \"X509StreamParser.TESTOBJECT\";\n        Object previousValue = provider.put(key, OBJECT_CLASS_NAME);\n\n        try {\n            assertThatThrownBy(() -> X509StreamParser.getInstance(\"TESTOBJECT\", provider))\n                .isInstanceOf(ClassCastException.class);\n        } finally {\n            if (previousValue == null) {\n                provider.remove(key);\n            } else {\n                provider.put(key, previousValue);\n            }\n        }\n    }\n\n    private static Provider findBootstrapLoadedProvider() {\n        Provider[] providers = Security.getProviders();\n        for (Provider provider : providers) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n        throw new AssertionError(\"Expected a JDK provider loaded by the bootstrap class loader\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 699, "output": 2332, "cacheRead": 38400, "cacheWrite": 0, "totalTokens": 41431, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778103897686, "responseId": "resp_0b25a9a30c2ae6be0169fbb65b2b8481a0b057ab5c816cc601"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZZgDiwz4mo3sUCIZVVm002mx|fc_0b25a9a30c2ae6be0169fbb676679481a0a01910c721f59ce0", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2124 bytes to tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/X509UtilTest.java"}], "isError": false, "timestamp": 1778103929478}]}
