[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCElGamalPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.PublicKey;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.oiw.ElGamalParameter;\nimport org.bouncycastle.asn1.oiw.OIWObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPublicKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;\nimport org.bouncycastle.jce.spec.ElGamalParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCElGamalPublicKeyTest {\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger Y = BigInteger.valueOf(8L);\n\n    @Test\n    public void javaSerializationRestoresElGamalPublicKeyParameters() throws Exception {\n        BCElGamalPublicKey original = createPublicKey(P, G, Y);\n\n        BCElGamalPublicKey restored = deserialize(serialize(original));\n        ElGamalParameterSpec restoredParameters = restored.getParameters();\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restoredParameters.getP()).isEqualTo(P);\n        assertThat(restoredParameters.getG()).isEqualTo(G);\n        assertThat(restored.getParams().getP()).isEqualTo(P);\n        assertThat(restored.getParams().getG()).isEqualTo(G);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n\n    private static BCElGamalPublicKey createPublicKey(BigInteger p, BigInteger g, BigInteger y) throws Exception {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                OIWObjectIdentifiers.elGamalAlgorithm,\n                new ElGamalParameter(p, g).toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(y));\n        PublicKey publicKey = new KeyFactorySpi().generatePublic(publicKeyInfo);\n\n        return (BCElGamalPublicKey)publicKey;\n    }\n\n    private static byte[] serialize(BCElGamalPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(publicKey);\n        }\n        return output.toByteArray();\n    }\n\n    private static BCElGamalPublicKey deserialize(byte[] bytes) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (BCElGamalPublicKey)inputStream.readObject();\n        }\n    }\n}\n"}
