              invokeReadObject(restored, inputStream);
          }
          ElGamalParameterSpec restoredParameters = restored.getParameters();
  
          assertThat(restored.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(Y);
          assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);
          assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);
          assertThat(restored.getParams().getP()).isEqualTo(RESTORED_P);
          assertThat(restored.getParams().getG()).isEqualTo(RESTORED_G);
      }
  
      private static BCElGamalPublicKey createPublicKey(BigInteger p, BigInteger g, BigInteger y)
