yFactory.getInstance(\"ElGamal\", new BouncyCastleProvider());\n\n        return (BCElGamalPublicKey)keyFactory.generatePublic(keySpec);\n    }\n\n    private static byte[] serialize(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static byte[] invokeWriteObject(BCElGamalPublicKey publicKey) throws Throwable {"}, {"oldText": "        try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {\n            READ_OBJECT.invokeExact(restored, inputStream);\n        }", "newText": "        try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {\n            invokeReadObject(restored, inputStream);\n        }"}, {"oldText": "    private static byte[] writeObjects(Object firstObject, Object secondObject) throws IOException {", "newText": "    private static void invokeReadObject(BCElGamalPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(publicKey, inputStream);\n    }\n\n    private static byte[] writeObjects(Object firstObject, Object secondObject) throws IOException {"}, {"oldText": "    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return new Object[] {inputStream.readObject(), inputStream.readObject()};\n        }\n    }\n\n    private static MethodHandle findWriteObject() {", "newText": "    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return new Object[] {inputStream.readObject(), inputStream.readObject()};\n        }\n    }\n\n    private static <T> T deserialize(byte[] bytes, Class<T> type) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return type.cast(inputStream.readObject());\n        }\n    }\n\n    private static MethodHandle findWriteObject() {"}, {"oldText": "    private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {\n        private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n}", "newText": "    private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {\n        private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n\n    private static final class TrackedBigInteger extends BigInteger {\n        private static final long serialVersionUID = 1L;\n\n        private TrackedBigInteger(long value) {\n            super(Long.toString(value));\n        }\n\n        private static TrackedBigInteger trackedValueOf(long value) {\n            return new TrackedBigInteger(value);\n        }\n    }\n}\n"}]}
