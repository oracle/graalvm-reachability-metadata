  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.math.BigInteger;
  
  import javax.crypto.spec.DHParameterSpec;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.pkcs.DHParameter;
  import org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;
  import org.junit.jupiter.api.Test;
  
  public class BCDHPublicKeyTest {
      private static final BigInteger P = BigInteger.valueOf(23L);
      private static final BigInteger G = BigInteger.valueOf(5L);
      private static final BigInteger Y = BigInteger.valueOf(8L);
      private static final BigInteger RESTORED_P = BigInteger.valueOf(47L);
      private static final BigInteger RESTORED_G = BigInteger.valueOf(2L);
      private static final int PUBLIC_VALUE_LENGTH = 5;
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void serializesAndRestoresDiffieHellmanPublicKeyParameters() throws Throwable {
          BCDHPublicKey original = createPublicKey(P, G);
          RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();
  
          invokeWriteObject(original, outputStream);
  
          assertThat(outputStream.writtenObjects()).containsExactly(P, G);
          assertThat(outputStream.writtenInt()).isEqualTo(PUBLIC_VALUE_LENGTH);
  
          BCDHPublicKey restored = createPublicKey(P, G);
          ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(
                  RESTORED_P,
                  RESTORED_G,
                  PUBLIC_VALUE_LENGTH);
  
          invokeReadObject(restored, inputStream);
          DHParameterSpec restoredParameters = restored.getParams();
  
          assertThat(restored.getAlgorithm()).isEqualTo("DH");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(Y);
          assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);
          assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);
          assertThat(restoredParameters.getL()).isEqualTo(PUBLIC_VALUE_LENGTH);
      }
  
      private static BCDHPublicKey createPublicKey(BigInteger p, BigInteger g) throws Exception {
          DHParameter parameters = new DHParameter(p, g, PUBLIC_VALUE_LENGTH);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  PKCSObjectIdentifiers.dhKeyAgreement,
                  parameters.toASN1Primitive());
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(Y));
  
          return new BCDHPublicKey(publicKeyInfo);
      }
  
      private static void invokeWriteObject(BCDHPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {
          WRITE_OBJECT.invokeExact(publicKey, outputStream);
      }
  
      private static void invokeReadObject(BCDHPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {
          READ_OBJECT.invokeExact(publicKey, inputStream);
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCDHPublicKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCDHPublicKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static final class RecordingObjectOutputStream extends ObjectOutputStream {
          private final Object[] objects = new Object[2];
          private int objectCount;
          private int intValue;
  
          private RecordingObjectOutputStream() throws IOException {
              super();
          }
  
          @Override
          public void defaultWriteObject() {
          }
  
          @Override
          protected void writeObjectOverride(Object object) {
              objects[objectCount] = object;
              objectCount++;
          }
  
          @Override
          public void writeInt(int value) {
              intValue = value;
          }
  
          private Object[] writtenObjects() {
              Object[] written = new Object[objectCount];
              System.arraycopy(objects, 0, written, 0, objectCount);
              return written;
          }
  
          private int writtenInt() {
              return intValue;
          }
      }
  
      private static final class ReplayingObjectInputStream extends ObjectInputStream {
          private final Object[] objects;
          private final int intValue;
          private int objectIndex;
  
          private ReplayingObjectInputStream(Object firstObject, Object secondObject, int intValue) throws IOException {
              super();
              this.objects = new Object[] {firstObject, secondObject};
              this.intValue = intValue;
          }
  
          @Override
          public void defaultReadObject() {
          }
  
          @Override
          protected Object readObjectOverride() {
              Object object = objects[objectIndex];
              objectIndex++;
              return object;
          }
  
          @Override
          public int readInt() {
              return intValue;
          }
      }
  }
