[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JCEElGamalPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jce.provider.JCEElGamalPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamConstants;\nimport java.math.BigInteger;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCEElGamalPublicKeyTest {\n    private static final BigInteger P = new BigInteger(\"104729\");\n    private static final BigInteger G = new BigInteger(\"2\");\n    private static final BigInteger Y = new BigInteger(\"54321\");\n\n    @Test\n    void serializesAndRestoresJceElGamalPublicKeyParameters() throws Exception {\n        TrackingObjectInputStream input = new TrackingObjectInputStream(serializedJceElGamalPublicKey());\n        JCEElGamalPublicKey restored = input.readJceElGamalPublicKey();\n\n        assertThat(input.resolvedBigIntegers()).contains(Y, P, G);\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restored.getParameters().getP()).isEqualTo(P);\n        assertThat(restored.getParameters().getG()).isEqualTo(G);\n        assertThat(restored.getParams().getP()).isEqualTo(P);\n        assertThat(restored.getParams().getG()).isEqualTo(G);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n\n        TrackingObjectOutputStream output = new TrackingObjectOutputStream();\n        output.writeObject(restored);\n        output.close();\n\n        assertThat(output.replacedBigIntegers()).contains(Y, P, G);\n        JCEElGamalPublicKey roundTripped = deserialize(output.toByteArray());\n\n        assertThat(roundTripped.getY()).isEqualTo(restored.getY());\n        assertThat(roundTripped.getParameters().getP()).isEqualTo(restored.getParameters().getP());\n        assertThat(roundTripped.getParameters().getG()).isEqualTo(restored.getParameters().getG());\n    }\n\n    private static byte[] serializedJceElGamalPublicKey() throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(serialized);\n        output.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        output.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        output.writeByte(ObjectStreamConstants.TC_OBJECT);\n        output.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        output.writeUTF(JCEElGamalPublicKey.class.getName());\n        output.writeLong(ObjectStreamClass.lookup(JCEElGamalPublicKey.class).getSerialVersionUID());\n        output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n        output.writeShort(0);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        output.writeByte(ObjectStreamConstants.TC_NULL);\n        output.write(serializedObjectPayload(Y));\n        output.write(serializedObjectPayload(P));\n        output.write(serializedObjectPayload(G));\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        return serialized.toByteArray();\n    }\n\n    private static byte[] serializedObjectPayload(Object value) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream object