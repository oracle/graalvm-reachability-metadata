   private static final BigInteger P = new BigInteger(\"104729\");\n    private static final BigInteger G = new BigInteger(\"2\");\n    private static final BigInteger X = new BigInteger(\"12345\");\n\n    @Test\n    void serializesAndRestoresJceElGamalPrivateKeyParameters() throws Exception {\n        TrackingObjectInputStream input = new TrackingObjectInputStream(serializedJceElGamalPrivateKey());\n        JCEElGamalPrivateKey restored = input.readJceElGamalPrivateKey();\n\n        assertThat(input.resolvedBigIntegers()).contains(X, P, G);\n        assertThat(restored.getX()).isEqualTo(X);\n        assertThat(restored.getParameters().getP()).isEqualTo(P);\n        assertThat(restored.getParameters().getG()).isEqualTo(G);\n        assertThat(restored.getParams().getP()).isEqualTo(P);\n        assertThat(restored.getParams().getG()).isEqualTo(G);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n\n        TrackingObjectOutputStream output = new TrackingObjectOutputStream();\n        output.writeObject(restored);\n        output.close();\n\n        assertThat(output.replacedBigIntegers()).contains(X, P, G);\n        JCEElGamalPrivateKey roundTripped = deserialize(output.toByteArray());\n\n        assertThat(roundTripped.getX()).isEqualTo(restored.getX());\n        assertThat(roundTripped.getParameters().getP()).isEqualTo(restored.getParameters().getP());\n        assertThat(roundTripped.getParameters().getG()).isEqualTo(restored.getParameters().getG());\n    }\n\n    private static byte[] serializedJceElGamalPrivateKey() throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(serialized);\n        output.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        output.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        output.writeByte(ObjectStreamConstants.TC_OBJECT);\n        output.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        output.writeUTF(JCEElGamalPrivateKey.class.getName());\n        output.writeLong(ObjectStreamClass.lookup(JCEElGamalPrivateKey.class).getSerialVersionUID());\n        output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n        output.writeShort(0);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        output.writeByte(ObjectStreamConstants.TC_NULL);\n        output.write(serializedObjectPayload(X));\n        output.write(serializedObjectPayload(P));\n        output.write(serializedObjectPayload(G));\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        return serialized.toByteArray();\n    }\n\n    private static byte[] serializedObjectPayload(Object value) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(value);\n        }\n        byte[] stream = serialized.toByteArray();\n        return Arrays.copyOfRange(stream, 4, stream.length);\n    }\n\n    private static JCEElGamalPrivateKey deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCEElGamalPrivateKey)objectInputStream.readObject();\n        }\n    }\n\n    private static final class TrackingObjectInputStream extends ObjectInputStream {\n        private final List<BigInteger> resolvedBigIntegers = new ArrayList<>();\n\n        private TrackingObjectInputStream(byte[] serialized) throws IOException {\n            super(new ByteArrayInputStream(serialized));\n            enableResolveObject(true);\n        }\n\n        private JCEElGamalPrivateKey readJceElGamalPrivateKey() throws I