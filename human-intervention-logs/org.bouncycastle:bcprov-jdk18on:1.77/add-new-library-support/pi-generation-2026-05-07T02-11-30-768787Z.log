  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.math.BigInteger;
  import java.security.spec.ECFieldFp;
  import java.security.spec.ECParameterSpec;
  import java.security.spec.ECPoint;
  import java.security.spec.ECPublicKeySpec;
  import java.security.spec.EllipticCurve;
  
  import org.bouncycastle.jcajce.provider.asymmetric.ec.BCECPublicKey;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  public class BCECPublicKeyTest {
      private static final BigInteger PUBLIC_X = new BigInteger(
              "6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296",
              16);
      private static final BigInteger PUBLIC_Y = new BigInteger(
              "4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5",
              16);
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void serializationHooksWriteAndReadEncodedEcPublicKey() throws Throwable {
          ECParameterSpec parameters = createSecp256r1Parameters();
          BCECPublicKey publicKey = createPublicKey(parameters);
          RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();
  
          invokeWriteObject(publicKey, outputStream);
  
          byte[] serializedEncodedKey = outputStream.serializedObject();
  
          assertThat(readSerializedObject(serializedEncodedKey)).isEqualTo(publicKey.getEncoded());
  
          BCECPublicKey restored = createPublicKey(parameters);
          ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(serializedEncodedKey);
  
          invokeReadObject(restored, inputStream);
  
          assertThat(restored.getAlgorithm()).isEqualTo("EC");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getW()).isEqualTo(new ECPoint(PUBLIC_X, PUBLIC_Y));
          assertThat(restored.getQ()).isEqualTo(publicKey.getQ());
          assertThat(restored.getEncoded()).isEqualTo(publicKey.getEncoded());
          assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());
          assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());
          assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());
      }
  
      private static BCECPublicKey createPublicKey(ECParameterSpec parameters) {
          return new BCECPublicKey(
                  "EC",
                  new ECPublicKeySpec(new ECPoint(PUBLIC_X, PUBLIC_Y), parameters),
                  BouncyCastleProvider.CONFIGURATION);
      }
  
      private static byte[] readSerializedObject(byte[] serializedObject) throws Exception {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serializedObject))) {
              return (byte[])inputStream.readObject();
          }
      }
  
      private static void invokeWriteObject(BCECPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {
          WRITE_OBJECT.invokeExact(publicKey, outputStream);
      }
  
      private static void invokeReadObject(BCECPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {
          READ_OBJECT.invokeExact(publicKey, inputStream);
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCECPublicKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECPublicKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCECPublicKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECPublicKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static ECParameterSpec createSecp256r1Parameters() {
          BigInteger p = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF", 16);
          BigInteger a = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC", 16);
          BigInteger b = new BigInteger("5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B", 16);
          BigInteger n = new BigInteger("FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551", 16);
  
          return new ECParameterSpec(
                  new EllipticCurve(new ECFieldFp(p), a, b),
                  new ECPoint(PUBLIC_X, PUBLIC_Y),
                  n,
                  1);
      }
  
      private static final class RecordingObjectOutputStream extends ObjectOutputStream {
          private final ByteArrayOutputStream output;
  
          private RecordingObjectOutputStream() throws IOException {
              this(new ByteArrayOutputStream());
          }
  
          private RecordingObjectOutputStream(ByteArrayOutputStream output) throws IOException {
              super(output);
              this.output = output;
          }
  
          @Override
          public void defaultWriteObject() {
          }
  
          private byte[] serializedObject() throws IOException {
              flush();
              return output.toByteArray();
          }
      }
  
      private static final class ReplayingObjectInputStream extends ObjectInputStream {
          private ReplayingObjectInputStream(byte[] serializedObject) throws IOException {
              super(new ByteArrayInputStream(serializedObject));
          }
  
          @Override
          public void defaultReadObject() {
          }
      }
  }
