  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.KeyPair;
  import java.security.SecureRandom;
  
  import org.bouncycastle.pqc.jcajce.provider.dilithium.BCDilithiumPublicKey;
  import org.bouncycastle.pqc.jcajce.provider.dilithium.DilithiumKeyPairGeneratorSpi;
  import org.bouncycastle.pqc.jcajce.spec.DilithiumParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCDilithiumPublicKeyTest {
      @Test
      public void objectSerializationWritesAndReadsEncodedDilithiumPublicKey() throws Exception {
          BCDilithiumPublicKey publicKey = newDilithiumPublicKey();
  
          Object restoredObject = readObject(writeObject(publicKey));
  
          assertThat(restoredObject).isInstanceOf(BCDilithiumPublicKey.class);
          BCDilithiumPublicKey restored = (BCDilithiumPublicKey)restoredObject;
          assertThat(restored).isNotSameAs(publicKey);
          assertDilithiumPublicKey(restored, publicKey);
      }
  
      private static BCDilithiumPublicKey newDilithiumPublicKey() throws Exception {
          DilithiumKeyPairGeneratorSpi generator = new DilithiumKeyPairGeneratorSpi();
          generator.initialize(DilithiumParameterSpec.dilithium2, fixedRandom());
          KeyPair keyPair = generator.generateKeyPair();
          return (BCDilithiumPublicKey)keyPair.getPublic();
      }
  
      private static SecureRandom fixedRandom() {
          return new SecureRandom(new byte[] {
              0x10, 0x32, 0x54, 0x76, 0x21, 0x43, 0x65, 0x07
          });
      }
  
      private static void assertDilithiumPublicKey(BCDilithiumPublicKey actual, BCDilithiumPublicKey expected) {
          assertThat(actual.getAlgorithm()).isEqualTo("DILITHIUM2");
          assertThat(actual.getFormat()).isEqualTo("X.509");
          assertThat(actual.getParameterSpec()).isSameAs(DilithiumParameterSpec.dilithium2);
          assertThat(actual).isEqualTo(expected);
          assertThat(actual.hashCode()).isEqualTo(expected.hashCode());
          assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());
      }
  
      private static byte[] writeObject(Object object) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(object);
          }
          return output.toByteArray();
      }
  
      private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return inputStream.readObject();
          }
      }
  }
