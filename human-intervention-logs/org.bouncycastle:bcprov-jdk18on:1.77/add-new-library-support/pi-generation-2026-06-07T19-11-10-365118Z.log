  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.DSAParameter;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.asn1.x9.X9ObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPublicKey;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.interfaces.DSAPublicKey;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDSAPublicKeyTest {
      private static final BigInteger P = new BigInteger(
              "fca682ce8e12caba26efccf7110e526db078b05edecbcd1eb4a208f3ae1617ae"
                      + "01f35b91a47e6df63413c5e12ed0899bcd132acd50d99151bdc43ee737592e17",
              16);
      private static final BigInteger Q = new BigInteger(
              "962eddcc369cba8ebb260ee6b6a126d9346e38c5",
              16);
      private static final BigInteger G = new BigInteger(
              "678471b27a9cf44ee91a49c5147db1a9aaf244f05a434d6486931d2d14271b9e"
                      + "35030b71fd73da179069b32e2935630e1c2062354d0da20a6c416e50be794ca4",
              16);
      private static final BigInteger PRIVATE_VALUE = new BigInteger("12345678901234567890");
      private static final BigInteger PUBLIC_VALUE = G.modPow(PRIVATE_VALUE, P);
  
      @Test
      void serializesAndRestoresDsaPublicKeyParameters() throws Exception {
          DSAPublicKey original = newBcDsaPublicKey();
  
          DSAPublicKey restored = deserialize(serialize(original));
  
          assertThat(restored).isInstanceOf(BCDSAPublicKey.class);
          assertThat(restored.getY()).isEqualTo(original.getY());
          assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());
          assertThat(restored.getParams().getQ()).isEqualTo(original.getParams().getQ());
          assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());
          assertThat(restored.getAlgorithm()).isEqualTo("DSA");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getEncoded()).isNotEmpty();
      }
  
      @Test
      void serializesAndRestoresDsaPublicKeyWithoutParameters() throws Exception {
          DSAPublicKey original = newBcDsaPublicKeyWithoutParameters();
  
          DSAPublicKey restored = deserialize(serialize(original));
  
          assertThat(restored).isInstanceOf(BCDSAPublicKey.class);
          assertThat(restored.getY()).isEqualTo(original.getY());
          assertThat(restored.getParams()).isNull();
          assertThat(restored.getAlgorithm()).isEqualTo("DSA");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getEncoded()).isNotEmpty();
      }
  
      private static BCDSAPublicKey newBcDsaPublicKey() throws Exception {
          DSAParameter parameters = new DSAParameter(P, Q, G);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  X9ObjectIdentifiers.id_dsa,
                  parameters.toASN1Primitive());
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(
                  algorithmIdentifier,
                  new ASN1Integer(PUBLIC_VALUE));
  
          return new BCDSAPublicKey(publicKeyInfo);
      }
  
      private static BCDSAPublicKey newBcDsaPublicKeyWithoutParameters() throws Exception {
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(X9ObjectIdentifiers.id_dsa);
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(
                  algorithmIdentifier,
                  new ASN1Integer(PUBLIC_VALUE));
  
          return new BCDSAPublicKey(publicKeyInfo);
      }
  
      private static byte[] serialize(DSAPublicKey publicKey) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(publicKey);
          }
          return serialized.toByteArray();
      }
  
      private static DSAPublicKey deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (DSAPublicKey)objectInputStream.readObject();
          }
      }
  }
