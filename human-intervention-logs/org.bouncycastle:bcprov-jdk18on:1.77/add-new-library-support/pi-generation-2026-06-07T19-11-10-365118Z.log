          {
              EllipticCurve ellipticCurve = EC5Util.convertCurve(spec.getCurve(), spec.getSeed());
  
              this.ecSpec = EC5Util.convertSpec(ellipticCurve, spec);
          }
  
          this.ecPublicKey = params;
          this.configuration = configuration;
      }
  
      /*
