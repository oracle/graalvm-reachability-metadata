          X9ECPoint derQ = new X9ECPoint(curve, key);
  
          this.ecPublicKey = new ECPublicKeyParameters(derQ.getPoint(), ECUtil.getDomainParameters(configuration, params));
      }
  
      public String getAlgorithm()
      {
          return algorithm;
      }
  
      public String getFormat()
