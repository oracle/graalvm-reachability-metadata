  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jcajce.provider.asymmetric.ec.BCECPrivateKey;
  import org.bouncycastle.jce.ECNamedCurveTable;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.bouncycastle.util.CollectionStore;
  import org.bouncycastle.util.Selector;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.interfaces.ECPrivateKey;
  import java.security.spec.ECPrivateKeySpec;
  import java.util.Collection;
  import java.util.List;
  import java.util.concurrent.atomic.AtomicReference;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCECPrivateKeyTest {
      private static final BigInteger PRIVATE_VALUE = new BigInteger(
              "1122334455667788990011223344556677889900112233445566778899001122");
  
      @Test
      void serializesAndRestoresEcPrivateKeySpecParameters() throws Exception {
          ECPrivateKey original = newBcEcPrivateKey();
  
          ECPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);
  
          assertRestoredKeyMatchesOriginal(original, restored);
      }
  
      @Test
      void serializesAndRestoresCompressedEcPrivateKeySpecParameters() throws Exception {
          BCECPrivateKey original = newBcEcPrivateKey();
          original.setPointFormat("COMPRESSED");
  
          ECPrivateKey restored = deserialize(serialize(original));
  
          assertRestoredKeyMatchesOriginal(original, restored);
      }
  
      private static BCECPrivateKey newBcEcPrivateKey() {
          ECNamedCurveParameterSpec namedCurve = ECNamedCurveTable.getParameterSpec("secp256r1");
          ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(
                  "secp256r1",
                  namedCurve.getCurve(),
                  namedCurve.getG(),
                  namedCurve.getN(),
                  namedCurve.getH(),
                  namedCurve.getSeed());
          ECPrivateKeySpec privateKeySpec = new ECPrivateKeySpec(PRIVATE_VALUE, namedCurveSpec);
  
          return new BCECPrivateKey("EC", privateKeySpec, BouncyCastleProvider.CONFIGURATION);
      }
  
      private static void assertRestoredKeyMatchesOriginal(ECPrivateKey original, ECPrivateKey restored) {
          assertThat(original).isInstanceOf(BCECPrivateKey.class);
          assertThat(restored).isInstanceOf(BCECPrivateKey.class);
          assertThat(restored.getS()).isEqualTo(original.getS());
          assertThat(restored.getParams().getOrder()).isEqualTo(original.getParams().getOrder());
          assertThat(restored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());
          assertThat(restored.getAlgorithm()).isEqualTo("EC");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getEncoded()).isNotEmpty();
          assertThat(((BCECPrivateKey)restored).getBagAttributeKeys().hasMoreElements()).isFalse();
      }
  
      private static ECPrivateKey serializeAndDeserializeFromBouncyCastleFrame(ECPrivateKey privateKey) {
          CollectionStore<ECPrivateKey> store = new CollectionStore<>(List.of(privateKey));
          AtomicReference<ECPrivateKey> restored = new AtomicReference<>();
  
          Collection<ECPrivateKey> matches = store.getMatches(new Selector<>() {
              @Override
              public boolean match(ECPrivateKey key) {
                  try {
                      restored.set(deserialize(serialize(key)));
                      return true;
                  }
                  catch (Exception e) {
                      throw new IllegalStateException("EC private key serialization failed", e);
                  }
              }
  
              @Override
              public Object clone() {
                  return this;
              }
          });
  
          assertThat(matches).containsExactly(privateKey);
          return restored.get();
      }
  
      private static byte[] serialize(ECPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(privateKey);
          }
          return serialized.toByteArray();
      }
  
      private static ECPrivateKey deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (ECPrivateKey)objectInputStream.readObject();
          }
      }
