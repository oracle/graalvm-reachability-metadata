ws Exception {\n        ECPublicKey original = newBcEcPublicKey();\n\n        ECPublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void serializesAndRestoresCompressedEcPublicKeySpecParameters() throws Exception {\n        BCECPublicKey original = newBcEcPublicKey();\n        original.setPointFormat(\"COMPRESSED\");\n\n        ECPublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n\n    private static BCECPublicKey newBcEcPublicKey() {\n        ECNamedCurveParameterSpec namedCurve = ECNamedCurveTable.getParameterSpec(\"secp256r1\");\n        ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(\n                \"secp256r1\",\n                namedCurve.getCurve(),\n                namedCurve.getG(),\n                namedCurve.getN(),\n                namedCurve.getH(),\n                namedCurve.getSeed());\n        ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(\n                namedCurveSpec.getGenerator(),\n                namedCurveSpec);\n\n        return new BCECPublicKey(\"EC\", publicKeySpec, BouncyCastleProvider.CONFIGURATION);\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(ECPublicKey original, ECPublicKey restored) {\n        assertThat(original).isInstanceOf(BCECPublicKey.class);\n        assertThat(restored).isInstanceOf(BCECPublicKey.class);\n        assertThat(restored.getW()).isEqualTo(original.getW());\n        assertThat(restored.getParams().getOrder()).isEqualTo(original.getParams().getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n    }\n\n    private static byte[] serialize(ECPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static ECPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ECPublicKey)objectInputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1758, "output": 1163, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 20841, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780859439178, "responseId": "resp_0e9f35094975ac74016a25c22fa7688197b4133243da1ce260"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_mg9afW1VYgksmySC1FkNBkyK|fc_0e9f35094975ac74016a25c236c8988197b742260f2d42d86c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3552 bytes to tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCECPublicKeyTest.java"}], "isError": false, "timestamp": 1780859455585}]}
