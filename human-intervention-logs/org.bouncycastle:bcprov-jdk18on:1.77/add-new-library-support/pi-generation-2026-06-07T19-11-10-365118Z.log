  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jcajce.provider.asymmetric.ec.BCECPublicKey;
  import org.bouncycastle.jce.ECNamedCurveTable;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.security.KeyPair;
  import java.security.KeyPairGenerator;
  import java.security.Signature;
  import java.security.SignedObject;
  import java.security.interfaces.ECPublicKey;
  import java.security.spec.ECPublicKeySpec;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCECPublicKeyTest {
      @Test
      void serializesAndRestoresEcPublicKeySpecParameters() throws Exception {
          ECPublicKey original = newBcEcPublicKey();
  
          byte[] serialized = serialize(original);
          ECPublicKey restored = deserialize(serialized);
  
          assertThat(serialized).containsSequence(original.getEncoded());
          assertRestoredKeyMatchesOriginal(original, restored);
      }
  
      @Test
      void serializesAndRestoresCompressedEcPublicKeySpecParameters() throws Exception {
          BCECPublicKey original = newBcEcPublicKey();
          original.setPointFormat("COMPRESSED");
  
          byte[] serialized = serialize(original);
          ECPublicKey restored = deserialize(serialized);
  
          assertThat(serialized).containsSequence(original.getEncoded());
          assertRestoredKeyMatchesOriginal(original, restored);
          assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());
      }
  
      @Test
      void signedObjectSerializesAndRestoresEcPublicKey() throws Exception {
          ECPublicKey original = newBcEcPublicKey();
          KeyPair signingKeyPair = newSigningKeyPair();
          Signature signingSignature = Signature.getInstance("SHA256withRSA");
  
          SignedObject signedObject = new SignedObject(original, signingKeyPair.getPrivate(), signingSignature);
  
          assertThat(signedObject.verify(signingKeyPair.getPublic(), Signature.getInstance("SHA256withRSA"))).isTrue();
          assertRestoredKeyMatchesOriginal(original, (ECPublicKey)signedObject.getObject());
      }
  
      private static BCECPublicKey newBcEcPublicKey() {
          ECNamedCurveParameterSpec namedCurve = ECNamedCurveTable.getParameterSpec("secp256r1");
          ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(
                  "secp256r1",
                  namedCurve.getCurve(),
                  namedCurve.getG(),
                  namedCurve.getN(),
                  namedCurve.getH(),
                  namedCurve.getSeed());
          ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(
                  namedCurveSpec.getGenerator(),
                  namedCurveSpec);
  
          return new BCECPublicKey("EC", publicKeySpec, BouncyCastleProvider.CONFIGURATION);
      }
  
      private static KeyPair newSigningKeyPair() throws Exception {
          KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance("RSA");
          keyPairGenerator.initialize(2048);
          return keyPairGenerator.generateKeyPair();
      }
  
      private static void assertRestoredKeyMatchesOriginal(ECPublicKey original, ECPublicKey restored) {
          assertThat(original).isInstanceOf(BCECPublicKey.class);
          assertThat(restored).isInstanceOf(BCECPublicKey.class);
          assertThat(restored.getW()).isEqualTo(original.getW());
          assertThat(restored.getParams().getOrder()).isEqualTo(original.getParams().getOrder());
          assertThat(restored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());
          assertThat(restored.getAlgorithm()).isEqualTo("EC");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getEncoded()).isNotEmpty();
      }
  
      private static byte[] serialize(ECPublicKey publicKey) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(publicKey);
          }
          return serialized.toByteArray();
      }
  
      private static ECPublicKey deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (ECPublicKey)objectInputStream.readObject();
          }
      }
  }
