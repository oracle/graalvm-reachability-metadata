tle.jce.ECNamedCurveTable;\nimport org.bouncycastle.jce.provider.JCEECPrivateKey;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECPrivateKeySpec;\n", "newText": "import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\n"}, {"oldText": "import java.math.BigInteger;\nimport java.util.Enumeration;\n", "newText": "import java.util.Enumeration;\n"}, {"oldText": "    private static final String FRIENDLY_NAME = \"native image key\";\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\n            \"39175055993443409939119959424019790719415747144290992075825378743744377387183\");\n\n    @Test\n    void serializesAndRestoresPkcs12BagAttributesThroughEcPrivateKey() throws Exception {\n        JCEECPrivateKey original = newEcPrivateKeyWithBagAttribute();\n\n        JCEECPrivateKey restored = deserialize(serialize(original));\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restored.getD()).isEqualTo(original.getD());\n        assertThat(singleBagAttributeKey(restored)).isEqualTo(FRIENDLY_NAME_OID);\n        assertThat(getFriendlyName(restored)).isEqualTo(FRIENDLY_NAME);\n    }\n\n    private static JCEECPrivateKey newEcPrivateKeyWithBagAttribute() {\n        ECNamedCurveParameterSpec curveParameters = ECNamedCurveTable.getParameterSpec(\"prime256v1\");\n        JCEECPrivateKey privateKey = new JCEECPrivateKey(\n                \"EC\",\n                new ECPrivateKeySpec(PRIVATE_VALUE, curveParameters));\n\n        privateKey.setBagAttribute(FRIENDLY_NAME_OID, new DERBMPString(FRIENDLY_NAME));\n        return privateKey;\n    }\n\n    private static ASN1ObjectIdentifier singleBagAttributeKey(JCEECPrivateKey privateKey) {\n", "newText": "    private static final String FRIENDLY_NAME = \"native image key\";\n\n    @Test\n    void writesAndReadsPkcs12BagAttributes() throws Exception {\n        PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();\n        original.setBagAttribute(FRIENDLY_NAME_OID, new DERBMPString(FRIENDLY_NAME));\n\n        PKCS12BagAttributeCarrierImpl restored = new PKCS12BagAttributeCarrierImpl();\n        restored.readObject(new ObjectInputStream(new ByteArrayInputStream(writeCarrier(original))));\n\n        assertThat(singleBagAttributeKey(restored)).isEqualTo(FRIENDLY_NAME_OID);\n        assertThat(getFriendlyName(restored)).isEqualTo(FRIENDLY_NAME);\n    }\n\n    private static ASN1ObjectIdentifier singleBagAttributeKey(PKCS12BagAttributeCarrierImpl privateKey) {\n"}, {"oldText": "    private static String getFriendlyName(JCEECPrivateKey privateKey) {\n", "newText": "    private static String getFriendlyName(PKCS12BagAttributeCarrierImpl privateKey) {\n"}, {"oldText": "    private static byte[] serialize(JCEECPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JCEECPrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCEECPrivateKey)objectInputStream.readObject();\n        }\n    }\n", "newText": "    private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            carrier.writeObject(objectOutputStream);\n        }\n        return serialized.toByteArray();\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 20919, "output": 1500, "cacheRead": 11776, "cacheWrite": 0, "totalTo