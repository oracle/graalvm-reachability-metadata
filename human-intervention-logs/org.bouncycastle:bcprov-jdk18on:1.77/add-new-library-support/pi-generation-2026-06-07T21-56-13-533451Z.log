  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;
  import org.bouncycastle.util.CollectionStore;
  import org.bouncycastle.util.Selector;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  import java.math.BigInteger;
  import java.security.KeyFactory;
  import java.security.KeyPair;
  import java.security.KeyPairGenerator;
  import java.security.PrivateKey;
  import java.security.SecureRandom;
  import java.security.Signature;
  import java.security.SignedObject;
  import java.security.interfaces.DSAPrivateKey;
  import java.security.spec.DSAParameterSpec;
  import java.security.spec.DSAPrivateKeySpec;
  import java.util.Collection;
  import java.util.List;
  import java.util.concurrent.atomic.AtomicReference;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDSAPrivateKeyTest {
      private static final BigInteger P = new BigInteger(
              "fca682ce8e12caba26efccf7110e526db078b05edecbcd1eb4a208f3ae1617ae"
                      + "01f35b91a47e6df63413c5e12ed0899bcd132acd50d99151bdc43ee737592e17",
              16);
      private static final BigInteger Q = new BigInteger(
              "962eddcc369cba8ebb260ee6b6a126d9346e38c5",
              16);
      private static final BigInteger G = new BigInteger(
              "678471b27a9cf44ee91a49c5147db1a9aaf244f05a434d6486931d2d14271b9e"
                      + "35030b71fd73da179069b32e2935630e1c2062354d0da20a6c416e50be794ca4",
              16);
      private static final BigInteger PRIVATE_VALUE = new BigInteger("12345678901234567890");
  
      @Test
      void serializesAndRestoresDsaPrivateKeyParameters() throws Exception {
          DSAPrivateKey original = newBcDsaPrivateKey();
  
          DSAPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);
  
          assertRestoredKeyMatchesOriginal(original, restored);
      }
  
      @Test
      void signedObjectSerializesAndRestoresProviderGeneratedDsaPrivateKey() throws Exception {
          KeyPair keyPair = newDsaKeyPair();
          DSAPrivateKey original = (DSAPrivateKey)keyPair.getPrivate();
          BouncyCastleProvider provider = new BouncyCastleProvider();
          Signature signingSignature = Signature.getInstance("SHA1withDSA", provider);
  
          SignedObject signedObject = new SignedObject(
                  (Serializable)original,
                  keyPair.getPrivate(),
                  signingSignature);
          Signature verificationSignature = Signature.getInstance("SHA1withDSA", provider);
          DSAPrivateKey restored = (DSAPrivateKey)signedObject.getObject();
  
          assertThat(signedObject.verify(keyPair.getPublic(), verificationSignature)).isTrue();
          assertRestoredKeyMatchesOriginal(original, restored);
      }
  
      private static DSAPrivateKey newBcDsaPrivateKey() throws Exception {
          KeyFactory keyFactory = KeyFactory.getInstance("DSA", new BouncyCastleProvider());
          PrivateKey privateKey = keyFactory.generatePrivate(new DSAPrivateKeySpec(PRIVATE_VALUE, P, Q, G));
  
          return (DSAPrivateKey)privateKey;
      }
  
      private static KeyPair newDsaKeyPair() throws Exception {
          KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance("DSA", new BouncyCastleProvider());
          keyPairGenerator.initialize(new DSAParameterSpec(P, Q, G), new SecureRandom(new byte[] {
                  1, 2, 3, 4, 5
          }));
  
          return keyPairGenerator.generateKeyPair();
      }
  
      private static void assertRestoredKeyMatchesOriginal(DSAPrivateKey original, DSAPrivateKey restored) {
          assertThat(original).isInstanceOf(BCDSAPrivateKey.class);
          assertThat(restored).isInstanceOf(BCDSAPrivateKey.class);
          assertThat(restored.getX()).isEqualTo(original.getX());
          assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());
          assertThat(restored.getParams().getQ()).isEqualTo(original.getParams().getQ());
          assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());
          assertThat(restored.getAlgorithm()).isEqualTo("DSA");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getEncoded()).isNotEmpty();
          assertThat(((BCDSAPrivateKey)restored).getBagAttributeKeys().hasMoreElements()).isFalse();
      }
  
      private static DSAPrivateKey serializeAndDeserializeFromBouncyCastleFrame(DSAPrivateKey privateKey) {
          CollectionStore<DSAPrivateKey> store = new CollectionStore<>(List.of(privateKey));
          AtomicReference<DSAPrivateKey> restored = new AtomicReference<>();
  
          Collection<DSAPrivateKey> matches = store.getMatches(new Selector<>() {
              @Override
              public boolean match(DSAPrivateKey key) {
                  try {
                      restored.set(deserialize(serialize(key)));
                      return true;
                  }
                  catch (Exception e) {
                      throw new IllegalStateException("DSA private key serialization failed", e);
                  }
              }
  
              @Override
              public Object clone() {
                  return this;
              }
          });
  
          assertThat(matches).containsExactly(privateKey);
          return restored.get();
      }
  
      private static byte[] serialize(DSAPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(privateKey);
          }
          return serialized.toByteArray();
      }
  
      private static DSAPrivateKey deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (DSAPrivateKey)objectInputStream.readObject();
          }
