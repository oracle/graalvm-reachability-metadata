[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/PKCS12BagAttributeCarrierImplTest.java","edits":[{"oldText":"import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\nimport org.junit.jupiter.api.Test;\n","newText":"import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\nimport org.bouncycastle.jce.ECNamedCurveTable;\nimport org.bouncycastle.jce.provider.JCEECPrivateKey;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECPrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"import java.io.ObjectOutputStream;\nimport java.util.Enumeration;\n","newText":"import java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.Enumeration;\n"},{"oldText":"    private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = PKCSObjectIdentifiers.pkcs_9_at_friendlyName;\n    private static final String FRIENDLY_NAME = \"native image key\";\n\n    @Test\n    void writesAndReadsPkcs12BagAttributes() throws Exception {\n","newText":"    private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = PKCSObjectIdentifiers.pkcs_9_at_friendlyName;\n    private static final String FRIENDLY_NAME = \"native image key\";\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\n            \"39175055993443409939119959424019790719415747144290992075825378743744377387183\");\n\n    @Test\n    void writesAndReadsPkcs12BagAttributes() throws Exception {\n"},{"oldText":"        assertThat(singleBagAttributeKey(restored)).isEqualTo(FRIENDLY_NAME_OID);\n        assertThat(getFriendlyName(restored)).isEqualTo(FRIENDLY_NAME);\n    }\n\n    private static ASN1ObjectIdentifier singleBagAttributeKey(PKCS12BagAttributeCarrierImpl carrier) {\n","newText":"        assertThat(singleBagAttributeKey(restored)).isEqualTo(FRIENDLY_NAME_OID);\n        assertThat(getFriendlyName(restored)).isEqualTo(FRIENDLY_NAME);\n    }\n\n    @Test\n    void writesAndReadsEmptyPkcs12BagAttributes() throws Exception {\n        PKCS12BagAttributeCarrierImpl restored = readCarrier(writeCarrier(new PKCS12BagAttributeCarrierImpl()));\n\n        assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    @Test\n    void javaSerializationOfEcPrivateKeyPreservesPkcs12BagAttributes() throws Exception {\n        JCEECPrivateKey original = newEcPrivateKeyWithBagAttribute();\n\n        JCEECPrivateKey restored = deserializeKey(serializeKey(original));\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restored.getD()).isEqualTo(original.getD());\n        assertThat(singleBagAttributeKey(restored)).isEqualTo(FRIENDLY_NAME_OID);\n        assertThat(getFriendlyName(restored)).isEqualTo(FRIENDLY_NAME);\n    }\n\n    private static JCEECPrivateKey newEcPrivateKeyWithBagAttribute() {\n        ECNamedCurveParameterSpec curveParameters = ECNamedCurveTable.getParameterSpec(\"prime256v1\");\n        JCEECPrivateKey privateKey = new JCEECPrivateKey(\n                \"EC\",\n                new ECPrivateKeySpec(PRIVATE_VALUE, curveParameters));\n\n        privateKey.setBagAttribute(FRIENDLY_NAME_OID, new DERBMPString(FRIENDLY_NAME));\n        return privateKey;\n    }\n\n    private static ASN1ObjectIdentifier singleBagAttributeKey(PKCS12BagAttributeCarrierImpl carrier) {\n"},{"oldText":"    private static String getFriendlyName(PKCS12BagAttributeCarrierImpl carrier) {\n        ASN1Encodable attribute = carrier.getBagAttribute(FRIENDLY_NAME_OID);\n\n        assertThat(attribute).isInstanceOf(DERBMPString.class);\n        return ((DERBMPString)attribute).getString();\n    }\n\n    private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws Exception {\n","newText":"    private static ASN1ObjectIdentifier singleBagAttributeKey(JCEECPrivateKey privateKey) {\n        Enumeration<?> keys = privateKey.getBagAttributeKeys();\n        ASN1ObjectIdentifier key = (ASN1ObjectIdentifier)keys.nextElement();\n\n        assertThat(keys.hasMoreElements()).isFalse();\n        return key;\n    }\n\n    private static String getFriendlyName(PKCS12BagAttributeCarrierImpl carrier) {\n        ASN1Encodable attribute = carrier.getBagAttribute(FRIENDLY_NAME_OID);\n\n        assertThat(attribute).isInstanceOf(DERBMPString.class);\n        return ((DERBMPString)attribute).getString();\n    }\n\n    private static String getFriendlyName(JCEECPrivateKey privateKey) {\n        ASN1Encodable attribute = privateKey.getBagAttribute(FRIENDLY_NAME_OID);\n\n        assertThat(attribute).isInstanceOf(DERBMPString.class);\n        return ((DERBMPString)attribute).getString();\n    }\n\n    private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws Exception {\n"},{"oldText":"    private static PKCS12BagAttributeCarrierImpl readCarrier(byte[] serialized) throws Exception {\n        PKCS12BagAttributeCarrierImpl carrier = new PKCS12BagAttributeCarrierImpl();\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            carrier.readObject(objectInputStream);\n        }\n        return carrier;\n    }\n","newText":"    private static PKCS12BagAttributeCarrierImpl readCarrier(byte[] serialized) throws Exception {\n        PKCS12BagAttributeCarrierImpl carrier = new PKCS12BagAttributeCarrierImpl();\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            carrier.readObject(objectInputStream);\n        }\n        return carrier;\n    }\n\n    private static byte[] serializeKey(JCEECPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JCEECPrivateKey deserializeKey(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCEECPrivateKey)objectInputStream.readObject();\n        }\n    }\n"}]}
