  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.asn1.ASN1Encodable;
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.DERBMPString;
  import org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.Enumeration;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PKCS12BagAttributeCarrierImplTest {
      private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = PKCSObjectIdentifiers.pkcs_9_at_friendlyName;
      private static final String FRIENDLY_NAME = "native image key";
  
      @Test
      void writesAndReadsPkcs12BagAttributes() throws Exception {
          PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();
          original.setBagAttribute(FRIENDLY_NAME_OID, new DERBMPString(FRIENDLY_NAME));
  
          PKCS12BagAttributeCarrierImpl restored = readCarrier(writeCarrier(original));
  
          assertThat(singleBagAttributeKey(restored)).isEqualTo(FRIENDLY_NAME_OID);
          assertThat(getFriendlyName(restored)).isEqualTo(FRIENDLY_NAME);
      }
  
      private static ASN1ObjectIdentifier singleBagAttributeKey(PKCS12BagAttributeCarrierImpl carrier) {
          Enumeration<?> keys = carrier.getBagAttributeKeys();
          ASN1ObjectIdentifier key = (ASN1ObjectIdentifier)keys.nextElement();
  
          assertThat(keys.hasMoreElements()).isFalse();
          return key;
      }
  
      private static String getFriendlyName(PKCS12BagAttributeCarrierImpl carrier) {
          ASN1Encodable attribute = carrier.getBagAttribute(FRIENDLY_NAME_OID);
  
          assertThat(attribute).isInstanceOf(DERBMPString.class);
          return ((DERBMPString)attribute).getString();
      }
  
      private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              carrier.writeObject(objectOutputStream);
          }
          return serialized.toByteArray();
      }
  
      private static PKCS12BagAttributeCarrierImpl readCarrier(byte[] serialized) throws Exception {
          PKCS12BagAttributeCarrierImpl carrier = new PKCS12BagAttributeCarrierImpl();
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              carrier.readObject(objectInputStream);
          }
          return carrier;
      }
  }
