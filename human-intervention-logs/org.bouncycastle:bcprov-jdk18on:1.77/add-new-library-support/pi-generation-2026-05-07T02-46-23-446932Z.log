[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BaseBlockCipherInnerAEADGenericBlockCipherTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.security.Provider;\n\nimport javax.crypto.AEADBadTagException;\nimport javax.crypto.Cipher;\nimport javax.crypto.spec.GCMParameterSpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BaseBlockCipherInnerAEADGenericBlockCipherTest {\n    private static final byte[] KEY = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b,\n        0x0c, 0x0d, 0x0e, 0x0f\n    };\n    private static final byte[] IV = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1a, 0x1b\n    };\n    private static final byte[] AAD = new byte[] {0x21, 0x22, 0x23, 0x24};\n    private static final byte[] PLAINTEXT = \"authenticated message\".getBytes();\n\n    @Test\n    void gcmDecryptWithInvalidTagUsesAeadBadTagExceptionConstructor() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        byte[] ciphertext = encryptWithGcm(provider);\n        ciphertext[ciphertext.length - 1] ^= 0x01;\n\n        Cipher decryptCipher = newGcmCipher(provider, Cipher.DECRYPT_MODE);\n        decryptCipher.updateAAD(AAD);\n\n        assertThatThrownBy(() -> decryptCipher.doFinal(ciphertext))\n            .isInstanceOf(AEADBadTagException.class)\n            .hasMessageContaining(\"mac check in GCM failed\");\n    }\n\n    private static byte[] encryptWithGcm(Provider provider) throws Exception {\n        Cipher encryptCipher = newGcmCipher(provider, Cipher.ENCRYPT_MODE);\n        encryptCipher.updateAAD(AAD);\n\n        byte[] ciphertext = encryptCipher.doFinal(PLAINTEXT);\n\n        assertThat(ciphertext).hasSizeGreaterThan(PLAINTEXT.length);\n        return ciphertext;\n    }\n\n    private static Cipher newGcmCipher(Provider provider, int mode) throws Exception {\n        Cipher cipher = Cipher.getInstance(\"AES/GCM/NoPadding\", provider);\n        cipher.init(mode, new SecretKeySpec(KEY, \"AES\"), new GCMParameterSpec(128, IV));\n        return cipher;\n    }\n}\n"}
