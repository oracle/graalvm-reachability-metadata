  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.URL;
  import java.net.URLConnection;
  import java.net.URLStreamHandler;
  import java.nio.charset.StandardCharsets;
  import java.util.Locale;
  import java.util.TimeZone;
  
  import org.bouncycastle.i18n.LocalizedMessage;
  import org.junit.jupiter.api.Test;
  
  public class LocalizedMessageTest {
      private static final String CLASSPATH_BUNDLE_NAME = "org_bouncycastle.bcprov_jdk18on.LocalizedMessageMessages";
      private static final String IN_MEMORY_BUNDLE_NAME =
              "org_bouncycastle.bcprov_jdk18on.LocalizedMessageInMemoryMessages";
      private static final Locale LOCALE = Locale.ENGLISH;
      private static final TimeZone UTC = TimeZone.getTimeZone("UTC");
  
      @Test
      public void readsResourceBundleWithDefaultClassLoader() throws Exception {
          LocalizedMessage message = new LocalizedMessage(CLASSPATH_BUNDLE_NAME, "localized", new Object[] {"Alice"});
  
          String entry = message.getEntry("greeting", LOCALE, UTC);
  
          assertThat(entry).isEqualTo("Hello Alice");
      }
  
      @Test
      public void readsResourceBundleWithExplicitClassLoader() throws Exception {
          LocalizedMessage message = new LocalizedMessage(IN_MEMORY_BUNDLE_NAME, "localized");
          message.setClassLoader(new InMemoryPropertiesClassLoader(IN_MEMORY_BUNDLE_NAME,
                  "localized.loader=Loaded with explicit class loader\n"));
  
          String entry = message.getEntry("loader", LOCALE, UTC);
  
          assertThat(entry).isEqualTo("Loaded with explicit class loader");
      }
  
      private static final class InMemoryPropertiesClassLoader extends ClassLoader {
          private final String resourcePath;
          private final byte[] properties;
  
          private InMemoryPropertiesClassLoader(String bundleName, String properties) {
              super(LocalizedMessageTest.class.getClassLoader());
              this.resourcePath = bundleName.replace('.', '/') + ".properties";
              this.properties = properties.getBytes(StandardCharsets.ISO_8859_1);
          }
  
          @Override
          public URL getResource(String name) {
              if (!resourcePath.equals(name)) {
                  return super.getResource(name);
              }
              try {
                  return new URL(null, "memory:///" + resourcePath, new PropertiesUrlStreamHandler(properties));
              } catch (IOException e) {
                  throw new IllegalStateException("Failed to create in-memory resource URL", e);
              }
          }
      }
  
      private static final class PropertiesUrlStreamHandler extends URLStreamHandler {
          private final byte[] properties;
  
          private PropertiesUrlStreamHandler(byte[] properties) {
              this.properties = properties;
          }
  
          @Override
          protected URLConnection openConnection(URL url) {
              return new URLConnection(url) {
                  @Override
                  public void connect() {
                  }
  
                  @Override
                  public InputStream getInputStream() {
                      return new ByteArrayInputStream(properties);
                  }
              };
          }
      }
  }
