sets;\n\nimport javax.crypto.AEADBadTagException;\nimport javax.crypto.Cipher;\nimport javax.crypto.spec.GCMParameterSpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jcajce.provider.symmetric.AES;\nimport org.junit.jupiter.api.Test;\n\npublic class BaseBlockCipherInnerAEADGenericBlockCipherTest {\n    private static final byte[] KEY = new byte[] {\n        0x00, 0x01, 0x02, 0x03,\n        0x04, 0x05, 0x06, 0x07,\n        0x08, 0x09, 0x0a, 0x0b,\n        0x0c, 0x0d, 0x0e, 0x0f\n    };\n    private static final byte[] IV = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1a, 0x1b\n    };\n    private static final byte[] AAD = new byte[] {0x21, 0x22, 0x23, 0x24};\n    private static final byte[] PLAINTEXT = \"authenticated message\".getBytes(StandardCharsets.UTF_8);\n\n    @Test\n    void invalidGcmTagUsesAeadBadTagExceptionConstructor() throws Exception {\n        AccessibleAesGcm encryptCipher = new AccessibleAesGcm();\n        encryptCipher.initialize(Cipher.ENCRYPT_MODE);\n        encryptCipher.updateAad(AAD);\n        byte[] ciphertext = encryptCipher.doFinal(PLAINTEXT);\n        assertThat(ciphertext).hasSizeGreaterThan(PLAINTEXT.length);\n\n        ciphertext[ciphertext.length - 1] ^= 0x01;\n\n        AccessibleAesGcm decryptCipher = new AccessibleAesGcm();\n        decryptCipher.initialize(Cipher.DECRYPT_MODE);\n        decryptCipher.updateAad(AAD);\n\n        assertThatThrownBy(() -> decryptCipher.doFinal(ciphertext))\n            .isInstanceOf(AEADBadTagException.class);\n    }\n\n    private static final class AccessibleAesGcm extends AES.GCM {\n        private void initialize(int mode) throws Exception {\n            engineInit(mode, new SecretKeySpec(KEY, \"AES\"), new GCMParameterSpec(128, IV), null);\n        }\n\n        private void updateAad(byte[] input) {\n            engineUpdateAAD(input, 0, input.length);\n        }\n\n        private byte[] doFinal(byte[] input) throws Exception {\n            return engineDoFinal(input, 0, input.length);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778122441757}]}
