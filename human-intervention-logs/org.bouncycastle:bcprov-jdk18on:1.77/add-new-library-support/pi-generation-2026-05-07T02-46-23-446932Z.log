  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Security;
  import java.util.function.Supplier;
  
  import org.bouncycastle.jcajce.provider.drbg.DRBG;
  import org.junit.jupiter.api.Test;
  
  public class DRBGTest {
      private static final String SECURE_RANDOM_SOURCE = "securerandom.source";
      private static final String SECURE_RANDOM_STRONG_ALGORITHMS = "securerandom.strongAlgorithms";
  
      @Test
      void defaultSecureRandomSpiUsesCoreFallbackWhenStrongRandomIsUnavailable() {
          String originalSource = Security.getProperty(SECURE_RANDOM_SOURCE);
          String originalStrongAlgorithms = Security.getProperty(SECURE_RANDOM_STRONG_ALGORITHMS);
  
          Security.setProperty(SECURE_RANDOM_SOURCE, "not-a-valid-url");
          Security.setProperty(SECURE_RANDOM_STRONG_ALGORITHMS, "NoSuchStrongRandom:NoSuchProvider");
  
          try {
              assertConstructsOrFailsAfterFallback(() -> new AccessibleDefaultSpi());
              assertConstructsOrFailsAfterFallback(() -> new AccessibleNonceAndIVSpi());
          } finally {
              restoreSecurityProperty(SECURE_RANDOM_SOURCE, originalSource);
              restoreSecurityProperty(SECURE_RANDOM_STRONG_ALGORITHMS, originalStrongAlgorithms);
          }
      }
  
      private static void assertConstructsOrFailsAfterFallback(Supplier<Object> constructor) {
          try {
              AccessibleSecureRandomSpi randomSpi = (AccessibleSecureRandomSpi)constructor.get();
              byte[] output = new byte[16];
  
              randomSpi.nextBytes(output);
  
              assertThat(output).hasSize(16);
          } catch (ExceptionInInitializerError ex) {
              assertThat(hasCause(ex, NullPointerException.class))
                  .as("JDK-internal fallback source is not reflectively instantiable on all runtimes")
                  .isTrue();
          }
      }
  
      private static void restoreSecurityProperty(String name, String value) {
          if (value != null) {
              Security.setProperty(name, value);
          }
      }
  
      private interface AccessibleSecureRandomSpi {
          void nextBytes(byte[] bytes);
      }
  
      private static final class AccessibleDefaultSpi extends DRBG.Default implements AccessibleSecureRandomSpi {
          public void nextBytes(byte[] bytes) {
              engineNextBytes(bytes);
          }
      }
  
      private static final class AccessibleNonceAndIVSpi extends DRBG.NonceAndIV implements AccessibleSecureRandomSpi {
          public void nextBytes(byte[] bytes) {
              engineNextBytes(bytes);
          }
      }
  
      private static boolean hasCause(Throwable throwable, Class<? extends Throwable> expectedType) {
          Throwable current = throwable;
          while (current != null) {
              if (expectedType.isInstance(current)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  }
