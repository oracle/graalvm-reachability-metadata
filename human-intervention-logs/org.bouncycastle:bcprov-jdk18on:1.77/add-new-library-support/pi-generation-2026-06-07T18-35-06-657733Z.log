tored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());\n        assertThat(restored.getEncoded()).isNotEmpty();\n        assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n", "newText": "    void serializesDstuPrivateKeyEncodedForm() throws Exception {\n        BCDSTU4145PrivateKey privateKey = newDstuPrivateKey();\n        byte[] encoded = privateKey.getEncoded();\n\n        byte[] serialized = serialize(privateKey);\n\n        assertThat(privateKey.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(privateKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(privateKey.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(privateKey.getParams().getOrder()).isEqualTo(DSTU4145_PARAMETERS.getN());\n        assertThat(privateKey.getParams().getCofactor()).isEqualTo(DSTU4145_PARAMETERS.getH().intValue());\n        assertThat(privateKey.getParams().getGenerator()).isNotNull();\n        assertThat(encoded).isNotEmpty();\n        assertThat(serialized).containsSequence(encoded);\n        assertThat(privateKey.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n"}, {"oldText": "    private static final String DSTU4145_CURVE_OID = \"1.2.804.2.1.1.1.1.3.1.1.2.0\";\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"12345678901234567890\");\n", "newText": "    private static final String DSTU4145_CURVE_OID = \"1.2.804.2.1.1.1.1.3.1.1.2.0\";\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"12345678901234567890\");\n    private static final ECDomainParameters DSTU4145_PARAMETERS = DSTU4145NamedCurves.getByOID(\n            new ASN1ObjectIdentifier(DSTU4145_CURVE_OID));\n"}, {"oldText": "        ECDomainParameters parameters = DSTU4145NamedCurves.getByOID(new ASN1ObjectIdentifier(DSTU4145_CURVE_OID));\n        ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(\n                DSTU4145_CURVE_OID,\n                parameters.getCurve(),\n                parameters.getG(),\n                parameters.getN(),\n                parameters.getH(),\n                parameters.getSeed());\n", "newText": "        ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(\n                DSTU4145_CURVE_OID,\n                DSTU4145_PARAMETERS.getCurve(),\n                DSTU4145_PARAMETERS.getG(),\n                DSTU4145_PARAMETERS.getN(),\n                DSTU4145_PARAMETERS.getH(),\n                DSTU4145_PARAMETERS.getSeed());\n"}, {"oldText": "\n    private static BCDSTU4145PrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (BCDSTU4145PrivateKey)objectInputStream.readObject();\n        }\n    }\n", "newText": ""}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 981, "output": 2155, "cacheRead": 74752, "cacheWrite": 0, "totalTokens": 77888, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780857697388, "responseId": "resp_0a78858b2f8d37b1016a25bb620d988196a17f91b6d6348b78"}}
