              public Object run()
              {
                  try
                  {
                      Method m = paramSpec.getClass().getMethod("getName");
  
                      return m.invoke(paramSpec);
                  }
                  catch (Exception e)
                  {
                      // ignore - maybe log?
                  }
  
                  return null;
              }
          });
      }
  
