[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JCERSAPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jce.provider.JCERSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamConstants;\nimport java.math.BigInteger;\nimport java.security.interfaces.RSAPrivateKey;\nimport java.util.Arrays;\nimport java.util.Hashtable;\nimport java.util.Vector;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCERSAPrivateKeyTest {\n    private static final BigInteger MODULUS = new BigInteger(\n            \"da128be3f507273042c14df4163627bff91755d9e251dced1cc04e06c1913851\"\n                    + \"35cab2f32616b2e4ff5b2acf3c701daaedc8b0c1e32de0baab4696b0bb3\"\n                    + \"642da9e3275761bc0dd0bd1c9c98f80b6867c3fd9ed85b5da9b261a9a\"\n                    + \"1b3e73b7f6fa0cc9318cdb7cc525f20dc5f74fc3dea7432af4659325d\"\n                    + \"23df25f72117d488035\",\n            16);\n    private static final BigInteger PRIVATE_EXPONENT = new BigInteger(\n            \"15b46f60d1679f141e865b9f8f1fef1d504f1d6810cfdc9098563102b87c8d\"\n                    + \"26cdbb67abf5a96947f9e4760e3d0deb1a8a35ee6f20389e9966d3ce0c11\"\n                    + \"762887ee9cc0f10db4ae92fd21c2b99d7c45b5a7fe4637337518e8af20b\"\n                    + \"7c71db6759469f9f58e0cfeb8860fd57239e8edc87433a5ebf2cb42e7\",\n            16);\n\n    @Test\n    void serializesAndRestoresJceRsaPrivateKeyParameters() throws Exception {\n        JCERSAPrivateKey restored = deserialize(serializedJceRsaPrivateKey());\n\n        assertRestoredKeyMatches(restored);\n\n        JCERSAPrivateKey roundTripped = deserialize(serialize(restored));\n\n        assertRestoredKeyMatches(roundTripped);\n        assertThat(roundTripped).isEqualTo(restored);\n        assertThat(roundTripped.hashCode()).isEqualTo(restored.hashCode());\n    }\n\n    private static void assertRestoredKeyMatches(JCERSAPrivateKey restored) {\n        assertThat(restored.getModulus()).isEqualTo(MODULUS);\n        assertThat(restored.getPrivateExponent()).isEqualTo(PRIVATE_EXPONENT);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"RSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n        assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static byte[] serializedJceRsaPrivateKey() throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(serialized);\n        output.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        output.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        output.writeByte(ObjectStreamConstants.TC_OBJECT);\n        output.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        output.writeUTF(JCERSAPrivateKey.class.getName());\n        output.writeLong(ObjectStreamClass.lookup(JCERSAPrivateKey.class).getSerialVersionUID());\n        output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n        output.writeShort(0);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        output.writeByte(ObjectStreamConstants.TC_NULL);\n        output.write(serializedObjectPayload(MODULUS));\n        output.write(serializedObjectPayload(new Hashtable<>()));\n        output.write(serializedObjectPayload(new Vector<>()));\n        output.write(serializedObjectPayload(PRIVATE_EXPONENT));\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        return serialized.toByteArray();\n    }\n\n    private static byte[] serializedObjectPayload(Object value) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(value);\n        }\n        byte[] stream = serialized.toByteArray();\n        return Arrays.copyOfRange(stream, 4, stream.length);\n    }\n\n    private static byte[] serialize(RSAPrivateKey privateKey) throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JCERSAPrivateKey deserialize(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCERSAPrivateKey)objectInputStream.readObject();\n        }\n    }\n}\n"}
