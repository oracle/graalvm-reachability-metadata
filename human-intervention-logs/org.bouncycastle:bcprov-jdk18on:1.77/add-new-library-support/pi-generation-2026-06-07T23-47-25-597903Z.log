  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.jcajce.provider.asymmetric.rsa.BCRSAPublicKey;
  import org.bouncycastle.jcajce.provider.asymmetric.rsa.KeyFactorySpi;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.PublicKey;
  import java.security.interfaces.RSAPublicKey;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCRSAPublicKeyTest {
      private static final BigInteger MODULUS = new BigInteger(
              "da128be3f507273042c14df4163627bff91755d9e251dced1cc04e06c1913851"
                      + "35cab2f32616b2e4ff5b2acf3c701daaedc8b0c1e32de0baab4696b0bb3"
                      + "642da9e3275761bc0dd0bd1c9c98f80b6867c3fd9ed85b5da9b261a9a"
                      + "1b3e73b7f6fa0cc9318cdb7cc525f20dc5f74fc3dea7432af4659325d"
                      + "23df25f72117d488035",
              16);
      private static final BigInteger PUBLIC_EXPONENT = BigInteger.valueOf(65537L);
  
      @Test
      void serializesAndRestoresRsaPssPublicKeyAlgorithmIdentifier() throws Exception {
          RSAPublicKey original = newRsaPssPublicKey();
  
          RSAPublicKey restored = (RSAPublicKey)deserialize(serialize(original));
  
          assertRestoredRsaPssPublicKeyMatches(original, restored);
      }
  
      @Test
      void serializesAndRestoresUnsharedRsaPssPublicKeyAlgorithmIdentifier() throws Exception {
          RSAPublicKey original = newRsaPssPublicKey();
  
          RSAPublicKey restored = deserializeUnshared(serializeUnshared(original));
  
          assertRestoredRsaPssPublicKeyMatches(original, restored);
      }
  
      @Test
      void serializesAndRestoresRsaPssPublicKeyInsideObjectArray() throws Exception {
          RSAPublicKey original = newRsaPssPublicKey();
  
          Object[] restored = (Object[])deserialize(serialize(new Object[] {
                  original
          }));
  
          assertRestoredRsaPssPublicKeyMatches(original, (RSAPublicKey)restored[0]);
      }
  
      private static RSAPublicKey newRsaPssPublicKey() throws Exception {
          org.bouncycastle.asn1.pkcs.RSAPublicKey rsaPublicKey =
                  new org.bouncycastle.asn1.pkcs.RSAPublicKey(MODULUS, PUBLIC_EXPONENT);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  PKCSObjectIdentifiers.id_RSASSA_PSS);
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, rsaPublicKey);
          PublicKey publicKey = new KeyFactorySpi().generatePublic(publicKeyInfo);
  
          return (RSAPublicKey)publicKey;
      }
  
      private static void assertRestoredRsaPssPublicKeyMatches(
              RSAPublicKey original,
              RSAPublicKey restored) {
          assertThat(original).isInstanceOf(BCRSAPublicKey.class);
          assertThat(restored).isInstanceOf(BCRSAPublicKey.class);
          assertThat(restored.getModulus()).isEqualTo(original.getModulus());
          assertThat(restored.getPublicExponent()).isEqualTo(original.getPublicExponent());
          assertThat(restored.getAlgorithm()).isEqualTo("RSASSA-PSS");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getEncoded()).isNotEmpty();
      }
  
      private static byte[] serialize(Object object) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(object);
          }
          return serialized.toByteArray();
      }
  
      private static Object deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return objectInputStream.readObject();
          }
      }
  
      private static byte[] serializeUnshared(RSAPublicKey publicKey) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeUnshared(publicKey);
          }
          return serialized.toByteArray();
      }
  
      private static RSAPublicKey deserializeUnshared(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (RSAPublicKey)objectInputStream.readUnshared();
          }
      }
  }
