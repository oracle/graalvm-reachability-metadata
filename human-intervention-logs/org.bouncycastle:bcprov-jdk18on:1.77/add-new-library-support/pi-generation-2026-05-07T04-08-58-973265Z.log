  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.ObjectStreamConstants;
  import java.io.Serializable;
  import java.math.BigInteger;
  
  import org.bouncycastle.jce.provider.JCEDHPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class JCEDHPrivateKeyTest {
      private static final BigInteger X = BigInteger.valueOf(7L);
      private static final BigInteger P = BigInteger.valueOf(23L);
      private static final BigInteger G = BigInteger.valueOf(5L);
      private static final int PRIVATE_VALUE_LENGTH = 11;
  
      @Test
      public void deserializesLegacyDiffieHellmanPrivateKeyPayload() throws Exception {
          JCEDHPrivateKey restored = deserialize(serializedJceDhPrivateKey());
  
          assertThat(restored).isExactlyInstanceOf(JCEDHPrivateKey.class);
          assertPrivateKey(restored);
          assertThat(restored.getAlgorithm()).isEqualTo("DH");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getEncoded()).isNotEmpty();
      }
  
      @Test
      public void serializesAndRestoresDiffieHellmanPrivateKeyParameters() throws Exception {
          JCEDHPrivateKey original = deserialize(serializedJceDhPrivateKey());
  
          JCEDHPrivateKey reparsed = deserialize(serialize(original));
  
          assertThat(reparsed).isExactlyInstanceOf(JCEDHPrivateKey.class);
          assertPrivateKey(reparsed);
      }
  
      private static void assertPrivateKey(JCEDHPrivateKey privateKey) {
          assertThat(privateKey.getX()).isEqualTo(X);
          assertThat(privateKey.getParams().getP()).isEqualTo(P);
          assertThat(privateKey.getParams().getG()).isEqualTo(G);
          assertThat(privateKey.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);
      }
  
      private static byte[] serializedJceDhPrivateKey() throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new JceDhPrivateKeyDescriptorObjectOutputStream(bytes)) {
              outputStream.writeObject(new SerializedDhPrivateKey(X, P, G, PRIVATE_VALUE_LENGTH));
          }
          return bytes.toByteArray();
      }
  
      private static byte[] serialize(JCEDHPrivateKey privateKey) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {
              outputStream.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static JCEDHPrivateKey deserialize(byte[] encoded) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(encoded))) {
              return (JCEDHPrivateKey) inputStream.readObject();
          }
      }
  
      private static final class SerializedDhPrivateKey implements Serializable {
  
