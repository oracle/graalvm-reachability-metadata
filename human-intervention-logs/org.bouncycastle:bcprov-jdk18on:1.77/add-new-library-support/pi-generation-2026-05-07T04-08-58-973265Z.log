t(0);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_NULL);\n        writeSerializedObjectContent(dataOutputStream, x);\n        writeSerializedObjectContent(dataOutputStream, p);\n        writeSerializedObjectContent(dataOutputStream, g);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        dataOutputStream.flush();\n        return output.toByteArray();\n    }\n\n    private static void writeSerializedObjectContent(DataOutputStream output, Object value) throws IOException {\n        byte[] serializedObject = serializeObject(value);\n        output.write(serializedObject, 4, serializedObject.length - 4);\n    }\n\n    private static byte[] serializeObject(Object value) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n}\n"}
