[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JCEElGamalPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamConstants;\nimport java.math.BigInteger;\n\nimport org.bouncycastle.jce.provider.JCEElGamalPrivateKey;\nimport org.bouncycastle.jce.spec.ElGamalParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class JCEElGamalPrivateKeyTest {\n    private static final BigInteger X = BigInteger.valueOf(7L);\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final long SERIAL_VERSION_UID = 4819350091141529678L;\n\n    @Test\n    public void serializationRoundTripRestoresElGamalPrivateKeyParameters() throws Exception {\n        JCEElGamalPrivateKey key = deserializeKey(craftedSerializedKey(X, P, G));\n\n        assertKey(key, X, P, G);\n\n        byte[] serializedKey = serialize(key);\n        JCEElGamalPrivateKey restoredKey = deserializeKey(serializedKey);\n\n        assertKey(restoredKey, X, P, G);\n    }\n\n    private static void assertKey(\n            JCEElGamalPrivateKey key,\n            BigInteger expectedX,\n            BigInteger expectedP,\n            BigInteger expectedG) {\n        ElGamalParameterSpec parameters = key.getParameters();\n\n        assertThat(key.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(key.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(key.getX()).isEqualTo(expectedX);\n        assertThat(parameters.getP()).isEqualTo(expectedP);\n        assertThat(parameters.getG()).isEqualTo(expectedG);\n        assertThat(key.getParams().getP()).isEqualTo(expectedP);\n        assertThat(key.getParams().getG()).isEqualTo(expectedG);\n        assertThat(key.getEncoded()).isNotEmpty();\n    }\n\n    private static byte[] serialize(JCEElGamalPrivateKey key) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(key);\n        }\n        return output.toByteArray();\n    }\n\n    private static JCEElGamalPrivateKey deserializeKey(byte[] serializedKey)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (JCEElGamalPrivateKey)objectInputStream.readObject();\n        }\n    }\n\n    private static byte[] craftedSerializedKey(BigInteger x, BigInteger p, BigInteger g) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        DataOutputStream dataOutputStream = new DataOutputStream(output);\n        dataOutputStream.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        dataOutputStream.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_OBJECT);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        dataOutputStream.writeUTF(JCEElGamalPrivateKey.class.getName());\n        dataOutputStream.writeLong(SERIAL_VERSION_UID);\n        dataOutputStream.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n        dataOutputStream.writeShort(0);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_NULL);\n        writeSerializedObjectContent(dataOutputStream, x);\n        writeSerializedObjectContent(dataOutputStream, p);\n        writeSerializedObjectContent(dataOutputStream, g);\n        dataOutputStream.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        dataOutputStream.flush();\n        return output.toByteArray();\n    }\n\n    private static void writeSerializedObjectContent(DataOutputStream output, Object value) throws IOException {\n        byte[] serializedObject = serializeObject(value);\n        output.write(serializedObject, 4, serializedObject.length - 4);\n    }\n\n    private static byte[] serializeObject(Object value) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(output)) {\n            objectOutputStream.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n}\n"}
