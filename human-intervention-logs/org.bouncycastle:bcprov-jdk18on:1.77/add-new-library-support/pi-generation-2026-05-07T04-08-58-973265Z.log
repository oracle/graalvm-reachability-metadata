[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JCEElGamalPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamConstants;\nimport java.io.Serializable;\nimport java.math.BigInteger;\n\nimport org.bouncycastle.jce.provider.JCEElGamalPrivateKey;\nimport org.bouncycastle.jce.spec.ElGamalParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class JCEElGamalPrivateKeyTest {\n    private static final BigInteger X = BigInteger.valueOf(7L);\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger G = BigInteger.valueOf(5L);\n\n    @Test\n    public void deserializesElGamalPrivateKeyPayload() throws Exception {\n        JCEElGamalPrivateKey restored = deserialize(serializedJceElGamalPrivateKey());\n\n        assertThat(restored).isExactlyInstanceOf(JCEElGamalPrivateKey.class);\n        assertPrivateKey(restored);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n    }\n\n    @Test\n    public void serializesAndRestoresElGamalPrivateKeyParameters() throws Exception {\n        JCEElGamalPrivateKey original = deserialize(serializedJceElGamalPrivateKey());\n\n        JCEElGamalPrivateKey reparsed = deserialize(serialize(original));\n\n        assertThat(reparsed).isExactlyInstanceOf(JCEElGamalPrivateKey.class);\n        assertPrivateKey(reparsed);\n    }\n\n    private static void assertPrivateKey(JCEElGamalPrivateKey privateKey) {\n        ElGamalParameterSpec parameters = privateKey.getParameters();\n\n        assertThat(privateKey.getX()).isEqualTo(X);\n        assertThat(parameters.getP()).isEqualTo(P);\n        assertThat(parameters.getG()).isEqualTo(G);\n        assertThat(privateKey.getParams().getP()).isEqualTo(P);\n        assertThat(privateKey.getParams().getG()).isEqualTo(G);\n    }\n\n    private static byte[] serializedJceElGamalPrivateKey() throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JceElGamalPrivateKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedElGamalPrivateKey(X, P, G));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serialize(JCEElGamalPrivateKey privateKey) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JCEElGamalPrivateKey deserialize(byte[] encoded) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(encoded))) {\n            return (JCEElGamalPrivateKey) inputStream.readObject();\n        }\n    }\n\n    private static final class SerializedElGamalPrivateKey implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final BigInteger x;\n        private final BigInteger p;\n        private final BigInteger g;\n\n        private SerializedElGamalPrivateKey(BigInteger x, BigInteger p, BigInteger g) {\n            this.x = x;\n            this.p = p;\n            this.g = g;\n        }\n\n        private void writeObject(ObjectOutputStream outputStream) throws IOException {\n            outputStream.writeObject(x);\n            outputStream.writeObject(p);\n            outputStream.writeObject(g);\n        }\n    }\n\n    private static final class JceElGamalPrivateKeyDescriptorObjectOutputStream extends ObjectOutputStream {\n        private JceElGamalPrivateKeyDescriptorObjectOutputStream(ByteArrayOutputStream bytes) throws IOException {\n            super(bytes);\n        }\n\n        @Override\n        protected void writeClassDescriptor(ObjectStreamClass descriptor) throws IOException {\n            if (descriptor.getName().equals(SerializedElGamalPrivateKey.class.getName())) {\n                writeUTF(JCEElGamalPrivateKey.class.getName());\n                writeLong(ObjectStreamClass.lookup(JCEElGamalPrivateKey.class).getSerialVersionUID());\n                writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n                writeShort(0);\n                return;\n            }\n            super.writeClassDescriptor(descriptor);\n        }\n    }\n}\n"}
