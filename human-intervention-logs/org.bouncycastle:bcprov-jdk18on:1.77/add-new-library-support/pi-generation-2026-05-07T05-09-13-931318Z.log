      private static void assertPrivateKey(JDKDSAPrivateKey privateKey) {
          assertThat(privateKey.getX()).isEqualTo(X);
          assertThat(privateKey.getParams().getP()).isEqualTo(P);
          assertThat(privateKey.getParams().getQ()).isEqualTo(Q);
          assertThat(privateKey.getParams().getG()).isEqualTo(G);
      }
  
      private static void assertRestoredPrivateKey(JDKDSAPrivateKey privateKey) {
          assertThat(privateKey.getAlgorithm()).isEqualTo("DSA");
          assertThat(privateKey.getFormat()).isEqualTo("PKCS#8");
          assertThat(privateKey.getX()).isEqualTo(RESTORED_X);
          assertThat(privateKey.getParams().getP()).isEqualTo(RESTORED_P);
          assertThat(privateKey.getParams().getQ()).isEqualTo(RESTORED_Q);
          assertThat(privateKey.getParams().getG()).isEqualTo(RESTORED_G);
          assertThat(privateKey.getBagAttributeKeys().hasMoreElements()).isFalse();
