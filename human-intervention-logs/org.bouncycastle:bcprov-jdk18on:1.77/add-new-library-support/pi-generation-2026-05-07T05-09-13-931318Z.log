ld have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamConstants;\nimport java.io.Serializable;\nimport java.math.BigInteger;\nimport java.security.interfaces.DSAParams;\n\nimport org.bouncycastle.jce.provider.JDKDSAPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class JDKDSAPublicKeyTest {\n    private static final BigInteger Y = BigInteger.valueOf(18L);\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger Q = BigInteger.valueOf(11L);\n    private static final BigInteger G = BigInteger.valueOf(4L);\n\n    @Test\n    public void deserializesLegacyDsaPublicKeyPayload() throws Exception {\n        JDKDSAPublicKey publicKey = deserialize(serializedJdkDsaPublicKey());\n\n        assertThat(publicKey).isExactlyInstanceOf(JDKDSAPublicKey.class);\n        assertPublicKey(publicKey);\n        assertThat(publicKey.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(publicKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(publicKey.getEncoded()).isNotEmpty();\n        assertThat(publicKey.toString()).contains(\"DSA Public Key\", Y.toString(16));\n    }\n\n    @Test\n    public void javaSerializationRoundTripsDsaPublicKeyParameters() throws Exception {\n        JDKDSAPublicKey original = deserialize(serializedJdkDsaPublicKey());\n\n        JDKDSAPublicKey restored = deserialize(serialize(original));\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertPublicKey(restored);\n    }\n\n    private static void assertPublicKey(JDKDSAPublicKey publicKey) {\n        DSAParams parameters = publicKey.getParams();\n\n        assertThat(publicKey.getY()).isEqualTo(Y);\n        assertThat(parameters).isNotNull();\n        assertThat(parameters.getP()).isEqualTo(P);\n        assertThat(parameters.getQ()).isEqualTo(Q);\n        assertThat(parameters.getG()).isEqualTo(G);\n    }\n\n    private static byte[] serialize(JDKDSAPublicKey publicKey) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JDKDSAPublicKey deserialize(byte[] encoded) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(encoded))) {\n            return (JDKDSAPublicKey) inputStream.readObject();\n        }\n    }\n\n    private static byte[] serializedJdkDsaPublicKey() throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JdkDsaPublicKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedDsaPublicKey(Y, P, Q, G));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static final class SerializedDsaPublicKey implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final BigInteger y;\n        private final BigInteger p;\n        private final BigInteger q;\n        private final BigInteger g;\n\n        private SerializedDsaPublicKey(BigInteger y, BigInteger p, BigInteger q, BigInteger g) {\n            this.y = y;\n            this.p = p;\n            this.q = q;\n            this.g = g;\n        }\n\n        private void writeObject(ObjectOutputStream outputStream) throws IOException {\n            outputStream.writeObject(y);\n            outputStream.writeObject(p);\n            outputStream.writeObject(q);\n            outputStream.writeObject(g);\n        }\n    }\n\n    private static final class JdkDsaPublicKeyDescriptorObjectOutputStream extends ObjectOutputStream {\n        private JdkDsaPublicKeyDescriptorObjectOutputStream(ByteArrayOutputStream bytes) throws IOException {\n            super(bytes);\n        }\n\n        @Override\n        protected void writeClassDescriptor(ObjectStreamClass descriptor) throws IOException {\n            if (descriptor.getName().equals(SerializedDsaPublicKey.class.getName())) {\n                writeUTF(JDKDSAPublicKey.class.getName());\n                writeLong(ObjectStreamClass.lookup(JDKDSAPublicKey.class).getSerialVersionUID());\n                writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n                writeShort(0);\n                return;\n            }\n            super.writeClassDescriptor(descriptor);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 646, "output": 1793, "cacheRead": 17920, "cacheWrite": 0, "totalTokens": 20359, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778130516969, "responseId": "resp_0b73063cb9f920ab0169fc1e554ebc81959c5b0f864cedbdfb"}}
