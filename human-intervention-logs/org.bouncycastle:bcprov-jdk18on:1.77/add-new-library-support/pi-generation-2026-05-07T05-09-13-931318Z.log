t java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamConstants;\nimport java.io.Serializable;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\nimport java.util.ArrayList;\nimport java.util.Hashtable;\nimport java.util.IdentityHashMap;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Vector;\n\nimport org.bouncycastle.jce.provider.JDKDSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class JDKDSAPrivateKeyTest {\n    private static final BigInteger X = TrackedBigInteger.trackedValueOf(3L);\n    private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);\n    private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);\n    private static final BigInteger RESTORED_X = TrackedBigInteger.trackedValueOf(7L);\n    private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);\n    private static final BigInteger RESTORED_Q = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(2L);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void deserializesLegacyDsaPrivateKeyPayload() throws Exception {\n        JDKDSAPrivateKey restored = deserialize(serializedJdkDsaPrivateKey());\n\n        assertThat(restored).isExactlyInstanceOf(JDKDSAPrivateKey.class);\n        assertPrivateKey(restored);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n        assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    @Test\n    public void serializesAndRestoresDsaPrivateKeyParameters() throws Exception {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n\n        JDKDSAPrivateKey reparsed = deserialize(serialize(original));\n\n        assertThat(reparsed).isExactlyInstanceOf(JDKDSAPrivateKey.class);\n        assertPrivateKey(reparsed);\n        assertThat(reparsed.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    @Test\n    public void serializationHooksUseObjectStreamOverridePath() throws Throwable {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(original, (ObjectOutputStream) outputStream);\n\n        assertThat(outputStream.objects()).containsExactly(X, P, Q, G, new Hashtable<>(), new Vector<>());\n\n        JDKDSAPrivateKey restored = deserialize(serializedJdkDsaPrivateKey());\n        SequenceObjectInputStream inputStream = new SequenceObjectInputStream(\n                RESTORED_X,\n                RESTORED_P,\n                RESTORED_Q,\n                RESTORED_G,\n                new Hashtable<>(),\n                new Vector<>());\n\n        invokeReadObject(restored, inputStream);\n\n        assertRestoredPrivateKey(restored);\n    }\n\n    @Test\n    public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n\n        byte[] writtenParameters = invokeWriteObject(original);\n\n        assertThat(readObjects(writtenParameters))\n                .containsExactly(X, P, Q, G, new Hashtable<>(), new Vector<>());\n\n        JDKDSAPrivateKey restored = deserialize(serializedJdkDsaPrivateKey());\n        byte[] restoredParameterStream = writeObjects(\n                payloadKeyRepresenting(RESTORED_X),\n                payloadKeyRepresenting(RESTORED_P),\n                payloadKeyRepresenting(RESTORED_Q),\n                payloadKeyRepresenting(RESTORED_G),\n                new Hashtable<>(),\n                new Vector<>());\n\n        try (ObjectInputStream inputStream = new ResolvingObjectInputStream(restoredParameterStream)) {\n            invokeReadObject(restored, inputStream);\n        }\n\n        assertRestoredPrivateKey(restored);\n    }\n\n    private static void assertPrivateKey(JDKDSAPrivateKey privateKey) {\n        assertThat(privateKey.getX()).isEqualTo(X);\n        assertThat(privateKey.getParams().getP()).isEqualTo(P);\n        assertThat(privateKey.getParams().getQ()).isEqualTo(Q);\n        assertThat(privateKey.getParams().getG()).isEqualTo(G);\n    }\n\n    private static void assertRestoredPrivateKey(JDKDSAPrivateKey privateKey) {\n        assertThat(privateKey.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(privateKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(privateKey.getX()).isEqualTo(RESTORED_X);\n        assertThat(privateKey.getParams().getP()).isEqualTo(RESTORED_P);\n        assertThat(privateKey.getParams().getQ()).isEqualTo(RESTORED_Q);\n        assertThat(privateKey.getParams().getG()).isEqualTo(RESTORED_G);\n        assertThat(privateKey.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static byte[] serializedJdkDsaPrivateKey() throws IOException {\n        return serializedJdkDsaPrivateKey(X, P, Q, G);\n    }\n\n    private static byte[] serializedJdkDsaPrivateKey(\n            BigInteger x,\n            BigInteger p,\n            BigInteger q,\n            BigInteger g) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JdkDsaPrivateKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedDsaPrivateKey(x, p, q, g));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serialize(JDKDSAPrivateKey privateKey) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JDKDSAPrivateKey deserialize(byte[] encoded) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(encoded))) {\n            return (JDKDSAPrivateKey) inputStream.readObject();\n        }\n    }\n\n    private static byte[] invokeWriteObject(JDKDSAPrivateKey privateKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ReplacingObjectOutputStream(output, privateKey)) {\n            WRITE_OBJECT.invokeExact(privateKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n\n    private static void invokeReadObject(JDKDSAPrivateKey privateKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(privateKey, inputStream);\n    }\n\n    private static byte[] writeObjects(Object... objects) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            for (Object object : objects) {\n                outputStream.writeObject(object);\n            }\n        }\n        return output.toByteArray();\n    }\n\n    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ResolvingObjectInputStream(bytes)) {\n            return new Object[] {\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject()\n            };\n        }\n    }\n\n    private static JDKDSAPrivateKey payloadKeyRepresenting(BigInteger value)\n            throws IOException, ClassNotFoundException {\n        BigInteger copiedValue = new BigInteger(value.toString());\n        return deserialize(serializedJdkDsaPrivateKey(\n                copiedValue,\n                new BigInteger(\"101\"),\n                new BigInteger(\"29\"),\n                new BigInteger(\"7\")));\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPrivateKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JDKDSAPrivateKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPrivateKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JDKDSAPrivateKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final List<Object> objects = new ArrayList<>();\n\n        private RecordingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects.add(object);\n        }\n\n        private List<Object> objects() {\n            return objects;\n        }\n    }\n\n    private static final class SequenceObjectInputStream extends ObjectInputStream {\n        private final Object[] objects;\n        private int index;\n\n        private SequenceObjectInputStream(Object... objects) throws IOException {\n            super();\n            this.objects = objects;\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return objects[index++];\n        }\n    }\n\n    private static final class ReplacingObjectOutputStream extends ObjectOutputStream {\n        private final Map<Object, Object> replacements = new IdentityHashMap<>();\n\n        private ReplacingObjectOutputStream(ByteArrayOutputStream bytes, JDKDSAPrivateKey privateKey)\n                throws IOException, ClassNotFoundException {\n            super(bytes);\n            enableReplaceObject(true);\n            replacements.put(privateKey.getX(), payloadKeyRepresenting(privateKey.getX()));\n            replacements.put(privateKey.getParams().getP(), payloadKeyRepresenting(privateKey.getParams().getP()));\n            replacements.put(privateKey.getParams().getQ(), payloadKeyRepresenting(privateKey.getParams().getQ()));\n            replacements.put(privateKey.getParams().getG(), payloadKeyRepresenting(privateKey.getParams().getG()));\n        }\n\n        @Override\n        protected Object replaceObject(Object object) throws IOException {\n            Object replacement = replacements.get(object);\n            if (replacement != null) {\n                return replacement;\n            }\n            return object;\n        }\n    }\n\n    private static final class ResolvingObjectInputStream extends ObjectInputStream {\n        private ResolvingObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) throws IOException {\n            if (object instanceof JDKDSAPrivateKey privateKey) {\n                return privateKey.getX();\n            }\n            return object;\n        }\n    }\n\n    private static final class SerializedDsaPrivateKey implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final BigInteger x;\n        private final BigInteger p;\n        private final BigInteger q;\n        private final BigInteger g;\n\n        private SerializedDsaPrivateKey(BigInteger x, BigInteger p, BigInteger q, BigInteger g) {\n            this.x = x;\n            this.p = p;\n            this.q = q;\n            this.g = g;\n        }\n\n        private void writeObject(ObjectOutputStream outputStream) throws IOException {\n            outputStream.writeObject(x);\n            outputStream.writeObject(p);\n            outputStream.writeObject(q);\n            outputStream.writeObject(g);\n            outputStream.writeObject(new Hashtable<>());\n            outputStream.writeObject(new Vector<>());\n        }\n    }\n\n    private static final class TrackedBigInteger extends BigInteger {\n        private static final long serialVersionUID = 1L;\n\n        private TrackedBigInteger(long value) {\n            super(Long.toString(value));\n        }\n\n        private static TrackedBigInteger trackedValueOf(long value) {\n            return new TrackedBigInteger(value);\n        }\n    }\n\n    private static final class JdkDsaPrivateKeyDescriptorObjectOutputStream extends ObjectOutputStream {\n        private JdkDsaPrivateKeyDescriptorObjectOutputStream(ByteArrayOutputStream bytes) throws IOException {\n            super(bytes);\n        }\n\n        @Override\n        protected void writeClassDescriptor(ObjectStreamClass descriptor) throws IOException {\n            if (descriptor.getName().equals(SerializedDsaPrivateKey.class.getName())) {\n                writeUTF(JDKDSAPrivateKey.class.getName());\n                writeLong(ObjectStreamClass.lookup(JDKDSAPrivateKey.class).getSerialVersionUID());\n                writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n                writeShort(0);\n                return;\n            }\n            super.writeClassDescriptor(descriptor);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778130507188}, {"role": "toolResult", "toolCallId": "call_ubuIBSRZYyx56vwNjQ96wh2i|fc_0b73063cb9f920ab0169fc1e4af12c8195a76c7b001d1bf5be", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.OutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\nimport java.security.GeneralSecurityException;\nimport java.security.KeyFactory;\nimport java.security.interfaces.DSAParams;\nimport java.security.spec.DSAPublicKeySpec;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSAPublicKeyTest {\n    private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);\n    private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);\n    private static final BigInteger Y = BigInteger.valueOf(18L);\n    private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);\n    private static final BigInteger RESTORED_Q = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(14L);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void javaSerializationRoundTripsDsaPublicKeyParameters() throws Exception {\n        BCDSAPublicKey original = createPublicKeyWithParameters();\n\n        BCDSAPublicKey restored = deserialize(serialize(original), BCDSAPublicKey.class);\n        DSAParams restoredParameters = restored.getParams();\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restoredParameters).isNotNull();\n        assertThat(restoredParameters.getP()).isEqualTo(P);\n        assertThat(restoredParameters.getQ()).isEqualTo(Q);\n        assertThat(restoredParameters.getG()).isEqualTo(G);\n    }\n\n    @Test\n    public void serializationHooksWriteAndRestoreDsaPublicKeyParameters() throws Throwable {\n        BCDSAPublicKey original = createPublicKeyWithParameters();\n\n        byte[] writtenParameters = invokeWriteObject(original);\n\n        assertThat(readObjects(writtenParameters)).containsExactly(P, Q, G);\n\n        BCDSAPublicKey restored = createPublicKeyWithParameters();\n        byte[] restoredParameterStream = writeObjects(RESTORED_P, RESTORED_Q, RESTORED_G);\n\n        try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {\n            invokeReadObject(restored, inputStream);\n        }\n        DSAParams restoredParameters = restored.getParams();\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);\n        assertThat(restoredParameters.getQ()).isEqualTo(RESTORED_Q);\n        assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);\n    }\n\n    @Test\n    public void javaSerializationRoundTripsDsaPublicKeyWithoutParameters() throws Exception {\n        BCDSAPublicKey original = createPublicKeyWithoutParameters();\n\n        BCDSAPublicKey restored = deserialize(serialize(original), BCDSAPublicKey.class);\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restored.getParams()).isNull();\n    }\n\n    private static BCDSAPublicKey createPublicKeyWithParameters() throws GeneralSecurityException {\n        DSAPublicKeySpec keySpec = new DSAPublicKeySpec(Y, P, Q, G);\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", new BouncyCastleProvider());\n\n        return (BCDSAPublicKey) keyFactory.generatePublic(keySpec);\n    }\n\n    private static BCDSAPublicKey createPublicKeyWithoutParameters() throws IOException {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(X9ObjectIdentifiers.id_dsa);\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(Y));\n\n        return new BCDSAPubli