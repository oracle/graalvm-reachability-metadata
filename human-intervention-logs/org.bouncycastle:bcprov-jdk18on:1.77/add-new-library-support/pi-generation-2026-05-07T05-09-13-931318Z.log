[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JDKDSAPublicKeyTest.java","edits":[{"oldText":"import java.io.Serializable;\nimport java.math.BigInteger;\nimport java.security.interfaces.DSAParams;","newText":"import java.io.Serializable;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\nimport java.security.interfaces.DSAParams;\nimport java.util.ArrayList;\nimport java.util.List;"},{"oldText":"    private static final BigInteger Y = TrackedBigInteger.trackedValueOf(18L);\n    private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);\n    private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);","newText":"    private static final BigInteger Y = TrackedBigInteger.trackedValueOf(18L);\n    private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);\n    private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);\n    private static final BigInteger RESTORED_Y = TrackedBigInteger.trackedValueOf(21L);\n    private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);\n    private static final BigInteger RESTORED_Q = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(2L);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();"},{"oldText":"    @Test\n    public void javaSerializationRoundTripsDsaPublicKeyParameters() throws Exception {\n        JDKDSAPublicKey original = deserialize(serializedJdkDsaPublicKey());\n\n        JDKDSAPublicKey restored = deserialize(serialize(original));\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertPublicKey(restored);\n    }\n\n    private static void assertPublicKey(JDKDSAPublicKey publicKey) {","newText":"    @Test\n    public void javaSerializationRoundTripsDsaPublicKeyParameters() throws Exception {\n        JDKDSAPublicKey original = deserialize(serializedJdkDsaPublicKey());\n\n        JDKDSAPublicKey restored = deserialize(serialize(original));\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertPublicKey(restored);\n    }\n\n    @Test\n    public void serializationHooksUseObjectStreamOverridePath() throws Throwable {\n        JDKDSAPublicKey original = deserialize(serializedJdkDsaPublicKey());\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(original, (ObjectOutputStream) outputStream);\n\n        assertThat(outputStream.objects()).containsExactly(Y, P, Q, G);\n\n        JDKDSAPublicKey restored = deserialize(serializedJdkDsaPublicKey());\n        SequenceObjectInputStream inputStream = new SequenceObjectInputStream(\n                RESTORED_Y,\n                RESTORED_P,\n                RESTORED_Q,\n                RESTORED_G);\n\n        invokeReadObject(restored, inputStream);\n\n        assertPublicKey(restored, RESTORED_Y, RESTORED_P, RESTORED_Q, RESTORED_G);\n    }\n\n    private static void assertPublicKey(JDKDSAPublicKey publicKey) {\n        assertPublicKey(publicKey, Y, P, Q, G);\n    }\n\n    private static void assertPublicKey(\n            JDKDSAPublicKey publicKey,\n            BigInteger expectedY,\n            BigInteger expectedP,\n            BigInteger expectedQ,\n            BigInteger expectedG) {"},{"oldText":"        assertThat(publicKey.getY()).isEqualTo(Y);\n        assertThat(parameters).isNotNull();\n        assertThat(parameters.getP()).isEqualTo(P);\n        assertThat(parameters.getQ()).isEqualTo(Q);\n        assertThat(parameters.getG()).isEqualTo(G);\n    }\n\n    private static byte[] serialize(JDKDSAPublicKey publicKey) throws IOException {","newText":"        assertThat(publicKey.getY()).isEqualTo(expectedY);\n        assertThat(parameters).isNotNull();\n        assertThat(parameters.getP()).isEqualTo(expectedP);\n        assertThat(parameters.getQ()).isEqualTo(expectedQ);\n        assertThat(parameters.getG()).isEqualTo(expectedG);\n    }\n\n    private static void invokeReadObject(JDKDSAPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(publicKey, inputStream);\n    }\n\n    private static byte[] serialize(JDKDSAPublicKey publicKey) throws IOException {"},{"oldText":"    private static byte[] serializedJdkDsaPublicKey() throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JdkDsaPublicKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedDsaPublicKey(Y, P, Q, G));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static final class SerializedDsaPublicKey implements Serializable {","newText":"    private static byte[] serializedJdkDsaPublicKey() throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JdkDsaPublicKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedDsaPublicKey(Y, P, Q, G));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JDKDSAPublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JDKDSAPublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final List<Object> objects = new ArrayList<>();\n\n        private RecordingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects.add(object);\n        }\n\n        private List<Object> objects() {\n            return objects;\n        }\n    }\n\n    private static final class SequenceObjectInputStream extends ObjectInputStream {\n        private final Object[] objects;\n        private int index;\n\n        private SequenceObjectInputStream(Object... objects) throws IOException {\n            super();\n            this.objects = objects;\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return objects[index++];\n        }\n    }\n\n    private static final class SerializedDsaPublicKey implements Serializable {"}]}
