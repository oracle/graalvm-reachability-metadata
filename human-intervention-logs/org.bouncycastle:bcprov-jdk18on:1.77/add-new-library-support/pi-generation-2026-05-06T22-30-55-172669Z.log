[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDSAPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.interfaces.DSAParams;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.DSAParameter;\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSAPrivateKeyTest {\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger Q = BigInteger.valueOf(11L);\n    private static final BigInteger G = BigInteger.valueOf(4L);\n    private static final BigInteger X = BigInteger.valueOf(3L);\n\n    @Test\n    public void serializesAndRestoresDsaPrivateKeyParameters() throws Exception {\n        BCDSAPrivateKey original = createPrivateKey();\n\n        BCDSAPrivateKey restored = roundTrip(original);\n        DSAParams restoredParameters = restored.getParams();\n\n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(X);\n        assertThat(restoredParameters.getP()).isEqualTo(P);\n        assertThat(restoredParameters.getQ()).isEqualTo(Q);\n        assertThat(restoredParameters.getG()).isEqualTo(G);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restored).isEqualTo(original);\n    }\n\n    private static BCDSAPrivateKey createPrivateKey() throws Exception {\n        DSAParameter parameters = new DSAParameter(P, Q, G);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                X9ObjectIdentifiers.id_dsa,\n                parameters.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(X));\n\n        return new BCDSAPrivateKey(privateKeyInfo);\n    }\n\n    private static BCDSAPrivateKey roundTrip(BCDSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {\n            objectOutput.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream objectInput = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {\n            return (BCDSAPrivateKey)objectInput.readObject();\n        }\n    }\n}\n"}
