lass, outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(P, G);\n        assertThat(outputStream.writtenInt()).isEqualTo(PUBLIC_VALUE_LENGTH);\n\n        BCDHPublicKey restored = createPublicKey(P, G);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                RESTORED_P,\n                RESTORED_G,\n                PUBLIC_VALUE_LENGTH);\n\n        invokeSerializationHook(restored, \"readObject\", ObjectInputStream.class, inputStream);\n        DHParameterSpec restoredParameters = restored.getParams();\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);\n        assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);\n        assertThat(restoredParameters.getL()).isEqualTo(PUBLIC_VALUE_LENGTH);\n    }\n\n    private static BCDHPublicKey createPublicKey(BigInteger p, BigInteger g) throws Exception {\n        DHParameter parameters = new DHParameter(p, g, PUBLIC_VALUE_LENGTH);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                PKCSObjectIdentifiers.dhKeyAgreement,\n                parameters.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(Y));\n\n        return new BCDHPublicKey(publicKeyInfo);\n    }\n\n    private static void invokeSerializationHook(\n            BCDHPublicKey publicKey,\n            String methodName,\n            Class<?> streamType,\n            Object stream) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n        MethodHandle methodHandle = lookup.findSpecial(\n                BCDHPublicKey.class,\n                methodName,\n                MethodType.methodType(void.class, streamType),\n                BCDHPublicKey.class);\n        methodHandle.invokeWithArguments(publicKey, stream);\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final Object[] objects = new Object[2];\n        private int objectCount;\n        private int intValue;\n\n        private RecordingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects[objectCount] = object;\n            objectCount++;\n        }\n\n        @Override\n        public void writeInt(int value) {\n            intValue = value;\n        }\n\n        private Object[] writtenObjects() {\n            Object[] written = new Object[objectCount];\n            System.arraycopy(objects, 0, written, 0, objectCount);\n            return written;\n        }\n\n        private int writtenInt() {\n            return intValue;\n        }\n    }\n\n    private static final class ReplayingObjectInputStream extends ObjectInputStream {\n        private final Object[] objects;\n        private final int intValue;\n        private int objectIndex;\n\n        private ReplayingObjectInputStream(Object firstObject, Object secondObject, int intValue) throws IOException {\n            super();\n            this.objects = new Object[] {firstObject, secondObject};\n            this.intValue = intValue;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            Object object = objects[objectIndex];\n            objectIndex++;\n            return object;\n        }\n\n        @Override\n        public int readInt() {\n            return intValue;\n        }\n    }\n}\n"}
