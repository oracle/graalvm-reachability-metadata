[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDHPublicKeyTest.java","edits":[{"oldText":"        invokeSerializationHook(original, \"writeObject\", ObjectOutputStream.class, outputStream);\n","newText":"        invokeWriteObject(original, outputStream);\n"},{"oldText":"        invokeSerializationHook(restored, \"readObject\", ObjectInputStream.class, inputStream);\n","newText":"        invokeReadObject(restored, inputStream);\n"},{"oldText":"    private static void invokeSerializationHook(\n            BCDHPublicKey publicKey,\n            String methodName,\n            Class<?> streamType,\n            Object stream) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n        MethodHandle methodHandle = lookup.findSpecial(\n                BCDHPublicKey.class,\n                methodName,\n                MethodType.methodType(void.class, streamType),\n                BCDHPublicKey.class);\n        methodHandle.invokeWithArguments(publicKey, stream);\n    }\n","newText":"    private static void invokeWriteObject(BCDHPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n        MethodHandle methodHandle = lookup.findVirtual(\n                BCDHPublicKey.class,\n                \"writeObject\",\n                MethodType.methodType(void.class, ObjectOutputStream.class));\n        methodHandle.invoke(publicKey, outputStream);\n    }\n\n    private static void invokeReadObject(BCDHPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n        MethodHandle methodHandle = lookup.findVirtual(\n                BCDHPublicKey.class,\n                \"readObject\",\n                MethodType.methodType(void.class, ObjectInputStream.class));\n        methodHandle.invoke(publicKey, inputStream);\n    }\n"}]}
