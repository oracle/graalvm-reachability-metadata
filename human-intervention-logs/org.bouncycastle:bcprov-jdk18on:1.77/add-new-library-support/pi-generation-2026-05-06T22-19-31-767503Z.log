778106437116, "responseId": "resp_07243418edd0b4600169fbc04627448195969c3da7edce05a0"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_n0lLlob4nzZ8NoHJbjbaVCpJ|fc_07243418edd0b4600169fbc04ff1488195bc50e1c421a05101", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\n\nimport javax.crypto.spec.DHParameterSpec;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.DHParameter;\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDHPublicKeyTest {\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger Y = BigInteger.valueOf(8L);\n    private static final BigInteger RESTORED_P = BigInteger.valueOf(47L);\n    private static final BigInteger RESTORED_G = BigInteger.valueOf(2L);\n    private static final int PUBLIC_VALUE_LENGTH = 5;\n\n    @Test\n    public void serializesAndRestoresDiffieHellmanPublicKeyParameters() throws Throwable {\n        BCDHPublicKey original = createPublicKey(P, G);\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        invokeWriteObject(original, outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(P, G);\n        assertThat(outputStream.writtenInt()).isEqualTo(PUBLIC_VALUE_LENGTH);\n\n        BCDHPublicKey restored = createPublicKey(P, G);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                RESTORED_P,\n                RESTORED_G,\n                PUBLIC_VALUE_LENGTH);\n\n        invokeReadObject(restored, inputStream);\n        DHParameterSpec restoredParameters = restored.getParams();\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);\n        assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);\n        assertThat(restoredParameters.getL()).isEqualTo(PUBLIC_VALUE_LENGTH);\n    }\n\n    private static BCDHPublicKey createPublicKey(BigInteger p, BigInteger g) throws Exception {\n        DHParameter parameters = new DHParameter(p, g, PUBLIC_VALUE_LENGTH);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                PKCSObjectIdentifiers.dhKeyAgreement,\n                parameters.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(Y));\n\n        return new BCDHPublicKey(publicKeyInfo);\n    }\n\n    private static void invokeWriteObject(BCDHPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n        MethodHandle methodHandle = lookup.findVirtual(\n                BCDHPublicKey.class,\n                \"writeObject\",\n                MethodType.methodType(void.class, ObjectOutputStream.class));\n        methodHandle.invoke(publicKey, outputStream);\n    }\n\n    private static void invokeReadObject(BCDHPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n        MethodHandle methodHandle = lookup.findVirtual(\n                BCDHPublicKey.class,\n                \"readObject\",\n                MethodType.methodType(void.class, ObjectInputStream.class));\n        methodHandle.invoke(publicKey, inputStream);\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final Object[] objects = new Object[2];\n        private int objectCount;\n        private int intValue;\n\n        private RecordingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects[objectCount] = object;\n            objectCount++;\n        }\n\n        @Override\n        public void writeInt(int value) {\n            intValue = value;\n        }\n\n        private Object[] writtenObjects() {\n            Object[] written = new Object[objectCount];\n            System.arraycopy(objects, 0, written, 0, objectCount);\n            return written;\n        }\n\n        private int writtenInt() {\n            return intValue;\n        }\n    }\n\n    private static final class ReplayingObjectInputStream extends ObjectInputStream {\n        private final Object[] objects;\n        private final int intValue;\n        private int objectIndex;\n\n        private ReplayingObjectInputStream(Object firstObject, Object secondObject, int intValue) throws IOException {\n            super();\n            this.objects = new Object[] {firstObject, secondObject};\n            this.intValue = intValue;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            Object object = objects[objectIndex];\n            objectIndex++;\n            return object;\n        }\n\n        @Override\n        public int readInt() {\n            return intValue;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778106448365}]}
