  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.crypto.util.JournaledAlgorithm;
  import org.bouncycastle.crypto.util.JournalingSecureRandom;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.nio.file.Path;
  import java.security.SecureRandom;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JournaledAlgorithmTest {
      private static final ASN1ObjectIdentifier SHA256_WITH_RSA_ENCRYPTION = new ASN1ObjectIdentifier(
              "1.2.840.113549.1.1.11");
      private static final byte[] TRANSCRIPT = new byte[] { 11, 22, 33, 44, 55, 66 };
  
      @Test
      void serializesAndRestoresAlgorithmState() throws Exception {
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);
          JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);
  
          byte[] serialized = serialize(original);
          JournaledAlgorithm restored = deserialize(serialized);
  
          assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);
      }
  
      @Test
      void storesAndRestoresEncodedStateThroughStreams() throws Exception {
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);
          JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);
  
          ByteArrayOutputStream storedState = new ByteArrayOutputStream();
          original.storeState(storedState);
          JournaledAlgorithm restored = JournaledAlgorithm.getState(
                  new ByteArrayInputStream(storedState.toByteArray()),
                  new SecureRandom());
  
          assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);
      }
  
      @Test
      void storesAndRestoresEncodedStateThroughFiles(@TempDir Path temporaryDirectory) throws Exception {
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);
          JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);
          Path stateFile = temporaryDirectory.resolve("journaled-algorithm-state.der");
  
          original.storeState(stateFile.toFile());
          JournaledAlgorithm restored = JournaledAlgorithm.getState(stateFile.toFile(), new SecureRandom());
  
          assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);
      }
  
      @Test
      void restoresStateFromRawEncoding() throws Exception {
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);
          JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);
  
          JournaledAlgorithm restored = new JournaledAlgorithm(original.getEncoded(), new SecureRandom());
  
          assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);
      }
  
      private static JournaledAlgorithm newJournaledAlgorithm(AlgorithmIdentifier algorithmIdentifier) {
          return new JournaledAlgorithm(
                  algorithmIdentifier,
                  new JournalingSecureRandom(TRANSCRIPT, new SecureRandom()));
      }
  
      private static byte[] serialize(JournaledAlgorithm journaledAlgorithm) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(journaledAlgorithm);
          }
          return serialized.toByteArray();
      }
  
      private static JournaledAlgorithm deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (JournaledAlgorithm)objectInputStream.readObject();
          }
      }
  
      private static void assertRestoredState(
              JournaledAlgorithm restored,
              AlgorithmIdentifier algorithmIdentifier,
              byte[] transcript
      ) {
          assertThat(restored.getAlgorithmIdentifier().getAlgorithm())
                  .isEqualTo(algorithmIdentifier.getAlgorithm());
          assertThat(restored.getJournalingSecureRandom().getFullTranscript())
                  .containsExactly(transcript);
          assertThat(nextBytes(restored.getJournalingSecureRandom(), transcript.length))
                  .containsExactly(transcript);
      }
  
      private static byte[] nextBytes(JournalingSecureRandom random, int length) {
          byte[] bytes = new byte[length];
          random.nextBytes(bytes);
          return bytes;
      }
  }
