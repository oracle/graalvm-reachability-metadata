          BigInteger              j,
          DHValidationParameters  validation)
      {
          this(p, g, q, DEFAULT_MINIMUM_LENGTH, 0, j, validation);
      }
  
      public DHParameters(
          BigInteger              p,
          BigInteger              g,
          BigInteger              q,
          int                     m,
          int                     l,
          BigInteger              j,
          DHValidationParameters  validation)
