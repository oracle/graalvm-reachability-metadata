castle.jce.interfaces.ElGamalPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n", "newText": "import org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPublicKey;\nimport org.bouncycastle.jce.interfaces.ElGamalPublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.util.CollectionStore;\nimport org.bouncycastle.util.Selector;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.PublicKey;\nimport java.security.spec.X509EncodedKeySpec;\nimport java.util.Collection;\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n"}, {"oldText": "        ElGamalPublicKey restored = deserialize(serialize(original));\n\n        assertThat(original).isInstanceOf(BCElGamalPublicKey.class);\n        assertThat(restored).isInstanceOf(BCElGamalPublicKey.class);\n        assertThat(restored.getY()).isEqualTo(Y).isEqualTo(original.getY());\n        assertThat(restored.getParameters().getP()).isEqualTo(P).isEqualTo(original.getParameters().getP());\n        assertThat(restored.getParameters().getG()).isEqualTo(G).isEqualTo(original.getParameters().getG());\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\n        assertThat(restored.getParams().getL()).isEqualTo(original.getParams().getL());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n", "newText": "        ElGamalPublicKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n"}, {"oldText": "    private static ElGamalPublicKey newBcElGamalPublicKey() throws Exception {\n        AlgorithmIdentifier algorithm = new AlgorithmIdentifier(\n                OIWObjectIdentifiers.elGamalAlgorithm,\n                new ElGamalParameter(P, G));\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithm, new ASN1Integer(Y));\n\n        return (ElGamalPublicKey)new KeyFactorySpi().generatePublic(publicKeyInfo);\n    }\n\n    private static byte[] serialize(ElGamalPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static ElGamalPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ElGamalPublicKey)objectInputStream.readObject();\n        }\n    }\n", "newText": "    private static ElGamalPublicKey newBcElGamalPublicKey() throws Exception {\n        AlgorithmIdentifier algorithm = new AlgorithmIdentifier(\n                OIWObjectIdentifiers.elGamalAlgorithm,\n                new ElGamalParameter(P, G));\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithm, new ASN1Integer(Y));\n        KeyFactory keyFactory = KeyFactory.getInstance(\"ElGamal\", new BouncyCastleProvider());\n        PublicKey publicKey = keyFactory.generatePublic(new X509EncodedKeySpec(publicKeyInfo.getEncoded()));\n\n        return (ElGamalPublicKey)publicKey;\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(ElGamalPublicKey original, ElGamalPublicKey restored) {\n        assertThat(original).isInstanceOf(BCElGamalPublicKey.class);\n        assertThat(restored).isInstanceOf(BCElGamalPublicKey.class);\n        assertThat(restored.getY()).isEqualTo(Y).isEqualTo(original.getY());\n        assertThat(restored.getParameters().getP()).isEqualTo(P).isEqualTo(original.getParameters().getP());\n        assertThat(restored.getParameters().getG()).isEqualTo(G).isEqualTo(original.getParameters().getG());\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\n        assertThat(restored.getParams().getL()).isEqualTo(original.getParams().getL());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n    }\n\n    private static ElGamalPublicKey serializeAndDeserializeFromBouncyCastleFrame(ElGamalPublicKey publicKey) {\n        CollectionStore<ElGamalPublicKey> store = new CollectionStore<>(List.of(publicKey));\n        AtomicReference<ElGamalPublicKey> restored = new AtomicReference<>();\n\n        Collection<ElGamalPublicKey> matches = store.getMatches(new Selector<>() {\n            @Override\n            public boolean match(ElGamalPublicKey key) {\n                try {\n                    restored.set(deserialize(serialize(key)));\n                    return true;\n                }\n                catch (Exception e) {\n                    throw new IllegalStateException(\"ElGamal public key serialization failed\", e);\n                }\n            }\n\n            @Override\n            public Object clone() {\n                return this;\n            }\n        });\n\n        assertThat(matches).containsExactly(publicKey);\n        return restored.get();\n    }\n\n    private static byte[] serialize(ElGamalPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeUnshared(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static ElGamalPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ElGamalPublicKey)objectInputStream.readUnshared();\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 457, "output": 2602, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 35827, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780866670273, "responseId": "resp_097bb51b86c3a738016a25de6ee0cc81909995b018636299f8"}}
