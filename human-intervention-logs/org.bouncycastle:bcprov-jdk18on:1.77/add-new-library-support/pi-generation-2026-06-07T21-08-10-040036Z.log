e.asn1.DERUTF8String;\nimport org.bouncycastle.asn1.oiw.ElGamalParameter;\nimport org.bouncycastle.asn1.oiw.OIWObjectIdentifiers;\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPrivateKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;\nimport org.bouncycastle.jce.interfaces.ElGamalPrivateKey;\nimport org.bouncycastle.jce.interfaces.PKCS12BagAttributeCarrier;\nimport org.bouncycastle.util.CollectionStore;\nimport org.bouncycastle.util.Selector;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.Collection;\nimport java.util.List;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCElGamalPrivateKeyTest {\n    private static final BigInteger P = new BigInteger(\"104729\");\n    private static final BigInteger G = new BigInteger(\"2\");\n    private static final BigInteger X = new BigInteger(\"12345\");\n    private static final ASN1ObjectIdentifier FRIENDLY_NAME_OID = new ASN1ObjectIdentifier(\"1.2.840.113549.1.9.20\");\n\n    @Test\n    void serializesAndRestoresElGamalPrivateKeyParameters() throws Exception {\n        ElGamalPrivateKey original = newBcElGamalPrivateKey();\n        ((PKCS12BagAttributeCarrier)original).setBagAttribute(FRIENDLY_NAME_OID, new DERUTF8String(\"elgamal-key\"));\n\n        ElGamalPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static ElGamalPrivateKey newBcElGamalPrivateKey() throws Exception {\n        AlgorithmIdentifier algorithm = new AlgorithmIdentifier(\n                OIWObjectIdentifiers.elGamalAlgorithm,\n                new ElGamalParameter(P, G));\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithm, new ASN1Integer(X));\n\n        return (ElGamalPrivateKey)new KeyFactorySpi().generatePrivate(privateKeyInfo);\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(ElGamalPrivateKey original, ElGamalPrivateKey restored) {\n        assertThat(original).isInstanceOf(BCElGamalPrivateKey.class);\n        assertThat(restored).isInstanceOf(BCElGamalPrivateKey.class);\n        assertThat(restored.getX()).isEqualTo(X).isEqualTo(original.getX());\n        assertThat(restored.getParameters().getP()).isEqualTo(P).isEqualTo(original.getParameters().getP());\n        assertThat(restored.getParameters().getG()).isEqualTo(G).isEqualTo(original.getParameters().getG());\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n        PKCS12BagAttributeCarrier restoredBagAttributes = (PKCS12BagAttributeCarrier)restored;\n        assertThat(restoredBagAttributes.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static ElGamalPrivateKey serializeAndDeserializeFromBouncyCastleFrame(ElGamalPrivateKey privateKey) {\n        CollectionStore<ElGamalPrivateKey> store = new CollectionStore<>(List.of(privateKey));\n        AtomicReference<ElGamalPrivateKey> restored = new AtomicReference<>();\n\n        Collection<ElGamalPrivateKey> matches = store.getMatches(new Selector<>() {\n            @Override\n            public boolean match(ElGamalPrivateKey key) {\n                try {\n                    restored.set(deserialize(serialize(key)));\n                    return true;\n                }\n                catch (Exception e) {\n                    throw new IllegalStateException(\"ElGamal private key serialization failed\", e);\n                }\n            }\n\n            @Override\n            public Object clone() {\n                return this;\n            }\n        });\n\n        assertThat(matches).containsExactly(privateKey);\n        return restored.get();\n    }\n\n    private static byte[] serialize(ElGamalPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static ElGamalPrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ElGamalPrivateKey)objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780866416282}, {"role": "toolResult", "toolCallId": "call_fhbkNJC85m5Q0svKuCGyK4Kn|fc_097bb51b86c3a738016a25dd7013348190be79f663fde783cf", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/1500-96ad851a/local_repositories/source_context/org.bouncycastle/bcprov-jdk18on/1.77/main/extracted/org/bouncycastle/jcajce/provider/asymmetric/elgamal/BCElGamalPublicKey.java'"}], "details": {}, "isError": true, "timestamp": 1780866416282}, {"role": "toolResult", "toolCallId": "call_3SPCCd9MJC3Acjf6jtEV7SFG|fc_097bb51b86c3a738016a25dd70133c81909284bba7e62797dc", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.bouncycastle:bcprov-jdk18on:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780866416282}]}
