[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCElGamalPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.oiw.ElGamalParameter;\nimport org.bouncycastle.asn1.oiw.OIWObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPublicKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;\nimport org.bouncycastle.jce.interfaces.ElGamalPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCElGamalPublicKeyTest {\n    private static final BigInteger P = new BigInteger(\"104729\");\n    private static final BigInteger G = new BigInteger(\"2\");\n    private static final BigInteger Y = new BigInteger(\"67890\");\n\n    @Test\n    void serializesAndRestoresElGamalPublicKeyParameters() throws Exception {\n        ElGamalPublicKey original = newBcElGamalPublicKey();\n\n        ElGamalPublicKey restored = deserialize(serialize(original));\n\n        assertThat(original).isInstanceOf(BCElGamalPublicKey.class);\n        assertThat(restored).isInstanceOf(BCElGamalPublicKey.class);\n        assertThat(restored.getY()).isEqualTo(Y).isEqualTo(original.getY());\n        assertThat(restored.getParameters().getP()).isEqualTo(P).isEqualTo(original.getParameters().getP());\n        assertThat(restored.getParameters().getG()).isEqualTo(G).isEqualTo(original.getParameters().getG());\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\n        assertThat(restored.getParams().getL()).isEqualTo(original.getParams().getL());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n    }\n\n    private static ElGamalPublicKey newBcElGamalPublicKey() throws Exception {\n        AlgorithmIdentifier algorithm = new AlgorithmIdentifier(\n                OIWObjectIdentifiers.elGamalAlgorithm,\n                new ElGamalParameter(P, G));\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithm, new ASN1Integer(Y));\n\n        return (ElGamalPublicKey)new KeyFactorySpi().generatePublic(publicKeyInfo);\n    }\n\n    private static byte[] serialize(ElGamalPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static ElGamalPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ElGamalPublicKey)objectInputStream.readObject();\n        }\n    }\n}\n"}
