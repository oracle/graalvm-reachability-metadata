tream = new EncodingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);\n\n        byte[] encoded = privateKey.getEncoded();\n        assertThat(readEncodedObject(outputStream.toByteArray())).isEqualTo(encoded);\n\n        BCECGOST3410_2012PrivateKey restored = new BCECGOST3410_2012PrivateKey(\n                new ECPrivateKeySpec(BigInteger.ONE, parameters));\n        EncodingObjectInputStream inputStream = new EncodingObjectInputStream(outputStream.toByteArray());\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ECGOST3410-2012\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getEncoded()).isEqualTo(encoded);\n        assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCECGOST3410_2012PrivateKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCECGOST3410_2012PrivateKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCEC