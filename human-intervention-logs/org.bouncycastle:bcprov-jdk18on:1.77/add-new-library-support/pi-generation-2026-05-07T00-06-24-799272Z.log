[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCECGOST34102012PrivateKeyTest.java","edits":[{"oldText":"import java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;","newText":"import java.io.IOException;\nimport java.io.ObjectInputStream;"},{"oldText":"    @Test\n    public void javaSerializationRoundTripPreservesEncodedEcGost2012PrivateKey() throws Exception {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        BCECGOST3410_2012PrivateKey privateKey = new BCECGOST3410_2012PrivateKey(\n                new ECPrivateKeySpec(PRIVATE_VALUE, parameters));\n        byte[] encoded = privateKey.getEncoded();\n\n        BCECGOST3410_2012PrivateKey restored = serializeAndDeserialize(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ECGOST3410-2012\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getEncoded()).isEqualTo(encoded);\n        assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());\n    }\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedEcGost2012PrivateKey() throws Throwable {","newText":"    @Test\n    public void serializationHooksWriteAndReadEncodedEcGost2012PrivateKey() throws Throwable {"},{"oldText":"        EncodingObjectOutputStream outputStream = new EncodingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);\n\n        byte[] encoded = privateKey.getEncoded();\n        assertThat(readEncodedObject(outputStream.toByteArray())).isEqualTo(encoded);\n\n        BCECGOST3410_2012PrivateKey restored = new BCECGOST3410_2012PrivateKey(\n                new ECPrivateKeySpec(BigInteger.ONE, parameters));\n        EncodingObjectInputStream inputStream = new EncodingObjectInputStream(outputStream.toByteArray());\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);","newText":"        EncodedKeyObjectOutputStream outputStream = new EncodedKeyObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);\n\n        byte[] encoded = privateKey.getEncoded();\n        assertThat(outputStream.getEncodedKey()).isEqualTo(encoded);\n\n        BCECGOST3410_2012PrivateKey restored = new BCECGOST3410_2012PrivateKey(\n                new ECPrivateKeySpec(BigInteger.ONE, parameters));\n        EncodedKeyObjectInputStream inputStream = new EncodedKeyObjectInputStream(outputStream.getEncodedKey());\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);"},{"oldText":"    private static BCECGOST3410_2012PrivateKey serializeAndDeserialize(\n            BCECGOST3410_2012PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (BCECGOST3410_2012PrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static byte[] readEncodedObject(byte[] serializedObject) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serializedObject))) {\n            return (byte[])inputStream.readObject();\n        }\n    }\n\n    private static ECParameterSpec createSecp256r1Parameters() {","newText":"    private static ECParameterSpec createSecp256r1Parameters() {"},{"oldText":"    private static final class EncodingObjectOutputStream extends ObjectOutputStream {\n        private final ByteArrayOutputStream outputStream;\n\n        private EncodingObjectOutputStream() throws Exception {\n            this(new ByteArrayOutputStream());\n        }\n\n        private EncodingObjectOutputStream(ByteArrayOutputStream outputStream) throws Exception {\n            super(outputStream);\n            this.outputStream = outputStream;\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        private byte[] toByteArray() throws Exception {\n            flush();\n            return outputStream.toByteArray();\n        }\n    }\n\n    private static final class EncodingObjectInputStream extends ObjectInputStream {\n        private EncodingObjectInputStream(byte[] serializedObject) throws Exception {\n            super(new ByteArrayInputStream(serializedObject));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n","newText":"    private static final class EncodedKeyObjectOutputStream extends ObjectOutputStream {\n        private byte[] encodedKey;\n\n        private EncodedKeyObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            encodedKey = (byte[])object;\n        }\n\n        private byte[] getEncodedKey() {\n            return encodedKey;\n        }\n    }\n\n    private static final class EncodedKeyObjectInputStream extends ObjectInputStream {\n        private final byte[] encodedKey;\n\n        private EncodedKeyObjectInputStream(byte[] encodedKey) throws IOException {\n            super();\n            this.encodedKey = encodedKey;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return encodedKey;\n        }\n    }\n"}]}
[tool-call] end id=call_KU99zf6M4Xe4qXdtbPA8EIJD|fc_0b8c2e6fe0bb2dc90169fbd92d682481929321f56cc8d7675f name=edit args={"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCECGOST34102012PrivateKeyTest.java", "edits": [{"oldText": "import java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;", "newText": "import java.io.IOException;\nimport java.io.ObjectInputStream;"}, {"oldText": "    @Test\n    public void javaSerializationRoundTripPreservesEncodedEcGost2012PrivateKey() throws Exception {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        BCECGOST3410_2012PrivateKey privateKey = new BCECGOST3410_2012PrivateKey(\n                new ECPrivateKeySpec(PRIVATE_VALUE, parameters));\n        byte[] encoded = privateKey.getEncoded();\n\n        BCECGOST3410_2012PrivateKey restored = serializeAndDeserialize(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ECGOST3410-2012\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getEncoded()).isEqualTo(encoded);\n        assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());\n    }\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedEcGost2012PrivateKey() throws Throwable {", "newText": "    @Test\n    public void serializationHooksWriteAndReadEncodedEcGost2012PrivateKey() throws Throwable {"}, {"oldText": "        EncodingObjectOutputStream outputStream = new EncodingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);\n\n        byte[] encoded = privateKey.getEncoded();\n        assertThat(readEncodedObject(outputStream.toByteArray())).isEqualTo(encoded);\n\n        BCECGOST3410_2012PrivateKey restored = new BCECGOST3410_2012PrivateKey(\n                new ECPrivateKeySpec(BigInteger.ONE, parameters));\n        EncodingObjectInputStream inputStream = new EncodingObjectInputStream(outputStream.toByteArray());\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);", "newText": "        EncodedKeyObjectOutputStream outputStream = new EncodedKeyObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);\n\n        byte[] encoded = privateKey.getEncoded();\n        assertThat(outputStream.getEncodedKey()).isEqualTo(encoded);\n\n        BCECGOST3410_2012PrivateKey restored = new BCECGOST3410_2012PrivateKey(\n                new ECPrivateKeySpec(BigInteger.ONE, parameters));\n        EncodedKeyObjectInputStream inputStream = new EncodedKeyObjectInputStream(outputStream.getEncodedKey());\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);"}, {"oldText": "    private static BCECGOST3410_2012PrivateKey serializeAndDeserialize(\n            BCECGOST3410_2012PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (BCECGOST3410_2012PrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static byte[] readEncodedObject(byte[] serializedObject) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serializedObject))) {\n            return (byte[])inputStream.readObject();\n        }\n    }\n\n    private static ECParameterSpec createSecp256r1Parameters() {", "newText": "    private static ECParameterSpec createSecp256r1Parameters() {"}, {"oldText": "    private static final class EncodingObjectOutputStream extends ObjectOutputStream {\n        private final ByteArrayOutputStream outputStream;\n\n        private EncodingObjectOutputStream() throws Exception {\n            this(new ByteArrayOutputStream());\n        }\n\n        private EncodingObjectOutputStream(ByteArrayOutputStream outputStream) throws Exception {\n            super(outputStream);\n            this.outputStream = outputStream;\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        private byte[] toByteArray() throws Exception {\n            flush();\n            return outputStream.toByteArray();\n        }\n    }\n\n    private static final class EncodingObjectInputStream extends ObjectInputStream {\n        private EncodingObjectInputStream(byte[] serializedObject) throws Exception {\n            super(new ByteArrayInputStream(serializedObject));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n", "newText": "    private static final class EncodedKeyObjectOutputStream extends ObjectOutputStream {\n        private byte[] encodedKey;\n\n        private EncodedKeyObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            encodedKey = (byte[])object;\n        }\n\n        private byte[] getEncodedKey() {\n            return encodedKey;\n        }\n    }\n\n    private static final class EncodedKeyObjectInputStream extends ObjectInputStream {\n        private final byte[] encodedKey;\n\n        private EncodedKeyObjectInputStream(byte[] encodedKey) throws IOException {\n            super();\n            this.encodedKey = encodedKey;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return encodedKey;\n        }\n    }\n"}]}
