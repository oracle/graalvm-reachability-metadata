erator()).isEqualTo(parameters.getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCECGOST3410_2012PrivateKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCECGOST3410_2012PrivateKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCECGOST3410_2012PrivateKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCECGOST3410_2012PrivateKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static BCECGOST3410_2012PrivateKey serializeAndDeserialize(\n            BCECGOST3410_2012PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return (BCECGOST3410_2012PrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static byte[] readEncodedObject(byte[] serializedObject) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serializedObject))) {\n            return (byte[])inputStream.readObject();\n        }\n    }\n\n    private static ECParameterSpec createSecp256r1Parameters() {\n        BigInteger p = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF\", 16);\n        BigInteger a = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC\", 16);\n        BigInteger b = new BigInteger(\"5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B\", 16);\n        BigInteger gx = new BigInteger(\"6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296\", 16);\n        BigInteger gy = new BigInteger(\"4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5\", 16);\n        BigInteger n = new BigInteger(\"FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551\", 16);\n\n        return new ECParameterSpec(\n                new EllipticCurve(new ECFieldFp(p), a, b),\n                new ECPoint(gx, gy),\n                n,\n                1);\n    }\n\n    private static final class EncodingObjectOutputStream extends ObjectOutputStream {\n        private final ByteArrayOutputStream outputStream;\n\n        private EncodingObjectOutputStream() throws Exception {\n            this(new ByteArrayOutputStream());\n        }\n\n        private EncodingObjectOutputStream(ByteArrayOutputStream outputStream) throws Exception {\n            super(outputStream);\n            this.outputStream = outputStream;\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        private byte[] toByteArray() throws Exception {\n            flush();\n            return outputStream.toByteArray();\n        }\n    }\n\n    private static final class EncodingObjectInputStream extends ObjectInputStream {\n        private EncodingObjectInputStream(byte[] serializedObject) throws Exception {\n            super(new ByteArrayInputStream(serializedObject));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778112586480}]}
