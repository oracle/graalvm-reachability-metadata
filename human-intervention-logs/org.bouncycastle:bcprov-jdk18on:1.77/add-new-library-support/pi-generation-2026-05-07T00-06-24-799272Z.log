  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.security.spec.ECPoint;
  import java.security.spec.ECPublicKeySpec;
  
  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PublicKey;
  import org.bouncycastle.jce.ECGOST3410NamedCurveTable;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCECGOST3410PublicKeyTest {
      private static final String CURVE_NAME = "GostR3410-2001-CryptoPro-A";
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void javaSerializationInvokesEcGostPublicKeyWriteHook() throws Exception {
          BCECGOST3410PublicKey publicKey = createPublicKey();
          byte[] encoded = publicKey.getEncoded();
  
          byte[] serialized = serialize(publicKey);
  
          assertThat(serialized).isNotEmpty();
          assertThat(serialized.length).isGreaterThan(encoded.length);
      }
  
      @Test
      public void serializationHooksWriteAndReadEncodedEcGostPublicKey() throws Throwable {
          BCECGOST3410PublicKey publicKey = createPublicKey();
          EncodingObjectOutputStream outputStream = new EncodingObjectOutputStream();
  
          WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);
  
          byte[] encoded = publicKey.getEncoded();
          assertThat(readEncodedObject(outputStream.toByteArray())).isEqualTo(encoded);
  
          BCECGOST3410PublicKey restored = createPublicKey();
          EncodingObjectInputStream inputStream = new EncodingObjectInputStream(outputStream.toByteArray());
  
          READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);
  
          assertThat(restored.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getW()).isEqualTo(publicKey.getW());
