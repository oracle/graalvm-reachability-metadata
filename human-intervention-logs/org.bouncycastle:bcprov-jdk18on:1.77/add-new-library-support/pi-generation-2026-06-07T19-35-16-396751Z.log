          }
  
          this.algorithm = algorithm;
          this.ecPublicKey = params;
  
          if (spec == null)
          {
              EllipticCurve ellipticCurve = EC5Util.convertCurve(dp.getCurve(), dp.getSeed());
  
              this.ecSpec = createSpec(ellipticCurve, dp);
          }
