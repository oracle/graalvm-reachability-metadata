  private static ECPublicKey newEcGostPublicKey() {\n        ASN1ObjectIdentifier publicKeyParamSet = CryptoProObjectIdentifiers.gostR3410_2001_CryptoPro_A;\n        X9ECParameters curveParameters = ECGOST3410NamedCurves.getByOIDX9(publicKeyParamSet);\n        ECGOST3410Parameters domainParameters = new ECGOST3410Parameters(\n                new ECNamedDomainParameters(publicKeyParamSet, curveParameters),\n                publicKeyParamSet,\n                CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet,\n                null);\n        ECPoint publicPoint = curveParameters.getG().multiply(PRIVATE_VALUE).normalize();\n        ECPublicKeyParameters publicKeyParameters = new ECPublicKeyParameters(\n                publicPoint,\n                domainParameters);\n        ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(\n                ECGOST3410NamedCurves.getName(publicKeyParamSet),\n                curveParameters.getCurve(),\n                curveParameters.getG(),\n                curveParameters.getN(),\n                curveParameters.getH(),\n                curveParameters.getSeed());\n\n        return new BCECGOST3410PublicKey(\n                \"ECGOST3410\",\n                publicKeyParameters,\n                namedCurveSpec);\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(ECPublicKey original, ECPublicKey restored) {\n        assertThat(original).isInstanceOf(BCECGOST3410PublicKey.class);\n        assertThat(restored).isInstanceOf(BCECGOST3410PublicKey.class);\n        assertThat(restored.getW()).isEqualTo(original.getW());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ECGOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restored.getParams().getOrder()).isEqualTo(original.getParams().getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());\n    }\n\n    private static byte[] serialize(ECPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static ECPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ECPublicKey)objectInputStream.readObject();\n        }\n    }\n}\n"}
