ll_vviO96BY9uNHMKuW4igUaUKW|fc_0dcb5ef5eef1e0170169fbf08300f081939304548cc495d69f", "name": "write", "arguments": {"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCGOST3410PublicKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\nimport java.security.PublicKey;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.asn1.DEROctetString;\nimport org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;\nimport org.bouncycastle.asn1.cryptopro.GOST3410PublicKeyAlgParameters;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PublicKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.KeyFactorySpi;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCGOST3410PublicKeyTest {\n    private static final BigInteger PUBLIC_VALUE = new BigInteger(\n            \"11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF\",\n            16);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void serializationHookWritesGost3410PublicKeyOidParameters() throws Throwable {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        BCGOST3410PublicKey publicKey = createPublicKey(keyParamSetOid, digestParamSetOid);\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(keyParamSetOid, digestParamSetOid, null);\n    }\n\n    @Test\n    public void serializationHookReadsGost3410PublicKeyOidParameters() throws Throwable {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        BCGOST3410PublicKey publicKey = createPublicKey(keyParamSetOid, digestParamSetOid);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                keyParamSetOid,\n                digestParamSetOid,\n                null);\n\n        READ_OBJECT.invokeExact(publicKey, (ObjectInputStream)inputStream);\n\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);\n        assertThat(publicKey.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(publicKey.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);\n        assertThat(publicKey.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);\n        assertThat(publicKey.getParameters().getEncryptionParamSetOID()).isNull();\n        assertThat(publicKey.getParameters().getPublicKeyParameters())\n                .isEqualTo(parameterSpec.getPublicKeyParameters());\n    }\n\n    private static BCGOST3410PublicKey createPublicKey(\n            String keyParamSetOid,\n            String digestParamSetOid) throws Exception {\n        GOST3410PublicKeyAlgParameters parameters = new GOST3410PublicKeyAlgParameters(\n                new ASN1ObjectIdentifier(keyParamSetOid),\n                new ASN1ObjectIdentifier(digestParamSetOid));\n        SubjectPublicKeyInfo keyInfo = new SubjectPublicKeyInfo(\n                new AlgorithmIdentifier(CryptoProObjectIdentifiers.gostR3410_94, parameters),\n                new DEROctetString(toLittleEndianUnsigned(PUBLIC_VALUE)));\n        PublicKey publicKey = new KeyFactorySpi().generatePublic(keyInfo);\n\n        assertThat(publicKey).isInstanceOf(BCGOST3410PublicKey.class);\n        return (BCGOST3410PublicKey)publicKey;\n    }\n\n    private static byte[] toLittleEndianUnsigned(BigInteger value) {\n        byte[] bigEndian = value.toByteArray();\n        int startIndex = bigEndian[0] == 0 ? 1 : 0;\n        byte[] littleEndian = new byte[bigEndian.length - startIndex];\n\n        for (int i = 0; i != littleEndian.length; i++) {\n            littleEndian[i] = bigEndian[bigEndian.length - 1 - i];\n        }\n\n        return littleEndian;\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCGOST3410PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCGOST3410PublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCGOST3410PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCGOST3410PublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final List<Object> writtenObjects = new ArrayList<>();\n\n        private RecordingObjectOutputStream() throws Exception {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            writtenObjects.add(object);\n        }\n\n        private List<Object> writtenObjects() {\n            return writtenObjects;\n        }\n    }\n\n    private static final class ReplayingObjectInputStream extends ObjectInputStream {\n        private final List<Object> objects;\n        private int nextObjectIndex;\n\n        private ReplayingObjectInputStream(Object... objects) throws Exception {\n            super();\n            this.objects = Arrays.asList(objects);\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return objects.get(nextObjectIndex++);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 4021, "output": 2980, "cacheRead": 37888, "cacheWrite": 0, "totalTokens": 44889, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778118770217, "responseId": "resp_0dcb5ef5eef1e0170169fbf072d7f08193a2d10f49173e415a"}}
[tool-exec] start id=call_vviO96BY9uNHMKuW4igUaUKW|fc_0dcb5ef5eef1e0170169fbf08300f081939304548cc495d69f name=write args={"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCGOST3410PublicKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\nimport java.security.PublicKey;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.asn1.DEROctetString;\nimport org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;\nimport org.bouncycastle.asn1.cryptopro.GOST3410PublicKeyAlgParameters;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PublicKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.KeyFactorySpi;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCGOST3410PublicKeyTest {\n    private static final BigInteger PUBLIC_VALUE = new BigInteger(\n            \"11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF\",\n            16);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void serializationHookWritesGost3410PublicKeyOidParameters() throws Throwable {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        BCGOST3410PublicKey publicKey = createPublicKey(keyParamSetOid, digestParamSetOid);\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(keyParamSetOid, digestParamSetOid, null);\n    }\n\n    @Test\n    public void serializationHookReadsGost3410PublicKeyOidParameters() throws Throwable {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        BCGOST3410PublicKey publicKey = createPublicKey(keyParamSetOid, digestParamSetOid);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                keyParamSetOid,\n                digestParamSetOid,\n                null);\n\n        READ_OBJECT.invokeExact(publicKey, (ObjectInputStream)inputStream);\n\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);\n        assertThat(publicKey.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(publicKey.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);\n        assertThat(publicKey.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);\n        assertThat(publicKey.getParameters().getEncryptionParamSetOID()).isNull();\n        assertThat(publicKey.getParameters().getPublicKeyParameters())\n                .isEqualTo(parameterSpec.getPublicKeyParameters());\n    }\n\n    private static BCGOST3410PublicKey createPublicKey(\n            String keyParamSetOid,\n            String digestParamSetOid) throws Exception {\n        GOST3410PublicKeyAlgParameters parameters = new GOST3410PublicKeyAlgParameters(\n                new ASN1ObjectIdentifier(keyParamSetOid),\n                new ASN1ObjectIdentifier(digestParamSetOid));\n        SubjectPublicKeyInfo keyInfo = new SubjectPublicKeyInfo(\n                new AlgorithmIdentifier(CryptoProObjectIdentifiers.gostR3410_94, parameters),\n                new DEROctetString(toLittleEndianUnsigned(PUBLIC_VALUE)));\n        PublicKey publicKey = new KeyFactorySpi().generatePublic(keyInfo);\n\n        assertThat(publicKey).isInstanceOf(BCGOST3410PublicKey.class);\n        return (BCGOST3410PublicKey)publicKey;\n    }\n\n    private static byte[] toLittleEndianUnsigned(BigInteger value) {\n        byte[] bigEndian = value.toByteArray();\n        int startIndex = bigEndian[0] == 0 ? 1 : 0;\n        byte[] littleEndian = new byte[bigEndian.length - startIndex];\n\n        for (int i = 0; i != littleEndian.length; i++) {\n            littleEndian[i] = bigEndian[bigEndian.length - 1 - i];\n        }\n\n        return littleEndian;\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCGOST3410PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCGOST3410PublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCGOST3410PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCGOST3410PublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final List<Object> writtenObjects = new ArrayList<>();\n\n        private RecordingObjectOutputStream() throws Exception {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            writtenObjects.add(object);\n        }\n\n        private List<Object> writtenObjects() {\n            return writtenObjects;\n        }\n    }\n\n    private static final class ReplayingObjectInputStream extends ObjectInputStream {\n        private final List<Object> objects;\n        private int nextObjectIndex;\n\n        private ReplayingObjectInputStream(Object... objects) throws Exception {\n            super();\n            this.objects = Arrays.asList(objects);\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return objects.get(nextObjectIndex++);\n        }\n    }\n}\n"}
