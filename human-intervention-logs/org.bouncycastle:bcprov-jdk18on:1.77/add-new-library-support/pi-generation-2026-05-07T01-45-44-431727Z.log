  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.Key;
  import java.security.KeyFactory;
  import java.security.PublicKey;
  
  import org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PublicKey;
  import org.bouncycastle.jce.interfaces.GOST3410Params;
  import org.bouncycastle.jce.interfaces.GOST3410PublicKey;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.spec.GOST3410ParameterSpec;
  import org.bouncycastle.jce.spec.GOST3410PublicKeyParameterSetSpec;
  import org.bouncycastle.jce.spec.GOST3410PublicKeySpec;
  import org.junit.jupiter.api.Test;
  
  public class BCGOST3410PublicKeyTest {
      private static final BigInteger PUBLIC_VALUE = new BigInteger(
              "11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF",
              16);
  
      @Test
      public void javaSerializationRoundTripPreservesGost3410PublicKeyParameters() throws Exception {
          GOST3410PublicKeyParameterSetSpec parameters = createCryptoProAParameters();
          BCGOST3410PublicKey publicKey = createPublicKey(parameters);
  
          BCGOST3410PublicKey restored = roundTrip(publicKey);
  
          assertThat(restored.getAlgorithm()).isEqualTo("GOST3410");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restored.getParameters().getPublicKeyParamSetOID()).isNull();
