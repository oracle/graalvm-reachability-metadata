jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.math.BigInteger;\nimport java.security.Key;\nimport java.security.KeyFactory;\nimport java.security.PrivateKey;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PrivateKey;\nimport org.bouncycastle.jce.interfaces.GOST3410Params;\nimport org.bouncycastle.jce.interfaces.GOST3410PrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.bouncycastle.jce.spec.GOST3410PrivateKeySpec;\nimport org.bouncycastle.jce.spec.GOST3410PublicKeyParameterSetSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCGOST3410PrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\n            \"11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF\",\n            16);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void javaSerializationRoundTripPreservesGost3410PrivateKeyParameters() throws Exception {\n        GOST3410PublicKeyParameterSetSpec parameters = createCryptoProAParameters();\n        BCGOST3410PrivateKey privateKey = createPrivateKey(parameters);\n\n        BCGOST3410PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParameters().getPublicKeyParameters()).isEqualTo(parameters);\n        assertThat(restored.getParameters().getDigestParamSetOID())\n                .isEqualTo(CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n    }\n\n    @Test\n    public void javaSerializationRoundTripPreservesGost3410PrivateKeyOidParameters() throws Exception {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);\n        BCGOST3410PrivateKey privateKey = translatePrivateKey(new FixedGost3410PrivateKey(parameterSpec));\n\n        BCGOST3410PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);\n        assertThat(restored.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n        assertThat(restored.getParameters().getPublicKeyParameters())\n                .isEqualTo(parameterSpec.getPublicKeyParameters());\n    }\n\n    @Test\n    public void serializationHooksWriteAndReadGost3410OidParameters() throws Throwable {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);\n        BCGOST3410PrivateKey privateKey = translatePrivateKey(new FixedGost3410PrivateKey(parameterSpec));\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(keyParamSetOid, digestParamSetOid, null);\n\n        BCGOST3410PrivateKey restored = createPrivateKey(createCryptoProAParameters());\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                keyParamSetOid,\n                digestParamSetOid,\n                null);\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);\n\n        assertThat(restored.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);\n        assertThat(restored.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n        assertThat(restored.getParameters().getPublicKeyParameters())\n                .isEqualTo(parameterSpec.getPublicKeyParameters());\n    }\n\n    private static BCGOST3410PrivateKey createPrivateKey(\n            GOST3410PublicKeyParameterSetSpec parameters) throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        GOST3410PrivateKeySpec keySpec = new GOST3410PrivateKeySpec(\n                PRIVATE_VALUE,\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA());\n        PrivateKey privateKey = keyFactory.generatePrivate(keySpec);\n\n        assertThat(privateKey).isInstanceOf(BCGOST3410PrivateKey.class);\n        return (BCGOST3410PrivateKey)privateKey;\n    }\n\n    private static BCGOST3410PrivateKey translatePrivateKey(GOST3410PrivateKey privateKey) throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n      