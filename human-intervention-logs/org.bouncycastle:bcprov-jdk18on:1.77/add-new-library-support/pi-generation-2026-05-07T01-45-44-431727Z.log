  public class BCGOST3410PublicKeyTest {
      private static final BigInteger PUBLIC_VALUE = new BigInteger(
              "11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF",
              16);
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void javaSerializationRoundTripPreservesGost3410PublicKeyParameters() throws Exception {
          GOST3410PublicKeyParameterSetSpec parameters = createCryptoProAParameters();
          BCGOST3410PublicKey publicKey = createPublicKey(parameters);
  
          BCGOST3410PublicKey restored = roundTrip(publicKey);
  
          assertThat(restored.getAlgorithm()).isEqualTo("GOST3410");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restored.getParameters().getPublicKeyParamSetOID()).isNull();
          assertThat(restored.getParameters().getPublicKeyParameters()).isEqualTo(parameters);
          assertThat(restored.getParameters().getDigestParamSetOID())
                  .isEqualTo(CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());
          assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();
      }
  
      @Test
      public void javaSerializationRoundTripPreservesGost3410PublicKeyOidParameters() throws Exception {
          String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();
          String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();
          GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);
          BCGOST3410PublicKey publicKey = translatePublicKey(new FixedGost3410PublicKey(parameterSpec));
  
          BCGOST3410PublicKey restored = roundTrip(publicKey);
  
          assertThat(restored.getAlgorithm()).isEqualTo("GOST3410");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restored.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);
          assertThat(restored.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);
          assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();
          assertThat(restored.getParameters().getPublicKeyParameters())
                  .isEqualTo(parameterSpec.getPublicKeyParameters());
      }
  
      @Test
      public void serializationHooksWriteAndReadGost3410PublicKeyParameters() throws Throwable {
          GOST3410PublicKeyParameterSetSpec parameters = createCryptoProAParameters();
          BCGOST3410PublicKey publicKey = createPublicKey(parameters);
          RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();
  
          WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);
  
          assertThat(outputStream.writtenObjects()).containsExactly(
                  null,
                  parameters.getP(),
                  parameters.getQ(),
                  parameters.getA(),
                  CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId(),
                  null);
  
          BCGOST3410PublicKey restored = translatePublicKey(new FixedGost3410PublicKey(
                  new GOST3410ParameterSpec(CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId())));
          ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(
                  null,
                  parameters.getP(),
                  parameters.getQ(),
                  parameters.getA(),
                  CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId(),
                  null);
  
          READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);
  
          assertThat(restored.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restored.getParameters().getPublicKeyParamSetOID()).isNull();
          assertThat(restored.getParameters().getPublicKeyParameters()).isEqualTo(parameters);
          assertThat(restored.getParameters().getDigestParamSetOID())
                  .isEqualTo(CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());
          assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();
      }
  
      @Test
      public void serializationHooksWriteAndReadGost3410PublicKeyOidParameters() throws Throwable {
          String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();
          String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();
          GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);
          BCGOST3410PublicKey publicKey = translatePublicKey(new FixedGost3410PublicKey(parameterSpec));
          RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();
  
          WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);
  
          assertThat(outputStream.writtenObjects()).containsExactly(keyParamSetOid, digestParamSetOid, null);
  
          BCGOST3410PublicKey restored = createPublicKey(createCryptoProAParameters());
          ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(
                  keyParamSetOid,
                  digestParamSetOid,
                  null);
  
          READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);
  
          assertThat(restored.getY()).isEqualTo(PUBLIC_VALUE);
          assertThat(restored.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);
          assertThat(restored.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);
          assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();
          assertThat(restored.getParameters().getPublicKeyParameters())
                  .isEqualTo(parameterSpec.getPublicKeyParameters());
      }
  
      private static BCGOST3410PublicKey createPublicKey(
              GOST3410PublicKeyParameterSetSpec parameters) throws Exception {
          KeyFactory keyFactory = KeyFactory.getInstance("GOST3410", new BouncyCastleProvider());
          GOST3410PublicKeySpec keySpec = new GOST3410PublicKeySpec(
                  PUBLIC_VALUE,
                  parameters.getP(),
                  parameters.getQ(),
                  parameters.getA());
          PublicKey publicKey = keyFactory.generatePublic(keySpec);
  
          assertThat(publicKey).isInstanceOf(BCGOST3410PublicKey.class);
          return (BCGOST3410PublicKey)publicKey;
      }
  
      private static BCGOST3410PublicKey translatePublicKey(GOST3410PublicKey publicKey) throws Exception {
          KeyFactory keyFactory = KeyFactory.getInstance("GOST3410", new BouncyCastleProvider());
          Key translatedKey = keyFactory.translateKey(publicKey);
  
          assertThat(translatedKey).isInstanceOf(BCGOST3410PublicKey.class);
          return (BCGOST3410PublicKey)translatedKey;
      }
  
      private static GOST3410PublicKeyParameterSetSpec createCryptoProAParameters() {
          GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(
                  CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId());
          return parameterSpec.getPublicKeyParameters();
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCGOST3410PublicKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
