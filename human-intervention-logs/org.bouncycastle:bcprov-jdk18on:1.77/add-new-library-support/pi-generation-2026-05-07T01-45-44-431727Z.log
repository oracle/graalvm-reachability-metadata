jectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        BCGOST3410PublicKey publicKey = createPublicKey(keyParamSetOid, digestParamSetOid);\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(keyParamSetOid, digestParamSetOid, null);\n    }\n\n    @Test\n    public void serializationHookReadsGost3410PublicKeyOidParameters() throws Throwable {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        BCGOST3410PublicKey publicKey = createPublicKey(keyParamSetOid, digestParamSetOid);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                keyParamSetOid,\n                digestParamSetOid,\n                null);\n\n        READ_OBJECT.invokeExact(publicKey, (ObjectInputStream)inputStream);\n\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);\n        assertThat(publicKey.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(publicKey.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);\n        assertThat(publicKey.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);\n        assertThat(publicKey.getParameters().getEncryptionParamSetOID()).isNull();\n        assertThat(publicKey.getParameters().getPublicKeyParameters())\n                .isEqualTo(parameterSpec.getPublicKeyParameters());\n    }\n\n    private static BCGOST3410PublicKey createPublicKey(\n            String keyParamSetOid,\n            String digestParamSetOid) throws Exception {\n        GOST3410PublicKeyAlgParameters parameters = new GOST3410PublicKeyAlgParameters(\n                new ASN1ObjectIdentifier(keyParamSetOid),\n        