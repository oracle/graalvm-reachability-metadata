try (ObjectOutputStream outputStream = new ReplacingEncodedKeyObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ResolvingEncodedKeyObjectInputStream(output.toByteArray())) {\n            return (BCECPrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static ECParameterSpec createSecp256r1Parameters() {\n        BigInteger p = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF\", 16);\n        BigInteger a = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC\", 16);\n        BigInteger b = new BigInteger(\"5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B\", 16);\n        BigInteger gx = new BigInteger(\"6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296\", 16);\n        BigInteger gy = new BigInteger(\"4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5\", 16);\n        BigInteger n = new BigInteger(\"FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551\", 16);\n\n        return new ECParameterSpec(\n                new EllipticCurve(new ECFieldFp(p), a, b),\n                new ECPoint(gx, gy),\n                n,\n                1);\n    }\n\n    private static final class ReplacingEncodedKeyObjectOutputStream extends ObjectOutputStream {\n        private ReplacingEncodedKeyObjectOutputStream(OutputStream outputStream) throws IOException {\n            super(outputStream);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) {\n            if (object instanceof byte[]) {\n                return new EncodedKey((byte[])object);\n            }\n            return object;\n        }\n    }\n\n    private static final class ResolvingEncodedKeyObjectInputStream extends ObjectInputStream {\n        private ResolvingEncodedKeyObjectInputStream(byte[] bytes) throws IOExceptio