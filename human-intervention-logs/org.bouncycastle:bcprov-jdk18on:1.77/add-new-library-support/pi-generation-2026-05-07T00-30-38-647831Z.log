  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.OutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.invoke.VarHandle;
  import java.math.BigInteger;
  import java.security.interfaces.DSAParams;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.DSAParameter;
  import org.bouncycastle.asn1.x9.X9ObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCDSAPrivateKeyTest {
      private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);
      private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);
      private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);
      private static final BigInteger X = BigInteger.valueOf(3L);
      private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);
      private static final BigInteger RESTORED_Q = TrackedBigInteger.trackedValueOf(23L);
      private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(2L);
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
      private static final VarHandle DSA_SPEC = findDsaSpec();
  
      @Test
      public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {
          BCDSAPrivateKey original = createPrivateKey(P, Q, G);
          DSA_SPEC.set(original, new DsaParams(P, Q, G));
  
          byte[] writtenParameters = invokeWriteObject(original);
  
          assertThat(readObjects(writtenParameters)).containsExactly(P, Q, G);
  
          BCDSAPrivateKey restored = createPrivateKey(P, Q, G);
          byte[] restoredParameterStream = writeObjects(RESTORED_P, RESTORED_Q, RESTORED_G);
  
          try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {
              invokeReadObject(restored, inputStream);
          }
          DSAParams restoredParameters = restored.getParams();
  
          assertThat(restored.getAlgorithm()).isEqualTo("DSA");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getX()).isEqualTo(X);
          assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);
          assertThat(restoredParameters.getQ()).isEqualTo(RESTORED_Q);
          assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);
      }
  
      private static BCDSAPrivateKey createPrivateKey(BigInteger p, BigInteger q, BigInteger g) throws Exception {
          DSAParameter parameters = new DSAParameter(p, q, g);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  X9ObjectIdentifiers.id_dsa,
                  parameters.toASN1Primitive());
          PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(X));
  
          return new BCDSAPrivateKey(privateKeyInfo);
      }
  
      private static byte[] invokeWriteObject(BCDSAPrivateKey privateKey) throws Throwable {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {
              WRITE_OBJECT.invokeExact(privateKey, outputStream);
          }
          return output.toByteArray();
      }
  
      private static void invokeReadObject(BCDSAPrivateKey privateKey, ObjectInputStream inputStream) throws Throwable {
          READ_OBJECT.invokeExact(privateKey, inputStream);
      }
  
      private static byte[] writeObjects(Object firstObject, Object secondObject, Object thirdObject) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(firstObject);
              outputStream.writeObject(secondObject);
              outputStream.writeObject(thirdObject);
          }
          return output.toByteArray();
      }
  
      private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return new Object[] {inputStream.readObject(), inputStream.readObject(), inputStream.readObject()};
          }
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPrivateKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCDSAPrivateKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPrivateKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      BCDSAPrivateKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static VarHandle findDsaSpec() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPrivateKey.class, MethodHandles.lookup());
              return lookup.findVarHandle(BCDSAPrivateKey.class, "dsaSpec", DSAParams.class);
          }
          catch (IllegalAccessException | NoSuchFieldException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static final class NoDefaultWriteObjectOutputStream extends ObjectOutputStream {
          private NoDefaultWriteObjectOutputStream(OutputStream outputStream) throws IOException {
              super(outputStream);
          }
  
          @Override
          public void defaultWriteObject() {
          }
      }
  
      private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {
          private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {
              super(new ByteArrayInputStream(bytes));
          }
  
          @Override
          public void defaultReadObject() {
          }
      }
  
      private static final class DsaParams implements DSAParams {
          private final BigInteger p;
          private final BigInteger q;
          private final BigInteger g;
  
          private DsaParams(BigInteger p, BigInteger q, BigInteger g) {
              this.p = p;
              this.q = q;
              this.g = g;
          }
  
          @Override
          public BigInteger getP() {
              return p;
          }
  
          @Override
          public BigInteger getQ() {
              return q;
          }
  
          @Override
          public BigInteger getG() {
              return g;
          }
      }
  
      private static final class TrackedBigInteger extends BigInteger {
          private static final long serialVersionUID = 1L;
  
          private TrackedBigInteger(long value) {
              super(Long.toString(value));
          }
  
          private static TrackedBigInteger trackedValueOf(long value) {
              return new TrackedBigInteger(value);
          }
