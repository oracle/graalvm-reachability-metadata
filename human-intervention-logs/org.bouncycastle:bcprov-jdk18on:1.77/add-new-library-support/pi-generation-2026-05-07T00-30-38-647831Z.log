          this.secureRandom = secureRandom;
  
          this.generator = null;
      }
  
      public KeyPair generateKeyPair()
      {
          if (algorithmInitialized == 0)
          {
              throw new IllegalStateException("generator not correctly initialized");
          }
  
          if (null == generator)
          {
