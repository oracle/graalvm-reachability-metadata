ttp://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.OutputStream;\nimport java.io.Serializable;\nimport java.math.BigInteger;\nimport java.security.spec.ECFieldFp;\nimport java.security.spec.ECParameterSpec;\nimport java.security.spec.ECPoint;\nimport java.security.spec.ECPrivateKeySpec;\nimport java.security.spec.EllipticCurve;\nimport java.util.Base64;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.ec.BCECPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BCECPrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\n            \"11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF\",\n            16);\n\n    @Test\n    public void javaSerializationRoundTripPreservesEcPrivateKey() throws Exception {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        BCECPrivateKey privateKey = createPrivateKey(PRIVATE_VALUE, parameters);\n        BCECPrivateKey restored = roundTrip(privateKey);\n\n        assertRestoredKey(restored, privateKey, parameters);\n    }\n\n    @Test\n    public void serializationHooksReadAndWriteEncodedKeyObject() throws Exception {\n        ECParameterSpec parameters = createSecp256r1Parameters();\n        BCECPrivateKey privateKey = createPrivateKey(PRIVATE_VALUE, parameters);\n        BCECPrivateKey restored = roundTripWithEncodedKeyReplacement(privateKey);\n\n        assertRestoredKey(restored, privateKey, parameters);\n    }\n\n    private static void assertRestoredKey(\n            BCECPrivateKey restored,\n            BCECPrivateKey privateKey,\n            ECParameterSpec parameters) {\n        assertThat(restored.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getD()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());\n    }\n\n    private static BCECPrivateKey createPrivateKey(\n            BigInteger privateValue,\n            ECParameterSpec parameters) {\n        return new BCECPrivateKey(\n                \"EC\",\n                new ECPrivateKeySpec(privateValue, parameters),\n                BouncyCastleProvider.CONFIGURATION);\n    }\n\n    private static BCECPrivateKey roundTrip(BCECPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {\n            return (BCECPrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static BCECPrivateKey roundTripWithEncodedKeyReplacement(BCECPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ReplacingEncodedKeyObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ResolvingEncodedKeyObjectInputStream(output.toByteArray())) {\n            return (BCECPrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static ECParameterSpec createSecp256r1Parameters() {\n        BigInteger p = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF\", 16);\n        BigInteger a = new BigInteger(\"FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC\", 16);\n        BigInteger b = new BigInteger(\"5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B\", 16);\n        BigInteger gx = new BigInteger(\"6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296\", 16);\n        BigInteger gy = new BigInteger(\"4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5\", 16);\n        BigInteger n = new BigInteger(\"FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551\", 16);\n\n        return new ECParameterSpec(\n                new EllipticCurve(new ECFieldFp(p), a, b),\n                new ECPoint(gx, gy),\n                n,\n                1);\n    }\n\n    private static final class ReplacingEncodedKeyObjectOutputStream extends ObjectOutputStream {\n        private ReplacingEncodedKeyObjectOutputStream(OutputStream outputStream) throws IOException {\n            super(outputStream);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) {\n            if (object instanceof byte[]) {\n                return new EncodedKey((byte[])object);\n            }\n            return object;\n        }\n    }\n\n    private static final class ResolvingEncodedKeyObjectInputStream extends ObjectInputStream {\n        private ResolvingEncodedKeyObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) {\n            if (object instanceof EncodedKey) {\n                return ((EncodedKey)object).encoded();\n            }\n            return object;\n        }\n    }\n\n    private static fina