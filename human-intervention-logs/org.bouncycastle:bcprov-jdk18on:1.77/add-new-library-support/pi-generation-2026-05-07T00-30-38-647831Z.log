[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCEdDSAPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.OutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.security.KeyPair;\n\nimport org.bouncycastle.crypto.prng.FixedSecureRandom;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.BCEdDSAPrivateKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.KeyPairGeneratorSpi.Ed25519;\nimport org.junit.jupiter.api.Test;\n\npublic class BCEdDSAPrivateKeyTest {\n    private static final byte[] PRIVATE_KEY_SEED = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1A, 0x1B,\n        0x1C, 0x1D, 0x1E, 0x1F,\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27,\n        0x28, 0x29, 0x2A, 0x2B,\n        0x2C, 0x2D, 0x2E, 0x2F\n    };\n    private static final byte[] RESTORED_PRIVATE_KEY_SEED = new byte[] {\n        0x30, 0x31, 0x32, 0x33,\n        0x34, 0x35, 0x36, 0x37,\n        0x38, 0x39, 0x3A, 0x3B,\n        0x3C, 0x3D, 0x3E, 0x3F,\n        0x40, 0x41, 0x42, 0x43,\n        0x44, 0x45, 0x46, 0x47,\n        0x48, 0x49, 0x4A, 0x4B,\n        0x4C, 0x4D, 0x4E, 0x4F\n    };\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedEdDsaPrivateKey() throws Throwable {\n        BCEdDSAPrivateKey privateKey = generateEd25519PrivateKey(PRIVATE_KEY_SEED);\n        BCEdDSAPrivateKey restoredSource = generateEd25519PrivateKey(RESTORED_PRIVATE_KEY_SEED);\n\n        byte[] writtenObjectStream = invokeWriteObject(privateKey);\n        assertThat(readObject(writtenObjectStream)).isEqualTo(privateKey.getEncoded());\n\n        byte[] restoredKeyStream = writeObject(restoredSource.getEncoded());\n        invokeReadObject(privateKey, new NoDefaultReadObjectInputStream(restoredKeyStream));\n\n        assertThat(privateKey.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(privateKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(privateKey).isEqualTo(restoredSource);\n        assertThat(privateKey.hashCode()).isEqualTo(restoredSource.hashCode());\n        assertThat(privateKey.getEncoded()).isEqualTo(restoredSource.getEncoded());\n        assertThat(privateKey.getPublicKey().getEncoded()).isEqualTo(restoredSource.getPublicKey().getEncoded());\n    }\n\n    private static BCEdDSAPrivateKey generateEd25519PrivateKey(byte[] seed) {\n        Ed25519 generator = new Ed25519();\n        generator.initialize(255, new FixedSecureRandom(seed));\n        KeyPair keyPair = generator.generateKeyPair();\n        assertThat(keyPair.getPrivate()).isInstanceOf(BCEdDSAPrivateKey.class);\n        return (BCEdDSAPrivateKey)keyPair.getPrivate();\n    }\n\n    private static byte[] invokeWriteObject(BCEdDSAPrivateKey privateKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {\n            WRITE_OBJECT.invokeExact(privateKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n\n    private static void invokeReadObject(BCEdDSAPrivateKey privateKey, ObjectInputStream inputStream) throws Throwable {\n        try (ObjectInputStream closeableInputSt