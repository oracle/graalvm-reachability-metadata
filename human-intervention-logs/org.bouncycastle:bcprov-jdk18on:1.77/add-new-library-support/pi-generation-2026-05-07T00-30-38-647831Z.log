[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCEdDSAPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.KeyPairGenerator;\nimport java.security.Provider;\nimport java.security.Signature;\n\nimport org.bouncycastle.crypto.prng.FixedSecureRandom;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.BCEdDSAPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class BCEdDSAPrivateKeyTest {\n    private static final byte[] PRIVATE_KEY_SEED = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1A, 0x1B,\n        0x1C, 0x1D, 0x1E, 0x1F,\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27,\n        0x28, 0x29, 0x2A, 0x2B,\n        0x2C, 0x2D, 0x2E, 0x2F\n    };\n    private static final byte[] MESSAGE = \"BCEdDSAPrivateKey serialization\".getBytes();\n\n    @Test\n    public void javaSerializationRoundTripPreservesEd25519PrivateKey() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyPair keyPair = generateEd25519KeyPair(provider);\n        assertThat(keyPair.getPrivate()).isInstanceOf(BCEdDSAPrivateKey.class);\n\n        BCEdDSAPrivateKey privateKey = (BCEdDSAPrivateKey)keyPair.getPrivate();\n        BCEdDSAPrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored).isNotSameAs(privateKey);\n        assertThat(restored).isEqualTo(privateKey);\n        assertThat(restored.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restored.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());\n\n        byte[] signature = sign(provider, restored);\n        assertThat(verifies(provider, keyPair, signature)).isTrue();\n    }\n\n    private static KeyPair generateEd25519KeyPair(Provider provider) throws Exception {\n        KeyPairGenerator generator = KeyPairGenerator.getInstance(\"Ed25519\", provider);\n        generator.initialize(255, new FixedSecureRandom(PRIVATE_KEY_SEED));\n        return generator.generateKeyPair();\n    }\n\n    private static BCEdDSAPrivateKey roundTrip(BCEdDSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {\n            return (BCEdDSAPrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static byte[] sign(Provider provider, BCEdDSAPrivateKey privateKey) throws Exception {\n        Signature signer = Signature.getInstance(\"Ed25519\", provider);\n        signer.initSign(privateKey);\n        signer.update(MESSAGE);\n        return signer.sign();\n    }\n\n    private static boolean verifies(Provider provider, KeyPair keyPair, byte[] signature) throws Exception {\n        Signature verifier = Signature.getInstance(\"Ed25519\", provider);\n        verifier.initVerify(keyPair.getPublic());\n        verifier.update(MESSAGE);\n        return verifier.verify(signature);\n    }\n}\n"}
