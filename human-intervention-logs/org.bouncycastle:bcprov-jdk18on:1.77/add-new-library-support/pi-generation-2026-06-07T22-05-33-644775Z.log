icates our setup. However, native images might initialize classes at build time before reaching test main.\"}]}"}, {"type": "toolCall", "id": "call_zBy7ny0wq6Blm11EkGE9V4Xj|fc_0eb6df6e03b175a4016a25ebd3231481969ca3700644ebda82", "name": "edit", "arguments": {"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/DRBGTest.java", "edits": [{"oldText": "            Provider provider = new BouncyCastleProvider();\n            SecureRandom random = SecureRandom.getInstance(\"DEFAULT\", provider);\n            byte[] generated = new byte[16];\n            random.nextBytes(generated);\n\n            assertThat(random.getAlgorithm()).isEqualTo(\"DEFAULT\");\n            assertThat(random.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n            assertThat(generated).hasSize(16);", "newText": "            Provider provider = new BouncyCastleProvider();\n\n            assertGeneratesBytesWithAlgorithm(provider, \"DEFAULT\");\n            assertGeneratesBytesWithAlgorithm(provider, \"NONCEANDIV\");"}, {"oldText": "    private static String requireSecurityProperty(String propertyName) {\n        String propertyValue = Security.getProperty(propertyName);\n        assertThat(propertyValue).isNotNull();\n        return propertyValue;\n    }", "newText": "    private static void assertGeneratesBytesWithAlgorithm(Provider provider, String algorithm) throws Exception {\n        SecureRandom random = SecureRandom.getInstance(algorithm, provider);\n        byte[] generated = new byte[16];\n        random.nextBytes(generated);\n\n        assertThat(random.getAlgorithm()).isEqualTo(algorithm);\n        assertThat(random.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n        assertThat(generated).hasSize(16);\n    }\n\n    private static String requireSecurityProperty(String propertyName) {\n        String propertyValue = Security.getProperty(propertyName);\n        assertThat(propertyValue