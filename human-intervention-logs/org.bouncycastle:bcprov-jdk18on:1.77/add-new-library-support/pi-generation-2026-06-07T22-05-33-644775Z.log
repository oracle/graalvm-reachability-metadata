       Security.setProperty(RANDOM_SOURCE_PROPERTY, INVALID_RANDOM_SOURCE_URL);\n            Security.setProperty(STRONG_ALGORITHMS_PROPERTY, UNAVAILABLE_STRONG_ALGORITHM);\n\n            Provider provider = new BouncyCastleProvider();", "newText": "        try {\n            configureInitialEntropySourceDiscovery();\n            assertThatThrownBy(SecureRandom::getInstanceStrong)\n                    .isInstanceOf(NoSuchAlgorithmException.class);\n\n            Provider provider = new BouncyCastleProvider();"}, {"oldText": "    private static void assertGeneratesBytesWithAlgorithm(Provider provider, String algorithm) throws Exception {\n        SecureRandom random = SecureRandom.getInstance(algorithm, provider);\n        byte[] generated = new byte[16];\n        random.nextBytes(generated);\n\n        assertThat(random.getAlgorithm()).isEqualTo(algorithm);\n        assertThat(random.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n        assertThat(generated).hasSize(16);\n    }\n\n    private static String requireSecurityProperty(String propertyName) {", "newText": "    private static void assertGeneratesBytesWithAlgorithm(Provider provider, String algorithm) throws Exception {\n        SecureRandom random = SecureRandom.getInstance(algorithm, provider);\n        byte[] generated = new byte[16];\n        random.nextBytes(generated);\n\n        assertThat(random.getAlgorithm()).isEqualTo(algorithm);\n        assertThat(random.getProvider().getName()).isEqualTo(BouncyCastleProvider.PROVIDER_NAME);\n        assertThat(generated).hasSize(16);\n    }\n\n    private static void configureInitialEntropySourceDiscovery() {\n        Security.setProperty(RANDOM_SOURCE_PROPERTY, INVALID_RANDOM_SOURCE_URL);\n        Security.setProperty(STRONG_ALGORITHMS_PROPERTY, UNAVAILABLE_STRONG_ALGORITHM);\n    }\n\n    public static class DRBGSecurityPropertiesExtension implements BeforeAllCallback {\n        @Override\n        public void beforeAll(ExtensionContext context) {\n            configureInitialEntropySourceDiscovery();\n        }\n    }\n\n    private static String requireSecurityProperty(String propertyName) {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 762, "output": 1724, "cacheRead": 48640, "cacheWrite": 0, "totalTokens": 51126, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780870411458, "responseId": "resp_0eb6df6e03b175a4016a25ed0c93d481968917cee490034da9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Z1YrSsQCvn1dYNNtnm4KpVkC|fc_0eb6df6e03b175a4016a25ed2661408196a45dcd1fdb3515d5", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 3 block(s) in tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/DRBGTest.java."}], "details": {"diff": "    ...\n  7 package org_bouncycastle.bcprov_jdk18on;\n  8 \n  9 import org.bouncycastle.jce.provider.BouncyCastleProvider;\n 10 import org.junit.jupiter.api.Test;\n+11 import org.junit.jupiter.api.extension.BeforeAllCallback;\n+12 import org.junit.jupiter.api.extension.ExtensionContext;\n 11 import org.junit.jupiter.api.parallel.ResourceLock;\n 12 \n+15 import java.security.NoSuchAlgorithmException;\n 13 import java.security.Provider;\n 14 import java.security.SecureRandom;\n 15 import java.security.Security;\n 16 \n 17 import static org.assertj.core.api.Assertions.assertThat;\n+21 import static org.assertj.core.api.Assertions.assertThatThrownBy;\n 18 \n 19 public class DRBGTest {\n 20     private static final String RANDOM_SOURCE_PROPERTY = \"securerandom.source\";\n 21     private static final String STRONG_ALGORITHMS_PROPERTY = \"securerandom.strongAlgorithms\";\n    ...\n 28         String originalRandomSource = requireSecurityProperty(RANDOM_SOURCE_PROPERTY);\n 29         String originalStrongAlgorithms = requireSecurityProperty(STRONG_ALGORITHMS_PROPERTY);\n 30 