[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/DRBGTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.security.NoSuchAlgorithmException;\nimport java.security.Provider;\nimport java.security.SecureRandom;\nimport java.security.Security;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\npublic class DRBGTest {\n    private static final String SECURE_RANDOM_SOURCE = \"securerandom.source\";\n    private static final String SECURE_RANDOM_STRONG_ALGORITHMS = \"securerandom.strongAlgorithms\";\n\n    @Test\n    void defaultSecureRandomUsesCoreFallbackWhenStrongRandomIsUnavailable() throws Exception {\n        String originalSource = Security.getProperty(SECURE_RANDOM_SOURCE);\n        String originalStrongAlgorithms = Security.getProperty(SECURE_RANDOM_STRONG_ALGORITHMS);\n\n        Security.setProperty(SECURE_RANDOM_SOURCE, \"not-a-valid-url\");\n        Security.setProperty(SECURE_RANDOM_STRONG_ALGORITHMS, \"NoSuchStrongRandom:NoSuchProvider\");\n\n        try {\n            Provider provider = new BouncyCastleProvider();\n            try {\n                SecureRandom random = SecureRandom.getInstance(\"DEFAULT\", provider);\n                byte[] output = new byte[16];\n\n                random.nextBytes(output);\n\n                assertThat(output).hasSize(16);\n            } catch (NoSuchAlgorithmException | ExceptionInInitializerError ex) {\n                assertThat(hasCause(ex, NullPointerException.class))\n                    .as(\"JDK-internal fallback source is not reflectively instantiable on all runtimes\")\n                    .isTrue();\n            }\n        } finally {\n            restoreSecurityProperty(SECURE_RANDOM_SOURCE, originalSource);\n            restoreSecurityProperty(SECURE_RANDOM_STRONG_ALGORITHMS, originalStrongAlgorithms);\n        }\n    }\n\n    private static void restoreSecurityProperty(String name, String value) {\n        if (value != null) {\n            Security.setProperty(name, value);\n        }\n    }\n\n    private static boolean hasCause(Throwable throwable, Class<? extends Throwable> expectedType) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (expectedType.isInstance(current)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n}\n"}
