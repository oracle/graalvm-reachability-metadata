              }
  
              void schedule()
              {
                  if (!scheduled.getAndSet(true))
                  {
                      entropyDaemon.addTask(new EntropyGatherer(entropySource, seedAvailable, entropy));
                  }
              }
  
              public int entropySize()
              {
                  return byteLength * 8;
              }
          }
