  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.x509.X509CollectionStoreParameters;
  import org.bouncycastle.x509.X509Store;
  import org.bouncycastle.x509.X509StreamParser;
  import org.bouncycastle.x509.util.StreamParsingException;
  import org.junit.jupiter.api.Test;
  
  import java.security.Provider;
  import java.security.Security;
  import java.util.Collections;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class X509UtilTest {
      private static final String bootstrapParserType = "GRAALVMREACHABILITYTESTCERTIFICATE";
      private static final String bootstrapStoreType = "GRAALVMREACHABILITYTESTCERTIFICATE/COLLECTION";
      private static final String parserProperty = "X509StreamParser." + bootstrapParserType;
      private static final String storeProperty = "X509Store." + bootstrapStoreType;
      private static final String certificateParserClass = "org.bouncycastle.jce.provider.X509CertParser";
      private static final String certificateStoreClass = "org.bouncycastle.jce.provider.X509StoreCertCollection";
  
      @Test
      void createsParserFromBouncyCastleProvider() throws Exception {
          Provider provider = new BouncyCastleProvider();
  
          X509StreamParser parser = X509StreamParser.getInstance("CERTIFICATE", provider);
  
          assertThat(parser.getProvider()).isSameAs(provider);
          assertEmptyParser(parser);
      }
  
      @Test
      void createsParserFromBootstrapLoadedProvider() throws Exception {
          Provider provider = findBootstrapLoadedProvider();
          Object previousValue = provider.put(parserProperty, certificateParserClass);
  
          try {
              X509StreamParser parser = X509StreamParser.getInstance(bootstrapParserType, provider);
  
              assertThat(parser.getProvider()).isSameAs(provider);
              assertEmptyParser(parser);
          } finally {
              restoreProviderProperty(provider, parserProperty, previousValue);
          }
      }
  
      @Test
      void createsParserFromFirstSecurityProvider() throws Exception {
          Provider provider = new BouncyCastleProvider();
          Object[] previousProviderState = installProviderFirst(provider);
  
          try {
              X509StreamParser parser = X509StreamParser.getInstance("CERTIFICATE");
  
              assertThat(parser.getProvider().getName()).isEqualTo(provider.getName());
              assertEmptyParser(parser);
          } finally {
              restoreSecurityProvider(provider, previousProviderState);
          }
      }
  
      @Test
      void createsStoreFromBouncyCastleProvider() throws Exception {
          Provider provider = new BouncyCastleProvider();
  
          X509Store store = X509Store.getInstance(
                  "CERTIFICATE/COLLECTION",
                  new X509CollectionStoreParameters(Collections.emptyList()),
                  provider);
  
          assertThat(store.getProvider()).isSameAs(provider);
          assertThat(store.getMatches(null)).isEmpty();
      }
  
      @Test
      void createsStoreFromBootstrapLoadedProvider() throws Exception {
          Provider provider = findBootstrapLoadedProvider();
          Object previousValue = provider.put(storeProperty, certificateStoreClass);
  
          try {
              X509Store store = X509Store.getInstance(
                      bootstrapStoreType,
                      new X509CollectionStoreParameters(Collections.emptyList()),
                      provider);
  
              assertThat(store.getProvider()).isSameAs(provider);
              assertThat(store.getMatches(null)).isEmpty();
          } finally {
              restoreProviderProperty(provider, storeProperty, previousValue);
          }
      }
  
      @Test
      void createsStoreFromFirstSecurityProvider() throws Exception {
          Provider provider = new BouncyCastleProvider();
          Object[] previousProviderState = installProviderFirst(provider);
  
          try {
              X509Store store = X509Store.getInstance(
                      "CERTIFICATE/COLLECTION",
                      new X509CollectionStoreParameters(Collections.emptyList()));
  
              assertThat(store.getProvider().getName()).isEqualTo(provider.getName());
              assertThat(store.getMatches(null)).isEmpty();
          } finally {
              restoreSecurityProvider(provider, previousProviderState);
          }
      }
  
      private static void restoreProviderProperty(Provider provider, String property, Object previousValue) {
          if (previousValue == null) {
              provider.remove(property);
          } else {
              provider.put(property, previousValue);
          }
      }
  
      private static Object[] installProviderFirst(Provider provider) {
          Provider[] providers = Security.getProviders();
          Provider previousProvider = null;
          int previousPosition = -1;
  
          for (int i = 0; i < providers.length; i++) {
              if (providers[i].getName().equals(provider.getName())) {
                  previousProvider = providers[i];
                  previousPosition = i + 1;
                  Security.removeProvider(provider.getName());
                  break;
              }
          }
  
          Security.insertProviderAt(provider, 1);
          return new Object[] { previousProvider, previousPosition };
      }
  
      private static void restoreSecurityProvider(Provider provider, Object[] previousProviderState) {
          Security.removeProvider(provider.getName());
  
          Provider previousProvider = (Provider)previousProviderState[0];
          if (previousProvider != null) {
              int previousPosition = (Integer)previousProviderState[1];
              Security.insertProviderAt(previousProvider, previousPosition);
          }
      }
  
      private static Provider findBootstrapLoadedProvider() {
          for (Provider provider : Security.getProviders()) {
              if (provider.getClass().getClassLoader() == null) {
                  return provider;
              }
          }
  
          throw new IllegalStateException("No bootstrap-loaded JCA provider is available");
      }
  
      private static void assertEmptyParser(X509StreamParser parser) throws StreamParsingException {
          parser.init(new byte[0]);
  
          assertThat(parser.read()).isNull();
          assertThat(parser.readAll()).isEmpty();
      }
  }
