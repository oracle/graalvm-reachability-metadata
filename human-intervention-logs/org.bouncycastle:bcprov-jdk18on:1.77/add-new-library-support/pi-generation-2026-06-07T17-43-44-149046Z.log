[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/LocalizedMessageTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.i18n.LocalizedMessage;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Locale;\nimport java.util.TimeZone;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LocalizedMessageTest {\n    private static final String CERT_PATH_REVIEWER_MESSAGES = \"org.bouncycastle.x509.CertPathReviewerMessages\";\n    private static final TimeZone UTC = TimeZone.getTimeZone(\"UTC\");\n\n    @Test\n    void loadsResourceBundleEntryWithDefaultClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(\n                CERT_PATH_REVIEWER_MESSAGES,\n                \"CertPathReviewer.emptyCertPath\");\n\n        String title = message.getEntry(\"title\", Locale.ENGLISH, UTC);\n\n        assertThat(title).isEqualTo(\"CertPath is empty\");\n    }\n\n    @Test\n    void loadsResourceBundleEntryWithExplicitClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(\n                CERT_PATH_REVIEWER_MESSAGES,\n                \"CertPathReviewer.totalPathLength\",\n                new Object[] { Integer.valueOf(3) });\n        ClassLoader resourceLoader = ClassLoader.getSystemClassLoader();\n        assertThat(resourceLoader).isNotNull();\n        message.setClassLoader(resourceLoader);\n\n        String text = message.getEntry(\"text\", Locale.ENGLISH, UTC);\n\n        assertThat(text).isEqualTo(\"The total path length without self-signed certificates is 3.\");\n    }\n}\n"}
