[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/LocalizedMessageTest.java","edits":[{"oldText":"import org.bouncycastle.i18n.LocalizedMessage;\nimport org.bouncycastle.i18n.MissingEntryException;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.Locale;\nimport java.util.TimeZone;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class LocalizedMessageTest {\n    private static final String MISSING_MESSAGES = \"org.bouncycastle.missing.Messages\";\n    private static final TimeZone UTC = TimeZone.getTimeZone(\"UTC\");\n\n    @Test\n    void reportsMissingResourceBundleWithDefaultClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(MISSING_MESSAGES, \"missingMessage\");\n\n        assertThatThrownBy(() -> message.getEntry(\"title\", Locale.ENGLISH, UTC))\n                .isInstanceOfSatisfying(MissingEntryException.class, exception -> {\n                    assertThat(exception.getResource()).isEqualTo(MISSING_MESSAGES);\n                    assertThat(exception.getKey()).isEqualTo(\"missingMessage.title\");\n                    assertThat(exception.getLocale()).isEqualTo(Locale.ENGLISH);\n                    assertThat(exception.getClassLoader()).isNull();\n                });\n    }\n\n    @Test\n    void reportsMissingResourceBundleWithExplicitClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(MISSING_MESSAGES, \"missingMessage\");\n        ClassLoader resourceLoader = ClassLoader.getSystemClassLoader();\n        assertThat(resourceLoader).isNotNull();\n        message.setClassLoader(resourceLoader);\n\n        assertThatThrownBy(() -> message.getEntry(\"text\", Locale.ENGLISH, UTC))\n                .isInstanceOfSatisfying(MissingEntryException.class, exception -> {\n                    assertThat(exception.getResource()).isEqualTo(MISSING_MESSAGES);\n                    assertThat(exception.getKey()).isEqualTo(\"missingMessage.text\");\n                    assertThat(exception.getLocale()).isEqualTo(Locale.ENGLISH);\n                    assertThat(exception.getClassLoader()).isSameAs(resourceLoader);\n                });\n    }\n}\n","newText":"import org.bouncycastle.i18n.LocalizedMessage;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.ListResourceBundle;\nimport java.util.Locale;\nimport java.util.TimeZone;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LocalizedMessageTest {\n    private static final String TEST_MESSAGES = Messages.class.getName();\n    private static final TimeZone UTC = TimeZone.getTimeZone(\"UTC\");\n\n    @Test\n    void loadsClassBackedResourceBundleEntryWithDefaultClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(TEST_MESSAGES, \"localizedMessage\");\n\n        String title = message.getEntry(\"title\", Locale.ENGLISH, UTC);\n\n        assertThat(title).isEqualTo(\"Localized title\");\n    }\n\n    @Test\n    void loadsClassBackedResourceBundleEntryWithExplicitClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(\n                TEST_MESSAGES,\n                \"localizedMessage\",\n                new Object[] { \"argument\" });\n        ClassLoader resourceLoader = ClassLoader.getSystemClassLoader();\n        assertThat(resourceLoader).isNotNull();\n        message.setClassLoader(resourceLoader);\n\n        String text = message.getEntry(\"text\", Locale.ENGLISH, UTC);\n\n        assertThat(text).isEqualTo(\"Localized text with argument\");\n    }\n\n    public static class Messages extends ListResourceBundle {\n        @Override\n        protected Object[][] getContents() {\n            return new Object[][] {\n                    { \"localizedMessage.title\", \"Localized title\" },\n                    { \"localizedMessage.text\", \"Localized text with {0}\" }\n            };\n        }\n    }\n}\n"}]}
