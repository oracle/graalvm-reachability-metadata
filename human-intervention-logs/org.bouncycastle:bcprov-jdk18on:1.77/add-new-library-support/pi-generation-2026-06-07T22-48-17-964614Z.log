[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JCEDHPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jce.provider.JCEDHPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.ObjectStreamConstants;\nimport java.math.BigInteger;\nimport java.util.Arrays;\n\nimport javax.crypto.interfaces.DHPublicKey;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCEDHPublicKeyTest {\n    private static final BigInteger P = new BigInteger(\n            \"155251809230070893513091813125848175563133404943451431320235\"\n                    + \"119490296623994910210725866945387659164244291000768028886422\"\n                    + \"915080371891804634263272761303128298374438082089019628850917\"\n                    + \"0691316593175367469551763119843371637221007210577919\");\n    private static final BigInteger G = BigInteger.valueOf(2L);\n    private static final BigInteger PUBLIC_VALUE = new BigInteger(\"987654321098765432109876543210987654321\");\n    private static final int PUBLIC_VALUE_LENGTH = 32;\n\n    @Test\n    void serializesAndRestoresJceDhPublicKeyParameters() throws Exception {\n        JCEDHPublicKey restored = deserialize(serializedJceDhPublicKey());\n\n        assertThat(restored.getY()).isEqualTo(PUBLIC_VALUE);\n        assertThat(restored.getParams().getP()).isEqualTo(P);\n        assertThat(restored.getParams().getG()).isEqualTo(G);\n        assertThat(restored.getParams().getL()).isEqualTo(PUBLIC_VALUE_LENGTH);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n\n        JCEDHPublicKey roundTripped = deserialize(serialize(restored));\n\n        assertThat(roundTripped.getY()).isEqualTo(restored.getY());\n        assertThat(roundTripped.getParams().getP()).isEqualTo(restored.getParams().getP());\n        assertThat(roundTripped.getParams().getG()).isEqualTo(restored.getParams().getG());\n        assertThat(roundTripped.getParams().getL()).isEqualTo(restored.getParams().getL());\n    }\n\n    private static byte[] serializedJceDhPublicKey() throws IOException {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        DataOutputStream output = new DataOutputStream(serialized);\n        output.writeShort(ObjectStreamConstants.STREAM_MAGIC);\n        output.writeShort(ObjectStreamConstants.STREAM_VERSION);\n        output.writeByte(ObjectStreamConstants.TC_OBJECT);\n        output.writeByte(ObjectStreamConstants.TC_CLASSDESC);\n        output.writeUTF(JCEDHPublicKey.class.getName());\n        output.writeLong(ObjectStreamClass.lookup(JCEDHPublicKey.class).getSerialVersionUID());\n        output.writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n        output.writeShort(0);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        output.writeByte(ObjectStreamConstants.TC_NULL);\n        output.write(serializedObjectPayload(PUBLIC_VALUE));\n        output.write(serializedObjectPayload(P));\n        output.write(serializedObjectPayload(G));\n        output.writeByte(ObjectStreamConstants.TC_BLOCKDATA);\n        output.writeByte(Integer.BYTES);\n        output.writeInt(PUBLIC_VALUE_LENGTH);\n        output.writeByte(ObjectStreamConstants.TC_ENDBLOCKDATA);\n        return serialized.toByteArray();\n    }\n\n    private