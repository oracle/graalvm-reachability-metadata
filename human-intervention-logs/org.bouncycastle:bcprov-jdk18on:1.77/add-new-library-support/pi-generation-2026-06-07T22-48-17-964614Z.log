          }
      }
  
      private static JournaledAlgorithm newJournaledAlgorithm() {
          return new JournaledAlgorithm(
                  new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION),
                  new JournalingSecureRandom(new byte[] { 11, 22, 33, 44 }, new SecureRandom()));
      }
  }
