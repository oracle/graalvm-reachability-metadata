  assertBikePrivateKey(restored, privateKey);\n    }\n\n    private static BCBIKEPrivateKey newBikePrivateKey() {\n        BIKEParameters parameters = BIKEParameters.bike128;\n        byte[] h0 = filledBytes(parameters.getRByte(), 0x11);\n        byte[] h1 = filledBytes(parameters.getRByte(), 0x33);\n        byte[] sigma = filledBytes(parameters.getLByte(), 0x55);\n        BIKEPrivateKeyParameters keyParameters = new BIKEPrivateKeyParameters(parameters, h0, h1, sigma);\n        return new BCBIKEPrivateKey(keyParameters);\n    }\n\n    private static byte[] filledBytes(int length, int firstValue) {\n        byte[] bytes = new byte[length];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte)(firstValue + index);\n        }\n        return bytes;\n    }\n\n    private static void assertBikePrivateKey(BCBIKEPrivateKey actual, BCBIKEPrivateKey expected) {\n        assertThat(actual.getAlgorithm()).isEqualTo(\"BIKE128\");\n        assertThat(actual.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(actual.getParameterSpec()).isSameAs(BIKEParameterSpec.bike128);\n        assertThat(actual).isEqualTo(expected);\n        assertThat(actual.hashCode()).isEqualTo(expected.hashCode());\n        assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());\n    }\n\n    private static byte[] writeObject(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return inputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778132249054}, {"role": "toolResult",