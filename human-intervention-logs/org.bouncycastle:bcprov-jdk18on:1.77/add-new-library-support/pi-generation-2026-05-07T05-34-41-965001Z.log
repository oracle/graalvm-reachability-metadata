[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCBIKEPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.bouncycastle.pqc.crypto.bike.BIKEParameters;\nimport org.bouncycastle.pqc.crypto.bike.BIKEPrivateKeyParameters;\nimport org.bouncycastle.pqc.jcajce.provider.bike.BCBIKEPrivateKey;\nimport org.bouncycastle.pqc.jcajce.spec.BIKEParameterSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCBIKEPrivateKeyTest {\n    @Test\n    public void objectSerializationWritesAndReadsEncodedBikePrivateKey() throws Exception {\n        BCBIKEPrivateKey privateKey = newBikePrivateKey();\n\n        Object restoredObject = readObject(writeObject(privateKey));\n\n        assertThat(restoredObject).isInstanceOf(BCBIKEPrivateKey.class);\n        BCBIKEPrivateKey restored = (BCBIKEPrivateKey)restoredObject;\n        assertThat(restored).isNotSameAs(privateKey);\n        assertBikePrivateKey(restored, privateKey);\n    }\n\n    private static BCBIKEPrivateKey newBikePrivateKey() {\n        BIKEParameters parameters = BIKEParameters.bike128;\n        byte[] h0 = filledBytes(parameters.getRByte(), 0x11);\n        byte[] h1 = filledBytes(parameters.getRByte(), 0x33);\n        byte[] sigma = filledBytes(parameters.getLByte(), 0x55);\n        BIKEPrivateKeyParameters keyParameters = new BIKEPrivateKeyParameters(parameters, h0, h1, sigma);\n        return new BCBIKEPrivateKey(keyParameters);\n    }\n\n    private static byte[] filledBytes(int length, int firstValue) {\n        byte[] bytes = new byte[length];\n        for (int index = 0; index < bytes.length; index++) {\n            bytes[index] = (byte)(firstValue + index);\n        }\n        return bytes;\n    }\n\n    private static void assertBikePrivateKey(BCBIKEPrivateKey actual, BCBIKEPrivateKey expected) {\n        assertThat(actual.getAlgorithm()).isEqualTo(\"BIKE128\");\n        assertThat(actual.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(actual.getParameterSpec()).isSameAs(BIKEParameterSpec.bike128);\n        assertThat(actual).isEqualTo(expected);\n        assertThat(actual.hashCode()).isEqualTo(expected.hashCode());\n        assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());\n    }\n\n    private static byte[] writeObject(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return inputStream.readObject();\n        }\n    }\n}\n"}
