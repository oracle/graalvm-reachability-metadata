alueOf(5L);\n    private static final BigInteger X = BigInteger.valueOf(6L);\n    private static final BigInteger RESTORED_P = BigInteger.valueOf(47L);\n    private static final BigInteger RESTORED_G = BigInteger.valueOf(2L);\n    private static final int PRIVATE_VALUE_LENGTH = 5;\n\n    @Test\n    public void serializesAndRestoresDiffieHellmanPrivateKeyParameters() throws Exception {\n        BCDHPrivateKey original = createPrivateKey(P, G);\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        invokeSerializationHook(original, \"writeObject\", ObjectOutputStream.class, outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(P, G);\n        assertThat(outputStream.writtenInt()).isEqualTo(PRIVATE_VALUE_LENGTH);\n\n        BCDHPrivateKey restored = createPrivateKey(P, G);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                RESTORED_P,\n                RESTORED_G,\n                PRIVATE_VALUE_LENGTH);\n\n        invokeSerializationHook(restored, \"readObject\", ObjectInputStream.class, inputStream);\n\n        assertThat(restored.getX()).isEqualTo(X);\n        assertThat(restored.getParams().getP()).isEqualTo(RESTORED_P);\n        assertThat(restored.getParams().getG()).isEqualTo(RESTORED_G);\n        assertThat(restored.getParams().getL()).isEqualTo(PRIVATE_VALUE_LENGTH);\n    }\n\n    private static BCDHPrivateKey createPrivateKey(BigInteger p, BigInteger g) throws Exception {\n        DHParameter parameters = new DHParameter(p, g, PRIVATE_VALUE_LENGTH);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                PKCSObjectIdentifiers.dhKeyAgreement,\n                parameters.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(X));\n\n        return new BCDHPrivateKey(privateKeyInfo);\n    }\n\n    private static void invokeSerializationHook(\n            BCDHPrivateKey privateKey,\n            String methodName,\n            Class<?> streamType,\n            Object stream) throws Exception {\n        Method method = BCDHPrivateKey.class.getDeclaredMethod(methodName, streamType);\n        method.setAccessible(true);\n        method.invoke(privateKey, stream);\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final Object[] objects = new Object[2];\n        private int objectCount;\n        private int intValue;\n\n        private RecordingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects[objectCount] = object;\n            objectCount++;\n        }\n\n        @Override\n        public void writeInt(int value) {\n            intValue = value;\n        }\n\n        private Object[] writtenObjects() {\n            Object[] written = new Object[objectCount];\n            System.arraycopy(objects, 0, written, 0, objectCount);\n            return written;\n        }\n\n        private int writtenInt() {\n            return intValue;\n        }\n    }\n\n    private static final class ReplayingObjectInputStream extends ObjectInputStream {\n        private final Object[] objects;\n        private final int intValue;\n        private int objectIndex;\n\n        private ReplayingObjectInputStream(Object firstObject, Object secondObject, int intValue) throws IOException {\n            super();\n            this.objects = new Object[] {firstObject, secondObject};\n            this.intValue = intValue;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            Object object = objects[objectIndex];\n            objectIndex++;\n            return object;\n        }\n\n        @Override\n        public int readInt() {\n            return intValue;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778108246953}]}
