ava/org_bouncycastle/bcprov_jdk18on/JournaledAlgorithmTest.java", "limit": 220}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1813, "output": 970, "cacheRead": 54272, "cacheWrite": 0, "totalTokens": 57055, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778108565286, "responseId": "resp_048c618117f648020169fbc8962e208197b01076f647bdbee1"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ci51NVjNn6Y28ZF4qujzHoGQ|fc_048c618117f648020169fbc8a629b88197b3c045452a2fb186", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.OutputStream;\nimport java.security.SecureRandom;\n\nimport org.bouncycastle.asn1.nist.NISTObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.crypto.util.JournaledAlgorithm;\nimport org.bouncycastle.crypto.util.JournalingSecureRandom;\nimport org.junit.jupiter.api.Test;\n\npublic class JournaledAlgorithmTest {\n    @Test\n    public void serializesAndRestoresJournaledAlgorithmState() throws Exception {\n        JournalingSecureRandom journalingSecureRandom = new JournalingSecureRandom(new SecureRandom());\n        byte[] originalRandom = new byte[32];\n        journalingSecureRandom.nextBytes(originalRandom);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(NISTObjectIdentifiers.id_aes128_CBC);\n        JournaledAlgorithm original = new JournaledAlgorithm(algorithmIdentifier, journalingSecureRandom);\n\n        byte[] serialized = serialize(original);\n        JournaledAlgorithm restored = deserialize(serialized);\n\n        byte[] replayedRandom = new byte[originalRandom.length];\n        restored.getJournalingSecureRandom().nextBytes(replayedRandom);\n        assertThat(replayedRandom).isEqualTo(originalRandom);\n        assertThat(restored.getAlgorithmIdentifier().getAlgorithm()).isEqualTo(algorithmIdentifier.getAlgorithm());\n    }\n\n    private static byte[] serialize(JournaledAlgorithm journaledAlgorithm) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ReplacingObjectOutputStream(serialized)) {\n            outputStream.writeObject(journaledAlgorithm);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JournaledAlgorithm deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream inputStream = new ResolvingObjectInputStream(serialized)) {\n            return (JournaledAlgorithm) inputStream.readObject();\n        }\n    }\n\n    private static final class ReplacingObjectOutputStream extends ObjectOutputStream {\n        private boolean replacedEncoding;\n\n        ReplacingObjectOutputStream(OutputStream outputStream) throws IOException {\n            super(outputStream);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) {\n            if (!replacedEncoding && object instanceof byte[]) {\n                replacedEncoding = true;\n                return new JournaledAlgorithm((byte[]) object, new SecureRandom());\n            }\n            return object;\n        }\n    }\n\n    private static final class ResolvingObjectInputStream extends ObjectInputStream {\n        private boolean resolvedEncoding;\n\n        ResolvingObjectInputStream(byte[] serialized) throws IOException {\n            super(new ByteArrayInputStream(serialized));\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) throws IOException {\n            if (!resolvedEncoding && object instanceof JournaledAlgorithm) {\n                resolvedEncoding = true;\n                return ((JournaledAlgorithm) object).getEncoded();\n            }\n            return object;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778108582666}]}
