  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.math.BigInteger;
  import java.security.spec.ECFieldFp;
  import java.security.spec.ECParameterSpec;
  import java.security.spec.ECPoint;
  import java.security.spec.ECPrivateKeySpec;
  import java.security.spec.EllipticCurve;
  
  import org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCDSTU4145PrivateKeyTest {
      private static final BigInteger PRIVATE_VALUE = new BigInteger(
              "11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF",
              16);
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void javaSerializationRoundTripPreservesDstu4145PrivateKey() throws Exception {
          ECParameterSpec parameters = createSecp256r1Parameters();
          BCDSTU4145PrivateKey privateKey = new BCDSTU4145PrivateKey(
                  new ECPrivateKeySpec(PRIVATE_VALUE, parameters));
  
          BCDSTU4145PrivateKey restored = roundTrip(privateKey);
  
          assertThat(restored.getAlgorithm()).isEqualTo("DSTU4145");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getEncoded()).isEqualTo(privateKey.getEncoded());
          assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());
          assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());
          assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());
      }
  
      @Test
      public void serializationHooksWriteAndReadEncodedKey() throws Throwable {
          ECParameterSpec parameters = createSecp256r1Parameters();
          BCDSTU4145PrivateKey privateKey = new BCDSTU4145PrivateKey(
                  new ECPrivateKeySpec(PRIVATE_VALUE, parameters));
          RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();
  
          WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);
  
          byte[] encoded = privateKey.getEncoded();
          assertThat(outputStream.writtenObject()).isEqualTo(encoded);
  
          BCDSTU4145PrivateKey restored = new BCDSTU4145PrivateKey(
                  new ECPrivateKeySpec(BigInteger.ONE, parameters));
          ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(encoded);
  
          READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);
  
          assertThat(restored.getAlgorithm()).isEqualTo("DSTU4145");
          assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getEncoded()).isEqualTo(encoded);
          assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());
      }
  
      private static BCDSTU4145PrivateKey roundTrip(BCDSTU4145PrivateKey privateKey) throws Exception {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              outputStream.writeObject(privateKey);
          }
  
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {
              return (BCDSTU4145PrivateKey)inputStream.readObject();
          }
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCDSTU4145PrivateKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCDSTU4145PrivateKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCDSTU4145PrivateKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCDSTU4145PrivateKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static ECParameterSpec createSecp256r1Parameters() {
          BigInteger p = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF", 16);
          BigInteger a = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC", 16);
          BigInteger b = new BigInteger("5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B", 16);
          BigInteger gx = new BigInteger("6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296", 16);
          BigInteger gy = new BigInteger("4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5", 16);
          BigInteger n = new BigInteger("FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551", 16);
  
          return new ECParameterSpec(
                  new EllipticCurve(new ECFieldFp(p), a, b),
                  new ECPoint(gx, gy),
                  n,
                  1);
      }
  
      private static final class RecordingObjectOutputStream extends ObjectOutputStream {
          private Object writtenObject;
  
          private RecordingObjectOutputStream() throws Exception {
              super();
          }
  
          @Override
          public void defaultWriteObject() {
          }
  
          @Override
          protected void writeObjectOverride(Object object) {
              writtenObject = object;
          }
  
          private Object writtenObject() {
              return writtenObject;
          }
      }
  
      private static final class ReplayingObjectInputStream extends ObjectInputStream {
          private final Object object;
  
          private ReplayingObjectInputStream(Object object) throws Exception {
              super();
              this.object = object;
          }
  
          @Override
          public void defaultReadObject() {
          }
  
          @Override
          protected Object readObjectOverride() {
              return object;
          }
      }
  }
