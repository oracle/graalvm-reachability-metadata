import org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.DSAParameter;\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSAPrivateKeyTest {\n    private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);\n    private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);\n    private static final BigInteger X = BigInteger.valueOf(3L);\n    private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);\n    private static final BigInteger RESTORED_Q = TrackedBigInteger.trackedValueOf(23L);\n    private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(2L);\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n    private static final VarHandle DSA_SPEC = findDsaSpec();\n\n    @Test\n    public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {\n        BCDSAPrivateKey original = createPrivateKey(P, Q, G);\n        DSA_SPEC.set(original, new DsaParams(P, Q, G));\n\n        byte[] writtenParameters = invokeWriteObject(original);\n\n        assertThat(readObjects(writtenParameters)).containsExactly(P, Q, G);\n\n        BCDSAPrivateKey restored = createPrivateKey(P, Q, G);\n        byte[] restoredParameterStream = writeObjects(RESTORED_P, RESTORED_Q, RESTORED_G);\n\n        try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(restoredParameterStream)) {\n            invokeReadObject(restored, inputStream);\n        }\n        DSAParams restoredParameters = restored.getParams();\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(X);\n        assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);\n        assertThat(restoredParameters.getQ()).isEqualTo(RESTORED_Q);\n        assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);\n    }\n\n    private static BCDSAPrivateKey createPrivateKey(BigInteger p, BigInteger q, BigInteger g) throws Exception {\n        DSAParameter parameters = new DSAParameter(p, q, g);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                X9ObjectIdentifiers.id_dsa,\n                parameters.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(X));\n\n        return new BCDSAPrivateKey(privateKeyInfo);\n    }\n\n    private static byte[] invokeWriteObject(BCDSAPrivateKey privateKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {\n            WRITE_OBJECT.invokeExact(privateKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n\n    private static void invokeReadObject(BCDSAPrivateKey privateKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(privateKey, inputStream);\n    }\n\n    private static byte[] writeObjects(Object firstObject, Object secondObject, Object thirdObject) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(firstObject);\n            outputStream.writeObject(secondObject);\n            outputStream.writeObject(thirdObject);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return new Object[] {inputStream.readObject(), inputStream.readObject(), inputStream.readObject()};\n        }\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPrivateKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSAPrivateKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPrivateKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSAPrivateKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static VarHandle findDsaSpec() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDSAPrivateKey.class, MethodHandles.lookup());\n            return lookup.findVarHandle(BCDSAPrivateKey.class, \"dsaSpec\", DSAParams.class);\n        }\n        catch (IllegalAccessException | NoSuchFieldException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class NoDefaultWriteObjectOutputStream extends ObjectOutputStream {\n        private NoDefaultWriteObjectOutputStream(OutputStream outputStream) throws IOException {\n            super(outputStream);\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n    }\n\n    private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {\n        private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n\n    private static final class DsaParams implements DSAParams {\n        private final BigInteger p;\n        private final BigInteger q;\n        private final BigInteger g;\n\n        private DsaParams(BigInteger p, BigInteger q, BigInteger g) {\n            this.p = p;\n            this.q = q;\n            this.g = g;\n        }\n\n        @Override\n        public BigInteger getP() {\n            return p;\n        }\n\n        @Override\n        public BigInteger getQ() {\n            return q;\n        }\n\n        @Override\n        public BigInteger getG() {\n            return g;\n        }\n    }\n\n    private static final class TrackedBigInteger extends BigInteger {\n        private static final long serialVersionUID = 1L;\n\n        private TrackedBigInteger(long value) {\n            super(Long.toString(value));\n        }\n\n        private static TrackedBigInteger trackedValueOf(long value) {\n            return new TrackedBigInteger(value);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778108015933}]}
