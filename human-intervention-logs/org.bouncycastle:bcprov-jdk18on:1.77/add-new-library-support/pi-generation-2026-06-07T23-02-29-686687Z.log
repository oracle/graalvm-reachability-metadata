       \"1122334455667788990011223344556677889900112233445566778899001122\");\n\n    @Test\n    void serializesAndRestoresEcPrivateKeySpecParameters() throws Exception {\n        ECPrivateKey original = newBcEcPrivateKey();\n\n        ECPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void serializesAndRestoresCompressedEcPrivateKeySpecParameters() throws Exception {\n        BCECPrivateKey original = newBcEcPrivateKey();\n        original.setPointFormat(\"COMPRESSED\");\n\n        ECPrivateKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static BCECPrivateKey newBcEcPrivateKey() {\n        ECNamedCurveParameterSpec namedCurve = ECNamedCurveTable.getParameterSpec(\"secp256r1\");\n        ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(\n                \"secp256r1\",\n                namedCurve.getCurve(),\n                namedCurve.getG(),\n                namedCurve.getN(),\n                namedCurve.getH(),\n                namedCurve.getSeed());\n        ECPrivateKeySpec privateKeySpec = new ECPrivateKeySpec(PRIVATE_VALUE, namedCurveSpec);\n\n        return new BCECPrivateKey(\"EC\", privateKeySpec, BouncyCastleProvider.CONFIGURATION);\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(ECPrivateKey original, ECPrivateKey restored) {\n        assertThat(original).isInstanceOf(BCECPrivateKey.class);\n        assertThat(restored).isInstanceOf(BCECPrivateKey.class);\n        assertThat(restored.getS()).isEqualTo(original.getS());\n        assertThat(restored.getParams().getOrder()).isEqualTo(original.getParams().getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n        assertThat(((BCECPrivateKey)restored).getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static ECPrivateKey serializeAndDeserializeFromBouncyCastleFrame(ECPrivateKey privateKey) {\n        CollectionStore<ECPrivateKey> store = new CollectionStore<>(List.of(privateKey));\n        AtomicReference<ECPrivateKey> restored = new AtomicReference<>();\n\n        Collection<ECPrivateKey> matches = store.getMatches(new Selector<>() {\n            @Override\n            public boolean match(ECPrivateKey key) {\n                try {\n                    restored.set(deserialize(serialize(key)));\n                    return true;\n                }\n                catch (Exception e) {\n                    throw new IllegalStateException(\"EC private key serialization failed\", e);\n                }\n            }\n\n            @Override\n            public Object clone() {\n                return this;\n            }\n        });\n\n        assertThat(matches).containsExactly(privateKey);\n        return restored.get();\n    }\n\n    private static byte[] serialize(ECPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static ECPrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (ECPrivateKey)objectInputStream.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780873291539}, {"role": "toolResult", "toolCallId": "call_YBIgXqPVUGdrlFLFxkypMSxY|fc_0e7574659754201b016a25f84b58e88190a6e319506620c2d7", "toolName": "read", "content":