;\n", "newText": "import java.math.BigInteger;\nimport java.util.ArrayList;\nimport java.util.Hashtable;\n"}, {"oldText": "import java.util.Map;\nimport java.util.Vector;\n", "newText": "import java.util.List;\nimport java.util.Map;\nimport java.util.Vector;\n"}, {"oldText": "    @Test\n    public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {\n", "newText": "    @Test\n    public void serializationHooksUseObjectStreamOverridePath() throws Throwable {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(original, (ObjectOutputStream) outputStream);\n\n        assertThat(outputStream.objects()).containsExactly(X, P, Q, G, new Hashtable<>(), new Vector<>());\n\n        JDKDSAPrivateKey restored = deserialize(serializedJdkDsaPrivateKey());\n        SequenceObjectInputStream inputStream = new SequenceObjectInputStream(\n                RESTORED_X,\n                RESTORED_P,\n                RESTORED_Q,\n                RESTORED_G,\n                new Hashtable<>(),\n                new Vector<>());\n\n        invokeReadObject(restored, inputStream);\n\n        assertRestoredPrivateKey(restored);\n    }\n\n    @Test\n    public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {\n"}, {"oldText": "        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(RESTORED_X);\n        assertThat(restored.getParams().getP()).isEqualTo(RESTORED_P);\n        assertThat(restored.getParams().getQ()).isEqualTo(RESTORED_Q);\n        assertThat(restored.getParams().getG()).isEqualTo(RESTORED_G);\n        assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();\n", "newText": "        assertRestoredPrivateKey(restored);\n"}, {"oldText": "    p