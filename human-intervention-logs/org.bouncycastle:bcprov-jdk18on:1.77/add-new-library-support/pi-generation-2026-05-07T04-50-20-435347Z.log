  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.ObjectStreamConstants;
  import java.io.Serializable;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.invoke.VarHandle;
  import java.math.BigInteger;
  import java.security.interfaces.DSAParams;
  import java.util.Hashtable;
  import java.util.Vector;
  
  import org.bouncycastle.jce.provider.JDKDSAPrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class JDKDSAPrivateKeyTest {
      private static final BigInteger X = BigInteger.valueOf(3L);
      private static final BigInteger P = TrackedBigInteger.trackedValueOf(23L);
      private static final BigInteger Q = TrackedBigInteger.trackedValueOf(11L);
      private static final BigInteger G = TrackedBigInteger.trackedValueOf(4L);
      private static final BigInteger RESTORED_X = TrackedBigInteger.trackedValueOf(7L);
      private static final BigInteger RESTORED_P = TrackedBigInteger.trackedValueOf(47L);
      private static final BigInteger RESTORED_Q = TrackedBigInteger.trackedValueOf(23L);
      private static final BigInteger RESTORED_G = TrackedBigInteger.trackedValueOf(2L);
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
      private static final VarHandle X_FIELD = findXField();
      private static final VarHandle DSA_SPEC = findDsaSpec();
  
      @Test
      public void deserializesLegacyDsaPrivateKeyPayload() throws Exception {
          JDKDSAPrivateKey restored = deserialize(serializedJdkDsaPrivateKey());
  
          assertThat(restored).isExactlyInstanceOf(JDKDSAPrivateKey.class);
          assertPrivateKey(restored);
          assertThat(restored.getAlgorithm()).isEqualTo("DSA");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getEncoded()).isNotEmpty();
          assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();
      }
  
      @Test
      public void serializesAndRestoresDsaPrivateKeyParameters() throws Exception {
          JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());
  
          JDKDSAPrivateKey reparsed = deserialize(serialize(original));
  
          assertThat(reparsed).isExactlyInstanceOf(JDKDSAPrivateKey.class);
          assertPrivateKey(reparsed);
          assertThat(reparsed.getBagAttributeKeys().hasMoreElements()).isFalse();
      }
  
      @Test
      public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {
          TestableJdkDsaPrivateKey original = new TestableJdkDsaPrivateKey();
          X_FIELD.set(original, X);
          DSA_SPEC.set(original, new DsaParams(P, Q, G));
  
          byte[] writtenParameters = invokeWriteObject(original);
  
          assertThat(readObjects(writtenParameters))
                  .containsExactly(X, P, Q, G, new Hashtable<>(), new Vector<>());
  
          TestableJdkDsaPrivateKey restored = new TestableJdkDsaPrivateKey();
          byte[] restoredParameterStream = writeObjects(
                  RESTORED_X,
                  RESTORED_P,
                  RESTORED_Q,
                  RESTORED_G,
                  new Hashtable<>(),
                  new Vector<>());
  
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(restoredParameterStream))) {
              invokeReadObject(restored, inputStream);
          }
  
          assertThat(restored.getAlgorithm()).isEqualTo("DSA");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getX()).isEqualTo(RESTORED_X);
          assertThat(restored.getParams().getP()).isEqualTo(RESTORED_P);
          assertThat(restored.getParams().getQ()).isEqualTo(RESTORED_Q);
          assertThat(restored.getParams().getG()).isEqualTo(RESTORED_G);
          assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();
      }
  
      private static void assertPrivateKey(JDKDSAPrivateKey privateKey) {
          assertThat(privateKey.getX()).isEqualTo(X);
          assertThat(privateKey.getParams().getP()).isEqualTo(P);
          assertThat(privateKey.getParams().getQ()).isEqualTo(Q);
          assertThat(privateKey.getParams().getG()).isEqualTo(G);
      }
  
      private static byte[] serializedJdkDsaPrivateKey() throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new JdkDsaPrivateKeyDescriptorObjectOutputStream(bytes)) {
              outputStream.writeObject(new SerializedDsaPrivateKey(X, P, Q, G));
          }
          return bytes.toByteArray();
      }
  
      private static byte[] serialize(JDKDSAPrivateKey privateKey) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {
              outputStream.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static JDKDSAPrivateKey deserialize(byte[] encoded) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(encoded))) {
              return (JDKDSAPrivateKey) inputStream.readObject();
          }
      }
  
      private static byte[] invokeWriteObject(JDKDSAPrivateKey privateKey) throws Throwable {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              WRITE_OBJECT.invokeExact(privateKey, outputStream);
          }
          return output.toByteArray();
      }
  
      private static void invokeReadObject(JDKDSAPrivateKey privateKey, ObjectInputStream inputStream) throws Throwable {
          READ_OBJECT.invokeExact(privateKey, inputStream);
      }
  
      private static byte[] writeObjects(Object... objects) throws IOException {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {
              for (Object object : objects) {
                  outputStream.writeObject(object);
              }
          }
          return output.toByteArray();
      }
  
      private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return new Object[] {
                  inputStream.readObject(),
                  inputStream.readObject(),
                  inputStream.readObject(),
                  inputStream.readObject(),
                  inputStream.readObject(),
                  inputStream.readObject()
              };
          }
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPrivateKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      JDKDSAPrivateKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPrivateKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      JDKDSAPrivateKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static VarHandle findXField() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPrivateKey.class, MethodHandles.lookup());
              return lookup.findVarHandle(JDKDSAPrivateKey.class, "x", BigInteger.class);
          }
          catch (IllegalAccessException | NoSuchFieldException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static VarHandle findDsaSpec() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JDKDSAPrivateKey.class, MethodHandles.lookup());
              return lookup.findVarHandle(JDKDSAPrivateKey.class, "dsaSpec", DSAParams.class);
          }
          catch (IllegalAccessException | NoSuchFieldException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static final class SerializedDsaPrivateKey implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final BigInteger x;
          private final BigInteger p;
          private final BigInteger q;
          private final BigInteger g;
  
          private SerializedDsaPrivateKey(BigInteger x, BigInteger p, BigInteger q, BigInteger g) {
              this.x = x;
              this.p = p;
              this.q = q;
              this.g = g;
          }
  
          private void writeObject(ObjectOutputStream outputStream) throws IOException {
              outputStream.writeObject(x);
              outputStream.writeObject(p);
              outputStream.writeObject(q);
              outputStream.writeObject(g);
              outputStream.writeObject(new Hashtable<>());
              outputStream.writeObject(new Vector<>());
          }
      }
  
      private static final class DsaParams implements DSAParams {
          private final BigInteger p;
          private final BigInteger q;
          private final BigInteger g;
  
          private DsaParams(BigInteger p, BigInteger q, BigInteger g) {
              this.p = p;
              this.q = q;
              this.g = g;
          }
  
          @Override
          public BigInteger getP() {
              return p;
          }
  
          @Override
          public BigInteger getQ() {
              return q;
          }
  
          @Override
          public BigInteger getG() {
              return g;
          }
  
