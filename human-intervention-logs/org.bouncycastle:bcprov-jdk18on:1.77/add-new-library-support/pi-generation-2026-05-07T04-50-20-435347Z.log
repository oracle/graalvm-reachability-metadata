[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/JDKDSAPrivateKeyTest.java","edits":[{"oldText":"import java.lang.invoke.VarHandle;\nimport java.math.BigInteger;\nimport java.security.interfaces.DSAParams;\nimport java.util.Hashtable;\nimport java.util.Vector;\n","newText":"import java.math.BigInteger;\nimport java.util.Hashtable;\nimport java.util.IdentityHashMap;\nimport java.util.Map;\nimport java.util.Vector;\n"},{"oldText":"    private static final BigInteger X = BigInteger.valueOf(3L);\n","newText":"    private static final BigInteger X = TrackedBigInteger.trackedValueOf(3L);\n"},{"oldText":"    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n    private static final VarHandle X_FIELD = findXField();\n    private static final VarHandle DSA_SPEC = findDsaSpec();\n","newText":"    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n"},{"oldText":"    public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {\n        TestableJdkDsaPrivateKey original = new TestableJdkDsaPrivateKey();\n        X_FIELD.set(original, X);\n        DSA_SPEC.set(original, new DsaParams(P, Q, G));\n\n        byte[] writtenParameters = invokeWriteObject(original);\n\n        assertThat(readObjects(writtenParameters))\n                .containsExactly(X, P, Q, G, new Hashtable<>(), new Vector<>());\n\n        TestableJdkDsaPrivateKey restored = new TestableJdkDsaPrivateKey();\n        byte[] restoredParameterStream = writeObjects(\n                RESTORED_X,\n                RESTORED_P,\n                RESTORED_Q,\n                RESTORED_G,\n                new Hashtable<>(),\n                new Vector<>());\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(restoredParameterStream))) {\n            invokeReadObject(restored, inputStream);\n        }\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n","newText":"    public void serializationHooksWriteAndRestoreDsaPrivateKeyParameters() throws Throwable {\n        JDKDSAPrivateKey original = deserialize(serializedJdkDsaPrivateKey());\n\n        byte[] writtenParameters = invokeWriteObject(original);\n\n        assertThat(readObjects(writtenParameters))\n                .containsExactly(X, P, Q, G, new Hashtable<>(), new Vector<>());\n\n        JDKDSAPrivateKey restored = deserialize(serializedJdkDsaPrivateKey());\n        byte[] restoredParameterStream = writeObjects(\n                payloadKeyRepresenting(RESTORED_X),\n                payloadKeyRepresenting(RESTORED_P),\n                payloadKeyRepresenting(RESTORED_Q),\n                payloadKeyRepresenting(RESTORED_G),\n                new Hashtable<>(),\n                new Vector<>());\n\n        try (ObjectInputStream inputStream = new ResolvingObjectInputStream(restoredParameterStream)) {\n            invokeReadObject(restored, inputStream);\n        }\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSA\");\n"},{"oldText":"    private static byte[] serializedJdkDsaPrivateKey() throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JdkDsaPrivateKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedDsaPrivateKey(X, P, Q, G));\n        }\n        return bytes.toByteArray();\n    }\n","newText":"    private static byte[] serializedJdkDsaPrivateKey() throws IOException {\n        return serializedJdkDsaPrivateKey(X, P, Q, G);\n    }\n\n    private static byte[] serializedJdkDsaPrivateKey(\n            BigInteger x,\n            BigInteger p,\n            BigInteger q,\n            BigInteger g) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JdkDsaPrivateKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedDsaPrivateKey(x, p, q, g));\n        }\n        return bytes.toByteArray();\n    }\n"},{"oldText":"    private static byte[] invokeWriteObject(JDKDSAPrivateKey privateKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            WRITE_OBJECT.invokeExact(privateKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n","newText":"    private static byte[] invokeWriteObject(JDKDSAPrivateKey privateKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ReplacingObjectOutputStream(output, privateKey)) {\n            WRITE_OBJECT.invokeExact(privateKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n"},{"oldText":"    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return new Object[] {\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject()\n            };\n        }\n    }\n","newText":"    private static Object[] readObjects(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ResolvingObjectInputStream(bytes)) {\n            return new Object[] {\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject(),\n                inputStream.readObject()\n            };\n        }\n    }\n\n    private static JDKDSAPrivateKey payloadKeyRepresenting(BigInteger value)\n            throws IOException, ClassNotFoundException {\n        BigInteger copiedValue = new BigInteger(value.toString());\n        return deserialize(serializedJdkDsaPrivateKey(\n                copiedValue,\n                new BigInteger(\"101\"),\n                new BigInteger(\"29\"),\n                new BigInteger(\"7\")));\n    }\n"}]}
