       assertThat(restored.getParams()).isInstanceOf(ECNamedCurveSpec.class);\n        assertThat(((ECNamedCurveSpec)restored.getParams()).getName()).isEqualTo(CURVE_NAME);\n    }\n\n    private static BCECGOST3410PublicKey createPublicKey() {\n        ECNamedCurveParameterSpec curve = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);\n        ECNamedCurveSpec parameters = new ECNamedCurveSpec(\n                CURVE_NAME,\n                curve.getCurve(),\n                curve.getG(),\n                curve.getN(),\n                curve.getH(),\n                curve.getSeed());\n        org.bouncycastle.math.ec.ECPoint generator = curve.getG().normalize();\n        ECPoint publicPoint = new ECPoint(\n                generator.getAffineXCoord().toBigInteger(),\n                generator.getAffineYCoord().toBigInteger());\n        return new BCECGOST3410PublicKey(new ECPublicKeySpec(publicPoint, parameters));\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {\n            objectOutput.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInput = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return objectInput.readObject();\n        }\n    }\n}\n"}
