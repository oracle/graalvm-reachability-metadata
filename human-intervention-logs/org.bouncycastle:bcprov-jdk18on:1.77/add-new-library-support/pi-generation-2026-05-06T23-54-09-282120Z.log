          else if (params instanceof ECGenParameterSpec || params instanceof ECNamedCurveGenParameterSpec)
          {
              String curveName;
  
              if (params instanceof ECGenParameterSpec)
              {
                  curveName = ((ECGenParameterSpec)params).getName();
