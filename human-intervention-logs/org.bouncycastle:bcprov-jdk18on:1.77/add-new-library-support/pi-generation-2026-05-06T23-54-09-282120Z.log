  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.security.spec.ECPoint;
  import java.security.spec.ECPublicKeySpec;
  
  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PublicKey;
  import org.bouncycastle.jce.ECGOST3410NamedCurveTable;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.junit.jupiter.api.Test;
  
  public class BCECGOST3410PublicKeyTest {
      private static final String CURVE_NAME = "GostR3410-2001-CryptoPro-A";
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void javaSerializationInvokesEcGostPublicKeyWriteHook() throws Exception {
          BCECGOST3410PublicKey publicKey = createPublicKey();
          byte[] encoded = publicKey.getEncoded();
  
          byte[] serialized = serialize(publicKey);
  
          assertThat(serialized).isNotEmpty();
          assertThat(serialized.length).isGreaterThan(encoded.length);
      }
  
      @Test
      public void serializationHooksWriteAndReadEncodedEcGostPublicKey() throws Throwable {
          BCECGOST3410PublicKey publicKey = createPublicKey();
          EncodingObjectOutputStream outputStream = new EncodingObjectOutputStream();
  
          WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);
  
          byte[] encoded = publicKey.getEncoded();
          assertThat(readEncodedObject(outputStream.toByteArray())).isEqualTo(encoded);
  
          BCECGOST3410PublicKey restored = createPublicKey();
          EncodingObjectInputStream inputStream = new EncodingObjectInputStream(outputStream.toByteArray());
  
          READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);
  
          assertThat(restored.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getW()).isEqualTo(publicKey.getW());
          assertThat(restored.getQ()).isEqualTo(publicKey.getQ());
          assertThat(restored.getEncoded()).isEqualTo(encoded);
          assertThat(restored.getParams()).isInstanceOf(ECNamedCurveSpec.class);
          assertThat(((ECNamedCurveSpec)restored.getParams()).getName()).isEqualTo(CURVE_NAME);
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCECGOST3410PublicKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECGOST3410PublicKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCECGOST3410PublicKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECGOST3410PublicKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static BCECGOST3410PublicKey createPublicKey() {
          ECNamedCurveParameterSpec curve = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);
          ECNamedCurveSpec parameters = new ECNamedCurveSpec(
                  CURVE_NAME,
                  curve.getCurve(),
                  curve.getG(),
                  curve.getN(),
                  curve.getH(),
                  curve.getSeed());
          org.bouncycastle.math.ec.ECPoint generator = curve.getG().normalize();
          ECPoint publicPoint = new ECPoint(
                  generator.getAffineXCoord().toBigInteger(),
                  generator.getAffineYCoord().toBigInteger());
          return new BCECGOST3410PublicKey(new ECPublicKeySpec(publicPoint, parameters));
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream output = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {
              objectOutput.writeObject(value);
          }
          return output.toByteArray();
      }
  
      private static byte[] readEncodedObject(byte[] serializedObject) throws Exception {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serializedObject))) {
              return (byte[])inputStream.readObject();
          }
      }
  
      private static final class EncodingObjectOutputStream extends ObjectOutputStream {
          private final ByteArrayOutputStream outputStream;
  
          private EncodingObjectOutputStream() throws Exception {
              this(new ByteArrayOutputStream());
          }
  
          private EncodingObjectOutputStream(ByteArrayOutputStream outputStream) throws Exception {
              super(outputStream);
              this.outputStream = outputStream;
          }
  
          @Override
          public void defaultWriteObject() {
          }
  
          private byte[] toByteArray() throws Exception {
              flush();
              return outputStream.toByteArray();
          }
      }
  
      private static final class EncodingObjectInputStream extends ObjectInputStream {
          private EncodingObjectInputStream(byte[] serializedObject) throws Exception {
              super(new ByteArrayInputStream(serializedObject));
          }
  
          @Override
          public void defaultReadObject() {
          }
      }
