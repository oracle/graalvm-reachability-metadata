OST3410PublicKey publicKey = createPublicKey();\n        byte[] encoded = publicKey.getEncoded();\n\n        Object restoredObject = deserialize(serialize(publicKey));\n\n        assertThat(restoredObject).isInstanceOf(BCECGOST3410PublicKey.class);\n        BCECGOST3410PublicKey restored = (BCECGOST3410PublicKey)restoredObject;\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ECGOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getW()).isEqualTo(publicKey.getW());\n        assertThat(restored.getQ()).isEqualTo(publicKey.getQ());\n        assertThat(restored.getEncoded()).isEqualTo(encoded);\n        assertThat(restored.getParams()).isInstanceOf(ECNamedCurveSpec.class);\n        assertThat(((ECNamedCurveSpec)restored.getParams()).getName()).isEqualTo(CURVE_NAME);\n    }\n\n    private static BCECGOST3410PublicKey createPublicKey() {\n        ECNamedCurveParameterSpec curve = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);\n        ECNamedCurveSpec parameters = new ECNamedCurveSpec(\n                CURVE_NAME,\n                curve.getCurve(),\n                curve.getG(),\n                curve.getN(),\n                curve.getH(),\n                curve.getSeed());\n        org.bouncycastle.math.ec.ECPoint generator = curve.getG().normalize();\n        ECPoint publicPoint = new ECPoint(\n                generator.getAffineXCoord().toBigInteger(),\n                generator.getAffineYCoord().toBigInteger());\n        return new BCECGOST3410PublicKey(new ECPublicKeySpec(publicPoint, parameters));\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutput = new ObjectOutputStream(output)) {\n            objectOutput.writeObject(value);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInput = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return objectInput.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1825, "output": 1263, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 28688, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778111606112, "responseId": "resp_0c7554d5ea4783ee0169fbd476ccf8819f8bd1592d902650a2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_8yXNwMhNhm820sjTnBnVTb6C|fc_0c7554d5ea4783ee0169fbd47fb574819fa9b15df652ff9b68", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3173 bytes to tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCECGOST3410PublicKeyTest.java"}], "isError": false, "timestamp": 1778111618998}]}
