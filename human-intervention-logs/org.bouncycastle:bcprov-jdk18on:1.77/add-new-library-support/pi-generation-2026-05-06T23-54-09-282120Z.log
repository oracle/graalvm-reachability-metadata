  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PrivateKey;
  import org.junit.jupiter.api.Test;
  
  public class BCECGOST3410PrivateKeyTest {
      private static final BigInteger PRIVATE_VALUE = new BigInteger(
              "11223344556677889900AABBCCDDEEFF11223344556677889900AABBCCDDEEFF",
              16);
  
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void serializationHooksWriteAndReadEncodedEcGost3410PrivateKey() throws Throwable {
          ECParameterSpec parameters = createSecp256r1Parameters();
          BCECGOST3410PrivateKey privateKey = new BCECGOST3410PrivateKey(
                  new ECPrivateKeySpec(PRIVATE_VALUE, parameters));
          EncodingObjectOutputStream outputStream = new EncodingObjectOutputStream();
  
          WRITE_OBJECT.invokeExact(privateKey, (ObjectOutputStream)outputStream);
  
          byte[] encoded = privateKey.getEncoded();
          assertThat(readEncodedObject(outputStream.toByteArray())).isEqualTo(encoded);
  
          BCECGOST3410PrivateKey restored = new BCECGOST3410PrivateKey(
                  new ECPrivateKeySpec(BigInteger.ONE, parameters));
          EncodingObjectInputStream inputStream = new EncodingObjectInputStream(outputStream.toByteArray());
  
          READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);
  
          assertThat(restored.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getS()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getD()).isEqualTo(PRIVATE_VALUE);
          assertThat(restored.getEncoded()).isEqualTo(encoded);
          assertThat(restored.getParams().getOrder()).isEqualTo(parameters.getOrder());
          assertThat(restored.getParams().getGenerator()).isEqualTo(parameters.getGenerator());
          assertThat(restored.getParams().getCofactor()).isEqualTo(parameters.getCofactor());
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCECGOST3410PrivateKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECGOST3410PrivateKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      BCECGOST3410PrivateKey.class,
                      MethodHandles.lookup());
              return lookup.findVirtual(
                      BCECGOST3410PrivateKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static ECParameterSpec createSecp256r1Parameters() {
          BigInteger p = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFF", 16);
          BigInteger a = new BigInteger("FFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFC", 16);
          BigInteger b = new BigInteger("5AC635D8AA3A93E7B3EBBD55769886BC651D06B0CC53B0F63BCE3C3E27D2604B", 16);
          BigInteger gx = new BigInteger("6B17D1F2E12C4247F8BCE6E563A440F277037D812DEB33A0F4A13945D898C296", 16);
          BigInteger gy = new BigInteger("4FE342E2FE1A7F9B8EE7EB4A7C0F9E162BCE33576B315ECECBB6406837BF51F5", 16);
          BigInteger n = new BigInteger("FFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC632551", 16);
  
          return new ECParameterSpec(
                  new EllipticCurve(new ECFieldFp(p), a, b),
                  new ECPoint(gx, gy),
                  n,
                  1);
      }
  
      private static byte[] readEncodedObject(byte[] serializedObject) throws Exception {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(serializedObject))) {
              return (byte[])inputStream.readObject();
          }
      }
  
      private static final class EncodingObjectOutputStream extends ObjectOutputStream {
          private final ByteArrayOutputStream outputStream;
  
          private EncodingObjectOutputStream() throws Exception {
              this(new ByteArrayOutputStream());
          }
  
          private EncodingObjectOutputStream(ByteArrayOutputStream outputStream) throws Exception {
              super(outputStream);
              this.outputStream = outputStream;
          }
  
          @Override
          public void defaultWriteObject() {
          }
  
          private byte[] toByteArray() throws Exception {
              flush();
              return outputStream.toByteArray();
          }
      }
  
      private static final class EncodingObjectInputStream extends ObjectInputStream {
          private EncodingObjectInputStream(byte[] serializedObject) throws Exception {
              super(new ByteArrayInputStream(serializedObject));
          }
  
          @Override
          public void defaultReadObject() {
          }
      }
  }
