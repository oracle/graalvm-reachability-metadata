[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BouncyCastlePQCProviderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.security.Provider;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BouncyCastlePQCProviderTest {\n    @Test\n    void constructsProviderAndLoadsPqcAlgorithmMappings() {\n        BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();\n\n        assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);\n        assertThat(provider.hasAlgorithm(\"KeyPairGenerator\", \"KYBER\")).isTrue();\n        assertThat(provider.hasAlgorithm(\"KeyFactory\", \"SPHINCSPLUS\")).isTrue();\n\n        Provider.Service kyberKeyPairGenerator = provider.getService(\"KeyPairGenerator\", \"KYBER\");\n        assertThat(kyberKeyPairGenerator).isNotNull();\n        assertThat(kyberKeyPairGenerator.getClassName())\n                .isEqualTo(\"org.bouncycastle.pqc.jcajce.provider.kyber.KyberKeyPairGeneratorSpi\");\n    }\n}\n"}
