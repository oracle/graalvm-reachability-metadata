          Provider    prov)
          throws NoSuchAlgorithmException
      {
          algorithm = Strings.toUpperCase(algorithm);
  
          String      alias;
  
          while ((alias = prov.getProperty("Alg.Alias." + baseName + "." + algorithm)) != null)
          {
