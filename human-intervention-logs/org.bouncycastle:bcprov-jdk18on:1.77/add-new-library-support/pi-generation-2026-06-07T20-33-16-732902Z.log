ey.class);\n        assertThat(restored).isExactlyInstanceOf(BCEdDSAPublicKey.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restored.getPointEncoding()).isEqualTo(ED25519_PUBLIC_POINT);\n    }\n\n    private static EdDSAPublicKey newEd25519PublicKey() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"Ed25519\", provider);\n        PublicKey publicKey = keyFactory.generatePublic(new X509EncodedKeySpec(encodedEd25519PublicKey()));\n        return (EdDSAPublicKey)publicKey;\n    }\n\n    private static byte[] encodedEd25519PublicKey() {\n        byte[] encoded = new byte[ED25519_X509_PREFIX.length + ED25519_PUBLIC_POINT.length];\n        System.arraycopy(ED25519_X509_PREFIX, 0, encoded, 0, ED25519_X509_PREFIX.length);\n        System.arraycopy(ED25519_PUBLIC_POINT, 0, encoded, ED25519_X509_PREFIX.length, ED25519_PUBLIC_POINT.length);\n        return encoded;\n    }\n\n    private static byte[] serialize(PublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static EdDSAPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (EdDSAPublicKey)objectInputStream.readObject();\n        }\n    }\n}\n"}
