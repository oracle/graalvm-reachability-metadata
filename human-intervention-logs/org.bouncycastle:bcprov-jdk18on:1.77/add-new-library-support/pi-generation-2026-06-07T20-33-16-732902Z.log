      private AsymmetricCipherKeyPairGenerator setupGenerator()
      {
          if (null == secureRandom)
          {
              this.secureRandom = CryptoServicesRegistrar.getSecureRandom();
          }
  
          switch (algorithmInitialized)
          {
          case Ed25519:
