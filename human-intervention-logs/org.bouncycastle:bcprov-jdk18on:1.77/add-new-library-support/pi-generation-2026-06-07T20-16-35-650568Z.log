      }
  
      public String toString()
      {
          return Utils.keyToString("Private Key", getAlgorithm(), eddsaPublicKey);
      }
  
      public boolean equals(Object o)
      {
          if (o == this)
          {
              return true;
          }
  
          if (!(o instanceof PrivateKey))
          {
              return false;
          }
  
          PrivateKey other = (PrivateKey)o;
  
