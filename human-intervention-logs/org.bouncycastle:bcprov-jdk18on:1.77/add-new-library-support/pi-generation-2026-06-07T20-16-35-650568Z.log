[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCEdDSAPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.BCEdDSAPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.KeyPairGenerator;\nimport java.security.PrivateKey;\nimport java.security.SecureRandom;\nimport java.security.Signature;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCEdDSAPrivateKeyTest {\n    private static final byte[] MESSAGE = \"BCEdDSAPrivateKey serialization\".getBytes();\n\n    @Test\n    void serializesAndRestoresProviderGeneratedEd25519PrivateKey() throws Exception {\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n        KeyPair keyPair = newEd25519KeyPair(provider);\n        PrivateKey original = keyPair.getPrivate();\n\n        PrivateKey restored = deserialize(serialize(original));\n\n        assertThat(original).isInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(signatureVerifiesWithOriginalPublicKey(provider, keyPair, restored)).isTrue();\n    }\n\n    private static KeyPair newEd25519KeyPair(BouncyCastleProvider provider) throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"Ed25519\", provider);\n        keyPairGenerator.initialize(255, new SecureRandom(new byte[] {\n                1, 2, 3, 4, 5\n        }));\n\n        return keyPairGenerator.generateKeyPair();\n    }\n\n    private static boolean signatureVerifiesWithOriginalPublicKey(\n            BouncyCastleProvider provider,\n            KeyPair keyPair,\n            PrivateKey privateKey) throws Exception {\n        Signature signingSignature = Signature.getInstance(\"Ed25519\", provider);\n        signingSignature.initSign(privateKey);\n        signingSignature.update(MESSAGE);\n        byte[] signature = signingSignature.sign();\n\n        Signature verificationSignature = Signature.getInstance(\"Ed25519\", provider);\n        verificationSignature.initVerify(keyPair.getPublic());\n        verificationSignature.update(MESSAGE);\n        return verificationSignature.verify(signature);\n    }\n\n    private static byte[] serialize(PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static PrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (PrivateKey)objectInputStream.readObject();\n        }\n    }\n}\n"}
