          }
          else
          {
              eddsaPrivateKey = new Ed25519PrivateKeyParameters(encoding);
              eddsaPublicKey = ((Ed25519PrivateKeyParameters)eddsaPrivateKey).generatePublicKey();
          }
  
          this.hashCode = calculateHashCode();
      }
  
