ded()).isEqualTo(original.getEncoded());\n        assertThat(signatureVerifiesWithOriginalPublicKey(provider, keyPair, restored)).isTrue();\n    }\n\n    private static KeyPair newEd25519KeyPair(BouncyCastleProvider provider) throws Exception {\n        KeyPairGenerator keyPairGenerator = KeyPairGenerator.getInstance(\"Ed25519\", provider);\n        keyPairGenerator.initialize(255, new SecureRandom(new byte[] {\n                1, 2, 3, 4, 5\n        }));\n\n        return keyPairGenerator.generateKeyPair();\n    }\n\n    private static boolean signatureVerifiesWithOriginalPublicKey(\n            BouncyCastleProvider provider,\n            KeyPair keyPair,\n            PrivateKey privateKey) throws Exception {\n        Signature signingSignature = Signature.getInstance(\"Ed25519\", provider);\n        signingSignature.initSign(privateKey);\n        signingSignature.update(MESSAGE);\n        byte[] signature = signingSignature.sign();\n\n        Signature verificationSignature = Signature.getInstance(\"Ed25519\", provider);\n        verificationSignature.initVerify(keyPair.getPublic());\n        verificationSignature.update(MESSAGE);\n        return verificationSignature.verify(signature);\n    }\n\n    private static byte[] serialize(PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static PrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (PrivateKey)objectInputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2547, "output": 1533, "cacheRead": 44032, "