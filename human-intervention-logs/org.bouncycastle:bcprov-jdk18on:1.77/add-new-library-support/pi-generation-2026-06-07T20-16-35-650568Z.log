[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCEdDSAPrivateKeyTest.java","edits":[{"oldText":"import java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.PrivateKey;\nimport java.security.SecureRandom;\n","newText":"import java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.PrivateKey;\nimport java.security.SecureRandom;\n"},{"oldText":"public class BCEdDSAPrivateKeyTest {\n    @Test\n    void serializesAndRestoresGeneratedEd25519PrivateKey() throws Exception {\n        PrivateKey original = newEd25519KeyPair().getPrivate();\n\n        PrivateKey restored = deserialize(serialize(original));\n\n        assertThat(original).isInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n","newText":"public class BCEdDSAPrivateKeyTest {\n    private static final int STREAM_MAGIC = 0xACED;\n    private static final int STREAM_VERSION = 5;\n    private static final int TC_OBJECT = 0x73;\n    private static final int TC_CLASSDESC = 0x72;\n    private static final int TC_STRING = 0x74;\n    private static final int TC_NULL = 0x70;\n    private static final int TC_ENDBLOCKDATA = 0x78;\n    private static final int SC_WRITE_METHOD = 0x01;\n    private static final int SC_SERIALIZABLE = 0x02;\n    private static final String PRIVATE_KEY_CLASS_NAME =\n            \"org.bouncycastle.jcajce.provider.asymmetric.edec.BCEdDSAPrivateKey\";\n\n    @Test\n    void serializesAndRestoresBaseEd25519PrivateKey() throws Exception {\n        PrivateKey providerKey = newEd25519KeyPair().getPrivate();\n        PrivateKey original = deserialize(basePrivateKeySerialization(providerKey.getEncoded()));\n\n        PrivateKey restored = deserialize(serialize(original));\n\n        assertThat(original).isExactlyInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isExactlyInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n"}]}
[tool-call] end id=call_MKrXEGko4XPBfMzMb1rXE4M1|fc_0c965265dcb860e7016a25d45c12448193adbf317314492b45 name=edit args={"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCEdDSAPrivateKeyTest.java", "edits": [{"oldText": "import java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.PrivateKey;\nimport java.security.SecureRandom;\n", "newText": "import java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\nimport java.security.PrivateKey;\nimport java.security.SecureRandom;\n"}, {"oldText": "public class BCEdDSAPrivateKeyTest {\n    @Test\n    void serializesAndRestoresGeneratedEd25519PrivateKey() throws Exception {\n        PrivateKey original = newEd25519KeyPair().getPrivate();\n\n        PrivateKey restored = deserialize(serialize(original));\n\n        assertThat(original).isInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n", "newText": "public class BCEdDSAPrivateKeyTest {\n    private static final int STREAM_MAGIC = 0xACED;\n    private static final int STREAM_VERSION = 5;\n    private static final int TC_OBJECT = 0x73;\n    private static final int TC_CLASSDESC = 0x72;\n    private static final int TC_STRING = 0x74;\n    private static final int TC_NULL = 0x70;\n    private static final int TC_ENDBLOCKDATA = 0x78;\n    private static final int SC_WRITE_METHOD = 0x01;\n    private static final int SC_SERIALIZABLE = 0x02;\n    private static final String PRIVATE_KEY_CLASS_NAME =\n            \"org.bouncycastle.jcajce.provider.asymmetric.edec.BCEdDSAPrivateKey\";\n\n    @Test\n    void serializesAndRestoresBaseEd25519PrivateKey() throws Exception {\n        PrivateKey providerKey = newEd25519KeyPair().getPrivate();\n        PrivateKey original = deserialize(basePrivateKeySerialization(providerKey.getEncoded()));\n\n        PrivateKey restored = deserialize(serialize(original));\n\n        assertThat(original).isExactlyInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isExactlyInstanceOf(BCEdDSAPrivateKey.class);\n        assertThat(restored).isEqualTo(original);\n        assertThat(restored.hashCode()).isEqualTo(original.hashCode());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n"}]}
