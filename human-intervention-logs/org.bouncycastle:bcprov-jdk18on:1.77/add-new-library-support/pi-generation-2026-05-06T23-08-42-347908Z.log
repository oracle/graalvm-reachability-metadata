              BCDSTU4145PublicKey pubKey = new BCDSTU4145PublicKey(algorithm, pub, p);
  
              return new KeyPair(pubKey, new BCDSTU4145PrivateKey(algorithm, priv, pubKey, p));
          }
      }
  }
  
