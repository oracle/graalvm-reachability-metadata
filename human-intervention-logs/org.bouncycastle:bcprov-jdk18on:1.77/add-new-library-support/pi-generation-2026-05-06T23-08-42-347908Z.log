ts are essential.\"}]}"}, {"type": "toolCall", "id": "call_aFXFteed9R6Bcjov4c8PZBG8|fc_06ab8ec6d83384bf0169fbcaca82c4819f8a0e7f0a5adf37d2", "name": "write", "arguments": {"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDSTU4145PublicKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.security.spec.ECParameterSpec;\nimport java.security.spec.ECPublicKeySpec;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.asn1.ua.DSTU4145NamedCurves;\nimport org.bouncycastle.crypto.params.ECDomainParameters;\nimport org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PublicKey;\nimport org.bouncycastle.jce.spec.ECNamedCurveSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSTU4145PublicKeyTest {\n    private static final ASN1ObjectIdentifier CURVE_OID = DSTU4145NamedCurves.getOIDs()[0];\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedDstu4145PublicKey() throws Throwable {\n        BCDSTU4145PublicKey publicKey = createPublicKey();\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        WRITE_OBJECT.invokeExact(publicKey, (ObjectOutputStream)outputStream);\n\n        byte[] encoded = publicKey.getEncoded();\n        assertThat((byte[])outputStream.writtenObject()).isEqualTo(encoded);\n\n        BCDSTU4145PublicKey restored = createPublicKey();\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(encoded);\n\n        READ_OBJECT.invokeExact(restored, (ObjectInputStream)inputStream);\n\n        assertThat(restored).isNotSameAs(publicKey);\n        assertThat(restored).isEqualTo(publicKey);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isEqualTo(encoded);\n        assertThat(restored.getW()).isEqualTo(publicKey.getW());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(publicKey.getParams().getGenerator());\n        assertThat(restored.getParams().getOrder()).isEqualTo(publicKey.getParams().getOrder());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(publicKey.getParams().getCofactor());\n    }\n\n    private static BCDSTU4145PublicKey createPublicKey() {\n        ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(CURVE_OID);\n        ECParameterSpec parameters = createNamedCurveSpec(domainParameters);\n        ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(parameters.getGenerator(), parameters);\n\n        return new BCDSTU4145PublicKey(publicKeySpec);\n    }\n\n    private static ECParameterSpec createNamedCurveSpec(ECDomainParameters domainParameters) {\n        return new ECNamedCurveSpec(\n                CURVE_OID.getId(),\n                domainParameters.getCurve(),\n                domainParameters.getG(),\n                domainParameters.getN(),\n                domainParameters.getH(),\n                domainParameters.getSeed());\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCDSTU4145PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSTU4145PublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCDSTU4145PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSTU4145PublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private Object writtenObject;\n\n        private RecordingObjectOutputStream() throws Exception {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            writtenObject = object;\n        }\n\n        private Object writtenObject() {\n            return writtenObject;\n        }\n    }\n\n    private static final class ReplayingObjectInputStream extends ObjectInputStream {\n        private final Object object;\n\n        private ReplayingObjectInputStream(Object object) throws Exception {\n            super();\n            this.object = object;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return object;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 967, "output": 1854, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 39685, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778109119919, "responseId": "resp_06ab8ec6d83384bf0169fbcac09c18819f98902d0f3a96ca46"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_aFXFteed9R6Bcjov4c8PZBG8|fc_06ab8ec6d83384bf0169fbcaca82c4819f8a0e7f0a5adf37d2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 5420 bytes to tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDSTU4145PublicKeyTest.java"}], "isError": false, "timestamp": 1778109135479}]}
