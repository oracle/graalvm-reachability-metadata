Key restored = deserialize(serialize(publicKey), BCDSTU4145PublicKey.class);\n\n        assertThat(restored).isNotSameAs(publicKey);\n        assertThat(restored).isEqualTo(publicKey);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restored.getW()).isEqualTo(publicKey.getW());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(publicKey.getParams().getGenerator());\n        assertThat(restored.getParams().getOrder()).isEqualTo(publicKey.getParams().getOrder());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(publicKey.getParams().getCofactor());\n    }\n\n    @Test\n    public void keyFactoryGeneratedPublicKeySerializationUsesDstu4145Hooks() throws Exception {\n        BCDSTU4145PublicKey publicKey = createKeyFactoryPublicKey();\n\n        BCDSTU4145PublicKey restored = deserialize(serialize(publicKey), BCDSTU4145PublicKey.class);\n\n        assertThat(restored).isNotSameAs(publicKey);\n        assertThat(restored).isEqualTo(publicKey);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restored.getW()).isEqualTo(publicKey.getW());\n    }\n\n    private static BCDSTU4145PublicKey createPublicKey() {\n        ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(CURVE_OID);\n        ECParameterSpec parameters = createNamedCurveSpec(domainParameters);\n        ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(parameters.getGenerator(), parameters);\n\n        return new BCDSTU4145PublicKey(publicKeySpec);\n    }\n\n    private static BCDSTU4145PublicKey createKeyFactoryPublicKey() throws Exception {\n        ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(CURVE_OID);\n        ECParameterSpec parameters = createNamedCurveSpec(domainParameters);\n        ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(parameters.getGenerator(), parameters);\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSTU4145\", new BouncyCastleProvider());\n        PublicKey publicKey = keyFactory.generatePublic(publicKeySpec);\n\n        assertThat(publicKey).isInstanceOf(BCDSTU4145PublicKey.class);\n        return (BCDSTU4145PublicKey)publicKey;\n    }\n\n    private static ECParameterSpec createNamedCurveSpec(ECDomainParameters domainParameters) {\n        return new ECNamedCurveSpec(\n                CURVE_OID.getId(),\n                domainParameters.getCurve(),\n                domainParameters.getG(),\n                domainParameters.getN(),\n                domainParameters.getH(),\n                domainParameters.getSeed());\n    }\n\n    private static byte[] serialize(Object object) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static <T> T deserialize(byte[] bytes, Class<T> type) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return type.cast(inputStream.readObject());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1886, "output": 1784, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 30294, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778108884369, "responseId": "resp_06ab8ec6d83384bf0169fbc9d4fc18819f957af80f9a0ef9fc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_XCqJz6xeVpXkh0E87DFavV5S|fc_06ab8ec6d83384bf0169fbc9dd6f4881