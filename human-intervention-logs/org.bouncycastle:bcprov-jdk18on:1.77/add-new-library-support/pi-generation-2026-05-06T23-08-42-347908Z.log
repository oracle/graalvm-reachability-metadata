rg_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.OutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.security.spec.ECParameterSpec;\nimport java.security.spec.ECPublicKeySpec;\n\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.asn1.ua.DSTU4145NamedCurves;\nimport org.bouncycastle.crypto.params.ECDomainParameters;\nimport org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PublicKey;\nimport org.bouncycastle.jce.spec.ECNamedCurveSpec;\nimport org.junit.jupiter.api.Test;\n\npublic class BCDSTU4145PublicKeyTest {\n    private static final ASN1ObjectIdentifier CURVE_OID = DSTU4145NamedCurves.getOIDs()[0];\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void javaSerializationWritesEncodedDstu4145PublicKey() throws Exception {\n        BCDSTU4145PublicKey publicKey = createPublicKey();\n\n        byte[] serialized = serialize(publicKey);\n\n        assertThat(serialized).isNotEmpty();\n    }\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedDstu4145PublicKey() throws Throwable {\n        BCDSTU4145PublicKey publicKey = createPublicKey();\n\n        byte[] writtenObjects = invokeWriteObject(publicKey);\n\n        byte[] encoded = publicKey.getEncoded();\n        assertThat(readObject(writtenObjects, byte[].class)).isEqualTo(encoded);\n\n        BCDSTU4145PublicKey restored = createPublicKey();\n        byte[] encodedObjectStream = writeObject(encoded);\n        try (ObjectInputStream inputStream = new NoDefaultReadObjectInputStream(encodedObjectStream)) {\n            READ_OBJECT.invokeExact(restored, inputStream);\n        }\n\n        assertThat(restored).isNotSameAs(publicKey);\n        assertThat(restored).isEqualTo(publicKey);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isEqualTo(encoded);\n        assertThat(restored.getW()).isEqualTo(publicKey.getW());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(publicKey.getParams().getGenerator());\n        assertThat(restored.getParams().getOrder()).isEqualTo(publicKey.getParams().getOrder());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(publicKey.getParams().getCofactor());\n    }\n\n    private static BCDSTU4145PublicKey createPublicKey() {\n        ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(CURVE_OID);\n        ECParameterSpec parameters = createNamedCurveSpec(domainParameters);\n        ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(parameters.getGenerator(), parameters);\n\n        return new BCDSTU4145PublicKey(publicKeySpec);\n    }\n\n    private static ECParameterSpec createNamedCurveSpec(ECDomainParameters domainParameters) {\n        return new ECNamedCurveSpec(\n                CURVE_OID.getId(),\n                domainParameters.getCurve(),\n                domainParameters.getG(),\n                domainParameters.getN(),\n                domainParameters.getH(),\n                domainParameters.getSeed());\n    }\n\n    private static byte[] serialize(Object object) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static byte[] invokeWriteObject(BCDSTU4145PublicKey publicKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {\n            WRITE_OBJECT.invokeExact(publicKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n\n    private static byte[] writeObject(Object object) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static <T> T readObject(byte[] bytes, Class<T> type) throws Exception {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return type.cast(inputStream.readObject());\n        }\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCDSTU4145PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSTU4145PublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCDSTU4145PublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDSTU4145PublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class NoDefaultWriteObjectOutputStream extends ObjectOutputStream {\n        private NoDefaultWriteObjectOutputStream(OutputStream outputStream) throws Exception {\n            super(outputStream);\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n    }\n\n    private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {\n        private NoDefaultReadObjectInputStream(byte[] bytes) throws Exception {\n            super(new ByteArrayInputStream(bytes));\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1941, "output": 2880, "cacheRead": 40448, "cacheWrite": 0, "totalTokens": 45269, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778109282524, "responseId": "resp_06ab8ec6d83384bf0169fbcb63660c819f9ba02145b78afe16"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_bHQWsjhXlOuccVPMbPO8HyWm|fc_06ab8ec6d83384bf0169fbcb766848819fbebf94a5900ed2c8", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6683 bytes to tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDSTU4145PublicKeyTest.java"}], "isError": false, "timestamp": 1778109312050}]}
