tInputStream(Object object) throws Exception {\n            super();\n            this.object = object;\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            return object;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778109277813}]}
