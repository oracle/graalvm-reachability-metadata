[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/XMSSUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.crypto.digests.SHA256Digest;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSParameters;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSPrivateKeyParameters;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class XMSSUtilTest {\n    private static final int TREE_HEIGHT = 2;\n\n    @Test\n    void serializesAndRestoresXmssPrivateKeyState() throws Exception {\n        XMSSParameters parameters = new XMSSParameters(TREE_HEIGHT, new SHA256Digest());\n        XMSSPrivateKeyParameters original = new XMSSPrivateKeyParameters.Builder(parameters).build();\n\n        byte[] encoded = original.getEncoded();\n        XMSSPrivateKeyParameters restored = new XMSSPrivateKeyParameters.Builder(parameters)\n                .withPrivateKey(encoded)\n                .build();\n\n        assertThat(restored.getIndex()).isEqualTo(original.getIndex());\n        assertThat(restored.getUsagesRemaining()).isEqualTo(original.getUsagesRemaining());\n        assertThat(restored.getSecretKeySeed()).containsExactly(original.getSecretKeySeed());\n        assertThat(restored.getSecretKeyPRF()).containsExactly(original.getSecretKeyPRF());\n        assertThat(restored.getPublicSeed()).containsExactly(original.getPublicSeed());\n        assertThat(restored.getRoot()).containsExactly(original.getRoot());\n        assertThat(restored.getEncoded()).containsExactly(encoded);\n    }\n}\n"}
[tool-call] end id=call_aRIFyND4ETWo7R87x82kKYm6|fc_04ac32bc4c46d8df016a260b276e948190b99a1c59a9e2afaf name=write args={"path": "tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/XMSSUtilTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.crypto.digests.SHA256Digest;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSParameters;\nimport org.bouncycastle.pqc.crypto.xmss.XMSSPrivateKeyParameters;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class XMSSUtilTest {\n    private static final int TREE_HEIGHT = 2;\n\n    @Test\n    void serializesAndRestoresXmssPrivateKeyState() throws Exception {\n        XMSSParameters parameters = new XMSSParameters(TREE_HEIGHT, new SHA256Digest());\n        XMSSPrivateKeyParameters original = new XMSSPrivateKeyParameters.Builder(parameters).build();\n\n        byte[] encoded = original.getEncoded();\n        XMSSPrivateKeyParameters restored = new XMSSPrivateKeyParameters.Builder(parameters)\n                .withPrivateKey(encoded)\n                .build();\n\n        assertThat(restored.getIndex()).isEqualTo(original.getIndex());\n        assertThat(restored.getUsagesRemaining()).isEqualTo(original.getUsagesRemaining());\n        assertThat(restored.getSecretKeySeed()).containsExactly(original.getSecretKeySeed());\n        assertThat(restored.getSecretKeyPRF()).containsExactly(original.getSecretKeyPRF());\n        assertThat(restored.getPublicSeed()).containsExactly(original.getPublicSeed());\n        assertThat(restored.getRoot()).containsExactly(original.getRoot());\n        assertThat(restored.getEncoded()).containsExactly(encoded);\n    }\n}\n"}
