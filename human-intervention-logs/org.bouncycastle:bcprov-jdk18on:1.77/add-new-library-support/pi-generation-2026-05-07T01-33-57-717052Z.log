rameters() throws Exception {\n        GOST3410PublicKeyParameterSetSpec parameters = createCryptoProAParameters();\n        BCGOST3410PrivateKey privateKey = createPrivateKey(parameters);\n\n        BCGOST3410PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParameters().getPublicKeyParameters()).isEqualTo(parameters);\n        assertThat(restored.getParameters().getDigestParamSetOID())\n                .isEqualTo(CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n    }\n\n    private static BCGOST3410PrivateKey createPrivateKey(\n            GOST3410PublicKeyParameterSetSpec parameters) throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        GOST3410PrivateKeySpec keySpec = new GOST3410PrivateKeySpec(\n                PRIVATE_VALUE,\n                parameters.getP(),\n                parameters.getQ(),\n                parameters.getA());\n        PrivateKey privateKey = keyFactory.generatePrivate(keySpec);\n\n        assertThat(privateKey).isInstanceOf(BCGOST3410PrivateKey.class);\n        return (BCGOST3410PrivateKey)privateKey;\n    }\n\n    private static GOST3410PublicKeyParameterSetSpec createCryptoProAParameters() {\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId());\n        return parameterSpec.getPublicKeyParameters();\n    }\n\n    private static BCGOST3410PrivateKey roundTrip(BCGOST3410PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {\n            return (BCGOST3410PrivateKey)inputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 759, "output": 1752, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 35279, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778117592120, "responseId": "resp_098401fa4a607db60169fbebd898bc8192bdbba7db9e998892"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_F2pxFa0Ytf6RpHtl8NdpskeU|fc_098401fa4a607db60169fbebe4cd7c8192bdeaa0544683a999", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3488 bytes to tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCGOST3410PrivateKeyTest.java"}], "isError": false, "timestamp": 1778117607705}]}
