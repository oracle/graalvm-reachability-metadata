[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCGOST3410PrivateKeyTest.java","edits":[{"oldText":"import java.security.KeyFactory;\nimport java.security.PrivateKey;\n\nimport org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.bouncycastle.jce.spec.GOST3410PrivateKeySpec;\nimport org.bouncycastle.jce.spec.GOST3410PublicKeyParameterSetSpec;\nimport org.junit.jupiter.api.Test;\n","newText":"import java.security.Key;\nimport java.security.KeyFactory;\nimport java.security.PrivateKey;\n\nimport org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PrivateKey;\nimport org.bouncycastle.jce.interfaces.GOST3410Params;\nimport org.bouncycastle.jce.interfaces.GOST3410PrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.GOST3410ParameterSpec;\nimport org.bouncycastle.jce.spec.GOST3410PrivateKeySpec;\nimport org.bouncycastle.jce.spec.GOST3410PublicKeyParameterSetSpec;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"import org.bouncycastle.jce.interfaces.GOST3410PrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\n","newText":"import org.bouncycastle.jce.interfaces.GOST3410PrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\n"},{"oldText":"    @Test\n    public void javaSerializationRoundTripPreservesGost3410PrivateKeyParameters() throws Exception {\n        GOST3410PublicKeyParameterSetSpec parameters = createCryptoProAParameters();\n        BCGOST3410PrivateKey privateKey = createPrivateKey(parameters);\n\n        BCGOST3410PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParameters().getPublicKeyParameters()).isEqualTo(parameters);\n        assertThat(restored.getParameters().getDigestParamSetOID())\n                .isEqualTo(CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n    }\n","newText":"    @Test\n    public void javaSerializationRoundTripPreservesGost3410PrivateKeyParameters() throws Exception {\n        GOST3410PublicKeyParameterSetSpec parameters = createCryptoProAParameters();\n        BCGOST3410PrivateKey privateKey = createPrivateKey(parameters);\n\n        BCGOST3410PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParameters().getPublicKeyParameters()).isEqualTo(parameters);\n        assertThat(restored.getParameters().getDigestParamSetOID())\n                .isEqualTo(CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId());\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n    }\n\n    @Test\n    public void javaSerializationRoundTripPreservesGost3410PrivateKeyOidParameters() throws Exception {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);\n        BCGOST3410PrivateKey privateKey = translatePrivateKey(new FixedGost3410PrivateKey(parameterSpec));\n\n        BCGOST3410PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);\n        assertThat(restored.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n        assertThat(restored.getParameters().getPublicKeyParameters())\n                .isEqualTo(parameterSpec.getPublicKeyParameters());\n    }\n"},{"oldText":"    private static GOST3410PublicKeyParameterSetSpec createCryptoProAParameters() {\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId());\n        return parameterSpec.getPublicKeyParameters();\n    }\n\n    private static BCGOST3410PrivateKey roundTrip(BCGOST3410PrivateKey privateKey) throws Exception {\n","newText":"    private static BCGOST3410PrivateKey translatePrivateKey(GOST3410PrivateKey privateKey) throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        Key translatedKey = keyFactory.translateKey(privateKey);\n\n        assertThat(translatedKey).isInstanceOf(BCGOST3410PrivateKey.class);\n        return (BCGOST3410PrivateKey)translatedKey;\n    }\n\n    private static GOST3410PublicKeyParameterSetSpec createCryptoProAParameters() {\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId());\n        return parameterSpec.getPublicKeyParameters();\n    }\n\n    private static BCGOST3410PrivateKey roundTrip(BCGOST3410PrivateKey privateKey) throws Exception {\n"},{"oldText":"    private static BCGOST3410PrivateKey roundTrip(BCGOST3410PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {\n            return (BCGOST3410PrivateKey)inputStream.readObject();\n        }\n    }\n}\n","newText":"    private static BCGOST3410PrivateKey roundTrip(BCGOST3410PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(privateKey);\n        }\n\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(output.toByteArray()))) {\n            return (BCGOST3410PrivateKey)inputStream.readObject();\n        }\n    }\n\n    private static final class FixedGost3410PrivateKey implements GOST3410PrivateKey {\n        private static final long serialVersionUID = 1L;\n\n        private final GOST3410Params parameters;\n\n        private FixedGost3410PrivateKey(GOST3410Params parameters) {\n            this.parameters = parameters;\n        }\n\n        @Override\n        public String getAlgorithm() {\n            return \"GOST3410\";\n        }\n\n        @Override\n        public String getFormat() {\n            return null;\n        }\n\n        @Override\n        public byte[] getEncoded() {\n            return null;\n        }\n\n        @Override\n        public GOST3410Params getParameters() {\n            return parameters;\n        }\n\n        @Override\n        public BigInteger getX() {\n            return PRIVATE_VALUE;\n        }\n    }\n}\n"}]}
