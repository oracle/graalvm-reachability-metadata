ParamSetOID()).isNull();\n    }\n\n    @Test\n    public void javaSerializationRoundTripPreservesGost3410PrivateKeyOidParameters() throws Exception {\n        String keyParamSetOid = CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId();\n        String digestParamSetOid = CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet.getId();\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(keyParamSetOid, digestParamSetOid);\n        BCGOST3410PrivateKey privateKey = translatePrivateKey(new FixedGost3410PrivateKey(parameterSpec));\n\n        BCGOST3410PrivateKey restored = roundTrip(privateKey);\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getX()).isEqualTo(PRIVATE_VALUE);\n        assertThat(restored.getParameters().getPublicKeyParamSetOID()).isEqualTo(keyParamSetOid);\n        assertThat(restored.getParameters().getDigestParamSetOID()).isEqualTo(digestParamSetOid);\n        assertThat(restored.getParameters().getEncryptionParamSetOID()).isNull();\n        assertThat(restored.getParameters().getPublicKeyParameters())\n                .isEqualTo(parameterSpec.getPublicKeyParameters());\n    }\n"}, {"oldText": "    private static GOST3410PublicKeyParameterSetSpec createCryptoProAParameters() {\n        GOST3410ParameterSpec parameterSpec = new GOST3410ParameterSpec(\n                CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A.getId());\n        return parameterSpec.getPublicKeyParameters();\n    }\n\n    private static BCGOST3410PrivateKey roundTrip(BCGOST3410PrivateKey privateKey) throws Exception {\n", "newText": "    private static BCGOST3410PrivateKey translatePrivateKey(GOST3410PrivateKey privateKey) throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"GOST3410\", new BouncyCastleProvider());\n        Key translatedKey = keyFactory.translateKey(privateKey);\n\n        assertThat(transl