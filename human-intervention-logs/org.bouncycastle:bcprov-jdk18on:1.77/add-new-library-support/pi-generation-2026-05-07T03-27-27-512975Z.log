 final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void serializesAndRestoresDiffieHellmanPublicKeyParameters() throws Throwable {\n        BCDHPublicKey original = createPublicKey(P, G);\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n\n        invokeWriteObject(original, outputStream);\n\n        assertThat(outputStream.writtenObjects()).containsExactly(P, G);\n        assertThat(outputStream.writtenInt()).isEqualTo(PUBLIC_VALUE_LENGTH);\n\n        BCDHPublicKey restored = createPublicKey(P, G);\n        ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(\n                RESTORED_P,\n                RESTORED_G,\n                PUBLIC_VALUE_LENGTH);\n\n        invokeReadObject(restored, inputStream);\n        DHParameterSpec restoredParameters = restored.getParams();\n\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getY()).isEqualTo(Y);\n        assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);\n        assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);\n        assertThat(restoredParameters.getL()).isEqualTo(PUBLIC_VALUE_LENGTH);\n    }\n\n    private static BCDHPublicKey createPublicKey(BigInteger p, BigInteger g) throws Exception {\n        DHParameter parameters = new DHParameter(p, g, PUBLIC_VALUE_LENGTH);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n                PKCSObjectIdentifiers.dhKeyAgreement,\n                parameters.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(Y));\n\n        return new BCDHPublicKey(publicKeyInfo);\n    }\n\n    private static void invokeWriteObject(BCDHPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {\n        WRITE_OBJECT.invokeExact(publicKey, outputStream);\n    }\n\n    private static void invokeReadObject(BCDHPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(publicKey, inputStream);\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDHPublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(BCDHPublicKey.class, MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCDHPublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class RecordingObjectOutputStream extends ObjectOutputStream {\n        private final Object[] objects = new Object[2];\n        private int objectCount;\n        private int intValue;\n\n        private RecordingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects[objectCount] = object;\n            objectCount++;\n        }\n\n        @Override\n        public void writeInt(int value) {\n            intValue = value;\n        }\n\n        private Object[] writtenObjects() {\n            Object[] written