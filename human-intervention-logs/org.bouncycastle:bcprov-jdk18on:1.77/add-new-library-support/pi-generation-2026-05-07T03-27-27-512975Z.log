  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.math.BigInteger;
  
  import javax.crypto.spec.DHParameterSpec;
  import javax.crypto.spec.DHPublicKeySpec;
  
  import org.bouncycastle.jce.provider.JCEDHPublicKey;
  import org.junit.jupiter.api.Test;
  
  public class JCEDHPublicKeyTest {
      private static final BigInteger Y = BigInteger.valueOf(8L);
      private static final BigInteger P = BigInteger.valueOf(23L);
      private static final BigInteger G = BigInteger.valueOf(5L);
      private static final BigInteger RESTORED_P = BigInteger.valueOf(47L);
      private static final BigInteger RESTORED_G = BigInteger.valueOf(2L);
      private static final int PUBLIC_VALUE_LENGTH = 11;
      private static final MethodHandle CONSTRUCTOR = findConstructor();
      private static final MethodHandle WRITE_OBJECT = findWriteObject();
      private static final MethodHandle READ_OBJECT = findReadObject();
  
      @Test
      public void invokesCustomSerializationMethodsWithObjectStreams() throws Throwable {
          JCEDHPublicKey original = newPublicKey(Y, P, G);
          RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();
  
          invokeWriteObject(original, outputStream);
  
          assertThat(outputStream.writtenObjects()).containsExactly(Y, P, G);
          assertThat(outputStream.writtenInt()).isEqualTo(PUBLIC_VALUE_LENGTH);
  
          ReplayingObjectInputStream inputStream = new ReplayingObjectInputStream(
                  Y,
                  RESTORED_P,
                  RESTORED_G,
                  PUBLIC_VALUE_LENGTH);
  
          invokeReadObject(original, inputStream);
          DHParameterSpec restoredParameters = original.getParams();
  
          assertThat(original.getY()).isEqualTo(Y);
          assertThat(restoredParameters.getP()).isEqualTo(RESTORED_P);
          assertThat(restoredParameters.getG()).isEqualTo(RESTORED_G);
          assertThat(restoredParameters.getL()).isEqualTo(PUBLIC_VALUE_LENGTH);
      }
  
      private static void assertPublicKey(JCEDHPublicKey publicKey) {
          assertThat(publicKey.getY()).isEqualTo(Y);
          assertThat(publicKey.getParams().getP()).isEqualTo(P);
          assertThat(publicKey.getParams().getG()).isEqualTo(G);
          assertThat(publicKey.getParams().getL()).isEqualTo(PUBLIC_VALUE_LENGTH);
      }
  
      private static JCEDHPublicKey newPublicKey(BigInteger y, BigInteger p, BigInteger g) throws Throwable {
          return (JCEDHPublicKey) CONSTRUCTOR.invokeExact(new DHPublicKeySpec(y, p, g));
      }
  
      private static void invokeWriteObject(JCEDHPublicKey publicKey, ObjectOutputStream outputStream) throws Throwable {
          WRITE_OBJECT.invokeExact(publicKey, outputStream);
      }
  
      private static void invokeReadObject(JCEDHPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {
          READ_OBJECT.invokeExact(publicKey, inputStream);
      }
  
      private static MethodHandle findConstructor() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JCEDHPublicKey.class, MethodHandles.lookup());
              return lookup.findConstructor(
                      JCEDHPublicKey.class,
                      MethodType.methodType(void.class, DHPublicKeySpec.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findWriteObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JCEDHPublicKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      JCEDHPublicKey.class,
                      "writeObject",
                      MethodType.methodType(void.class, ObjectOutputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static MethodHandle findReadObject() {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(JCEDHPublicKey.class, MethodHandles.lookup());
              return lookup.findVirtual(
                      JCEDHPublicKey.class,
                      "readObject",
                      MethodType.methodType(void.class, ObjectInputStream.class));
          }
          catch (IllegalAccessException | NoSuchMethodException e) {
              throw new ExceptionInInitializerError(e);
          }
      }
  
      private static final class RecordingObjectOutputStream extends ObjectOutputStream {
          private final Object[] objects = new Object[3];
          private int objectCount;
          private int intValue;
  
          private RecordingObjectOutputStream() throws IOException {
              super();
          }
  
          @Override
          protected void writeObjectOverride(Object object) {
              objects[objectCount] = object;
              objectCount++;
          }
  
          @Override
          public void writeInt(int value) {
              intValue = value;
          }
  
          private Object[] writtenObjects() {
              Object[] written = new Object[objectCount];
              System.arraycopy(objects, 0, written, 0, objectCount);
              return written;
          }
  
          private int writtenInt() {
              return intValue;
          }
      }
  
      private static final class ReplayingObjectInputStream extends ObjectInputStream {
          private final Object[] objects;
          private final int intValue;
          private int objectIndex;
  
          private ReplayingObjectInputStream(
                  Object firstObject,
                  Object secondObject,
                  Object thirdObject,
                  int intValue)
                  throws IOException {
              super();
              this.objects = new Object[] {firstObject, secondObject, thirdObject};
              this.intValue = intValue;
          }
  
          @Override
          protected Object readObjectOverride() {
              Object object = objects[objectIndex];
              objectIndex++;
              return object;
          }
  
          @Override
          public int readInt() {
              return intValue;
          }
