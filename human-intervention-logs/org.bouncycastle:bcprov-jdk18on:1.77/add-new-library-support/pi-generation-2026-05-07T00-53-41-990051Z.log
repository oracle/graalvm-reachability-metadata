licKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.KeyPairGeneratorSpi.Ed25519;\nimport org.junit.jupiter.api.Test;\n\npublic class BCEdDSAPublicKeyTest {\n    private static final byte[] PRIVATE_KEY_SEED = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1A, 0x1B,\n        0x1C, 0x1D, 0x1E, 0x1F,\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27,\n        0x28, 0x29, 0x2A, 0x2B,\n        0x2C, 0x2D, 0x2E, 0x2F\n    };\n    private static final byte[] RESTORED_PRIVATE_KEY_SEED = new byte[] {\n        0x30, 0x31, 0x32, 0x33,\n        0x34, 0x35, 0x36, 0x37,\n        0x38, 0x39, 0x3A, 0x3B,\n        0x3C, 0x3D, 0x3E, 0x3F,\n        0x40, 0x41, 0x42, 0x43,\n        0x44, 0x45, 0x46, 0x47,\n        0x48, 0x49, 0x4A, 0x4B,\n        0x4C, 0x4D, 0x4E, 0x4F\n    };\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void objectSerializationWritesAndReadsEncodedEdDsaPublicKey() throws Exception {\n        BCEdDSAPublicKey publicKey = generateEd25519PublicKey(PRIVATE_KEY_SEED);\n\n        CapturingObjectOutputStream outputStream = new CapturingObjectOutputStream();\n        outputStream.writeObject(publicKey);\n        outputStream.close();\n\n        assertThat(outputStream.encodedKeyCount()).isOne();\n        assertThat(outputStream.encodedKey()).isEqualTo(publicKey.getEncoded());\n\n        Object restoredObject = readObject(outputStream.toByteArray());\n\n        assertThat(restoredObject).isInstanceOf(BCEdDSAPublicKey.class);\n        BCEdDSAPublicKey restored = (BCEdDSAPublicKey)restoredObject;\n        assertThat(restored).isNotSameAs(publicKey);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored).isEqualTo(publicKey);\n        assertThat(restored.hashCode()).isEqualTo(publicKey.hashCode());\n        assertThat(restored.getEncoded()).isEqualTo(publicKey.getEncoded());\n        assertThat(restored.getPointEncoding()).isEqualTo(publicKey.getPointEncoding());\n    }\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedEdDsaPublicKey() throws Throwable {\n        BCEdDSAPublicKey publicKey = generateEd25519PublicKey(PRIVATE_KEY_SEED);\n        BCEdDSAPublicKey restoredSource = generateEd25519PublicKey(RESTORED_PRIVATE_KEY_SEED);\n\n        RecordingObjectOutputStream outputStream = new RecordingObjectOutputStream();\n        invokeWriteObject(publicKey, outputStream);\n        assertThat(outputStream.writtenObject()).isEqualTo(publicKey.getEncoded());\n\n        invokeReadObject(publicKey, new ReplayingObjectInputStream(restoredSource.getEncoded()));\n\n        assertThat(publicKey.getAlgorithm()).isEqualTo(\"Ed25519\");\n        assertThat(publicKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(publicKey).isEqualTo(restoredSource);\n        assertThat(publicKey.hashCode()).isEqualTo(restoredSource.hashCode());\n        assertThat(publicKey.getEncoded()).isEqualTo(restoredSource.getEncoded());\n        assertThat(publicKey.getPointEncoding()).isEqualTo(restoredSource.getPointEncoding());\n    }\n\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ResolvingObjectInputStream(bytes)) {\n            return inputStream.readObject();\n        }\n    }\n\n    private static BCEdDSAPublicKey generateEd25519PublicKey(byte[] seed) {\n        Ed25519 generator = new Ed25519();\n        generator.initialize(255, new FixedSecureRandom(seed));\n        KeyPair keyPair = generator.generateKeyPair();\n        PublicKey publicKey = keyPair.getPublic();\n        assertThat(publicKey).isInstanceOf(BCEdDSAPublicKey.class);\n        return (BCEdDSAPublicKey)publicKey;\n    }\n\n    private static void invokeWriteObject(BCEdDSAPublicK