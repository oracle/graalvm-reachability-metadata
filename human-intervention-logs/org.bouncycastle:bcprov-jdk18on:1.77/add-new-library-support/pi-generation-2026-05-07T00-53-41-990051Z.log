ke.MethodType;\nimport java.security.KeyPair;\nimport java.util.Base64;\n\nimport org.bouncycastle.crypto.prng.FixedSecureRandom;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.BCXDHPrivateKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.KeyPairGeneratorSpi.X25519;\nimport org.junit.jupiter.api.Test;\n\npublic class BCXDHPrivateKeyTest {\n    private static final byte[] PRIVATE_KEY_SEED = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1A, 0x1B,\n        0x1C, 0x1D, 0x1E, 0x1F,\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27,\n        0x28, 0x29, 0x2A, 0x2B,\n        0x2C, 0x2D, 0x2E, 0x2F\n    };\n    private static final byte[] RESTORED_PRIVATE_KEY_SEED = new byte[] {\n        0x30, 0x31, 0x32, 0x33,\n        0x34, 0x35, 0x36, 0x37,\n        0x38, 0x39, 0x3A, 0x3B,\n        0x3C, 0x3D, 0x3E, 0x3F,\n        0x40, 0x41, 0x42, 0x43,\n        0x44, 0x45, 0x46, 0x47,\n        0x48, 0x49, 0x4A, 0x4B,\n        0x4C, 0x4D, 0x4E, 0x4F\n    };\n    private static final MethodHandle WRITE_OBJECT = findWriteObject();\n    private static final MethodHandle READ_OBJECT = findReadObject();\n\n    @Test\n    public void objectSerializationWritesAndReadsEncodedXdhPrivateKey() throws Exception {\n        BCXDHPrivateKey privateKey = generateX25519PrivateKey(PRIVATE_KEY_SEED);\n\n        Object restoredObject = readObject(writeObject(privateKey));\n\n        assertThat(restoredObject).isInstanceOf(BCXDHPrivateKey.class);\n        BCXDHPrivateKey restored = (BCXDHPrivateKey)restoredObject;\n        assertThat(restored).isNotSameAs(privateKey);\n        assertXdhPrivateKey(restored, privateKey);\n    }\n\n    @Test\n    public void serializationHooksWriteAndReadEncodedXdhPrivateKey() throws Throwable {\n        BCXDHPrivateKey privateKey = generateX25519PrivateKey(PRIVATE_KEY_SEED);\n        BCXDHPrivateKey restoredSource = generateX25519PrivateKey(RESTORED_PRIVATE_KEY_SEED);\n\n        byte[] writtenObjectStream = invokeWriteObject(privateKey);\n        assertThat(readResolvedObject(writtenObjectStream)).isEqualTo(privateKey.getEncoded());\n\n        byte[] restoredKeyStream = writeEncodedKey(restoredSource.getEncoded());\n        invokeReadObject(privateKey, new NoDefaultReadObjectInputStream(restoredKeyStream));\n\n        assertXdhPrivateKey(privateKey, restoredSource);\n    }\n\n    private static BCXDHPrivateKey generateX25519PrivateKey(byte[] seed) {\n        X25519 generator = new X25519();\n        generator.initialize(255, new FixedSecureRandom(seed));\n        KeyPair keyPair = generator.generateKeyPair();\n        assertThat(keyPair.getPrivate()).isInstanceOf(BCXDHPrivateKey.class);\n        return (BCXDHPrivateKey)keyPair.getPrivate();\n    }\n\n    private static void assertXdhPrivateKey(BCXDHPrivateKey actual, BCXDHPrivateKey expected) {\n        assertThat(actual.getAlgorithm()).isEqualTo(\"X25519\");\n        assertThat(actual.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(actual).isEqualTo(expected);\n        assertThat(actual.hashCode()).isEqualTo(expected.hashCode());\n        assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());\n        assertThat(actual.getPublicKey().getEncoded()).isEqualTo(expected.getPublicKey().getEncoded());\n    }\n\n    private static byte[] writeObject(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return inputStream.readObject();\n        }\n    }\n\n    private static byte[] invokeWriteObject(BCXDHPrivateKey privateKey) throws Throwable {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new NoDefaultWriteObjectOutputStream(output)) {\n            WRITE_OBJECT.invokeExact(privateKey, outputStream);\n        }\n        return output.toByteArray();\n    }\n\n    private static void invokeReadObject(BCXDHPrivateKey privateKey, ObjectInputStream inputStream) throws Throwable {\n        try (ObjectInputStream closeableInputStream = inputStream) {\n            READ_OBJECT.invokeExact(privateKey, closeableInputStream);\n        }\n    }\n\n    private static byte[] writeEncodedKey(byte[] encoded) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(new EncodedKey(encoded));\n        }\n        return output.toByteArray();\n    }\n\n    private static Object readResolvedObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ResolvingEncodedKeyObjectInputStream(bytes)) {\n            return inputStream.readObject();\n        }\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCXDHPrivateKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCXDHPrivateKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    BCXDHPrivateKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    BCXDHPrivateKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class NoDefaultWriteObjectOutputStream extends ObjectOutputStream {\n        private NoDefaultWriteObjectOutputStream(OutputStream outputStream) throws IOException {\n            super(outputStream);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        public void defaultWriteObject() {\n        }\n\n        @Override\n        protected Object replaceObject(Object object) {\n            if (object instanceof byte[]) {\n                return new EncodedKey((byte[])object);\n            }\n            return object;\n        }\n    }\n\n    private static final class NoDefaultReadObjectInputStream extends ObjectInputStream {\n        private NoDefaultReadObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n            enableResolveObject(true);\n        }\n\n        @Override\n        public void defaultReadObject() {\n        }\n\n        @Override\n        protected Object resolveObject(Object object) {\n            if (object instanceof EncodedKey) {\n                return ((EncodedKey)object).encoded();\n            }\n            return object;\n        }\n    }\n\n    private static final class ResolvingEncodedKeyObjectInputStream extends ObjectInputStream {\n        private ResolvingEncodedKeyObjectInputStream(byte[] bytes) throws IOException {\n            super(new ByteArrayInputStream(bytes));\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) {\n            if (object instanceof EncodedKey) {\n                return ((EncodedKey)object).encoded();\n            }\n            return object;\n        }\n    }\n\n    private static final class EncodedKey implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final String encoded;\n\n        private EncodedKey(byte[] encoded) {\n            this.encoded = Base64.getEncoder().encodeToString(encoded);\n        }\n\n        private byte[] encoded() {\n            return Base64.getDecoder().decode(encoded);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1976, "output": 3178, "cacheRead": 26624, "cacheWrite": 0, "totalTokens": 31778, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778115526473, "responseId": "resp_06f8f13f8ddd29d90169fbe3c71a3c819490b6d151d3dc5e93"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_tS53UfmsgcWd9fChR2JzGNCz|fc_06f8f13f8ddd29d90169fbe3d2a62c819496d2880f526e68ae", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 8932 bytes to tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCXDHPrivateKeyTest.java"}], "isError": false, "timestamp": 1778115550506}]}
