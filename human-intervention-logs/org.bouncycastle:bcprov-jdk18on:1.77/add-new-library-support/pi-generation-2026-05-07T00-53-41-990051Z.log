[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCXDHPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.security.KeyPair;\n\nimport org.bouncycastle.crypto.prng.FixedSecureRandom;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.BCXDHPrivateKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.edec.KeyPairGeneratorSpi.X25519;\nimport org.junit.jupiter.api.Test;\n\npublic class BCXDHPrivateKeyTest {\n    private static final byte[] PRIVATE_KEY_SEED = new byte[] {\n        0x10, 0x11, 0x12, 0x13,\n        0x14, 0x15, 0x16, 0x17,\n        0x18, 0x19, 0x1A, 0x1B,\n        0x1C, 0x1D, 0x1E, 0x1F,\n        0x20, 0x21, 0x22, 0x23,\n        0x24, 0x25, 0x26, 0x27,\n        0x28, 0x29, 0x2A, 0x2B,\n        0x2C, 0x2D, 0x2E, 0x2F\n    };\n\n    @Test\n    public void objectSerializationWritesAndReadsEncodedXdhPrivateKey() throws Exception {\n        BCXDHPrivateKey privateKey = generateX25519PrivateKey(PRIVATE_KEY_SEED);\n\n        Object restoredObject = readObject(writeObject(privateKey));\n\n        assertThat(restoredObject).isInstanceOf(BCXDHPrivateKey.class);\n        BCXDHPrivateKey restored = (BCXDHPrivateKey)restoredObject;\n        assertThat(restored).isNotSameAs(privateKey);\n        assertThat(restored.getAlgorithm()).isEqualTo(\"X25519\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored).isEqualTo(privateKey);\n        assertThat(restored.hashCode()).isEqualTo(privateKey.hashCode());\n        assertThat(restored.getEncoded()).isEqualTo(privateKey.getEncoded());\n        assertThat(restored.getPublicKey().getEncoded()).isEqualTo(privateKey.getPublicKey().getEncoded());\n    }\n\n    private static BCXDHPrivateKey generateX25519PrivateKey(byte[] seed) {\n        X25519 generator = new X25519();\n        generator.initialize(255, new FixedSecureRandom(seed));\n        KeyPair keyPair = generator.generateKeyPair();\n        assertThat(keyPair.getPrivate()).isInstanceOf(BCXDHPrivateKey.class);\n        return (BCXDHPrivateKey)keyPair.getPrivate();\n    }\n\n    private static byte[] writeObject(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return inputStream.readObject();\n        }\n    }\n}\n"}
