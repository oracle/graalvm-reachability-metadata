mIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);\n        JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);\n\n        byte[] serialized = serialize(original);\n        JournaledAlgorithm restored = deserialize(serialized);\n\n        assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);\n    }\n\n    @Test\n    void storesAndRestoresEncodedStateThroughStreams() throws Exception {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);\n        JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);\n\n        ByteArrayOutputStream storedState = new ByteArrayOutputStream();\n        original.storeState(storedState);\n        JournaledAlgorithm restored = JournaledAlgorithm.getState(\n                new ByteArrayInputStream(storedState.toByteArray()),\n                new SecureRandom());\n\n        assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);\n    }\n\n    @Test\n    void storesAndRestoresEncodedStateThroughFiles(@TempDir Path temporaryDirectory) throws Exception {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);\n        JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);\n        Path stateFile = temporaryDirectory.resolve(\"journaled-algorithm-state.der\");\n\n        original.storeState(stateFile.toFile());\n        JournaledAlgorithm restored = JournaledAlgorithm.getState(stateFile.toFile(), new SecureRandom());\n\n        assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);\n    }\n\n    @Test\n    void restoresStateFromRawEncoding() throws Exception {\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(SHA256_WITH_RSA_ENCRYPTION);\n        JournaledAlgorithm original = newJournaledAlgorithm(algorithmIdentifier);\n\n        JournaledAlgorithm restored = new JournaledAlgorithm(original.getEncoded(), new SecureRandom());\n\n        assertRestoredState(restored, algorithmIdentifier, TRANSCRIPT);\n    }\n\n    private static JournaledAlgorithm newJournaledAlgorithm(AlgorithmIdentifier algorithmIdentifier) {\n        return new JournaledAlgorithm(\n                algorithmIdentifier,\n                new JournalingSecureRandom(TRANSCRIPT, new SecureRandom()));\n    }\n\n    private static byte[] serialize(JournaledAlgorithm journaledAlgorithm) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(journaledAlgorithm);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JournaledAlgorithm deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JournaledAlgorithm)objectInputStream.readObject();\n        }\n    }\n\n    private static void assertRestoredState(\n            JournaledAlgorithm restored,\n            AlgorithmIdentifier algorithmIdentifier,\n            byte[] transcript\n    ) {\n        assertThat(restored.getAlgorithmIdentifier().getAlgorithm())\n                .isEqualTo(algorithmIdentifier.getAlgorithm());\n        assertThat(restored.getJournalingSecureRandom().getFullTranscript())\n                .containsExactly(transcript);\n        assertThat(nextBytes(restored.getJournalingSecureRandom(), transcript.length))\n                .containsExactly(transcript);\n    }\n\n    private static byte[] nextBytes(JournalingSecureRandom random, int length) {\n        byte[] bytes = new byte[length];\n        random.nextBytes(bytes);\n        return bytes;\n    }\n}\n"}], "isError": false, "timestamp": 1780855249076}, {"role": "toolResult", "toolCallId": "call_h79aYrIGmKrV8LZuV73LNOru|fc_0b1e1cbe3fcd9e78016a25b1d0da048196a74cea76c8c93875", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.x509.X509CollectionStoreParameters;\nimport org.bouncycastle.x509.X509Store;\nimport org.bouncycastle.x509.X509StreamParser;\nimport org.bouncycastle.x509.util.StreamParsingException;\nimport org.junit.jupiter.api.Test;\n\nimport java.security.Provider;\nimport java.security.Security;\nimport java.util.Collections;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class X509UtilTest {\n    private static final String bootstrapParserType = \"GRAALVMREACHABILITYTESTCERTIFICATE\";\n    private static final String bootstrapStoreType = \"GRAALVMREACHABILITYTESTCERTIFICATE/COLLECTION\";\n    private static final String parserProperty = \"X509StreamParser.\" + bootstrapParserType;\n    private static final String storeProperty = \"X509Store.\" + bootstrapStoreType;\n    private static final String certificateParserClass = \"org.bouncycastle.jce.provider.X509CertParser\";\n    private static final String certificateStoreClass = \"org.bouncycastle.jce.provider.X509StoreCertCollection\";\n\n    @Test\n    void createsParserFromBouncyCastleProvider() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n\n        X509StreamParser parser = X509StreamParser.getInstance(\"CERTIFICATE\", provider);\n\n        assertThat(parser.getProvider()).isSameAs(provider);\n        assertEmptyParser(parser);\n    }\n\n    @Test\n    void createsParserFromBootstrapLoadedProvider() throws Exception {\n        Provider provider = findBootstrapLoadedProvider();\n        Object previousValue = provider.put(parserProperty, certificateParserClass);\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(bootstrapParserType, provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n            assertEmptyParser(parser);\n        } finally {\n            restoreProviderProperty(provider, parserProperty, previousValue);\n        }\n    }\n\n    @Test\n    void createsParserFromFirstSecurityProvider() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        Object[] previousProviderState = installProviderFirst(provider);\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(\"CERTIFICATE\");\n\n            assertThat(parser.getProvider().getName()).isEqualTo(provider.getName());\n            assertEmptyParser(parser);\n        } finally {\n            restoreSecurityProvider(provider, previousProviderState);\n        }\n    }\n\n    @Test\n    void createsStoreFromBouncyCastleProvider() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n\n        X509Store store = X509Store.getInstance(\n                \"CERTIFICATE/COLLECTION\",\n                new X509CollectionStoreParameters(Collections.emptyList()),\n                provider);\n\n        assertThat(store.getProvider()).isSameAs(provider);\n        assertThat(store.getMatches(null)).isEmpty();\n    }\n\n    @Test\n    void createsStoreFromBootstrapLoadedProvider() throws Exception {\n        Provider provider = findBootstrapLoadedProvider();\n        Object previousValue = provider.put(storeProperty, certificateStoreClass);\n\n        try {\n            X509Store store = X509Store.getInstance(\n                    bootstrapStoreType,\n                    new X509CollectionStoreParameters(Collections.emptyList()),\n                    provider);\n\n            assertThat(store.getProvider()).isSameAs(provider);\n            assertThat(store.getMatches(null)).isEmpty();\n        } finally {\n            restoreProviderProperty(provider, storeProperty, previousValue);\n        }\n    }\n\n    @Test\n    void createsStoreFromFirstSecurityProvider() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        Object[] previousProviderState = installProviderFirst(provider);\n\n        try {\n            X509Store store = X509Store.getInstance(\n                    \"CERTIFICATE/COLLECTION\",\n                    new X509CollectionStoreParameters(Collections.emptyList()));\n\n            assertThat(store.getProvider().getName()).isEqualTo(provider.getName());\n            assertThat(store.getMatches(null)).isEmpty();\n        } finally {\n            restoreSecurityProvider(provider, previousProviderState);\n        }\n    }\n\n    private static void restoreProviderProperty(Provider provider, String property, Object previousValue) {\n        if (previousValue == null) {\n            provider.remove(property);\n        } else {\n            provider.put(property, previousValue);\n        }\n    }\n\n    private static Object[] installProviderFirst(Provider provider) {\n        Provider[] providers = Security.getProviders();\n        Provider previousProvider = null;\n        int previousPosition = -1;\n\n        for (int i = 0; i < providers.length; i++) {\n            if (providers[i].getName().equals(provider.getName())) {\n                previousProvider = providers[i];\n                previousPosition = i + 1;\n                Security.removeProvider(provider.getName());\n                break;\n            }\n        }\n\n        Security.insertProviderAt(provider, 1);\n        return new Object[] { previousProvider, previousPosition };\n    }\n\n    private static void restoreSecurityProvider(Provider provider, Object[] previousProviderState) {\n        Security.removeProvider(provider.getName());\n\n        Provider previousProvider = (Provider)previousProviderState[0];\n        if (previousProvider != null) {\n            int previousPosition = (Integer)previousProviderState[1];\n            Security.insertProviderAt(previousProvider, previousPosition);\n        }\n    }\n\n    private static Provider findBootstrapLoadedProvider() {\n        for (Provider provider : Security.getProviders()) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n\n        throw new IllegalStateException(\"No bootstrap-loaded JCA provider is available\");\n    }\n\n    private static void assertEmptyParser(X509StreamParser parser) throws StreamParsingException {\n        parser.init(new byte[0]);\n\n        assertThat(parser.read()).isNull();\n        assertThat(parser.readAll()).isEmpty();\n    }\n}\n"}], "isError": false, "timestamp": 1780855249077}, {"role": "toolResult", "toolCallId": "call_RmeWWDEFVPvSStLvVO5m0DhN|fc_0b1e1cbe3fcd9e78016a25b1d0da088196b514fc4330d0d74e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.i18n.LocalizedMessage;\nimport org.junit.jupiter.api.Test;\n\nimport java.util.ListResourceBundle;\nimport java.util.Locale;\nimport java.util.TimeZone;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LocalizedMessageTest {\n    private static final String TEST_MESSAGES = Messages.class.getName();\n    private static final TimeZone UTC = TimeZone.getTimeZone(\"UTC\");\n\n    @Test\n    void loadsClassBackedResourceBundleEntryWithDefaultClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(TEST_MESSAGES, \"localizedMessage\");\n\n        String title = message.getEntry(\"title\", Locale.ENGLISH, UTC);\n\n        assertThat(title).isEqualTo(\"Localized title\");\n    }\n\n    @Test\n    void loadsClassBackedResourceBundleEntryWithExplicitClassLoader() throws Exception {\n        LocalizedMessage message = new LocalizedMessage(\n                TEST_MESSAGES,\n                \"localizedMessage\",\n                new Object[] { \"argument\" });\n        ClassLoader resourceLoader = ClassLoader.getSystemClassLoader();\n        assertThat(resourceLoader).isNotNull();\n        message.setClassLoader(resourceLoader);\n\n        String text = message.getEntry(\"text\", Locale.ENGLISH, UTC);\n\n        assertThat(text).isEqualTo(\"Localized text with argument\");\n    }\n\n    public static class Messages extends ListResourceBundle {\n        @Override\n        protected Object[][] getContents() {\n            return new Object[][] {\n                    { \"localizedMessage.title\", \"Localized title\" },\n                    { \"localizedMessage.text\", \"Localized text with {0}\" }\n            };\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780855249077}]}
