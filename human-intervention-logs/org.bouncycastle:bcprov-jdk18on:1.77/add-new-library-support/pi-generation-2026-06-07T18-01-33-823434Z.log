[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk18on/1.77/src/test/java/org_bouncycastle/bcprov_jdk18on/BCDHPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk18on;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.Provider;\n\nimport javax.crypto.interfaces.DHPublicKey;\nimport javax.crypto.spec.DHPublicKeySpec;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCDHPublicKeyTest {\n    private static final BigInteger P = new BigInteger(\n            \"155251809230070893513091813125848175563133404943451431320235\"\n                    + \"119490296623994910210725866945387659164244291000768028886422\"\n                    + \"915080371891804634263272761303128298374438082089019628850917\"\n                    + \"0691316593175367469551763119843371637221007210577919\");\n    private static final BigInteger G = BigInteger.valueOf(2L);\n    private static final BigInteger PUBLIC_VALUE = new BigInteger(\"987654321098765432109876543210987654321\");\n\n    @Test\n    void serializesAndRestoresDhPublicKeyParameters() throws Exception {\n        DHPublicKey original = newBcDhPublicKey();\n\n        DHPublicKey restored = deserialize(serialize(original));\n\n        assertThat(restored).isInstanceOf(BCDHPublicKey.class);\n        assertThat(restored.getY()).isEqualTo(original.getY());\n        assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());\n        assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());\n        assertThat(restored.getParams().getL()).isEqualTo(original.getParams().getL());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restored.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restored.getEncoded()).isNotEmpty();\n    }\n\n    private static DHPublicKey newBcDhPublicKey() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DH\", provider);\n\n        return (DHPublicKey)keyFactory.generatePublic(new DHPublicKeySpec(PUBLIC_VALUE, P, G));\n    }\n\n    private static byte[] serialize(DHPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static DHPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (DHPublicKey)objectInputStream.readObject();\n        }\n    }\n}\n"}
