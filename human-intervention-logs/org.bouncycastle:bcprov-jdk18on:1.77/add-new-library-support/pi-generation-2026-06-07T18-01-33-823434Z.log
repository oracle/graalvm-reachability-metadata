  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.pkcs.DHParameter;
  import org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;
  import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey;
  import org.bouncycastle.util.CollectionStore;
  import org.bouncycastle.util.Selector;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.util.Collection;
  import java.util.List;
  import java.util.concurrent.atomic.AtomicReference;
  
  import javax.crypto.interfaces.DHPrivateKey;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDHPrivateKeyTest {
      private static final BigInteger P = new BigInteger(
              "155251809230070893513091813125848175563133404943451431320235"
                      + "119490296623994910210725866945387659164244291000768028886422"
                      + "915080371891804634263272761303128298374438082089019628850917"
                      + "0691316593175367469551763119843371637221007210577919");
      private static final BigInteger G = BigInteger.valueOf(2L);
      private static final BigInteger PRIVATE_VALUE = new BigInteger("1234567890123456789012345678901234567890");
  
      @Test
      void serializesAndRestoresDhPrivateKeyParameters() throws Exception {
          BCDHPrivateKey original = newBcDhPrivateKey();
  
          DHPrivateKey restored = serializeAndDeserializeFromBouncyCastleFrame(original);
  
          assertThat(restored).isInstanceOf(BCDHPrivateKey.class);
          assertThat(restored.getX()).isEqualTo(original.getX());
          assertThat(restored.getParams().getP()).isEqualTo(original.getParams().getP());
          assertThat(restored.getParams().getG()).isEqualTo(original.getParams().getG());
          assertThat(restored.getParams().getL()).isEqualTo(original.getParams().getL());
          assertThat(restored.getAlgorithm()).isEqualTo("DH");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
          assertThat(restored.getEncoded()).isNotEmpty();
      }
  
      private static BCDHPrivateKey newBcDhPrivateKey() throws Exception {
          DHParameter parameters = new DHParameter(P, G, 0);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
                  PKCSObjectIdentifiers.dhKeyAgreement,
                  parameters.toASN1Primitive());
          PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(PRIVATE_VALUE));
  
          return new BCDHPrivateKey(privateKeyInfo);
      }
  
      private static DHPrivateKey serializeAndDeserializeFromBouncyCastleFrame(BCDHPrivateKey privateKey) {
          CollectionStore<BCDHPrivateKey> store = new CollectionStore<>(List.of(privateKey));
          AtomicReference<DHPrivateKey> restored = new AtomicReference<>();
  
          Collection<BCDHPrivateKey> matches = store.getMatches(new Selector<>() {
              @Override
              public boolean match(BCDHPrivateKey key) {
                  try {
                      restored.set(deserialize(serialize(key)));
                      return true;
                  }
                  catch (Exception e) {
                      throw new IllegalStateException("DH private key serialization failed", e);
                  }
              }
  
              @Override
              public Object clone() {
                  return this;
              }
          });
  
          assertThat(matches).containsExactly(privateKey);
          return restored.get();
      }
  
      private static byte[] serialize(DHPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(privateKey);
          }
          return serialized.toByteArray();
      }
  
      private static DHPrivateKey deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (DHPrivateKey)objectInputStream.readObject();
          }
      }
