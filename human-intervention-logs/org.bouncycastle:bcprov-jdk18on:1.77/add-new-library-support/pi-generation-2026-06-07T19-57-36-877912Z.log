  package org_bouncycastle.bcprov_jdk18on;
  
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;
  import org.bouncycastle.asn1.cryptopro.ECGOST3410NamedCurves;
  import org.bouncycastle.asn1.x9.X9ECParameters;
  import org.bouncycastle.crypto.params.ECGOST3410Parameters;
  import org.bouncycastle.crypto.params.ECNamedDomainParameters;
  import org.bouncycastle.crypto.params.ECPublicKeyParameters;
  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PublicKey;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.bouncycastle.math.ec.ECPoint;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.interfaces.ECPublicKey;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCECGOST3410PublicKeyTest {
      private static final BigInteger PRIVATE_VALUE = new BigInteger("123456789012345678901234567890");
  
      @Test
      void serializesAndRestoresEcGostPublicKeyWithGostParameters() throws Exception {
          ECPublicKey original = newEcGostPublicKey();
  
          byte[] serialized = serialize(original);
          ECPublicKey restored = deserialize(serialized);
  
          assertThat(serialized).containsSequence(original.getEncoded());
          assertRestoredKeyMatchesOriginal(original, restored);
      }
  
      private static ECPublicKey newEcGostPublicKey() {
          ASN1ObjectIdentifier publicKeyParamSet = CryptoProObjectIdentifiers.gostR3410_2001_CryptoPro_A;
          X9ECParameters curveParameters = ECGOST3410NamedCurves.getByOIDX9(publicKeyParamSet);
          ECGOST3410Parameters domainParameters = new ECGOST3410Parameters(
                  new ECNamedDomainParameters(publicKeyParamSet, curveParameters),
                  publicKeyParamSet,
                  CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet,
                  null);
          ECPoint publicPoint = curveParameters.getG().multiply(PRIVATE_VALUE).normalize();
          ECPublicKeyParameters publicKeyParameters = new ECPublicKeyParameters(
                  publicPoint,
                  domainParameters);
          ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(
                  ECGOST3410NamedCurves.getName(publicKeyParamSet),
                  curveParameters.getCurve(),
                  curveParameters.getG(),
                  curveParameters.getN(),
                  curveParameters.getH(),
                  curveParameters.getSeed());
  
          return new BCECGOST3410PublicKey(
                  "ECGOST3410",
                  publicKeyParameters,
                  namedCurveSpec);
      }
  
      private static void assertRestoredKeyMatchesOriginal(ECPublicKey original, ECPublicKey restored) {
          assertThat(original).isInstanceOf(BCECGOST3410PublicKey.class);
          assertThat(restored).isInstanceOf(BCECGOST3410PublicKey.class);
          assertThat(restored.getW()).isEqualTo(original.getW());
          assertThat(restored.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());
          assertThat(restored.getParams().getOrder()).isEqualTo(original.getParams().getOrder());
          assertThat(restored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());
          assertThat(restored.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());
      }
  
      private static byte[] serialize(ECPublicKey publicKey) throws Exception {
          ByteArrayOutputStream serialized = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {
              objectOutputStream.writeObject(publicKey);
          }
          return serialized.toByteArray();
      }
  
      private static ECPublicKey deserialize(byte[] serialized) throws Exception {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              return (ECPublicKey)objectInputStream.readObject();
          }
      }
