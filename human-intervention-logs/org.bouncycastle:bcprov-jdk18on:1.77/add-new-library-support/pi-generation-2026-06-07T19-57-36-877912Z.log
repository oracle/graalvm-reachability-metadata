 java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCECGOST3410_2012PrivateKeyTest {\n    private static final BigInteger PRIVATE_VALUE = new BigInteger(\"123456789012345678901234567890\");\n\n    @Test\n    void serializesAndRestoresEcGost2012PrivateKeyWithGostParameters() throws Exception {\n        BCECGOST3410_2012PrivateKey original = newEcGost2012PrivateKey();\n\n        BCECGOST3410_2012PrivateKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    private static BCECGOST3410_2012PrivateKey newEcGost2012PrivateKey() {\n        ASN1ObjectIdentifier publicKeyParamSet = RosstandartObjectIdentifiers.id_tc26_gost_3410_12_256_paramSetA;\n        X9ECParameters curveParameters = ECGOST3410NamedCurves.getByOIDX9(publicKeyParamSet);\n        ECGOST3410Parameters domainParameters = new ECGOST3410Parameters(\n                new ECNamedDomainParameters(publicKeyParamSet, curveParameters),\n                publicKeyParamSet,\n                RosstandartObjectIdentifiers.id_tc26_gost_3411_12_256,\n                null);\n        ECPoint publicPoint = curveParameters.getG().multiply(PRIVATE_VALUE).normalize();\n        ECPublicKeyParameters publicKeyParameters = new ECPublicKeyParameters(\n                publicPoint,\n                domainParameters);\n        ECPrivateKeyParameters privateKeyParameters = new ECPrivateKeyParameters(\n                PRIVATE_VALUE,\n                domainParameters);\n        ECNamedCurveSpec namedCurveSpec = new ECNamedCurveSpec(\n                ECGOST3410NamedCurves.getName(publicKeyParamSet),\n                curveParameters.getCurve(),\n                curveParameters.getG(),\n                curveParameters.getN(),\n                curveParameters.getH(),\n                curveParameters.getSeed());\n        BCECGOST3410_2012PublicKey publicKey = new BCECGOST3410_2012PublicKey(\n                \"ECGOST3410-2012\",\n                publicKeyParameters,\n                namedCurveSpec);\n\n        return new BCECGOST3410_2012PrivateKey(\n                \"ECGOST3410-2012\",\n                privateKeyParameters,\n                publicKey,\n                namedCurveSpec);\n    }\n\n    private static void assertRestoredKeyMatchesOriginal(\n            BCECGOST3410_2012PrivateKey original,\n            BCECGOST3410_2012PrivateKey restored) {\n        assertThat(restored).isInstanceOf(BCECGOST3410_2012PrivateKey.class);\n        assertThat(restored.getS()).isEqualTo(original.getS());\n        assertThat(restored.getAlgorithm()).isEqualTo(\"ECGOST3410-2012\");\n        assertThat(restored.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(restored.getParams().getOrder()).isEqualTo(original.getParams().getOrder());\n        assertThat(restored.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());\n        assertThat(restored.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());\n        assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    private static byte[] serialize(BCECGOST3410_2012PrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(privateKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static BCECGOST3410_2012PrivateKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (BCECGOST3410_2012PrivateKey)objectInputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5"