= newJceEcPublicKey();\n        original.setPointFormat(\"COMPRESSED\");\n\n        JCEECPublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n\n    private static JCEECPublicKey newJceEcPublicKey() {\n", "newText": "    @Test\n    void serializesAndRestoresCompressedJceEcPublicKeyParameters() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n        original.setPointFormat(\"COMPRESSED\");\n\n        JCEECPublicKey restored = deserialize(serialize(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n        assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());\n    }\n\n    @Test\n    void unsharedSerializationRestoresJceEcPublicKey() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n\n        JCEECPublicKey restored = deserializeUnshared(serializeUnshared(original));\n\n        assertRestoredKeyMatchesOriginal(original, restored);\n    }\n\n    @Test\n    void containingSerializableObjectRestoresJceEcPublicKeyField() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n        PublicKeyHolder restored = deserializeHolder(serialize(new PublicKeyHolder(original)));\n\n        assertRestoredKeyMatchesOriginal(original, restored.publicKey);\n    }\n\n    @Test\n    void collectionSerializationRestoresJceEcPublicKeyElement() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n        List<JCEECPublicKey> publicKeys = new ArrayList<>();\n        publicKeys.add(original);\n\n        List<JCEECPublicKey> restored = deserializePublicKeys(serialize((Serializable)publicKeys));\n\n        assertThat(restored).hasSize(1);\n        assertRestoredKeyMatchesOriginal(original, restored.get(0));\n    }\n\n    private static JCEECPublicKey newJceEcPublicKey() {\n"}, {"oldText": "    private static JCEECPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCEECPublicKey)objectInputStream.readObject();\n        }\n    }\n}\n", "newText": "    private static byte[] serialize(Serializable serializable) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeObject(serializable);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JCEECPublicKey deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCEECPublicKey)objectInputStream.readObject();\n        }\n    }\n\n    private static byte[] serializeUnshared(JCEECPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream serialized = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(serialized)) {\n            objectOutputStream.writeUnshared(publicKey);\n        }\n        return serialized.toByteArray();\n    }\n\n    private static JCEECPublicKey deserializeUnshared(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (JCEECPublicKey)objectInputStream.readUnshared();\n        }\n    }\n\n    private static PublicKeyHolder deserializeHolder(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (PublicKeyHolder)objectInputStream.readObject();\n        }\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static List<JCEECPublicKey> deserializePublicKeys(byte[] serialized) throws Exception {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (List<JCEECPublicKey>)objectInputStream.readObject();\n        }\n    }\n\n    private static final class PublicKeyHolder implements Serializable {\n        private final JCEECPublicKey publicKey;\n\n        private PublicKeyHolder(JCEECPublicKey publicKey) {\n            this.publicKey = publicKey;\n        }\n    }\n}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 994, "output": 2754, "cacheRead": 32768, "cacheWrite": 0, "totalTokens": 36516, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780874388377, "responseId": "resp_0ed8237e74cbf403016a25fc94d444819692634ce23657a8a5"}}
