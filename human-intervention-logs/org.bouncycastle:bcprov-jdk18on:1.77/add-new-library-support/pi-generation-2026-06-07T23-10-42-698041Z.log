y.spec.ECPublicKeySpec;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n"}, {"oldText": "    @Test\n    void collectionSerializationRestoresJceEcPublicKeyElement() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n        List<JCEECPublicKey> publicKeys = new ArrayList<>();\n        publicKeys.add(original);\n\n        List<JCEECPublicKey> restored = deserializePublicKeys(serialize((Serializable)publicKeys));\n\n        assertThat(restored).hasSize(1);\n        assertRestoredKeyMatchesOriginal(original, restored.get(0));\n    }\n\n    private static JCEECPublicKey newJceEcPublicKey() {\n", "newText": "    @Test\n    void collectionSerializationRestoresJceEcPublicKeyElement() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n        List<JCEECPublicKey> publicKeys = new ArrayList<>();\n        publicKeys.add(original);\n\n        List<JCEECPublicKey> restored = deserializePublicKeys(serialize((Serializable)publicKeys));\n\n        assertThat(restored).hasSize(1);\n        assertRestoredKeyMatchesOriginal(original, restored.get(0));\n    }\n\n    @Test\n    void customSerializationWritesEncodedKeyAndAlgorithmObjects() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n\n        try (TrackingObjectOutputStream objectOutputStream = new TrackingObjectOutputStream()) {\n            objectOutputStream.writeObject(original);\n\n            assertThat(objectOutputStream.replacedObjects()).anySatisfy(value -> {\n                assertThat(value).isInstanceOf(byte[].class);\n                assertThat((byte[])value).isEqualTo(original.getEncoded());\n            });\n            assertThat(objectOutputStream.replacedObjects()).contains(\"EC\");\n        }\n    }\n\n    @Test\n    void customDeserializationReadsEncodedKeyAndAlgorithmObjects() throws Exception {\n        JCEECPublicKey original = newJceEcPublicKey();\n\n        try (TrackingObjectInputStream objectInputSt