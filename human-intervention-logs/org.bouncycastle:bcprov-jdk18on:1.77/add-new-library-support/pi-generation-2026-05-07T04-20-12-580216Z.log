          BCElGamalPublicKey original = createPublicKey(P, G, Y);
  
          BCElGamalPublicKey restored = deserialize(serialize(original), BCElGamalPublicKey.class);
          ElGamalParameterSpec restoredParameters = restored.getParameters();
  
          assertThat(restored).isNotSameAs(original);
          assertThat(restored).isEqualTo(original);
          assertThat(restored.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restored.getFormat()).isEqualTo("X.509");
          assertThat(restored.getY()).isEqualTo(Y);
          assertThat(restoredParameters.getP()).isEqualTo(P);
          assertThat(restoredParameters.getG()).isEqualTo(G);
          assertThat(restored.getParams().getP()).isEqualTo(P);
          assertThat(restored.getParams().getG()).isEqualTo(G);
          assertThat(restored.getEncoded()).isEqualTo(original.getEncoded());
      }
  
      @Test
