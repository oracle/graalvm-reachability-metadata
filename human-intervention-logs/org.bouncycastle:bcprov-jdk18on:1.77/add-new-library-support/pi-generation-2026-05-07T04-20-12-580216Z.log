    JCEElGamalPublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findConstructor(\n                    JCEElGamalPublicKey.class,\n                    MethodType.methodType(void.class, BigInteger.class, ElGamalParameterSpec.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    JCEElGamalPublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JCEElGamalPublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    JCEElGamalPublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JCEElGamalPublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class CapturingObjectOutputStream extends ObjectOutputStream {\n        private final List<Object> objects = new ArrayList<>();\n\n        private CapturingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        private List<Object> getObjects() {\n            return objects;\n        }\n\n        @Override\n        prote