 outputStream);\n\n        assertThat(outputStream.getObjects()).containsExactly(Y, P, G);\n        assertPublicKey(publicKey, Y, P, G);\n    }\n\n    @Test\n    public void serializationHookReadsElGamalPublicKeyObjects() throws Throwable {\n        JCEElGamalPublicKey publicKey = createPublicKey(ORIGINAL_Y, ORIGINAL_P, ORIGINAL_G);\n\n        try (ObjectInputStream inputStream = new SequenceObjectInputStream(Y, P, G)) {\n            invokeReadObject(publicKey, inputStream);\n        }\n\n        assertPublicKey(publicKey, Y, P, G);\n        assertThat(publicKey.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(publicKey.getFormat()).isEqualTo(\"X.509\");\n    }\n\n    private static JCEElGamalPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger g) throws Throwable {\n        ElGamalParameterSpec parameters = new ElGamalParameterSpec(p, g);\n        return (JCEElGamalPublicKey) CONSTRUCTOR.invokeExact(y, parameters);\n    }\n\n    private static void assertPublicKey(JCEElGamalPublicKey publicKey, BigInteger y, BigInteger p, BigInteger g) {\n        ElGamalParameterSpec parameters = publicKey.getParameters();\n\n        assertThat(publicKey.getY()).isEqualTo(y);\n        assertThat(parameters.getP()).isEqualTo(p);\n        assertThat(parameters.getG()).isEqualTo(g);\n        assertThat(publicKey.getParams().getP()).isEqualTo(p);\n        assertThat(publicKey.getParams().getG()).isEqualTo(g);\n    }\n\n    private static void invokeWriteObject(JCEElGamalPublicKey publicKey, ObjectOutputStream outputStream)\n            throws Throwable {\n        WRITE_OBJECT.invokeExact(publicKey, outputStream);\n    }\n\n    private static void invokeReadObject(JCEElGamalPublicKey publicKey, ObjectInputStream inputStream) throws Throwable {\n        READ_OBJECT.invokeExact(publicKey, inputStream);\n    }\n\n    private static MethodHandle findConstructor() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    JCEElGamalPublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findConstructor(\n                    JCEElGamalPublicKey.class,\n                    MethodType.methodType(void.class, BigInteger.class, ElGamalParameterSpec.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findWriteObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    JCEElGamalPublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JCEElGamalPublicKey.class,\n                    \"writeObject\",\n                    MethodType.methodType(void.class, ObjectOutputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static MethodHandle findReadObject() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    JCEElGamalPublicKey.class,\n                    MethodHandles.lookup());\n            return lookup.findVirtual(\n                    JCEElGamalPublicKey.class,\n                    \"readObject\",\n                    MethodType.methodType(void.class, ObjectInputStream.class));\n        }\n        catch (IllegalAccessException | NoSuchMethodException e) {\n            throw new ExceptionInInitializerError(e);\n        }\n    }\n\n    private static final class CapturingObjectOutputStream extends ObjectOutputStream {\n        private final List<Object> objects = new ArrayList<>();\n\n        private CapturingObjectOutputStream() throws IOException {\n            super();\n        }\n\n        private List<Object> getObjects() {\n            return objects;\n        }\n\n        @Override\n        protected void writeObjectOverride(Object object) {\n            objects.add(object);\n        }\n    }\n\n    private static final class SequenceObjectInputStream extends ObjectInputStream {\n        private final Object[] objects;\n        private int index;\n\n        private SequenceObjectInputStream(Object... objects) throws IOException {\n            super();\n            this.objects = objects.clone();\n        }\n\n        @Override\n        protected Object readObjectOverride() {\n            Object object = objects[index];\n            index++;\n            return object;\n        }\n    }\n}\n"}
