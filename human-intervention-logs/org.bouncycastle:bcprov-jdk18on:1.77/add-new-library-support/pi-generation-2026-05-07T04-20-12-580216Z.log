ed).isExactlyInstanceOf(JCEElGamalPublicKey.class);\n        assertPublicKey(reparsed);\n    }\n\n    private static void assertPublicKey(JCEElGamalPublicKey publicKey) {\n        ElGamalParameterSpec parameters = publicKey.getParameters();\n\n        assertThat(publicKey.getY()).isEqualTo(Y);\n        assertThat(parameters.getP()).isEqualTo(P);\n        assertThat(parameters.getG()).isEqualTo(G);\n        assertThat(publicKey.getParams().getP()).isEqualTo(P);\n        assertThat(publicKey.getParams().getG()).isEqualTo(G);\n    }\n\n    private static byte[] serializedJceElGamalPublicKey() throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new JceElGamalPublicKeyDescriptorObjectOutputStream(bytes)) {\n            outputStream.writeObject(new SerializedElGamalPublicKey(Y, P, G));\n        }\n        return bytes.toByteArray();\n    }\n\n    private static byte[] serialize(JCEElGamalPublicKey publicKey) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {\n            outputStream.writeObject(publicKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JCEElGamalPublicKey deserialize(byte[] encoded) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(encoded))) {\n            return (JCEElGamalPublicKey) inputStream.readObject();\n        }\n    }\n\n    private static final class SerializedElGamalPublicKey implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private final BigInteger y;\n        private final BigInteger p;\n        private final BigInteger g;\n\n        private SerializedElGamalPublicKey(BigInteger y, BigInteger p, BigInteger g) {\n            this.y = y;\n            this.p = p;\n            this.g = g;\n        }\n\n        private void writeObject(ObjectOutputStream outputStream) throws IOException {\n            outputStream.writeObject(y);\n            outputStream.writeObject(p);\n            outputStream.writeObject(g);\n        }\n    }\n\n    private static final class JceElGamalPublicKeyDescriptorObjectOutputStream extends ObjectOutputStream {\n        private JceElGamalPublicKeyDescriptorObjectOutputStream(ByteArrayOutputStream bytes) throws IOException {\n            super(bytes);\n        }\n\n        @Override\n        protected void writeClassDescriptor(ObjectStreamClass descriptor) throws IOException {\n            if (descriptor.getName().equals(SerializedElGamalPublicKey.class.getName())) {\n                writeUTF(JCEElGamalPublicKey.class.getName());\n                writeLong(ObjectStreamClass.lookup(JCEElGamalPublicKey.class).getSerialVersionUID());\n                writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);\n                writeShort(0);\n                return;\n            }\n            super.writeClassDescriptor(descriptor);\n        }\n    }\n}\n"}
