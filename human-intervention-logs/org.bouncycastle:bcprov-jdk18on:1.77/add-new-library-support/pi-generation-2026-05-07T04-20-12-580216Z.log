  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.ObjectStreamConstants;
  import java.io.Serializable;
  import java.math.BigInteger;
  
  import org.bouncycastle.jce.provider.JCEElGamalPrivateKey;
  import org.bouncycastle.jce.spec.ElGamalParameterSpec;
  import org.junit.jupiter.api.Test;
  
  public class JCEElGamalPrivateKeyTest {
      private static final BigInteger X = BigInteger.valueOf(7L);
      private static final BigInteger P = BigInteger.valueOf(23L);
      private static final BigInteger G = BigInteger.valueOf(5L);
  
      @Test
      public void deserializesElGamalPrivateKeyPayload() throws Exception {
          JCEElGamalPrivateKey restored = deserialize(serializedJceElGamalPrivateKey());
  
          assertThat(restored).isExactlyInstanceOf(JCEElGamalPrivateKey.class);
          assertPrivateKey(restored);
          assertThat(restored.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(restored.getFormat()).isEqualTo("PKCS#8");
      }
  
      @Test
      public void serializesAndRestoresElGamalPrivateKeyParameters() throws Exception {
          JCEElGamalPrivateKey original = deserialize(serializedJceElGamalPrivateKey());
  
          JCEElGamalPrivateKey reparsed = deserialize(serialize(original));
  
          assertThat(reparsed).isExactlyInstanceOf(JCEElGamalPrivateKey.class);
          assertPrivateKey(reparsed);
      }
  
      private static void assertPrivateKey(JCEElGamalPrivateKey privateKey) {
          ElGamalParameterSpec parameters = privateKey.getParameters();
  
          assertThat(privateKey.getX()).isEqualTo(X);
          assertThat(parameters.getP()).isEqualTo(P);
          assertThat(parameters.getG()).isEqualTo(G);
          assertThat(privateKey.getParams().getP()).isEqualTo(P);
          assertThat(privateKey.getParams().getG()).isEqualTo(G);
      }
  
      private static byte[] serializedJceElGamalPrivateKey() throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new JceElGamalPrivateKeyDescriptorObjectOutputStream(bytes)) {
              outputStream.writeObject(new SerializedElGamalPrivateKey(X, P, G));
          }
          return bytes.toByteArray();
      }
  
      private static byte[] serialize(JCEElGamalPrivateKey privateKey) throws IOException {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream outputStream = new ObjectOutputStream(bytes)) {
              outputStream.writeObject(privateKey);
          }
          return bytes.toByteArray();
      }
  
      private static JCEElGamalPrivateKey deserialize(byte[] encoded) throws IOException, ClassNotFoundException {
          try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(encoded))) {
              return (JCEElGamalPrivateKey) inputStream.readObject();
          }
      }
  
      private static final class SerializedElGamalPrivateKey implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final BigInteger x;
          private final BigInteger p;
          private final BigInteger g;
  
          private SerializedElGamalPrivateKey(BigInteger x, BigInteger p, BigInteger g) {
              this.x = x;
              this.p = p;
              this.g = g;
          }
  
          private void writeObject(ObjectOutputStream outputStream) throws IOException {
              outputStream.writeObject(x);
              outputStream.writeObject(p);
              outputStream.writeObject(g);
          }
      }
  
      private static final class JceElGamalPrivateKeyDescriptorObjectOutputStream extends ObjectOutputStream {
          private JceElGamalPrivateKeyDescriptorObjectOutputStream(ByteArrayOutputStream bytes) throws IOException {
              super(bytes);
          }
  
          @Override
          protected void writeClassDescriptor(ObjectStreamClass descriptor) throws IOException {
              if (descriptor.getName().equals(SerializedElGamalPrivateKey.class.getName())) {
                  writeUTF(JCEElGamalPrivateKey.class.getName());
                  writeLong(ObjectStreamClass.lookup(JCEElGamalPrivateKey.class).getSerialVersionUID());
                  writeByte(ObjectStreamConstants.SC_SERIALIZABLE | ObjectStreamConstants.SC_WRITE_METHOD);
                  writeShort(0);
                  return;
              }
              super.writeClassDescriptor(descriptor);
          }
      }
  }
