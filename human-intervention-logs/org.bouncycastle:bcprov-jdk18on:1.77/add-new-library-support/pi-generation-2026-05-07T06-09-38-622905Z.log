ateKey newDilithiumPrivateKey() throws Exception {\n        DilithiumKeyPairGeneratorSpi generator = new DilithiumKeyPairGeneratorSpi();\n        generator.initialize(DilithiumParameterSpec.dilithium2, fixedRandom());\n        KeyPair keyPair = generator.generateKeyPair();\n        return (BCDilithiumPrivateKey)keyPair.getPrivate();\n    }\n\n    private static SecureRandom fixedRandom() {\n        return new SecureRandom(new byte[] {\n            0x10, 0x32, 0x54, 0x76, 0x21, 0x43, 0x65, 0x07\n        });\n    }\n\n    private static void assertDilithiumPrivateKey(BCDilithiumPrivateKey actual, BCDilithiumPrivateKey expected) {\n        assertThat(actual.getAlgorithm()).isEqualTo(\"DILITHIUM2\");\n        assertThat(actual.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(actual.getParameterSpec()).isSameAs(DilithiumParameterSpec.dilithium2);\n        assertThat(actual.getPublicKey().getEncoded()).isEqualTo(expected.getPublicKey().getEncoded());\n        assertThat(actual).isEqualTo(expected);\n        assertThat(actual.hashCode()).isEqualTo(expected.hashCode());\n        assertThat(actual.getEncoded()).isEqualTo(expected.getEncoded());\n    }\n\n    private static byte[] writeObject(Object object) throws IOException {\n        ByteArrayOutputStream output = new ByteArrayOutputStream();\n        try (ObjectOutputStream outputStream = new ObjectOutputStream(output)) {\n            outputStream.writeObject(object);\n        }\n        return output.toByteArray();\n    }\n\n    private static Object readObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream inputStream = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return inputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1425, "output": 1338, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 28875, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWr