  package org_bouncycastle.bcprov_jdk18on;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.security.Provider;
  import java.security.Security;
  
  import org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;
  import org.junit.jupiter.api.Test;
  
  public class BouncyCastlePQCProviderTest {
      @Test
      void constructorLoadsPostQuantumAlgorithmMappings() {
          Provider originalProvider = Security.getProvider(BouncyCastlePQCProvider.PROVIDER_NAME);
          Security.removeProvider(BouncyCastlePQCProvider.PROVIDER_NAME);
          Provider provider = new BouncyCastlePQCProvider();
  
          try {
              int position = Security.addProvider(provider);
  
              assertThat(position).isGreaterThan(0);
              assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);
              assertThat(provider.getService("KeyPairGenerator", "KYBER")).isNotNull();
              assertThat(provider.getService("KeyFactory", "DILITHIUM")).isNotNull();
              assertThat(provider.getService("Signature", "FALCON")).isNotNull();
              assertThat(provider.getService("KeyGenerator", "BIKE")).isNotNull();
          } finally {
              Security.removeProvider(BouncyCastlePQCProvider.PROVIDER_NAME);
              if (originalProvider != null) {
                  Security.addProvider(originalProvider);
              }
          }
      }
  }
