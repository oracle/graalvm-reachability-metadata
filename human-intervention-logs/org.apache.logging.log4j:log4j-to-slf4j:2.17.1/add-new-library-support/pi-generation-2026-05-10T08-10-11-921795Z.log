"toolResult", "toolCallId": "call_zhVFH1KxSVw2nazThagdJtAZ|fc_0e6e3d51033a0b08016a003d023bb8819681076bed77c5211c", "toolName": "bash", "content": [{"type": "text", "text": "Compiled from \"LoggerNameAwareMessage.java\"\npublic interface org.apache.logging.log4j.message.LoggerNameAwareMessage {\n  public abstract void setLoggerName(java.lang.String);\n  public abstract java.lang.String getLoggerName();\n}\nCompiled from \"SimpleMessage.java\"\npublic class org.apache.logging.log4j.message.SimpleMessage implements org.apache.logging.log4j.message.Message,org.apache.logging.log4j.util.StringBuilderFormattable,java.lang.CharSequence {\n  public org.apache.logging.log4j.message.SimpleMessage();\n  public org.apache.logging.log4j.message.SimpleMessage(java.lang.String);\n  public org.apache.logging.log4j.message.SimpleMessage(java.lang.CharSequence);\n  public java.lang.String getFormattedMessage();\n  public void formatTo(java.lang.StringBuilder);\n  public java.lang.String getFormat();\n  public java.lang.Object[] getParameters();\n  public boolean equals(java.lang.Object);\n  public int hashCode();\n  public java.lang.String toString();\n  public java.lang.Throwable getThrowable();\n  public int length();\n  public char charAt(int);\n  public java.lang.CharSequence subSequence(int, int);\n}\nCompiled from \"StringMap.java\"\npublic interface org.apache.logging.log4j.util.StringMap extends org.apache.logging.log4j.util.ReadOnlyStringMap {\n  public abstract void clear();\n  public abstract boolean equals(java.lang.Object);\n  public abstract void freeze();\n  public abstract int hashCode();\n  public abstract boolean isFrozen();\n  public abstract void putAll(org.apache.logging.log4j.util.ReadOnlyStringMap);\n  public abstract void putValue(java.lang.String, java.lang.Object);\n  public abstract void remove(java.lang.String);\n}\n"}], "isError": false, "timestamp": 1778400514991}]}
