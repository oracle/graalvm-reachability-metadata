  254:     @Test
  255:     void openSslCredentialApiIsNotAvailableWithJdkProvider() throws Exception {
  256:         assumeTrue(OpenSslCredential.isAvailable());
  257:         X509Bundle bundle = new CertificateBuilder()
  258:                 .subject("cn=netty")
  259:                 .setIsCertificateAuthority(true)
  260:                 .buildSelfSigned();
  261:         OpenSslCredential credential = OpenSslCredentialBuilder.forX509(
  262:                 bundle.getKeyPair().getPrivate(), bundle.getCertificatePath())
  263:                 .build();
  264:         try {
  265:             SslContextBuilder clientBuilder = SslContextBuilder.forClient();
  266:             SslContextBuilder serverBuilder = SslContextBuilder.forServer(bundle.toKeyManagerFactory());
  267:             clientBuilder.sslProvider(SslProvider.JDK);
  268:             serverBuilder.sslProvider(SslProvider.JDK);
  269:             clientBuilder.addCredential(credential);
  270:             serverBuilder.addCredential(credential);
  271:             assertThrows(IllegalArgumentException.class, () -> clientBuilder.build());
  272:             assertThrows(IllegalArgumentException.class, () -> serverBuilder.build());
  273:         } finally {
  274:             credential.release();
  275:         }
  276:     }
