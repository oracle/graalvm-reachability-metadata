nnot sign others\n132:         IllegalArgumentException e = assertThrows(IllegalArgumentException.class, () -> {\n133:             mlDsaBuilder.buildIssuedBy(mlKemBundle);\n134:         });\n135:         assertThat(e).hasMessageContaining(\"cannot be used for signing\");\n136:     }\n137: \n138:     @Test\n139:     void createCertIssuedBySameAlgorithm() throws Exception {\n140:         CertificateBuilder builder = BASE.copy().ecp256();\n141:         X509Bundle root = builder.copy()\n142:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n143:                 .setIsCertificateAuthority(true)\n144:                 .buildSelfSigned();\n145:         X509Bundle leaf = builder.copy()\n146:                 .subject(\"CN=leaf.netty.io, O=Netty\")\n147:                 .buildIssuedBy(root);\n148:         assertThat(leaf.getCertificate().getSubjectX500Principal()).isEqualTo(\n149:                 new X500Principal(\"CN=leaf.netty.io, O=Netty\"));\n150:         assertThat(leaf.getCertificate().getIssuerX500Principal()).isEqualTo(\n151:                 new X500Principal(SUBJECT));\n152: \n153:         Signature signature = Signature.getInstance(leaf.getCertificate().getSigAlgName());\n154:         signature.initVerify(root.getCertificate());\n155:         signature.update(leaf.getCertificate().getTBSCertificate());\n156:         assertTrue(signature.verify(leaf.getCertificate().getSignature()));\n157:     }\n158: \n159:     @Test\n160:     void createCertIssuedByDifferentAlgorithmEcp384vsEcp256() throws Exception {\n161:         X509Bundle root = BASE.copy()\n162:                 .algorithm(Algorithm.ecp384)\n163:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n164:                 .setIsCertificateAuthority(true)\n165:                 .buildSelfSigned();\n166:         X509Bundle leaf = BASE.copy()\n167:                 .ecp256()\n168:                 .subject(\"CN=leaf.netty.io, O=Netty\")\n169:                 .buildIssuedBy(root);\n170:         assertThat(leaf.getCertificate().getSubjectX500Principal()).isEqualTo(\n171:                 new X500Principal(\"CN=leaf.netty.io, O=Netty\"));\n172:         assertThat(leaf.getCertificate().getIssuerX500Principal()).isEqualTo(\n173:                 new X500Principal(SUBJECT));\n174: \n175:         Signature signature = Signature.getInstance(leaf.getCertificate().getSigAlgName());\n176:         signature.initVerify(root.getCertificate());\n177:         signature.update(leaf.getCertificate().getTBSCertificate());\n178:         assertTrue(signature.verify(leaf.getCertificate().getSignature()));\n179:     }\n180: \n181:     @Test\n182:     void createCertIssuedByDifferentAlgorithmEcp256vsRsa2048() throws Exception {\n183:         X509Bundle root = BASE.copy()\n184:                 .ecp256()\n185:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n186:                 .setIsCertificateAuthority(true)\n187:                 .buildSelfSigned();\n188:         X509Bundle leaf = BASE.copy()\n189:                 .rsa2048()\n190:                 .subject(\"CN=leaf.netty.io, O=Netty\")\n---\n190:                 .subject(\"CN=leaf.netty.io, O=Netty\")\n191:                 .buildIssuedBy(root);\n192:         assertThat(leaf.getCertificate().getSubjectX500Principal()).isEqualTo(\n193:                 new X500Principal(\"CN=leaf.netty.io, O=Netty\"));\n194:         assertThat(leaf.getCertificate().getIssuerX500Principal()).isEqualTo(\n195:                 new X500Principal(SUBJECT));\n196: \n197:         Signature signature = Signature.getInstance(leaf.getCertificate().getSigAlgName());\n198:         signature.initVerify(root.getCertificate());\n199:         signature.update(leaf.getCertificate().getTBSCertificate());\n200:         assertTrue(signature.verify(leaf.getCertificate().getSignature()));\n201:     }\n202: \n203:     @Test\n204:     void createCertIssuedByDifferentAlgorithmEd25519vEcp256() throws