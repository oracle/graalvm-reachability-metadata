  127:         assertFalse(mlKemBundle.isCertificateAuthority());
  128:         assertFalse(mlKemBundle.isSelfSigned());
  129:         assertThat(cert.getSubjectX500Principal()).isEqualTo(new X500Principal(SUBJECT));
