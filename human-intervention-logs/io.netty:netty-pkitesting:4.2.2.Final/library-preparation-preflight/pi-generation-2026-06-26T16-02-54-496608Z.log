gnature = Algorithms.signature(leaf.getCertificate().getSigAlgName());\n242:         signature.initVerify(root.getCertificate());\n243:         signature.update(leaf.getCertificate().getTBSCertificate());\n244:         assertTrue(signature.verify(leaf.getCertificate().getSignature()));\n245:     }\n246: \n247:     @Test\n248:     void createCertificateWithSans() throws Exception {\n249:         X509Bundle root = BASE.copy()\n250:                 .setIsCertificateAuthority(true)\n251:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n252:                 .buildSelfSigned();\n253:         X509Bundle leaf = BASE.copy()\n254:                 .subject(\"CN=leaf.netty.io\")\n255:                 .addSanDirectoryName(\"CN=san.leaf.netty.io\")\n256:                 .addSanDnsName(\"san-1.leaf.netty.io\")\n257:                 .addSanDnsName(\"san-2.leaf.netty.io\")\n258:                 .addSanIpAddress(\"192.0.2.1\") // RFC 5737 example IP\n259:                 .addSanRfc822Name(\"san@netty.io\")\n260:                 .addSanRegisteredId(\"1.2.840.113635.100.1.2.42\")\n261:                 .addSanUriName(\"spiffe://netty.io/example/san\")\n262:                 .addSanOtherName(\"1.2.840.113635.100.1.2.42\", new byte[] {0x01, 0x01, 0x00})\n263:                 .buildIssuedBy(root);\n264:         X509Certificate cert = leaf.getCertificate();\n265:         assertEquals(new X500Principal(\"CN=leaf.netty.io\"), cert.getSubjectX500Principal());\n266:         List<List<?>> sans = new ArrayList<>(cert.getSubjectAlternativeNames());\n267:         assertThat(sans).hasSize(8);\n268:         assertThat(sans.get(0)).isEqualTo(Arrays.asList(4, \"CN=san.leaf.netty.io\"));\n269:         assertThat(sans.get(1)).isEqualTo(Arrays.asList(2, \"san-1.leaf.netty.io\"));\n270:         assertThat(sans.get(2)).isEqualTo(Arrays.asList(2, \"san-2.leaf.netty.io\"));\n271:         assertThat(sans.get(3)).isEqualTo(Arrays.asList(7, \"192.0.2.1\"));\n272:         assertThat(sans.get(4)).isEqualTo(Arrays.asList(1, \"san@netty.io\"));\n273:         assertThat(sans.get(5)).isEqualTo(Arrays.asList(8, \"1.2.840.113635.100.1.2.42\"));\n274:         assertThat(sans.get(6)).isEqualTo(Arrays.asList(6, \"spiffe://netty.io/example/san\"));\n275:         assertThat(sans.get(7).get(0)).isEqualTo(0);\n276:         if (PlatformDependent.javaVersion() >= 19) {\n277:             assertThat(sans.get(7).get(1)).isEqualTo(new byte[] {\n278:                     48, 17, 6, 10, 42, -122, 72, -122, -9, 99, 100, 1, 2, 42, -96, 3, 1, 1, 0 });\n279:         } else {\n280:             // Java versions older than 19 re-encode the value in an extra context-constructed tag, the {-96, 5} bit.\n281:             assertThat(sans.get(7).get(1)).isEqualTo(new byte[] {\n282:                     48, 19, 6, 10, 42, -122, 72, -122, -9, 99, 100, 1, 2, 42, -96, 5, -96, 3, 1, 1, 0 });\n283:         }\n284:         if (sans.get(7).size() > 2) {\n285:             assertThat(sans.get(7).get(2)).isEqualTo(\"1.2.840.113635.100.1.2.42\");\n286:             assertThat(sans.get(7).get(3)).isEqualTo(new byte[]{0x01, 0x01, 0x00});\n287:         }\n288:     }\n289: \n290:     @Test\n291:     void createCertificteWithExtendedKeyUsage() throws Exception {\n292:         CertificateBuilder builder = BASE.copy()\n293:                 .setIsCertificateAuthority(true)\n294:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n295:                 .addExtendedKeyUsage(\"1.2.840.113635.100.1.2.42\");\n296:         for (CertificateBuilder.ExtendedKeyUsage extendedKeyUsage : CertificateBuilder.ExtendedKeyUsage.values()) {\n297:             builder.addExtendedKeyUsage(extendedKeyUsage);\n298:         }\n299:         X509Bundle bundle = builder.buildSelfSigned();\n300:         TreeSet<String> expectedExtendedKeyUsage = new TreeSet<>();\n301:         expectedExtendedKeyUsage.add(\"1.2.840.113635.100.1.2.42\");\n302:         for (CertificateBuilder.ExtendedKeyUsage extendedKeyUsage : CertificateBuilder.ExtendedKeyUsage.values()) {\n303:             expectedExtendedKeyUsage.add(extendedKeyUsage.getOid());\n304:         }\n305:         List<String> actualExtendedKeyUsage = bundle.getCertificate().getExtendedKeyUsage();\n306:         assertThat(actualExtendedKeyUsage).containsExactlyInAnyOrderElementsOf(expectedExtendedKeyUsage);\n307:     }\n308: \n309:     @Test\n310:     void createCertificateWithOtherFields() throws Exception {\n311:         X509Bundle root = BASE.copy()\n312:                 .setIsCertificateAuthority(true)\n313:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n314:                 .setPathLengthConstraint(OptionalInt.of(42))\n315:                 .serial(BigInteger.TEN)\n316:                 .buildSelfSigned();\n317:         X509Certificate cert = root.getCertificate();\n318:         assertThat(cert.getBasicConstraints()).isEqualTo(42);\n319:         assertThat(cert.getSerialNumber()).isEqualTo(10);\n320:         assertEquals(3, cert.getVersion());\n321:         assertFalse(cert.hasUnsupportedCriticalExtension());\n322:         assertThat(cert.getKeyUsage()).isEqualTo(\n323:                 new boolean[] {true, false, false, false, false, true, false, false, false});\n324:         cert.checkValidity();\n325:         assertThat(NOW.minus(1, DAYS).truncatedTo(SECONDS).toEpochMilli()).isEqualTo(cert.getNotBefore().getTime());\n326:         assertThat(NOW.plus(1, DAYS).truncatedTo(SECONDS).toEpochMilli()).isEqualTo(cert.getNotAfter().getTime());\n327:     }\n328: \n329:     @Test\n330:     void validCertificatesWithCrlMustPassValidation() throws Exception {\n331:         X509Bundle root = BASE.copy()\n332:                 .setIsCertificateAuthority(true)\n333:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign, KeyUsage.cRLSign)\n334:                 .buildSelfSigned();\n335:         RevocationServer server = RevocationServer.getInstance();\n336: