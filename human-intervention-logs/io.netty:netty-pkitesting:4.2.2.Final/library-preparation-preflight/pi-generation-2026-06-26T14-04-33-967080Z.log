 java.math.BigInteger;\n29: import java.security.KeyPair;\n30: import java.security.SecureRandom;\n31: import java.security.Signature;\n32: import java.security.cert.CertPathBuilder;\n33: import java.security.cert.CertificateException;\n34: import java.security.cert.PKIXBuilderParameters;\n35: import java.security.cert.PKIXRevocationChecker;\n36: import java.security.cert.TrustAnchor;\n37: import java.security.cert.X509Certificate;\n38: import java.time.Instant;\n39: import java.util.ArrayList;\n40: import java.util.Arrays;\n41: import java.util.Collections;\n42: import java.util.List;\n43: import java.util.OptionalInt;\n44: import java.util.TreeSet;\n45: import javax.net.ssl.CertPathTrustManagerParameters;\n46: import javax.net.ssl.TrustManagerFactory;\n47: import javax.net.ssl.X509TrustManager;\n48: import javax.security.auth.x500.X500Principal;\n49: \n50: import static java.time.temporal.ChronoUnit.DAYS;\n51: import static java.time.temporal.ChronoUnit.SECONDS;\n52: import static org.assertj.core.api.Assertions.assertThat;\n53: import static org.junit.jupiter.api.Assertions.assertEquals;\n54: import static org.junit.jupiter.api.Assertions.assertFalse;\n55: import static org.junit.jupiter.api.Assertions.assertNotNull;\n56: import static org.junit.jupiter.api.Assertions.assertThrows;\n57: import static org.junit.jupiter.api.Assertions.assertTrue;\n58: import static org.junit.jupiter.api.Assumptions.assumeTrue;\n59: \n60: class CertificateBuilderTest {\n61:     private static final Instant NOW = Instant.now();\n62:     private static final String SUBJECT = \"CN=netty.io, O=Netty\";\n63:     private static final CertificateBuilder BASE = new CertificateBuilder()\n64:             .notBefore(NOW.minus(1, DAYS))\n65:             .notAfter(NOW.plus(1, DAYS))\n66:             .subject(SUBJECT);\n67:     private static final SecureRandom RNG = new SecureRandom();\n68: \n69:     @ParameterizedTest\n70:     @EnumSource\n71:     void createCertOfEveryKeyType(Algorithm algorithm) throws Exception {\n72:         // Assume that RSA 4096 and RSA 8192 work if the other RSA bit-widths work.\n73:         // These big keys just take too long to test with.\n74:         assumeTrue(algorithm != Algorithm.rsa4096 && algorithm != Algorithm.rsa8192);\n75:         assumeTrue(algorithm.isSupported());\n76:         assumeTrue(algorithm.supportSigning());\n77: \n78:         X509Bundle bundle = BASE.copy()\n79:                 .algorithm(algorithm)\n80:                 .setIsCertificateAuthority(true)\n81:                 .buildSelfSigned();\n82:         X509Certificate cert = bundle.getCertificate();\n83:         assertTrue(bundle.isCertificateAuthority());\n84:         assertTrue(bundle.isSelfSigned());\n85:         assertThat(cert.getSubjectX500Principal()).isEqualTo(new X500Principal(SUBJECT));\n86:     }\n87: \n88:     @ParameterizedTest\n89:     @EnumSource\n90:     void createKeyPairOfEveryKeyType(Algorithm algorithm) throws Exception {\n91:         // Assume that RSA 4096 and RSA 8192 work if the other RSA bit-widths work.\n92:         // These big keys just take too long to test with.\n93:         assumeTrue(algorithm != Algorithm.rsa4096 && algorithm != Algorithm.rsa8192);\n94:         assumeTrue(algorithm.isSupported());\n95: \n96:         KeyPair keyPair = algorithm.generateKeyPair(RNG);\n97:         assertNotNull(keyPair);\n98:         assertNotNull(keyPair.getPrivate());\n99:         assertNotNull(keyPair.getPublic());\n100:     }\n101: \n102:     @EnabledForJreRange(\n103:             min = JRE.JAVA_24,\n104:             disabledReason = \"ML-KEM is only supported in Java 24 onwards\")\n105:     @ParameterizedTest\n106:     @EnumSource(names = {\"mlKem512\", \"mlKem768\", \"mlKem1024\"})\n107:     void createMlKemCerts(Algorithm algorithm) throws Exception {\n108:         CertificateBuilder mlKemBuilder = BASE.copy()\n109:                 .algorithm(algorithm);\n110: \n111:         // ML-KEM cannot be used to sign itself\n112:         assertThrows(IllegalStateException.class, () -> {\n113:             mlKemBuilder.copy().setIsCertificateAuthority(true).buildSelfSigned();\n114:         });\n115: \n116:         CertificateBuilder mlDsaBuilder = BASE.copy()\n117:                 .algorithm(Algorithm.mlDsa44);\n118:         X509Bundle issuer = mlDsaBuilder\n119:                 .subject(\"CN=issuer.netty.io, O=Netty\")\n120:                 .setIsCertificateAuthority(true)\n121:                 .buildSelfSigned();\n122: \n123:         // ML-KEM can be signed by others\n124:         X509Bundle mlKemBundle = mlKemBuilder.buildIssuedBy(issuer);\n125: \n126:         X509Certificate cert = mlKemBundle.getCertificate();\n127:         assertFalse(mlKemBundle.isCertificateAuthority());\n128:         assertFalse(mlKemBundle.isSelfSigned());\n129:         assertThat(cert.getSubjectX500Principal()).isEqualTo(new X500Principal(SUBJECT));\n130: \n131:         // ML-KEM cannot sign others\n132:         IllegalArgumentException e = assertThrows(IllegalArgumentException.class, () -> {\n133:             mlDsaBuilder.buildIssuedBy(mlKemBundle);\n134:         });\n135:         assertThat(e).hasMessageContaining(\"cannot be used for signing\");\n136:     }\n137: \n138:     @Test\n139:     void createCertIssuedBySameAlgorithm() throws Exception {\n140:         CertificateBuilder builder = BASE.copy().ecp256();\n141:         X509Bundle root = builder.copy()\n142:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n143:                 .setIsCertificateAuthority(true)\n144:                 .buildSelfSigned();\n145:         X509Bundle leaf = builder.copy()\n146:                 .subject(\"CN=leaf.netty.io, O=Netty\")\n147:                 .buildIssuedBy(root);\n148:         assertThat(leaf.getCertificate().getSubjectX500Principal()).isEqualTo(\n149:                 new X500Principal(\"CN=leaf.netty.io, O=Netty\"));\n150:         assertThat(leaf.getCertificate().getIssuerX500Principal()).isEqualTo(\n151:                 new X500Principal(SUBJECT));\n152: \n153:         Signature signature = Signature.getInstance(leaf.getCertificate().getSigAlgName());\n154:         signature.initVerify(root.getCertificate());\n155:         signature.update(leaf.getCertificate().getTBSCertificate());\n156:         assertTrue(signature.verify(leaf.getCertificate().getSignature()));\n157:     }\n158: \n159:     @Test\n160:     void createCertIssuedByDifferentAlgorithmEcp384vsEcp256() throws Exception {\n161:         X509Bundle root = BASE.copy()\n162:                 .algorithm(Algorithm.ecp384)\n163:                 .setKeyUsage(true, KeyUsage.digitalSignature, KeyUsage.keyCertSign)\n164:                 .setIsCertificateAuthority(true)\n165:                 .buildSelfSigned();\n166:         X509Bundle leaf = BASE.copy()\n167:                 .ecp256()\n168:                 .subject(\"CN=leaf.netty.io, O=Netty\")\n169:                 .buildIssuedBy(root);\n170:         assertThat(leaf.getCertificate().getSubjectX500Principal()).isEqualTo(\n171:                 new X500Principal(\"CN=leaf.netty.io, O=Netty\"));\n172:         assertThat(leaf.getCertificate().getIssuerX500Principal()).isEqualTo(\n173:                 new X500Principal(SUBJECT));\n174: \n175:         Signature signature = Signature.getInstance(leaf.getCertificate().getSigAlgName());\n176:         signature.initVerify(root.getCertificate());\n177:         signature.update(leaf.getCertificate().getTBSCertificate());\n178:         assertTrue(signature.verify(leaf.getCertificate().getSignature()));\n179:     }\n180: \n"}], "isError": false, "timestamp": 1782482660902}]}
