  388:     private static X509TrustManager getX509TrustManager(X509Bundle root) throws Exception {
  389:         TrustManagerFactory tmf = TrustManagerFactory.getInstance(TrustManagerFactory.getDefaultAlgorithm());
  390:         PKIXBuilderParameters params = new PKIXBuilderParameters(Collections.singleton(
  391:                 new TrustAnchor(root.getCertificate(), null)), null);
  392: 
  393:         // Explicitly add the revocation checker. We cannot use params.setRevocationEnabled(true) because
  394:         // it will not do any online revocation checking, i.e. it will not do any network access.
  395:         CertPathBuilder cpb = CertPathBuilder.getInstance("PKIX");
  396:         PKIXRevocationChecker rc = (PKIXRevocationChecker) cpb.getRevocationChecker();
  397:         params.addCertPathChecker(rc);
  398: 
  399:         tmf.init(new CertPathTrustManagerParameters(params));
  400:         return (X509TrustManager) tmf.getTrustManagers()[0];
  401:     }
  402: }
