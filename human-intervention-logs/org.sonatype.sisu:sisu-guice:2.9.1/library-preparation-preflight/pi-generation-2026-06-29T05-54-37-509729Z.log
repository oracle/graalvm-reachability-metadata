              <configuration>
                <includes>
                  <include>*:asm</include>
                  <include>*:cglib</include>
                </includes>
              </configuration>
            </plugin>
            <plugin>
              <!--
               | Package the original non-JarJar'd classes so extensions can compile against them
              -->
              <artifactId>maven-jar-plugin</artifactId>
              <executions>
                <execution>
                  <id>nodeps</id>
                  <phase>package</phase>
  
