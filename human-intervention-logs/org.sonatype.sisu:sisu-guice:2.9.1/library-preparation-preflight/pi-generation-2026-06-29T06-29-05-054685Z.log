  017: package com.google.inject.internal;
  018: 
  019: import com.google.inject.internal.util.Function;
  020: import com.google.inject.internal.util.ImmutableMap;
  021: import com.google.inject.internal.util.MapMaker;
  022: import com.google.inject.internal.util.Nullable;
  023: 
  024: import java.lang.reflect.Constructor;
  025: import java.lang.reflect.Member;
  026: import java.lang.reflect.Method;
  027: import java.lang.reflect.Modifier;
  028: import java.security.AccessController;
  029: import java.security.PrivilegedAction;
  030: import java.util.Map;
  031: import java.util.logging.Logger;
  032: 
  033: /**
  034:  * Utility methods for runtime code generation and class loading. We use this stuff for {@link
  035:  * net.sf.cglib.reflect.FastClass faster reflection}, {@link net.sf.cglib.proxy.Enhancer method
  036:  * interceptors} and to proxy circular dependencies.
  037:  *
  038:  * <p>When loading classes, we need to be careful of:
  039:  * <ul>
  040:  *   <li><strong>Memory leaks.</strong> Generated classes need to be garbage collected in long-lived
  041:  *       applications. Once an injector and any instances it created can be garbage collected, the
  042:  *       corresponding generated classes should be collectable.
  043:  *   <li><strong>Visibility.</strong> Containers like <code>OSGi</code> use class loader boundaries
  044:  *       to enforce modularity at runtime.
  045:  * </ul>
  046:  *
  047:  * <p>For each generated class, there's multiple class loaders involved:
  048:  * <ul>
  049:  *    <li><strong>The related class's class loader.</strong> Every generated class services exactly
  050:  *        one user-supplied class. This class loader must be used to access members with private and
  051:  *        package visibility.
  052:  *    <li><strong>Guice's class loader.</strong>
  053:  *    <li><strong>Our bridge class loader.</strong> This is a child of the user's class loader. It
  054:  *        selectively delegates to either the user's class loader (for user classes) or the Guice
  055:  *        class loader (for internal classes that are used by the generated classes). This class
  056:  *        loader that owns the classes generated by Guice.
  057:  * </ul>
  058:  *
  059:  * @author mcculls@gmail.com (Stuart McCulloch)
  060:  * @author jessewilson@google.com (Jesse Wilson)
  061:  */
  062: public final class BytecodeGen {
  063: 
  064:   static final Logger logger = Logger.getLogger(BytecodeGen.class.getName());
  065: 
  066:   static final ClassLoader GUICE_CLASS_LOADER = canonicalize(BytecodeGen.class.getClassLoader());
  067: 
  068:   // initialization-on-demand...
  069:   private static class SystemBridgeHolder {
  070:     static final BridgeClassLoader SYSTEM_BRIDGE = new BridgeClassLoader();
  071:   }
  072: 
  073:   /** ie. "com.google.inject.internal" */
  074:   static final String GUICE_INTERNAL_PACKAGE
  075:       = BytecodeGen.class.getName().replaceFirst("\\.internal\\..*$", ".internal");
  076: 
  077:   /*if[AOP]*/
  078:   /** either "net.sf.cglib", or "com.google.inject.internal.cglib" */
  079:   static final String CGLIB_PACKAGE
  080:       = net.sf.cglib.proxy.Enhancer.class.getName().replaceFirst("\\.cglib\\..*$", ".cglib");
  081: 
  082:   static final net.sf.cglib.core.NamingPolicy NAMING_POLICY
  083:       = new net.sf.cglib.core.DefaultNamingPolicy() {
  084:     @Override protected String getTag() {
  085:       return "ByGuice";
  086:     }
  087:   };
  088:   /*end[AOP]*/
  089:   /*if[NO_AOP]
  090:   private static final String CGLIB_PACKAGE = " "; // any string that's illegal in a package name
  091:   end[NO_AOP]*/
  092: 
  093:   /** Use "-Dguice.custom.loader=false" to disable custom classloading. */
  094:   private static final boolean CUSTOM_LOADER_ENABLED
  095:       = Boolean.parseBoolean(System.getProperty("guice.custom.loader", "true"));
  096: 
  097:   /**
  098:    * Weak cache of bridge class loaders that make the Guice implementation
  099:    * classes visible to various code-generated proxies of client classes.
  100:    */
  101:   private static final Map<ClassLoader, ClassLoader> CLASS_LOADER_CACHE;
  102: 
  103:   static {
  104:     if (CUSTOM_LOADER_ENABLED) {
  105:       CLASS_LOADER_CACHE = new MapMaker().weakKeys().weakValues().makeComputingMap(
  106:           new Function<ClassLoader, ClassLoader>() {
  107:             public ClassLoader apply(final @Nullable ClassLoader typeClassLoader) {
  108:               logger.fine("Creating a bridge ClassLoader for " + typeClassLoader);
  109:               return AccessController.doPrivileged(new PrivilegedAction<ClassLoader>() {
  110:                 public ClassLoader run() {
  111:                   return new BridgeClassLoader(typeClassLoader);
  112:                 }
  113:               });
  114:             }
  115:           });
  116:     } else {
  117:       CLASS_LOADER_CACHE = ImmutableMap.of();
  118:     }
  119:   }
  120: 
  121:   /**
  122:    * Attempts to canonicalize null references to the system class loader.
  123:    * May return null if for some reason the system loader is unavailable.
  124:    */
  125:   private static ClassLoader canonicalize(ClassLoader classLoader) {
  126:     return classLoader != null ? classLoader : SystemBridgeHolder.SYSTEM_BRIDGE.getParent();
  127:   }
  128: 
  129:   /**
  130:    * Returns the class loader to host generated classes for {@code type}.
  131:    */
  132:   public static ClassLoader getClassLoader(Class<?> type) {
  133:     return getClassLoader(type, type.getClassLoader());
  134:   }
  135: 
  136:   private static ClassLoader getClassLoader(Class<?> type, ClassLoader delegate) {
  137: 
  138:     // simple case: do nothing!
  139:     if (!CUSTOM_LOADER_ENABLED) {
  140:       return delegate;
  141:     }
  142:     
  143:     // java.* types can be seen everywhere
  144:     if (type.getName().startsWith("java.")) {
  145:       return GUICE_CLASS_LOADER;
  146:     }
  147: 
  148:     delegate = canonicalize(delegate);
  149: 
  150:     // no need for a bridge if using same class loader, or it's already a bridge
  151:     if (delegate == GUICE_CLASS_LOADER || delegate instanceof BridgeClassLoader) {
  152:       return delegate;
  153:     }
  154: 
  155:     // don't try bridging private types as it won't work
  156:     if (Visibility.forType(type) == Visibility.PUBLIC) {
  157:       if (delegate != SystemBridgeHolder.SYSTEM_BRIDGE.getParent()) {
  158:         // delegate guaranteed to be non-null here
  159:         return CLASS_LOADER_CACHE.get(delegate);
  160:       }
  161:       // delegate may or may not be null here
  162:       return SystemBridgeHolder.SYSTEM_BRIDGE;
  163:     }
  164: 
  165:     return delegate; // last-resort: do nothing!
  166:   }
  167: 
  168:   /*if[AOP]*/
  169:   // use fully-qualified names so imports don't need preprocessor statements 
  170:   public static net.sf.cglib.reflect.FastClass newFastClass(Class<?> type, Visibility visibility) {
  171:     net.sf.cglib.reflect.FastClass.Generator generator
  172:         = new net.sf.cglib.reflect.FastClass.Generator();
  173:     generator.setType(type);
  174:     if (visibility == Visibility.PUBLIC) {
  175:       generator.setClassLoader(getClassLoader(type));
  176:     }
  177:     generator.setNamingPolicy(NAMING_POLICY);
  178:     logger.fine("Loading " + type + " FastClass with " + generator.getClassLoader());
  179:     return generator.create();
  180:   }
  181: 
  182:   public static net.sf.cglib.proxy.Enhancer newEnhancer(Class<?> type, Visibility visibility) {
  183:     net.sf.cglib.proxy.Enhancer enhancer = new net.sf.cglib.proxy.Enhancer();
  184:     enhancer.setSuperclass(type);
  185:     enhancer.setUseFactory(false);
  186:     if (visibility == Visibility.PUBLIC) {
  187:       enhancer.setClassLoader(getClassLoader(type));
  188:     }
  189:     enhancer.setNamingPolicy(NAMING_POLICY);
  190:     logger.fine("Loading " + type + " Enhancer with " + enhancer.getClassLoader());
  191:     return enhancer;
  192:   }
  193:   /*end[AOP]*/
  194: 
  195:   /**
  196:    * The required visibility of a user's class from a Guice-generated class. Visibility of
  197:    * package-private members depends on the loading classloader: only if two classes were loaded by
  198:    * the same classloader can they see each other's package-private members. We need to be careful
  199:    * when choosing which classloader to use for generated classes. We prefer our bridge classloader,
  200:    * since it's OSGi-safe and doesn't leak permgen space. But often we cannot due to visibility.
  201:    */
  202:   public enum Visibility {
  203: 
  204:     /**
  205:      * Indicates that Guice-generated classes only need to call and override public members of the
  206:      * target class. These generated classes may be loaded by our bridge classloader.
  207:      */
  208:     PUBLIC {
  209:       @Override
  210:       public Visibility and(Visibility that) {
  211:         return that;
  212:       }
  213:     },
  214: 
  215:     /**
  216:      * Indicates that Guice-generated classes need to call or override package-private members.
  217:      * These generated classes must be loaded in the same classloader as the target class. They
  218:      * won't work with OSGi, and won't get garbage collected until the target class' classloader is
  219:      * garbage collected.
  220:      */
  221:     SAME_PACKAGE {
  222:       @Override
  223:       public Visibility and(Visibility that) {
  224:         return this;
  225:       }
  226:     };
  227: 
  228:     public static Visibility forMember(Member member) {
  229:       if ((member.getModifiers() & (Modifier.PROTECTED | Modifier.PUBLIC)) == 0) {
  230:         return SAME_PACKAGE;
  231:       }
  232: 
  233:       Class[] parameterTypes = member instanceof Constructor
  234:           ? ((Constructor) member).getParameterTypes()
  235:           : ((Method) member).getParameterTypes();
  236:       for (Class<?> type : parameterTypes) {
  237:         if (forType(type) == SAME_PACKAGE) {
  238:           return SAME_PACKAGE;
  239:         }
  240:       }
