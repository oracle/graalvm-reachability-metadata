        <artifactId>slf4j-api</artifactId>
        <version>1.6.1</version>
        <optional>true</optional>
      </dependency>
      <dependency>
        <groupId>javax.inject</groupId>
        <artifactId>javax.inject-tck</artifactId>
        <version>1</version>
        <scope>test</scope>
      </dependency>
      <dependency>
