        coords = tck.getMatchingCoordinatesStrict(coordinateFilter)\n            }\n            coords = coords.findAll { !it.startsWith(\"samples:\") }\n        } else {\n            coords = new ArrayList<>(matchingCoordinates)\n        }\n        coords.sort()\n        if (coords.isEmpty()) {\n            println \"No matching coordinates found!\"\n        } else {\n            coords.each { println it }\n        }\n        writeGithubOutput(\"coordinates\", coords.join(' '))\n    }\n}\n\ntasks.register(\"populateArtifactURLs\", PopulateArtifactURLs.class) { task ->\n    task.setDescription(\"Uses a coding agent command to fill source-code-url, repository-url, test-code-url, documentation-url, description, and language in matching metadata index entries.\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"discoverArtifactMetadata\", DiscoverArtifactMetadata.class) { task ->\n    task.setDescription(\"Uses a coding agent command to discover artifact metadata for a single coordinate and stores it under build/.\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"listLibraryJars\", ListLibraryJarsInvocationTask.class) { task ->\n    task.setDescription(\"Lists resolved tested-library JARs for matching coordinates (one per line)\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"generateDynamicAccessReport\", GenerateDynamicAccessReportInvocationTask.class) { task ->\n    task.setDescription(\"Builds native tests and prints generated dynamic-access JSON report files for matching coordinates\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"generateDynamicAccessCoverageReport\", GenerateDynamicAccessCoverageReportTask.class) { task ->\n    task.setDescription(\"Generates a per-class dynamic-access coverage report for matching coordinates\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"generateLibraryStats\", GenerateLibraryStatsTask.class) { task ->\n    task.setDescription(\"Generates local library stats and updates stats/<group>/<artifact>/<metadata-version>/stats.json\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"generateReadmeBadgeSummary\", GenerateReadmeBadgeSummaryTask.class) { task ->\n    task.setDescription(\"Generates current README metrics data, coverage Markdown, and updates README metrics history\")\n    task.setGroup(METADATA_GROUP)\n}\n\ntasks.register(\"validateLibraryStats\", ValidateLibraryStatsTask.class) { task ->\n    task.setDescription(\"Validates exploded stats/*.json files against the committed JSON schema\")\n    task.setGroup(JavaBasePlugin.VERIFICATION_GROUP)\n}\n\ntasks.register(\"checkDocLinks\", CheckDocLinksTask.class) { task ->\n    task.setDescription(\"Verifies that every repo-local link in Markdown documentation resolves\")\n    task.setGroup(JavaBasePlugin.VERIFICATION_GROUP)\n    task.getRepoRoot().set(tck.repoRoot)\n}\n\ntasks.register(\"analyzeExternalLibraryDynamicAccess\", AnalyzeExternalLibraryDynamicAccessTask.class) { task ->\n    task.setDescription(\"Resolves an external Maven coordinate and reports preserve/track dynamic-access totals\")\n","exit_code":0,"status":"completed"}}
