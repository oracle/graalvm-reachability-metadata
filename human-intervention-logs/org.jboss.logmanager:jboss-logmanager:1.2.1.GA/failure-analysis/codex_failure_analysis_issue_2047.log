th\n    else:\n        resolved_reachability_root = reachability_default\n        if not os.path.exists(reachability_default):\n            clone_repo(\n                reachability_default,\n                \"git@github.com:oracle/graalvm-reachability-metadata.git\",\n            )\n\n    # metadata-forge-metrics repo root\n    log_stage(\"resolve-repo\", \"Resolving metadata-forge-metrics root path\")\n    if explicit_metrics_repo_path:\n        resolved_metrics_root = explicit_metrics_repo_path\n    else:\n        resolved_metrics_root = metrics_default\n        if not os.path.exists(metrics_default):\n            clone_repo(\n                metrics_default,\n                \"ssh://git@ol-bitbucket.us.oracle.com:7999/~vojin.jovanovic_oracle.com/metadata-forge-metrics.git\",\n            )\n\n    return resolved_reachability_root, resolved_metrics_root\n","exit_code":0,"status":"completed"}}
