  package org_jboss_logmanager.jboss_logmanager;
  
  import java.security.Permission;
  import java.util.logging.Level;
  
  import org.jboss.logmanager.ExtLogRecord;
  import org.jboss.logmanager.formatters.PatternFormatter;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FormattersAnonymous12Anonymous2Test {
  
      @Test
      @SuppressWarnings("removal")
      void privilegedResourceLookupUsesClassLoaderResourceForApplicationFrameClass() {
          final ProtectionDomainDenyingSecurityManager securityManager = new ProtectionDomainDenyingSecurityManager();
  
          final String formatted = formatWithSecurityManager(FrameClass.class.getName(), securityManager);
  
          assertThat(formatted).contains("\tat " + FrameClass.class.getName() + ".invoke");
          assertThat(securityManager.deniedProtectionDomainChecks()).isGreaterThan(0);
      }
  
      @Test
      @SuppressWarnings("removal")
      void privilegedResourceLookupUsesSystemResourceForBootstrapFrameClass() {
          final ProtectionDomainDenyingSecurityManager securityManager = new ProtectionDomainDenyingSecurityManager();
  
          final String formatted = formatWithSecurityManager(String.class.getName(), securityManager);
  
          assertThat(formatted).contains("\tat " + String.class.getName() + ".invoke");
          assertThat(securityManager.deniedProtectionDomainChecks()).isGreaterThan(0);
      }
  
      @SuppressWarnings("removal")
      private static String formatWithSecurityManager(
              final String frameClassName,
              final ProtectionDomainDenyingSecurityManager securityManager
      ) {
          final SecurityManager previousSecurityManager = System.getSecurityManager();
          try {
              System.setSecurityManager(securityManager);
              final PatternFormatter formatter = new PatternFormatter("%E");
              final ExtLogRecord record = new ExtLogRecord(
                      Level.SEVERE,
                      "coverage",
                      FormattersAnonymous12Anonymous2Test.class.getName()
              );
              record.setThrown(newFailure(frameClassName));
              return formatter.format(record);
          } finally {
              System.setSecurityManager(previousSecurityManager);
          }
      }
  
      private static IllegalStateException newFailure(final String frameClassName) {
          final IllegalStateException failure = new IllegalStateException("boom");
          failure.setStackTrace(new StackTraceElement[] {
                  new StackTraceElement(frameClassName, "invoke", "GeneratedFrame.java", 17)
          });
          return failure;
      }
  
      @SuppressWarnings("removal")
      private static final class ProtectionDomainDenyingSecurityManager extends SecurityManager {
          private int deniedProtectionDomainChecks;
  
          int deniedProtectionDomainChecks() {
              return deniedProtectionDomainChecks;
          }
  
          @Override
          public void checkPermission(final Permission permission) {
              if (permission instanceof RuntimePermission && "getProtectionDomain".equals(permission.getName())) {
                  deniedProtectionDomainChecks++;
                  throw new SecurityException("deny protection-domain lookup to exercise resource fallback");
              }
          }
      }
  
      private static final class FrameClass {
      }
  }
