{"type":"item.completed","item":{"id":"item_46","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.mockito/mockito-scala_2.13/2.0.0/src/test/scala/org_mockito/mockito_scala_2_13/ReflectionUtilsTest.scala\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_scala_2_13\n\nimport java.lang.invoke.MethodHandle\nimport java.lang.invoke.MethodHandles\nimport java.lang.invoke.MethodType.methodType\nimport java.lang.reflect.Field\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNotNull\nimport org.junit.jupiter.api.Assertions.assertNull\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\nimport org.mockito.ReflectionUtils\n\nclass ReflectionUtilsTest {\n  @Test\n  def legacySetFinalStaticImplementationUpdatesMutableStaticField(): Unit = {\n    val mutableField: Field = classOf[LegacyMutableStaticTarget].getDeclaredField(\"mutableValue\")\n    val originalValue: Object = LegacyMutableStaticTarget.mutableValue\n    val replacementValue: Object = \"replacement\"\n    val legacySetter: MethodHandle = setFinalStatic17MinusHandle()\n\n    try {\n      legacySetter.invokeWithArguments(ReflectionUtils, mutableField, replacementValue)\n\n      assertSame(replacementValue, LegacyMutableStaticTarget.mutableValue)\n    } finally {\n      LegacyMutableStaticTarget.mutableValue = originalValue\n    }\n  }\n\n  @Test\n  def legacySetFinalStaticImplementationUpdatesAndRestoresStaticModuleField(): Unit = {\n    val moduleClass: Class[_] = LegacyFinalStaticModuleTarget.getClass\n    val moduleField: Field = moduleClass.getDeclaredField(\"MODULE$\")\n    val originalModule: Object = moduleField.get(null)\n    val legacySetter: MethodHandle = setFinalStatic17MinusHandle()\n\n    var updated: Boolean = false\n    var failedOnModernJdk: Boolean = false\n    try {\n      try {\n        legacySetter.invokeWithArguments(ReflectionUtils, moduleField, null)\n        updated = true\n\n        assertNull(moduleField.get(null))\n      } catch {\n        case e: InternalError if causedByIllegalAccess(e) =>\n          failedOnModernJdk = true\n          assertNotNull(e.getMessage)\n      }\n    } finally {\n      if (updated) {\n        legacySetter.invokeWithArguments(ReflectionUtils, moduleField, originalModule)\n      }\n    }\n\n    if (!failedOnModernJdk) {\n      assertSame(originalModule, moduleField.get(null))\n    }\n    assertEquals(\"legacy\", LegacyFinalStaticModuleTarget.value)\n  }\n\n  @Test\n  def listToTupleBuildsRuntimeTupleForMultipleElements(): Unit = {\n    val tuple: Any = ReflectionUtils.listToTuple(\n      List[Object](\"alpha\", Integer.valueOf(7), java.lang.Boolean.TRUE)\n    )\n\n    assertEquals((\"alpha\", Integer.valueOf(7), java.lang.Boolean.TRUE), tuple)\n  }\n\n  @Test\n  def setFinalStaticUpdatesAndRestoresStaticModuleField(): Unit = {\n    val moduleClass: Class[_] = FinalStaticModuleTarget.getClass\n    val moduleField: Field = moduleClass.getDeclaredField(\"MODULE$\")\n    val originalModule: Object = moduleField.get(null)\n\n    try {\n      ReflectionUtils.setFinalStatic(moduleField, null)\n\n      assertNull(moduleField.get(null))\n    } finally {\n      ReflectionUtils.setFinalStatic(moduleField, originalModule)\n    }\n\n    assertSame(originalModule, moduleField.get(null))\n    assertEquals(\"original\", FinalStaticModuleTarget.value)\n  }\n\n  private def causedByIllegalAccess(error: InternalError): Boolean = {\n    val cause: Throwable = error.getCause\n    cause != null && cause.isInstanceOf[IllegalAccessException]\n  }\n\n  private def setFinalStatic17MinusHandle(): MethodHandle =\n    MethodHandles\n      .privateLookupIn(ReflectionUtils.getClass, MethodHandles.lookup())\n      .findVirtual