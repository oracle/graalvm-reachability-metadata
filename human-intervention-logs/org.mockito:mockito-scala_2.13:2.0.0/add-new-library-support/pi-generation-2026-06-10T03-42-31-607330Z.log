tent": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_scala_2_13\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.mockito.MockitoSugar\n\nclass ReflectionExtractorTest extends MockitoSugar {\n  @Test\n  def thenReturnSupportsInterfaceMethodReturningValueClass(): Unit = {\n    val repository: ValueClassRepository = mock[ValueClassRepository]\n\n    when(repository.current()).thenReturn(ValueClassUserId(\"user-1\"))\n\n    assertThat(repository.current()).isEqualTo(ValueClassUserId(\"user-1\"))\n  }\n}\n\nfinal case class ValueClassUserId(value: String) extends AnyVal\n\ntrait ValueClassRepository {\n  def current(): ValueClassUserId\n}\n"}], "isError": false, "timestamp": 1781062825415}, {"role": "toolResult", "toolCallId": "call_EIjtrCP4zgpsmH7axWusqkto|fc_08ce8533f08483a9016a28dca912b48193a1c4c0ec220fb916", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_mockito.mockito_scala_2_13\n\nimport java.lang.reflect.Field\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.mockito.MockitoSugar\nimport org.mockito.ReflectionUtils\n\nclass ReflectionUtilsTest extends MockitoSugar {\n  @Test\n  def partialFunctionAnswerMatchesTupleArguments(): Unit = {\n    val service: TupledService = mock[TupledService]\n\n    val answer: PartialFunction[Any, String] = {\n      case (first: String, second: String, third: String) => s\"$first-$second-$third\"\n    }\n\n    when(service.join(\"alpha\", \"beta\", \"gamma\")).thenAnswer(answer)\n\n    assertThat(service.join(\"alpha\", \"beta\", \"gamma\")).isEqualTo(\"alpha-beta-gamma\")\n  }\n\n  @Test\n  def setFinalStaticAcceptsScalaModuleField(): Unit = {\n    val moduleField: Field = StaticFinalFixture.getClass.getDeclaredField(\"MODULE$\")\n    val moduleInstance: Object = moduleField.get(null).asInstanceOf[Object]\n\n    ReflectionUtils.setFinalStatic(moduleField, moduleInstance)\n\n    assertThat(moduleField.get(null)).isSameAs(moduleInstance)\n    assertThat(StaticFinalFixture.message).isEqualTo(\"fixture\")\n  }\n}\n\ntrait TupledService {\n  def join(first: String, second: String, third: String): String\n}\n\nobject StaticFinalFixture {\n  def message: String = \"fixture\"\n}\n"}], "isError": false, "timestamp": 1781062825416}]}
