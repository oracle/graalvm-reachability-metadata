  package org_mockito.mockito_scala_2_13
  
  import java.lang.reflect.Method
  
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Assertions.assertTrue
  import org.junit.jupiter.api.Test
  import org.mockito.ReflectionUtils.InvocationOnMockOps
  import org.mockito.invocation.InvocationOnMock
  
  class ReflectionUtilsInnerInvocationOnMockOpsInnerAnonfunInnerNestedInanonfunInnerFindTypeSymbolInnerExtensionAnonymous1Anonymous1Test {
    @Test
    def returnTypeResolvesGenericMethodByInspectingTheScalaTypeSymbol(): Unit = {
      val invocation: InvocationOnMock = new CapturedInvocation(
        new ConcreteGenericSymbolService,
        genericSymbolMethod("genericValue")
      )
  
      assertEquals(classOf[String], invocation.returnType)
    }
  
    @Test
    def returnsValueClassDetectsValueClassReturnFromTheScalaTypeSymbol(): Unit = {
      val invocation: InvocationOnMock = new CapturedInvocation(
        new ConcreteGenericSymbolService,
        genericSymbolMethod("valueClassValue")
      )
  
      assertTrue(invocation.returnsValueClass)
    }
  
    private def genericSymbolMethod(name: String): Method =
      classOf[GenericSymbolService[_]].getMethod(name)
  }
  
  trait GenericSymbolService[A] {
    def genericValue: A
  
    def valueClassValue: GenericSymbolValue
  }
  
  final class ConcreteGenericSymbolService extends GenericSymbolService[String] {
    override def genericValue: String = "resolved"
  
    override def valueClassValue: GenericSymbolValue = new GenericSymbolValue("id-1")
  }
  
  final class GenericSymbolValue(val value: String) extends AnyVal
  
  final class CapturedInvocation(mock: AnyRef, method: Method) extends InvocationOnMock {
    override def getMock: AnyRef = mock
  
    override def getMethod: Method = method
  
    override def getRawArguments: Array[AnyRef] = Array.empty[AnyRef]
  
    override def getArguments: Array[AnyRef] = Array.empty[AnyRef]
  
    override def getArgument[T](index: Int): T =
      throw new IndexOutOfBoundsException(index)
  
    override def getArgument[T](index: Int, clazz: Class[T]): T = getArgument[T](index)
  
    @throws[Throwable]
    override def callRealMethod(): AnyRef =
