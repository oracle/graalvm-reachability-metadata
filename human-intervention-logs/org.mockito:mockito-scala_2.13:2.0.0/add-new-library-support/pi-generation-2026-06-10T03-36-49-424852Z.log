  package org_mockito.mockito_scala_2_13
  
  import org.assertj.core.api.Assertions.assertThat
  import org.assertj.core.api.Assertions.assertThatThrownBy
  import org.junit.jupiter.api.Test
  import org.mockito.MockitoSugar
  import org.mockito.exceptions.base.MockitoException
  
  class MockitoEnhancerTest extends MockitoSugar {
    @Test
    def withObjectMockedLoadsScalaModuleBeforeCreatingObjectMock(): Unit = {
      var blockEntered: Boolean = false
  
      assertThat(MockitoEnhancerModuleFixture.message).isEqualTo("real")
      assertThatThrownBy(() =>
        withObjectMocked[MockitoEnhancerModuleFixture.type] {
          blockEntered = true
        }
      ).isInstanceOf(classOf[MockitoException])
        .hasMessageContaining("non-interface")
  
      assertThat(blockEntered).isFalse()
      assertThat(MockitoEnhancerModuleFixture.message).isEqualTo("real")
    }
  }
  
  object MockitoEnhancerModuleFixture {
    def message: String = "real"
  }
