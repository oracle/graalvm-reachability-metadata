[tool-call] delta {"path":"tests/src/org.mockito/mockito-scala_2.13/2.0.0/src/test/scala/org_mockito/mockito_scala_2_13/ReflectionUtilsTest.scala","edits":[{"oldText":"package org_mockito.mockito_scala_2_13\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNull\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\nimport org.mockito.ReflectionUtils\n","newText":"package org_mockito.mockito_scala_2_13\n\nimport java.lang.invoke.MethodHandles\nimport java.lang.invoke.MethodType.methodType\nimport java.lang.reflect.Field\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNull\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\nimport org.mockito.ReflectionUtils\n"},{"oldText":"class ReflectionUtilsTest {\n  @Test\n  def listToTupleBuildsRuntimeTupleForMultipleElements(): Unit = {","newText":"class ReflectionUtilsTest {\n  @Test\n  def legacySetFinalStaticImplementationUpdatesAndRestoresStaticModuleField(): Unit = {\n    val moduleClass: Class[_] = LegacyFinalStaticModuleTarget.getClass\n    val moduleField: Field = moduleClass.getDeclaredField(\"MODULE$\")\n    val originalModule: Object = moduleField.get(null)\n    val legacySetter = MethodHandles\n      .privateLookupIn(ReflectionUtils.getClass, MethodHandles.lookup())\n      .findVirtual(\n        ReflectionUtils.getClass,\n        \"setFinalStatic17Minus\",\n        methodType(classOf[Void], classOf[Field], classOf[Object])\n      )\n\n    try {\n      legacySetter.invokeWithArguments(ReflectionUtils, moduleField, null)\n\n      assertNull(moduleField.get(null))\n    } finally {\n      legacySetter.invokeWithArguments(ReflectionUtils, moduleField, originalModule)\n    }\n\n    assertSame(originalModule, moduleField.get(null))\n    assertEquals(\"legacy\", LegacyFinalStaticModuleTarget.value)\n  }\n\n  @Test\n  def listToTupleBuildsRuntimeTupleForMultipleElements(): Unit = {"},{"oldText":"object FinalStaticModuleTarget {\n  def value: String = \"original\"\n}\n","newText":"object FinalStaticModuleTarget {\n  def value: String = \"original\"\n}\n\nobject LegacyFinalStaticModuleTarget {\n  def value: String = \"legacy\"\n}\n"}]}
[tool-call] end id=call_n7OcE39X9lB52lefREqLCV1A|fc_048a9df48b4ddf110169fb27410a8c81a18c7f7db9f554c568 name=edit args={"path": "tests/src/org.mockito/mockito-scala_2.13/2.0.0/src/test/scala/org_mockito/mockito_scala_2_13/ReflectionUtilsTest.scala", "edits": [{"oldText": "package org_mockito.mockito_scala_2_13\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNull\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\nimport org.mockito.ReflectionUtils\n", "newText": "package org_mockito.mockito_scala_2_13\n\nimport java.lang.invoke.MethodHandles\nimport java.lang.invoke.MethodType.methodType\nimport java.lang.reflect.Field\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNull\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\nimport org.mockito.ReflectionUtils\n"}, {"oldText": "class ReflectionUtilsTest {\n  @Test\n  def listToTupleBuildsRuntimeTupleForMultipleElements(): Unit = {", "newText": "class ReflectionUtilsTest {\n  @Test\n  def legacySetFinalStaticImplementationUpdatesAndRestoresStaticModuleField(): Unit = {\n    val moduleClass: Class[_] = LegacyFinalStaticModuleTarget.getClass\n    val moduleField: Field = moduleClass.getDeclaredField(\"MODULE$\")\n    val originalModule: Object = moduleField.get(null)\n    val legacySetter = MethodHandles\n      .privateLookupIn(ReflectionUtils.getClass, MethodHandles.lookup())\n      .findVirtual(\n        ReflectionUtils.getClass,\n        \"setFinalStatic17Minus\",\n        methodType(classOf[Void], classOf[Field], classOf[Object])\n      )\n\n    try {\n      legacySetter.invokeWithArguments(ReflectionUtils, moduleField, null)\n\n      assertNull(moduleField.get(null))\n    } finally {\n      legacySetter.invokeWithArguments(ReflectionUtils, moduleField, originalModule)\n    }\n\n    assertSame(originalModule, moduleField.get(null))\n    asse