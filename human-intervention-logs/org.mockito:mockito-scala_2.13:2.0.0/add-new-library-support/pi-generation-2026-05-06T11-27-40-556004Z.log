ions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNull\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Test\nimport org.mockito.ReflectionUtils\n\nclass ReflectionUtilsTest {\n  @Test\n  def listToTupleBuildsRuntimeTupleForMultipleElements(): Unit = {\n    val tuple: Any = ReflectionUtils.listToTuple(\n      List[Object](\"alpha\", Integer.valueOf(7), java.lang.Boolean.TRUE)\n    )\n\n    assertEquals((\"alpha\", Integer.valueOf(7), java.lang.Boolean.TRUE), tuple)\n  }\n\n  @Test\n  def setFinalStaticUpdatesAndRestoresStaticModuleField(): Unit = {\n    val moduleClass: Class[_] = FinalStaticModuleTarget.getClass\n    val moduleField = moduleClass.getDeclaredField(\"MODULE$\")\n    val originalModule: Object = moduleField.get(null)\n\n    try {\n      ReflectionUtils.setFinalStatic(moduleField, null)\n\n      assertNull(moduleField.get(null))\n    } finally {\n      ReflectionUtils.setFinalStatic(moduleField, originalModule)\n    }\n\n    assertSame(originalModule, moduleField.get(null))\n    assertEquals(\"original\", FinalStaticModuleTarget.value)\n  }\n}\n\nobject FinalStaticModuleTarget {\n  def value: String = \"original\"\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 724, "output": 1339, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25615, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778066809601, "responseId": "resp_048a9df48b4ddf110169fb257a168481a1b3541082025de99a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_yrm9r5UxgF2zHRBg5o4ZUhxN|fc_048a9df48b4ddf110169fb25876a9081a1960aa09376aedd0d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1428 bytes to tests/src/org.mockito/mockito-scala_2.13/2.0.0/src/test/scala/org_mockito/mockito_scala_2_13/ReflectionUtilsTest.scala"}], "isError": false, "timestamp": 1778066825677}]}
