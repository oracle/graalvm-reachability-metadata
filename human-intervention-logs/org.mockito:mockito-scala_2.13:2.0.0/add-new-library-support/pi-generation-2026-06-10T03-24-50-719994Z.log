  package org_mockito.mockito_scala_2_13
  
  import java.lang.reflect.Field
  
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import org.mockito.MockitoSugar
  import org.mockito.ReflectionUtils
  
  class ReflectionUtilsTest extends MockitoSugar {
    @Test
    def partialFunctionAnswerMatchesTupleArguments(): Unit = {
      val service: TupledService = mock[TupledService]
  
      val answer: PartialFunction[Any, String] = {
        case (first: String, second: String, third: String) => s"$first-$second-$third"
      }
  
      when(service.join("alpha", "beta", "gamma")).thenAnswer(answer)
  
      assertThat(service.join("alpha", "beta", "gamma")).isEqualTo("alpha-beta-gamma")
    }
  
    @Test
    def setFinalStaticAcceptsScalaModuleField(): Unit = {
      val moduleField: Field = StaticFinalFixture.getClass.getDeclaredField("MODULE$")
      val moduleInstance: Object = moduleField.get(null).asInstanceOf[Object]
  
      ReflectionUtils.setFinalStatic(moduleField, moduleInstance)
  
      assertThat(moduleField.get(null)).isSameAs(moduleInstance)
      assertThat(StaticFinalFixture.message).isEqualTo("fixture")
    }
  }
  
  trait TupledService {
    def join(first: String, second: String, third: String): String
  }
  
  object StaticFinalFixture {
    def message: String = "fixture"
  }
