  package org_mockito.mockito_scala_2_13
  
  import org.junit.jupiter.api.Assertions.assertSame
  import org.junit.jupiter.api.Assertions.assertTrue
  import org.junit.jupiter.api.Test
  import org.mockito.ReflectionUtils.InvocationOnMockOps
  import org.mockito.internal.ValueClassExtractor
  import org.mockito.invocation.InvocationOnMock
  
  class ReflectionExtractorTest {
    @Test
    def valueClassExtractorReadsTheUnderlyingInvocation(): Unit = {
      val extractor: ValueClassExtractor[InvocationOnMockOps] = ValueClassExtractor[InvocationOnMockOps]
      val invocation: InvocationOnMock = new CapturedInvocation(
        new Object,
        classOf[Object].getMethod("toString")
      )
      val valueClass: InvocationOnMockOps = new InvocationOnMockOps(invocation)
  
      assertTrue(extractor.isValueClass)
      assertSame(invocation, extractor.extract(valueClass))
      assertSame(invocation, extractor.extractAs[InvocationOnMock](valueClass))
    }
  }
