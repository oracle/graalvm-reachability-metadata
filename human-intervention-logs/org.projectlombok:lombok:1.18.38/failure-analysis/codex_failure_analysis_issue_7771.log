rary-support/pi-generation-2026-06-06T03-55-19-959085Z.log:592:  \t\t\t} catch (ClassNotFoundException e) {\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-593-  \t\t\t\tthrow sneakyThrow(e);\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-594-  \t\t\t}\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-595-  \t\t}\n--\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-597-  \t\tpublic static Method findMethod(Class<?> type, String name, Class<?>... parameterTypes) {\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-598-  \t\t\ttry {\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-599-  \t\t\t\treturn type.getDeclaredMethod(name, parameterTypes);\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log:600:  \t\t\t} catch (NoSuchMethodException e) {\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-601-  \t\t\t\tthrow sneakyThrow(e);\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-602-  \t\t\t}\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-603-  \t\t}\n--\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generation-2026-06-06T03-55-19-959085Z.log-608-  \t\t\t\t\treturn m;\nhuman-intervention-logs/org.projectlombok:lombok:1.18.38/add-new-library-support/pi-generati