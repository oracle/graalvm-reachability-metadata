Class = shadowLoader.loadClass(\"lombok.core.Main\");\n        URL mainResource = shadowLoader.getResource(\"lombok/core/Main.class\");\n        assertThat(mainResource).isNotNull();\n\n        Method urlToDefineClass = shadowLoader.getClass().getDeclaredMethod(\n                \"urlToDefineClass\", String.class, URL.class, boolean.class);\n        urlToDefineClass.setAccessible(true);\n\n        Object duplicateDefinition = urlToDefineClass.invoke(shadowLoader, \"lombok.core.Main\", mainResource, false);\n\n        assertThat(duplicateDefinition).isSameAs(mainClass);\n    }\n\n    private static ClassLoader newShadowClassLoader(Path override) throws Exception {\n        String previousOverride = System.getProperty(\"shadow.override.lombok\");\n        if (override == null) {\n            System.clearProperty(\"shadow.override.lombok\");\n        } else {\n            System.setProperty(\"shadow.override.lombok\", override.toString());\n        }\n\n        try {\n            Class<?> type = Class.forName(SHADOW_CLASS_LOADER);\n            Constructor<?> constructor = type.getDeclaredConstructor(\n                    ClassLoader.class, String.class, String.class, List.class, List.class);\n            constructor.setAccessible(true);\n            return (ClassLoader) constructor.newInstance(\n                    ShadowClassLoaderTest.class.getClassLoader(),\n                    \"lombok\",\n                    null,\n                    List.of(),\n                    List.of(\"lombok.patcher.Symbols\"));\n        } finally {\n            if (previousOverride == null) {\n                System.clearProperty(\"shadow.override.lombok\");\n            } else {\n                System.setProperty(\"shadow.override.lombok\", previousOverride);\n            }\n        }\n    }\n\n    private static String diagnosticText(DiagnosticCollector<JavaFileObject> diagnostics, StringWriter compilerOutput) {\n        StringBuilder text = new StringBuilder(compilerOutput.toString());\n        for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {\n            text.append(System.lineSeparator()).append(diagnostic);\n        }\n        return text.toString();\n    }\n\n    private static final class SourceFile extends SimpleJavaFileObject {\n        private final String source;\n\n        private SourceFile(String className, String source) {\n            super(java.net.URI.create(\"string:///\" + className.replace('.', '/') + JavaFileObject.Kind.SOURCE.extension),\n                    JavaFileObject.Kind.SOURCE);\n            this.source = source;\n        }\n\n        @Override\n        public CharSequence getCharContent(boolean ignoreEncodingErrors) {\n            return source;\n        }\n    }\n}\n"}
