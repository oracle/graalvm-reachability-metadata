  	private Class<?> urlToDefineClass(String name, URL res, boolean resolve) throws ClassNotFoundException {
  		byte[] b;
  		int p = 0;
  		try {
  			InputStream in = res.openStream();
  			
  			try {
  				b = new byte[65536];
  				while (true) {
  					int r = in.read(b, p, b.length - p);
  					if (r == -1) break;
  					p += r;
