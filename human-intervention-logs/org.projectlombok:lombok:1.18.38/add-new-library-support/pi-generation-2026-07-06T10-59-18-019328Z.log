  		public static Class<?> shadowLoadClass(String name) {
  			try {
  				if (shadowLoader == null) {
  					try {
  						Class.forName("lombok.core.LombokNode");
  						// If we get here, then lombok is already available.
  						shadowLoader = Delombok.class.getClassLoader();
