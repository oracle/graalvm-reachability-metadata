[tool-call] delta {"path":"tests/src/org.projectlombok/lombok/1.18.38/src/test/java/org_projectlombok/lombok/PatchFixesHiderInnerUtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_projectlombok.lombok;\n\nimport java.lang.reflect.Method;\n\nimport lombok.eclipse.agent.PatchFixesShadowLoaded;\nimport lombok.launch.PatchFixesHider$Util;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PatchFixesHiderInnerUtilTest {\n    @Test\n    void loadsShadowedClassAndInvokesItsMethod() {\n        Class<?> shadowedClass = PatchFixesHider$Util.shadowLoadClass(\n                PatchFixesShadowLoaded.class.getName());\n\n        assertThat(shadowedClass).isEqualTo(PatchFixesShadowLoaded.class);\n\n        Method methodWithTypes = PatchFixesHider$Util.findMethod(\n                shadowedClass,\n                \"addLombokNotesToEclipseAboutDialog\",\n                String.class,\n                String.class);\n        Method methodWithTypeNames = PatchFixesHider$Util.findMethod(\n                shadowedClass,\n                \"addLombokNotesToEclipseAboutDialog\",\n                String.class.getName(),\n                String.class.getName());\n        Method methodWithAnyArguments = PatchFixesHider$Util.findMethodAnyArgs(\n                shadowedClass,\n                \"addLombokNotesToEclipseAboutDialog\");\n\n        assertThat(methodWithTypeNames).isEqualTo(methodWithTypes);\n        assertThat(methodWithAnyArguments).isEqualTo(methodWithTypes);\n\n        String notes = (String) PatchFixesHider$Util.invokeMethod(\n                methodWithTypes,\n                \"Lombok is active.\",\n                \"aboutText\");\n\n        assertThat(notes)\n                .startsWith(\"Lombok is active.\")\n                .contains(\" is installed. https://projectlombok.org/\");\n    }\n}\n"}
