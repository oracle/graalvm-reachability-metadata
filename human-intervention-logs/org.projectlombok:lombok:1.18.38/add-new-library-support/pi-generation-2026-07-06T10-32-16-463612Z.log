h": "tests/src/org.projectlombok/lombok/1.18.38/src/test/java/org_projectlombok/lombok/PatchFixesHiderInnerUtilTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_projectlombok.lombok;\n\nimport java.lang.reflect.Method;\n\nimport lombok.eclipse.agent.PatchFixesShadowLoaded;\nimport lombok.launch.PatchFixesHider$Util;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PatchFixesHiderInnerUtilTest {\n    @Test\n    void loadsShadowedClassAndInvokesItsMethod() {\n        Class<?> shadowedClass = PatchFixesHider$Util.shadowLoadClass(\n                PatchFixesShadowLoaded.class.getName());\n\n        assertThat(shadowedClass).isEqualTo(PatchFixesShadowLoaded.class);\n\n        Method methodWithTypes = PatchFixesHider$Util.findMethod(\n                shadowedClass,\n                \"addLombokNotesToEclipseAboutDialog\",\n                String.class,\n                String.class);\n        Method methodWithTypeNames = PatchFixesHider$Util.findMethod(\n                shadowedClass,\n                \"addLombokNotesToEclipseAboutDialog\",\n                String.class.getName(),\n                String.class.getName());\n        Method methodWithAnyArguments = PatchFixesHider$Util.findMethodAnyArgs(\n                shadowedClass,\n                \"addLombokNotesToEclipseAboutDialog\");\n\n        assertThat(methodWithTypeNames).isEqualTo(methodWithTypes);\n        assertThat(methodWithAnyArguments).isEqualTo(methodWithTypes);\n\n        String notes = (String) PatchFixesHider$Util.invokeMethod(\n                methodWithTypes,\n                \"Lombok is active.\",\n                \"aboutText\");\n\n        assertThat(notes)\n                .startsWith(\"Lombok is active.\")\n                .contains(\" is installed. https://projectlombok.org/\");\n    }\n}\n"}}], "api": "openai-codex-responses", "provider": "openai-codex", "model": "gpt-5.6-terra", "usage": {"input": 1283, "output": 1118, "cacheRead": 59392, "cacheWrite": 0, "totalTokens": 61793, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1783333897900, "responseId": "resp_0937a963dedf3425016a4b840a644481918b4ec24af3179210"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_yYJU66j70GSUFTqHmGz6KGPk|fc_0937a963dedf3425016a4b8416cca88191a30784c8792910eb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1850 bytes to tests/src/org.projectlombok/lombok/1.18.38/src/test/java/org_projectlombok/lombok/PatchFixesHiderInnerUtilTest.java"}], "isError": false, "timestamp": 1783333920208}]}
