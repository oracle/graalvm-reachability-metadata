t\t\t\tinstrumentation.removeTransformer(this);\n\t\t\t\t\t\t\t\tbreak;\n\t\t\t\t\t\t\t} catch (Exception e) {\n\t\t\t\t\t\t\t\t// There are no appropriate loggers available at\n\t\t\t\t\t\t\t\t// this point in time.\n\t\t\t\t\t\t\t\te.printStackTrace(System.err);\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\treturn NOT_TRANSFORMED;\n\t\t\t}\n\t\t});\n\t}\n}\n"}], "isError": false, "timestamp": 1783334752479}}
