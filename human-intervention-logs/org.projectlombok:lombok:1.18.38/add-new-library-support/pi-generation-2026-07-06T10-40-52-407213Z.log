  package org_projectlombok.lombok;
  
  import java.lang.reflect.Method;
  
  import lombok.eclipse.agent.PatchFixesShadowLoaded;
  import lombok.launch.PatchFixesHider$Util;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PatchFixesHiderInnerUtilTest {
      @Test
      void resolvesAndInvokesShadowLoadedMethod() {
          Class<?> shadowLoadedClass = PatchFixesHider$Util.shadowLoadClass(
                  PatchFixesShadowLoaded.class.getName());
  
          assertThat(shadowLoadedClass).isEqualTo(PatchFixesShadowLoaded.class);
  
          Method method = PatchFixesHider$Util.findMethod(
                  shadowLoadedClass,
                  "addLombokNotesToEclipseAboutDialog",
                  String.class,
                  String.class);
          Method methodByTypeName = PatchFixesHider$Util.findMethod(
                  shadowLoadedClass,
                  "addLombokNotesToEclipseAboutDialog",
                  String.class.getName(),
                  String.class.getName());
          Method methodWithAnyArguments = PatchFixesHider$Util.findMethodAnyArgs(
                  shadowLoadedClass,
                  "addLombokNotesToEclipseAboutDialog");
  
          assertThat(methodByTypeName).isEqualTo(method);
          assertThat(methodWithAnyArguments).isEqualTo(method);
  
          String result = (String) PatchFixesHider$Util.invokeMethod(method, "Lombok", "aboutText");
  
          assertThat(result)
                  .startsWith("Lombok")
                  .contains(" is installed. https://projectlombok.org/");
      }
  }
