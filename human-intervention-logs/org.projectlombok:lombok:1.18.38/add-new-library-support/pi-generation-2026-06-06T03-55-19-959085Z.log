  package org_projectlombok.lombok;
  
  import java.lang.reflect.Method;
  import org.eclipse.jdt.internal.compiler.parser.Parser;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PatchFixesHiderInnerUtilTest {
      private static final String PATCH_FIXES_HIDER = "lombok.launch.PatchFixesHider";
  
      @Test
      void lombokDepsBridgeLoadsAndInvokesShadowLoadedMethod() throws Exception {
          Method addNotes = patchMethod(
                  "LombokDeps",
                  "addLombokNotesToEclipseAboutDialog",
                  String.class,
                  String.class);
  
          Object result = addNotes.invoke(null, "Eclipse IDE", "aboutText");
  
          assertThat(result).isInstanceOf(String.class);
          assertThat((String) result)
                  .contains("Eclipse IDE")
                  .contains("Lombok")
                  .contains("https://projectlombok.org");
      }
  
      @Test
      void valBridgeFindsEcjMethodsByNameAndParameterTypeNames() throws Exception {
          Method handleVal = patchMethod("Val", "handleValForLocalDeclaration", Object.class, Object.class);
  
          Object result = handleVal.invoke(null, null, null);
  
          assertThat(result).isEqualTo(false);
      }
  
      @Test
      void transformBridgeFindsShadowLoadedMethodsWithAnyArguments() throws Exception {
          String previousDisable = System.getProperty("lombok.disable");
          System.setProperty("lombok.disable", "true");
          try {
              Method transform = patchMethod("Transform", "transform", Object.class, Object.class);
  
              transform.invoke(null, new Parser(), null);
          } finally {
              if (previousDisable == null) {
                  System.clearProperty("lombok.disable");
              } else {
                  System.setProperty("lombok.disable", previousDisable);
              }
          }
      }
  
      private static Method patchMethod(String innerClassName, String methodName, Class<?>... parameterTypes)
              throws Exception {
          Class<?> type = Class.forName(PATCH_FIXES_HIDER + "$" + innerClassName);
          Method method = type.getDeclaredMethod(methodName, parameterTypes);
          method.setAccessible(true);
          return method;
      }
  }
