  package org_projectlombok.lombok;
  
  import java.io.IOException;
  import java.io.StringWriter;
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.net.URI;
  import java.net.URL;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collections;
  import java.util.List;
  import java.util.Locale;
  import javax.tools.Diagnostic;
  import javax.tools.DiagnosticCollector;
  import javax.tools.JavaCompiler;
  import javax.tools.JavaFileObject;
  import javax.tools.SimpleJavaFileObject;
  import javax.tools.StandardJavaFileManager;
  import javax.tools.ToolProvider;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ShadowClassLoaderTest {
      private static final String SHADOW_CLASS_LOADER = "lombok.launch.ShadowClassLoader";
      private static final String PROCESSOR = "lombok.launch.AnnotationProcessorHider$AnnotationProcessor";
  
      @Test
      void javacAnnotationProcessingLoadsLombokThroughShadowClassLoader() throws IOException {
          JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();
          assertThat(compiler).isNotNull();
  
          DiagnosticCollector<JavaFileObject> diagnostics = new DiagnosticCollector<>();
          try (StandardJavaFileManager fileManager = compiler.getStandardFileManager(
                  diagnostics, Locale.ROOT, null)) {
              Path outputDirectory = Files.createTempDirectory("lombok-shadow-classes");
              JavaFileObject source = new SourceFile("example.Person", """
                      package example;
  
                      import lombok.Getter;
  
                      final class Person {
                          @Getter
                          private final String name = "Ada";
                      }
                      """);
              List<String> options = List.of(
                      "-proc:only",
                      "-classpath", System.getProperty("java.class.path", ""),
                      "-processor", PROCESSOR,
                      "-d", outputDirectory.toString());
  
              StringWriter compilerOutput = new StringWriter();
              Boolean successful = compiler.getTask(
                      compilerOutput, fileManager, diagnostics, options, null, List.of(source)).call();
  
              assertThat(successful).as(diagnosticText(diagnostics, compilerOutput)).isTrue();
          }
      }
  
      @Test
      void parentResourcesAndClassesAreResolvedThroughShadowClassLoader() throws Exception {
          ClassLoader shadowLoader = newShadowClassLoader(null);
  
          assertThat(shadowLoader.loadClass("java.lang.String")).isSameAs(String.class);
          assertThat(shadowLoader.getResource("java/lang/String.class")).isNotNull();
          assertThat(Collections.list(shadowLoader.getResources("lombok/launch/Main.class"))).isNotEmpty();
      }
  
      @Test
      void overrideModeSkipsResourcesFromTheShadowLoaderItself() throws Exception {
          Path emptyOverride = Files.createTempDirectory("lombok-empty-shadow-override");
          ClassLoader shadowLoader = newShadowClassLoader(emptyOverride);
  
          assertThat(shadowLoader.getResource("java/lang/String.class")).isNotNull();
          assertThat(shadowLoader.getResource("lombok/launch/Main.class")).isNull();
          assertThat(Collections.list(shadowLoader.getResources("lombok/launch/Main.class"))).isEmpty();
      }
  
      @Test
      void duplicateDefinitionFallsBackToTheAlreadyLoadedClass() throws Exception {
          ClassLoader shadowLoader = newShadowClassLoader(null);
          Class<?> mainClass = shadowLoader.loadClass("lombok.core.Main");
          URL mainResource = shadowLoader.getResource("lombok/core/Main.class");
          assertThat(mainResource).isNotNull();
  
          Method urlToDefineClass = shadowLoader.getClass().getDeclaredMethod(
                  "urlToDefineClass", String.class, URL.class, boolean.class);
          urlToDefineClass.setAccessible(true);
  
          Object duplicateDefinition = urlToDefineClass.invoke(shadowLoader, "lombok.core.Main", mainResource, false);
  
          assertThat(duplicateDefinition).isSameAs(mainClass);
      }
  
      @Test
      void prependedParentLoaderIsConsultedBeforeTheRegularParent() throws Exception {
          ClassLoader shadowLoader = newShadowClassLoader(null);
          prependParent(shadowLoader, new PrependedOnlyClassLoader());
  
          Class<?> loadedClass = shadowLoader.loadClass(PrependedOnlyClassLoader.CLASS_NAME);
  
          assertThat(loadedClass).isSameAs(PrependedMarker.class);
      }
  
      private static ClassLoader newShadowClassLoader(Path override) throws Exception {
          String previousOverride = System.getProperty("shadow.override.lombok");
          if (override == null) {
              System.clearProperty("shadow.override.lombok");
          } else {
              System.setProperty("shadow.override.lombok", override.toString());
          }
  
          try {
              Class<?> type = Class.forName(SHADOW_CLASS_LOADER);
              Constructor<?> constructor = type.getDeclaredConstructor(
                      ClassLoader.class, String.class, String.class, List.class, List.class);
              constructor.setAccessible(true);
              return (ClassLoader) constructor.newInstance(
                      ShadowClassLoaderTest.class.getClassLoader(),
                      "lombok",
                      null,
                      List.of(),
                      List.of("lombok.patcher.Symbols"));
          } finally {
              if (previousOverride == null) {
                  System.clearProperty("shadow.override.lombok");
              } else {
                  System.setProperty("shadow.override.lombok", previousOverride);
              }
          }
      }
  
      private static void prependParent(ClassLoader shadowLoader, ClassLoader prependedParent) throws Exception {
          Method prependParent = shadowLoader.getClass().getMethod("prependParent", ClassLoader.class);
          prependParent.setAccessible(true);
          prependParent.invoke(shadowLoader, prependedParent);
      }
  
      private static String diagnosticText(DiagnosticCollector<JavaFileObject> diagnostics, StringWriter compilerOutput) {
          StringBuilder text = new StringBuilder(compilerOutput.toString());
          for (Diagnostic<? extends JavaFileObject> diagnostic : diagnostics.getDiagnostics()) {
              text.append(System.lineSeparator()).append(diagnostic);
          }
          return text.toString();
      }
  
      private static final class PrependedOnlyClassLoader extends ClassLoader {
          private static final String CLASS_NAME = "example.OnlyInPrependedParent";
  
          @Override
          public Class<?> loadClass(String name) throws ClassNotFoundException {
              if (CLASS_NAME.equals(name)) {
                  return PrependedMarker.class;
              }
              throw new ClassNotFoundException(name);
          }
      }
  
      private static final class PrependedMarker {
      }
  
      private static final class SourceFile extends SimpleJavaFileObject {
          private final String source;
  
          private SourceFile(String className, String source) {
              super(sourceUri(className), JavaFileObject.Kind.SOURCE);
              this.source = source;
          }
  
          @Override
          public CharSequence getCharContent(boolean ignoreEncodingErrors) {
              return source;
          }
  
          private static URI sourceUri(String className) {
              return URI.create("string:///" + className.replace('.', '/') + JavaFileObject.Kind.SOURCE.extension);
          }
      }
  }
