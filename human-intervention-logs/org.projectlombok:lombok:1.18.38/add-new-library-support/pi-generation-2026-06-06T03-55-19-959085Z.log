  package org_projectlombok.lombok;
  
  import java.lang.reflect.Method;
  import org.eclipse.jdt.internal.compiler.CompilationResult;
  import org.eclipse.jdt.internal.compiler.ast.CompilationUnitDeclaration;
  import org.eclipse.jdt.internal.compiler.parser.Parser;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PatchFixesHiderInnerUtilTest {
      private static final String LOMBOK_DEPS = "lombok.launch.PatchFixesHider$LombokDeps";
      private static final String TRANSFORM = "lombok.launch.PatchFixesHider$Transform";
      private static final String VAL = "lombok.launch.PatchFixesHider$Val";
  
      @Test
      void lombokDepsBridgeLoadsAndInvokesShadowLoadedMethod() throws Exception {
          Method addNotes = Class.forName(LOMBOK_DEPS).getDeclaredMethod(
                  "addLombokNotesToEclipseAboutDialog",
                  String.class,
                  String.class);
          addNotes.setAccessible(true);
  
          Object result = addNotes.invoke(null, "Eclipse IDE", "aboutText");
  
          assertThat(result).isInstanceOf(String.class);
          assertThat((String) result)
                  .contains("Eclipse IDE")
                  .contains("Lombok")
                  .contains("https://projectlombok.org");
      }
  
      @Test
      void valBridgeFindsEcjMethodsByNameAndParameterTypeNames() throws Exception {
          Method handleVal = Class.forName(VAL).getDeclaredMethod(
                  "handleValForLocalDeclaration",
                  Object.class,
                  Object.class);
          handleVal.setAccessible(true);
  
          Object result = handleVal.invoke(null, null, null);
  
          assertThat(result).isEqualTo(false);
      }
  
      @Test
      void transformBridgeFindsShadowLoadedMethodsWithAnyArguments() throws Exception {
          String previousDisable = System.getProperty("lombok.disable");
          System.setProperty("lombok.disable", "true");
          try {
              Method transform = Class.forName(TRANSFORM).getDeclaredMethod(
                      "transform",
                      Object.class,
                      Object.class);
              transform.setAccessible(true);
  
              CompilationResult result = new CompilationResult(
                      "Example.java".toCharArray(),
                      0,
                      1,
                      0);
              CompilationUnitDeclaration unit = new CompilationUnitDeclaration(null, result, 0);
  
              transform.invoke(null, new Parser(), unit);
          } finally {
              if (previousDisable == null) {
                  System.clearProperty("lombok.disable");
              } else {
                  System.setProperty("lombok.disable", previousDisable);
              }
          }
      }
  
  }
