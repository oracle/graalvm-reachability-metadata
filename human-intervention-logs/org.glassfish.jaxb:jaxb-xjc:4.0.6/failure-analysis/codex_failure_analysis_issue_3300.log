acade.main(new String[] {\\\"-version\\\"});\\n            } catch (Throwable failure) {\\n                thrown = failure;\\n            }\\n\\n            assertThat(thrown)\\n                    .as(\\\"Driver.main should be reflectively invoked, then stopped before it can terminate the test VM\\\")\\n                    .isInstanceOfAny(VersionMessagePrintedException.class, ExitException.class);\\n            if (thrown instanceof VersionMessagePrintedException) {\\n                assertThat(thrown.getMessage()).isNotBlank();\\n            } else {\\n                assertThat(((ExitException) thrown).status()).isEqualTo(-1);\\n            }\\n        } finally {\\n            System.setOut(originalOut);\\n            if (securityManagerInstalled) {\\n                System.setSecurityManager(originalSecurityManager);\\n            }\\n            restoreProperty(DRIVER_NO_THREAD_SWAP_PROPERTY, originalNoThreadSwapProperty);\\n            restoreProperty(SYSTEM_PROXY_PROPERTY, originalSystemProxyProperty);\\n            throwingOut.close();\\n        }\\n    }\\n\\n    @Test\\n    void mainInvokeReturnsWhenLoadedDriverMainReturns() throws Exception {\\n        ReturningDriver.lastArgs = null;\\n        try {\\n            ClassLoader loader = new XjcFacadeIsolatingClassLoader(XJCFacade.class.getClassLoader());\\n            Class<?> facadeClass = loader.loadClass(\\\"com.sun.tools.xjc.XJCFacade\\\");\\n            Method main = facadeClass.getMethod(\\\"main\\\", String[].class);\\n\\n            main.invoke(null, (Object) new String[] {\\\"-source\\\", \\\"3.0\\\"});\\n\\n            assertThat(ReturningDriver.lastArgs).containsExactly(\\\"-source\\\", \\\"3.0\\\");\\n        } catch (InvocationTargetException exception) {\\n            Throwable cause = exception.getCause();\\n            if (cause instanceof Error error) {\\n                rethrowIfNotNativeImageDynamicClassLoadingError(error);\\n                return;\\n            }\\n            throw exception;\\n        } catch (Error error) {\\n            rethrowIfNotNativeImageDynamicClassLoadingError(error);\\n        }\\n    }\\n\\n    @SuppressWarnings(\\\"removal\\\")\\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\\n        try {\\n            System.setSecurityManager(securityManager);\\n            return System.getSecurityManager() == securityManager;\\n        } catch (UnsupportedOperationException | SecurityException unsupported) {\\n            return false;\\n        }\\n    }\\n\\n    private static void restoreProperty(String propertyName, String originalValue) {\\n        if (originalValue == null) {\\n            System.clearProperty(propertyName);\\n        } else {\\n            System.setProperty(propertyName, originalValue);\\n        }\\n    }\\n\\n    private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {\\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n            throw error;\\n        }\\n    }\\n\\n    public static final class ReturningDriver {\\n        private static String[] lastArgs;\\n\\n        private ReturningDriver() {\\n        }\\n\\n        public static void main(String[] args) {\\n            lastArgs = args.clone();\\n        }\\n    }\\n\\n    private static final class XjcFacadeIsolatingClassLoader extends ClassLoader {\\n        private static final String DRIVER_CLASS_NAME = \\\"com.sun.tools.xjc.Driver\\\";\\n        private static final String FACADE_CLASS_NAME = \\\"com.sun.tools.xjc.XJCFacade\\\";\\n        private static final String SECURE_LOADER_CLASS_NAME = \\\"com.sun.tools.xjc.SecureLoader\\\";\\n\\n        private XjcFacadeIsolatingClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n\\n        @Override\\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\\n            synchronized (getClassLoadingLock(name)) {\\n                Class<?> loadedClass = findLoadedClass(name);\\n                if (loadedClass == null) {\\n                    loadedClass = loadUncachedClass(name);\\n                }\\n                if (resolve) {\\n                    resolveClass(loadedClass);\\n                }\\n                return loadedClass;\\n            }\\n        }\\n\\n        private Class<?> loadUncachedClass(String name) throws ClassNotFoundException {\\n            if (DRIVER_CLASS_NAME.equals(name)) {\\n                return ReturningDriver.class;\\n            }\\n            if (FACADE_CLASS_NAME.equals(name) || SECURE_LOADER_CLASS_NAME.equals(name)) {\\n                return defineOriginalXjcClass(name);\\n            }\\n            return super.loadClass(name, false);\\n        }\\n\\n        private Class<?> defineOriginalXjcClass(String name) throws ClassNotFoundException {\\n            String resourceName = name.replace('.', '/') + \\\".class\\\";\\n            try (InputStream input = getParent().getResourceAsStream(resourceName)) {\\n                if (input == null) {\\n                    throw new ClassNotFoundException(name + \\\" resource is not available\\\");\\n                }\\n                byte[] classBytes = input.readAllBytes();\\n                return defineClass(name, classBytes, 0, classBytes.length);\\n            } catch (IOException exception) {\\n                throw new ClassNotFoundException(name, exception);\\n            }\\n        }\\n    }\\n\\n    private static final class VersionMessagePrintStream extends PrintStream {\\n        private VersionMessagePrintStream() {\\n            super(OutputStream.nullOutputStream(), true, StandardCharsets.UTF_8);\\n        }\\n\\n        @Override\\n        public void print(String value) {\\n            throw new VersionMessagePrintedException(value);\\n        }\\n\\n        @Override\\n        public void println() {\\n            throw new VersionMessagePrintedException(\\\"\\\");\\n        }\\n\\n    