  public class XJCFacadeTest {
      private static final String DRIVER_NO_THREAD_SWAP_PROPERTY = "com.sun.tools.xjc.Driver.noThreadSwap";
      private static final String SYSTEM_PROXY_PROPERTY = "java.net.useSystemProxies";
  
      @Test
      @SuppressWarnings("removal")
      void mainLoadsDriverAndInvokesItsMainMethod() throws Throwable {
          PrintStream originalOut = System.out;
          SecurityManager originalSecurityManager = System.getSecurityManager();
          String originalNoThreadSwapProperty = System.getProperty(DRIVER_NO_THREAD_SWAP_PROPERTY);
          String originalSystemProxyProperty = System.getProperty(SYSTEM_PROXY_PROPERTY);
          VersionMessagePrintStream throwingOut = new VersionMessagePrintStream();
          boolean securityManagerInstalled = installSecurityManagerIfSupported(new ExitCatchingSecurityManager());
          try {
              System.setOut(throwingOut);
              System.setProperty(DRIVER_NO_THREAD_SWAP_PROPERTY, "true");
  
              Throwable thrown = null;
              try {
                  XJCFacade.main(new String[] {"-version"});
              } catch (Throwable failure) {
                  thrown = failure;
              }
  
              assertThat(thrown)
                      .as("Driver.main should be reflectively invoked, then stopped before it can terminate the test VM")
                      .isInstanceOfAny(VersionMessagePrintedException.class, ExitException.class);
              if (thrown instanceof VersionMessagePrintedException) {
                  assertThat(thrown.getMessage()).isNotBlank();
              } else {
                  assertThat(((ExitException) thrown).status()).isEqualTo(-1);
              }
          } finally {
              System.setOut(originalOut);
              if (securityManagerInstalled) {
                  System.setSecurityManager(originalSecurityManager);
              }
              restoreProperty(DRIVER_NO_THREAD_SWAP_PROPERTY, originalNoThreadSwapProperty);
              restoreProperty(SYSTEM_PROXY_PROPERTY, originalSystemProxyProperty);
              throwingOut.close();
          }
      }
  
      @Test
      void mainInvokeReturnsWhenLoadedDriverMainReturns() throws Exception {
          ReturningDriver.lastArgs = null;
          try {
              ClassLoader loader = new XjcFacadeIsolatingClassLoader(XJCFacade.class.getClassLoader());
              Class<?> facadeClass = loader.loadClass("com.sun.tools.xjc.XJCFacade");
              Method main = facadeClass.getMethod("main", String[].class);
  
              main.invoke(null, (Object) new String[] {"-source", "3.0"});
  
              assertThat(ReturningDriver.lastArgs).containsExactly("-source", "3.0");
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause();
              if (cause instanceof Error error) {
                  rethrowIfNotNativeImageDynamicClassLoadingError(error);
                  return;
              }
              throw exception;
          } catch (Error error) {
              rethrowIfNotNativeImageDynamicClassLoadingError(error);
          }
      }
  
      @SuppressWarnings("removal")
      private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException unsupported) {
              return false;
          }
      }
  
      private static void restoreProperty(String propertyName, String originalValue) {
          if (originalValue == null) {
              System.clearProperty(propertyName);
          } else {
              System.setProperty(propertyName, originalValue);
          }
      }
  
      private static void rethrowIfNotNativeImageDynamicClassLoadingError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      public static final class ReturningDriver {
          private static String[] lastArgs;
  
          private ReturningDriver() {
          }
  
          public static void main(String[] args) {
              lastArgs = args.clone();
          }
      }
  
      private static final class XjcFacadeIsolatingClassLoader extends ClassLoader {
          private static final String DRIVER_CLASS_NAME = "com.sun.tools.xjc.Driver";
          private static final String FACADE_CLASS_NAME = "com.sun.tools.xjc.XJCFacade";
          private static final String SECURE_LOADER_CLASS_NAME = "com.sun.tools.xjc.SecureLoader";
  
          private XjcFacadeIsolatingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              synchronized (getClassLoadingLock(name)) {
                  Class<?> loadedClass = findLoadedClass(name);
                  if (loadedClass == null) {
                      loadedClass = loadUncachedClass(name);
                  }
                  if (resolve) {
                      resolveClass(loadedClass);
                  }
                  return loadedClass;
              }
          }
  
          private Class<?> loadUncachedClass(String name) throws ClassNotFoundException {
              if (DRIVER_CLASS_NAME.equals(name)) {
                  return ReturningDriver.class;
              }
              if (FACADE_CLASS_NAME.equals(name) || SECURE_LOADER_CLASS_NAME.equals(name)) {
                  return defineOriginalXjcClass(name);
              }
              return super.loadClass(name, false);
          }
  
          private Class<?> defineOriginalXjcClass(String name) throws ClassNotFoundException {
              String resourceName = name.replace('.', '/') + ".class";
              try (InputStream input = getParent().getResourceAsStream(resourceName)) {
                  if (input == null) {
                      throw new ClassNotFoundException(name + " resource is not available");
                  }
                  byte[] classBytes = input.readAllBytes();
                  return defineClass(name, classBytes, 0, classBytes.length);
              } catch (IOException exception) {
                  throw new ClassNotFoundException(name, exception);
              }
          }
      }
  
      private static final class VersionMessagePrintStream extends PrintStream {
          private VersionMessagePrintStream() {
              super(OutputStream.nullOutputStream(), true, StandardCharsets.UTF_8);
          }
  
          @Override
          public void print(String value) {
              throw new VersionMessagePrintedException(value);
          }
  
          @Override
          public void println() {
              throw new VersionMessagePrintedException("");
          }
  
          @Override
          public void println(String value) {
              throw new VersionMessagePrintedException(value);
          }
  
          @Override
          public void println(Object value) {
              throw new VersionMessagePrintedException(String.valueOf(value));
          }
  
          @Override
          public void write(byte[] buffer, int offset, int length) {
              String message = new String(buffer, offset, length, StandardCharsets.UTF_8);
              throw new VersionMessagePrintedException(message);
          }
      }
  
      @SuppressWarnings("removal")
      private static final class ExitCatchingSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
          }
  
          @Override
          public void checkExit(int status) {
              throw new ExitException(status);
          }
      }
  
      private static final class ExitException extends SecurityException {
          private static final long serialVersionUID = 1L;
  
          private final int status;
  
          private ExitException(int status) {
              super("Intercepted System.exit(" + status + ")");
              this.status = status;
          }
  
          private int status() {
              return status;
          }
      }
  
      private static final class VersionMessagePrintedException extends RuntimeException {
          private static final long serialVersionUID = 1L;
  
          private VersionMessagePrintedException(String message) {
              super(message);
          }
      }
