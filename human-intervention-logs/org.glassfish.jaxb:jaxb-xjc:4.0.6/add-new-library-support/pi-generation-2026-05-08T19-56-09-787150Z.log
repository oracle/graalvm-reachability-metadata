PfOIY5DmgZw8D8mroevDRQ|fc_0b18d20b683614f20169fe41a2b23481a39d2e79a568117a3f", "toolName": "bash", "content": [{"type": "text", "text": "diff --git i/tests/src/org.glassfish.jaxb/jaxb-xjc/4.0.6/src/test/java/org_glassfish_jaxb/jaxb_xjc/XJCFacadeTest.java w/tests/src/org.glassfish.jaxb/jaxb-xjc/4.0.6/src/test/java/org_glassfish_jaxb/jaxb_xjc/XJCFacadeTest.java\nindex 63dcdd81ea..3aa9ad2fac 100644\n--- i/tests/src/org.glassfish.jaxb/jaxb-xjc/4.0.6/src/test/java/org_glassfish_jaxb/jaxb_xjc/XJCFacadeTest.java\n+++ w/tests/src/org.glassfish.jaxb/jaxb-xjc/4.0.6/src/test/java/org_glassfish_jaxb/jaxb_xjc/XJCFacadeTest.java\n@@ -7,38 +7,97 @@\n package org_glassfish_jaxb.jaxb_xjc;\n \n import static org.assertj.core.api.Assertions.assertThat;\n-import static org.assertj.core.api.Assertions.fail;\n \n+import java.io.IOException;\n+import java.io.InputStream;\n import java.io.OutputStream;\n import java.io.PrintStream;\n+import java.lang.reflect.InvocationTargetException;\n+import java.lang.reflect.Method;\n import java.nio.charset.StandardCharsets;\n+import java.security.Permission;\n \n import com.sun.tools.xjc.XJCFacade;\n \n+import org.graalvm.internal.tck.NativeImageSupport;\n import org.junit.jupiter.api.Test;\n \n public class XJCFacadeTest {\n+    private static final String DRIVER_NO_THREAD_SWAP_PROPERTY = \"com.sun.tools.xjc.Driver.noThreadSwap\";\n     private static final String SYSTEM_PROXY_PROPERTY = \"java.net.useSystemProxies\";\n \n     @Test\n+    @SuppressWarnings(\"removal\")\n     void mainLoadsDriverAndInvokesItsMainMethod() throws Throwable {\n         PrintStream originalOut = System.out;\n+        SecurityManager originalSecurityManager = System.getSecurityManager();\n+        String originalNoThreadSwapProperty = System.getProperty(DRIVER_NO_THREAD_SWAP_PROPERTY);\n         String originalSystemProxyProperty = System.getProperty(SYSTEM_PROXY_PROPERTY);\n         VersionMessagePrintStream throwingOut = new VersionMessagePrintStream();\n+        boolean securityManagerInstalled = installSecurityManagerIfSupported(new ExitCatchingSecurityManager());\n         try {\n             System.setOut(throwingOut);\n+            System.setProperty(DRIVER_NO_THREAD_SWAP_PROPERTY, \"true\");\n \n-            XJCFacade.main(new String[] {\"-version\"});\n-            fail(\"Expected the version message print stream to abort before Driver.main exits the VM\");\n-        } catch (VersionMessagePrintedException expected) {\n-            assertThat(expected.getMessage()).isNotBlank();\n+            Throwable thrown = null;\n+            try {\n+                XJCFacade.main(new String[] {\"-version\"});\n+            } catch (Throwable failure) {\n+                thrown = failure;\n+            }\n+\n+            assertThat(thrown)\n+                    .as(\"Driver.main should be reflectively invoked, then stopped before it can terminate the test VM\")\n+                    .isInstanceOfAny(VersionMessagePrintedException.class, ExitException.class);\n+            if (thrown instanceof VersionMessagePrintedException) {\n+                assertThat(thrown.getMessage()).isNotBlank();\n+            } else {\n+                assertThat(((ExitException) thrown).status()).isEqualTo(-1);\n+            }\n         } finally {\n             System.setOut(originalOut);\n+            if (securityManagerInstalled) {\n+                System.setSecurityManager(originalSecurityManager);\n+            }\n+            restoreProperty(DRIVER_NO_THREAD_SWAP_PROPERTY, originalNoThreadSwapProperty);\n             restoreProperty(SYSTEM_PROXY_PROPERTY, originalSystemProxyProperty);\n             throwingOut.close();\n         }\n     }\n \n+    @Test\n+    void mainInvokeReturnsWhenLoadedDriverMainReturns() throws Exception {\n+        ReturningDriver.lastArgs = null;\n+        try {\n+            ClassLoader loader = new XjcFacadeIsolatingClassLoader(XJCFacade.class.getClassLoader());\n+            Class<?> facadeClass = loader.loadClass(\"com.sun