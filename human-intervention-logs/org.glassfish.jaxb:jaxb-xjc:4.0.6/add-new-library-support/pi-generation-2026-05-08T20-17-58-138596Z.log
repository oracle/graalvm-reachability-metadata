[tool-call] delta {"path":"tests/src/org.glassfish.jaxb/jaxb-xjc/4.0.6/src/test/java/org_glassfish_jaxb/jaxb_xjc/JAXBContextFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jaxb.jaxb_xjc;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Map;\n\nimport com.sun.tools.xjc.runtime.JAXBContextFactory;\n\nimport jakarta.xml.bind.JAXBContext;\nimport jakarta.xml.bind.JAXBException;\n\nimport org.junit.jupiter.api.Test;\n\nimport org_glassfish_jaxb.jaxb_xjc.jaxb_context_factory_model.ObjectFactory;\n\npublic class JAXBContextFactoryTest {\n    private static final Class<?> IMPLEMENTATION_OBJECT_FACTORY =\n            org_glassfish_jaxb.jaxb_xjc.jaxb_context_factory_model.impl.ObjectFactory.class;\n\n    @Test\n    void createContextWithClassesLoadsImplementationObjectFactory() throws JAXBException {\n        JAXBContext context = JAXBContextFactory.createContext(new Class<?>[] {ObjectFactory.class}, Map.of());\n\n        assertThat(context).isNotNull();\n        assertThat(IMPLEMENTATION_OBJECT_FACTORY.getName()).endsWith(\".impl.ObjectFactory\");\n    }\n\n    @Test\n    void createContextWithContextPathLoadsImplementationObjectFactory() throws JAXBException {\n        JAXBContext context = JAXBContextFactory.createContext(\n                ObjectFactory.class.getPackageName(), ObjectFactory.class.getClassLoader(), Map.of());\n\n        assertThat(context).isNotNull();\n        assertThat(IMPLEMENTATION_OBJECT_FACTORY.getName()).endsWith(\".impl.ObjectFactory\");\n    }\n}\n"}
