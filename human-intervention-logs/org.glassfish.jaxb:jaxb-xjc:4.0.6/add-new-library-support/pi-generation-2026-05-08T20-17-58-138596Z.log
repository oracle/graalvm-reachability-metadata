  package org_glassfish_jaxb.jaxb_xjc;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import com.sun.tools.xjc.reader.Ring;
  
  import org.junit.jupiter.api.Test;
  
  public class RingTest {
      @Test
      void getCreatesAndCachesComponentWithNoArgumentConstructor() {
          Ring previousRing = Ring.begin();
          try {
              RingConstructedComponent component = Ring.get(RingConstructedComponent.class);
              RingConstructedComponent cachedComponent = Ring.get(RingConstructedComponent.class);
  
              assertThat(component).isNotNull();
              assertThat(component.createdByConstructor()).isTrue();
              assertThat(cachedComponent).isSameAs(component);
          } finally {
              Ring.end(previousRing);
          }
      }
  
      public static final class RingConstructedComponent {
          private final boolean createdByConstructor;
  
          private RingConstructedComponent() {
              createdByConstructor = true;
          }
  
          private boolean createdByConstructor() {
              return createdByConstructor;
          }
      }
  }
