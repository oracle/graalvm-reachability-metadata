              InputStream is = clazz.getResourceAsStream(systemId);
              streamsToClose.add(is);
              return new Input(is, publicId, systemId);
          }
  
          void closeStreams() {
              for (InputStream is : streamsToClose) {
                  if (is != null) {
                      try {
                          is.close();
                      } catch (IOException e) {
                          // nothing to do ...
                      }
                  }
              }
