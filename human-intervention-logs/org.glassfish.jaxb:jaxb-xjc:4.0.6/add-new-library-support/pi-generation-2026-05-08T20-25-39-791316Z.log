[tool-call] delta {"path":"tests/src/org.glassfish.jaxb/jaxb-xjc/4.0.6/src/test/java/org_glassfish_jaxb/jaxb_xjc/SchemaCacheTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_glassfish_jaxb.jaxb_xjc;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport javax.xml.validation.ValidatorHandler;\n\nimport com.sun.tools.xjc.SchemaCache;\nimport com.sun.tools.xjc.reader.xmlschema.bindinfo.BindInfo;\n\nimport org.junit.jupiter.api.Test;\n\npublic class SchemaCacheTest {\n    @Test\n    void newValidatorLoadsSchemaFromClassResource() {\n        SchemaCache cache = new SchemaCache(\"binding.xsd\", BindInfo.class, true);\n\n        ValidatorHandler firstValidator = cache.newValidator();\n        ValidatorHandler secondValidator = cache.newValidator();\n\n        assertThat(firstValidator).isNotNull();\n        assertThat(secondValidator).isNotNull();\n        assertThat(secondValidator).isNotSameAs(firstValidator);\n    }\n}\n"}
