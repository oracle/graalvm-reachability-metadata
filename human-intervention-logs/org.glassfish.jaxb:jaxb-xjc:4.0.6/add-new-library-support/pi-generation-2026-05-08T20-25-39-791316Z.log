  package org_glassfish_jaxb.jaxb_xjc;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatExceptionOfType;
  
  import java.util.Map;
  
  import com.sun.tools.xjc.runtime.JAXBContextFactory;
  
  import jakarta.xml.bind.JAXBException;
  
  import org.junit.jupiter.api.Test;
  
  public class JAXBContextFactoryTest {
      private static final String UNSUPPORTED_PROPERTY_NAME = "org.example.unsupportedJaxbProperty";
      private static final Map<String, Object> UNSUPPORTED_PROPERTIES = Map.of(UNSUPPORTED_PROPERTY_NAME, Boolean.TRUE);
  
      @Test
      void createContextWithClassesLoadsImplementationObjectFactory() {
          assertThat(ImplementationObjectFactoryHolder.TYPE.getName()).isEqualTo(ObjectFactory.class.getPackageName()
                  + ".impl.ObjectFactory");
  
          assertThatExceptionOfType(JAXBException.class)
                  .isThrownBy(() -> JAXBContextFactory.createContext(
                          new Class<?>[] {ObjectFactory.class}, UNSUPPORTED_PROPERTIES))
                  .satisfies(JAXBContextFactoryTest::assertDelegationFailedAfterImplementationObjectFactoryWasLoaded);
      }
  
      @Test
      void createContextWithContextPathLoadsImplementationObjectFactory() {
          assertThat(ImplementationObjectFactoryHolder.TYPE.getName()).isEqualTo(ObjectFactory.class.getPackageName()
                  + ".impl.ObjectFactory");
  
          assertThatExceptionOfType(JAXBException.class)
                  .isThrownBy(() -> JAXBContextFactory.createContext(
                          ObjectFactory.class.getPackageName(),
                          ObjectFactory.class.getClassLoader(),
                          UNSUPPORTED_PROPERTIES))
                  .satisfies(JAXBContextFactoryTest::assertDelegationFailedAfterImplementationObjectFactoryWasLoaded);
      }
  
      private static void assertDelegationFailedAfterImplementationObjectFactoryWasLoaded(JAXBException exception) {
