ntextFactory.createContext(\n                        ObjectFactory.class.getPackageName(),\n                        ObjectFactory.class.getClassLoader(),\n                        UNSUPPORTED_PROPERTIES))\n                .satisfies(JAXBContextFactoryTest::assertDelegationFailedAfterImplementationObjectFactoryWasLoaded);\n    }\n\n    private static void assertDelegationFailedAfterImplementationObjectFactoryWasLoaded(JAXBException exception) {\n        Throwable linkedException = exception.getLinkedException();\n        boolean rejectedUnsupportedProperty = exception.getMessage().contains(UNSUPPORTED_PROPERTY_NAME);\n        boolean missingRuntimeProvider = linkedException instanceof ClassNotFoundException\n                && \"org.glassfish.jaxb.runtime.v2.ContextFactory\".equals(linkedException.getMessage());\n\n        assertThat(rejectedUnsupportedProperty || missingRuntimeProvider)\n                .as(\"JAXBContextFactory should fail only after delegating to the runtime JAXB provider\")\n                .isTrue();\n    }\n\n    private static final class ImplementationObjectFactoryHolder {\n        private static final Class<?> TYPE = org_glassfish_jaxb.jaxb_xjc.impl.ObjectFactory.class;\n\n        private ImplementationObjectFactoryHolder() {\n        }\n    }\n}\n\nfinal class ObjectFactory {\n    private ObjectFactory() {\n    }\n}\n","exit_code":0,"status":"completed"}}
