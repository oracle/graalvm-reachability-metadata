                              new ParsedDynamicAccessCallSite(
                                      reportType,
                                      trackedApi,
                                      rawFrame,
                                      parsedFrame.className(),
                                      parsedFrame.sourceFile(),
                                      parsedFrame.lineNumber(),
                                      covered
                              )
                      );
                  }
              }
          } catch (IOException e) {
              throw new GradleException("Failed to parse dynamic access report " + path, e);
          }
      }
  
