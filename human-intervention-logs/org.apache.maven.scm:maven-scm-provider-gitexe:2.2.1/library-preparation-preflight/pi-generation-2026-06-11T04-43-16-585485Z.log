          if (interactive) {
              // This is the default behavior therefore make sure to remove the variable if it was set before.
              environmentVariables.remove(GIT_TERMINAL_PROMPT);
          } else {
              environmentVariables.put(GIT_TERMINAL_PROMPT, "0");
          }
