s/src/org.apache.maven.scm/maven-scm-provider-gitexe/2.2.1/src/test/java/org_apache_maven_scm/maven_scm_provider_gitexe/GitExeCommandLineConstructionTest.java", "edits": [{"oldText": "import java.util.List;\nimport java.util.Map;", "newText": "import java.util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.concurrent.TimeUnit;"}, {"oldText": "import org.apache.maven.scm.ScmException;\nimport org.apache.maven.scm.ScmFileSet;\nimport org.apache.maven.scm.ScmTag;", "newText": "import org.apache.maven.scm.ScmException;\nimport org.apache.maven.scm.ScmFileSet;\nimport org.apache.maven.scm.ScmResult;\nimport org.apache.maven.scm.ScmTag;\nimport org.apache.maven.scm.ScmTagParameters;"}, {"oldText": "        Commandline tagCommandLine = GitTagCommand.createCommandLine(\n                repository, workingDirectory, \"v1.1.0\", messagePath.toFile(), SignOption.DEFAULT);\n        assertThat(tagCommandLine.getArguments())\n                .containsExactly(\"tag\", \"-F\", messagePath.toAbsolutePath().toString(), \"v1.1.0\");\n\n        Commandline signedTagCommandLine = GitTagCommand.createCommandLine(\n                repository, workingDirectory, \"v1.1.0\", messagePath.toFile(), SignOption.FORCE_SIGN);\n        assertThat(signedTagCommandLine.getArguments())\n                .containsExactly(\"tag\", \"-s\", \"-F\", messagePath.toAbsolutePath().toString(), \"v1.1.0\");", "newText": "        initializeGitRepository(workingDirectory, trackedPath);\n        repository.setPushChanges(false);\n        ScmTagParameters tagParameters = new ScmTagParameters(\"message\\n\");\n        tagParameters.setSignOption(SignOption.FORCE_NO_SIGN);\n        ScmResult tagResult = new GitTagCommand(Map.of())\n                .executeTagCommand(repository, new ScmFileSet(workingDirectory), \"v1.1.0\", tagParameters);\n        assertThat(tagResult.isSuccess()).isTrue();\n        assertThat(runGit(workingDirectory, \"tag\", \"--list\", \"v1.1.0\").trim()).isEqualTo(\"v1