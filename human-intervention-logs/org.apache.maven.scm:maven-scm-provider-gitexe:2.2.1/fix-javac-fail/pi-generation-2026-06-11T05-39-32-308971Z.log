      ProcessBuilder processBuilder = new ProcessBuilder();\n        processBuilder.command(buildGitCommand(arguments));\n        processBuilder.directory(workingDirectory);\n        processBuilder.redirectErrorStream(true);\n\n        Process process = processBuilder.start();\n        boolean finished = process.waitFor(30, TimeUnit.SECONDS);\n        if (!finished) {\n            process.destroyForcibly();\n            process.waitFor(5, TimeUnit.SECONDS);\n        }\n        String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n\n        assertThat(finished).as(\"git command timed out: %s\", String.join(\" \", buildGitCommand(arguments))).isTrue();\n        assertThat(process.exitValue()).as(\"git command output: %s\", output).isEqualTo(0);\n        return output;\n    }\n\n    private static List<String> buildGitCommand(String... arguments) {\n        List<String> command = new java.util.ArrayList<>();\n        command.add(\"git\");\n        command.addAll(List.of(arguments));\n        return command;\n    }\n\n    private static final class CapturingGitInfoCommand extends GitInfoCommand {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1180, "output": 2288, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 27532, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781156222669, "responseId": "resp_0b06d45179d48d6b016a2a497f24cc81939194ec29f9454442"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_TXgnlSmWBeOBlCl6MePEKnGk|fc_0b06d45179d48d6b016a2a499829d48193b0acb5917e3d681a", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 4 block(s) in tests/src/org.apache.maven.scm/maven-scm-provider-gitexe/2.2.1/src/test/java/org_apache_maven_scm/maven_scm_provider_gitexe/GitExeCommandLineConstructionTest.java."}], "details": {"diff": "     ...\n  11 import java.nio.file.Files;