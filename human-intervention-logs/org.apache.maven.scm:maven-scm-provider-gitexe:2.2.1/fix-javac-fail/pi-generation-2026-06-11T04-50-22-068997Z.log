[tool-call] delta {"path":"tests/src/org.apache.maven.scm/maven-scm-provider-gitexe/2.2.1/src/test/java/org_apache_maven_scm/maven_scm_provider_gitexe/GitExeCommandLineConstructionTest.java","edits":[{"oldText":"import java.util.List;\nimport java.util.Map;","newText":"import java.util.List;\nimport java.util.Map;\nimport java.util.concurrent.TimeUnit;"},{"oldText":"import org.apache.maven.scm.ScmFileSet;\nimport org.apache.maven.scm.ScmTag;","newText":"import org.apache.maven.scm.ScmFileSet;\nimport org.apache.maven.scm.ScmResult;\nimport org.apache.maven.scm.ScmTag;\nimport org.apache.maven.scm.ScmTagParameters;"},{"oldText":"        GitScmProviderRepository repository = new GitScmProviderRepository(\"https://example.invalid/team/project.git\");\n        ScmTag startTag = new ScmTag(\"v1.0.0\");","newText":"        setupLocalGitRepository(workingDirectory, trackedPath);\n\n        GitScmProviderRepository repository = new GitScmProviderRepository(\"https://example.invalid/team/project.git\");\n        repository.setPushChanges(false);\n        ScmTag startTag = new ScmTag(\"v1.0.0\");"},{"oldText":"        Commandline tagCommandLine = GitTagCommand.createCommandLine(\n                repository, workingDirectory, \"v1.1.0\", messagePath.toFile(), SignOption.DEFAULT);\n        assertThat(tagCommandLine.getArguments())\n                .containsExactly(\"tag\", \"-F\", messagePath.toAbsolutePath().toString(), \"v1.1.0\");\n\n        Commandline signedTagCommandLine = GitTagCommand.createCommandLine(\n                repository, workingDirectory, \"v1.1.0\", messagePath.toFile(), SignOption.FORCE_SIGN);\n        assertThat(signedTagCommandLine.getArguments())\n                .containsExactly(\"tag\", \"-s\", \"-F\", messagePath.toAbsolutePath().toString(), \"v1.1.0\");","newText":"        ScmTagParameters tagParameters = new ScmTagParameters(\"release 1.1.0\");\n        tagParameters.setSignOption(SignOption.FORCE_NO_SIGN);\n        ScmResult tagResult = new GitTagCommand(Map.of())\n                .executeTagCommand(repository, new ScmFileSet(workingDirectory), \"v1.1.0\", tagParameters);\n        assertThat(tagResult.isSuccess()).as(tagResult.getProviderMessage()).isTrue();\n        assertThat(runGit(workingDirectory, \"cat-file\", \"-p\", \"v1.1.0\")).contains(\"release 1.1.0\");"},{"oldText":"    private static void assertGitExecutable(Commandline commandLine) {\n        assertThat(commandLine.getExecutable()).isIn(\"git\", \"'git'\");\n    }\n","newText":"    private static void assertGitExecutable(Commandline commandLine) {\n        assertThat(commandLine.getExecutable()).isIn(\"git\", \"'git'\");\n    }\n\n    private static void setupLocalGitRepository(File workingDirectory, Path trackedPath) throws Exception {\n        runGit(workingDirectory, \"init\");\n        runGit(workingDirectory, \"config\", \"user.email\", \"native-tests@example.invalid\");\n        runGit(workingDirectory, \"config\", \"user.name\", \"Native Tests\");\n        runGit(workingDirectory, \"add\", trackedPath.getFileName().toString());\n        runGit(workingDirectory, \"commit\", \"-m\", \"initial\");\n    }\n\n    private static String runGit(File workingDirectory, String... arguments) throws Exception {\n        ProcessBuilder processBuilder = new ProcessBuilder();\n        processBuilder.command(buildGitCommand(arguments));\n        processBuilder.directory(workingDirectory);\n        processBuilder.redirectErrorStream(true);\n        Process process = processBuilder.start();\n        boolean finished = process.waitFor(10, TimeUnit.SECONDS);\n        if (!finished) {\n            process.destroyForcibly();\n            throw new AssertionError(\"Timed out running git \" + String.join(\" \", arguments));\n        }\n        String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n        assertThat(process.exitValue()).as(output).isZero();\n        return output;\n    }\n\n    private static List<String> buildGitCommand(String... arguments) {\n        List<String> command = new java.util.ArrayList<>();\n        command.add(\"git\");\n        command.addAll(List.of(arguments));\n        return command;\n    }\n"}]}
