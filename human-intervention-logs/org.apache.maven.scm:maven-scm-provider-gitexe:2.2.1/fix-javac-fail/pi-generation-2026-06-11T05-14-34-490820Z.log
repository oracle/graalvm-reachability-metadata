[tool-call] delta {"path":"tests/src/org.apache.maven.scm/maven-scm-provider-gitexe/2.2.1/src/test/java/org_apache_maven_scm/maven_scm_provider_gitexe/GitExeCommandLineConstructionTest.java","edits":[{"oldText":"import java.io.File;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.List;\nimport java.util.Map;","newText":"import java.io.File;\nimport java.io.IOException;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.concurrent.TimeUnit;"},{"oldText":"import org.apache.maven.scm.ScmException;\nimport org.apache.maven.scm.ScmFileSet;\nimport org.apache.maven.scm.ScmTag;","newText":"import org.apache.maven.scm.ScmException;\nimport org.apache.maven.scm.ScmFileSet;\nimport org.apache.maven.scm.ScmResult;\nimport org.apache.maven.scm.ScmTag;\nimport org.apache.maven.scm.ScmTagParameters;"},{"oldText":"        GitScmProviderRepository repository = new GitScmProviderRepository(\"https://example.invalid/team/project.git\");\n        ScmTag startTag = new ScmTag(\"v1.0.0\");","newText":"        initializeGitRepository(temporaryDirectory);\n\n        GitScmProviderRepository repository = new GitScmProviderRepository(\"https://example.invalid/team/project.git\");\n        repository.setPushChanges(false);\n        ScmTag startTag = new ScmTag(\"v1.0.0\");"},{"oldText":"        Commandline tagCommandLine = GitTagCommand.createCommandLine(\n                repository, workingDirectory, \"v1.1.0\", messagePath.toFile(), SignOption.FORCE_NO_SIGN);\n        assertThat(tagCommandLine.getArguments())\n                .containsExactly(\"tag\", \"--no-sign\", \"-F\", messagePath.toAbsolutePath().toString(), \"v1.1.0\");\n\n        Commandline signedTagCommandLine = GitTagCommand.createCommandLine(\n                repository, workingDirectory, \"v1.1.0\", messagePath.toFile(), SignOption.FORCE_SIGN);\n        assertThat(signedTagCommandLine.getArguments())\n                .containsExactly(\"tag\", \"-s\", \"-F\", messagePath.toAbsolutePath().toString(), \"v1.1.0\");\n\n        Commandline tagPushCommandLine = new GitTagCommand(Map.of()).createPushCommandLine(","newText":"        ScmTagParameters tagParameters = new ScmTagParameters(\"release message\");\n        tagParameters.setSignOption(SignOption.FORCE_NO_SIGN);\n        ScmResult tagResult = new GitTagCommand(Map.of())\n                .executeTagCommand(repository, new ScmFileSet(workingDirectory), \"v1.1.0\", tagParameters);\n        assertThat(tagResult.isSuccess()).isTrue();\n        assertThat(tagResult.getCommandLine()).contains(\"tag\", \"--no-sign\", \"-F\", \"v1.1.0\");\n\n        Commandline tagPushCommandLine = new GitTagCommand(Map.of()).createPushCommandLine("},{"oldText":"    private static void assertGitExecutable(Commandline commandLine) {\n        assertThat(commandLine.getExecutable()).isIn(\"git\", \"'git'\");\n    }\n\n    private static final class CapturingGitInfoCommand extends GitInfoCommand {","newText":"    private static void assertGitExecutable(Commandline commandLine) {\n        assertThat(commandLine.getExecutable()).isIn(\"git\", \"'git'\");\n    }\n\n    private static void initializeGitRepository(Path workingDirectory) throws IOException, InterruptedException {\n        runGit(workingDirectory, \"init\");\n        runGit(workingDirectory, \"config\", \"user.name\", \"Native Test\");\n        runGit(workingDirectory, \"config\", \"user.email\", \"native-test@example.invalid\");\n        runGit(workingDirectory, \"add\", \"tracked.txt\");\n        runGit(workingDirectory, \"commit\", \"-m\", \"Initial commit\");\n    }\n\n    private static void runGit(Path workingDirectory, String... arguments) throws IOException, InterruptedException {\n        List<String> command = new ArrayList<>();\n        command.add(\"git\");\n        command.addAll(List.of(arguments));\n        Process process = new ProcessBuilder(command)\n                .directory(workingDirectory.toFile())\n                .redirectErrorStream(true)\n                .start();\n        boolean finished = process.waitFor(10, TimeUnit.SECONDS);\n        if (!finished) {\n            process.destroyForcibly();\n            process.waitFor(5, TimeUnit.SECONDS);\n        }\n        String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n        assertThat(finished).as(\"git command timed out: %s\", command).isTrue();\n        assertThat(process.exitValue()).as(output).isZero();\n    }\n\n    private static final class CapturingGitInfoCommand extends GitInfoCommand {"}]}
