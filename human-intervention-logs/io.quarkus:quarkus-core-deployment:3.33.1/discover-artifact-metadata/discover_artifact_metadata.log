                        <phase>${maven-enforcer-plugin.phase}</phase>
                        <goals>
                            <goal>enforce</goal>
                        </goals>
                        <configuration>
                            <!--
                                This artifact contains JUnit dependencies so we need to override the rules
                                to avoid testing it.

                                Also we enforce some additional banned dependencies.
