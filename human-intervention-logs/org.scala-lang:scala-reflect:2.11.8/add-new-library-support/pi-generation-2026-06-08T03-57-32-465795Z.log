[tool-call] delta {"path":"tests/src/org.scala-lang/scala-reflect/2.11.8/src/test/scala/org_scala_lang/scala_reflect/ReflectionUtilsTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_reflect\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertSame\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Test\n\nimport scala.reflect.internal.util.AbstractFileClassLoader\nimport scala.reflect.io.VirtualDirectory\nimport scala.reflect.runtime.ReflectionUtils\n\nclass ReflectionUtilsTest {\n  @Test\n  def loadsTopLevelModuleThroughStaticSingletonLookup(): Unit = {\n    val moduleClassName: String = ReflectionUtilsStaticSingletonFixture.getClass.getName\n    val singleton: AnyRef = ReflectionUtils.staticSingletonInstance(\n      getClass.getClassLoader,\n      moduleClassName.stripSuffix(\"$\"))\n\n    assertSame(ReflectionUtilsStaticSingletonFixture, singleton)\n    assertEquals(\"static-singleton\", singleton.asInstanceOf[ReflectionUtilsStaticSingletonFixture.type].name)\n  }\n\n  @Test\n  def invokesMemberObjectAccessorThroughInnerSingletonLookup(): Unit = {\n    val outer: ReflectionUtilsOuterSingletonFixture = new ReflectionUtilsOuterSingletonFixture(\"outer\")\n    val singleton: AnyRef = ReflectionUtils.innerSingletonInstance(outer, \"NestedSingleton\")\n\n    assertSame(outer.NestedSingleton, singleton)\n    assertEquals(\"outer:nested\", singleton.asInstanceOf[outer.NestedSingleton.type].description)\n  }\n\n  @Test\n  def showsAbstractFileClassLoaderClasspathFromItsRoot(): Unit = {\n    val root: VirtualDirectory = new VirtualDirectory(\"reflection-utils-root\", None)\n    val loader: AbstractFileClassLoader = new AbstractFileClassLoader(root, getClass.getClassLoader)\n\n    val description: String = ReflectionUtils.show(loader)\n\n    assertTrue(description.contains(\"AbstractFileClassLoader\"))\n    assertTrue(description.contains(\"reflection-utils-root\"))\n  }\n}\n\nobject ReflectionUtilsStaticSingletonFixture {\n  val name: String = \"static-singleton\"\n}\n\nclass ReflectionUtilsOuterSingletonFixture(prefix: String) {\n  object NestedSingleton {\n    val description: String = s\"$prefix:nested\"\n  }\n}\n"}
