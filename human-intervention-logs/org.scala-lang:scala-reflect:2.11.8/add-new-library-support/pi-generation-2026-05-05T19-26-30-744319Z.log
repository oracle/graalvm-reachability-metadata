    def lookupNameUnchecked(name: String, directory: Boolean): AbstractFile
  
    /** Return an abstract file that does not check that `path` denotes
     *  an existing file.
     */
    def lookupPathUnchecked(path: String, directory: Boolean): AbstractFile = {
  
