[tool-call] delta {"path":"tests/src/org.scala-lang/scala-reflect/2.11.8/src/test/scala/org_scala_lang/scala_reflect/JavaMirrorsInnerJavaMirrorInnerJavaVanillaMethodMirror2Test.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_reflect\n\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Test\n\nimport scala.reflect.runtime.{universe => ru}\n\nclass JavaMirrorsInnerJavaMirrorInnerJavaVanillaMethodMirror2Test {\n  private val mirror: ru.Mirror = ru.runtimeMirror(getClass.getClassLoader)\n\n  @Test\n  def invokesTwoArgumentMethodThroughVanillaMethodMirror(): Unit = {\n    val instance: JavaVanillaMethodMirror2Fixture = new JavaVanillaMethodMirror2Fixture(\n      \"left\",\n      \"right\")\n    val classSymbol: ru.ClassSymbol = ru.typeOf[JavaVanillaMethodMirror2Fixture]\n      .typeSymbol\n      .asClass\n    val instanceMirror: ru.InstanceMirror = mirror.reflect(instance)\n    val join: ru.MethodSymbol = method(classSymbol, \"join\")\n\n    val result: Any = instanceMirror.reflectMethod(join)(\"alpha\", \"beta\")\n\n    assertEquals(\"left/right:alpha/beta\", result)\n  }\n\n  @Test\n  def invokesTwoArgumentTopLevelConstructorThroughVanillaMethodMirror(): Unit = {\n    val classSymbol: ru.ClassSymbol = mirror.staticClass(\n      \"org_scala_lang.scala_reflect.JavaVanillaMethodMirror2Fixture\")\n    val classMirror: ru.ClassMirror = mirror.reflectClass(classSymbol)\n    val constructor: ru.MethodSymbol = classSymbol.primaryConstructor.asMethod\n\n    val result: JavaVanillaMethodMirror2Fixture = classMirror\n      .reflectConstructor(constructor)(\"top\", \"level\")\n      .asInstanceOf[JavaVanillaMethodMirror2Fixture]\n\n    assertEquals(\"top/level:x/y\", result.join(\"x\", \"y\"))\n  }\n\n  @Test\n  def invokesTwoArgumentInnerConstructorThroughVanillaMethodMirror(): Unit = {\n    val outer: JavaVanillaMethodMirror2OuterFixture =\n      new JavaVanillaMethodMirror2OuterFixture(\"outer\")\n    val outerMirror: ru.InstanceMirror = mirror.reflect(outer)\n    val memberClass: ru.ClassSymbol = ru.typeOf[JavaVanillaMethodMirror2OuterFixture#Member]\n      .typeSymbol\n      .asClass\n    val memberConstructor: ru.MethodSymbol = memberClass.primaryConstructor.asMethod\n\n    val result: outer.Member = outerMirror\n      .reflectClass(memberClass)\n      .reflectConstructor(memberConstructor)(\"inner\", \"member\")\n      .asInstanceOf[outer.Member]\n\n    assertEquals(\"outer:inner/member\", result.summary)\n  }\n\n  private def method(classSymbol: ru.ClassSymbol, name: String): ru.MethodSymbol = {\n    classSymbol.toType.decl(ru.TermName(name)).asMethod\n  }\n}\n\nclass JavaVanillaMethodMirror2Fixture(val first: String, val second: String) {\n  def join(left: String, right: String): String = s\"$first/$second:$left/$right\"\n}\n\nclass JavaVanillaMethodMirror2OuterFixture(prefix: String) {\n  class Member(first: String, second: String) {\n    def summary: String = s\"$prefix:$first/$second\"\n  }\n}\n"}
