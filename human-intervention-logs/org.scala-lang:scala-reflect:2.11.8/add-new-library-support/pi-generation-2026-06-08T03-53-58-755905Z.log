[tool-call] delta {"path":"tests/src/org.scala-lang/scala-reflect/2.11.8/src/test/scala/org_scala_lang/scala_reflect/RichClassLoaderTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_reflect\n\nimport org.junit.jupiter.api.Assertions.assertArrayEquals\nimport org.junit.jupiter.api.Assertions.assertEquals\nimport org.junit.jupiter.api.Assertions.assertNotNull\nimport org.junit.jupiter.api.Assertions.assertTrue\nimport org.junit.jupiter.api.Assertions.fail\nimport org.junit.jupiter.api.Test\n\nimport scala.reflect.internal.util.RichClassLoader\n\nclass RichClassLoaderTest {\n  private val loader: RichClassLoader = new RichClassLoader(getClass.getClassLoader)\n\n  @Test\n  def loadsCreatesAndReadsClassesThroughRichClassLoader(): Unit = {\n    val fixtureClassName: String = classOf[RichClassLoaderNoArgFixture].getName\n    val loadedClass: Option[Class[RichClassLoaderNoArgFixture]] =\n      loader.tryToLoadClass[RichClassLoaderNoArgFixture](fixtureClassName)\n\n    assertTrue(loadedClass.exists(_ == classOf[RichClassLoaderNoArgFixture]))\n\n    val initializedClass: Option[Class[RichClassLoaderNoArgFixture]] =\n      loader.tryToInitializeClass[RichClassLoaderNoArgFixture](fixtureClassName)\n    assertTrue(initializedClass.exists(_ == classOf[RichClassLoaderNoArgFixture]))\n\n    val instance: RichClassLoaderNoArgFixture =\n      loader.create(fixtureClassName).asInstanceOf[RichClassLoaderNoArgFixture]\n    assertEquals(\"created-with-no-args\", instance.message)\n\n    val stream = loader.classAsStream(fixtureClassName)\n    try {\n      assertNotNull(stream)\n    } finally {\n      if (stream != null) {\n        stream.close()\n      }\n    }\n\n    val bytes: Array[Byte] = loader.classBytes(fixtureClassName)\n    assertTrue(bytes.length > 0)\n    assertArrayEqu