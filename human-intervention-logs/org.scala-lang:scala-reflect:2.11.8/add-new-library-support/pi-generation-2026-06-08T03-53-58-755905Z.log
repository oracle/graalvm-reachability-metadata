  package org_scala_lang.scala_reflect
  
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Test
  
  import scala.reflect.runtime.{universe => ru}
  
  class JavaMirrorsInnerJavaMirrorTest {
    private val mirror: ru.Mirror = ru.runtimeMirror(getClass.getClassLoader)
  
    @Test
    def unpicklesScalaSignaturesAndReflectsTopLevelMembers(): Unit = {
      val classSymbol: ru.ClassSymbol = mirror.staticClass(
        "org_scala_lang.scala_reflect.TopLevelReflectFixture")
      val classMirror: ru.ClassMirror = mirror.reflectClass(classSymbol)
      val constructor: ru.MethodSymbol = classSymbol.primaryConstructor.asMethod
      val instance: TopLevelReflectFixture = classMirror.reflectConstructor(constructor)("alpha")
        .asInstanceOf[TopLevelReflectFixture]
      val instanceMirror: ru.InstanceMirror = mirror.reflect(instance)
  
      val publicField: ru.TermSymbol = term(classSymbol, "value")
      val privateField: ru.TermSymbol = term(classSymbol, "secret")
      val publicMethod: ru.MethodSymbol = method(classSymbol, "greet")
      val privateMethod: ru.MethodSymbol = method(classSymbol, "secretGreeting")
  
      assertEquals("alpha", instanceMirror.reflectField(publicField).get)
      assertEquals("hidden-alpha", instanceMirror.reflectField(privateField).get)
      assertEquals("hello beta from alpha", instanceMirror.reflectMethod(publicMethod)("beta"))
      assertEquals("secret beta from alpha", instanceMirror.reflectMethod(privateMethod)("beta"))
    }
  
    @Test
    def mapsNestedScalaClassesBackToDeclaredJavaClasses(): Unit = {
      val outer: TopLevelReflectFixture = new TopLevelReflectFixture("outer")
      val outerMirror: ru.InstanceMirror = mirror.reflect(outer)
      val memberClass: ru.ClassSymbol = ru.typeOf[TopLevelReflectFixture#Member].typeSymbol.asClass
      val memberConstructor: ru.MethodSymbol = memberClass.primaryConstructor.asMethod
      val memberInstance: outer.Member = outerMirror.reflectClass(memberClass)
        .reflectConstructor(memberConstructor)(7)
        .asInstanceOf[outer.Member]
  
      val idMethod: ru.MethodSymbol = method(memberClass, "id")
      assertEquals(7, mirror.reflect(memberInstance).reflectMethod(idMethod)())
    }
  
    @Test
    def mapsClassesOwnedByATopLevelObjectBackToJavaClasses(): Unit = {
      val memberClass: ru.ClassSymbol = ru.typeOf[ObjectOwnedReflectFixture.Member].typeSymbol.asClass
      val classMirror: ru.ClassMirror =
        if (memberClass.isStatic) mirror.reflectClass(memberClass)
        else mirror.reflect(ObjectOwnedReflectFixture).reflectClass(memberClass)
      val constructor: ru.MethodSymbol = memberClass.primaryConstructor.asMethod
      val memberInstance: ObjectOwnedReflectFixture.Member = classMirror
        .reflectConstructor(constructor)("object-owned")
        .asInstanceOf[ObjectOwnedReflectFixture.Member]
  
      val labelMethod: ru.MethodSymbol = method(memberClass, "label")
      assertEquals("object-owned", mirror.reflect(memberInstance).reflectMethod(labelMethod)())
    }
  
    private def term(classSymbol: ru.ClassSymbol, name: String): ru.TermSymbol = {
      classSymbol.toType.decl(ru.TermName(name)).asTerm
    }
  
    private def method(classSymbol: ru.ClassSymbol, name: String): ru.MethodSymbol = {
      classSymbol.toType.decl(ru.TermName(name)).asMethod
    }
  }
  
  class TopLevelReflectFixture(val value: String) {
    private val secret: String = s"hidden-$value"
  
    def greet(name: String): String = s"hello $name from $value"
  
    private def secretGreeting(name: String): String = s"secret $name from $value"
  
    class Member(val id: Int)
  }
  
  class ObjectOwnedReflectFixture
  
  object ObjectOwnedReflectFixture {
    class Member(val label: String)
  }
