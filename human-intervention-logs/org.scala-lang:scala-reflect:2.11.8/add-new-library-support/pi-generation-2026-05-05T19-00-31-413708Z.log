      classOf[RichClassLoaderFixtures.NoArgService].getName\n    )\n    val initializedClass = richClassLoader.tryToInitializeClass[RichClassLoaderFixtures.NoArgService](\n      classOf[RichClassLoaderFixtures.NoArgService].getName\n    )\n\n    assertThat(loadedClass.isDefined).isTrue()\n    assertThat(initializedClass.isDefined).isTrue()\n    assertThat(richClassLoader.tryToLoadClass[AnyRef](\"org_scala_lang.scala_reflect.DoesNotExist\").isDefined)\n      .isFalse()\n\n    val stream = richClassLoader.classAsStream(getClass.getName)\n    try assertThat(stream).isNotNull()\n    finally if (stream != null) stream.close()\n  }\n\n  @Test\n  def createsInstancesWithNoArgAndSelectedConstructors(): Unit = {\n    val noArgService = richClassLoader.create(classOf[RichClassLoaderFixtures.NoArgService].getName)\n      .asInstanceOf[RichClassLoaderFixtures.NoArgService]\n\n    assertThat(noArgService.label).isEqualTo(\"created-with-no-arg-constructor\")\n\n    val service = richClassLoader.create[RichClassLoaderFixtures.TwoArgService](\n      classOf[RichClassLoaderFixtures.TwoArgService].getName,\n      message => throw new IllegalArgumentException(message),\n      Seq(\"left\", \"right\")\n    )\n\n    assertThat(service.combined).isEqualTo(\"left:right\")\n  }\n\n  @Test\n  def runsStaticMainWithContextClassLoader(): Unit = {\n    RichClassLoaderRunMain.reset()\n\n    richClassLoader.run(\"org_scala_lang.scala_reflect.RichClassLoaderRunMain\", Seq(\"alpha\", \"beta\"))\n\n    assertThat(RichClassLoaderRunMain.capturedArguments).containsExactly(\"alpha\", \"beta\")\n    assertThat(RichClassLoaderRunMain.contextWasRichLoader).isTrue()\n  }\n}\n\nobject RichClassLoaderFixtures {\n  class NoArgService {\n    def label: String = \"created-with-no-arg-constructor\"\n  }\n\n  class TwoArgService(first: String, second: String) {\n    def combined: String = s\"$first:$second\"\n  }\n}\n\nobject RichClassLoaderRunMain {\n  private var arguments: Vector[String] = Vector.empty\n  private var contextMatched: Boolean = false\n\n  def main(args: Array[String]): Unit = {\n    arguments = args.toVector\n    contextMatched = Thread.currentThread().getContextClassLoader == getClass.getClassLoader\n  }\n\n  def reset(): Unit = {\n    arguments = Vector.empty\n    contextMatched = false\n  }\n\n  def capturedArguments: java.lang.Iterable[String] = arguments.asJava\n\n  def contextWasRichLoader: Boolean = contextMatched\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.scala-lang/scala-reflect/2.11.8/src/test/scala/org_scala_lang/scala_reflect/RichClassLoaderTest.scala\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scala_lang.scala_reflect\\n\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport scala.reflect.internal.util.RichClassLoader\\n\\nclass RichClassLoaderTest {\\n  private val richClassLoader: RichClassLoader = new RichClassLoader(getClass.getClassLoader)\\n\\n  @Test\\n  def loadsClassesAndClassResources(): Unit = {\\n    val loadedClass = richClassLoader.tryToLoadClass[RichClassLoaderFixtures.NoArgService](\\n      classOf[RichClassLoaderFixtures.NoArgService].getName\\n    )\\n    val initializedClass = richClassLoader.tryToInitializeClass[RichClassLoaderFixtures.NoArgService](\\n      classOf[RichClassLoaderFixtures.NoArgService].getName\\n    )\\n\\n    assertThat(loadedClass.isDefined).isTrue()\\n    assertThat(initializedClass.isDefined).isTrue()\\n    assertThat(richClassLoader.tryToLoadClass[AnyRef](\\\"org_scala_lang.scala_reflect.DoesNotExist\\\").isDefined)\\n      .isFalse()\\n\\n    val stream = richClassLoader.classAsStream(getClass.getName)\\n    try assertThat(stream).isNotNull()\\n    finally if (stream != null) stream.close()\\n  }\\n\\n  @Test\\n  def createsInstancesWithNoArgAndSelected