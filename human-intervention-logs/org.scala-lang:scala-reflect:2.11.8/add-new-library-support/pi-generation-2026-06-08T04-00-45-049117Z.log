  package org_scala_lang.scala_reflect
  
  import java.io.InputStream
  
  import org.junit.jupiter.api.Assertions.assertArrayEquals
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Assertions.assertNotNull
  import org.junit.jupiter.api.Assertions.assertTrue
  import org.junit.jupiter.api.Assertions.fail
  import org.junit.jupiter.api.Test
  
  import scala.reflect.internal.util.RichClassLoader
  
  class RichClassLoaderTest {
    private val loader: RichClassLoader = new RichClassLoader(getClass.getClassLoader)
  
    @Test
    def loadsCreatesAndReadsClassesThroughRichClassLoader(): Unit = {
      val fixtureClassName: String = classOf[RichClassLoaderNoArgFixture].getName
      val loadedClass: Option[Class[RichClassLoaderNoArgFixture]] =
        loader.tryToLoadClass[RichClassLoaderNoArgFixture](fixtureClassName)
  
      assertTrue(loadedClass.exists(_ == classOf[RichClassLoaderNoArgFixture]))
  
      val initializedClass: Option[Class[RichClassLoaderNoArgFixture]] =
        loader.tryToInitializeClass[RichClassLoaderNoArgFixture](fixtureClassName)
      assertTrue(initializedClass.exists(_ == classOf[RichClassLoaderNoArgFixture]))
  
      val instance: RichClassLoaderNoArgFixture =
        loader.create(fixtureClassName).asInstanceOf[RichClassLoaderNoArgFixture]
      assertEquals("created-with-no-args", instance.message)
  
      val stream: InputStream = loader.classAsStream(fixtureClassName)
      try {
        assertNotNull(stream)
      } finally {
        if (stream != null) {
          stream.close()
        }
      }
  
      val bytes: Array[Byte] = loader.classBytes(fixtureClassName)
      assertTrue(bytes.length > 0)
      assertArrayEquals(
        Array[Byte](0xCA.toByte, 0xFE.toByte, 0xBA.toByte, 0xBE.toByte),
        bytes.take(4))
    }
  
    @Test
    def createsTypedInstanceWithMatchingConstructorArguments(): Unit = {
      val instance: RichClassLoaderConstructorArgFixture =
        loader.create[RichClassLoaderConstructorArgFixture](
          classOf[RichClassLoaderConstructorArgFixture].getName,
          failOnCreateError)("delta", Integer.valueOf(3))
  
      assertEquals("delta", instance.name)
      assertEquals(Integer.valueOf(3), instance.count)
      assertEquals("delta:3", instance.describe)
    }
  
    private def failOnCreateError(message: String): Unit = {
      fail(message)
    }
  
    @Test
    def runsStaticMainMethodWithContextClassLoader(): Unit = {
      val propertyName: String = RichClassLoaderRunnableFixture.propertyName
      System.clearProperty(propertyName)
  
      loader.run(RichClassLoaderRunnableFixture.getClass.getName.stripSuffix("$"), Seq("one", "two"))
  
      assertEquals("one,two", System.getProperty(propertyName))
    }
  }
  
  class RichClassLoaderNoArgFixture {
    val message: String = "created-with-no-args"
  }
  
  class RichClassLoaderConstructorArgFixture(val name: String, val count: Integer) {
    def describe: String = s"$name:$count"
  }
  
  object RichClassLoaderRunnableFixture {
    val propertyName: String = "org_scala_lang.scala_reflect.RichClassLoaderRunnableFixture.arguments"
  
    def main(args: Array[String]): Unit = {
      System.setProperty(propertyName, args.mkString(","))
    }
  }
