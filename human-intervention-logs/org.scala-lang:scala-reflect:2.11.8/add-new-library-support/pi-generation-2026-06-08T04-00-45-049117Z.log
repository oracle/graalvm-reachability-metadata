  package org_scala_lang.scala_reflect
  
  import org.junit.jupiter.api.Assertions.assertEquals
  import org.junit.jupiter.api.Test
  
  import scala.reflect.runtime.{universe => ru}
  
  class JavaMirrorsInnerJavaMirrorInnerJavaMethodMirrorTest {
    private val mirror: ru.Mirror = ru.runtimeMirror(getClass.getClassLoader)
  
    @Test
    def invokesGenericMethodMirrorForMethodsWithMoreThanFourArguments(): Unit = {
      val instance: JavaMethodMirrorGenericFixture = new JavaMethodMirrorGenericFixture(
        "root-a",
        "root-b",
        "root-c",
        "root-d",
        "root-e")
      val classSymbol: ru.ClassSymbol = ru.typeOf[JavaMethodMirrorGenericFixture].typeSymbol.asClass
      val instanceMirror: ru.InstanceMirror = mirror.reflect(instance)
      val combine: ru.MethodSymbol = method(classSymbol, "combine")
  
      val result: Any = instanceMirror.reflectMethod(combine)("one", "two", "three", "four", "five")
  
      assertEquals("root-a/root-b/root-c/root-d/root-e:one/two/three/four/five", result)
    }
  
    @Test
    def invokesGenericMethodMirrorForTopLevelConstructorsWithMoreThanFourArguments(): Unit = {
      val classSymbol: ru.ClassSymbol = mirror.staticClass(
        "org_scala_lang.scala_reflect.JavaMethodMirrorGenericFixture")
      val classMirror: ru.ClassMirror = mirror.reflectClass(classSymbol)
      val constructor: ru.MethodSymbol = classSymbol.primaryConstructor.asMethod
  
      val result: JavaMethodMirrorGenericFixture = classMirror
        .reflectConstructor(constructor)("a", "b", "c", "d", "e")
        .asInstanceOf[JavaMethodMirrorGenericFixture]
  
      assertEquals("a/b/c/d/e:x/y/z/u/v", result.combine("x", "y", "z", "u", "v"))
    }
  
    @Test
    def invokesGenericMethodMirrorForInnerConstructorsWithMoreThanFourArguments(): Unit = {
      val outer: JavaMethodMirrorGenericOuterFixture =
        new JavaMethodMirrorGenericOuterFixture("outer")
      val outerMirror: ru.InstanceMirror = mirror.reflect(outer)
      val memberClass: ru.ClassSymbol = ru.typeOf[JavaMethodMirrorGenericOuterFixture#Member]
        .typeSymbol
        .asClass
      val memberConstructor: ru.MethodSymbol = memberClass.primaryConstructor.asMethod
  
      val result: outer.Member = outerMirror
        .reflectClass(memberClass)
        .reflectConstructor(memberConstructor)("a", "b", "c", "d", "e")
        .asInstanceOf[outer.Member]
  
      assertEquals("outer:a/b/c/d/e", result.summary)
    }
  
    private def method(classSymbol: ru.ClassSymbol, name: String): ru.MethodSymbol = {
      classSymbol.toType.decl(ru.TermName(name)).asMethod
    }
  }
  
  class JavaMethodMirrorGenericFixture(
      val first: String,
      val second: String,
      val third: String,
      val fourth: String,
      val fifth: String) {
    def combine(a: String, b: String, c: String, d: String, e: String): String = {
      s"$first/$second/$third/$fourth/$fifth:$a/$b/$c/$d/$e"
    }
  }
  
  class JavaMethodMirrorGenericOuterFixture(prefix: String) {
    class Member(
        first: String,
        second: String,
        third: String,
        fourth: String,
        fifth: String) {
      def summary: String = s"$prefix:$first/$second/$third/$fourth/$fifth"
    }
  }
