o.VirtualDirectory\nimport scala.reflect.runtime.ReflectionUtils\n\nclass ReflectionUtilsTest {\n  @Test\n  def loadsTopLevelModuleThroughStaticSingletonLookup(): Unit = {\n    val moduleClassName: String = ReflectionUtilsStaticSingletonFixture.getClass.getName\n    val singleton: AnyRef = ReflectionUtils.staticSingletonInstance(\n      getClass.getClassLoader,\n      moduleClassName.stripSuffix(\"$\"))\n\n    assertSame(ReflectionUtilsStaticSingletonFixture, singleton)\n    assertEquals(\"static-singleton\", singleton.asInstanceOf[ReflectionUtilsStaticSingletonFixture.type].name)\n  }\n\n  @Test\n  def invokesMemberObjectAccessorThroughInnerSingletonLookup(): Unit = {\n    val outer: ReflectionUtilsOuterSingletonFixture = new ReflectionUtilsOuterSingletonFixture(\"outer\")\n    val singleton: AnyRef = ReflectionUtils.innerSingletonInstance(outer, \"NestedSingleton\")\n\n    assertSame(outer.NestedSingleton, singleton)\n    assertEquals(\"outer:nested\", singleton.asInstanceOf[outer.NestedSingleton.type].description)\n  }\n\n  @Test\n  def showsAbstractFileClassLoaderClasspathFromItsRoot(): Unit = {\n    val root: VirtualDirectory = new VirtualDirectory(\"reflection-utils-root\", None)\n    val loader: AbstractFileClassLoader = new AbstractFileClassLoader(root, getClass.getClassLoader)\n\n    val description: String = ReflectionUtils.show(loader)\n\n    assertTrue(description.contains(\"AbstractFileClassLoader\"))\n    assertTrue(description.contains(\"reflection-utils-root\"))\n  }\n}\n\nobject ReflectionUtilsStaticSingletonFixture {\n  val name: String = \"static-singleton\"\n}\n\nclass ReflectionUtilsOuterSingletonFixture(prefix: String) {\n  object NestedSingleton {\n    val description: String = s\"$prefix:nested\"\n  }\n}\n"}], "isError": false, "timestamp": 1780891166838}, {"role": "toolResult", "toolCallId": "call_fILbEwcoOcuBXYYg8k3pTb5d|fc_066b4ab47dfdf5b3016a263e1e990881948e637e54dd4c4acb", "toolName": "read", "content": [{"type": "text", "text": "/*\n * 