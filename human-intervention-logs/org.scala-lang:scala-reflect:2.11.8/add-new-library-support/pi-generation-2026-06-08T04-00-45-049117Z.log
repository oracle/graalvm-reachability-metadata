assMirror: ru.ClassMirror = mirror.reflectClass(classSymbol)\n    val constructor: ru.MethodSymbol = classSymbol.primaryConstructor.asMethod\n    val instance: TopLevelReflectFixture = classMirror.reflectConstructor(constructor)(\"alpha\")\n      .asInstanceOf[TopLevelReflectFixture]\n    val instanceMirror: ru.InstanceMirror = mirror.reflect(instance)\n\n    val publicField: ru.TermSymbol = term(classSymbol, \"value\")\n    val privateField: ru.TermSymbol = term(classSymbol, \"secret\")\n    val publicMethod: ru.MethodSymbol = method(classSymbol, \"greet\")\n    val privateMethod: ru.MethodSymbol = method(classSymbol, \"secretGreeting\")\n\n    assertEquals(\"alpha\", instanceMirror.reflectField(publicField).get)\n    assertEquals(\"hidden-alpha\", instanceMirror.reflectField(privateField).get)\n    assertEquals(\"hello beta from alpha\", instanceMirror.reflectMethod(publicMethod)(\"beta\"))\n    assertEquals(\"secret beta from alpha\", instanceMirror.reflectMethod(privateMethod)(\"beta\"))\n  }\n\n  @Test\n  def mapsNestedScalaClassesBackToDeclaredJavaClasses(): Unit = {\n    val outer: TopLevelReflectFixture = new TopLevelReflectFixture(\"outer\")\n    val outerMirror: ru.InstanceMirror = mirror.reflect(outer)\n    val memberClass: ru.ClassSymbol = ru.typeOf[TopLevelReflectFixture#Member].typeSymbol.asClass\n    val memberConstructor: ru.MethodSymbol = memberClass.primaryConstructor.asMethod\n    val memberInstance: outer.Member = outerMirror.reflectClass(memberClass)\n      .reflectConstructor(memberConstructor)(7)\n      .asInstanceOf[outer.Member]\n\n    val idMethod: ru.MethodSymbol = method(memberClass, \"id\")\n    assertEquals(7, mirror.reflect(memberInstance).reflectMethod(idMethod)())\n  }\n\n  @Test\n  def mapsClassesOwnedByATopLevelObjectBackToJavaClasses(): Unit = {\n    val memberClass: ru.ClassSymbol = ru.typeOf[ObjectOwnedReflectFixture.Member].typeSymbol.asClass\n    val classMirror: ru.ClassMirror =\n      if (memberClass.isStatic) mirror.reflect