        case LongTag    => LongTpe
        case FloatTag   => FloatTpe
        case DoubleTag  => DoubleTpe
        case StringTag  => StringTpe
        case NullTag    => NullTpe
        case ClazzTag   => ClassType(typeValue)
        case EnumTag    => EnumType(symbolValue)
