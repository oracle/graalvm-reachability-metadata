egalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_scala_lang.scala_reflect\n\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.jdk.CollectionConverters._\nimport scala.reflect.runtime.universe.Annotation\nimport scala.reflect.runtime.universe.runtimeMirror\n\nclass JavaMirrorsInnerJavaMirrorInnerJavaAnnotationProxyTest {\n  @Test\n  def readsAssociationsFromJavaAnnotationProxies(): Unit = {\n    val mirror = runtimeMirror(getClass.getClassLoader)\n    val deprecatedAnnotationSymbol = mirror.staticClass(\"java.lang.Deprecated\")\n\n    val associationsByAnnotation: Map[String, Map[String, String]] =\n      deprecatedAnnotationSymbol.annotations.map { annotation =>\n        annotation.atp.typeSymbol.fullName -> associationStrings(annotation)\n      }.toMap\n\n    assertThat(associationsByAnnotation.keySet.asJava).contains(\n      \"java.lang.annotation.Retention\",\n      \"java.lang.annotation.Target\"\n    )\n    assertThat(associationsByAnnotation(\"java.lang.annotation.Retention\").asJava)\n      .containsEntry(\"value\", \"RUNTIME\")\n    assertThat(associationsByAnnotation(\"java.lang.annotation.Target\")(\"value\"))\n      .contains(\"METHOD\")\n      .contains(\"TYPE\")\n  }\n\n  private def associationStrings(annotation: Annotation): Map[String, String] =\n    annotation.assocs.map { case (name, argument) => name.toString -> argument.toString }.toMap\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.scala-lang/scala-reflect/2.11.8/src/test/scala/org_scala_lang/scala_reflect/JavaMirrorsInnerJavaMirrorInnerJavaAnnotationProxyTest.scala\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scala_lang.scala_reflect\\n\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\n\\nimport scala.jdk.CollectionConverters._\\nimport scala.reflect.runtime.universe.Annotation\\nimport scala.reflect.runtime.universe.runtimeMirror\\n\\nclass JavaMirrorsInnerJavaMirrorInnerJavaAnnotationProxyTest {\\n  @Test\\n  def readsAssociationsFromJavaAnnotationProxies(): Unit = {\\n    val mirror = runtimeMirror(getClass.getClassLoader)\\n    val deprecatedAnnotationSymbol = mirror.staticClass(\\\"java.lang.Deprecated\\\")\\n\\n    val associationsByAnnotation: Map[String, Map[String, String]] =\\n      deprecatedAnnotationSymbol.annotations.map { annotation =>\\n        annotation.atp.typeSymbol.fullName -> associationStrings(annotation)\\n      }.toMap\\n\\n    assertThat(associationsByAnnotation.keySet.asJava).contains(\\n      \\\"java.lang.annotation.Retention\\\",\\n      \\\"java.lang.annotation.Target\\\"\\n    )\\n    assertThat(associationsByAnnotation(\\\"java.lang.annotation.Retention\\\").asJava)\\n      .containsEntry(\\\"value\\\", \\\"RUNTIME\\\")\\n    assertThat(associationsByAnnotation(\\\"java.lang.annotation.Target\\\")(\\\"value\\\"))\\n      .contains(\\\"METHOD\\\")\\n      .contains(\\\"TYPE\\\")\\n  }\\n\\n  private def associationStrings(annotation: Annotation): Map[String, String] =\\n    annotation.assocs.map { case (name, argument) => name.toString -> argument.toString }.toMap\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1308, "output": 1362, "cacheRead": 24576, "cacheWrite": 0, "totalTokens": 27246, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778011080240, "responseId": "resp_0edfda62f23244470169fa4bc9c51c81a28bfcbefbe5eed7a2"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_kqQTpHcHAq7euGtgkICZa9TC|fc_0edfda62f23244470169fa4bd70f6081a28a530c94d6a45d68", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1547 bytes