ssLoader)\\n\\n  @Test\\n  def unpicklesScalaSignaturesAndReflectsTopLevelMembers(): Unit = {\\n    val classSymbol: ru.ClassSymbol = mirror.staticClass(\\n      \\\"org_scala_lang.scala_reflect.TopLevelReflectFixture\\\")\\n    val classMirror: ru.ClassMirror = mirror.reflectClass(classSymbol)\\n    val constructor: ru.MethodSymbol = classSymbol.primaryConstructor.asMethod\\n    val instance: TopLevelReflectFixture = classMirror.reflectConstructor(constructor)(\\\"alpha\\\")\\n      .asInstanceOf[TopLevelReflectFixture]\\n    val instanceMirror: ru.InstanceMirror = mirror.reflect(instance)\\n\\n    val publicField: ru.TermSymbol = term(classSymbol, \\\"value\\\")\\n    val privateField: ru.TermSymbol = term(classSymbol, \\\"secret\\\")\\n    val publicMethod: ru.MethodSymbol = method(classSymbol, \\\"greet\\\")\\n    val privateMethod: ru.MethodSymbol = method(classSymbol, \\\"secretGreeting\\\")\\n\\n    assertEquals(\\\"alpha\\\", instanceMirror.reflectField(publicField).get)\\n    assertEquals(\\\"hidden-alpha\\\", instanceMirror.reflectField(privateField).get)\\n    assertEquals(\\\"hello beta from alpha\\\", instanceMirror.reflectMethod(publicMethod)(\\\"beta\\\"))\\n    assertEquals(\\\"secret beta from alpha\\\", instanceMirror.reflectMethod(privateMethod)(\\\"beta\\\"))\\n  }\\n\\n  @Test\\n  def mapsNestedScalaClassesBackToDeclaredJavaClasses(): Unit = {\\n    val outer: TopLevelReflectFixture = new TopLevelReflectFixture(\\\"outer\\\")\\n    val outerMirror: ru.InstanceMirror = mirror.reflect(outer)\\n    val memberClass: ru.ClassSymbol = ru.typeOf[TopLevelReflectFixture#Member].typeSymbol.asClass\\n    val memberConstructor: ru.MethodSymbol = memberClass.primaryConstructor.asMethod\\n    val memberInstance: outer.Member = outerMirror.reflectClass(memberClass)\\n      .reflectConstructor(memberConstructor)(7)\\n      .asInstanceOf[outer.Member]\\n\\n    val idMethod: ru.MethodSymbol = method(memberClass, \\\"id\\\")\\n    assertEquals(7, mirror.reflect(memberInstance).reflectMethod(idMethod)())\\n  }\\n\\n  @Test\\n  def mapsClassesOwnedByATopLevelObjectBackToJavaClasses(): Unit = {\\n    val memberClass: ru.ClassSymbol = ru.typeOf[ObjectOwnedReflectFixture.Member].typeSymbol.asClass\\n    val classMirror: ru.ClassMirror =\\n      if (memberClass.isStatic) mirror.reflectClass(memberClass)\\n      else mirror.reflect(ObjectOwnedReflectFixture).reflectClass(memberClass)\\n    val constructor: ru.MethodSymbol = memberClass.primaryConstructor.asMethod\\n    val memberInstance: ObjectOwnedReflectFixture.Member = classMirror\\n      .reflectConstructor(constructor)(\\\"object-owned\\\")\\n      .asInstanceOf[ObjectOwnedReflectFixture.Member]\\n\\n    val labelMethod: ru.MethodSymbol = method(memberClass, \\\"label\\\")\\n    assertEquals(\\\"object-owned\\\", mirror.reflect(memberInstance).reflectMethod(labelMethod)())\\n  }\\n\\n  private def term(classSymbol: ru.ClassSymbol, name: String): ru.TermSymbol = {\\n    classSymbol.toType.decl(ru.TermName(name)).asTerm\\n  }\\n\\n  private def method(classSymbol: ru.ClassSymbol, name: String): ru.MethodSymbol = {\\n    classSymbol.toType.decl(ru.TermName(name)).asMethod\\n  }\\n}\\n\\nclass TopLevelReflectFixture(val value: String) {\\n  private val secret: String = s\\\"hidden-$value\\\"\\n\\n  def greet(name: String): String = s\\\"hello $name from $value\\\"\\n\\n  private def secretGreeting(name: String): String = s\\\"secret $name from $value\\\"\\n\\n  class Member(val id: Int)\\n}\\n\\nclass ObjectOwnedReflectFixture\\n\\nobject ObjectOwnedReflectFixture {\\n  class Member(val label: String)\\n}\\n\"}], \"isError\": false, \"timestamp\": 1780891166838}, {\"role\": \"toolResult\", \"toolCallId\": \"call_yusie2teOe7lQIqA5nQ3KUFb|fc_066b4ab47dfdf5b3016a263e1e99008194b2e7abd49f41ab5a\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scala_lang.scala_reflect\\n\\nimport org.junit.jupiter.api.Assertions.assertEquals\\nimport org.junit.jupiter.api.Assertions.assertSame\\nimport org.junit.jupiter.api.Assertions.assertTrue\\nimport org.junit.jupiter.api.Test\\n\\nimport scala.reflect.internal.util.AbstractFileClassLoader\\nimport scala.reflect.io.VirtualDirectory\\nimport scala.reflect.runtime.ReflectionUtils\\n\\nclass ReflectionUtilsTest {\\n  @Test\\n  def loadsTopLevelModuleThroughStaticSingletonLookup(): Unit = {\\n    val moduleClassName: String = ReflectionUtilsStaticSingletonFixture.getClass.getName\\n    val singleton: AnyRef = ReflectionUtils.staticSingletonInstance(\\n      getClass.getClassLoader,\\n      moduleClassName.stripSuffix(\\\"$\\\"))\\n\\n    assertSame(ReflectionUtilsStaticSingletonFixture, singleton)\\n    assertEquals(\\\"static-singleton\\\", singleton.asInstanceOf[ReflectionUtilsStaticSingletonFixture.type].name)\\n  }\\n\\n  @Test\\n  def invokesMemberObjectAccessorThroughInnerSingletonLookup(): Unit = {\\n    val outer: ReflectionUtilsOuterSingletonFixture = new ReflectionUtilsOuterSingletonFixture(\\\"outer\\\")\\n    val singleton: AnyRef = ReflectionUtils.innerSingletonInstance(outer, \\\"NestedSingleton\\\")\\n\\n    assertSame(outer.NestedSingleton, singleton)\\n    assertEquals(\\\"outer:nested\\\", singleton.asInstanceOf[outer.NestedSingleton.type].description)\\n  }\\n\\n  @Test\\n  def showsAbstractFileClassLoaderClasspathFromItsRoot(): Unit = {\\n    val root: VirtualDirectory = new VirtualDirectory(\\\"reflection-utils-root\\\", None)\\n    val loader: AbstractFileClassLoader = new AbstractFileClassLoader(root, getClass.getClassLoader)\\n\\n    val description: String = ReflectionUtils.show(loader)\\n\\n    assertTrue(description.contains(\\\"AbstractFileClassLoader\\\"))\\n    assertTrue(description.contains(\\\"reflection-utils-root\\\"))\\n  }\\n}\\n