egalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_scala_lang.scala_reflect\\n\\nimport org.junit.jupiter.api.Assertions.assertEquals\\nimport org.junit.jupiter.api.Assertions.assertNotNull\\nimport org.junit.jupiter.api.Test\\n\\nimport scala.reflect.runtime.{universe => ru}\\n\\nclass JavaMirrorsInnerJavaMirrorTest {\\n  private val mirror: ru.Mirror = ru.runtimeMirror(getClass.getClassLoader)\\n\\n  @Test\\n  def unpicklesScalaSignaturesAndReflectsTopLevelMembers(): Unit = {\\n    val classSymbol: ru.ClassSymbol = mirror.staticClass(\\n      \\\"org_scala_lang.scala_reflect.TopLevelReflectFixture\\\")\\n    val classMirror: ru.ClassMirror = mirror.reflectClass(classSymbol)\\n    val constructor: ru.MethodSymbol = classSymbol.primaryConstructor.asMethod\\n    val instance: TopLevelReflectFixture = classMirror.reflectConstructor(constructor)(\\\"alpha\\\")\\n      .asInstanceOf[TopLevelReflectFixture]\\n    val instanceMirror: ru.InstanceMirror = mirror.reflect(instance)\\n\\n    val publicField: ru.TermSymbol = term(classSymbol, \\\"value\\\")\\n    val privateField: ru.TermSymbol = term(classSymbol, \\\"secret\\\")\\n    val publicMethod: ru.MethodSymbol = method(classSymbol, \\\"greet\\\")\\n    val privateMethod: ru.MethodSymbol = method(classSymbol, \\\"secretGreeting\\\")\\n\\n    assertEquals(\\\"alpha\\\", instanceMirror.reflectField(publicField).get)\\n    assertEquals(\\\"hidden-alpha\\\", instanceMirror.reflectField(privateField).get)\\n    assertEquals(\\\"hello beta from alpha\\\", instanceMirror.reflectMethod(publicMethod)(\\\"beta\\\"))\\n    assertEquals(\\\"secret beta from alpha\\\", instanceMirror.reflectMethod(privateMethod)(\\\"beta\\\"))\\n  }\\n\\n  @Test\\n  def mapsNestedScalaClassesBackToDeclaredJavaClasses(): Unit = {\\n    val outer: TopLevelReflectFixture = new TopLevelReflectFixture(\\\"outer\\\")\\n    val outerMirror: ru.InstanceMirror = mirror.reflect(outer)\\n   