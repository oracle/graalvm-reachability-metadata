ssOf[RichClassLoaderNoArgFixture]))\\n\\n    val initializedClass: Option[Class[RichClassLoaderNoArgFixture]] =\\n      loader.tryToInitializeClass[RichClassLoaderNoArgFixture](fixtureClassName)\\n    assertTrue(initializedClass.exists(_ == classOf[RichClassLoaderNoArgFixture]))\\n\\n    val instance: RichClassLoaderNoArgFixture =\\n      loader.create(fixtureClassName).asInstanceOf[RichClassLoaderNoArgFixture]\\n    assertEquals(\\\"created-with-no-args\\\", instance.message)\\n\\n    val stream = loader.classAsStream(fixtureClassName)\\n    try {\\n      assertNotNull(stream)\\n    } finally {\\n      if (stream != null) {\\n        stream.close()\\n      }\\n    }\\n\\n    val bytes: Array[Byte] = loader.classBytes(fixtureClassName)\\n    assertTrue(bytes.length > 0)\\n    assertArrayEquals(Array[Byte](0xCA.toByte, 0xFE.toByte, 0xBA.toByte, 0xBE.toByte), bytes.take(4))\\n  }\\n\\n  @Test\\n  def createsTypedInstanceWithMatchingConstructorArguments(): Unit = {\\n    val instance: RichClassLoaderConstructorArgFixture =\\n      loader.create[RichClassLoaderConstructorArgFixture](\\n        classOf[RichClassLoaderConstructorArgFixture].getName,\\n        message => fail(message),\\n        Seq(\\\"delta\\\", Integer.valueOf(3)))\\n\\n    assertEquals(\\\"delta\\\", instance.name)\\n    assertEquals(Integer.valueOf(3), instance.count)\\n    assertEquals(\\\"delta:3\\\", instance.describe)\\n  }\\n\\n  @Test\\n  def runsStaticMainMethodWithContextClassLoader(): Unit = {\\n    val propertyName: String = RichClassLoaderRunnableFixture.propertyName\\n    System.clearProperty(propertyName)\\n\\n    loader.run(RichClassLoaderRunnableFixture.getClass.getName.stripSuffix(\\\"$\\\"), Seq(\\\"one\\\", \\\"two\\\"))\\n\\n    assertEquals(\\\"one,two\\\", System.getProperty(propertyName))\\n  }\\n}\\n\\nclass RichClassLoaderNoArgFixture {\\n  val message: String = \\\"created-with-no-args\\\"\\n}\\n\\nclass RichClassLoaderConstructorArgFixture(val name: String, val count: Integer