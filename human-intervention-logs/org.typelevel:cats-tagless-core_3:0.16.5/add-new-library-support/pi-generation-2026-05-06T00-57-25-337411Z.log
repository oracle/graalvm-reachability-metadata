[tool-call] delta {"path":"tests/src/org.typelevel/cats-tagless-core_3/0.16.5/src/test/scala/org_typelevel/cats_tagless_core_3/DeriveMacrosTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_typelevel.cats_tagless_core_3\n\nimport cats.Id\nimport cats.~>\nimport cats.tagless.Derive\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.annotation.experimental\n\n@experimental\nclass DeriveMacrosTest {\n  trait KeyValueAlg[F[_]] {\n    type Key\n\n    def defaultKey: Key\n\n    def fetch(key: Key): F[String]\n\n    def store(key: Key, value: String): F[Int]\n  }\n\n  @Test\n  def derivesFunctorKForAlgebraWithTypeMember(): Unit = {\n    val idAlg: KeyValueAlg[Id] = new KeyValueAlg[Id] {\n      type Key = String\n\n      override val defaultKey: Key = \"primary\"\n\n      override def fetch(key: Key): Id[String] = s\"value:$key\"\n\n      override def store(key: Key, value: String): Id[Int] = key.length + value.length\n    }\n\n    val toOption: Id ~> Option = new (Id ~> Option) {\n      override def apply[A](value: Id[A]): Option[A] = Option(value)\n    }\n\n    val optionAlg: KeyValueAlg[Option] = Derive.functorK[KeyValueAlg].mapK(idAlg)(toOption)\n\n    assertThat(optionAlg.fetch(optionAlg.defaultKey)).contains(\"value:primary\")\n    assertThat(optionAlg.store(optionAlg.defaultKey, \"updated\")).contains(14)\n  }\n}\n"}
[tool-call] end id=call_GQkOqO5uBuAb8zX6PE05qLLW|fc_07bef1267bb135810169fa918e3bd0819fbd26e50cb05da5d1 name=write args={"path": "tests/src/org.typelevel/cats-tagless-core_3/0.16.5/src/test/scala/org_typelevel/cats_tagless_core_3/DeriveMacrosTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_typelevel.cats_tagless_core_3\n\nimport cats.Id\nimport cats.~>\nimport cats.tagless.Derive\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\n\nimport scala.annotation.experimental\n\n@experimental\nclass DeriveMacrosTest {\n  trait KeyValueAlg[F[_]] {\n    type Key\n\n    def defaultKey: Key\n\n    def fetch(key: Key): F[String]\n\n    def store(key: Key, value: String): F[Int]\n  }\n\n  @Test\n  def derivesFunctorKForAlgebraWithTypeMember(): Unit = {\n    val idAlg: KeyValueAlg[Id] = new KeyValueAlg[Id] {\n      type Key = String\n\n      override val defaultKey: Key = \"primary\"\n\n      override def fetch(key: Key): Id[String] = s\"value:$key\"\n\n      override def store(key: Key, value: String): Id[Int] = key.length + value.length\n    }\n\n    val toOption: Id ~> Option = new (Id ~> Option) {\n      override def apply[A](value: Id[A]): Option[A] = Option(value)\n    }\n\n    val optionAlg: KeyValueAlg[Option] = Derive.functorK[KeyValueAlg].mapK(idAlg)(toOption)\n\n    assertThat(optionAlg.fetch(optionAlg.defaultKey)).contains(\"value:primary\")\n    assertThat(optionAlg.store(optionAlg.defaultKey, \"updated\")).contains(14)\n  }\n}\n"}
