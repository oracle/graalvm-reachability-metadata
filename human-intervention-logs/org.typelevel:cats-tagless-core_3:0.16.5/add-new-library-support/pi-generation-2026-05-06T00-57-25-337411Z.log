[tool-call] delta {"path":"tests/src/org.typelevel/cats-tagless-core_3/0.16.5/src/test/scala/org_typelevel/cats_tagless_core_3/DeriveMacrosTest.scala","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_typelevel.cats_tagless_core_3\n\nimport dotty.tools.dotc.Driver\nimport dotty.tools.dotc.interfaces.CompilerCallback\nimport dotty.tools.dotc.interfaces.Diagnostic\nimport dotty.tools.dotc.interfaces.SimpleReporter\nimport org.assertj.core.api.Assertions.assertThat\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Test\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\nimport java.util.ArrayList\n\nclass DeriveMacrosTest {\n  @Test\n  def compilesDerivedFunctorKForAlgebraWithTypeMember(): Unit = {\n    try compileSourceThatExpandsDeriveMacro()\n    catch\n      case error: Error =>\n        if !NativeImageSupport.isUnsupportedFeatureError(error) then throw error\n  }\n\n  private def compileSourceThatExpandsDeriveMacro(): Unit = {\n    val workspace: Path = Path.of(\"build\", \"derive-macros-test\")\n    val outputDirectory: Path = workspace.resolve(\"classes\")\n    val sourceFile: Path = workspace.resolve(\"UsesDeriveMacros.scala\")\n    Files.createDirectories(outputDirectory)\n    Files.writeString(sourceFile, sourceText, StandardCharsets.UTF_8)\n\n    val diagnostics = ArrayList[String]()\n    val reporter: SimpleReporter = new SimpleReporter {\n      override def report(diagnostic: Diagnostic): Unit = {\n        diagnostics.add(s\"${diagnostic.level()}: ${diagnostic.message()}\")\n      }\n    }\n    val arguments: Array[String] = Array(\n      \"-classpath\",\n      System.getProperty(\"java.class.path\"),\n      \"-d\",\n      outputDirectory.toString,\n      sourceFile.toString\n    )\n\n    val result = Driver().process(arguments, reporter, new CompilerCallback {})\n\n    assertThat(result.hasErrors()).as(diagnostics.toString).isFalse()\n    assertThat(Files.exists(outputDirectory.resolve(\"generated/UsesDeriveMacros.class\"))).isTrue()\n  }\n\n  private def sourceText: String =\n    \"\"\"\n      |package generated\n      |\n      |import cats.Id\n      |import cats.~>\n      |import cats.tagless.Derive\n      |import cats.tagless.FunctorK\n      |\n      |import scala.annotation.experimental\n      |\n      |@experimental\n      |object UsesDeriveMacros:\n      |  trait KeyValueAlg[F[_]]:\n      |    type Key\n      |\n      |    def defaultKey: Key\n      |\n      |    def fetch(key: Key): F[String]\n      |\n      |    def store(key: Key, value: String): F[Int]\n      |\n      |  \n      |  val idAlg: KeyValueAlg[Id] = new KeyValueAlg[Id]:\n      |    type Key = String\n      |\n      |    override val defaultKey: Key = \"primary\"\n      |\n      |    override def fetch(key: Key): Id[String] = s\"value:$key\"\n      |\n      |    override def store(key: Key, value: String): Id[Int] = key.length + value.length\n      |\n      |  val toOption: Id ~> Option = new (Id ~> Option):\n      |    override def apply[A](value: Id[A]): Option[A] = Option(value)\n      |\n      |  val functorK: FunctorK[KeyValueAlg] = Derive.functorK[KeyValueAlg]\n      |  val optionAlg: KeyValueAlg[Option] = functorK.mapK(idAlg)(toOption)\n      |  val fetched: Option[String] = optionAlg.fetch(optionAlg.defaultKey)\n      |  val stored: Option[Int] = optionAlg.store(optionAlg.defaultKey, \"updated\")\n      |\"\"\".stripMargin\n}\n"}
[tool-call] end id=call_CM9108JUlyHHSJUEC6sjwG4U|fc_07bef1267bb135810169fa93d65ef0819fa5e648f8c7faad22 name=write args={"path": "tests/src/org.typelevel/cats-tagless-core_3/0.16.5/src/test/scala/org_typelevel/cats_tagless_core_3/DeriveMacrosTest.scala", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_typelevel.cats_tagless_core_3\n\nimport dotty.tools.dotc.Driver\nimport dotty.tools.dotc.interfaces.CompilerCallback\nimport dotty.tools.dotc.interfaces.Diagnostic\nimport dotty.tools.dotc.interfaces.SimpleReporter\nimport org.assertj.core.api.Assertions.assertThat\nimport org.graalvm.internal.tck.NativeImageSupport\nimport org.junit.jupiter.api.Test\n\nimport java.nio.charset.StandardCharsets\nimport java.nio.file.Files\nimport java.nio.file.Path\nimport java.util.ArrayList\n\nclass DeriveMacrosTest {\n  @Test\n  def compilesDerivedFunctorKForAlgebraWithTypeMember(): Unit = {\n    try compileSourceThatExpandsDeriveMacro()\n    catch\n      case error: Error =>\n        if !NativeImageSupport.isUnsupportedFeatureError(error) then throw error\n  }\n\n  private def compileSourceThatExpandsDeriveMacro(): Unit = {\n    val workspace: Path = Path.of(\"build\", \"derive-macros-test\")\n    val outputDirectory: Path = workspace.resolve(\"classes\")\n    val sourceFile: Path = workspace.resolve(\"UsesDeriveMacros.scala\")\n    Files.createDirectories(outputDirectory)\n    Files.writeString(sourceFile, sourceText, StandardCharsets.UTF_8)\n\n    val diagnostics = ArrayList[String]()\n    val reporter: SimpleReporter = new SimpleReporter {\n      override def report(diagnostic: Diagnostic): Unit = {\n        diagnostics.add(s\"${diagnostic.level()}: ${diagnostic.message()}\")\n      }\n    }\n    val arguments: Array[String] = Array(\n      \"-classpath\",\n      System.getProperty(\"java.class.path\"),\n      \"-d\",\n      outputDirectory.toString,\n      sourceFile.toString\n    )\n\n    val result = Driver().process(arguments, reporter, new CompilerCallback {})\n\n    assertThat(result.hasErrors()).as(diagnostics.toString).isFalse()\n    assertThat(Files.exists(outputDirectory.resolve(\"generated/UsesDeriveMacros.class\"))).isTrue()\n  }\n\n  private def sourceText: String =\n    \"\"\"\n      |package generated\n      |\n      |import cats.Id\n      |import cats.~>\n      |import cats.tagless.Derive\n      |import cats.tagless.FunctorK\n      |\n      |import scala.annotation.experimental\n      |\n      |@experimental\n      |object UsesDeriveMacros:\n      |  trait KeyValueAlg[F[_]]:\n      |    type Key\n      |\n      |    def defaultKey: Key\n      |\n      |    def fetch(key: Key): F[String]\n      |\n      |    def store(key: Key, value: String): F[Int]\n      |\n      |  \n      |  val idAlg: KeyValueAlg[Id] = new KeyValueAlg[Id]:\n      |    type Key = String\n      |\n      |    override val defaultKey: Key = \"primary\"\n      |\n      |    override def fetch(key: Key): Id[String] = s\"value:$key\"\n      |\n      |    override def store(key: Key, value: String): Id[Int] = key.length + value.length\n      |\n      |  val toOption: Id ~> Option = new (Id ~> Option):\n      |    override def apply[A](value: Id[A]): Option[A] = Option(value)\n      |\n      |  val functorK: FunctorK[KeyValueAlg] = Derive.functorK[KeyValueAlg]\n      |  val optionAlg: KeyValueAlg[Option] = functorK.mapK(idAlg)(toOption)\n      |  val fetched: Option[String] = optionAlg.fetch(optionAlg.defaultKey)\n      |  val stored: Option[Int] = optionAlg.store(optionAlg.defaultKey, \"updated\")\n      |\"\"\".stripMargin\n}\n"}
