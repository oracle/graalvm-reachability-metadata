 |@experimental\n      |object UsesDeriveMacros:\n      |  trait KeyValueAlg[F[_]]:\n      |    type Key\n      |\n      |    def defaultKey: Key\n      |\n      |    def fetch(key: Key): F[String]\n      |\n      |    def store(key: Key, value: String): F[Int]\n      |\n      |  \n      |  val idAlg: KeyValueAlg[Id] = new KeyValueAlg[Id]:\n      |    type Key = String\n      |\n      |    override val defaultKey: Key = \"primary\"\n      |\n      |    override def fetch(key: Key): Id[String] = s\"value:$key\"\n      |\n      |    override def store(key: Key, value: String): Id[Int] = key.length + value.length\n      |\n      |  val toOption: Id ~> Option = new (Id ~> Option):\n      |    override def apply[A](value: Id[A]): Option[A] = Option(value)\n      |\n      |  val functorK: FunctorK[KeyValueAlg] = Derive.functorK[KeyValueAlg]\n      |  val optionAlg: KeyValueAlg[Option] = functorK.mapK(idAlg)(toOption)\n      |  val fetched: Option[String] = optionAlg.fetch(optionAlg.defaultKey)\n      |  val stored: Option[Int] = optionAlg.store(optionAlg.defaultKey, \"updated\")\n      |\"\"\".stripMargin\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.typelevel/cats-tagless-core_3/0.16.5/src/test/scala/org_typelevel/cats_tagless_core_3/DeriveMacrosTest.scala\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_typelevel.cats_tagless_core_3\\n\\nimport dotty.tools.dotc.Driver\\nimport dotty.tools.dotc.interfaces.CompilerCallback\\nimport dotty.tools.dotc.interfaces.Diagnostic\\nimport dotty.tools.dotc.interfaces.SimpleReporter\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.graalvm.internal.tck.NativeImageSupport\\nimport org.junit.jupiter.api.Test\\n\\nimport java.nio.charset.StandardCharsets\\nimport java.nio.file.Files\\nimport java.nio.file.Path\\nimport java.uti