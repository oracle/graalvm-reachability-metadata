      {
          return _created;
      }
  
      @Override
      public final String toString()
      {
          return String.format("%s@%h::%s", getClass().getSimpleName(), this, getEndPoint());
      }
  
      public String toConnectionString()
      {
          return String.format("%s@%h",
              getClass().getSimpleName(),
