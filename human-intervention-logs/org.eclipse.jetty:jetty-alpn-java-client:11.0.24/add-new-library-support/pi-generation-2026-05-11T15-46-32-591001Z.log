      protected AbstractConnection(EndPoint endPoint, Executor executor)
      {
          if (executor == null)
              throw new IllegalArgumentException("Executor must not be null!");
          _endPoint = endPoint;
          _executor = executor;
          _readCallback = new ReadCallback();
      }
  
      @Override
