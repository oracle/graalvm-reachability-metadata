  package org_springframework_boot.spring_boot_jackson;
  
  import java.util.List;
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import tools.jackson.core.JsonGenerator;
  import tools.jackson.databind.SerializationContext;
  
  import org.springframework.beans.factory.aot.AotServices;
  import org.springframework.beans.factory.aot.BeanFactoryInitializationAotContribution;
  import org.springframework.beans.factory.aot.BeanFactoryInitializationAotProcessor;
  import org.springframework.beans.factory.support.DefaultListableBeanFactory;
  import org.springframework.beans.factory.support.RootBeanDefinition;
  import org.springframework.boot.jackson.JacksonComponent;
  import org.springframework.boot.jackson.ObjectValueSerializer;
  import org.springframework.core.io.support.SpringFactoriesLoader;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JacksonComponentModuleInnerJacksonComponentBeanFactoryInitializationAotProcessorTest {
  
  	static final String PROCESSOR_CLASS_NAME = "org.springframework.boot.jackson.JacksonComponentModule"
  			+ "$JacksonComponentBeanFactoryInitializationAotProcessor";
  
  	@Test
  	void processAheadOfTimeDiscoversInnerJacksonComponentClasses() {
  		DefaultListableBeanFactory beanFactory = new DefaultListableBeanFactory();
  		beanFactory.registerBeanDefinition("componentWithInnerSerializer",
  				new RootBeanDefinition(ComponentWithInnerSerializer.class));
  
  		BeanFactoryInitializationAotProcessor processor = AotServices
  			.factories(new SingleJacksonProcessorSpringFactoriesLoader(getClass().getClassLoader()))
  			.load(BeanFactoryInitializationAotProcessor.class)
  			.stream()
  			.filter((candidate) -> candidate.getClass().getName().equals(PROCESSOR_CLASS_NAME))
  			.findFirst()
  			.orElseThrow();
  		BeanFactoryInitializationAotContribution contribution = processor.processAheadOfTime(beanFactory);
  
  		assertThat(contribution).isNotNull();
  	}
  
  	@JacksonComponent
  	public static class ComponentWithInnerSerializer {
  
  		public static class Serializer extends ObjectValueSerializer<SampleValue> {
  
  			@Override
  			protected void serializeObject(SampleValue value, JsonGenerator jgen, SerializationContext context) {
  				jgen.writeStringProperty("component", value.name());
  			}
  
  		}
  
  	}
  
  	static final class SampleValue {
  
  		private final String name;
  
  		SampleValue(String name) {
  			this.name = name;
  		}
  
  		String name() {
  			return this.name;
  		}
  
  	}
  
  }
  
  final class SingleJacksonProcessorSpringFactoriesLoader extends SpringFactoriesLoader {
  
  	SingleJacksonProcessorSpringFactoriesLoader(ClassLoader classLoader) {
  		super(classLoader, Map.of(BeanFactoryInitializationAotProcessor.class.getName(),
  				List.of(JacksonComponentModuleInnerJacksonComponentBeanFactoryInitializationAotProcessorTest.PROCESSOR_CLASS_NAME)));
  	}
  
  }
