_CASE\", \"KEBAB_CASE\");\n\t}\n\n\tstatic final class SingleJacksonRuntimeHintsSpringFactoriesLoader extends SpringFactoriesLoader {\n\n\t\tSingleJacksonRuntimeHintsSpringFactoriesLoader(ClassLoader classLoader) {\n\t\t\tsuper(classLoader, Map.of(RuntimeHintsRegistrar.class.getName(), List.of(RUNTIME_HINTS_CLASS_NAME)));\n\t\t}\n\n\t}\n\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 319, "output": 1633, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 20896, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779162003449, "responseId": "resp_081761b997efcc0d016a0bdb93eaf4819db9494427e973b0a9"}}
