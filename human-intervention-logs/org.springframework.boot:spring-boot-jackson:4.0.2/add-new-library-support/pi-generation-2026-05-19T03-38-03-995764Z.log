ject> properties = Map.of(\"spring.jackson.find-and-add-modules\", \"false\",\n\t\t\t\t\"spring.jackson.property-naming-strategy\", \"SNAKE_CASE\");\n\t\tSpringApplication application = new SpringApplication(JacksonAutoConfiguration.class);\n\t\tapplication.setWebApplicationType(WebApplicationType.NONE);\n\t\tapplication.setDefaultProperties(properties);\n\n\t\ttry (ConfigurableApplicationContext context = application.run()) {\n\t\t\tJsonMapper mapper = context.getBean(JsonMapper.class);\n\n\t\t\tassertThat(mapper.writeValueAsString(new SampleValue(\"Spring Boot\")))\n\t\t\t\t.isEqualTo(\"{\\\"sample_name\\\":\\\"Spring Boot\\\"}\");\n\t\t}\n", "newText": "\t\tMap<String, Object> properties = Map.of(\"spring.jackson.find-and-add-modules\", false,\n\t\t\t\t\"spring.jackson.property-naming-strategy\", \"SNAKE_CASE\");\n\n\t\ttry (AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext()) {\n\t\t\tcontext.getEnvironment().getPropertySources().addFirst(new MapPropertySource(\"test\", properties));\n\t\t\tcontext.register(JacksonAutoConfiguration.class);\n\t\t\tcontext.refresh();\n\t\t\tJsonMapper mapper = context.getBean(JsonMapper.class);\n\n\t\t\tassertThat(mapper.writeValueAsString(new SampleValue(\"Spring Boot\")))\n\t\t\t\t.isEqualTo(\"{\\\"sample_name\\\":\\\"Spring Boot\\\"}\");\n\t\t}\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1025, "output": 1378, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 27491, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779161858957, "responseId": "resp_0898fde1534ab2a6016a0bdb03671c8194ab4035f83686f5c9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ACxA3fkV5n1yVEH3OfsWkmKh|fc_0898fde1534ab2a6016a0bdb11e0dc8194adfaa5659c93dd25", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/org.springframework.boot/spring-boo