ory.aot.AotServices;\\nimport org.springframework.core.io.support.SpringFactoriesLoader;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class JacksonAutoConfigurationInnerJacksonAutoConfigurationRuntimeHintsTest {\\n\\n\\tstatic final String RUNTIME_HINTS_CLASS_NAME = \\\"org.springframework.boot.jackson.autoconfigure.JacksonAutoConfiguration\\\"\\n\\t\\t\\t+ \\\"$JacksonAutoConfigurationRuntimeHints\\\";\\n\\n\\t@Test\\n\\tvoid registerHintsRegistersPropertyNamingStrategyFields() {\\n\\t\\tRuntimeHintsRegistrar registrar = AotServices\\n\\t\\t\\t.factories(new SingleJacksonRuntimeHintsSpringFactoriesLoader(getClass().getClassLoader()))\\n\\t\\t\\t.load(RuntimeHintsRegistrar.class)\\n\\t\\t\\t.stream()\\n\\t\\t\\t.filter((candidate) -> candidate.getClass().getName().equals(RUNTIME_HINTS_CLASS_NAME))\\n\\t\\t\\t.findFirst()\\n\\t\\t\\t.orElseThrow();\\n\\t\\tRuntimeHints hints = new RuntimeHints();\\n\\n\\t\\tregistrar.registerHints(hints, getClass().getClassLoader());\\n\\n\\t\\tTypeHint typeHint = hints.reflection().getTypeHint(PropertyNamingStrategies.class);\\n\\t\\tassertThat(typeHint).isNotNull();\\n\\t\\tList<String> fieldNames = typeHint.fields().map(FieldHint::getName).toList();\\n\\t\\tassertThat(fieldNames).contains(\\\"LOWER_CAMEL_CASE\\\", \\\"SNAKE_CASE\\\", \\\"KEBAB_CASE\\\");\\n\\t}\\n\\n\\tstatic final class SingleJacksonRuntimeHintsSpringFactoriesLoader extends SpringFactoriesLoader {\\n\\n\\t\\tSingleJacksonRuntimeHintsSpringFactoriesLoader(ClassLoader classLoader) {\\n\\t\\t\\tsuper(classLoader, Map.of(RuntimeHintsRegistrar.class.getName(), List.of(RUNTIME_HINTS_CLASS_NAME)));\\n\\t\\t}\\n\\n\\t}\\n\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 319, \"output\": 1633, \"cacheRead\": 18944, \"cacheWrite\": 0, \"totalTokens\": 20896, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \