            }
          }
      }
  
    override private[getquill] def prepareParams(statement: String, prepare: Prepare): Seq[String] = {
      withConnectionWrapped { conn =>
        prepare(conn.prepareStatement(statement), conn)._1.reverse.map(prepareParam)
      }
