erties\ntests/src/io.getquill/quill-engine_2.13/4.8.5/user-code-filter.json\nmetadata/com.github.spotbugs/spotbugs-annotations/4.8.6/reachability-metadata.json\nstats/com.github.spotbugs/spotbugs-annotations/4.8.6/stats.json\nstats/com.github.spotbugs/spotbugs-annotations/4.8.6/execution-metrics.json\ntests/src/com.github.spotbugs/spotbugs-annotations/4.8.6/build.gradle\ntests/src/com.github.spotbugs/spotbugs-annotations/4.8.6/settings.gradle\ntests/src/com.github.spotbugs/spotbugs-annotations/4.8.6/src/test/java/com_github_spotbugs/spotbugs_annotations/Spotbugs_annotationsTest.java\ntests/src/com.github.spotbugs/spotbugs-annotations/4.8.6/gradle.properties\ntests/src/com.github.spotbugs/spotbugs-annotations/4.8.6/user-code-filter.json\nstats/io.getquill/quill-engine_3/4.8.4/stats.json\nstats/io.getquill/quill-engine_3/4.8.4/execution-metrics.json\nstats/io.getquill/quill-engine_2.13/4.8.5/stats.json\nstats/io.getquill/quill-engine_2.13/4.8.5/execution-metrics.json\nstats/io.getquill/quill-jdbc_3/4.8.6/stats.json\nstats/io.getquill/quill-jdbc_3/4.8.6/execution-metrics.json\nstats/io.getquill/quill-util_3/4.8.4/stats.json\nstats/io.getquill/quill-util_3/4.8.4/execution-metrics.json\n","exit_code":0,"status":"completed"}}
