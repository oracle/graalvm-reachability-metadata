.Static)\n    44\t  }\n    45\t\n    46\t  @Test\n    47\t  def insertValueActionPreparesLiftedCaseClassFields(): Unit = {\n    48\t    val person: PersonRow = PersonRow(1, \"Ada\", 36, active = true)\n    49\t    val result: ActionMirror = context.run {\n    50\t      quote {\n    51\t        query[PersonRow].insertValue(lift(person))\n    52\t      }\n    53\t    }\n    54\t\n    55\t    assertThat(result.string)\n    56\t      .isEqualTo(\"INSERT INTO PersonRow (id,name,age,active) VALUES (?, ?, ?, ?)\")\n    57\t    assertThat(result.prepareRow.data)\n    58\t      .isEqualTo(List(\"_1\" -> person.id, \"_2\" -> person.name, \"_3\" -> person.age, \"_4\" -> person.active))\n    59\t    assertThat(result.info.executionType)\n    60\t      .isEqualTo(ExecutionType.Static)\n    61\t  }\n    62\t\n    63\t  @Test\n    64\t  def batchInsertActionGroupsLiftedRowsForPreparedExecution(): Unit = {\n    65\t    val people: List[PersonRow] = List(\n    66\t      PersonRow(1, \"Ada\", 36, active = true),\n    67\t      PersonRow(2, \"Grace\", 85, active = false)\n    68\t    )\n    69\t    val result: BatchActionMirror = context.run {\n    70\t      quote {\n    71\t        liftQuery(people).foreach(person => query[PersonRow].insertValue(person))\n    72\t      }\n    73\t    }\n    74\t\n    75\t    assertThat(result.groups.map { case (sql, rows) => (sql, rows.map(_.data)) })\n    76\t      .isEqualTo(\n    77\t        List(\n    78\t          \"INSERT INTO PersonRow (id,name,age,active) VALUES (?, ?, ?, ?)\" -> List(\n    79\t            List(\"_1\" -> people.head.id, \"_2\" -> people.head.name, \"_3\" -> people.head.age, \"_4\" -> people.head.active),\n    80\t            List(\"_1\" -> people(1).id, \"_2\" -> people(1).name, \"_3\" -> people(1).age, \"_4\" -> people(1).active)\n    81\t          )\n    82\t        )\n    83\t      )\n    84\t    assertThat(result.info.executionType)\n    85\t      .isEqualTo(ExecutionType.Static)\n    86\t  }\n    87\t}\n","exit_code":0,"