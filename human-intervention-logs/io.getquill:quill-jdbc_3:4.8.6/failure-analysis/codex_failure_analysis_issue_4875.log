o.dev/img/zio.png\\\"><meta data-rh=\\\"true\\\" name=\\\"twitter:image\\\" content=\\\"https://zio.dev/img/zio.png\\\"><meta data-rh=\\\"true\\\" property=\\\"og:url\\\" content=\\\"https://zio.dev/zio-quill/contexts\\\"><meta data-rh=\\\"true\\\" property=\\\"og:locale\\\" content=\\\"en\\\"><meta data-rh=\\\"true\\\" name=\\\"docusaurus_locale\\\" content=\\\"en\\\"><meta data-rh=\\\"true\\\" name=\\\"docsearch:language\\\" content=\\\"en\\\"><meta data-rh=\\\"true\\\" name=\\\"docusaurus_version\\\" content=\\\"current\\\"><meta data-rh=\\\"true\\\" name=\\\"docusaurus_tag\\\" content=\\\"docs-default-current\\\"><meta data-rh=\\\"true\\\" name=\\\"docsearch:version\\\" content=\\\"current\\\"><meta data-rh=\\\"true\\\" name=\\\"docsearch:docusaurus_tag\\\" content=\\\"docs-default-current\\\"><meta data-rh=\\\"true\\\" property=\\\"og:title\\\" content=\\\"Contexts | ZIO\\\"><meta data-rh=\\\"true\\\" name=\\\"description\\\" content=\\\"Contexts represent the database and provide an execution interface for queries.\\\"><meta data-rh=\\\"true\\\" property=\\\"og:description\\\" content=\\\"Contexts represent the database and provide an execution interface for queries.\\\"><link data-rh=\\\"true\\\" rel=\\\"icon\\\" href=\\\"/img/favicon.png\\\"><link data-rh=\\\"true\\\" rel=\\\"canonical\\\" href=\\\"https://zio.dev/zio-quill/contexts\\\"><link data-rh=\\\"true\\\" rel=\\\"alternate\\\" href=\\\"https://zio.dev/zio-quill/contexts\\\" hreflang=\\\"en\\\"><link data-rh=\\\"true\\\" rel=\\\"alternate\\\" href=\\\"https://zio.dev/zio-quill/contexts\\\" hreflang=\\\"x-default\\\"><link data-rh=\\\"true\\\" rel=\\\"preconnect\\\" href=\\\"https://IAX8GRSWEQ-dsn.algolia.net\\\" crossorigin=\\\"anonymous\\\"><script data-rh=\\\"true\\\" type=\\\"application/ld+json\\\">{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Official Libraries\\\",\\\"