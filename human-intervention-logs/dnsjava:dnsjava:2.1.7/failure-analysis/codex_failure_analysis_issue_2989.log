re.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.InputStream;\\nimport java.lang.reflect.Field;\\nimport java.lang.reflect.Method;\\nimport java.nio.charset.StandardCharsets;\\nimport java.util.Arrays;\\nimport java.util.Locale;\\nimport org.junit.jupiter.api.Test;\\nimport org.xbill.DNS.Name;\\nimport org.xbill.DNS.ResolverConfig;\\n\\npublic class ResolverConfigTest {\\n    @Test\\n    void refreshesResolverConfigurationThroughPublicApi() {\\n        String originalServer = System.getProperty(\\\"dns.server\\\");\\n        String originalSearch = System.getProperty(\\\"dns.search\\\");\\n        try {\\n            System.clearProperty(\\\"dns.server\\\");\\n            System.clearProperty(\\\"dns.search\\\");\\n\\n            ResolverConfig.refresh();\\n\\n            ResolverConfig config = ResolverConfig.getCurrentConfig();\\n            assertThat(config).isNotNull();\\n            assertThat(config.ndots()).isGreaterThanOrEqualTo(1);\\n        } finally {\\n            restoreProperty(\\\"dns.server\\\", originalServer);\\n            restoreProperty(\\\"dns.search\\\", originalSearch);\\n        }\\n    }\\n\\n    @Test\\n    void parsesWindowsIpConfigUsingResourceBundles() throws Exception {\\n        Locale originalLocale = Locale.getDefault();\\n        try {\\n            Locale.setDefault(Locale.US);\\n            ResolverConfig config = new ResolverConfig();\\n            setField(config, \\\"servers\\\", null);\\n            setField(config, \\\"searchlist\\\", null);\\n\\n            Method findWin = ResolverConfig.class.getDeclaredMethod(\\\"findWin\\\", InputStream.class);\\n            findWin.setAccessible(true);\\n            findWin.invoke(config, ipConfigOutput());\\n\\n            assertThat(config.servers()).containsExactly(\\\"192.0.2.53\\\", \\\"192.0.2.54\\\");\\n            assertThat(Arrays.stream(config.searchPath()).map(Name::toString))\\n                    .contains(\\\"workstation.example.com.\\\", \\\"example.com.\\\", \\\"example.org.\\\");\\n        } finally {\\n            Locale.setDefault(originalLocale);\\n        }\\n    }\\n\\n    private static InputStream ipConfigOutput() {\\n        String output = \\\"\\\"\\\"\\n                Host Name . . . . . . . . . . . . : workstation.example.com\\n                Primary Dns Suffix  . . . . . . . : example.com\\n                DNS Suffix Search List. . . . . . : example.org\\n                DNS Servers . . . . . . . . . . . : 192.0.2.53\\n                                                    192.0.2.54\\n                \\\"\\\"\\\";\\n        return new ByteArrayInputStream(output.getBytes(StandardCharsets.UTF_8));\\n    }\\n\\n    private static void setField(ResolverConfig config, String fieldName, Object value) throws Exception {\\n        Field field = ResolverConfig.class.getDeclaredField(fieldName);\\n        field.setAccessible(true);\\n        field.set(config, value);\\n    }\\n\\n    private static void restoreProperty(String propertyName, String value) {\\n        if (value == null) {\\n            System.clearProperty(propertyName);\\n        } else {\\n            System.setProperty(propertyName, value);\\n        }\\n    }\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 647, \"output\": 1873, \"cacheRead\": 54272, \"cacheWrite\": 0, \"totalTokens\": 56792, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777808116337, \"responseId\": \"resp_0daabe48e56945910169f732f5032081a286dd349ebd2789c4\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_K2BSnTNtf2ZHlOIjF7rYhoRg|fc_0daabe48e56945910169f73303873481a28507e7ee6ba8dded\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 3229 bytes to tests/src/dnsjava/dnsjava/2.1.7/src/test/java/dnsjava/dnsjava/ResolverConfigTest.java\"