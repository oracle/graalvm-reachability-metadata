e fallback behavior**\\\\n\\\\nI'm looking into the Java ResourceBundle.Control fallback locale. The method getFallbackLocale returns the default locale when the target locale isn’t the default. For a Locale with empty parameters, it might revert to Locale.US, which suggests it could end up picking en_US again instead of the base. The ResourceBundle algorithm indicates that the candidate locales start with [root], and if no bundle is found, it defaults back to Locale.getDefault. However, if base is found, it shouldn't need to fallback, but en_US might still be cached from a previous request.\\\"}]}\"}, {\"type\": \"toolCall\", \"id\": \"call_Y1C2zhA1MPipAUU6urrHAA1m|fc_0daabe48e56945910169f73322a0b481a2ae40dc1d61ebd1e6\", \"name\": \"read\", \"arguments\": {\"path\": \"tests/src/dnsjava/dnsjava/2.1.7/build.gradle\"}}, {\"type\": \"toolCall\", \"id\": \"call_IKJA9L7aXca8ljL2C6A3EH1L|fc_0daabe48e56945910169f73322a0cc81a2aa46820724211bf0\", \"name\": \"read\", \"arguments\": {\"path\": \"tests/src/dnsjava/dnsjava/2.1.7/src/test/java/dnsjava/dnsjava/ResolverConfigTest.java\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 682, \"output\": 970, \"cacheRead\": 56832, \"cacheWrite\": 0, \"totalTokens\": 58484, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777808147914, \"responseId\": \"resp_0daabe48e56945910169f73314829481a28c836693031f05a2\"}}\n5281:      void parsesWindowsIpConfigUsingResourceBundles() throws Exception {\n5312:      private static void setField(ResolverConfig config, String fieldName, Object value) throws Exception {\n5326:[recv] {\"type\": \"message_start\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_IKJA9L7aXca8ljL2C6A3EH1L|fc_0daabe48e56945910169f73322a0cc81a2aa46820724211bf0\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage dnsjava.dnsjava;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.InputStream;\\nimport java.lang.reflect.Field;\\nimport java.lang.reflect.Method;\\nimport java.nio.charset.StandardCharsets;\\nimport java.util.Arrays;\\nimport java.util.Locale;\\nimport org.junit.jupiter.api.Test;\\nimport org.xbill.DNS.Name;\\nimport org.xbill.DNS.ResolverConfig;\\n\\npublic class ResolverConfigTest {\\n    @Test\\n    void refreshesResolverConfigurationThroughPublicApi() {\\n        String originalServer = System.getProperty(\\\"dns.server\\\");\\n        String originalSearch = System.getProperty(\\\"dns.search\\\");\\n        try {\\n            System.clearProperty(\\\"dns.server\\\");\\n            System.clearProperty(\\\"dns.search\\\");\\n\\n            ResolverConfig.refresh();\\n\\n            ResolverConfig config = ResolverConfig.getCurrentConfig();\\n            assertThat(config).isNotNull();\\n            assertThat(config.ndots()).isGreaterThanOrEqualTo(1);\\n        } finally {\\n            restoreProperty(\\\"dns.server\\\", originalServer);\\n            restoreProperty(\\\"dns.search\\\", originalSearch);\\n        }\\n    }\\n\\n    @Test\\n    void parsesWindowsIpConfigUsingResourceBundles() throws Exception {\\n        Locale originalLocale = Locale.getDefault();\\n        try {\\n            Locale.setDefault(Locale.US);\\n            ResolverConfig config = new ResolverConfig();\\n            setField(config, \\\"servers\\\", null);\\n            setField(config, \\\"searchlist\\\", null);\\n\\n            Method findWin = ResolverConfig.class.getDeclaredMethod(\\\"findWin\\\", InputStream.class);\\n            findWin.setAccessible(true);\\n            findWin.invoke(config, ipConfigOutput());\\n\\n            assertThat(config.servers()).containsExactly(\\\"192.0.2.53\\\", \\\"192.0.2.54\\\");\\n            assertThat(Arrays.stream(config.searchPath()).map(Name::toString))\\n                    .contains(\\\"workstation.example.com.\\\", \\\"example.com.\\\", \\\"example.org.\\\");\\n        } finally {\\n            Locale.setDefault(originalLocale);\\n        }\\n    }\\n\\n    private static InputStream ipConfigOutput() {\\n        String output = \\\"\\\"\\\"\\n                Host Name . . . . . . . . . . . . : workstation.example.com\\n                Primary Dns Suffix  . . . . . . . : example.com\\n                DNS Suffix Search List. . . . . . : example.org\\n                DNS Servers . . . . . . . . . . . : 192.0.2.53\\n                                                    192.0.2.54\\n                \\\"\\\"\\\";\\n        return new ByteArrayInputStream(output.getBytes(StandardCharsets.UTF_8));\\n    }\\n\\n    private static void setField(ResolverConfig config, String fieldName, Object value) throws Exception {\\n        Field field = ResolverConfig.class.getDeclaredField(fieldName);\\n        field.setAccessible(true);\\n        field.set(config, value);\\n    }\\n\\n    private static void restoreProperty(String propertyName, String value) {\\n        if (value == null) {\\n            System.clearProperty(propertyName);\\n        } else {\\n            System.setProperty(propertyName, value);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1777808162953}}\n5327:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_IKJA9L7aXca8ljL2C6A3EH1L|fc_0daabe48e56945910169f73322a0cc81a2aa46820724211bf0\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npa