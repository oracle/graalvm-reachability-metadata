                          boolean retry = trial < lastTrial && e.isRetryWorthy();
                          if (!retry && !checksumValidator.handle(e)) {
                              throw e;
                          }
                          listener.transferCorrupted(e);
                          if (retry) {
                              checksumValidator.retry();
                          } else {
                              break;
                          }
                      }
                  }
                  tempFile.move();
                  if (persistedChecksums) {
                      checksumValidator.commit();
                  }
              }
          }
      }
  
