          @Override
          public boolean fetchChecksum(URI remote, Path local) throws Exception {
              try {
                  transporter.get(new GetTask(remote).setDataPath(local));
              } catch (Exception e) {
                  if (transporter.classify(e) == Transporter.ERROR_NOT_FOUND) {
                      return false;
