              <!-- BMP_IMAGES_EXCLUDES -->
              <exclude>**/*.bmp</exclude>
              <!-- PMD files -->
              <exclude>**/.pmd</exclude>
              <!-- PMD Ruleset files -->
              <exclude>**/.pmdruleset.xml</exclude>
              <!-- Checkstyle files -->
              <exclude>**/.checkstyle</exclude>
              <!-- BIN files -->
              <exclude>**/bin/**/*</exclude>
              <!-- The IP clearance XML doc -->
              <exclude>docs/kerby-ip-clearance.xml</exclude>
              <!-- The resources files -->
