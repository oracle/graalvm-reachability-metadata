ent\");\n    }\n\n    private static final class ComponentDescriptor {\n        private static String descriptorType = \"component\";\n\n        private final String name;\n        private final int priority;\n        private final String owner;\n        private transient String lifecycle;\n\n        private ComponentDescriptor(String name, int priority, String lifecycle) {\n            this.name = name;\n            this.priority = priority;\n            this.owner = null;\n            this.lifecycle = lifecycle;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 4517, "output": 952, "cacheRead": 30208, "cacheWrite": 0, "totalTokens": 35677, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780733529989, "responseId": "resp_04d0edc95ee8f177016a23d65a907c819389d60c4d7cc5acca"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_f74tXgFWmZb9qq5IbsApuGUX|fc_04d0edc95ee8f177016a23d6650d50819382ecf0b49fdfafc5", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2092 bytes to tests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/src/test/java/io_sundr/sundr_codegen_velocity_nodeps/ReflectionToStringBuilderTest.java"}], "isError": false, "timestamp": 1780733545992}]}
