alityRecord(String name, int priority, String runtimeNote) {\n            assertThat(TYPE).isEqualTo(\"record\");\n            this.name = name;\n            this.priority = priority;\n            this.runtimeNote = runtimeNote;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 975, "output": 933, "cacheRead": 18944, "cacheWrite": 0, "totalTokens": 20852, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780732861990, "responseId": "resp_088290cb6f544e78016a23d3be95708190af01eeeca45b6b0b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_Ia2snuFojogiwYnaeu5Y8uIL|fc_088290cb6f544e78016a23d3cf292c8190a0280aa9af45fe45", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1602 bytes to tests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/src/test/java/io_sundr/sundr_codegen_velocity_nodeps/EqualsBuilderTest.java"}], "isError": false, "timestamp": 1780732885880}]}
