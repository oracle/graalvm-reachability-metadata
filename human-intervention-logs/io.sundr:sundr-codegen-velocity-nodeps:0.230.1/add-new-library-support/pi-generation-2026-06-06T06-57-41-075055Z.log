               .hasSize(2)\n                .containsEntry(\"present\", \"value\")\n                .containsEntry(\"nullable\", null);\n        assertThat(restored.get(\"missing\")).isEqualTo(\"fallback\");\n        assertThat(restored).doesNotContainKey(\"missing\");\n        assertThat(restored.get(\"nullable\")).isNull();\n    }\n\n    private static byte[] serialize(DefaultedMap<String, String> map) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(map);\n        }\n        return outputStream.toByteArray();\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static DefaultedMap<String, String> deserializeDefaultedMap(byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(DefaultedMap.class);\n            return (DefaultedMap<String, String>) restored;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780729011815}, {"role": "toolResult", "toolCallId": "call_T7BmLdR2MLTOjfvoi7odnHNR|fc_0149044bce421b6b016a23c4b383188194a5652baa109929ff", "toolName": "bash", "content": [{"type": "text", "text": "tests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/build.gradle\ntests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/build/jacoco/test.exec\ntests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/build/libs/io.sundr.sundr-codegen-velocity-nodeps_tests.jar\ntests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/build/native/generated/generateTestResourcesConfigFile/resource-config.json\ntests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/build/natively-collected/runs/cycle-0/binary-exit-code\ntests/src/io.sundr/s