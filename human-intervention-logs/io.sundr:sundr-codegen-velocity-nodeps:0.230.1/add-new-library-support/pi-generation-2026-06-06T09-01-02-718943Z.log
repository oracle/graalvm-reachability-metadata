    .isInstanceOf(UnsupportedOperationException.class);\n        assertThat(delegate).containsEntry(\"alpha\", 1);\n    }\n\n    @SuppressWarnings({\"unchecked\", \"rawtypes\"})\n    private static Set<Map.Entry<String, Integer>> unmodifiableEntrySet(\n            Map<String, Integer> delegate) {\n        return (Set) UnmodifiableEntrySet.decorate(delegate.entrySet());\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2473, "output": 1012, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 28573, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780736433228, "responseId": "resp_0456f4ac9ade2dc1016a23e1b315b88193a1a71af5574383b7"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_SCoa3qJMi9YYUscmEstwaoGb|fc_0456f4ac9ade2dc1016a23e1bfbba8819389aeafa621d81762", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1817 bytes to tests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/src/test/java/io_sundr/sundr_codegen_velocity_nodeps/UnmodifiableEntrySetTest.java"}], "isError": false, "timestamp": 1780736453886}]}
