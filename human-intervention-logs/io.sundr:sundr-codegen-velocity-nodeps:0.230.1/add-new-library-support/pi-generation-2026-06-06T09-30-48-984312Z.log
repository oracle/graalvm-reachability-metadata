Context() {\n        RuntimeInstance runtime = new RuntimeInstance();\n        Properties properties = shadedRuntimeProperties();\n        properties.setProperty(\n                RuntimeConstants.EVALUATE_CONTEXT_CLASS,\n                NonVelocityContext.class.getName());\n        runtime.init(properties);\n\n        assertThatThrownBy(() -> runtime.evaluate(\n                        new VelocityContext(),\n                        new StringWriter(),\n                        \"evaluate-context-test\",\n                        \"#evaluate('rendered by the evaluate directive')\"))\n                .isInstanceOf(RuntimeException.class)\n                .hasMessageContaining(\"does not implement\")\n                .hasMessageContaining(\"io.sundr.deps.org.apache.velocity.context.Context\");\n    }\n", "newText": "import io.sundr.deps.org.apache.velocity.VelocityContext;\nimport io.sundr.deps.org.apache.velocity.context.EvaluateContext;\nimport io.sundr.deps.org.apache.velocity.context.InternalContextAdapterImpl;\nimport io.sundr.deps.org.apache.velocity.runtime.RuntimeConstants;\nimport io.sundr.deps.org.apache.velocity.runtime.RuntimeInstance;\nimport java.util.Properties;\nimport org.junit.jupiter.api.Test;\n\npublic class EvaluateContextTest {\n    @Test\n    void rejectsConfiguredEvaluateContextClassThatDoesNotImplementContext() {\n        RuntimeInstance runtime = new RuntimeInstance();\n        Properties properties = shadedRuntimeProperties();\n        properties.setProperty(\n                RuntimeConstants.EVALUATE_CONTEXT_CLASS,\n                NonVelocityContext.class.getName());\n        runtime.init(properties);\n        InternalContextAdapterImpl context = new InternalContextAdapterImpl(new VelocityContext());\n\n        assertThatThrownBy(() -> new EvaluateContext(context, runtime))\n                .isInstanceOf(RuntimeException.class)\n                .hasMessageContaining(\"does not implement\")\n                .hasMessageContaining(\"io.sundr.deps.org.apache.velocity.context.Context\");\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 334, "output": 856, "cacheRead": 44032, "cacheWrite": 0, "totalTokens": 45222, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780738369200, "responseId": "resp_0f80ec2c575d5b8d016a23e9420870819484afd69ea515022b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ALdH7tUUcrfqe5SzBC2B7il4|fc_0f80ec2c575d5b8d016a23e949dd8c8194bfc45f30e7386437", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 1 block(s) in tests/src/io.sundr/sundr-codegen-velocity-nodeps/0.230.1/src/test/java/io_sundr/sundr_codegen_velocity_nodeps/EvaluateContextTest.java."}], "details": {"diff": "    ...\n  8 \n  9 import static org.assertj.core.api.Assertions.assertThatThrownBy;\n 10 \n 11 import io.sundr.deps.org.apache.velocity.VelocityContext;\n+12 import io.sundr.deps.org.apache.velocity.context.EvaluateContext;\n+13 import io.sundr.deps.org.apache.velocity.context.InternalContextAdapterImpl;\n 12 import io.sundr.deps.org.apache.velocity.runtime.RuntimeConstants;\n 13 import io.sundr.deps.org.apache.velocity.runtime.RuntimeInstance;\n-14 import java.io.StringWriter;\n 15 import java.util.Properties;\n 16 import org.junit.jupiter.api.Test;\n 17 \n 18 public class EvaluateContextTest {\n    ...\n 23         properties.setProperty(\n 24                 RuntimeConstants.EVALUATE_CONTEXT_CLASS,\n 25                 NonVelocityContext.class.getName());\n 26         runtime.init(properties);\n+28         InternalContextAdapterImpl context = new InternalContextAdapterImpl(new VelocityContext());\n 27 \n-28         assertThatThrownBy(() -> runtime.evaluate(\n-29                         new VelocityContext(),\n-30                         new StringWriter(),\n-31                         \"evaluate-context-test\",\n-32                         \"#evalu