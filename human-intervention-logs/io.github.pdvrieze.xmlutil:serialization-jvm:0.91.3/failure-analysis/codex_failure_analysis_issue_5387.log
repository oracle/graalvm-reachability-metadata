       indentString = \\\"  \\\"\\n        }\\n        val catalog = Catalog(\\n            id = \\\"cat-1\\\",\\n            owner = Owner(name = \\\"Ada\\\", label = \\\"primary curator\\\"),\\n            books = listOf(\\n                Book(isbn = \\\"978-1\\\", title = \\\"XML & Kotlin\\\", authors = listOf(\\\"Ada\\\", \\\"Grace\\\")),\\n                Book(isbn = \\\"978-2\\\", title = \\\"Native Image\\\", authors = listOf(\\\"Linus\\\")),\\n            ),\\n            description = Description(\\\"Uses <CDATA> & ordinary entities safely\\\"),\\n        )\\n\\n        val encoded: String = xml.encodeToString(Catalog.serializer(), catalog)\\n\\n        assertThat(encoded)\\n            .contains(\\\"catalog\\\")\\n            .contains(\\\"xmlns:c=\\\\\\\"$CATALOG_NS\\\\\\\"\\\")\\n            .contains(\\\"id=\\\\\\\"cat-1\\\\\\\"\\\")\\n            .contains(\\\"isbn=\\\\\\\"978-1\\\\\\\"\\\")\\n            .contains(\\\"<![CDATA[Uses <CDATA> & ordinary entities safely]]>\\\")\\n            .contains(\\\"<author>Ada</author>\\\")\\n        assertThat(xml.decodeFromString(Catalog.serializer(), encoded)).isEqualTo(catalog)\\n\\n        val descriptor = xml.xmlDescriptor(Catalog.serializer())\\n        assertThat(descriptor.tagName).isEqualTo(QName(CATALOG_NS, \\\"catalog\\\", \\\"c\\\"))\\n        assertThat(descriptor.elementsCount).isEqualTo(4)\\n    }\\n\\n    @Test\\n    fun writerAndReaderEntryPointsUseTheSameFormatCacheAndConfiguration(): Unit {\\n        val xml = XML {\\n            xmlDeclMode = XmlDeclMode.None\\n            indentString = \\\" \\\"\\n        }.copy {\\n            defaultToGenericParser = true\\n            indentString = \\\"    \\\"\\n        }\\n        val catalog = Catalog(\\n            id = \\\"streamed\\\",\\n            owner = Owner(name = \\\"Stream\\\", label = \\\"writer\\\"),\\n            books = listOf(Book(isbn = \\\"stream-1\\\", title = \\\"Streaming\\\", authors = listOf(\\\"Reader\\\"))),\\n            desc