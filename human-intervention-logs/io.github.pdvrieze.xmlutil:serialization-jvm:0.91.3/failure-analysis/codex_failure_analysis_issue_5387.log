xmlutil.serialization.XML\\nimport nl.adaptivity.xmlutil.serialization.XmlAfter\\nimport nl.adaptivity.xmlutil.serialization.XmlBefore\\nimport nl.adaptivity.xmlutil.serialization.XmlElement\\nimport nl.adaptivity.xmlutil.serialization.XmlSerialName\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\nimport javax.xml.namespace.QName\\n\\npublic class RootNameAndOrderingTest {\\n    @Test\\n    fun explicitRootQNameOverridesDescriptorNameAndRoundTrips(): Unit {\\n        val xml = XML {\\n            xmlDeclMode = XmlDeclMode.None\\n            repairNamespaces = true\\n        }\\n        val rootName = QName(ROOT_NAMESPACE, \\\"manifest\\\", \\\"m\\\")\\n        val manifest = RootNamedManifest(\\n            id = \\\"manifest-42\\\",\\n            title = \\\"Native image metadata\\\",\\n            owner = \\\"xmlutil\\\",\\n        )\\n\\n        val encoded: String = xml.encodeToString(RootNamedManifest.serializer(), manifest, rootName)\\n\\n        assertThat(encoded)\\n            .contains(\\\"<m:manifest\\\")\\n            .contains(\\\"xmlns:m=\\\\\\\"$ROOT_NAMESPACE\\\\\\\"\\\")\\n            .contains(\\\"id=\\\\\\\"manifest-42\\\\\\\"\\\")\\n            .contains(\\\"Native image metadata\\\")\\n        assertThat(xml.xmlDescriptor(RootNamedManifest.serializer(), rootName).tagName).isEqualTo(rootName)\\n        assertThat(xml.decodeFromString(RootNamedManifest.serializer(), encoded, rootName)).isEqualTo(manifest)\\n    }\\n\\n    @Test\\n    fun beforeAndAfterAnnotationsReorderElementChildrenDuringEncoding(): Unit {\\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\\n        val event = OrderedLifecycleEvent(\\n            last = \\\"archive\\\",\\n            middle = \\\"publish\\\",\\n            first = \\\"build\\\",\\n        )\\n\\n        val encoded: String = xml.encodeToString(OrderedLifecycleEvent.serializer(), event)\\n\\n        val firstIndex: Int = encoded.indexOf(\\\"<first>build</first>\\\")\\n        val middleIndex: Int = encoded.indexOf(\\\"<middle>publish</middle>\\\")\\n        val lastIndex: Int = encoded.indexOf(\\\"<last>archive</last>\\\")\\n        assertThat(firstIndex).isGreaterThanOrEqualTo(0)\\n        assertThat(middleIndex).isGreaterThan(firstIndex)\\n        assertThat(lastIndex).isGreaterThan(middleIndex)\\n        assertThat(xml.decodeFromString(OrderedLifecycleEvent.serializer(), encoded)).isEqualTo(event)\\n    }\\n\\n    private companion object {\\n        private const val ROOT_NAMESPACE: String = \\\"urn:test:explicit-root\\\"\\n    }\\n}\\n\\n@Serializable\\n@XmlSerialName(\\\"payload\\\")\\nprivate data class RootNamedManifest(\\n    @XmlElement(false)\\n    val id: String,\\n    @XmlElement(true)\\n    val title: String,\\n    @XmlElement(true)\\n    val owner: String,\\n)\\n\\n@Serializable\\n@XmlSerialName(\\\"lifecycle\\\")\\nprivate data class OrderedLifecycleEvent(\\n    @XmlElement(true)\\n    @XmlAfter(\\\"middle\\\")\\n    val last: String,\\n    @XmlElement(true)\\n    val middle: String,\\n    @XmlElement(true)\\n    @XmlBefore(\\\"middle\\\")\\n    val first: String,\\n)\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"usage\": {\"input\": 3518, \"output\": 2001, \"cacheRead\": 81920, \"cacheWrite\": 0, \"totalTokens\": 87439, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timestamp\": 1777905905590, \"responseId\": \"resp_0066cfd37b3aaa770169f8b0f267fc81938d08b73b6373e47a\"}, \"toolResults\": [{\"role\": \"toolResult\", \"toolCallId\": \"call_s1naB88Rnx9WdcgN4JjvEDDU|fc_0066cfd37b3aaa770169f8b10219948193ad187b7612e69ae7\", \"toolName\": \"write\", \"content\": [{\"type\": \"text\", \"text\": \"Successfully wrote 3197 bytes to tests/src/io.github.pdvrieze.xmlutil/serialization-jvm/0.91.3/src/test/kotlin/io_github_pdvrieze_xmlutil/serialization_jvm/RootNameAndOrderingTest.kt\"}], \"isError\": false,