ed=\\\"ignored\\\">\\n              <setting name=\\\"theme\\\">dark</setting>\\n              <setting name=\\\"pageSize\\\">50</setting>\\n              <ignored-child>ignored</ignored-child>\\n            </preferences>\\n        \\\"\\\"\\\".trimIndent()\\n        assertThatThrownBy { xml.decodeFromString(Preferences.serializer(), withUnknownContent) }\\n            .isInstanceOf(UnknownXmlFieldException::class.java)\\n\\n        val forgivingXml = XML {\\n            xmlDeclMode = XmlDeclMode.None\\n            unknownChildHandler = nl.adaptivity.xmlutil.serialization.XmlConfig.IGNORING_UNKNOWN_CHILD_HANDLER\\n        }\\n        assertThat(forgivingXml.decodeFromString(Preferences.serializer(), withUnknownContent))\\n            .isEqualTo(preferences)\\n    }\\n\\n    @Test\\n    fun polymorphicSealedValuesUseConfiguredSerializersModule(): Unit {\\n        val module = SerializersModule {\\n            polymorphic(Notification::class) {\\n                subclass(EmailNotification::class)\\n                subclass(SmsNotification::class)\\n            }\\n        }\\n        val xml = XML(module) { xmlDeclMode = XmlDeclMode.None }\\n        val batch = NotificationBatch(\\n            notifications = listOf(\\n                EmailNotification(address = \\\"ada@example.test\\\", subject = \\\"Build passed\\\"),\\n                SmsNotification(number = \\\"+155501\\\", message = \\\"Native image ready\\\"),\\n            ),\\n        )\\n\\n        val encoded: String = xml.encodeToString(NotificationBatch.serializer(), batch)\\n\\n        assertThat(encoded)\\n            .contains(\\\"notifications\\\")\\n            .contains(\\\"email\\\")\\n            .contains(\\\"sms\\\")\\n            .contains(\\\"Build passed\\\")\\n        assertThat(xml.decodeFromString(NotificationBatch.serializer(), encoded)).isEqualTo(batch)\\n    }\\n\\n    @Test\\n    fun builtInXmlFragmentAndDomSerializersPreserveEmbeddedMarkup(): Unit {\\n        val xml = XML { xmlDeclM