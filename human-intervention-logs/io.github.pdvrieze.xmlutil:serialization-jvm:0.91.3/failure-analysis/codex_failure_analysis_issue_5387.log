ativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_github_pdvrieze_xmlutil.serialization_jvm\\n\\nimport kotlinx.serialization.Serializable\\nimport nl.adaptivity.xmlutil.XmlDeclMode\\nimport nl.adaptivity.xmlutil.serialization.XML\\nimport nl.adaptivity.xmlutil.serialization.XmlAfter\\nimport nl.adaptivity.xmlutil.serialization.XmlBefore\\nimport nl.adaptivity.xmlutil.serialization.XmlElement\\nimport nl.adaptivity.xmlutil.serialization.XmlSerialName\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\nimport javax.xml.namespace.QName\\n\\npublic class RootNameAndOrderingTest {\\n    @Test\\n    fun explicitRootQNameOverridesDescriptorNameAndRoundTrips(): Unit {\\n        val xml = XML {\\n            xmlDeclMode = XmlDeclMode.None\\n            repairNamespaces = true\\n        }\\n        val rootName = QName(ROOT_NAMESPACE, \\\"manifest\\\", \\\"m\\\")\\n        val manifest = RootNamedManifest(\\n            id = \\\"manifest-42\\\",\\n            title = \\\"Native image metadata\\\",\\n            owner = \\\"xmlutil\\\",\\n        )\\n\\n        val encoded: String = xml.encodeToString(RootNamedManifest.serializer(), manifest, rootName)\\n\\n        assertThat(encoded)\\n            .contains(\\\"<m:manifest\\\")\\n            .contains(\\\"xmlns:m=\\\\\\\"$ROOT_NAMESPACE\\\\\\\"\\\")\\n            .contains(\\\"id=\\\\\\\"manifest-42\\\\\\\"\\\")\\n            .contains(\\\"Native image metadata\\\")\\n        assertThat(xml.xmlDescriptor(RootNamedManifest.serializer(), rootName).tagName).isEqualTo(rootName)\\n        assertThat(xml.decodeFromString(RootNamedManifest.serializer(), encoded, rootName)).isEqualTo(manifest)\\n    }\\n\\n    @Test\\n    fun beforeAndAfterAnnotationsReorderElementChildrenDuringEncoding(): Unit {\\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\\n        val event = OrderedLifecycleEvent(\\n            last = \\\"archive\\\",\\n            middle = \\\"publish\\\",\\n            first = \\\"build\\\",\\n        )\\n\\n        val encoded: String = xml.encodeToString(OrderedLifecycleEvent.serializer(), event)\\n\\n        val firstIndex: Int = encoded.indexOf(\\\"<first>build</first>\\\")\\n        val middleIndex: Int = encoded.indexOf(\\\"<middle>publish</middle>\\\")\\n        val lastIndex: Int = encoded.indexOf(\\\"<last>archive</last>\\\")\\n        assertThat(firstIndex).isGreaterThanOrEqualTo(0)\\n        assertThat(middleIndex).isGreaterThan(firstIndex)\\n        assertThat(lastIndex).isGreaterThan(middleIndex)\\n        assertThat(xml.decodeFromString(OrderedLifecycleEvent.serializer(), encoded)).isEqualTo(event)\\n    }\\n\\n    private companion object {\\n        private const val ROOT_NAMESPACE: String = \\\"urn:test:explicit-root\\\"\\n    }\\n}\\n\\n@Serializable\\n@XmlSerialName(\\\"payload\\\")\\nprivate data class RootNamedManifest(\\n    @XmlElement(false)\\n    val id: String,\\n    @XmlElement(true)\\n    val title: String,\\n    @XmlElement(true)\\n    val owner: String,\\n)\\n\\n@Serializable\\n@XmlSerialName(\\\"lifecycle\\\")\\nprivate data class OrderedLifecycleEvent(\\n    @XmlElement(true)\\n    @XmlAfter(\\\"middle\\\")\\n    val last: String,\\n    @XmlElement(true)\\n    val middle: String,\\n    @XmlElement(true)\\n    @XmlBefore(\\\"middle\\\")\\n    val first: String,\\n)\\n\"}\n16947:[tool-call] end id=call_s1naB88Rnx9WdcgN4JjvEDDU|fc_0066cfd37b3aaa770169f8b10219948193ad187b7612e69ae7 name=write args={\"path\": \"tests/src/io.github.pdvrieze.xmlutil/serialization-jvm/0.91.3/src/test/kotlin/io_github_pdvrieze_xmlutil/serialization_jvm/RootNameAndOrderingTest.kt\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_github_pdvrieze_xmlutil.serialization_jvm\\n\\nimport kotlinx.serialization.Serializable\\nimport nl.adaptivity.xmlutil.XmlDeclMode\\nimport nl.adaptivity.xmlutil.serialization.XML\\nimport nl.adaptivity.xmlutil.serialization.XmlAfter\\nimport nl.adaptivity.xmlutil.serialization.XmlBefore\\nimport nl.adaptivity.xmlutil.serialization.XmlElement\\nimport nl.adaptivity.xmlutil.serialization.XmlSerialName\\nimport org.assertj.core.api.Assertions.assertThat\\nimport org.junit.jupiter.api.Test\\nimport javax.xml.namespace.QName\\n\\npublic class RootNameAndOrderingTest {\\n    @Test\\n    fun explicitRootQNameOverridesDescriptorNameAndRoundTrips(): Unit {\\n        val xml = XML {\\n            xmlDeclMode = XmlDeclMode.None\\n            repairNamespaces = true\\n        }\\n        val rootName = QName(ROOT_NAMESPACE, \\\"manifest\\\", \\\"m\\\")\\n        val manifest = RootNamedManifest(\\n            id = \\\"manifest-42\\\",\\n            title = \\\"Native image metadata\\\",\\n            owner = \\\"xmlutil\\\",\\n        )\\n\\n        val encoded: String = xml.encodeToString(RootNamedManifest.serializer(), manifest, rootName)\\n\\n        assertThat(encoded)\\n            .contains(\\\"<m:manifest\\\")\\n            .contains(\\\"xmlns:m=\\\\\\\"$ROOT_NAMESPACE\\\\\\\"\\\")\\n            .contains(\\\"id=\\\\\\\"manifest-42\\\\\\\"\\\")\\n            .contains(\\\"Native image metadata\\\")\\n        assertThat(xml.xmlDescriptor(RootNamedManifest.serializer(), rootName).tagName).isEqualTo(rootName)\\n        assertThat(xml.decodeFromString(RootNamedManifest.serializer(), encoded, rootName)).isEqualTo(manifest)\\n    }\\n\\n    @Test\\n    fun beforeAndAfterAnnotationsReorderElementChildrenDuringEncoding(): Unit {\\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\\n        val event = OrderedLifecycleEvent(\\n            last = \\\"archive\\\",\\n            middle = \\\"publish\\\",\\n            first = \\\"build\\\",\\n        )\\n\\n        val encoded: String = xml.encodeToString(OrderedLifecycleEvent.serializer(), event)\\n\\n        val firstIndex: Int = encoded.indexOf(\\\"<first>build</first>\\\")\\n        val middleIndex: Int = encoded.indexOf(\\\"<middle>publish</middle>\\\")\\n        val lastIndex: Int = encoded.indexOf(\\\"<last>archive</last>\\\")\\n        assertThat(firstIndex).isGreaterThanOrEqualTo(0)\\n        assertThat(middleIndex).isGreaterThan(firstIndex)\\n        assertThat(lastIndex).isGreaterThan(middleIndex)\\n        assertThat(xml.decodeFromString(OrderedLifecycleEvent.serializer(), encoded)).isEqualTo(event)\\n    }\\n\\n    private companion object {\\n        private const val ROOT_NAMESPACE: String = \\\"urn:test:explicit-root\\\"\\n    }\\n}\\n\\n@Serializable\\n@XmlSerialName(\\\"payload\\\")\\nprivate data class RootNamedManifest(\\n    @XmlElement(false)\\n    val id: String,\\n    @XmlElement(true)\\n    val title: String,\\n    @XmlElement(true)\\n    val owner: String,\\n)\\n\\n@Serializable\\n@XmlSerialName(\\\"lifecycle\\\")\\nprivate data class OrderedLifecycleEvent(\\n    @XmlElement(true)\\n    @XmlAfter(\\\"middle\\\")\\n    val last: String,\\n    @XmlElement(true)\\n    val middle: String,\\n    @XmlElement(true)\\n    @XmlBefore(\\\"middle\\\")\\n    val first: String,\\n)\\n\"}\n16948:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"**Testing XML features**\\n\\nI need to add new tests but wonder if the existing ones still run. I'll opt for robust testing, and maybe the existing tests now pass, but we haven't run them. I should keep the existing tests unchanged while considering a feature like `XmlDefault`. I need to clarify behavior and perhaps use `XML.Companion` for simpler, high coverage. There are details like root QName override and XML declaration modes, and I might include two tests to ensure coverage.\\n\\n**Examining XML serialization**\\n\\nI’m looking at how encoding would use a structure like `<m:manifest xmlns:m=... id=...><m:title>...`, and decoding it with the right me