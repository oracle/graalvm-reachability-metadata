  val encoded: String = xml.encodeToString(manifest, rootName)\n\n        assertThat(encoded)\n            .contains(\"<m:manifest\")\n            .contains(\"xmlns:m=\\\"$ROOT_NAMESPACE\\\"\")\n            .contains(\"id=\\\"manifest-42\\\"\")\n            .contains(\"Native image metadata\")\n        assertThat(xml.decodeFromString<RootNamedManifest>(encoded, rootName)).isEqualTo(manifest)\n    }\n\n    @Test\n    fun beforeAndAfterAnnotationsReorderElementChildrenDuringEncoding(): Unit {\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\n        val event = OrderedLifecycleEvent(\n            last = \"archive\",\n            middle = \"publish\",\n            first = \"build\",\n        )\n\n        val encoded: String = xml.encodeToString(event, null as String?)\n\n        val firstIndex: Int = encoded.indexOf(\"<first>build</first>\")\n        val middleIndex: Int = encoded.indexOf(\"<middle>publish</middle>\")\n        val lastIndex: Int = encoded.indexOf(\"<last>archive</last>\")\n        assertThat(firstIndex).isGreaterThanOrEqualTo(0)\n        assertThat(middleIndex).isGreaterThan(firstIndex)\n        assertThat(lastIndex).isGreaterThan(middleIndex)\n        assertThat(xml.decodeFromString<OrderedLifecycleEvent>(encoded, null)).isEqualTo(event)\n    }\n\n    private companion object {\n        private const val ROOT_NAMESPACE: String = \"urn:test:explicit-root\"\n    }\n}\n\n@Serializable\n@XmlSerialName(\"payload\")\nprivate data class RootNamedManifest(\n    @XmlElement(false)\n    val id: String,\n    @XmlElement(true)\n    val title: String,\n    @XmlElement(true)\n    val owner: String,\n)\n\n@Serializable\n@XmlSerialName(\"lifecycle\")\nprivate data class OrderedLifecycleEvent(\n    @XmlElement(true)\n    @XmlAfter(\"middle\")\n    val last: String,\n    @XmlElement(true)\n    val middle: String,\n    @XmlElement(true)\n    @XmlBefore(\"middle\")\n    val first: String,\n)\n"}], "isError": false, "timestamp": 1777906009036}]}
