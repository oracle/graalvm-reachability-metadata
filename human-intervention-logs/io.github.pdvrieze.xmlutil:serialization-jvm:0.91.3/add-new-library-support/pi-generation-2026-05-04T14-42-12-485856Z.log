lization.ElementSerializer\nimport nl.adaptivity.xmlutil.serialization.XML\nimport nl.adaptivity.xmlutil.serialization.UnknownXmlFieldException\nimport nl.adaptivity.xmlutil.serialization.XmlCData\nimport nl.adaptivity.xmlutil.serialization.XmlChildrenName\nimport nl.adaptivity.xmlutil.serialization.XmlElement\nimport nl.adaptivity.xmlutil.serialization.XmlKeyName\nimport nl.adaptivity.xmlutil.serialization.XmlMapEntryName\nimport nl.adaptivity.xmlutil.serialization.XmlOtherAttributes\nimport nl.adaptivity.xmlutil.serialization.XmlSerialName\nimport nl.adaptivity.xmlutil.serialization.XmlValue\nimport nl.adaptivity.xmlutil.util.CompactFragment\nimport nl.adaptivity.xmlutil.xmlStreaming\nimport org.assertj.core.api.Assertions.assertThat\nimport org.assertj.core.api.Assertions.assertThatThrownBy\nimport org.junit.jupiter.api.Test\nimport org.w3c.dom.Element\nimport java.io.StringReader\nimport java.io.StringWriter\nimport javax.xml.namespace.QName\nimport javax.xml.parsers.DocumentBuilderFactory\n\npublic class SerializationJvmTest {\n    @Test\n    fun annotatedModelRoundTripsAttributesElementsListsNamespacesAndCData(): Unit {\n        val xml = XML {\n            xmlDeclMode = XmlDeclMode.None\n            indentString = \"  \"\n        }\n        val catalog = Catalog(\n            id = \"cat-1\",\n            owner = Owner(name = \"Ada\", label = \"primary curator\"),\n            books = listOf(\n                Book(isbn = \"978-1\", title = \"XML & Kotlin\", authors = listOf(\"Ada\", \"Grace\")),\n                Book(isbn = \"978-2\", title = \"Native Image\", authors = listOf(\"Linus\")),\n            ),\n            description = Description(\"Uses <CDATA> & ordinary entities safely\"),\n        )\n\n        val encoded: String = xml.encodeToString(Catalog.serializer(), catalog)\n\n        assertThat(encoded)\n            .contains(\"catalog\")\n            .contains(\"xmlns:c=\\\"$CATALOG_NS\\\"\")\n            .contains(\"id=\\\"cat-1\\\"\")\n            .contains(\"isbn=\\\"978-1\\\"\")\n            .contains(\"<![CDATA[Uses <CDATA> & ordinary entities safely]]>\")\n            .contains(\"<author>Ada</author>\")\n        assertThat(xml.decodeFromString(Catalog.serializer(), encoded)).isEqualTo(catalog)\n\n        val descriptor = xml.xmlDescriptor(Catalog.serializer())\n        assertThat(descriptor.tagName).isEqualTo(QName(CATALOG_NS, \"catalog\", \"c\"))\n        assertThat(descriptor.elementsCount).isEqualTo(4)\n    }\n\n    @Test\n    fun writerAndReaderEntryPointsUseTheSameFormatCacheAndConfiguration(): Unit {\n        val xml = XML {\n            xmlDeclMode = XmlDeclMode.None\n            indentString = \" \"\n        }.copy {\n            defaultToGenericParser = true\n            indentString = \"    \"\n        }\n        val catalog = Catalog(\n            id = \"streamed\",\n            owner = Owner(name = \"Stream\", label = \"writer\"),\n            books = listOf(Book(isbn = \"stream-1\", title = \"Streaming\", authors = listOf(\"Reader\"))),\n            description = Description(\"written through XmlWriter\"),\n        )\n\n        val buffer = StringWriter()\n        xmlStreaming.newWriter(buffer, true, XmlDeclMode.None).use { writer ->\n            xml.encodeToWriter(writer, Catalog.serializer(), catalog, null)\n        }\n        val encoded: String = buffer.toString()\n\n        assertThat(encoded).contains(\"streamed\", \"written through XmlWriter\")\n        xmlStreaming.newReader(StringReader(encoded), true).use { reader ->\n            assertThat(xml.decodeFromReader(Catalog.serializer(), reader)).isEqualTo(catalog)\n        }\n    }\n\n    @Test\n    fun mapEntriesOtherAttributesAndUnknownChildrenAreHandledByPolicy(): Unit {\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\n        val preferences = Preferences(\n            values = linkedMapOf(\"theme\" to \"dark\", \"pageSize\" to \"50\"),\n            attributes = linkedMapOf(\n                QName(EXTRA_NS, \"trace\", \"x\") to \"enabled\",\n                QName(\"\", \"localOnly\") to \"yes\",\n            ),\n        )\n\n        val encoded: String = xml.encodeToString(Preferences.serializer(), preferences)\n\n        assertThat(encoded)\n            .contains(\"setting\")\n            .contains(\"name=\\\"theme\\\"\")\n            .contains(\"x:trace=\\\"enabled\\\"\")\n            .contains(\"localOnly=\\\"yes\\\"\")\n        assertThat(xml.decodeFromString(Preferences.serializer(), encoded)).isEqualTo(preferences)\n\n        val withUnknownContent: String = encoded.replace(\n            \"</preferences>\",\n            \"<ignored-child>ignored</ignored-child></preferences>\",\n        )\n        assertThatThrownBy { xml.decodeFromString(Preferences.serializer(), withUnknownContent) }\n            .isInstanceOf(UnknownXmlFieldException::class.java)\n\n        val forgivingXml = XML {\n            xmlDeclMode = XmlDeclMode.None\n            unknownChildHandler = nl.adaptivity.xmlutil.serialization.XmlConfig.IGNORING_UNKNOWN_CHILD_HANDLER\n        }\n        assertThat(forgivingXml.decodeFromString(Preferences.serializer(), withUnknownContent))\n            .isEqualTo(preferences)\n    }\n\n    @Test\n    fun sealedValuesUseAutoPolymorphicDescriptors(): Unit {\n        val xml = XML {\n            xmlDeclMode = XmlDeclMode.None\n            autoPolymorphic = true\n        }\n        val batch = NotificationBatch(\n            notifications = listOf(\n                EmailNotification(address = \"ada@example.test\", subject = \"Build passed\"),\n                SmsNotification(number = \"+155501\", message = \"Native image ready\"),\n            ),\n        )\n\n        val encoded: String = xml.encodeToString(NotificationBatch.serializer(), batch)\n\n        assertThat(encoded)\n            .contains(\"notification\")\n            .contains(\"email\")\n            .contains(\"sms\")\n            .contains(\"Build passed\")\n        assertThat(xml.decodeFromString(NotificationBatch.serializer(), encoded)).isEqualTo(batch)\n    }\n\n    @Test\n    fun builtInXmlFragmentAndDomSerializersPreserveEmbeddedMarkup(): Unit {\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\n        val fragmentEnvelope = FragmentEnvelope(\n            fragment = CompactFragment(\"<snippet priority=\\\"high\\\"><line>one</line><line>two</line></snippet>\"),\n        )\n\n        val fragmentXml: String = xml.encodeToString(FragmentEnvelope.serializer(), fragmentEnvelope)\n\n        assertThat(fragmentXml).contains(\"snippet\", \"priority=\\\"high\\\"\", \"<line>two</line>\")\n        assertThat(xml.decodeFromString(FragmentEnvelope.serializer(), fragmentXml).fragment.contentString)\n            .contains(\"snippet\", \"priority=\\\"high\\\"\", \"<line>one</line>\")\n\n        val domEnvelope = DomEnvelope(createElement(\"<payload flag=\\\"true\\\"><child>text</child></payload>\"))\n        val domXml: String = xml.encodeToString(DomEnvelope.serializer(), domEnvelope)\n\n        assertThat(domXml).contains(\"payload\", \"flag=\\\"true\\\"\", \"<child>text</child>\")\n        val decoded: DomEnvelope = xml.decodeFromString(DomEnvelope.serializer(), domXml)\n        assertThat(decoded.element.localName).isEqualTo(\"payload\")\n        assertThat(decoded.element.getAttribute(\"flag\")).isEqualTo(\"true\")\n        assertThat(decoded.element.getElementsByTagName(\"child\").item(0).textContent).isEqualTo(\"text\")\n    }\n\n    private fun createElement(source: String): Element {\n        val factory = DocumentBuilderFactory.newInstance()\n        factory.isNamespaceAware = true\n        return factory.newDocumentBuilder().parse(source.byteInputStream()).documentElement\n    }\n\n}\n\nprivate const val CATALOG_NS: String = \"urn:test:catalog\"\nprivate const val EXTRA_NS: String = \"urn:test:extra\"\n\n@Serializable\n@XmlSerialName(\"catalog\", CATALOG_NS, \"c\")\nprivate data class Catalog(\n    @XmlElement(false)\n    @XmlSerialName(\"id\")\n    val id: String,\n    @XmlElement(true)\n    val owner: Owner,\n    val books: List<Book>,\n    @XmlElement(true)\n    val description: Description,\n)\n\n@Serializable\n@XmlSerialName(\"owner\")\nprivate data class Owner(\n    @XmlElement(false)\n    val name: String,\n    @XmlValue\n    val label: String,\n)\n\n@Serializable\n@XmlSerialName(\"book\")\nprivate data class Book(\n    @XmlElement(false)\n    val isbn: String,\n    @XmlElement(true)\n    val title: String,\n    @XmlChildrenName(\"author\")\n    val authors: List<String>,\n)\n\n@Serializable\n@XmlSerialName(\"description\")\nprivate data class Description(\n    @XmlCData\n    @XmlValue\n    val text: String,\n)\n\n@Serializable\n@XmlSerialName(\"preferences\")\nprivate data class Preferences(\n    @XmlMapEntryName(\"setting\")\n    @XmlKeyName(\"name\")\n    val values: Map<String, String>,\n    @XmlOtherAttributes\n    val attributes: Map<@Serializable(QNameSerializer::class) QName, String>,\n)\n\n@Serializable\n@XmlSerialName(\"notificationBatch\")\nprivate data class NotificationBatch(\n    @XmlSerialName(\"notification\")\n    val notifications: List<Notification>,\n)\n\n@Serializable\nprivate sealed class Notification\n\n@Serializable\n@XmlSerialName(\"email\")\nprivate data class EmailNotification(\n    @XmlElement(false)\n    val address: String,\n    @XmlElement(true)\n    val subject: String,\n) : Notification()\n\n@Serializable\n@XmlSerialName(\"sms\")\nprivate data class SmsNotification(\n    @XmlElement(false)\n    val number: String,\n    @XmlElement(true)\n    val message: String,\n) : Notification()\n\n@Serializable\n@XmlSerialName(\"fragmentEnvelope\")\nprivate data class FragmentEnvelope(\n    @XmlValue\n    @Serializable(with = CompactFragmentSerializer::class)\n    val fragment: CompactFragment,\n)\n\n@Serializable\n@XmlSerialName(\"domEnvelope\")\nprivate data class DomEnvelope(\n    @XmlValue\n    @Serializable(with = ElementSerializer::class)\n    val element: Element,\n)\n"}], "isError": false, "ti