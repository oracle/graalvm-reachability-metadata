(writer, Catalog.serializer(), catalog, null as String?)\n        }\n        val encoded: String = buffer.toString()\n\n        assertThat(encoded).contains(\"streamed\", \"written through XmlWriter\")\n        xmlStreaming.newReader(StringReader(encoded), true).use { reader ->\n            assertThat(xml.decodeFromReader(Catalog.serializer(), reader)).isEqualTo(catalog)\n        }\n    }\n\n    @Test\n    fun mapEntriesOtherAttributesAndUnknownChildrenAreHandledByPolicy(): Unit {\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\n        val preferences = Preferences(\n            values = linkedMapOf(\"theme\" to \"dark\", \"pageSize\" to \"50\"),\n            attributes = linkedMapOf(\n                QName(EXTRA_NS, \"trace\", \"x\") to \"enabled\",\n                QName(\"\", \"localOnly\") to \"yes\",\n            ),\n        )\n\n        val encoded: String = xml.encodeToString(Preferences.serializer(), preferences)\n\n        assertThat(encoded)\n            .contains(\"setting\")\n            .contains(\"name=\\\"theme\\\"\")\n            .contains(\"x:trace=\\\"enabled\\\"\")\n            .contains(\"localOnly=\\\"yes\\\"\")\n        assertThat(xml.decodeFromString(Preferences.serializer(), encoded)).isEqualTo(preferences)\n\n        val withUnknownContent: String = encoded.replace(\n            \"</preferences>\",\n            \"<ignored-child>ignored</ignored-child></preferences>\",\n        )\n        assertThatThrownBy { xml.decodeFromString(Preferences.serializer(), withUnknownContent) }\n            .isInstanceOf(UnknownXmlFieldException::class.java)\n\n        val forgivingXml = XML {\n            xmlDeclMode = XmlDeclMode.None\n            defaultPolicy {\n                unknownChildHandler = nl.adaptivity.xmlutil.serialization.XmlConfig.IGNORING_UNKNOWN_CHILD_HANDLER\n            }\n        }\n        assertThat(forgivingXml.decodeFromString(Preferences.serializer(), withUnknownContent))\n            .isEqualTo(preferences)\n    }\n\n    @Test\n    fun sealedValuesUseAutoPolymorphicDescriptors(): Unit {\n        val xml = XML {\n            xmlDeclMode = XmlDeclMode.None\n            autoPolymorphic = true\n        }\n        val batch = NotificationBatch(\n            notifications = listOf(\n                EmailNotification(address = \"ada@example.test\", subject = \"Build passed\"),\n                SmsNotification(number = \"+155501\", message = \"Native image ready\"),\n            ),\n        )\n\n        val encoded: String = xml.encodeToString(NotificationBatch.serializer(), batch)\n\n        assertThat(encoded)\n            .contains(\"notification\")\n            .contains(\"email\")\n            .contains(\"sms\")\n            .contains(\"Build passed\")\n        assertThat(xml.decodeFromString(NotificationBatch.serializer(), encoded)).isEqualTo(batch)\n    }\n\n    @Test\n    fun builtInXmlFragmentAndDomSerializersPreserveEmbeddedMarkup(): Unit {\n        val xml = XML { xmlDeclMode = XmlDeclMode.None }\n        val fragmentEnvelope = FragmentEnvelope(\n            fragment = CompactFragment(\"<snippet priority=\\\"high\\\"><line>one</line><line>two</line></snippet>\"),\n        )\n\n        val fragmentXml: String = xml.encodeToString(FragmentEnvelope.serializer(), fragmentEnvelope)\n\n        assertThat(fragmentXml).contains(\"snippet\", \"priority=\\\"high\\\"\", \"<line>two</line>\")\n        assertThat(xml.decodeFromString(FragmentEnvelope.serializer(), fragmentXml).fragment.contentString)\n            .contains(\"snippet\", \"priority=\\\"high\\\"\", \"<line>one</line>\")\n\n        val domEnvelope = DomEnvelope(createElement())\n        val domXml: String = xml.encodeToString(DomEnvelope.serializer(), domEnvelope)\n\n        assertThat(domXml).contains(\"payload\", \"flag=\\\"true\\\"\", \"<child>text</child>\")\n        val decoded: DomEnvelope = xml.decodeFromString(DomEnvelope.serializer(), domXml)\n        assertThat(decoded.element.localName).isEqualTo(\"payload\")\n        assertThat(decoded.element.getAttribute(\"flag\")).isEqualTo(\"true\")\n        assertThat(decoded.element.getElementsByTagName(\"child\").item(0).textContent).isEqualTo(\"text\")\n    }\n\n    private fun createElement(): Element {\n        val document = xmlStreaming.genericDomImplementation.createDocument(\"\", \"payload\", null)\n        val root = requireNotNull(document.documentElement)\n        root.setAttribute(\"flag\", \"true\")\n        val child = document.createElement(\"child\")\n        child.appendChild(document.createTextNode(\"text\"))\n        root.appendChild(child)\n        return root\n    }\n\n}\n\nprivate const val CATALOG_NS: String = \"urn:test:catalog\"\nprivate const val EXTRA_NS: String = \"urn:test:extra\"\n\n@Serializable\n@XmlSerialName(\"catalog\", CATALOG_NS, \"c\")\nprivate data class Catalog(\n    @XmlElement(false)\n    @XmlSerialName(\"id\")\n    val id: String,\n    @XmlElement(true)\n    val owner: Owner,\n    val books: List<Book>,\n    @XmlElement(true)\n    val description: Description,\n)\n\n@Serializable\n@XmlSerialName(\"owner\")\nprivate data class Owner(\n    @XmlElement(false)\n    val name: String,\n    @XmlValue\n    val label: String,\n)\n\n@Serializable\n@XmlSerialName(\"book\")\nprivate data class Book(\n    @XmlElement(false)\n    val isbn: String,\n    @XmlElement(true)\n    val title: String,\n    @XmlChildrenName(\"author\")\n    val authors: List<String>,\n)\n\n@Serializable\n@XmlSerialName(\"description\")\nprivate data class Description(\n    @XmlCData\n    @XmlValue\n    val text: String,\n)\n\n@Serializable\n@XmlSerialName(\"preferences\")\nprivate data class Preferences(\n    @XmlMapEntryName(\"setting\")\n    @XmlKeyName(\"name\")\n    val values: Map<String, String>,\n    @XmlOtherAttributes\n    val attributes: Map<@Serializable(QNameSerializer::class) QName, String>,\n)\n\n@Serializable\n@XmlSerialName(\"notificationBatch\")\nprivate data class NotificationBatch(\n    @XmlSerialName(\"notification\