  package io_github_pdvrieze_xmlutil.serialization_jvm
  
  import kotlinx.serialization.Serializable
  import nl.adaptivity.xmlutil.XmlDeclMode
  import nl.adaptivity.xmlutil.serialization.XML
  import nl.adaptivity.xmlutil.serialization.XmlAfter
  import nl.adaptivity.xmlutil.serialization.XmlBefore
  import nl.adaptivity.xmlutil.serialization.XmlElement
  import nl.adaptivity.xmlutil.serialization.XmlSerialName
  import org.assertj.core.api.Assertions.assertThat
  import org.junit.jupiter.api.Test
  import javax.xml.namespace.QName
  
  public class RootNameAndOrderingTest {
      @Test
      fun explicitRootQNameOverridesDescriptorNameAndRoundTrips(): Unit {
          val xml = XML {
              xmlDeclMode = XmlDeclMode.None
              repairNamespaces = true
          }
          val rootName = QName(ROOT_NAMESPACE, "manifest", "m")
          val manifest = RootNamedManifest(
              id = "manifest-42",
              title = "Native image metadata",
              owner = "xmlutil",
          )
  
          val encoded: String = xml.encodeToString(manifest, rootName)
  
          assertThat(encoded)
              .contains("<m:manifest")
              .contains("xmlns:m=\"$ROOT_NAMESPACE\"")
              .contains("id=\"manifest-42\"")
              .contains("Native image metadata")
          assertThat(xml.decodeFromString<RootNamedManifest>(encoded, rootName)).isEqualTo(manifest)
      }
  
      @Test
      fun beforeAndAfterAnnotationsReorderElementChildrenDuringEncoding(): Unit {
          val xml = XML { xmlDeclMode = XmlDeclMode.None }
          val event = OrderedLifecycleEvent(
              last = "archive",
              middle = "publish",
              first = "build",
          )
  
          val encoded: String = xml.encodeToString(event, null as String?)
  
          val firstIndex: Int = encoded.indexOf("<first>build</first>")
          val middleIndex: Int = encoded.indexOf("<middle>publish</middle>")
          val lastIndex: Int = encoded.indexOf("<last>archive</last>")
          assertThat(firstIndex).isGreaterThanOrEqualTo(0)
          assertThat(middleIndex).isGreaterThan(firstIndex)
          assertThat(lastIndex).isGreaterThan(middleIndex)
          assertThat(xml.decodeFromString<OrderedLifecycleEvent>(encoded, null)).isEqualTo(event)
      }
  
      private companion object {
          private const val ROOT_NAMESPACE: String = "urn:test:explicit-root"
      }
  }
  
  @Serializable
  @XmlSerialName("payload")
  private data class RootNamedManifest(
      @XmlElement(false)
      val id: String,
      @XmlElement(true)
      val title: String,
      @XmlElement(true)
      val owner: String,
  )
  
  @Serializable
  @XmlSerialName("lifecycle")
  private data class OrderedLifecycleEvent(
      @XmlElement(true)
      @XmlAfter("middle")
      val last: String,
      @XmlElement(true)
      val middle: String,
      @XmlElement(true)
      @XmlBefore("middle")
      val first: String,
  )
