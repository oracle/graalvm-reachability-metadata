[tool-call] delta {"path":"tests/src/io.github.pdvrieze.xmlutil/serialization-jvm/0.91.3/src/test/kotlin/io_github_pdvrieze_xmlutil/serialization_jvm/RootNameAndOrderingTest.kt","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_github_pdvrieze_xmlutil.serialization_jvm\n\nimport kotlinx.serialization.builtins.ListSerializer\nimport kotlinx.serialization.builtins.serializer\nimport nl.adaptivity.xmlutil.XmlDeclMode\nimport nl.adaptivity.xmlutil.serialization.XML\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport javax.xml.namespace.QName\n\npublic class RootNameAndOrderingTest {\n    @Test\n    fun explicitRootQNameControlsPrimitiveElementNameAndNamespace(): Unit {\n        val xml = XML {\n            xmlDeclMode = XmlDeclMode.None\n            repairNamespaces = true\n        }\n        val serializer = String.serializer()\n        val rootName = QName(ROOT_NAMESPACE, \"message\", \"msg\")\n        val value = \"Hello <native> & XML\"\n\n        val encoded: String = xml.encodeToString(serializer, value, rootName)\n\n        assertThat(encoded)\n            .contains(\"<msg:message\")\n            .contains(\"xmlns:msg=\\\"$ROOT_NAMESPACE\\\"\")\n            .contains(\"Hello &lt;native&gt; &amp; XML\")\n            .contains(\"</msg:message>\")\n        assertThat(xml.decodeFromString(serializer, encoded, rootName)).isEqualTo(value)\n    }\n\n    @Test\n    fun configuredXmlDeclarationAndGenericParserRoundTripCollectionRoot(): Unit {\n        val xml = XML {\n            xmlDeclMode = XmlDeclMode.Minimal\n            defaultToGenericParser = true\n            indentString = \"  \"\n        }\n        val serializer = ListSerializer(String.serializer())\n        val rootName = QName(\"\", \"aliases\")\n        val values = listOf(\"graal\", \"native-image\", \"xmlutil\")\n\n        val encoded: String = xml.encodeToString(serializer, values, rootName)\n\n        assertThat(encoded).startsWith(\"<?xml version=\")\n        assertThat(encoded)\n            .contains(\"<aliases>\")\n            .contains(\"graal\")\n            .contains(\"native-image\")\n            .contains(\"xmlutil\")\n        assertThat(xml.decodeFromString(serializer, encoded, rootName)).isEqualTo(values)\n    }\n\n    private companion object {\n        private const val ROOT_NAMESPACE: String = \"urn:test:explicit-root\"\n    }\n}\n"}
