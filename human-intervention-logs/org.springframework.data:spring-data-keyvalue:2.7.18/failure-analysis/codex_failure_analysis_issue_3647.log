\\n\\n    @KeySpace(\\\"people\\\")\\n    public static class Person {\\n        @Id\\n        private String id;\\n        private String firstName;\\n        private String lastName;\\n        private int age;\\n        private boolean active;\\n\\n        public Person() {\\n        }\\n\\n        Person(String id, String firstName, String lastName, int age, boolean active) {\\n            this.id = id;\\n            this.firstName = firstName;\\n            this.lastName = lastName;\\n            this.age = age;\\n            this.active = active;\\n        }\\n\\n        public String getId() {\\n            return id;\\n        }\\n\\n        public void setId(String id) {\\n            this.id = id;\\n        }\\n\\n        public String getFirstName() {\\n            return firstName;\\n        }\\n\\n        public void setFirstName(String firstName) {\\n            this.firstName = firstName;\\n        }\\n\\n        public String getLastName() {\\n            return lastName;\\n        }\\n\\n        public void setLastName(String lastName) {\\n            this.lastName = lastName;\\n        }\\n\\n        public int getAge() {\\n            return age;\\n        }\\n\\n        public void setAge(int age) {\\n            this.age = age;\\n        }\\n\\n        public boolean isActive() {\\n            return active;\\n        }\\n\\n        public void setActive(boolean active) {\\n            this.active = active;\\n        }\\n    }\\n}\\n\"}\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.springframework.data:spring-data-keyvalue:2.7.18/add-new-library-support/pi-generation-2026-05-08T18-41-48-243903Z.log:10044:  Successfully wrote 12816 bytes to tests/src/org.springframework.data/spring-data-keyvalue/2.7.18/src/test/java/org_springframework_data/spring_data_keyvalue/Spring_data_keyvalueTest.java\n/home/vjovanov/c/forge/forge8/graalvm-reachability-metadata/forge/logs/org.springframework.data:spring-data-keyvalue:2.7.18/add-