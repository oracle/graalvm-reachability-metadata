  		this.criteria = criteria;
  		setSort(sort);
  	}
  
  	/**
  	 * Creates new instance of {@link KeyValueQuery} with given {@link Sort}.
  	 *
  	 * @param sort must not be {@literal null}.
  	 */
  	public KeyValueQuery(Sort sort) {
  		this();
  		setSort(sort);
  	}
  
