    private void compilePredicates(int opPos, Expression[] predicates) throws TransformerException {
  
      for (int i = 0; OpCodes.OP_PREDICATE == getOp(opPos); i++) {
        predicates[i] = predicate(opPos);
        opPos = getNextOpPos(opPos);
      }
    }
  
