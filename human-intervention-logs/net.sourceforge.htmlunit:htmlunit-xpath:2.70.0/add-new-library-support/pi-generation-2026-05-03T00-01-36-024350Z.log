  package net_sourceforge_htmlunit.htmlunit_xpath;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import javax.xml.parsers.DocumentBuilderFactory;
  import net.sourceforge.htmlunit.xpath.XPath;
  import net.sourceforge.htmlunit.xpath.XPathAPI;
  import net.sourceforge.htmlunit.xpath.XPathContext;
  import net.sourceforge.htmlunit.xpath.compiler.FunctionTable;
  import net.sourceforge.htmlunit.xpath.functions.FuncTrue;
  import net.sourceforge.htmlunit.xpath.objects.XObject;
  import net.sourceforge.htmlunit.xpath.xml.utils.PrefixResolver;
  import net.sourceforge.htmlunit.xpath.xml.utils.PrefixResolverDefault;
  import org.junit.jupiter.api.Test;
  import org.w3c.dom.Document;
  import org.w3c.dom.Element;
  
  public class FunctionTableTest {
      @Test
      void compilesAndExecutesBuiltInFunction() throws Exception {
          Document document = newDocument();
  
          XObject result = XPathAPI.eval(document, "true()");
  
          assertThat(result.bool()).isTrue();
      }
  
      @Test
      void compilesAndExecutesInstalledCustomFunction() throws Exception {
          String functionName = "customTrue";
          FunctionTable functionTable = new FunctionTable();
          functionTable.installFunction(functionName, FuncTrue.class);
          Document document = newDocument();
          PrefixResolver prefixResolver = new PrefixResolverDefault(document.getDocumentElement());
  
          XPath xpath =
                  new XPath(functionName + "()", prefixResolver, XPath.SELECT, null, functionTable);
          XObject result = execute(xpath, document, prefixResolver);
  
          assertThat(functionTable.functionAvailable(functionName)).isTrue();
          assertThat(result.bool()).isTrue();
      }
  
      private static Document newDocument() throws Exception {
          Document document = DocumentBuilderFactory.newInstance().newDocumentBuilder().newDocument();
          Element root = document.createElement("root");
          document.appendChild(root);
          return document;
      }
  
      private static XObject execute(XPath xpath, Document document, PrefixResolver prefixResolver)
              throws Exception {
          XPathContext xpathContext = new XPathContext(false);
          int contextNode = xpathContext.getDTMHandleFromNode(document);
          return xpath.execute(xpathContext, contextNode, prefixResolver);
      }
  }
