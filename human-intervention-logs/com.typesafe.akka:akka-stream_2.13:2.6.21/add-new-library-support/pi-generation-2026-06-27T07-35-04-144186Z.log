  +          .via(Compression.gzip)
  +          .runFold(ByteString.empty)(_ ++ _))
  +      val inflated: ByteString = awaitResult(
  +        Source.single(compressed)
  +          .via(Compression.gunzip())
  +          .runFold(ByteString.empty)(_ ++ _))
  +
  +      assertThat(compressed.length).isGreaterThan(0)
