  +        Source(List(ByteString("alpha\nbr"), ByteString("avo\ncharlie\n")))
  +          .via(Framing.delimiter(ByteString("\n"), maximumFrameLength = 64, allowTruncation = false))
  +          .map(_.utf8String)
  +          .runWith(Sink.seq))
  +
  +      assertThat(framed.asJava).containsExactly("alpha", "bravo", "charlie")
  +  }
