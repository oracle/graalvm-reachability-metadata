\"com.typesafe:ssl-config-core_2.13:reference.conf\"].trim()\n        ]\n\n        File outputFile = generatedApplicationConf.get().asFile\n        outputFile.parentFile.mkdirs()\n        outputFile.setText(sections.join(\"\\n\\n\") + \"\\n\", StandardCharsets.UTF_8.name())\n    }\n}\n\nsourceSets {\n    test {\n        resources.srcDir(generatedTestResourcesDir)\n    }\n}\n\ntasks.named(\"processTestResources\") {\n    dependsOn(tasks.named(\"generateAkkaApplicationConfig\"))\n}\n","exit_code":0,"status":"completed"}}
