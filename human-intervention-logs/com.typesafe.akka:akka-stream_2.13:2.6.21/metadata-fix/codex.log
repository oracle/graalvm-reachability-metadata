{"type":"item.completed","item":{"id":"item_85","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,260p' tests/src/com.typesafe.akka/akka-stream_2.13/2.6.21/build.gradle\"","aggregated_output":"import java.nio.charset.StandardCharsets\nimport java.util.jar.JarFile\n\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n    id \"scala\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"com.typesafe.akka:akka-stream_2.13:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'org.scala-lang:scala-library:2.13.16'\n    testImplementation 'org.scala-lang:scala-compiler:2.13.16'\n}\n\njava {\n    toolchain {\n        languageVersion = JavaLanguageVersion.of(21)\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n\nList<String> akkaConfigModules = [\n        \"com.typesafe.akka:akka-actor_2.13\",\n        \"com.typesafe.akka:akka-stream_2.13\",\n        \"com.typesafe:ssl-config-core_2.13\"\n]\n\nProvider<Directory> generatedTestResourcesDir = layout.buildDirectory.dir(\"generated/test-resources\")\nProvider<RegularFile> generatedApplicationConf = generatedTestResourcesDir.map {\n    it.file(\"com_typesafe_akka/akka_stream_2_13/application.conf\")\n}\n\ntasks.register(\"generateAkkaApplicationConfig\") { task ->\n    task.description = \"Generates an application.conf that merges Akka defaults for native tests.\"\n    task.inputs.files(configurations.testRuntimeClasspath)\n    task.outputs.file(generatedApplicationConf)\n    task.doLast {\n        Map<String, String> resourceContents = [