[recv] {"type": "turn_end", "message": {"role": "assistant", "content": [{"type": "toolCall", "id": "call_w4IdcAx2iFwu26QCqPOc3cMj|fc_0c6163db8a25e8da016a41ae0fec808193ad20e60b6475f5e5", "name": "write", "arguments": {"path": "tests/src/org.springframework.boot/spring-boot-http-converter/4.0.2/src/test/java/org_springframework_boot/spring_boot_http_converter/HttpMessageConvertersTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot_http_converter;\n\nimport java.io.IOException;\nimport java.nio.charset.StandardCharsets;\nimport java.util.List;\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\nimport tools.jackson.databind.json.JsonMapper;\n\nimport org.springframework.boot.autoconfigure.AutoConfigurations;\nimport org.springframework.boot.http.converter.autoconfigure.ClientHttpMessageConvertersCustomizer;\nimport org.springframework.boot.http.converter.autoconfigure.HttpMessageConverters;\nimport org.springframework.boot.http.converter.autoconfigure.HttpMessageConvertersAutoConfiguration;\nimport org.springframework.boot.http.converter.autoconfigure.ServerHttpMessageConvertersCustomizer;\nimport org.springframework.boot.test.context.runner.ApplicationContextRunner;\nimport org.springframework.http.MediaType;\nimport org.springframework.http.converter.HttpMessageConverter;\nimport org.springframework.http.converter.HttpMessageConverters.ClientBuilder;\nimport org.springframework.http.converter.HttpMessageConverters.ServerBuilder;\nimport org.springframework.http.converter.json.JacksonJsonHttpMessageConverter;\nimport org.springframework.mock.http.MockHttpOutputMessage;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.springframework.http.converter.HttpMessageConverters.forClient;\nimport static org.springframework.http.converter.HttpMessageConverters.forServer;\n\npublic class HttpMessageConvertersTest {\n\n    private final ApplicationContextRunner contextRunner = new ApplicationContextRunner()\n            .withBean(JsonMapper.class, JsonMapper::new)\n            .withConfiguration(AutoConfigurations.of(HttpMessageConvertersAutoConfiguration.class));\n\n    @Test\n    @SuppressWarnings(\"deprecation\")\n    void legacyConvertersExposeAdditionalJacksonConverter() throws IOException {\n        JacksonJsonHttpMessageConverter jsonConverter = new JacksonJsonHttpMessageConverter(new JsonMapper());\n        HttpMessageConverters converters = new HttpMessageConverters(false, List.of(jsonConverter));\n\n        assertThat(converters.getConverters()).containsExactly(jsonConverter);\n        assertThat(writeJson(jsonConverter, \"legacy\")).isEqualTo(\"{\\\"message\\\":\\\"legacy\\\"}\");\n    }\n\n    @Test\n    void autoConfigurationContributesClientAndServerCustomizersWithJacksonJsonConversion() {\n        this.contextRunner.run((context) -> {\n            List<ClientHttpMessageConvertersCustomizer> clientCustomizers = context\n                    .getBeanProvider(ClientHttpMessageConvertersCustomizer.class)\n                    .orderedStream()\n                    .toList();\n            List<ServerHttpMessageConvertersCustomizer> serverCustomizers = context\n                    .getBeanProvider(ServerHttpMessageConvertersCustomizer.class)\n                    .orderedStream()\n                    .toList();\n\n            assertThat(clientCustomizers).isNotEmpty();\n            assertThat(serverCustomizers).isNotEmpty();\n            assertThat(writeJson(findJacksonConverter(customizedClientConverters(clientCustomizers)), \"client\"))\n                    .isEqualTo(\"{\\\"message\\\":\\\"client\\\"}\");\n            assertThat(writeJson(findJacksonConverter(customizedServerConverters(serverCustomizers)), \"server\"))\n                    .isEqualTo(\"{\\\"message\\\":\\\"server\\\"}\");\n        });\n    }\n\n    private static Iterable<HttpMessageConverter<?>> customizedClientConverters(\n            List<ClientHttpMessageConvertersCustomizer> customizers) {\n        ClientBuilder builder = forClient();\n        customizers.forEach((customizer) -> customizer.customize(builder));\n        return builder.build();\n    }\n\n    private static Iterable<HttpMessageConverter<?>> customizedServerConverters(\n            List<ServerHttpMessageConvertersCustomizer> customizers) {\n        ServerBuilder builder = forServer();\n        customizers.forEach((customizer) -> customizer.customize(builder));\n        return builder.build();\n    }\n\n    private static JacksonJsonHttpMessageConverter findJacksonConverter(Iterable<HttpMessageConverter<?>> converters) {\n        for (HttpMessageConverter<?> converter : converters) {\n            if (converter instanceof JacksonJsonHttpMessageConverter jacksonConverter) {\n                return jacksonConverter;\n            }\n        }\n        throw new AssertionError(\"No Jackson JSON HTTP message converter was registered\");\n    }\n\n    private static String writeJson(JacksonJsonHttpMessageConverter converter, String message) throws IOException {\n        MockHttpOutputMessage outputMessage = new MockHttpOutputMessage();\n        converter.write(Map.of(\"message\", message), MediaType.APPLICATION_JSON, outputMessage);\n        return outputMessage.getBodyAsString(StandardCharsets.UTF_8);\n    }\n\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 247, "output": 1053, "cacheRead": 35840, "cacheWrite": 0, "totalTokens": 37140, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782689293494, "responseId": "resp_0c6163db8a25e8da016a41ae0e4a6081939dd5893111cff20a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_w4IdcAx2iFwu26QCqPOc3cMj|fc_0c6163db8a25e8da016a41ae0fec