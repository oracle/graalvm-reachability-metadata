onHttpMessageConverter;\\nimport org.springframework.mock.http.MockHttpOutputMessage;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\nimport static org.springframework.http.converter.HttpMessageConverters.forClient;\\nimport static org.springframework.http.converter.HttpMessageConverters.forServer;\\n\\npublic class HttpMessageConvertersTest {\\n\\n    private final ApplicationContextRunner contextRunner = new ApplicationContextRunner()\\n            .withBean(JsonMapper.class, JsonMapper::new)\\n            .withConfiguration(AutoConfigurations.of(HttpMessageConvertersAutoConfiguration.class));\\n\\n    @Test\\n    @SuppressWarnings(\\\"deprecation\\\")\\n    void legacyConvertersExposeAdditionalJacksonConverter() throws IOException {\\n        JacksonJsonHttpMessageConverter jsonConverter = new JacksonJsonHttpMessageConverter(new JsonMapper());\\n        HttpMessageConverters converters = new HttpMessageConverters(false, List.of(jsonConverter));\\n\\n        assertThat(converters.getConverters()).containsExactly(jsonConverter);\\n        assertThat(writeJson(jsonConverter, \\\"legacy\\\")).isEqualTo(\\\"{\\\\\\\"message\\\\\\\":\\\\\\\"legacy\\\\\\\"}\\\");\\n    }\\n\\n    @Test\\n    void autoConfigurationContributesClientAndServerCustomizersWithJacksonJsonConversion() {\\n        this.contextRunner.run((context) -> {\\n            List<ClientHttpMessageConvertersCustomizer> clientCustomizers = context\\n                    .getBeanProvider(ClientHttpMessageConvertersCustomizer.class)\\n                    .orderedStream()\\n                    .toList();\\n            List<ServerHttpMessageConvertersCustomizer> serverCustomizers = context\\n                    .getBeanProvider(ServerHttpMessageConvertersCustomizer.class)\\n                    .orderedStream()\\n                    .toList();\\n\\n            assertThat(clientCustomizers).isNotEmpty();\\n            assertThat(serverCustomizers).isNotEmpty();\\n            assertThat(writeJson(findJacksonConverter(customizedClientConverters(clientCustomizers)), \\\"client\\\"))\\n                    .isEqualTo(\\\"{\\\\\\\"message\\\\\\\":\\\\\\\"client\\\\\\\"}\\\");\\n            assertThat(writeJson(findJacksonConverter(customizedServerConverters(serverCustomizers)), \\\"server\\\"))\\n                    .isEqualTo(\\\"{\\\\\\\"message\\\\\\\":\\\\\\\"server\\\\\\\"}\\\");\\n        });\\n    }\\n\\n    private static Iterable<HttpMessageConverter<?>> customizedClientConverters(\\n            List<ClientHttpMessageConvertersCustomizer> customizers) {\\n        ClientBuilder builder = forClient();\\n        customizers.forEach((customizer) -> customizer.customize(builder));\\n        return builder.build();\\n    }\\n\\n    private static Iterable<HttpMessageConverter<?>> customizedServerConverters(\\n            List<ServerHttpMessageConvertersCustomizer> customizers) {\\n        ServerBuilder builder = forServer();\\n        customizers.forEach((customizer) -> customizer.customize(builder));\\n        return builder.build();\\n    }\\n\\n    private static JacksonJsonHttpMessageConverter findJacksonConverter(Iterable<HttpMessageConverter<?>> converters) {\\n        for (HttpMessageConverter<?> converter : converters) {\\n            if (converter instanceof JacksonJsonHttpMessageConverter jacksonConverter) {\\n                return jacksonConverter;\\n            }\\n        }\\n        throw new AssertionError(\\\"No Jackson JSON HTTP message converter was registered\\\");\\n    }\\n\\n    private static String writeJson(JacksonJsonHttpMessageConverter converter, String message) throws IOException {\\n        MockHttpOutputMessage outputMessage = new MockHttpOutputMessage();\\n        converter.write(Map.of(\\\"message\\\", message), MediaType.APPLICATION_JSON, outputMessage);\\n        return outputMessage.getBodyAsString(StandardCharsets.UTF_8);\\n    }\\n\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n28:{\"type\":\"item.completed\",\"item\