     groovydoc.execute()\n\n        assertThat(documentationDirectory.toPath().resolve('index.html')).exists()\n        assertThat(documentationDirectory.toPath().resolve('example/DocumentedGreeter.html')).exists()\n    }\n\n    private static Project newProject() {\n","newText":"    @Test\n    void groovydocGeneratesDocumentationForGroovySources() {\n        Project project = newProject()\n        File sourceDirectory = temporaryDirectory.resolve('docs-src').toFile()\n        File documentationDirectory = temporaryDirectory.resolve('docs-out').toFile()\n        writeFile('docs-src/example/DocumentedGreeter.groovy', '''\n            package example\n\n            /** Greets users for documentation generation. */\n            class DocumentedGreeter {\n                /** Returns a friendly greeting. */\n                String greet(String name) {\n                    \"Hello, ${name}\"\n                }\n            }\n        ''')\n        Groovydoc groovydoc = new Groovydoc()\n        groovydoc.setProject(project)\n        groovydoc.setTaskName('groovydoc')\n        groovydoc.setSourcepath(new AntPath(project, sourceDirectory.absolutePath))\n        groovydoc.setDestdir(documentationDirectory)\n        groovydoc.setPackagenames('example')\n        groovydoc.setWindowtitle('Groovy Ant Test Docs')\n        groovydoc.setDoctitle('Groovy Ant Test Docs')\n        groovydoc.setNoTimestamp(true)\n        groovydoc.setNoVersionStamp(true)\n\n        groovydoc.execute()\n\n        assertThat(documentationDirectory.toPath().resolve('index.html')).exists()\n        assertThat(documentationDirectory.toPath().resolve('example/DocumentedGreeter.html')).exists()\n    }\n\n    @Test\n    void verifyClassScansCompiledClassFilesAndReportsSuccessfulVerification() {\n        Project project = newProject()\n        CapturingBuildListener listener = new CapturingBuildListener()\n        project.addBuildListener(listener)\n        File sourceDirectory = temporaryDirectory.resolve('verify-src').toFile()\n        File classesDirectory = temporaryDirectory.resolve('verify-classes').toFile()\n        Files.createDirectories(classesDirectory.toPath())\n        writeFile('verify-src/example/VerifiableCalculator.groovy', '''\n            package example\n\n            class VerifiableCalculator {\n                int doubleValue(int value) {\n                    value * 2\n                }\n            }\n        ''')\n        Groovyc compiler = new Groovyc()\n        compiler.setProject(project)\n        compiler.setTaskName('groovyc')\n        compiler.setSrcdir(new AntPath(project, sourceDirectory.absolutePath))\n        compiler.setDestdir(classesDirectory)\n        compiler.setFailonerror(true)\n        compiler.setFork(false)\n\n        compiler.execute()\n\n        VerifyClass verifier = new VerifyClass()\n        verifier.setProject(project)\n        verifier.setTaskName('verifyclass')\n        verifier.setDir(classesDirectory.absolutePath)\n        verifier.setVerbose(true)\n\n        verifier.execute()\n\n        assertThat(classesDirectory.toPath().resolve('example/VerifiableCalculator.class')).exists()\n        assertThat(listener.messages).contains('no bytecode problems found')\n        assertThat(listener.messages.find { String message -> message.startsWith('top dir is') })\n                .contains(classesDirectory.absolutePath)\n    }\n\n    private static Project newProject() {\n"},{"oldText":"    private static boolean executeAllowingNativeUnsupportedDynamicClassLoading(Closure<?> action) {\n        try {\n            action.call()\n            return true\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n            return false\n        }\n    }\n}\n","newText":"    private static boolean executeAllowingNativeUnsupportedDynamicClassLoading(Closure<?> action) {\n        try {\n            action.call()\n            return true\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n            return false\n        }\n    }\n\n    private static final class CapturingBuildListener implements BuildListener {\n        final List<String> messages = []\n\n        @Override\n        void buildStarted(BuildEvent event) {\n        }\n\n        @Override\n        void buildFinished(BuildEvent event) {\n        }\n\n        @Override\n        void targetStarted(BuildEvent event) {\n        }\n\n        @Override\n        void targetFinished(BuildEvent event) {\n        }\n\n        @Override\n        void taskStarted(BuildEvent event) {\n        }\n\n        @Override\n        void taskFinished(BuildEvent event) {\n        }\n\n        @Override\n        void messageLogged(BuildEvent event) {\n            messages.add(event.message)\n        }\n    }\n}\n"}]}
