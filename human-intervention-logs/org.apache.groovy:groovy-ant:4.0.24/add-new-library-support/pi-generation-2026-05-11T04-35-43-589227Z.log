utput.writeInt(0xCAFEBABE)\n            output.writeShort(0)\n            output.writeShort(52)\n            output.writeShort(8)\n            writeUtf8(output, 'example/VerifiedFixture')\n            output.writeByte(7)\n            output.writeShort(1)\n            writeUtf8(output, 'java/lang/Object')\n            output.writeByte(7)\n            output.writeShort(3)\n            writeUtf8(output, 'doubleValue')\n            writeUtf8(output, '(I)I')\n            writeUtf8(output, 'Code')\n            output.writeShort(0x0021)\n            output.writeShort(2)\n            output.writeShort(4)\n            output.writeShort(0)\n            output.writeShort(0)\n            output.writeShort(1)\n            output.writeShort(0x0009)\n            output.writeShort(5)\n            output.writeShort(6)\n            output.writeShort(1)\n            output.writeShort(7)\n            output.writeInt(16)\n            output.writeShort(2)\n            output.writeShort(1)\n            output.writeInt(4)\n            output.write([0x1A, 0x05, 0x68, 0xAC] as byte[])\n            output.writeShort(0)\n            output.writeShort(0)\n            output.writeShort(0)\n        }\n        Files.write(file, byteStream.toByteArray())\n        file.toFile()\n    }\n\n    private static void writeUtf8(DataOutputStream output, String value) {\n        byte[] bytes = value.getBytes(StandardCharsets.UTF_8)\n        output.writeByte(1)\n        output.writeShort(bytes.length)\n        output.write(bytes)\n    }\n\n    private static List<String> fileNames(List<String> paths) {\n"}]}
