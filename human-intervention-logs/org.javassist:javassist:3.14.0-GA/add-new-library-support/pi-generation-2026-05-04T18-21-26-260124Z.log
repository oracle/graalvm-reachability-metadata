.ClassMetaobject;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassMetaobjectTest {\n    @Test\n    void loadsClassWithClassForNameAndInvokesReflectiveMembers() throws Throwable {\n        boolean originalUseContextClassLoader = ClassMetaobject.useContextClassLoader;\n        try {\n            ClassMetaobject.useContextClassLoader = false;\n            ReflectiveStaticTarget.sharedValue = \"initial\";\n\n            ClassMetaobject metaobject = new ClassMetaobject(new String[] {ReflectiveStaticTarget.class.getName()});\n\n            Object created = metaobject.newInstance(new Object[] {\"created\"});\n            assertThat(created).isInstanceOf(ReflectiveStaticTarget.class);\n            assertThat(((ReflectiveStaticTarget) created).getName()).isEqualTo(\"created\");\n\n            assertThat(metaobject.trapFieldRead(\"sharedValue\")).isEqualTo(\"initial\");\n            metaobject.trapFieldWrite(\"sharedValue\", \"updated\");\n            assertThat(metaobject.trapFieldRead(\"sharedValue\")).isEqualTo(\"updated\");\n\n            assertThat(metaobject.trapMethodcall(0, new Object[] {\"Ada\"})).isEqualTo(\"updated Ada\");\n            assertThat(metaobject.getMethodName(0)).isEqualTo(\"staticGreeting\");\n            assertThat(metaobject.getParameterTypes(0)).containsExactly(String.class);\n            assertThat(metaobject.getReturnType(0)).isEqualTo(String.class);\n            assertThat(metaobject.getMethodIndex(\"staticGreeting\", new Class[] {String.class})).isZero();\n        } finally {\n            ClassMetaobject.useContextClassLoader = originalUseContextClassLoader;\n        }\n    }\n\n    @Test\n    void loadsClassWithContextClassLoader() {\n        boolean originalUseContextClassLoader = ClassMetaobject.useContextClassLoader;\n        ClassLoader originalClassLoader = Thread.currentThread().getContextClassLoader();\n        RecordingClassLoader recordingClassLoader = new RecordingClassLoader(originalClassLoader);\n        try {\n            ClassMetaobject.useContextClassLoader = true;\n            Thread.currentThread().setContextClassLoader(recordingClassLoader);\n\n            ClassMetaobject metaobject = new ClassMetaobject(new String[] {ReflectiveStaticTarget.class.getName()});\n\n            assertThat(metaobject.getJavaClass()).isEqualTo(ReflectiveStaticTarget.class);\n            assertThat(recordingClassLoader.getRequestedClassName()).isEqualTo(ReflectiveStaticTarget.class.getName());\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalClassLoader);\n            ClassMetaobject.useContextClassLoader = originalUseContextClassLoader;\n        }\n    }\n\n    @Test\n    void restoresConstructorsWhenDeserialized() throws Exception {\n        boolean originalUseContextClassLoader = ClassMetaobject.useContextClassLoader;\n        try {\n            ClassMetaobject.useContextClassLoader = false;\n            ClassMetaobject original = new ClassMetaobject(new String[] {ReflectiveStaticTarget.class.getName()});\n\n            ClassMetaobject restored = deserialize(serialize(original));\n\n            Object created = restored.newInstance(new Object[] {\"restored\"});\n            assertThat(((ReflectiveStaticTarget) created).getName()).isEqualTo(\"restored\");\n        } finally {\n            ClassMetaobject.useContextClassLoader = originalUseContextClassLoader;\n        }\n    }\n\n    @Test\n    void invokesInstanceMethodByReflectiveIdentifier() throws Throwable {\n        ReflectiveInstanceTarget target = new ReflectiveInstanceTarget(\"prefix-\");\n\n        Object result = ClassMetaobject.invoke(target, 7, new Object[] {\"value\"});\n\n        assertThat(result).isEqualTo(\"prefix-value\");\n    }\n\n    private static byte[] serialize(ClassMetaobject metaobject) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(metaobject);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static ClassMetaobject deserialize(byte[] serialized) throws Exception {\n        ByteArrayInputStream bytes = new ByteArrayInputStream(serialized);\n        try (ObjectInputStream input = new ObjectInputStream(bytes)) {\n            return (ClassMetaobject) input.readObject();\n        }\n    }\n\n    public static class ReflectiveStaticTarget {\n        public static String sharedValue = \"initial\";\n\n        private final String name;\n\n        public ReflectiveStaticTarget(String name) {\n            this.name = name;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public static String _m_0_staticGreeting(String name) {\n            return sharedValue + \" \" + name;\n        }\n    }\n\n    public static class ReflectiveInstanceTarget {\n        private final String prefix;\n\n        public ReflectiveInstanceTarget(String prefix) {\n            this.prefix = prefix;\n        }\n\n        public String _m_7_echo(String value) {\n            return prefix + value;\n        }\n    }\n\n    private static final class RecordingClassLoader extends ClassLoader {\n        private String requestedClassName;\n\n        private RecordingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        public Class<?> loadClass(String name) throws ClassNotFoundException {\n            requestedClassName = name;\n            return super.loadClass(name);\n        }\n\n        private String getRequestedClassName() {\n            return requestedClassName;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2375, "output": 1710, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 21493, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "tim