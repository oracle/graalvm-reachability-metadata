\n\n        private SimpleArtifact(String groupId, String artifactId, String version, String extension, String classifier, File file,\n                Map<String, String> properties) {\n            this.groupId = groupId;\n            this.artifactId = artifactId;\n            this.version = version;\n            this.extension = extension;\n            this.classifier = classifier;\n            this.file = file;\n            this.properties = Collections.unmodifiableMap(new HashMap<String, String>(properties));\n        }\n\n        @Override\n        public String getGroupId() {\n            return groupId;\n        }\n\n        @Override\n        public String getArtifactId() {\n            return artifactId;\n        }\n\n        @Override\n        public String getVersion() {\n            return version;\n        }\n\n        @Override\n        public Artifact setVersion(String version) {\n            return new SimpleArtifact(groupId, artifactId, version, extension, classifier, file, properties);\n        }\n\n        @Override\n        public String getBaseVersion() {\n            return version.endsWith(\"-SNAPSHOT\") ? version.substring(0, version.length() - \"-SNAPSHOT\".length()) : version;\n        }\n\n        @Override\n        public boolean isSnapshot() {\n            return version.endsWith(\"-SNAPSHOT\");\n        }\n\n        @Override\n        public String getClassifier() {\n            return classifier;\n        }\n\n        @Override\n        public String getExtension() {\n            return extension;\n        }\n\n        @Override\n        public File getFile() {\n            return file;\n        }\n\n        @Override\n        public Artifact setFile(File file) {\n            return new SimpleArtifact(groupId, artifactId, version, extension, classifier, file, properties);\n        }\n\n        @Override\n        public String getProperty(String key, String defaultValue) {\n            return properties.containsKey(key) ? properties.get(