metadata/org.scalatest/scalatest-refspec_2.13/index.json:9:    "description": "ScalaTest RefSpec provides the RefSpec testing style for ScalaTest on the JVM, where tests are represented by methods and discovered via reflection. It integrates with ScalaTest's core assertions, tagging, fixtures, and reporting so Scala projects can define and run method-oriented test suites.",
metadata/org.scalatest/scalatest-shouldmatchers_2.13/index.json:6:    "repository-url": "https://github.com/scalatest/scalatest",
metadata/org.scalatest/scalatest-shouldmatchers_2.13/index.json:9:    "description": "ScalaTest Should Matchers provides the should matcher syntax for expressing assertions in ScalaTest suites. It lets tests compare values, inspect collections and properties, and build readable expectations using ScalaTest's matcher DSL.",
metadata/com.aayushatharva.brotli4j/brotli4j/index.json:6:    "repository-url" : "https://github.com/hyperxpro/Brotli4j",
metadata/com.aayushatharva.brotli4j/brotli4j/index.json:9:    "description" : "Brotli4j provides Java bindings for Brotli compression and decompression using platform-specific native libraries. It exposes encoder and decoder APIs for working with Brotli-compressed data from JVM applications.",
