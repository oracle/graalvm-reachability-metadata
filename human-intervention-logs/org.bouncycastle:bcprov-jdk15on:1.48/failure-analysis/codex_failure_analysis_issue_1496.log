le.pqc.jcajce.provider.McEliece;\\nimport org.bouncycastle.pqc.jcajce.provider.Rainbow;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class BouncyCastlePQCProviderTest {\\n    @Test\\n    void registersPqcAlgorithmMappingsOnConstruction() {\\n        ensurePqcMappingsAreReachable();\\n\\n        BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();\\n\\n        assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);\\n        assertThat(provider.getInfo()).contains(\\\"Post-Quantum Security Provider\\\");\\n        boolean rainbowKeyFactoryRegistered = provider.hasAlgorithm(\\\"KeyFactory\\\", \\\"Rainbow\\\");\\n        boolean mcelieceKeyPairGeneratorRegistered = provider.hasAlgorithm(\\\"KeyPairGenerator\\\", \\\"McEliecePKCS\\\");\\n\\n        assertThat(provider.hasAlgorithm(\\\"KeyPairGenerator\\\", \\\"Rainbow\\\"))\\n            .isEqualTo(rainbowKeyFactoryRegistered);\\n        assertThat(provider.hasAlgorithm(\\\"Signature\\\", \\\"SHA256WITHRainbow\\\"))\\n            .isEqualTo(rainbowKeyFactoryRegistered);\\n        assertThat(provider.hasAlgorithm(\\\"Cipher\\\", \\\"McElieceKobaraImaiWithSHA256\\\"))\\n            .isEqualTo(mcelieceKeyPairGeneratorRegistered);\\n    }\\n\\n    @Test\\n    void exposesConfiguredImplementationClassNames() {\\n        ensurePqcMappingsAreReachable();\\n\\n        BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();\\n\\n        Object rainbowKeyFactory = provider.get(\\\"KeyFactory.Rainbow\\\");\\n        if (rainbowKeyFactory == null) {\\n            assertThat(provider.get(\\\"KeyPairGenerator.McEliecePKCS\\\")).isNull();\\n            assertThat(provider.get(\\\"Cipher.McElieceKobaraImaiWithSHA256\\\")).isNull();\\n        } else {\\n            assertThat(rainbowKeyFactory)\\n                .isEqualTo(\\\"org.bouncycastle.pqc.jcajce.provider.rainbow.RainbowKeyFactorySpi\\\");\\n            assertThat(provider.get(\\\"KeyPairGenerator.McEliecePKCS\\\"))\\n                .isEqualTo(\\\"org.bouncycastle.pqc.jcajce.provider.mceliece.McElieceKeyPairGeneratorSpi$McEliece\\\");\\n            String sha256KobaraImaiCipher = \\\"org.bouncycastle.pqc.jcajce.provider.mceliece.\\\"\\n                + \\\"McElieceKobaraImaiCipherSpi$McElieceKobaraImai256\\\";\\n            assertThat(provider.get(\\\"Cipher.McElieceKobaraImaiWithSHA256\\\"))\\n                .isEqualTo(sha256KobaraImaiCipher);\\n        }\\n    }\\n\\n    private void ensurePqcMappingsAreReachable() {\\n        assertThat(new Rainbow.Mappings().getClass().getName())\\n            .isEqualTo(\\\"org.bouncycastle.pqc.jcajce.provider.Rainbow$Mappings\\\");\\n        assertThat(new McEliece.Mappings().getClass().getName())\\n            .isEqualTo(\\\"org.bouncycastle.pqc.jcajce.provider.McEliece$Mappings\\\");\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.started\",\"item\":{\"id\":\"item_77\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'javap -classpath /home/vjovanov/.m2/repository/org/bouncycastle/bcprov-jdk15on/1.48/bcprov-jdk15on-1.48.jar -p -c org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_77\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'javap -classpath /home/vjovanov/.m2/repository/org/bouncycastle/bcprov-jdk15on/1.48/bcprov-jdk15on-1.48.jar -p -c org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider'\",\"aggregated_output\":\"public class org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider extends java.security.Provider implements org.bouncycastle.jcajce.provider.config.ConfigurableProvider {\\n  private static java.lang.String info;\\n\\n  public static java.lang.String PROVIDER_NAME;\\n\\n  public static final org.bouncycastle.jcajce.provider.config.ProviderConfigurati