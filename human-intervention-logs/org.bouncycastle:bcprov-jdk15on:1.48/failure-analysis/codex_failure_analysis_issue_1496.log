lueOf(13L);\\n        BCDSAPublicKey original = createPublicKey(y, p, q, g);\\n\\n        byte[] serializedKey = serialize(original);\\n        DSAPublicKey deserialized = (DSAPublicKey) deserialize(serializedKey);\\n\\n        assertThat(deserialized).isInstanceOf(BCDSAPublicKey.class);\\n        assertThat(deserialized).isEqualTo(original);\\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\\\"DSA\\\");\\n        assertThat(deserialized.getFormat()).isEqualTo(\\\"X.509\\\");\\n        assertThat(deserialized.getY()).isEqualTo(y);\\n        assertThat(deserialized.getParams().getP()).isEqualTo(p).isInstanceOf(TrackedBigInteger.class);\\n        assertThat(deserialized.getParams().getQ()).isEqualTo(q).isInstanceOf(TrackedBigInteger.class);\\n        assertThat(deserialized.getParams().getG()).isEqualTo(g).isInstanceOf(TrackedBigInteger.class);\\n        assertThat(deserialized.getEncoded()).isNotEmpty();\\n        assertThat(deserialized.toString()).contains(\\\"DSA Public Key\\\", y.toString(16));\\n    }\\n\\n    private static BCDSAPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger q, BigInteger g)\\n        throws Exception {\\n        DSAParameter dsaParameter = new DSAParameter(p, q, g);\\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\\n            X9ObjectIdentifiers.id_dsa,\\n            dsaParameter.toASN1Primitive());\\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(y));\\n        return new BCDSAPublicKey(publicKeyInfo);\\n    }\\n\\n    private static byte[] serialize(Object value) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream output = new TrackingObjectOutputStream(bytes)) {\\n            output.writeObject(value);\\n        }\\n        return bytes.toByteArray();\\n    }\\n\\n    private static Object deserialize(byte[] value) throws Exception {\\n        try (Object