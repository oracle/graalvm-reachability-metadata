)) {\\n            output.writeObject(publicKey);\\n        }\\n        assertThat(bytes.size()).isGreaterThan(0);\\n        return bytes.toByteArray();\\n    }\\n\\n    private static BCDHPublicKey deserialize(byte[] serializedKey) throws Exception {\\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\\n            return (BCDHPublicKey) input.readObject();\\n        }\\n    }\\n}\\n\"}, \"partialJson\": \"{\\\"path\\\":\\\"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCDHPublicKeyTest.java\\\",\\\"content\\\":\\\"/*\\\\n * Copyright and related rights waived via CC0\\\\n *\\\\n * You should have received a copy of the CC0 legalcode along with this\\\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\\\n */\\\\npackage org_bouncycastle.bcprov_jdk15on;\\\\n\\\\nimport org.bouncycastle.asn1.ASN1Integer;\\\\nimport org.bouncycastle.asn1.pkcs.DHParameter;\\\\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\\\\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\\\\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\\\\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;\\\\nimport org.junit.jupiter.api.Test;\\\\n\\\\nimport java.io.ByteArrayInputStream;\\\\nimport java.io.ByteArrayOutputStream;\\\\nimport java.io.ObjectInputStream;\\\\nimport java.io.ObjectOutputStream;\\\\nimport java.math.BigInteger;\\\\n\\\\nimport static org.assertj.core.api.Assertions.assertThat;\\\\n\\\\npublic class BCDHPublicKeyTest {\\\\n    private static final BigInteger P = new BigInteger(\\\\\\\"123456789123456789123456789123456789123456789123456789\\\\\\\");\\\\n    private static final BigInteger G = BigInteger.valueOf(5L);\\\\n    private static final BigInteger Y = new BigInteger(\\\\\\\"987654321987654321\\\\\\\");\\\\n    private static final int L = 64;\\\\n\\\\n    @Test\\\\n    public void serializesAndDeserializesDiffieHellmanPublicKey() throws Exception {\\\\n        BCDHPublicKey originalKey = createPublicKey();\\\\n\\\\n        byte[] serializedKey = serialize(originalKey);\\\\n        BCDHPublicKey restoredKey = deserialize(serializedKey);\\\\n\\\\n        assertThat(restoredKey.getY()).isEqualTo(originalKey.getY());\\\\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\\\\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\\\\n        assertThat(restoredKey.getParams().getL()).isEqualTo(originalKey.getParams().getL());\\\\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\\\\\\\"DH\\\\\\\");\\\\n        assertThat(restoredKey.getFormat()).isEqualTo(\\\\\\\"X.509\\\\\\\");\\\\n    }\\\\n\\\\n    private static BCDHPublicKey createPublicKey() {\\\\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(\\\\n                new AlgorithmIdentifier(\\\\n                        PKCSObjectIdentifiers.dhKeyAgreement,\\\\n                        new DHParameter(P, G, L).toASN1Primitive()),\\\\n                new ASN1Integer(Y));\\\\n\\\\n        return new BCDHPublicKey(publicKeyInfo);\\\\n    }\\\\n\\\\n    private static byte[] serialize(BCDHPublicKey publicKey) throws Exception {\\\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\\\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\\\n            output.writeObject(publicKey);\\\\n        }\\\\n        assertThat(bytes.size()).isGreaterThan(0);\\\\n        return bytes.toByteArray();\\\\n    }\\\\n\\\\n    private static BCDHPublicKey deserialize(byte[] serializedKey) throws Exception {\\\\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\\\\n            return (BCDHPublicKey) input.readObject();\\\\n        }\\\\n    }\\\\n}\\\\n\\\"}\"}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"gpt-5.5\", \"us