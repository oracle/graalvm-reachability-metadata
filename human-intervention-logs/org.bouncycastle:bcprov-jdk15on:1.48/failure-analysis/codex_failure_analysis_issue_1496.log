tStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\\n            return (BCDHPrivateKey) input.readObject();\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1780854770773}}\nhuman-intervention-logs/org.bouncycastle:bcprov-jdk15on:1.48/add-new-library-support/pi-generation-2026-06-07T17-53-22-139140Z.log:574:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_rc9vXOB6ulCuscdRkdhLsSWD|fc_0bc7e5e3d710be75016a25aff26d548194ad6bfbcf482611a3\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcprov_jdk15on;\\n\\nimport org.bouncycastle.asn1.ASN1Integer;\\nimport org.bouncycastle.asn1.pkcs.DHParameter;\\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.ObjectInputStream;\\nimport java.io.ObjectOutputStream;\\nimport java.math.BigInteger;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class BCDHPrivateKeyTest {\\n    private static final BigInteger P = new BigInteger(\\\"123456789123456789123456789123456789123456789123456789\\\");\\n    private static final BigInteger G = BigInteger.valueOf(5L);\\n    private static final BigInteger X = new BigInteger(\\\"123456789123456789\\\");\\n    private static final int L = 64;\\n\\n    @Test\\n    public void serializesAndDeserializesDiffieHellmanPrivateKey() throws Exception {\\n        BCDHPrivateKey originalKey = createPrivateKey();\\n\\n        byte[] serializedKey = serialize(originalKey);\\n        BCDHPrivateKey restoredKey = deserialize(serializedKey);\\n\\n        assertThat(restoredKey.getX()).isEqualTo(originalKey.getX());\\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\\n        assertThat(restoredKey.getParams().getL()).isEqualTo(originalKey.getParams().getL());\\n    }\\n\\n    private static BCDHPrivateKey createPrivateKey() throws Exception {\\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(\\n                new AlgorithmIdentifier(\\n                        PKCSObjectIdentifiers.dhKeyAgreement,\\n                        new DHParameter(P, G, L).toASN1Primitive()),\\n                new ASN1Integer(X));\\n\\n        return new BCDHPrivateKey(privateKeyInfo);\\n    }\\n\\n    private static byte[] serialize(BCDHPrivateKey privateKey) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\n            output.writeObject(privateKey);\\n        }\\n        assertThat(bytes.size()).isGreaterThan(0);\\n        return bytes.toByteArray();\\n    }\\n\\n    private static BCDHPrivateKey deserialize(byte[] serializedKey) throws Exception {\\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\\n            return (BCDHPrivateKey) input.readObject();\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1780854770773}}\nhuman-intervention-logs/org.bouncycastle:bcprov-jdk15on:1.48/add-new-library-support/pi-generation-2026-06-07T17-53-22-139140Z.log:595:      public void loadsPostQuantumAlgorithmMappings() throws Exception {\nhuman-intervention-logs/org.bouncycastle:bcprov-jdk15on:1.48/add-new-library-support/pi-generation-2026-06-07T17-53-22-139140Z.log:623:[recv]