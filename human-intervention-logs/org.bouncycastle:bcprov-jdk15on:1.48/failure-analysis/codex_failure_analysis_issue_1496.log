sn1.ASN1Integer;\\n    20\\timport org.bouncycastle.asn1.pkcs.DHParameter;\\n    21\\timport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\\n    22\\timport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\\n    23\\timport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\\n    24\\timport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey;\\n    25\\timport org.junit.jupiter.api.Test;\\n    26\\t\\n    27\\timport static org.assertj.core.api.Assertions.assertThat;\\n    28\\t\\n    29\\tpublic class BCDHPrivateKeyTest {\\n    30\\t    @Test\\n    31\\t    void serializesAndDeserializesDhPrivateKeyParameters() throws Exception {\\n    32\\t        BigInteger p = BigInteger.valueOf(23L);\\n    33\\t        BigInteger g = BigInteger.valueOf(5L);\\n    34\\t        BigInteger x = BigInteger.valueOf(6L);\\n    35\\t        DHPrivateKey original = createPrivateKey(x, p, g);\\n    36\\t\\n    37\\t        assertThat(original).isInstanceOf(BCDHPrivateKey.class);\\n    38\\t\\n    39\\t        byte[] serializedKey = serialize(original);\\n    40\\t        ensureSerializationBaseConstructorIsReachable();\\n    41\\t        DHPrivateKey deserialized = (DHPrivateKey) deserialize(serializedKey);\\n    42\\t\\n    43\\t        assertThat(deserialized).isInstanceOf(BCDHPrivateKey.class);\\n    44\\t        assertThat(deserialized).isEqualTo(original);\\n    45\\t        assertThat(deserialized.getAlgorithm()).isEqualTo(\\\"DH\\\");\\n    46\\t        assertThat(deserialized.getFormat()).isEqualTo(\\\"PKCS#8\\\");\\n    47\\t        assertThat(deserialized.getX()).isEqualTo(x);\\n    48\\t        assertThat(deserialized.getParams().getP()).isEqualTo(p);\\n    49\\t        assertThat(deserialized.getParams().getG()).isEqualTo(g);\\n    50\\t        assertThat(deserialized.getParams().getL()).isZero();\\n    51\\t        assertThat(deserialized.getEncoded()).isNotEmpty();\\n    52\\t    }\\n    53\\t\\n    54\\t    private static DHPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger g) throws Exception {\\n    55\\t        DHParameter dhParameter = new DHParameter(p, g, 0);\\n    56\\t        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\\n    57\\t            PKCSObjectIdentifiers.dhKeyAgreement,\\n    58\\t            dhParameter.toASN1Primitive());\\n    59\\t        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(x));\\n    60\\t        return new BCDHPrivateKey(privateKeyInfo);\\n    61\\t    }\\n    62\\t\\n    63\\t    private static byte[] serialize(Object value) throws Exception {\\n    64\\t        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n    65\\t        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\n    66\\t            output.writeObject(value);\\n    67\\t        }\\n    68\\t        return bytes.toByteArray();\\n    69\\t    }\\n    70\\t\\n    71\\t    private static void ensureSerializationBaseConstructorIsReachable() throws Exception {\\n    72\\t        assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();\\n    73\\t    }\\n    74\\t\\n    75\\t    private static Object deserialize(byte[] value) throws Exception {\\n    76\\t        try (ObjectInputStream input = new BouncyCastleObjectInputStream(new ByteArrayInputStream(value))) {\\n    77\\t            return input.readObject();\\n    78\\t        }\\n    79\\t    }\\n    80\\t\\n    81\\t    private static final class BouncyCastleObjectInputStream extends ObjectInputStream {\\n    82\\t        private BouncyCastleObjectInputStream(ByteArrayInputStream input) throws Exception {\\n    83\\t            super(input);\\n    84\\t        }\\n    85\\t\\n    86\\t        @Override\\n    87\\t        protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {\\n    88\\t            if (BCDHPrivateKey.class.getName().equals(description.getName())) {\\n    89\\t                return BCDH