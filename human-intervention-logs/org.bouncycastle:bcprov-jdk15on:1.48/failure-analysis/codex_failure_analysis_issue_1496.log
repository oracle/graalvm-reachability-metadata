icKeyParameters() throws Exception {\\n        BigInteger publicValue = BigInteger.valueOf(7L);\\n        BCGOST3410PublicKey original = createPublicKey(publicValue);\\n\\n        byte[] serializedKey = serialize(original);\\n        GOST3410PublicKey deserialized = (GOST3410PublicKey) deserialize(serializedKey);\\n\\n        assertThat(deserialized).isInstanceOf(BCGOST3410PublicKey.class);\\n        assertThat(deserialized).isEqualTo(original);\\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\\\"GOST3410\\\");\\n        assertThat(deserialized.getFormat()).isEqualTo(\\\"X.509\\\");\\n        assertThat(deserialized.getY()).isEqualTo(publicValue);\\n        assertThat(deserialized.getParameters().getPublicKeyParamSetOID())\\n            .isEqualTo(original.getParameters().getPublicKeyParamSetOID());\\n        assertThat(deserialized.getParameters().getDigestParamSetOID())\\n            .isEqualTo(original.getParameters().getDigestParamSetOID());\\n        assertThat(deserialized.getParameters().getPublicKeyParameters())\\n            .isEqualTo(original.getParameters().getPublicKeyParameters());\\n        assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());\\n        assertThat(deserialized.toString()).contains(\\\"GOST3410 Public Key\\\", publicValue.toString(16));\\n    }\\n\\n    @Test\\n    void serializesAndDeserializesExplicitGost3410PublicKeyParameters() throws Exception {\\n        BigInteger publicValue = BigInteger.valueOf(13L);\\n        BigInteger p = new TrackedBigInteger(\\\"23\\\");\\n        BigInteger q = new TrackedBigInteger(\\\"11\\\");\\n        BigInteger a = new TrackedBigInteger(\\\"2\\\");\\n        BCGOST3410PublicKey original = createPublicKey(publicValue, p, q, a);\\n\\n        byte[] serializedKey = serialize(original);\\n        GOST3410PublicKey deserialized = (GOST3410PublicKey) deserialize(serializedKey);\\n\\n        assertThat(deserialized).isInstanceOf(BCGOST3410PublicKey.class);\\n        assertThat