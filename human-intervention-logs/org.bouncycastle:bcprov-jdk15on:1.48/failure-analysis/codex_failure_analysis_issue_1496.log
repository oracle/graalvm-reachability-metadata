alue) throws Exception {\\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {\\n            return input.readObject();\\n        }\\n    }\\n\\n    private static byte[] replaceSerializedClassName(byte[] serializedValue, String oldName, String newName) {\\n        byte[] oldNameBytes = oldName.getBytes(StandardCharsets.UTF_8);\\n        byte[] newNameBytes = newName.getBytes(StandardCharsets.UTF_8);\\n        int oldNameIndex = indexOf(serializedValue, oldNameBytes);\\n\\n        assertThat(oldNameIndex).isGreaterThan(1);\\n        assertThat(serializedValue[oldNameIndex - 2] & 0xff).isEqualTo(oldNameBytes.length >>> 8);\\n        assertThat(serializedValue[oldNameIndex - 1] & 0xff).isEqualTo(oldNameBytes.length & 0xff);\\n\\n        ByteArrayOutputStream rewritten = new ByteArrayOutputStream(\\n            serializedValue.length - oldNameBytes.length + newNameBytes.length);\\n        rewritten.write(serializedValue, 0, oldNameIndex - 2);\\n        rewritten.write((newNameBytes.length >>> 8) & 0xff);\\n        rewritten.write(newNameBytes.length & 0xff);\\n        rewritten.write(newNameBytes, 0, newNameBytes.length);\\n        rewritten.write(\\n            serializedValue,\\n            oldNameIndex + oldNameBytes.length,\\n            serializedValue.length - oldNameIndex - oldNameBytes.length);\\n        return rewritten.toByteArray();\\n    }\\n\\n    private static int indexOf(byte[] value, byte[] pattern) {\\n        for (int i = 0; i <= value.length - pattern.length; i++) {\\n            if (Arrays.equals(Arrays.copyOfRange(value, i, i + pattern.length), pattern)) {\\n                return i;\\n            }\\n        }\\n        return -1;\\n    }\\n\\n    private static final class SerializedForm implements Serializable {\\n        private static final long serialVersionUID = JCE_DH_PUBLIC_KEY_SERIAL_VERSION_UID;\\n\\n        private final transient BigInteger y;\\n        private final transient BigInteger p;\\n        private final transient BigInteger g;\\n        private final transient int l;\\n\\n        private SerializedForm(BigInteger y, BigInteger p, BigInteger g, int l) {\\n            this.y = y;\\n            this.p = p;\\n            this.g = g;\\n            this.l = l;\\n        }\\n\\n        private void writeObject(ObjectOutputStream out) throws IOException {\\n            out.writeObject(y);\\n            out.writeObject(p);\\n            out.writeObject(g);\\n            out.writeInt(l);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1778118547136}]}\n","exit_code":0,"status":"completed"}}
