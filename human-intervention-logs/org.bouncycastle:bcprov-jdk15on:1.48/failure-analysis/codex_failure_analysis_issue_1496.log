s\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcprov_jdk15on;\\n\\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;\\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.io.ByteArrayInputStream;\\nimport java.io.ByteArrayOutputStream;\\nimport java.io.ObjectInputStream;\\nimport java.io.ObjectOutputStream;\\nimport java.math.BigInteger;\\nimport java.security.KeyFactory;\\nimport java.security.PrivateKey;\\nimport java.security.spec.DSAPrivateKeySpec;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class BCDSAPrivateKeyTest {\\n    private static final BigInteger P = new BigInteger(\\\"123456789123456789123456789123456789123456789123456789\\\");\\n    private static final BigInteger Q = new BigInteger(\\\"123456789123456789123456789\\\");\\n    private static final BigInteger G = BigInteger.valueOf(5L);\\n    private static final BigInteger X = new BigInteger(\\\"123456789123456789\\\");\\n\\n    @Test\\n    public void serializesAndDeserializesDsaPrivateKey() throws Exception {\\n        BCDSAPrivateKey originalKey = createPrivateKey();\\n\\n        byte[] serializedKey = serialize(originalKey);\\n        BCDSAPrivateKey restoredKey = deserialize(serializedKey);\\n\\n        assertThat(restoredKey.getX()).isEqualTo(originalKey.getX());\\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(originalKey.getParams().getQ());\\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\\n        assertThat(restoredKey).isEqualTo(originalKey);\\n    }\\n\\n    private static BCDSAPrivateKey createPrivateKey() throws Exception {\\n        KeyFactory keyFactory = KeyFactory.getInstance(\\\"DSA\\\", new BouncyCastleProvider());\\n        PrivateKey privateKey = ke