         assertThat(directlyReachableParser).isNotNull();\\n            assertThat(parser.getProvider()).isSameAs(provider);\\n            parser.init(new byte[0]);\\n            assertThat(parser.readAll()).isEmpty();\\n        } finally {\\n            restoreProviderProperty(provider, previousImplementation);\\n        }\\n    }\\n\\n    private static final class ParserProvider extends Provider {\\n        private ParserProvider() {\\n            super(\\\"X509UtilTestProvider\\\", 1.0, \\\"Provider for X509Util dynamic access coverage\\\");\\n            put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\\n        }\\n    }\\n\\n    private static Provider findBootstrapLoadedProvider() {\\n        for (Provider provider : Security.getProviders()) {\\n            if (provider.getClass().getClassLoader() == null) {\\n                return provider;\\n            }\\n        }\\n        throw new AssertionError(\\\"Expected a JDK security provider loaded by the bootstrap class loader\\\");\\n    }\\n\\n    private static void restoreProviderProperty(Provider provider, Object previousImplementation) {\\n        if (previousImplementation == null) {\\n            provider.remove(PARSER_PROPERTY);\\n        } else {\\n            provider.put(PARSER_PROPERTY, previousImplementation);\\n        }\\n    }\\n}\\n\"}], \"isError\": false, \"timestamp\": 1780854770774}}\nhuman-intervention-logs/org.bouncycastle:bcprov-jdk15on:1.48/add-new-library-support/pi-generation-2026-06-07T17-53-22-139140Z.log:705:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"toolResult\", \"toolCallId\": \"call_wXbUnSFH0BUzfTjXi8MZvg6l|fc_0bc7e5e3d710be75016a25aff26d6c8194a789421caf5cbff9\", \"toolName\": \"read\", \"content\": [{\"type\": \"text\", \"text\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcprov_jdk15on;\\n\\nimport org.bouncycastle.jce.provider.X509CertParser;\\nimport org.bouncycastle.x509.X509StreamParser;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.security.Provider;\\nimport java.security.Security;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class X509UtilTest {\\n    private static final String PARSER_TYPE = \\\"CERTIFICATE\\\";\\n    private static final String PARSER_PROPERTY = \\\"X509StreamParser.\\\" + PARSER_TYPE;\\n    private static final String PARSER_IMPLEMENTATION = X509CertParser.class.getName();\\n\\n    @Test\\n    public void createsX509StreamParserThroughProviderClassLoader() throws Exception {\\n        X509CertParser directlyReachableParser = new X509CertParser();\\n        Provider provider = new ParserProvider();\\n\\n        X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\\n\\n        assertThat(directlyReachableParser).isNotNull();\\n        assertThat(parser.getProvider()).isSameAs(provider);\\n        parser.init(new byte[0]);\\n        assertThat(parser.read()).isNull();\\n    }\\n\\n    @Test\\n    public void createsX509StreamParserThroughClassForNameFallback() throws Exception {\\n        X509CertParser directlyReachableParser = new X509CertParser();\\n        Provider provider = findBootstrapLoadedProvider();\\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\\n\\n        try {\\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\\n\\n            assertThat(directlyReachableParser).isNotNull();\\n            assertThat(parser.getProvider()).isSameAs(provider);\\n            parser.init(new byte[0]);\\n            assertThat(parser.readAll()).isEmpty();\\n        } finally {\\n            restoreProviderProperty(provider, previousImplementation);\\n        }\\n    }\\n\\n    private static final class ParserProvid