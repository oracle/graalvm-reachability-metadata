      }
  
      JCEElGamalPrivateKey(
          ElGamalPrivateKey    key)
      {
          this.x = key.getX();
          this.elSpec = key.getParameters();
      }
  
      JCEElGamalPrivateKey(
          DHPrivateKey    key)
      {
          this.x = key.getX();
          this.elSpec = new ElGamalParameterSpec(key.getParams().getP(), key.getParams().getG());
      }
      
      JCEElGamalPrivateKey(
