      {
          this.x = spec.getX();
          this.elSpec = new ElGamalParameterSpec(spec.getParams().getP(), spec.getParams().getG());
      }
  
      JCEElGamalPrivateKey(
          DHPrivateKeySpec    spec)
      {
          this.x = spec.getX();
          this.elSpec = new ElGamalParameterSpec(spec.getP(), spec.getG());
      }
      
