[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/PKCS12BagAttributeCarrierImplTest.java","edits":[{"oldText":"import java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.util.ArrayList;","newText":"import java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.ArrayList;"},{"oldText":"import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\nimport org.junit.jupiter.api.Test;","newText":"import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\nimport org.bouncycastle.jce.interfaces.PKCS12BagAttributeCarrier;\nimport org.bouncycastle.jce.provider.JCERSAPrivateKey;\nimport org.junit.jupiter.api.Test;"},{"oldText":"    private static final DERUTF8String FRIENDLY_NAME = new DERUTF8String(\"signing key\");\n    private static final DERUTF8String LOCAL_KEY_ID = new DERUTF8String(\"local key id\");","newText":"    private static final DERUTF8String FRIENDLY_NAME = new DERUTF8String(\"signing key\");\n    private static final DERUTF8String LOCAL_KEY_ID = new DERUTF8String(\"local key id\");\n    private static final BigInteger MODULUS = BigInteger.valueOf(65537L);\n    private static final BigInteger PRIVATE_EXPONENT = BigInteger.valueOf(17L);"},{"oldText":"    private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws Exception {","newText":"    @Test\n    void rsaPrivateKeySerializationRoundTripPreservesCarrierBagAttributes() throws Exception {\n        TestRsaPrivateKey privateKey = new TestRsaPrivateKey(MODULUS, PRIVATE_EXPONENT);\n        privateKey.setBagAttribute(FRIENDLY_NAME_OID, FRIENDLY_NAME);\n        privateKey.setBagAttribute(LOCAL_KEY_ID_OID, LOCAL_KEY_ID);\n\n        TestRsaPrivateKey restoredKey = (TestRsaPrivateKey)deserialize(serialize(privateKey));\n\n        assertThat(restoredKey.getModulus()).isEqualTo(MODULUS);\n        as