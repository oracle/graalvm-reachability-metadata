  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.KeyPair;
  import java.security.SecureRandom;
  import java.security.interfaces.ECPrivateKey;
  import java.security.spec.ECGenParameterSpec;
  
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.cryptopro.ECGOST3410NamedCurves;
  import org.bouncycastle.crypto.params.ECDomainParameters;
  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PrivateKey;
  import org.bouncycastle.jcajce.provider.asymmetric.ecgost.KeyPairGeneratorSpi;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECPrivateKeySpec;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCECGOST3410PrivateKeyTest {
      private static final String CURVE_NAME = "GostR3410-2001-CryptoPro-A";
  
      @Test
      void serializesAndDeserializesGost3410PrivateKeyEncoding() throws Exception {
          BigInteger privateValue = BigInteger.valueOf(7L);
          BCECGOST3410PrivateKey original = createPrivateKey(privateValue);
  
          assertThat(original.getEncoded()).isNotEmpty();
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          ECPrivateKey deserialized = (ECPrivateKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCECGOST3410PrivateKey.class);
          assertThat(deserialized.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(deserialized.getFormat()).isEqualTo("PKCS#8");
          assertThat(deserialized.getS()).isEqualTo(privateValue);
          assertThat(deserialized.getParams().getOrder()).isEqualTo(original.getParams().getOrder());
          assertThat(deserialized.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());
          assertThat(deserialized.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());
          assertThat(deserialized.getParams().getCurve()).isEqualTo(original.getParams().getCurve());
          assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());
      }
  
      @Test
      void serializesAndDeserializesProviderGeneratedGost3410PrivateKey() throws Exception {
          KeyPairGeneratorSpi generator = new KeyPairGeneratorSpi();
          generator.initialize(new ECGenParameterSpec(CURVE_NAME), new SecureRandom(new byte[] {1, 2, 3, 4}));
          KeyPair keyPair = generator.generateKeyPair();
  
          assertThat(keyPair.getPrivate()).isInstanceOf(BCECGOST3410PrivateKey.class);
          BCECGOST3410PrivateKey original = (BCECGOST3410PrivateKey) keyPair.getPrivate();
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          ECPrivateKey deserialized = (ECPrivateKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCECGOST3410PrivateKey.class);
          assertThat(deserialized.getAlgorithm()).isEqualTo("ECGOST3410");
          assertThat(deserialized.getS()).isEqualTo(original.getS());
          assertThat(deserialized.getParams().getOrder()).isEqualTo(original.getParams().getOrder());
          assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());
      }
  
      private static BCECGOST3410PrivateKey createPrivateKey(BigInteger privateValue) {
          ASN1ObjectIdentifier curveOid = ECGOST3410NamedCurves.getOID(CURVE_NAME);
          ECDomainParameters domainParameters = ECGOST3410NamedCurves.getByOID(curveOid);
          assertThat(domainParameters).isNotNull();
  
          ECNamedCurveParameterSpec parameterSpec = new ECNamedCurveParameterSpec(
              CURVE_NAME,
              domainParameters.getCurve(),
              domainParameters.getG(),
              domainParameters.getN(),
              domainParameters.getH(),
              domainParameters.getSeed());
          return new BCECGOST3410PrivateKey(new ECPrivateKeySpec(privateValue, parameterSpec));
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static void ensureSerializationBaseConstructorIsReachable() throws Exception {
          assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
      }
  }
