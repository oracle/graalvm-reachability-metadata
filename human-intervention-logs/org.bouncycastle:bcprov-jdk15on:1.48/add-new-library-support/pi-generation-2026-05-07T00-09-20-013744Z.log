[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_jstHDKkwxGI2lPmjJM7NJkWH|fc_01291e17151e63f70169fbd8187310819faf9a97bd05bb345e", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.math.BigInteger;\n\nimport javax.crypto.interfaces.DHPrivateKey;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.DHParameter;\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCDHPrivateKeyTest {\n    @Test\n    void serializesAndDeserializesDhPrivateKeyParameters() throws Exception {\n        BigInteger p = BigInteger.valueOf(23L);\n        BigInteger g = BigInteger.valueOf(5L);\n        BigInteger x = BigInteger.valueOf(6L);\n        DHPrivateKey original = createPrivateKey(x, p, g);\n\n        assertThat(original).isInstanceOf(BCDHPrivateKey.class);\n\n        byte[] serializedKey = serialize(original);\n        ensureSerializationBaseConstructorIsReachable();\n        DHPrivateKey deserialized = (DHPrivateKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(BCDHPrivateKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(deserialized.getX()).isEqualTo(x);\n        assertThat(deserialized.getParams().getP()).isEqualTo(p);\n        assertThat(deserialized.getParams().getG()).isEqualTo(g);\n        assertThat(deserialized.getParams().getL()).isZero();\n        assertThat(deserialized.getEncoded()).isNotEmpty();\n    }\n\n    private static DHPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger g) throws Exception {\n        DHParameter dhParameter = new DHParameter(p, g, 0);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n            PKCSObjectIdentifiers.dhKeyAgreement,\n            dhParameter.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(x));\n        return new BCDHPrivateKey(privateKeyInfo);\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static void ensureSerializationBaseConstructorIsReachable() throws Exception {\n        assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();\n    }\n\n    private static Object deserialize(byte[] value) throws Exception {\n        try (ObjectInputStream input = new BouncyCastleObjectInputStream(new ByteArrayInputStream(value))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class BouncyCastleObjectInputStream extends ObjectInputStream {\n        private BouncyCastleObjectInputStream(ByteArrayInputStream input) throws Exception {\n            super(input);\n        }\n\n        @Override\n        protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {\n            if (BCDHPrivateKey.class.getName().equals(description.getName())) {\n                return BCDHPrivateKey.class;\n            }\n            return super.resolveClass(description);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778112536766}}
