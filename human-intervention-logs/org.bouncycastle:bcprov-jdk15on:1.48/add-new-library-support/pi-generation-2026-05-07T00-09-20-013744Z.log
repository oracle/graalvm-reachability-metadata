  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.interfaces.ECPrivateKey;
  import java.util.Enumeration;
  
  import org.bouncycastle.asn1.ASN1Encodable;
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.jcajce.provider.asymmetric.ec.BCECPrivateKey;
  import org.bouncycastle.jce.ECNamedCurveTable;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;
  import org.bouncycastle.jce.spec.ECPrivateKeySpec;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCECPrivateKeyTest {
      @Test
      void serializesAndDeserializesEcPrivateKeyParameters() throws Exception {
          BigInteger privateValue = BigInteger.valueOf(7L);
          BCECPrivateKey original = createPrivateKey(privateValue);
  
          assertThat(original.getEncoded()).isNotEmpty();
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          ECPrivateKey deserialized = (ECPrivateKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCECPrivateKey.class);
          assertThat(deserialized.getAlgorithm()).isEqualTo("EC");
          assertThat(deserialized.getFormat()).isEqualTo("PKCS#8");
          assertThat(deserialized.getS()).isEqualTo(privateValue);
          assertThat(deserialized.getParams().getOrder()).isEqualTo(original.getParams().getOrder());
          assertThat(deserialized.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());
          assertThat(deserialized.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());
          assertThat(deserialized.getParams().getCurve()).isEqualTo(original.getParams().getCurve());
          assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());
  
          BCECPrivateKey bouncyCastleKey = (BCECPrivateKey) deserialized;
          ASN1ObjectIdentifier bagAttributeId = new ASN1ObjectIdentifier("1.2.840.113549.1.9.20");
          ASN1Encodable bagAttributeValue = new ASN1Integer(BigInteger.ONE);
          bouncyCastleKey.setBagAttribute(bagAttributeId, bagAttributeValue);
  
          Enumeration<?> bagAttributeKeys = bouncyCastleKey.getBagAttributeKeys();
          assertThat(bagAttributeKeys.hasMoreElements()).isTrue();
          assertThat(bagAttributeKeys.nextElement()).isEqualTo(bagAttributeId);
          assertThat(bouncyCastleKey.getBagAttribute(bagAttributeId)).isEqualTo(bagAttributeValue);
      }
  
      private static BCECPrivateKey createPrivateKey(BigInteger privateValue) {
          ECNamedCurveParameterSpec parameterSpec = ECNamedCurveTable.getParameterSpec("prime256v1");
          assertThat(parameterSpec).isNotNull();
          ECPrivateKeySpec privateKeySpec = new ECPrivateKeySpec(privateValue, parameterSpec);
          return new BCECPrivateKey("EC", privateKeySpec, BouncyCastleProvider.CONFIGURATION);
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static void ensureSerializationBaseConstructorIsReachable() throws Exception {
          assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
