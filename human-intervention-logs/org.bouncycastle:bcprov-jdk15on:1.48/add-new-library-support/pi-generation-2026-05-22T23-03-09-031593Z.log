eKeyTest {\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger X = BigInteger.valueOf(6L);\n\n    @Test\n    void legacyJceElGamalPrivateKeySerializationRoundTripPreservesPrivateParameters() throws Exception {\n        JCEElGamalPrivateKey privateKey = deserializeLegacyPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        JCEElGamalPrivateKey restoredKey = (JCEElGamalPrivateKey) deserialize(serializedKey);\n\n        assertThat(privateKey.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(privateKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(privateKey.getX()).isEqualTo(X);\n        assertThat(privateKey.getParameters().getP()).isEqualTo(P);\n        assertThat(privateKey.getParameters().getG()).isEqualTo(G);\n        assertThat(restoredKey.getX()).isEqualTo(X);\n        assertThat(restoredKey.getParameters().getP()).isEqualTo(P);\n        assertThat(restoredKey.getParameters().getG()).isEqualTo(G);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    private static JCEElGamalPrivateKey deserializeLegacyPrivateKey() throws Exception {\n        SerializedJCEElGamalPrivateKey proxy = new SerializedJCEElGamalPrivateKey(X, P, G);\n        byte[] proxyStream = serialize(proxy);\n        byte[] targetStream = replaceSerializedClassName(\n                proxyStream,\n                SerializedJCEElGamalPrivateKey.class.getName(),\n                JCEElGamalPrivateKey.class.getName());\n\n        return (JCEElGamalPrivateKey) deserialize(targetStream);\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream byteStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectStream = new ObjectOutputStream(byteStream)) {\n            objectStream.writeObject(value);\n        }\n        return byteStream.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectStream = new ObjectInputStream(new ByteArrayInputStream(serializedValue))) {\n            return objectStream.readObject();\n        }\n    }\n\n    private static byte[] replaceSerializedClassName(byte[] stream, String oldName, String newName) throws IOException {\n        byte[] oldUtf = serializedUtf(oldName);\n        byte[] newUtf = serializedUtf(newName);\n\n        int offset = firstIndexOf(stream, oldUtf);\n        assertThat(offset).isGreaterThanOrEqualTo(0);\n\n        ByteArrayOutputStream rewrittenStream = new ByteArrayOutputStream();\n        rewrittenStream.write(stream, 0, offset);\n        rewrittenStream.write(newUtf);\n        rewrittenStream.write(stream, offset + oldUtf.length, stream.length - offset - oldUtf.length);\n        return rewrittenStream.toByteArray();\n    }\n\n    private static byte[] serializedUtf(String value) throws IOException {\n        ByteArrayOutputStream byteStream = new ByteArrayOutputStream();\n        try (DataOutputStream dataStream = new DataOutputStream(byteStream)) {\n            dataStream.writeUTF(value);\n        }\n        return byteStream.toByteArray();\n    }\n\n    private static int firstIndexOf(byte[] bytes, byte[] pattern) {\n        for (int index = 0; index <= bytes.length - pattern.length; index++) {\n            if (startsWith(bytes, pattern, index)) {\n                return index;\n            }\n        }\n        return -1;\n    }\n\n    private static boolean startsWith(byte[] bytes, byte[] pattern, int offset) {\n        for (int index = 0; index < pattern.length; index++) {\n            if (bytes[offset + index] != pattern[index]) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    private static final class SerializedJCEElGamalPrivateKey implements Serializable {\n        private static final long serialVersionUID = 4819350091141529678L;\n\n        private final PKCS12BagAttributeCarrierImpl attrCarrier = new PKCS12BagAttributeCarrierImpl();\n        private final ElGamalParameterSpec elSpec;\n        private final BigInteger x;\n\n        private SerializedJCEElGamalPrivateKey(BigInteger x, BigInteger p, BigInteger g) {\n            this.x = x;\n            this.elSpec = new ElGamalParameterSpec(p, g);\n        }\n\n        private void writeObject(ObjectOutputStream out) throws IOException {\n            out.writeObject(x);\n            out.writeObject(elSpec.getP());\n            out.writeObject(elSpec.getG());\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1040, "output": 2903, "cacheRead": 37888, "cacheWrite": 0, "totalTokens": 41831, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779490820915, "responseId": "resp_0358030fd6ee26d7016a10e005933481919b7442c51fba55a5"}}
[tool-exec] start id=call_w2OSwRTHtDemIm4JvOiEwxy3|fc_0358030fd6ee26d7016a10e01fa1b88191883ea64067b3bf9e name=write args={"path": "tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/JCEElGamalPrivateKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.DataOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.math.BigInteger;\nimport java.nio.charset.StandardCharsets;\n\nimport org.bouncycastle.jce.provider.JCEElGamalPrivateKey;\nimport org.bouncycastle.jce.provider.PKCS12BagAttributeCarrierImpl;\nimport org.bouncycastle.jce.spec.ElGamalParameterSpec;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCEElGamalPrivateKeyTest {\n    private static final BigInteger P = BigInteger.valueOf(23L);\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger X = BigInteger.valueOf(6L);\n\n    @Test\n    void legacyJceElGamalPrivateKeySerializationRoundTripPreservesPrivateParameters() throws Exception {\n        JCEElGamalPrivateKey privateKey = deserializeLegacyPrivateKey();\n\n        byte[] serializedKey = serialize(privateKey);\n        JCEElGamalPrivateKey restoredKey = (JCEElGamalPrivateKey) deserialize(serializedKey);\n\n        assertThat(privateKey.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(privateKey.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(privateKey.getX()).isEqualTo(X);\n        assertThat(privateKey.getParameters().getP()).isEqualTo(P);\n        assertThat(privateKey.getParameters().getG()).isEqualTo(G);\n        assertThat(restoredKey.getX()).isEqualTo(X);\n        assertThat(restoredKey.getParameters().getP()).isEqualTo(P);\n        assertThat(restoredKey.getParameters().getG()).isEqualTo(G);\n        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());\n    }\n\n    private static JCEElGamalPrivateKey deserializeLegacyPrivateKey() throws Exception {\n        SerializedJCEElGamalPrivateKey proxy = new SerializedJCEElGamalPrivateKey(X, P, G);\n        byte[] proxyStream = serialize(proxy);\n        byte[] targetStream = replaceSerializedClassName(\n                proxyStream,\n                SerializedJCEElGamalPrivateKey.class.getName(),\n                JCEElGamalPrivateKey.class.getName());\n\n        return (JCEElGamalPrivateKey) deserialize(targetStream);\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream byteStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectStream = new ObjectOutputStream(byteStream)) {\n            objectStream.writeObject(value);\n        }\n        return byteStream.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedValue) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectStream = new ObjectInputStream(new ByteArrayInputStream(serializedValue))) {\n            return objectStream.readObject();\n        }\n    }\n\n    private static byte[] replaceSerializedClassName(byte[] stream, String oldName, String newName) throws IOException {\n        byte[] oldUtf = serializedUtf(oldName);\n        byte[] newUtf = serializedUtf(newName);\n\n        int offset = firstIndexOf(stream, oldUtf);\n        assertThat(offset).isGreaterThanOrEqualTo(0);\n\n        ByteArrayOutputStream rewrittenStream = new ByteArrayOutputStream();\n        rewrittenStream.write(stream, 0, offset);\n        rewrittenStream.write(newUtf);\n        rewrittenStream.write(stream, offset + oldUtf.length, stream.length - offset - oldUtf.length);\n        return rewrittenStream.toByteArray();\n    }\n\n    private static byte[] serializedUtf(String value) throws IOException {\n        ByteArrayOutputStream byteStream = new ByteArrayOutputStream();\n        try (DataOutputStream dataStream = new DataOutputStream(byteStream)) {\n            dataStream.writeUTF(value);\n        }\n        return byteStream.toByteArray();\n    }\n\n    private static int firstIndexOf(byte[] bytes, byte[] pattern) {\n        for (int index = 0; index <= bytes.length - pattern.length; index++) {\n            if (startsWith(bytes, pattern, index)) {\n                return index;\n            }\n        }\n        return -1;\n    }\n\n    private static boolean startsWith(byte[] bytes, byte[] pattern, int offset) {\n        for (int index = 0; index < pattern.length; index++) {\n            if (bytes[offset + index] != pattern[index]) {\n                return false;\n            }\n        }\n        return true;\n    }\n\n    private static final class SerializedJCEElGamalPrivateKey implements Serializable {\n        private static final long serialVersionUID = 4819350091141529678L;\n\n        private final PKCS12BagAttributeCarrierImpl attrCarrier = new PKCS12BagAttributeCarrierImpl();\n        private final ElGamalParameterSpec elSpec;\n        private final BigInteger x;\n\n        private SerializedJCEElGamalPrivateKey(BigInteger x, BigInteger p, BigInteger g) {\n            this.x = x;\n            this.elSpec = new ElGamalParameterSpec(p, g);\n        }\n\n        private void writeObject(ObjectOutputStream out) throws IOException {\n            out.writeObject(x);\n            out.writeObject(elSpec.getP());\n            out.writeObject(elSpec.getG());\n        }\n    }\n}\n"}
