assName(byte[] stream, String oldName, String newName) throws IOException {\n    73\t        byte[] oldUtf = serializedUtf(oldName);\n    74\t        byte[] newUtf = serializedUtf(newName);\n    75\t\n    76\t        int offset = firstIndexOf(stream, oldUtf);\n    77\t        assertThat(offset).isGreaterThanOrEqualTo(0);\n    78\t\n    79\t        ByteArrayOutputStream rewrittenStream = new ByteArrayOutputStream();\n    80\t        rewrittenStream.write(stream, 0, offset);\n    81\t        rewrittenStream.write(newUtf);\n    82\t        rewrittenStream.write(stream, offset + oldUtf.length, stream.length - offset - oldUtf.length);\n    83\t        return rewrittenStream.toByteArray();\n    84\t    }\n    85\t\n    86\t    private static byte[] serializedUtf(String value) throws IOException {\n    87\t        ByteArrayOutputStream byteStream = new ByteArrayOutputStream();\n    88\t        try (DataOutputStream dataStream = new DataOutputStream(byteStream)) {\n    89\t            dataStream.writeUTF(value);\n    90\t        }\n    91\t        return byteStream.toByteArray();\n    92\t    }\n    93\t\n    94\t    private static int firstIndexOf(byte[] bytes, byte[] pattern) {\n    95\t        for (int index = 0; index <= bytes.length - pattern.length; index++) {\n    96\t            if (startsWith(bytes, pattern, index)) {\n    97\t                return index;\n    98\t            }\n    99\t        }\n   100\t        return -1;\n   101\t    }\n   102\t\n   103\t    private static boolean startsWith(byte[] bytes, byte[] pattern, int offset) {\n   104\t        for (int index = 0; index < pattern.length; index++) {\n   105\t            if (bytes[offset + index] != pattern[index]) {\n   106\t                return false;\n   107\t            }\n   108\t        }\n   109\t        return true;\n   110\t    }\n   111\t\n   112\t    private static final class SerializedJCEElGamalPrivateKey implements Serializable {\n   113\t        private static final long serialVersionUID =