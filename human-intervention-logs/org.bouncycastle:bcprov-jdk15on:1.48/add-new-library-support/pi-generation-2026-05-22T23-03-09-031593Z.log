      22	import org.junit.jupiter.api.Test;
      23	
      24	import static org.assertj.core.api.Assertions.assertThat;
      25	
      26	public class JCEElGamalPrivateKeyTest {
      27	    private static final BigInteger P = BigInteger.valueOf(23L);
      28	    private static final BigInteger G = BigInteger.valueOf(5L);
      29	    private static final BigInteger X = BigInteger.valueOf(6L);
      30	
      31	    @Test
      32	    void jceElGamalPrivateKeySerializationRoundTripPreservesPrivateParameters() throws Exception {
      33	        JCEElGamalPrivateKey privateKey = deserializeJcePrivateKey();
      34	
      35	        byte[] serializedKey = serialize(privateKey);
      36	        JCEElGamalPrivateKey restoredKey = (JCEElGamalPrivateKey) deserialize(serializedKey);
      37	
      38	        assertThat(privateKey.getAlgorithm()).isEqualTo("ElGamal");
      39	        assertThat(privateKey.getFormat()).isEqualTo("PKCS#8");
      40	        assertThat(privateKey.getX()).isEqualTo(X);
      41	        assertThat(privateKey.getParameters().getP()).isEqualTo(P);
      42	        assertThat(privateKey.getParameters().getG()).isEqualTo(G);
      43	        assertThat(restoredKey.getX()).isEqualTo(X);
      44	        assertThat(restoredKey.getParameters().getP()).isEqualTo(P);
      45	        assertThat(restoredKey.getParameters().getG()).isEqualTo(G);
      46	        assertThat(restoredKey.getEncoded()).isEqualTo(privateKey.getEncoded());
      47	    }
      48	
      49	    private static JCEElGamalPrivateKey deserializeJcePrivateKey() throws Exception {
      50	        SerializedJCEElGamalPrivateKey proxy = new SerializedJCEElGamalPrivateKey(X, P, G);
      51	        byte[] proxyStream = serialize(proxy);
      52	        byte[] targetStream = replaceSerializedClassDescriptor(
      53	                proxyStream,
      54	                SerializedJCEElGamalPrivateKey.class.getName(),
      55	                JCEElGamalPrivateKey.class.getName(),
      56	                ObjectStreamClass.lookup(JCEElGamalPrivateKey.class).getSerialVersionUID());
      57	
      58	        return (JCEElGamalPrivateKey) deserialize(targetStream);
      59	    }
      60	
      61	    private static byte[] serialize(Object value) throws IOException {
      62	        ByteArrayOutputStream byteStream = new ByteArrayOutputStream();
      63	        try (ObjectOutputStream objectStream = new ObjectOutputStream(byteStream)) {
      64	            objectStream.writeObject(value);
      65	        }
      66	        return byteStream.toByteArray();
      67	    }
      68	
      69	    private static Object deserialize(byte[] serializedValue) throws IOException, ClassNotFoundException {
      70	        try (ObjectInputStream objectStream = new ObjectInputStream(new ByteArrayInputStream(serializedValue))) {
      71	            return objectStream.readObject();
      72	        }
      73	    }
      74	
      75	    private static byte[] replaceSerializedClassDescriptor(
      76	            byte[] stream,
      77	            String oldName,
      78	            String newName,
      79	            long serialVersionUid) throws IOException {
      80	        byte[] oldUtf = serializedUtf(oldName);
      81	        byte[] newUtf = serializedUtf(newName);
      82	
      83	        int offset = firstIndexOf(stream, oldUtf);
      84	        assertThat(offset).isGreaterThanOrEqualTo(0);
      85	
      86	        ByteArrayOutputStream rewrittenStream = new ByteArrayOutputStream();
      87	        rewrittenStream.write(stream, 0, offset);
      88	        rewrittenStream.write(newUtf);
      89	        try (DataOutputStream dataStream = new DataOutputStream(rewrittenStream)) {
      90	            dataStream.writeLong(serialVersionUid);
      91	        }
      92	        int remainingOffset = offset + oldUtf.length + Long.BYTES;
      93	        rewrittenStream.write(stream, remainingOffset, stream.length - remainingOffset);
      94	        return rewrittenStream.toByteArray();
      95	    }
      96	
      97	    private static byte[] serializedUtf(String value) throws IOException {
      98	        ByteArrayOutputStream byteStream = new ByteArrayOutputStream();
      99	        try (DataOutputStream dataStream = new DataOutputStream(byteStream)) {
     100	            dataStream.writeUTF(value);
     101	        }
     102	        return byteStream.toByteArray();
     103	    }
     104	
     105	    private static int firstIndexOf(byte[] bytes, byte[] pattern) {
     106	        for (int index = 0; index <= bytes.length - pattern.length; index++) {
     107	            if (startsWith(bytes, pattern, index)) {
     108	                return index;
     109	            }
     110	        }
     111	        return -1;
     112	    }
     113	
     114	    private static boolean startsWith(byte[] bytes, byte[] pattern, int offset) {
     115	        for (int index = 0; index < pattern.length; index++) {
     116	            if (bytes[offset + index] != pattern[index]) {
     117	                return false;
     118	            }
     119	        }
     120	        return true;
     121	    }
