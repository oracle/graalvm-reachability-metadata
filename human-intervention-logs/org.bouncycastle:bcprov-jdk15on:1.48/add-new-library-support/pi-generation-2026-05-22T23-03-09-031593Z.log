     135	        private void writeObject(ObjectOutputStream out) throws IOException {
     136	            out.writeObject(x);
     137	            out.writeObject(elSpec.getP());
     138	            out.writeObject(elSpec.getG());
     139	        }
     140	    }
     141	}
