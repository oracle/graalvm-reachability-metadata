ough it doesnŌĆÖt use this.getClass().getClassLoader. Subclassing might work, but then getClass() would refer to a test class loader that's not null. ItŌĆÖs a tricky situation!\"}]}"}, {"type": "toolCall", "id": "call_pWObCiedIhQI5h1UqGyu0y2V|fc_0bea203ae0cb8afa016a25a17d3ca0819489b506593d4e75bf", "name": "write", "arguments": {"path": "tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BouncyCastlePQCProviderTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BouncyCastlePQCProviderTest {\n    @Test\n    public void loadsPostQuantumAlgorithmMappings() {\n        BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();\n\n        assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);\n        assertThat(provider.hasAlgorithm(\"KeyFactory\", \"Rainbow\")).isTrue();\n        assertThat(provider.hasAlgorithm(\"KeyPairGenerator\", \"Rainbow\")).isTrue();\n        assertThat(provider.hasAlgorithm(\"KeyPairGenerator\", \"McEliecePKCS\")).isTrue();\n        assertThat(provider.hasAlgorithm(\"Cipher\", \"McEliecePKCS\")).isTrue();\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BouncyCastlePQCProviderTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcprov_jdk15on;\\n\\nimport org.bouncycastle.pqc.jca