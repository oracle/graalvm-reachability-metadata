ider.hasAlgorithm(\"KeyPairGenerator\", \"Rainbow\")).isTrue();\n            assertThat(provider.hasAlgorithm(\"KeyPairGenerator\", \"McEliecePKCS\")).isTrue();\n            assertThat(provider.hasAlgorithm(\"Cipher\", \"McEliecePKCS\")).isTrue();\n\n            assertThat(KeyPairGenerator.getInstance(\"Rainbow\", provider).getAlgorithm()).isEqualTo(\"Rainbow\");\n            assertThat(KeyPairGenerator.getInstance(\"McEliecePKCS\", provider).getAlgorithm()).isEqualTo(\"McEliecePKCS\");\n            assertThat(Cipher.getInstance(\"McEliecePKCS\", provider).getAlgorithm()).isEqualTo(\"McEliecePKCS\");\n        } finally {\n            Security.removeProvider(BouncyCastlePQCProvider.PROVIDER_NAME);\n            if (previousProvider != null) {\n                Security.addProvider(previousProvider);\n            }\n        }\n    }\n}\n"}]}
