  package org_bouncycastle.bcprov_jdk15on;
  
  import org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BouncyCastlePQCProviderTest {
      @Test
      public void loadsPostQuantumAlgorithmMappings() {
          BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();
  
          assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);
          assertThat(provider.hasAlgorithm("KeyFactory", "Rainbow")).isTrue();
          assertThat(provider.hasAlgorithm("KeyPairGenerator", "Rainbow")).isTrue();
          assertThat(provider.hasAlgorithm("KeyPairGenerator", "McEliecePKCS")).isTrue();
          assertThat(provider.hasAlgorithm("Cipher", "McEliecePKCS")).isTrue();
      }
  }
