5to18/) |\n./COVERAGE.md:847:| `org.bouncycastle:bcpkix-jdk18on` | [1.77<br>- 1.84](metadata/org.bouncycastle/bcpkix-jdk18on/index.json) | <details><summary>Show</summary> Bouncy Castle PKIX provides Java APIs for CMS, PKCS, EAC, TSP, CMP, CRMF, OCSP, and X.509 certificate generation on JDK 1.8 and later. It is typically used with a JCE/JCA provider such as Bouncy Castle to build and process public-key infrastructure and related cryptographic message formats.</details> | [0.0% (0/8 calls)](stats/org.bouncycastle/bcpkix-jdk18on/) |\n./metadata/org.apache.activemq/activemq-broker/6.0.0/reachability-metadata.json:245:      \"type\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15to18/index.json:9:    \"description\" : \"Provides Bouncy Castle Java APIs for PKIX, CMS, PKCS, EAC, TSP, CMP, CRMF, OCSP, and certificate generation. It targets JDK 1.5 through JDK 1.8 and is typically used alongside a JCE/JCA provider such as Bouncy Castle's cryptography provider.\",\n./metadata/org.bouncycastle/bcprov-jdk15on/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/bouncycastle/bcprov-jdk15on/$version$/bcprov-jdk15on-$version$-sources.jar\",\n./metadata/org.bouncycastle/bcprov-jdk15on/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/bouncycastle/bcprov-jdk15on/$version$/bcprov-jdk15on-$version$-javadoc.jar\",\n./metadata/org.bouncycastle/bcprov-jdk15on/index.json:9:    \"description\" : \"Bouncy Castle Provider is a Java cryptography provider and lightweight API implementation for the Bouncy Castle Crypto APIs. The 1.48 bcprov-jdk15on artifact targets JDK 1.5 through JDK 1.7 and supplies cryptographic algorithms for JCA/JCE-based applications.\",\n./metadata/org.bouncycastle/bcpkix-jdk15to18/1.77/reachability-metadata.json:5:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\n./metadata/org.bouncycastle/bcpkix-jdk15to18/1.77/reachability-metadata.json