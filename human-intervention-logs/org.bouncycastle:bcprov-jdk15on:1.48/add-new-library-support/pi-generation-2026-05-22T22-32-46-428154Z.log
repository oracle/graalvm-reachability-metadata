pi": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1653, "output": 896, "cacheRead": 95744, "cacheWrite": 0, "totalTokens": 98293, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "stop", "timestamp": 1779489579373, "responseId": "resp_0f7747aecb615386016a10db2c93508192b6fcc51c4242d274"}}
