\n            assertThat(store.getMatches(null)).isEmpty();\n        } finally {\n            if (previousValue == null) {\n                bootstrapProvider.remove(propertyName);\n            } else {\n                bootstrapProvider.put(propertyName, previousValue);\n            }\n        }\n    }\n\n    private static Provider findBootstrapProvider() {\n        for (Provider provider : Security.getProviders()) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n\n        throw new IllegalStateException(\"No bootstrap-loaded security provider is available\");\n    }\n\n    public static class RecordingStoreSpi extends X509StoreSpi {\n        private boolean initialized;\n\n        @Override\n        public void engineInit(X509StoreParameters parameters) {\n            assertThat(parameters).isNull();\n            initialized = true;\n        }\n\n        @Override\n        public Collection engineGetMatches(Selector selector) {\n            assertThat(initialized).isTrue();\n            return Collections.emptyList();\n        }\n    }\n\n    private static final class TestProvider extends Provider {\n        private static final long serialVersionUID = 1L;\n\n        @SuppressWarnings(\"deprecation\")\n        private TestProvider() {\n            super(\"X509UtilTestProvider\", 1.0, \"Provider for X509Util dynamic access tests\");\n            put(\"Alg.Alias.X509Store.\" + STORE_ALIAS, STORE_ALGORITHM);\n            put(\"X509Store.\" + STORE_ALGORITHM, STORE_SPI_CLASS_NAME);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778106778660}}
