     }\n\n        @Override\n        public Collection engineGetMatches(Selector selector) {\n            assertThat(initialized).isTrue();\n            return Collections.emptyList();\n        }\n    }\n\n    private static final class TestProvider extends Provider {\n        private static final long serialVersionUID = 1L;\n\n        @SuppressWarnings(\"deprecation\")\n        private TestProvider() {\n            super(\"X509UtilTestProvider\", 1.0, \"Provider for X509Util dynamic access tests\");\n            put(\"Alg.Alias.X509Store.\" + STORE_ALIAS, STORE_ALGORITHM);\n            put(\"X509Store.\" + STORE_ALGORITHM, STORE_SPI_CLASS_NAME);\n        }\n    }\n", "newText": "\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 590, "output": 1317, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 24947, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778106964933, "responseId": "resp_062527c6e96fb00e0169fbc2559a7c81a2ba89bcc43f96589f"}}
