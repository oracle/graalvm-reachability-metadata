[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/X509UtilTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.security.Provider;\nimport java.security.Security;\nimport java.util.Collection;\nimport java.util.Collections;\n\nimport org.bouncycastle.util.Selector;\nimport org.bouncycastle.x509.X509Store;\nimport org.bouncycastle.x509.X509StoreParameters;\nimport org.bouncycastle.x509.X509StoreSpi;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class X509UtilTest {\n    private static final String STORE_ALGORITHM = \"CUSTOM\";\n    private static final String STORE_ALIAS = \"CUSTOMALIAS\";\n    private static final String STORE_SPI_CLASS_NAME = RecordingStoreSpi.class.getName();\n\n    @Test\n    void x509StoreLoadsImplementationThroughProviderClassLoader() throws Exception {\n        Provider provider = new TestProvider();\n\n        X509Store store = X509Store.getInstance(STORE_ALIAS, null, provider);\n\n        assertThat(store.getProvider()).isSameAs(provider);\n        assertThat(store.getMatches(null)).isEmpty();\n    }\n\n    @Test\n    void x509StoreLoadsImplementationThroughClassForNameForBootstrapProvider() throws Exception {\n        Provider bootstrapProvider = findBootstrapProvider();\n        String propertyName = \"X509Store.\" + STORE_ALGORITHM;\n        Object previousValue = bootstrapProvider.put(propertyName, STORE_SPI_CLASS_NAME);\n\n        try {\n            X509Store store = X509Store.getInstance(STORE_ALGORITHM, null, bootstrapProvider);\n\n            assertThat(store.getProvider()).isSameAs(bootstrapProvider);\n            assertThat(store.getMatches(null)).isEmpty();\n        } finally {\n            if (previousValue == null) {\n                bootstrapProvider.remove(propertyName);\n            } else {\n                bootstrapProvider.put(propertyName, previousValue);\n            }\n        }\n    }\n\n    private static Provider findBootstrapProvider() {\n        for (Provider provider : Security.getProviders()) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n\n        throw new IllegalStateException(\"No bootstrap-loaded security provider is available\");\n    }\n\n    public static class RecordingStoreSpi extends X509StoreSpi {\n        @Override\n        public void engineInit(X509StoreParameters parameters) {\n        }\n\n        @Override\n        public Collection engineGetMatches(Selector selector) {\n            return Collections.emptyList();\n        }\n    }\n\n    private static final class TestProvider extends Provider {\n        private TestProvider() {\n            super(\"X509UtilTestProvider\", \"1.0\", \"Provider for X509Util dynamic access tests\");\n            put(\"Alg.Alias.X509Store.\" + STORE_ALIAS, STORE_ALGORITHM);\n            put(\"X509Store.\" + STORE_ALGORITHM, STORE_SPI_CLASS_NAME);\n        }\n    }\n}\n"}
