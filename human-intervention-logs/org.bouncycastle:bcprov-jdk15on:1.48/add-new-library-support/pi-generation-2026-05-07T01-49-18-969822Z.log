  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.Serializable;
  import java.math.BigInteger;
  import java.nio.charset.StandardCharsets;
  import java.util.Arrays;
  
  import javax.crypto.interfaces.DHPrivateKey;
  
  import org.bouncycastle.jce.provider.JCEDHPrivateKey;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JCEDHPrivateKeyTest {
      private static final long JCE_DH_PRIVATE_KEY_SERIAL_VERSION_UID = 311058815616901812L;
  
      @Test
      void serializesAndDeserializesLegacyDhPrivateKeyParameters() throws Exception {
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger g = BigInteger.valueOf(5L);
          BigInteger x = BigInteger.valueOf(6L);
          int privateValueLength = 7;
  
          DHPrivateKey original = deserializeLegacyPrivateKey(x, p, g, privateValueLength);
  
          assertThat(original).isInstanceOf(JCEDHPrivateKey.class);
