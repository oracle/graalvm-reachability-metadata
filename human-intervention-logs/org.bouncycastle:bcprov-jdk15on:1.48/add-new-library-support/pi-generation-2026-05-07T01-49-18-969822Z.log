      protected JCEDHPrivateKey()
      {
      }
  
      JCEDHPrivateKey(
          DHPrivateKey    key)
      {
          this.x = key.getX();
          this.dhSpec = key.getParams();
      }
  
      JCEDHPrivateKey(
          DHPrivateKeySpec    spec)
      {
          this.x = spec.getX();
          this.dhSpec = new DHParameterSpec(spec.getP(), spec.getG());
      }
  
      JCEDHPrivateKey(
