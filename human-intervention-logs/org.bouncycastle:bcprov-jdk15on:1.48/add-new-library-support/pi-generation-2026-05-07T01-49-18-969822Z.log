  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.io.Serializable;
  import java.math.BigInteger;
  import java.nio.charset.StandardCharsets;
  import java.util.Arrays;
  
  import javax.crypto.interfaces.DHPublicKey;
  
  import org.bouncycastle.jce.provider.JCEDHPublicKey;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JCEDHPublicKeyTest {
      private static final long JCE_DH_PUBLIC_KEY_SERIAL_VERSION_UID = -216691575254424324L;
  
      @Test
      void serializesAndDeserializesLegacyDhPublicKeyParameters() throws Exception {
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger g = BigInteger.valueOf(5L);
          BigInteger y = BigInteger.valueOf(8L);
          int privateValueLength = 7;
  
          DHPublicKey original = deserializeLegacyPublicKey(y, p, g, privateValueLength);
  
          assertThat(original).isInstanceOf(JCEDHPublicKey.class);
          assertThat(original.getAlgorithm()).isEqualTo("DH");
          assertThat(original.getFormat()).isEqualTo("X.509");
          assertThat(original.getY()).isEqualTo(y);
          assertThat(original.getParams().getP()).isEqualTo(p);
          assertThat(original.getParams().getG()).isEqualTo(g);
          assertThat(original.getParams().getL()).isEqualTo(privateValueLength);
          assertThat(original.getEncoded()).isNotEmpty();
  
          byte[] serializedKey = serialize(original);
          DHPublicKey deserialized = (DHPublicKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(JCEDHPublicKey.class);
          assertThat(deserialized.getAlgorithm()).isEqualTo("DH");
          assertThat(deserialized.getFormat()).isEqualTo("X.509");
          assertThat(deserialized.getY()).isEqualTo(y);
          assertThat(deserialized.getParams().getP()).isEqualTo(p);
          assertThat(deserialized.getParams().getG()).isEqualTo(g);
          assertThat(deserialized.getParams().getL()).isEqualTo(privateValueLength);
          assertThat(deserialized.getEncoded()).isNotEmpty();
      }
  
      private static DHPublicKey deserializeLegacyPublicKey(BigInteger y, BigInteger p, BigInteger g, int l)
          throws Exception {
          assertThat(ObjectStreamClass.lookup(JCEDHPublicKey.class).getSerialVersionUID())
              .isEqualTo(JCE_DH_PUBLIC_KEY_SERIAL_VERSION_UID);
  
          SerializedForm serializedForm = new SerializedForm(y, p, g, l);
          byte[] serializedKey = serialize(serializedForm);
          byte[] legacySerializedKey = replaceSerializedClassName(
              serializedKey,
              SerializedForm.class.getName(),
              JCEDHPublicKey.class.getName());
  
          return (DHPublicKey) deserialize(legacySerializedKey);
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
      }
  
      private static byte[] replaceSerializedClassName(byte[] serializedValue, String oldName, String newName) {
          byte[] oldNameBytes = oldName.getBytes(StandardCharsets.UTF_8);
          byte[] newNameBytes = newName.getBytes(StandardCharsets.UTF_8);
          int oldNameIndex = indexOf(serializedValue, oldNameBytes);
  
          assertThat(oldNameIndex).isGreaterThan(1);
          assertThat(serializedValue[oldNameIndex - 2] & 0xff).isEqualTo(oldNameBytes.length >>> 8);
          assertThat(serializedValue[oldNameIndex - 1] & 0xff).isEqualTo(oldNameBytes.length & 0xff);
  
          ByteArrayOutputStream rewritten = new ByteArrayOutputStream(
              serializedValue.length - oldNameBytes.length + newNameBytes.length);
          rewritten.write(serializedValue, 0, oldNameIndex - 2);
          rewritten.write((newNameBytes.length >>> 8) & 0xff);
          rewritten.write(newNameBytes.length & 0xff);
          rewritten.write(newNameBytes, 0, newNameBytes.length);
          rewritten.write(
              serializedValue,
              oldNameIndex + oldNameBytes.length,
              serializedValue.length - oldNameIndex - oldNameBytes.length);
          return rewritten.toByteArray();
      }
  
      private static int indexOf(byte[] value, byte[] pattern) {
          for (int i = 0; i <= value.length - pattern.length; i++) {
              if (Arrays.equals(Arrays.copyOfRange(value, i, i + pattern.length), pattern)) {
                  return i;
              }
          }
          return -1;
      }
  
      private static final class SerializedForm implements Serializable {
          private static final long serialVersionUID = JCE_DH_PUBLIC_KEY_SERIAL_VERSION_UID;
  
          private final transient BigInteger y;
          private final transient BigInteger p;
          private final transient BigInteger g;
          private final transient int l;
  
          private SerializedForm(BigInteger y, BigInteger p, BigInteger g, int l) {
              this.y = y;
              this.p = p;
              this.g = g;
              this.l = l;
          }
  
          private void writeObject(ObjectOutputStream out) throws IOException {
              out.writeObject(y);
              out.writeObject(p);
              out.writeObject(g);
              out.writeInt(l);
          }
