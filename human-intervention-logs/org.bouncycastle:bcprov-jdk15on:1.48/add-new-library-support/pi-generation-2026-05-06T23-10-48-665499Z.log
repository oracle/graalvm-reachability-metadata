[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCDHPublicKeyTest.java","edits":[{"oldText":"import java.math.BigInteger;\n\nimport javax.crypto.interfaces.DHPublicKey;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.DHParameter;\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;\n","newText":"import java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.Provider;\n\nimport javax.crypto.interfaces.DHPublicKey;\nimport javax.crypto.spec.DHPublicKeySpec;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\n"},{"oldText":"        int keyLength = 7;\n        DHPublicKey original = createPublicKey(y, p, g, keyLength);\n","newText":"        DHPublicKey original = createPublicKey(y, p, g);\n"},{"oldText":"        assertThat(deserialized.getParams().getL()).isEqualTo(keyLength);\n","newText":"        assertThat(deserialized.getParams().getL()).isZero();\n"},{"oldText":"    private static DHPublicKey createPublicKey(\n        BigInteger y,\n        BigInteger p,\n        BigInteger g,\n        int keyLength) throws Exception {\n        DHParameter dhParameter = new DHParameter(p, g, keyLength);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n            PKCSObjectIdentifiers.dhKeyAgreement,\n            dhParameter.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(y));\n        return new BCDHPublicKey(publicKeyInfo);\n    }\n","newText":"    private static DHPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger g) throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DH\", provider);\n        return (DHPublicKey) keyFactory.generatePublic(new DHPublicKeySpec(y, p, g));\n    }\n"}]}
