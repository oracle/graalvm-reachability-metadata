  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.math.BigInteger;
  import java.security.KeyFactory;
  import java.security.Provider;
  
  import javax.crypto.interfaces.DHPublicKey;
  import javax.crypto.spec.DHPublicKeySpec;
  
  import org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;
  import org.bouncycastle.jce.provider.BouncyCastleProvider;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDHPublicKeyTest {
      @Test
      void serializesAndDeserializesDhPublicKeyParameters() throws Exception {
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger g = BigInteger.valueOf(5L);
          BigInteger y = BigInteger.valueOf(8L);
          DHPublicKey original = createPublicKey(y, p, g);
  
          assertThat(original).isInstanceOf(BCDHPublicKey.class);
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          DHPublicKey deserialized = (DHPublicKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCDHPublicKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("DH");
          assertThat(deserialized.getFormat()).isEqualTo("X.509");
          assertThat(deserialized.getY()).isEqualTo(y);
          assertThat(deserialized.getParams().getP()).isEqualTo(p);
          assertThat(deserialized.getParams().getG()).isEqualTo(g);
          assertThat(deserialized.getParams().getL()).isZero();
          assertThat(deserialized.getEncoded()).isNotEmpty();
      }
  
      private static DHPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger g) throws Exception {
          Provider provider = new BouncyCastleProvider();
          KeyFactory keyFactory = KeyFactory.getInstance("DH", provider);
          return (DHPublicKey) keyFactory.generatePublic(new DHPublicKeySpec(y, p, g));
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static void ensureSerializationBaseConstructorIsReachable() throws Exception {
          assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new BouncyCastleObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
      }
  
      private static final class BouncyCastleObjectInputStream extends ObjectInputStream {
          private BouncyCastleObjectInputStream(ByteArrayInputStream input) throws Exception {
              super(input);
          }
  
          @Override
          protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {
              if (BCDHPublicKey.class.getName().equals(description.getName())) {
                  return BCDHPublicKey.class;
              }
              return super.resolveClass(description);
          }
      }
  }
