  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  
  import javax.crypto.interfaces.DHPublicKey;
  
  import org.bouncycastle.asn1.DERInteger;
  import org.bouncycastle.asn1.oiw.ElGamalParameter;
  import org.bouncycastle.asn1.oiw.OIWObjectIdentifiers;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPublicKey;
  import org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;
  import org.bouncycastle.jce.interfaces.ElGamalPublicKey;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCElGamalPublicKeyTest {
      @Test
      void serializesAndDeserializesElGamalPublicKeyParameters() throws Exception {
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger g = BigInteger.valueOf(5L);
          BigInteger y = BigInteger.valueOf(8L);
          ElGamalPublicKey original = createPublicKey(y, p, g);
  
          assertThat(original).isInstanceOf(BCElGamalPublicKey.class);
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          ElGamalPublicKey deserialized = (ElGamalPublicKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCElGamalPublicKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(deserialized.getFormat()).isEqualTo("X.509");
          assertThat(deserialized.getY()).isEqualTo(y);
