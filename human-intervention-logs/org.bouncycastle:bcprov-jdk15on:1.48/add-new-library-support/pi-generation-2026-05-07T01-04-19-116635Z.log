    }\n\n        @Override\n        protected Object replaceObject(Object object) throws IOException {\n            if (p.equals(object) || g.equals(object)) {\n                parameterObjectCount++;\n            }\n            return super.replaceObject(object);\n        }\n\n        private int getParameterObjectCount() {\n            return parameterObjectCount;\n        }\n    }\n\n    private static final class CountingObjectInputStream extends BouncyCastleObjectInputStream {\n        private final BigInteger p;\n        private final BigInteger g;\n        private int parameterObjectCount;\n\n        private CountingObjectInputStream(ByteArrayInputStream input, BigInteger p, BigInteger g) throws Exception {\n            super(input);\n            this.p = p;\n            this.g = g;\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) throws IOException {\n            if (p.equals(object) || g.equals(object)) {\n                parameterObjectCount++;\n            }\n            return super.resolveObject(object);\n        }\n\n        private int getParameterObjectCount() {\n            return parameterObjectCount;\n        }\n    }\n\n    private static class BouncyCastleObjectInputStream extends ObjectInputStream {\n        private BouncyCastleObjectInputStream(ByteArrayInputStream input) throws Exception {\n            super(input);\n        }\n\n        @Override\n        protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {\n            if (BCElGamalPublicKey.class.getName().equals(description.getName())) {\n                return BCElGamalPublicKey.class;\n            }\n            return super.resolveClass(description);\n        }\n    }","newText":"    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output =