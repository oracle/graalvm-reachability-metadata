[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCElGamalPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.math.BigInteger;\n\nimport javax.crypto.interfaces.DHPublicKey;\n\nimport org.bouncycastle.asn1.DERInteger;\nimport org.bouncycastle.asn1.oiw.ElGamalParameter;\nimport org.bouncycastle.asn1.oiw.OIWObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPublicKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;\nimport org.bouncycastle.jce.interfaces.ElGamalPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCElGamalPublicKeyTest {\n    @Test\n    void serializesAndDeserializesElGamalPublicKeyParameters() throws Exception {\n        BigInteger p = BigInteger.valueOf(23L);\n        BigInteger g = BigInteger.valueOf(5L);\n        BigInteger y = BigInteger.valueOf(8L);\n        ElGamalPublicKey original = createPublicKey(y, p, g);\n\n        assertThat(original).isInstanceOf(BCElGamalPublicKey.class);\n\n        byte[] serializedKey = serialize(original, p, g);\n        ElGamalPublicKey deserialized = (ElGamalPublicKey) deserialize(serializedKey, p, g);\n\n        assertThat(deserialized).isInstanceOf(BCElGamalPublicKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"X.509\");\n        assertThat(deserialized.getY()).isEqualTo(y);\n        assertThat(deserialized.getParameters().getP()).isEqualTo(p);\n        assertThat(deserialized.getParameters().getG()).isEqualTo(g);\n        assertThat(deserialized.getEncoded()).isNotEmpty();\n\n        DHPublicKey dhPublicKey = (DHPublicKey) deserialized;\n        assertThat(dhPublicKey.getParams().getP()).isEqualTo(p);\n        assertThat(dhPublicKey.getParams().getG()).isEqualTo(g);\n        assertThat(dhPublicKey.getParams().getL()).isZero();\n    }\n\n    private static ElGamalPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger g) throws Exception {\n        ElGamalParameter elGamalParameter = new ElGamalParameter(p, g);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n            OIWObjectIdentifiers.elGamalAlgorithm,\n            elGamalParameter.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new DERInteger(y));\n        return (ElGamalPublicKey) new KeyFactorySpi().generatePublic(publicKeyInfo);\n    }\n\n    private static byte[] serialize(Object value, BigInteger p, BigInteger g) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (CountingObjectOutputStream output = new CountingObjectOutputStream(bytes, p, g)) {\n            output.writeObject(value);\n            assertThat(output.getParameterObjectCount()).isEqualTo(2);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] value, BigInteger p, BigInteger g) throws Exception {\n        try (CountingObjectInputStream input = new CountingObjectInputStream(new ByteArrayInputStream(value), p, g)) {\n            Object deserialized = input.readObject();\n            assertThat(input.getParameterObjectCount()).isEqualTo(2);\n            return deserialized;\n        }\n    }\n\n    private static final class CountingObjectOutputStream extends ObjectOutputStream {\n        private final BigInteger p;\n        private final BigInteger g;\n        private int parameterObjectCount;\n\n        private CountingObjectOutputStream(ByteArrayOutputStream output, BigInteger p, BigInteger g) throws Exception {\n            super(output);\n            this.p = p;\n            this.g = g;\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object object) throws IOException {\n            if (p.equals(object) || g.equals(object)) {\n                parameterObjectCount++;\n            }\n            return super.replaceObject(object);\n        }\n\n        private int getParameterObjectCount() {\n            return parameterObjectCount;\n        }\n    }\n\n    private static final class CountingObjectInputStream extends BouncyCastleObjectInputStream {\n        private final BigInteger p;\n        private final BigInteger g;\n        private int parameterObjectCount;\n\n        private CountingObjectInputStream(ByteArrayInputStream input, BigInteger p, BigInteger g) throws Exception {\n            super(input);\n            this.p = p;\n            this.g = g;\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object object) throws IOException {\n            if (p.equals(object) || g.equals(object)) {\n                parameterObjectCount++;\n            }\n            return super.resolveObject(object);\n        }\n\n        private int getParameterObjectCount() {\n            return parameterObjectCount;\n        }\n    }\n\n    private static class BouncyCastleObjectInputStream extends ObjectInputStream {\n        private BouncyCastleObjectInputStream(ByteArrayInputStream input) throws Exception {\n            super(input);\n        }\n\n        @Override\n        protected Class<?> r