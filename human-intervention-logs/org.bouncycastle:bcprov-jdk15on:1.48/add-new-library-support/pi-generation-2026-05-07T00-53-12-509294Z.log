  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.math.BigInteger;
  
  import javax.crypto.interfaces.DHPrivateKey;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.oiw.ElGamalParameter;
  import org.bouncycastle.asn1.oiw.OIWObjectIdentifiers;
  import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPrivateKey;
  import org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;
  import org.bouncycastle.jce.interfaces.ElGamalPrivateKey;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCElGamalPrivateKeyTest {
      @Test
      void serializesAndDeserializesElGamalPrivateKeyParameters() throws Exception {
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger g = BigInteger.valueOf(5L);
          BigInteger x = BigInteger.valueOf(6L);
          ElGamalPrivateKey original = createPrivateKey(x, p, g);
  
          assertThat(original).isInstanceOf(BCElGamalPrivateKey.class);
  
          byte[] serializedKey = serialize(original, p, g);
          ElGamalPrivateKey deserialized = (ElGamalPrivateKey) deserialize(serializedKey, p, g);
  
          assertThat(deserialized).isInstanceOf(BCElGamalPrivateKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("ElGamal");
          assertThat(deserialized.getFormat()).isEqualTo("PKCS#8");
          assertThat(deserialized.getX()).isEqualTo(x);
          assertThat(deserialized.getParameters().getP()).isEqualTo(p);
          assertThat(deserialized.getParameters().getG()).isEqualTo(g);
          assertThat(deserialized.getEncoded()).isNotEmpty();
  
          DHPrivateKey dhPrivateKey = (DHPrivateKey) deserialized;
          assertThat(dhPrivateKey.getParams().getP()).isEqualTo(p);
          assertThat(dhPrivateKey.getParams().getG()).isEqualTo(g);
          assertThat(dhPrivateKey.getParams().getL()).isZero();
      }
  
      private static ElGamalPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger g) throws Exception {
          ElGamalParameter elGamalParameter = new ElGamalParameter(p, g);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
              OIWObjectIdentifiers.elGamalAlgorithm,
              elGamalParameter.toASN1Primitive());
          PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(x));
          return (ElGamalPrivateKey) new KeyFactorySpi().generatePrivate(privateKeyInfo);
      }
  
      private static byte[] serialize(Object value, BigInteger p, BigInteger g) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (CountingObjectOutputStream output = new CountingObjectOutputStream(bytes, p, g)) {
              output.writeObject(value);
              assertThat(output.getParameterObjectCount()).isEqualTo(2);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserialize(byte[] value, BigInteger p, BigInteger g) throws Exception {
          try (CountingObjectInputStream input = new CountingObjectInputStream(new ByteArrayInputStream(value), p, g)) {
              Object deserialized = input.readObject();
              assertThat(input.getParameterObjectCount()).isEqualTo(2);
              return deserialized;
          }
      }
  
      private static final class CountingObjectOutputStream extends ObjectOutputStream {
          private final BigInteger p;
          private final BigInteger g;
          private int parameterObjectCount;
  
          private CountingObjectOutputStream(ByteArrayOutputStream output, BigInteger p, BigInteger g) throws Exception {
              super(output);
              this.p = p;
              this.g = g;
              enableReplaceObject(true);
          }
  
          @Override
          protected Object replaceObject(Object object) throws IOException {
              if (p.equals(object) || g.equals(object)) {
                  parameterObjectCount++;
              }
              return super.replaceObject(object);
          }
  
          private int getParameterObjectCount() {
              return parameterObjectCount;
          }
      }
  
      private static final class CountingObjectInputStream extends BouncyCastleObjectInputStream {
          private final BigInteger p;
          private final BigInteger g;
          private int parameterObjectCount;
  
          private CountingObjectInputStream(ByteArrayInputStream input, BigInteger p, BigInteger g) throws Exception {
              super(input);
              this.p = p;
              this.g = g;
              enableResolveObject(true);
          }
  
          @Override
          protected Object resolveObject(Object object) throws IOException {
              if (p.equals(object) || g.equals(object)) {
                  parameterObjectCount++;
              }
              return super.resolveObject(object);
          }
  
          private int getParameterObjectCount() {
              return parameterObjectCount;
          }
      }
  
      private static class BouncyCastleObjectInputStream extends ObjectInputStream {
          private BouncyCastleObjectInputStream(ByteArrayInputStream input) throws Exception {
              super(input);
          }
  
          @Override
          protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {
              if (BCElGamalPrivateKey.class.getName().equals(description.getName())) {
                  return BCElGamalPrivateKey.class;
              }
              return super.resolveClass(description);
          }
      }
