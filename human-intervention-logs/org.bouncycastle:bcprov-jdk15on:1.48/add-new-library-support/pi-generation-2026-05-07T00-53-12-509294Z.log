org.bouncycastle.jce.interfaces.ElGamalPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.ElGamalParameterSpec;\nimport org.bouncycastle.jce.spec.ElGamalPrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCElGamalPrivateKeyTest {\n    @Test\n    void serializesAndDeserializesElGamalPrivateKeyParameters() throws Exception {\n        BigInteger p = BigInteger.valueOf(23L);\n        BigInteger g = BigInteger.valueOf(5L);\n        BigInteger x = BigInteger.valueOf(6L);\n        ElGamalPrivateKey original = createPrivateKey(x, p, g);\n\n        assertThat(original).isInstanceOf(BCElGamalPrivateKey.class);\n\n        byte[] serializedKey = serialize(original);\n        ElGamalPrivateKey deserialized = (ElGamalPrivateKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(BCElGamalPrivateKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"ElGamal\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(deserialized.getX()).isEqualTo(x);\n        assertThat(deserialized.getParameters().getP()).isEqualTo(p);\n        assertThat(deserialized.getParameters().getG()).isEqualTo(g);\n        assertThat(deserialized.getEncoded()).isNotEmpty();\n\n        DHPrivateKey dhPrivateKey = (DHPrivateKey) deserialized;\n        assertThat(dhPrivateKey.getParams().getP()).isEqualTo(p);\n        assertThat(dhPrivateKey.getParams().getG()).isEqualTo(g);\n        assertThat(dhPrivateKey.getParams().getL()).isZero();\n    }\n\n    private static ElGamalPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger g) throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"ElGamal\", provider);\n        ElGamalParameterSpec parameterSpec = new ElGamalParameterSpec(p, g);\n        return (ElGamalPrivateKey) keyFactory.generatePrivate(new ElGamalPrivateKeySpec(x, parameterSpec));\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] value) throws Exception {\n        try (ObjectInputStream input = new BouncyCastleObjectInputStream(new ByteArrayInputStream(value))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class BouncyCastleObjectInputStream extends ObjectInputStream {\n        private BouncyCastleObjectInputStream(ByteArrayInputStream input) throws Exception {\n            super(input);\n        }\n\n        @Override\n        protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {\n            if (BCElGamalPrivateKey.class.getName().equals(description.getName())) {\n                return BCElGamalPrivateKey.class;\n            }\n            return super.resolveClass(description);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 851, "output": 1285, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 22616, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778115149416, "responseId": "resp_0f0685683da137fd0169fbe24df820819296eaecc8b3dd74f9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_htyT1KlKtIrYeLfcOo15Y4wS|fc_0f0685683da137fd0169fbe25320748192a239560dc2d50763", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3881 bytes to tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCElGamalPrivate