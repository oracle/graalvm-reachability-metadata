[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCElGamalPrivateKeyTest.java","edits":[{"oldText":"import java.security.KeyFactory;\nimport java.security.Provider;\n\nimport javax.crypto.interfaces.DHPrivateKey;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPrivateKey;\nimport org.bouncycastle.jce.interfaces.ElGamalPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.ElGamalParameterSpec;\nimport org.bouncycastle.jce.spec.ElGamalPrivateKeySpec;\n","newText":"import javax.crypto.interfaces.DHPrivateKey;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.oiw.ElGamalParameter;\nimport org.bouncycastle.asn1.oiw.OIWObjectIdentifiers;\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.BCElGamalPrivateKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.elgamal.KeyFactorySpi;\nimport org.bouncycastle.jce.interfaces.ElGamalPrivateKey;\n"},{"oldText":"    private static ElGamalPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger g) throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"ElGamal\", provider);\n        ElGamalParameterSpec parameterSpec = new ElGamalParameterSpec(p, g);\n        return (ElGamalPrivateKey) keyFactory.generatePrivate(new ElGamalPrivateKeySpec(x, parameterSpec));\n    }\n","newText":"    private static ElGamalPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger g) throws Exception {\n        ElGamalParameter elGamalParameter = new ElGamalParameter(p, g);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n            OIWObjectIdentifiers.elGamalAlgorithm,\n            elGamalParameter.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(x));\n        return (ElGamalPrivateKey) new KeyFactorySpi().generatePrivate(privateKeyInfo);\n    }\n"}]}
