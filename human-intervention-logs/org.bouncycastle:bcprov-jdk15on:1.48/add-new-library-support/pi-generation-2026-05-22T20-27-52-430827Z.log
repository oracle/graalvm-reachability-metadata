                      coverageMetricOrNa(rootCounters, "INSTRUCTION"),
                      coverageMetricOrNa(rootCounters, "METHOD")
              );
          } catch (Exception e) {
              throw new GradleException("Failed to parse JaCoCo report " + jacocoReport, e);
          }
