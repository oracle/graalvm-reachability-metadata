cy Castle Provider is a Java cryptography provider that implements JCA/JCE algorithms and the Bouncy Castle lightweight crypto APIs. The bcprov-jdk15on artifact targets JDK 1.5 through JDK 1.7 and supplies cryptographic primitives, ASN.1 handling, and provider integrations for JVM applications.\",\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:5:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:17:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:29:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:41:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:53:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:55:      \"type\": \"org.bouncycastle.jcajce.provider.asymmetric.EC$Mappings\",\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:65:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:67:      \"type\": \"org.bouncycastle.jcajce.provider.asymmetric.ECGOST$Mappings\",\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:77:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:79:      \"type\": \"org.bouncycastle.jcajce.provider.asymmetric.EdEC$Mappings\",\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:89:        \"typeReached\": \"org.bouncycastle.jce.provider.B