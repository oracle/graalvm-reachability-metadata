ce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15to18/index.json:9:    \"description\" : \"Provides Bouncy Castle Java APIs for PKIX, CMS, PKCS, EAC, TSP, CMP, CRMF, OCSP, and certificate generation. It targets JDK 1.5 through JDK 1.8 and is typically used alongside a JCE/JCA provider such as Bouncy Castle's cryptography provider.\",\nmetadata/org.bouncycastle/bcprov-jdk15on/index.json:5:    \"source-code-url\" : \"https://repo1.maven.org/maven2/org/bouncycastle/bcprov-jdk15on/$version$/bcprov-jdk15on-$version$-sources.jar\",\nmetadata/org.bouncycastle/bcprov-jdk15on/index.json:8:    \"documentation-url\" : \"https://repo1.maven.org/maven2/org/bouncycastle/bcprov-jdk15on/$version$/bcprov-jdk15on-$version$-javadoc.jar\",\nmetadata/org.bouncycastle/bcprov-jdk15on/index.json:9:    \"description\" : \"Bouncy Castle Provider is a Java cryptography provider that implements JCA/JCE algorithms and the Bouncy Castle lightweight crypto APIs. The bcprov-jdk15on artifact targets JDK 1.5 through JDK 1.7 and supplies cryptographic primitives, ASN.1 handling, and provider integrations for JVM applications.\",\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:5:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:17:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:29:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:41:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:53:        \"typeReached\": \"org.bouncycastle.jce.provider.BouncyCastleProvider\"\nmetadata/org.bouncycastle/bcpkix-jdk15on/1.70/reachability-metadata.json:55:  