olean writtenExpectedEncodedKey;\n\n        private TrackingObjectOutputStream(ByteArrayOutputStream output, byte[] expectedEncodedKey) throws Exception {\n            super(output);\n            this.expectedEncodedKey = expectedEncodedKey;\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object value) {\n            if (value instanceof byte[] && Arrays.equals(expectedEncodedKey, (byte[]) value)) {\n                writtenExpectedEncodedKey = true;\n            }\n            return value;\n        }\n\n        private boolean hasWrittenExpectedEncodedKey() {\n            return writtenExpectedEncodedKey;\n        }\n    }\n\n    private static final class TrackingObjectInputStream extends ObjectInputStream {\n        private final byte[] expectedEncodedKey;\n        private boolean readExpectedEncodedKey;\n\n        private TrackingObjectInputStream(ByteArrayInputStream input, byte[] expectedEncodedKey) throws Exception {\n            super(input);\n            this.expectedEncodedKey = expectedEncodedKey;\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {\n            if (BCECPublicKey.class.getName().equals(description.getName())) {\n                return BCECPublicKey.class;\n            }\n            return super.resolveClass(description);\n        }\n\n        @Override\n        protected Object resolveObject(Object value) {\n            if (value instanceof byte[] && Arrays.equals(expectedEncodedKey, (byte[]) value)) {\n                readExpectedEncodedKey = true;\n            }\n            return value;\n        }\n\n        private boolean hasReadExpectedEncodedKey() {\n            return readExpectedEncodedKey;\n        }\n    }\n","newText":"    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new