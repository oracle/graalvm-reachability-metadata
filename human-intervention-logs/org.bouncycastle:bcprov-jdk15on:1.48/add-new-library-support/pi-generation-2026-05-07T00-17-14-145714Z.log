  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.ObjectStreamClass;
  import java.security.interfaces.ECPublicKey;
  import java.security.spec.ECPoint;
  import java.security.spec.ECPublicKeySpec;
  import java.util.Arrays;
  
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.ua.DSTU4145NamedCurves;
  import org.bouncycastle.crypto.params.ECDomainParameters;
  import org.bouncycastle.jcajce.provider.asymmetric.dstu.BCDSTU4145PublicKey;
  import org.bouncycastle.jce.spec.ECNamedCurveSpec;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDSTU4145PublicKeyTest {
      @Test
      void serializesAndDeserializesDstu4145PublicKeyParameters() throws Exception {
          ECPublicKey original = createPublicKey();
  
          assertThat(original).isInstanceOf(BCDSTU4145PublicKey.class);
          assertThat(original.getEncoded()).isNotEmpty();
  
          byte[] encodedKey = original.getEncoded();
          byte[] serializedKey = serialize(original, encodedKey);
          ECPublicKey deserialized = (ECPublicKey) deserialize(serializedKey, encodedKey);
  
          assertThat(deserialized).isInstanceOf(BCDSTU4145PublicKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("DSTU4145");
          assertThat(deserialized.getFormat()).isEqualTo("X.509");
          assertThat(deserialized.getW()).isEqualTo(original.getW());
          assertThat(deserialized.getParams().getOrder()).isEqualTo(original.getParams().getOrder());
          assertThat(deserialized.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());
          assertThat(deserialized.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());
          assertThat(deserialized.getParams().getCurve()).isEqualTo(original.getParams().getCurve());
          assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());
          assertThat(deserialized.toString()).contains("EC Public Key", original.getW().getAffineX().toString(16));
      }
  
      private static ECPublicKey createPublicKey() throws Exception {
          ASN1ObjectIdentifier curveOid = DSTU4145NamedCurves.getOIDs()[0];
          ECDomainParameters domainParameters = DSTU4145NamedCurves.getByOID(curveOid);
          ECNamedCurveSpec parameterSpec = new ECNamedCurveSpec(
              curveOid.getId(),
              domainParameters.getCurve(),
              domainParameters.getG(),
              domainParameters.getN(),
              domainParameters.getH(),
              domainParameters.getSeed());
          ECPoint publicPoint = new ECPoint(
              domainParameters.getG().getX().toBigInteger(),
              domainParameters.getG().getY().toBigInteger());
          return new BCDSTU4145PublicKey(new ECPublicKeySpec(publicPoint, parameterSpec));
      }
  
      private static byte[] serialize(Object value, byte[] expectedEncodedKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          TrackingObjectOutputStream output = new TrackingObjectOutputStream(bytes, expectedEncodedKey);
          try (output) {
              output.writeObject(value);
          }
          assertThat(output.hasWrittenExpectedEncodedKey()).isTrue();
          return bytes.toByteArray();
      }
  
      private static Object deserialize(byte[] value, byte[] expectedEncodedKey) throws Exception {
          TrackingObjectInputStream input = new TrackingObjectInputStream(new ByteArrayInputStream(value), expectedEncodedKey);
          Object deserialized;
          try (input) {
              deserialized = input.readObject();
          }
          assertThat(input.hasReadExpectedEncodedKey()).isTrue();
          return deserialized;
      }
  
      private static final class TrackingObjectOutputStream extends ObjectOutputStream {
          private final byte[] expectedEncodedKey;
          private boolean writtenExpectedEncodedKey;
  
          private TrackingObjectOutputStream(ByteArrayOutputStream output, byte[] expectedEncodedKey) throws Exception {
              super(output);
              this.expectedEncodedKey = expectedEncodedKey;
              enableReplaceObject(true);
          }
  
          @Override
          protected Object replaceObject(Object value) {
              if (value instanceof byte[] && Arrays.equals(expectedEncodedKey, (byte[]) value)) {
                  writtenExpectedEncodedKey = true;
              }
              return value;
          }
  
          private boolean hasWrittenExpectedEncodedKey() {
              return writtenExpectedEncodedKey;
          }
      }
  
      private static final class TrackingObjectInputStream extends ObjectInputStream {
          private final byte[] expectedEncodedKey;
          private boolean readExpectedEncodedKey;
  
          private TrackingObjectInputStream(ByteArrayInputStream input, byte[] expectedEncodedKey) throws Exception {
              super(input);
              this.expectedEncodedKey = expectedEncodedKey;
              enableResolveObject(true);
          }
  
          @Override
          protected Class<?> resolveClass(ObjectStreamClass description) throws IOException, ClassNotFoundException {
              if (BCDSTU4145PublicKey.class.getName().equals(description.getName())) {
                  return BCDSTU4145PublicKey.class;
              }
              return super.resolveClass(description);
          }
  
          @Override
          protected Object resolveObject(Object value) {
              if (value instanceof byte[] && Arrays.equals(expectedEncodedKey, (byte[]) value)) {
                  readExpectedEncodedKey = true;
              }
              return value;
          }
  
          private boolean hasReadExpectedEncodedKey() {
              return readExpectedEncodedKey;
          }
      }
  }
