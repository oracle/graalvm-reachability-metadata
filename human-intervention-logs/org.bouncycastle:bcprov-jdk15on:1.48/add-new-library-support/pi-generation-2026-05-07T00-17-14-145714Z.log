 java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.interfaces.ECPublicKey;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.ec.BCECPublicKey;\nimport org.bouncycastle.jce.ECNamedCurveTable;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECPublicKeySpec;\nimport org.bouncycastle.math.ec.ECPoint;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCECPublicKeyTest {\n    @Test\n    void serializesAndDeserializesEcPublicKeyParameters() throws Exception {\n        ECPublicKey original = createPublicKey();\n\n        assertThat(original).isInstanceOf(BCECPublicKey.class);\n        assertThat(original.getEncoded()).isNotEmpty();\n\n        byte[] serializedKey = serialize(original);\n        ECPublicKey deserialized = (ECPublicKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(BCECPublicKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"EC\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"X.509\");\n        assertThat(deserialized.getW()).isEqualTo(original.getW());\n        assertThat(deserialized.getParams().getOrder()).isEqualTo(original.getParams().getOrder());\n        assertThat(deserialized.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());\n        assertThat(deserialized.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());\n        assertThat(deserialized.getParams().getCurve()).isEqualTo(original.getParams().getCurve());\n        assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(deserialized.toString()).contains(\"EC Public Key\", original.getW().getAffineX().toString(16));\n    }\n\n    private static ECPublicKey createPublicKey() {\n        ECNamedCurveParameterSpec parameterSpec = ECNamedCurveTable.getParameterSpec(\"prime256v1\");\n        assertThat(parameterSpec).isNotNull();\n        ECPoint publicPoint = parameterSpec.getG().multiply(BigInteger.valueOf(7L));\n        ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(publicPoint, parameterSpec);\n        return new BCECPublicKey(\"EC\", publicKeySpec, BouncyCastleProvider.CONFIGURATION);\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] value) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {\n            return input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778113238954}]}
