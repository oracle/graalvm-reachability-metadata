0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.PrivateKey;\nimport java.security.spec.DSAPrivateKeySpec;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCDSAPrivateKeyTest {\n    private static final BigInteger P = new BigInteger(\"123456789123456789123456789123456789123456789123456789\");\n    private static final BigInteger Q = new BigInteger(\"123456789123456789123456789\");\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger X = new BigInteger(\"123456789123456789\");\n\n    @Test\n    public void serializesAndDeserializesDsaPrivateKey() throws Exception {\n        BCDSAPrivateKey originalKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(originalKey);\n        BCDSAPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getX()).isEqualTo(originalKey.getX());\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(originalKey.getParams().getQ());\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\n        assertThat(restoredKey).isEqualTo(originalKey);\n    }\n\n    private static BCDSAPrivateKey createPrivateKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", new BouncyCastleProvider());\n        PrivateKey privateKey = keyFactory.generatePrivate(new DSAPrivateKeySpec(X, P, Q, G));\n\n        assertThat(privateKey).isInstanceOf(BCDSAPrivateKey.class);\n        return (BCDSAPrivateKey) privateKey;\n    }\n\n    private static byte[] serialize(BCDSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(privateKey);\n        }\n        assertThat(bytes.size()).isGreaterThan(0);\n        return bytes.toByteArray();\n    }\n\n    private static BCDSAPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSAPrivateKey) input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780856173347}, {"role": "toolResult", "toolCallId": "call_67iuCivAYXOiPF2ElORIpRrP|fc_012b7cb494fac718016a25b56d18948190a192809c3a91b7c3", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.DHParameter;\nimport org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCDHPublicKeyTest {\n    private static final BigInteger P = new BigInteger(\"123456789123456789123456789123456789123456789123456789\");\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger Y = new BigInteger(\"987654321987654321\");\n    private static final int L = 64;\n\n    @Test\n    public void serializesAndDeserializesDiffieHellmanPublicKey() throws Exception {\n        BCDHPublicKey originalKey = createPublicKey();\n\n        byte[] serializedKey = serialize(originalKey);\n        BCDHPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getY()).isEqualTo(originalKey.getY());\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\n        assertThat(restoredKey.getParams().getL()).isEqualTo(originalKey.getParams().getL());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n    }\n\n    private static BCDHPublicKey createPublicKey() throws Exception {\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(\n                new AlgorithmIdentifier(\n                        PKCSObjectIdentifiers.dhKeyAgreement,\n                        new DHParameter(P, G, L).toASN1Primitive()),\n                new ASN1Integer(Y));\n\n        return new BCDHPublicKey(publicKeyInfo);\n    }\n\n    private static byte[] serialize(BCDHPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(publicKey);\n        }\n        assertThat(bytes.size()).isGreaterThan(0);\n        return bytes.toByteArray();\n    }\n\n    private static BCDHPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDHPublicKey) input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780856173347}, {"role": "toolResult", "toolCallId": "call_SzUytJkSDohyYLqkdSaQ8MVS|fc_012b7cb494fac718016a25b56d189c819095fd01a769c03970", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"org.bouncycastle:bcprov-jdk15on:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780856173347}]}
