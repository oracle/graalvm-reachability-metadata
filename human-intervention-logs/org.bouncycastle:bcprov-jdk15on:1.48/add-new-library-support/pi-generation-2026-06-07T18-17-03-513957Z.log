[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCDSAPublicKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.PublicKey;\nimport java.security.spec.DSAPublicKeySpec;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCDSAPublicKeyTest {\n    private static final BigInteger P = new BigInteger(\"123456789123456789123456789123456789123456789123456789\");\n    private static final BigInteger Q = new BigInteger(\"123456789123456789123456789\");\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger Y = new BigInteger(\"987654321987654321\");\n\n    @Test\n    public void serializesAndDeserializesDsaPublicKey() throws Exception {\n        BCDSAPublicKey originalKey = createPublicKey();\n\n        byte[] serializedKey = serialize(originalKey);\n        BCDSAPublicKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getY()).isEqualTo(originalKey.getY());\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(originalKey.getParams().getQ());\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey).isEqualTo(originalKey);\n    }\n\n    private static BCDSAPublicKey createPublicKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", new BouncyCastleProvider());\n        PublicKey publicKey = keyFactory.generatePublic(new DSAPublicKeySpec(Y, P, Q, G));\n\n        assertThat(publicKey).isInstanceOf(BCDSAPublicKey.class);\n        return (BCDSAPublicKey) publicKey;\n    }\n\n    private static byte[] serialize(BCDSAPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(publicKey);\n        }\n        assertThat(bytes.size()).isGreaterThan(0);\n        return bytes.toByteArray();\n    }\n\n    private static BCDSAPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSAPublicKey) input.readObject();\n        }\n    }\n}\n"}
