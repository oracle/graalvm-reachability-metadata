ams().getG());\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSA\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"X.509\");\n        assertThat(restoredKey).isEqualTo(originalKey);\n    }\n\n    private static BCDSAPublicKey createPublicKey() throws Exception {\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", new BouncyCastleProvider());\n        PublicKey publicKey = keyFactory.generatePublic(new DSAPublicKeySpec(Y, P, Q, G));\n\n        assertThat(publicKey).isInstanceOf(BCDSAPublicKey.class);\n        return (BCDSAPublicKey) publicKey;\n    }\n\n    private static byte[] serialize(BCDSAPublicKey publicKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(publicKey);\n        }\n        assertThat(bytes.size()).isGreaterThan(0);\n        return bytes.toByteArray();\n    }\n\n    private static BCDSAPublicKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSAPublicKey) input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1780856446099}}
