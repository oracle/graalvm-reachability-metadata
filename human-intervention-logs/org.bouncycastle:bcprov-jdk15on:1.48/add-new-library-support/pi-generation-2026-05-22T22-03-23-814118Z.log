he CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.security.Provider;\nimport java.security.spec.InvalidKeySpecException;\nimport java.security.spec.KeySpec;\nimport java.util.Arrays;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.DESKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jcajce.provider.symmetric.util.BaseSecretKeyFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    private static final byte[] SECRET_KEY_BYTES = new byte[] {\n        0x01, 0x23, 0x45, 0x67, (byte)0x89, (byte)0xab, (byte)0xcd, (byte)0xef\n    };\n\n    @Test\n    void secretKeyFactoryReflectivelyCreatesRequestedByteArrayKeySpec() throws Exception {\n        SecretKeyFactory factory = new TestSecretKeyFactory();\n        SecretKey generatedKey = factory.generateSecret(new SecretKeySpec(SECRET_KEY_BYTES, \"TEST\"));\n\n        DESKeySpec desKeySpec = (DESKeySpec)factory.getKeySpec(generatedKey, DESKeySpec.class);\n\n        assertThat(desKeySpec.getKey()).isEqualTo(Arrays.copyOf(generatedKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n    }\n\n    public static class TestSecretKeyFactory extends SecretKeyFactory {\n        protected TestSecretKeyFactory() {\n            super(new TestSecretKeyFactorySpi(), new TestProvider(), \"TEST\");\n        }\n    }\n\n    public static class TestSecretKeyFactorySpi extends BaseSecretKeyFactory {\n        public TestSecretKeyFactorySpi() {\n            super(\"TEST\", null);\n        }\n    }\n\n    public static class TestProvider extends Provider {\n        private static final long serialVersionUID = 1L;\n\n        TestProvider() {\n            super(\"TEST\", 1.0, \"Test provider for BaseSecretKeyFactory\");\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2527, "output": 2033, "cacheRead": 45568, "cacheWrite": 0, "totalTokens": 50128, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779487604602, "responseId": "resp_06fa3b6f0dfd484f016a10d37544948197b835c8cc967d059b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_DU2mgTIJshQS5RTOGp84qNnb|fc_06fa3b6f0dfd484f016a10d38c6ccc8197983f4840cc900ecb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1999 bytes to tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BaseSecretKeyFactoryTest.java"}], "isError": false, "timestamp": 1779487632147}]}
