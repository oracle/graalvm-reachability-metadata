[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BaseSecretKeyFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.security.spec.InvalidKeySpecException;\nimport java.security.spec.KeySpec;\nimport java.util.Arrays;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.spec.DESKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jcajce.provider.symmetric.util.BaseSecretKeyFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    private static final byte[] SECRET_KEY_BYTES = new byte[] {\n        0x01, 0x23, 0x45, 0x67, (byte)0x89, (byte)0xab, (byte)0xcd, (byte)0xef\n    };\n\n    @Test\n    void baseFactoryReflectivelyCreatesRequestedByteArrayKeySpec() throws Exception {\n        ExposedSecretKeyFactory factory = new ExposedSecretKeyFactory();\n        SecretKey secretKey = new SecretKeySpec(SECRET_KEY_BYTES, \"TEST\");\n\n        DESKeySpec desKeySpec = factory.getKeySpec(secretKey, DESKeySpec.class);\n\n        assertThat(desKeySpec.getKey()).isEqualTo(Arrays.copyOf(secretKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n    }\n\n    public static class ExposedSecretKeyFactory extends BaseSecretKeyFactory {\n        ExposedSecretKeyFactory() {\n            super(\"TEST\", null);\n        }\n\n        DESKeySpec getKeySpec(SecretKey key, Class<? extends KeySpec> keySpec) throws InvalidKeySpecException {\n            return (DESKeySpec)engineGetKeySpec(key, keySpec);\n        }\n    }\n}\n"}
