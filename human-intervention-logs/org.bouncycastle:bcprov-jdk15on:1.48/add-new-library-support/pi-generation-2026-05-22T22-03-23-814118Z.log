a.util.Arrays;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.DESKeySpec;\nimport javax.crypto.spec.PBEKeySpec;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    private static final String PBE_WITH_SHA_AND_IDEA_CBC = \"PBEWITHSHAANDIDEA-CBC\";\n    private static final char[] PASSWORD = \"correct horse battery staple\".toCharArray();\n    private static final byte[] SALT = new byte[] {\n        0x01, 0x23, 0x45, 0x67, (byte)0x89, (byte)0xab, (byte)0xcd, (byte)0xef\n    };\n\n    @Test\n    void pbeFactoryReflectivelyCreatesRequestedByteArrayKeySpec() throws Exception {\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n        SecretKeyFactory factory = SecretKeyFactory.getInstance(PBE_WITH_SHA_AND_IDEA_CBC, provider);\n        PBEKeySpec passwordSpec = new PBEKeySpec(PASSWORD, SALT, 100, 128);\n\n        SecretKey secretKey = factory.generateSecret(passwordSpec);\n        DESKeySpec desKeySpec = (DESKeySpec)factory.getKeySpec(secretKey, DESKeySpec.class);\n\n        assertThat(desKeySpec.getKey()).isEqualTo(Arrays.copyOf(secretKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1997, "output": 934, "cacheRead": 27136, "cacheWrite": 0, "totalTokens": 30067, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779487367153, "responseId": "resp_06fa3b6f0dfd484f016a10d287c6d8819789b3c70414e3300e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_pbJSAXoEIVzptjeDnhTFRmTw|fc_06fa3b6f0dfd484f016a10d29224c08197a64b59b7cbe8264a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1548 bytes to tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/