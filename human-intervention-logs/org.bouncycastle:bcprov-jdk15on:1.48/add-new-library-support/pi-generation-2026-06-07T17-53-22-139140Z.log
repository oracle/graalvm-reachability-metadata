  package org_bouncycastle.bcprov_jdk15on;
  
  import org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;
  import org.junit.jupiter.api.Test;
  
  import java.security.KeyPairGenerator;
  import java.security.Provider;
  import java.security.Security;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BouncyCastlePQCProviderTest {
      @Test
      public void loadsPostQuantumAlgorithmMappings() throws Exception {
          Provider previousProvider = Security.getProvider(BouncyCastlePQCProvider.PROVIDER_NAME);
          if (previousProvider != null) {
              Security.removeProvider(BouncyCastlePQCProvider.PROVIDER_NAME);
          }
  
          try {
              BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();
              Security.addProvider(provider);
  
              assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);
              assertThat(provider.getClass().getClassLoader()).isNotNull();
              assertThat(provider.hasAlgorithm("KeyFactory", "Rainbow")).isTrue();
              assertThat(provider.hasAlgorithm("KeyPairGenerator", "Rainbow")).isTrue();
              assertThat(provider.hasAlgorithm("KeyPairGenerator", "McEliecePKCS")).isTrue();
              assertThat(provider.hasAlgorithm("Cipher", "McEliecePKCS")).isTrue();
  
              assertThat(KeyPairGenerator.getInstance("Rainbow", provider)).isNotNull();
              assertThat(KeyPairGenerator.getInstance("McEliecePKCS", provider)).isNotNull();
              assertThat(provider.getService("Cipher", "McEliecePKCS")).isNotNull();
          } finally {
              Security.removeProvider(BouncyCastlePQCProvider.PROVIDER_NAME);
              if (previousProvider != null) {
                  Security.addProvider(previousProvider);
              }
          }
      }
  }
