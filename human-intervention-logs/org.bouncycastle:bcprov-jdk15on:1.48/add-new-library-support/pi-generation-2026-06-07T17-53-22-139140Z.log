  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_bouncycastle.bcprov_jdk15on;
  
  import org.bouncycastle.jce.provider.X509CertParser;
  import org.bouncycastle.x509.X509StreamParser;
  import org.junit.jupiter.api.Test;
  
  import java.security.Provider;
  import java.security.Security;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class X509UtilTest {
      private static final String PARSER_TYPE = "CERTIFICATE";
      private static final String PARSER_PROPERTY = "X509StreamParser." + PARSER_TYPE;
      private static final String PARSER_IMPLEMENTATION = X509CertParser.class.getName();
  
      @Test
      public void createsX509StreamParserThroughProviderClassLoader() throws Exception {
          X509CertParser directlyReachableParser = new X509CertParser();
          Provider provider = new ParserProvider();
  
          X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);
  
          assertThat(directlyReachableParser).isNotNull();
          assertThat(parser.getProvider()).isSameAs(provider);
          parser.init(new byte[0]);
          assertThat(parser.read()).isNull();
      }
  
      @Test
      public void createsX509StreamParserThroughClassForNameFallback() throws Exception {
          X509CertParser directlyReachableParser = new X509CertParser();
          Provider provider = findBootstrapLoadedProvider();
          Object previousImplementation = provider.get(PARSER_PROPERTY);
          provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);
  
          try {
              X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);
  
              assertThat(directlyReachableParser).isNotNull();
              assertThat(parser.getProvider()).isSameAs(provider);
              parser.init(new byte[0]);
              assertThat(parser.readAll()).isEmpty();
          } finally {
              restoreProviderProperty(provider, previousImplementation);
          }
      }
  
      private static final class ParserProvider extends Provider {
          private ParserProvider() {
              super("X509UtilTestProvider", 1.0, "Provider for X509Util dynamic access coverage");
              put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);
          }
      }
  
      private static Provider findBootstrapLoadedProvider() {
          for (Provider provider : Security.getProviders()) {
              if (provider.getClass().getClassLoader() == null) {
                  return provider;
              }
          }
          throw new AssertionError("Expected a JDK security provider loaded by the bootstrap class loader");
      }
  
      private static void restoreProviderProperty(Provider provider, Object previousImplementation) {
          if (previousImplementation == null) {
              provider.remove(PARSER_PROPERTY);
          } else {
              provider.put(PARSER_PROPERTY, previousImplementation);
          }
      }
  }
