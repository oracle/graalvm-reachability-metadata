      }
  
      private void writeObject(
          ObjectOutputStream  out)
          throws IOException
      {
          out.defaultWriteObject();
  
          out.writeObject(dhSpec.getP());
          out.writeObject(dhSpec.getG());
          out.writeInt(dhSpec.getL());
      }
  }
