actory;\nimport javax.crypto.spec.DESKeySpec;\nimport javax.crypto.spec.PBEKeySpec;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCESecretKeyFactoryTest {\n    private static final char[] PASSWORD = \"changeit\".toCharArray();\n    private static final byte[] SALT = new byte[] {\n        0x10, 0x32, 0x54, 0x76, (byte)0x98, (byte)0xba, (byte)0xdc, (byte)0xfe\n    };\n\n    @Test\n    void pbeSecretKeyFactoryCreatesRequestedByteArrayKeySpec() throws Exception {\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n        SecretKeyFactory factory = SecretKeyFactory.getInstance(\"PBEWITHMD5ANDDES\", provider);\n        SecretKey secretKey = factory.generateSecret(new PBEKeySpec(PASSWORD, SALT, 100));\n\n        DESKeySpec keySpec = (DESKeySpec)factory.getKeySpec(secretKey, DESKeySpec.class);\n\n        assertThat(keySpec.getKey()).isEqualTo(Arrays.copyOf(secretKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 901, "output": 468, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 25433, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779492475197, "responseId": "resp_063c996b75ddc5d2016a10e67bd2988196b5f487bfd0a2ce1c"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wRDAXKeB5ZAiPIc6c0k71C1W|fc_063c996b75ddc5d2016a10e67d2f3c8196909535fc610563b5", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1373 bytes to tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/JCESecretKeyFactoryTest.java"}], "isError": false, "timestamp": 1779492479994}]}
