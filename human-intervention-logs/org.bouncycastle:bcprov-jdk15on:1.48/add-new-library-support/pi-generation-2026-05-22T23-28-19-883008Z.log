ertThat(keySpec.getKey()).isEqualTo(Arrays.copyOf(secretKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n    }\n", "newText": "    void desSecretKeyFactoryRejectsNonKeySpecClassAfterConstructingItFromEncodedKey() throws Exception {\n        SecretKeyFactory factory = new TestSecretKeyFactory(new JCESecretKeyFactory.DES());\n        SecretKey secretKey = factory.generateSecret(new DESKeySpec(SECRET_KEY_BYTES));\n\n        assertThatThrownBy(() -> factory.getKeySpec(secretKey, DESParameters.class))\n            .isInstanceOf(InvalidKeySpecException.class);\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1769, "output": 1485, "cacheRead": 36864, "cacheWrite": 0, "totalTokens": 40118, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779492732929, "responseId": "resp_063c996b75ddc5d2016a10e77df83481968fb609762ea24164"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_JucMCjXbwA3H9xSMcAkHepFY|fc_063c996b75ddc5d2016a10e78c50b48196a61005dad5629c58", "toolName": "edit", "content": [{"type": "text", "text": "Successfully replaced 2 block(s) in tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/JCESecretKeyFactoryTest.java."}], "details": {"diff": "    ...\n  6  */\n  7 package org_bouncycastle.bcprov_jdk15on;\n  8 \n  9 import java.security.Provider;\n-10 import java.util.Arrays;\n+10 import java.security.spec.InvalidKeySpecException;\n 11 \n 12 import javax.crypto.SecretKey;\n 13 import javax.crypto.SecretKeyFactory;\n 14 import javax.crypto.SecretKeyFactorySpi;\n 15 import javax.crypto.spec.DESKeySpec;\n 16 \n+17 import org.bouncycastle.crypto.params.DESParameters;\n 17 import org.bouncycastle.jce.provider.JCESecretKeyFactory;\n 18 import org.junit.jupiter.api.Test;\n 19 \n-20 import static org.assertj.core.api.Assertions.assertThat;\n+21 import static org.assertj.core.api.Assertions.assertThatThrownBy;\