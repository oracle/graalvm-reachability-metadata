15on/JCESecretKeyFactoryTest.java"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1544, "output": 447, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 27079, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779492482297, "responseId": "resp_063c996b75ddc5d2016a10e682fb648196a0328978a1eeec33"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_wNFwKIBCulc8B8VvlF5Ynz5X|fc_063c996b75ddc5d2016a10e689b6488196817bcf903cbc8105", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.util.Arrays;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.DESKeySpec;\nimport javax.crypto.spec.PBEKeySpec;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCESecretKeyFactoryTest {\n    private static final char[] PASSWORD = \"changeit\".toCharArray();\n    private static final byte[] SALT = new byte[] {\n        0x10, 0x32, 0x54, 0x76, (byte)0x98, (byte)0xba, (byte)0xdc, (byte)0xfe\n    };\n\n    @Test\n    void pbeSecretKeyFactoryCreatesRequestedByteArrayKeySpec() throws Exception {\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n        SecretKeyFactory factory = SecretKeyFactory.getInstance(\"PBEWITHMD5ANDDES\", provider);\n        SecretKey secretKey = factory.generateSecret(new PBEKeySpec(PASSWORD, SALT, 100));\n\n        DESKeySpec keySpec = (DESKeySpec)factory.getKeySpec(secretKey, DESKeySpec.class);\n\n        assertThat(keySpec.getKey()).isEqualTo(Arrays.copyOf(secretKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n    }\n}\n"}], "isError": false, "timestamp": 1779492490336}]}
