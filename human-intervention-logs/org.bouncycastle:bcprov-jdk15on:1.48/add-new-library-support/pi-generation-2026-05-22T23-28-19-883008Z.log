ESecretKeyFactory.PBEWithMD5AndDES());\n        SecretKey secretKey = factory.generateSecret(new PBEKeySpec(PASSWORD, SALT, 100));\n\n        DESKeySpec keySpec = (DESKeySpec)factory.getKeySpec(secretKey, DESKeySpec.class);\n\n        assertThat(keySpec.getKey()).isEqualTo(Arrays.copyOf(secretKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n    }\n\n    public static class TestSecretKeyFactory extends SecretKeyFactory {\n        public TestSecretKeyFactory(SecretKeyFactorySpi keyFactorySpi) {\n            super(keyFactorySpi, new TestProvider(), \"PBEWITHMD5ANDDES\");\n        }\n    }\n\n    public static class TestProvider extends Provider {\n        private static final long serialVersionUID = 1L;\n\n        TestProvider() {\n            super(\"TEST\", 1.0, \"Test provider for JCESecretKeyFactory\");\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779492520349}]}
