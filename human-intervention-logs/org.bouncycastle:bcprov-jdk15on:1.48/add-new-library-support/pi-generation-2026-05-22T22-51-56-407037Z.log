                  {
                      ecP = SECNamedCurves.getByName(curveName);
                      if (ecP == null)
                      {
                          ecP = NISTNamedCurves.getByName(curveName);
                      }
                      if (ecP == null)
                      {
                          ecP = TeleTrusTNamedCurves.getByName(curveName);
                      }
