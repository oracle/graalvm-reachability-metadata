              ProviderConfiguration configuration)
          {
              super(algorithm);
              this.algorithm = algorithm;
              this.configuration = configuration;
          }
  
          public void initialize(
              int             strength,
              SecureRandom    random)
          {
              this.strength = strength;
              this.random = random;
