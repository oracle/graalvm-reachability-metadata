  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.interfaces.DSAPrivateKey;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.DSAParameter;
  import org.bouncycastle.asn1.x9.X9ObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDSAPrivateKeyTest {
      @Test
      void serializesAndDeserializesDsaPrivateKeyParameters() throws Exception {
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger q = BigInteger.valueOf(11L);
          BigInteger g = BigInteger.valueOf(2L);
          BigInteger x = BigInteger.valueOf(7L);
          BCDSAPrivateKey original = createPrivateKey(x, p, q, g);
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          DSAPrivateKey deserialized = (DSAPrivateKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCDSAPrivateKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("DSA");
          assertThat(deserialized.getFormat()).isEqualTo("PKCS#8");
          assertThat(deserialized.getX()).isEqualTo(x);
          assertThat(deserialized.getParams().getP()).isEqualTo(p);
          assertThat(deserialized.getParams().getQ()).isEqualTo(q);
          assertThat(deserialized.getParams().getG()).isEqualTo(g);
          assertThat(deserialized.getEncoded()).isNotEmpty();
  
          ASN1ObjectIdentifier bagAttributeId = new ASN1ObjectIdentifier("1.2.840.113549.1.9.20");
          ASN1Integer bagAttributeValue = new ASN1Integer(BigInteger.ONE);
          BCDSAPrivateKey bouncyCastleKey = (BCDSAPrivateKey) deserialized;
          bouncyCastleKey.setBagAttribute(bagAttributeId, bagAttributeValue);
          assertThat(bouncyCastleKey.getBagAttribute(bagAttributeId)).isEqualTo(bagAttributeValue);
      }
  
      private static BCDSAPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger q, BigInteger g)
          throws Exception {
          DSAParameter dsaParameter = new DSAParameter(p, q, g);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
              X9ObjectIdentifiers.id_dsa,
              dsaParameter.toASN1Primitive());
          PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(x));
          return new BCDSAPrivateKey(privateKeyInfo);
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static void ensureSerializationBaseConstructorIsReachable() throws Exception {
          assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
      }
  }
