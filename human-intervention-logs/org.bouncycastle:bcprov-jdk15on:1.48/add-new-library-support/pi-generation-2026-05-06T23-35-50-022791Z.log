ce.provider.asymmetric.dsa.BCDSAPublicKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n", "newText": "import java.security.interfaces.DSAPublicKey;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.DSAParameter;\nimport org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPublicKey;\nimport org.junit.jupiter.api.Test;\n"}, {"oldText": "        BigInteger p = new TrackedBigInteger(\"23\");\n        BigInteger q = new TrackedBigInteger(\"11\");\n        BigInteger g = new TrackedBigInteger(\"2\");\n        BigInteger y = BigInteger.valueOf(13L);\n        DSAPublicKey original = createPublicKey(y, p, q, g);\n", "newText": "        BigInteger p = BigInteger.valueOf(23L);\n        BigInteger q = BigInteger.valueOf(11L);\n        BigInteger g = BigInteger.valueOf(2L);\n        BigInteger y = BigInteger.valueOf(13L);\n        BCDSAPublicKey original = createPublicKey(y, p, q, g);\n"}, {"oldText": "    private static DSAPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger q, BigInteger g)\n        throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DSA\", provider);\n        return (DSAPublicKey) keyFactory.generatePublic(new DSAPublicKeySpec(y, p, q, g));\n    }\n", "newText": "    private static BCDSAPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger q, BigInteger g)\n        throws Exception {\n        DSAParameter dsaParameter = new DSAParameter(p, q, g);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n            X9ObjectIdentifiers.id_dsa,\n            dsaParameter.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(y));\n        return new BCDSAPublicKey(publicKeyInfo);\n    }\n"}, {"oldText": "        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n", "newText": "        try (ObjectOutputStream output = new TrackingObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n"}, {"oldText": "    private static final class TrackedBigInteger extends BigInteger {\n        private static final long serialVersionUID = 1L;\n\n        private TrackedBigInteger(String value) {\n            super(value);\n        }\n    }\n", "newText": "    private static final class TrackingObjectOutputStream extends ObjectOutputStream {\n        private TrackingObjectOutputStream(ByteArrayOutputStream output) throws Exception {\n            super(output);\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object value) {\n            if (value instanceof BigInteger) {\n                return new TrackedBigInteger(value.toString());\n            }\n            return value;\n        }\n    }\n\n    private static final class TrackedBigInteger extends BigInteger {\n        private static final long serialVersionUID = 1L;\n\n        private TrackedBigInteger(String value) {\n            super(value);\n        }\n    }\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3007, "output": 2960, "cacheRead": 26112, "cacheWrite": 0, "totalTokens": 32079, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778110970836, "responseId": "resp_00a49b4536a2451f0169fbd1fbc414819e9f94b9d8460000e8"}}
