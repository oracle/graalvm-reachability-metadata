[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BaseSecretKeyFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.security.spec.InvalidKeySpecException;\nimport java.security.spec.KeySpec;\nimport java.util.Arrays;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.spec.DESKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jcajce.provider.symmetric.util.BaseSecretKeyFactory;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    @Test\n    void createsRequestedByteArrayKeySpecThroughBaseFactory() throws Exception {\n        ExposedSecretKeyFactory factory = new ExposedSecretKeyFactory();\n        SecretKey originalKey = factory.generateSecret(new SecretKeySpec(\n            new byte[] {1, 3, 5, 7, 9, 11, 13, 15},\n            \"TEST-CIPHER\"));\n\n        DESKeySpec convertedSpec = (DESKeySpec) factory.getKeySpec(originalKey, DESKeySpec.class);\n        SecretKeySpec roundTrippedSpec = (SecretKeySpec) factory.getKeySpec(originalKey, SecretKeySpec.class);\n\n        assertThat(convertedSpec.getKey()).containsExactly(Arrays.copyOf(originalKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n        assertThat(roundTrippedSpec.getAlgorithm()).isEqualTo(\"TEST-CIPHER\");\n        assertThat(roundTrippedSpec.getEncoded()).containsExactly(originalKey.getEncoded());\n    }\n\n    private static final class ExposedSecretKeyFactory extends BaseSecretKeyFactory {\n        private ExposedSecretKeyFactory() {\n            super(\"TEST-CIPHER\", null);\n        }\n\n        private SecretKey generateSecret(KeySpec keySpec) throws InvalidKeySpecException {\n            return engineGenerateSecret(keySpec);\n        }\n\n        @SuppressWarnings(\"rawtypes\")\n        private KeySpec getKeySpec(SecretKey key, Class keySpec) throws InvalidKeySpecException {\n            return engineGetKeySpec(key, keySpec);\n        }\n    }\n}\n"}
