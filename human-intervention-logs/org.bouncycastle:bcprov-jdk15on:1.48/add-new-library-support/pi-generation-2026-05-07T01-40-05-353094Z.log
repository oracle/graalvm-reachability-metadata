ycastle.bcprov_jdk15on;\n\nimport java.security.Provider;\n\nimport javax.crypto.SecretKey;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.DESKeySpec;\nimport javax.crypto.spec.PBEKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BaseSecretKeyFactoryTest {\n    @Test\n    void createsRequestedByteArrayKeySpecFromPbeSecretKey() throws Exception {\n        SecretKeyFactory factory = SecretKeyFactory.getInstance(\"PBEWITHSHAANDIDEA-CBC\", bouncyCastleProvider());\n        PBEKeySpec passwordSpec = new PBEKeySpec(\n            \"correct horse battery staple\".toCharArray(),\n            new byte[] {1, 3, 5, 7, 9, 11, 13, 15},\n            19,\n            128);\n\n        SecretKey secretKey = factory.generateSecret(passwordSpec);\n        DESKeySpec convertedSpec = (DESKeySpec) factory.getKeySpec(secretKey, DESKeySpec.class);\n        SecretKeySpec roundTrippedSpec = (SecretKeySpec) factory.getKeySpec(secretKey, SecretKeySpec.class);\n\n        assertThat(secretKey.getAlgorithm()).isEqualTo(\"PBEwithSHAandIDEA-CBC\");\n        assertThat(secretKey.getFormat()).isEqualTo(\"RAW\");\n        assertThat(convertedSpec.getKey()).containsExactly(secretKey.getEncoded());\n        assertThat(roundTrippedSpec.getAlgorithm()).isEqualTo(\"PBEwithSHAandIDEA-CBC\");\n        assertThat(roundTrippedSpec.getEncoded()).containsExactly(secretKey.getEncoded());\n    }\n\n    private static Provider bouncyCastleProvider() {\n        return new BouncyCastleProvider();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1675, "output": 1677, "cacheRead": 31744, "cacheWrite": 0, "totalTokens": 35096, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778117924355, "responseId": "resp_04105273bb0441c50169fbed24d47c819d999597315eaace09"}}
