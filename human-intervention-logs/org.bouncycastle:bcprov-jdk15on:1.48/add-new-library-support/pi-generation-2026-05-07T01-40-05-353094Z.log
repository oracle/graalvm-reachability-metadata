tKey()).containsExactly(Arrays.copyOf(originalKey.getEncoded(), DESKeySpec.DES_KEY_LEN));\n        assertThat(roundTrippedSpec.getAlgorithm()).isEqualTo(\"TEST-CIPHER\");\n        assertThat(roundTrippedSpec.getEncoded()).containsExactly(originalKey.getEncoded());\n    }\n\n    private static final class ExposedSecretKeyFactory extends BaseSecretKeyFactory {\n        private ExposedSecretKeyFactory() {\n            super(\"TEST-CIPHER\", null);\n        }\n\n        private SecretKey generateSecret(KeySpec keySpec) throws InvalidKeySpecException {\n            return engineGenerateSecret(keySpec);\n        }\n\n        @SuppressWarnings(\"rawtypes\")\n        private KeySpec getKeySpec(SecretKey key, Class keySpec) throws InvalidKeySpecException {\n            return engineGetKeySpec(key, keySpec);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 34099, "output": 1601, "cacheRead": 7168, "cacheWrite": 0, "totalTokens": 42868, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778118015139, "responseId": "resp_04105273bb0441c50169fbed801918819d986925e611e97f6a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_jNi7mbQBgdesD2Z5OLfie1jP|fc_04105273bb0441c50169fbed903400819d8af3b470f65be8cc", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2050 bytes to tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BaseSecretKeyFactoryTest.java"}], "isError": false, "timestamp": 1778118035764}]}
