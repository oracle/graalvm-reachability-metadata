      public BCPBEKey(
          String algorithm,
          ASN1ObjectIdentifier oid,
          int type,
          int digest,
          int keySize,
          int ivSize,
          PBEKeySpec pbeKeySpec,
          CipherParameters param)
      {
          this.algorithm = algorithm;
          this.oid = oid;
          this.type = type;
          this.digest = digest;
          this.keySize = keySize;
          this.ivSize = ivSize;
          this.pbeKeySpec = pbeKeySpec;
          this.param = param;
