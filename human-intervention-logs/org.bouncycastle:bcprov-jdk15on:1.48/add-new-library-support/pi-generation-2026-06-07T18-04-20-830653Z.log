alKey.getParams().getG());\\n        assertThat(restoredKey).isEqualTo(originalKey);\\n    }\\n\\n    private static BCDSAPrivateKey createPrivateKey() throws Exception {\\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(\\n                new AlgorithmIdentifier(\\n                        X9ObjectIdentifiers.id_dsa,\\n                        new DSAParameter(P, Q, G).toASN1Primitive()),\\n                new ASN1Integer(X));\\n\\n        return new BCDSAPrivateKey(privateKeyInfo);\\n    }\\n\\n    private static byte[] serialize(BCDSAPrivateKey privateKey) throws Exception {\\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\\n            output.writeObject(privateKey);\\n        }\\n        assertThat(bytes.size()).isGreaterThan(0);\\n        return bytes.toByteArray();\\n    }\\n\\n    private static BCDSAPrivateKey deserialize(byte[] serializedKey) throws Exception {\\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\\n            return (BCDSAPrivateKey) input.readObject();\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 953, "output": 1502, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 18327, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780855417898, "responseId": "resp_05fe2a3f75903d0c016a25b27a6e548197845caddb66842f86"}}
[tool-exec] start id=call_tKg74ywMAaAkhBLsUQFgO8LG|fc_05fe2a3f75903d0c016a25b28ccc3c8197932d7edfec540ef7 name=write args={"path": "tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCDSAPrivateKeyTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.pkcs.PrivateKeyInfo;\nimport org.bouncycastle.asn1.x509.AlgorithmIdentifier;\nimport org.bouncycastle.asn1.x509.DSAParameter;\nimport org.bouncycastle.asn1.x9.X9ObjectIdentifiers;\nimport org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPrivateKey;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCDSAPrivateKeyTest {\n    private static final BigInteger P = new BigInteger(\"123456789123456789123456789123456789123456789123456789\");\n    private static final BigInteger Q = new BigInteger(\"123456789123456789123456789\");\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger X = new BigInteger(\"123456789123456789\");\n\n    @Test\n    public void serializesAndDeserializesDsaPrivateKey() throws Exception {\n        BCDSAPrivateKey originalKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(originalKey);\n        BCDSAPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getX()).isEqualTo(originalKey.getX());\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\n        assertThat(restoredKey.getParams().getQ()).isEqualTo(originalKey.getParams().getQ());\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\n        assertThat(restoredKey).isEqualTo(originalKey);\n    }\n\n    private static BCDSAPrivateKey createPrivateKey() throws Exception {\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(\n                new AlgorithmIdentifier(\n                        X9ObjectIdentifiers.id_dsa,\n                        new DSAParameter(P, Q, G).toASN1Primitive()),\n                new ASN1Integer(X));\n\n        return new BCDSAPrivateKey(privateKeyInfo);\n    }\n\n    private static byte[] serialize(BCDSAPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(privateKey);\n        }\n        assertThat(bytes.size()).isGreaterThan(0);\n        return bytes.toByteArray();\n    }\n\n    private static BCDSAPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDSAPrivateKey) input.readObject();\n        }\n    }\n}\n"}
