s;\n", "newText": "import org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.provider.X509CertParser;\nimport org.bouncycastle.x509.X509StreamParser;\nimport org.junit.jupiter.api.Test;\n\nimport java.security.Provider;\nimport java.security.Security;\n"}, {"oldText": "public class X509UtilTest extends X509StreamParserSpi {\n    private static final String PARSER_TYPE = \"CERTIFICATE\";\n    private static final String PARSER_PROPERTY = \"X509StreamParser.\" + PARSER_TYPE;\n    private static final String PARSER_IMPLEMENTATION = X509UtilTest.class.getName();\n\n    private InputStream input;\n", "newText": "public class X509UtilTest {\n    private static final String PARSER_TYPE = \"CERTIFICATE\";\n    private static final String PARSER_PROPERTY = \"X509StreamParser.\" + PARSER_TYPE;\n    private static final String PARSER_IMPLEMENTATION = X509CertParser.class.getName();\n"}, {"oldText": "        BouncyCastleProvider provider = new BouncyCastleProvider();\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n            parser.init(new byte[] {1, 2, 3});\n            assertThat(parser.read()).isNull();\n        } finally {\n            restoreProviderProperty(provider, previousImplementation);\n        }\n", "newText": "        X509CertParser directlyReachableParser = new X509CertParser();\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n\n        X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\n\n        assertThat(directlyReachableParser).isNotNull();\n        assertThat(parser.getProvider()).isSameAs(provider);\n        parser.init(new byte[0]);\n        assertThat(parser.read()).isNull();\n"}, {"oldText": "        Provider provider = findBootstrapLoadedProvider();\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n            parser.init(new byte[] {4, 5, 6});\n            assertThat(parser.readAll()).isEmpty();\n        } finally {\n            restoreProviderProperty(provider, previousImplementation);\n        }\n    }\n\n    @Override\n    public void engineInit(InputStream in) {\n        input = in;\n    }\n\n    @Override\n    public Object engineRead() throws StreamParsingException {\n        assertThat(input).isNotNull();\n        return null;\n    }\n\n    @Override\n    public Collection engineReadAll() throws StreamParsingException {\n        assertThat(input).isNotNull();\n        return Collections.emptyList();\n    }\n", "newText": "        X509CertParser directlyReachableParser = new X509CertParser();\n        Provider provider = findBootstrapLoadedProvider();\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\n\n            assertThat(directlyReachableParser).isNotNull();\n            assertThat(parser.getProvider()).isSameAs(provider);\n            parser.init(new byte[0]);\n            assertThat(parser.readAll()).isEmpty();\n        } finally {\n            restoreProviderProperty(provider, previousImplementation);\n        }\n    }\n"}]}, "partialJson": "{\"path\":\"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/X509UtilTest.java\",\"edits\":[{\"oldText\":\"import org.bouncycastle.jce.provider.BouncyCastleProvider;\\nimport org.bouncycastle.x509.X509StreamParser;\\nimport org.bo