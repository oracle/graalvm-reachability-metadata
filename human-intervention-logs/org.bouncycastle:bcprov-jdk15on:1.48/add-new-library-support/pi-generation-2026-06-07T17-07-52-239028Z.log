f not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.x509.X509StreamParser;\nimport org.bouncycastle.x509.X509StreamParserSpi;\nimport org.bouncycastle.x509.util.StreamParsingException;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.InputStream;\nimport java.security.Provider;\nimport java.security.Security;\nimport java.util.Collection;\nimport java.util.Collections;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class X509UtilTest extends X509StreamParserSpi {\n    private static final String PARSER_TYPE = \"CERTIFICATE\";\n    private static final String PARSER_PROPERTY = \"X509StreamParser.\" + PARSER_TYPE;\n    private static final String PARSER_IMPLEMENTATION = X509UtilTest.class.getName();\n\n    @Test\n    public void createsX509StreamParserThroughProviderClassLoader() throws Exception {\n        BouncyCastleProvider provider = new BouncyCastleProvider();\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n            parser.init(new byte[] {1, 2, 3});\n            assertThat(parser.read()).isNull();\n        } finally {\n            restoreProviderProperty(provider, previousImplementation);\n        }\n    }\n\n    @Test\n    public void createsX509StreamParserThroughClassForNameFallback() throws Exception {\n        Provider provider = findBootstrapLoadedProvider();\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\n\n        try {\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\n\n            assertThat(parser.getProvider()).isSameAs(provider);\n            parser.init(new byte[] {4, 5, 6});\n            assertThat(parser.readAll()).isEmpty();\n        } finally {\n            restoreProviderProperty(provider, previousImplementation);\n        }\n    }\n\n    @Override\n    public void engineInit(InputStream in) {\n    }\n\n    @Override\n    public Object engineRead() throws StreamParsingException {\n        return null;\n    }\n\n    @Override\n    public Collection engineReadAll() throws StreamParsingException {\n        return Collections.emptyList();\n    }\n\n    private static Provider findBootstrapLoadedProvider() {\n        for (Provider provider : Security.getProviders()) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n        throw new AssertionError(\"Expected a JDK security provider loaded by the bootstrap class loader\");\n    }\n\n    private static void restoreProviderProperty(Provider provider, Object previousImplementation) {\n        if (previousImplementation == null) {\n            provider.remove(PARSER_PROPERTY);\n        } else {\n            provider.put(PARSER_PROPERTY, previousImplementation);\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/X509UtilTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_bouncycastle.bcprov_jdk15on;\\n\\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\\nimport org.bouncycastle.x509.X509StreamParser;\\nimport org.bouncycastle.x509.X509StreamParserSpi;\\nimport org.bouncycastle.x509.util.StreamParsingException;\\nimport org.junit.jupiter.api.Test;\\n\\nimport java.io.InputStream;\\nimport java.security.Provider;\\nimport java.security.Security;\\nimport java.util.Collection;\\nimport java.util.Collections;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class X509UtilTest extends X509StreamParserSpi {\\n    private static final String PARSER_TYPE = \\\"CERTIFICATE\\\";\\n    private static final String PARSER_PROPERTY = \\\"X509StreamParser.\\\" + PARSER_TYPE;\\n    private static final String PARSER_IMPLEMENTATION = X509UtilTest.class.getName();\\n\\n    @Test\\n    public void createsX509StreamParserThroughProviderClassLoader() throws Exception {\\n        BouncyCastleProvider provider = new BouncyCastleProvider();\\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\\n\\n        try {\\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\\n\\n            assertThat(parser.getProvider()).isSameAs(provider);\\n            parser.init(new byte[] {1, 2, 3});\\n            assertThat(parser.read()).isNull();\\n        } finally {\\n            restoreProviderProperty(provider, previousImplementation);\\n        }\\n    }\\n\\n    @Test\\n    public void createsX509StreamParserThroughClassForNameFallback() throws Exception {\\n        Provider provider = findBootstrapLoadedProvider();\\n        Object previousImplementation = provider.get(PARSER_PROPERTY);\\n        provider.put(PARSER_PROPERTY, PARSER_IMPLEMENTATION);\\n\\n        try {\\n            X509StreamParser parser = X509StreamParser.getInstance(PARSER_TYPE, provider);\\n\\n            assertThat(parser.getProvider()).isSameAs(provider);\\n            parser.init(new byte[] {4, 5, 6});\\n            assertThat(parser.readAll()).isEmpty();\\n        } finally {\\n            restoreProviderProperty(provider, previousImplementation);\\n        }\\n    }\\n\\n    @Override\\n    public void engineInit(InputStream in) {\\n    }\\n\\n    @Override\\n    public Object engineRead() throws StreamParsingException {\\n        return null;\\n    }\\n\\n    @Override\\n    public Collection engineReadAll() throws StreamParsingException {\\n        return Collections.emptyList();\\n    }\\n\\n    private static Provider findBootstrapLoadedProvider() {\\n        for (Provider provider : Security.getProviders()) {\\n            if (provider.getClass().getClassLoader() == null) {\\n                return provider;\\n            }\\n        }\\n        throw new AssertionError(\\\"Expected a JDK security provider loaded by the bootstrap class loader\\\");\\n    }\\n\\n    private static void restoreProviderProperty(Provider provider, Object previousImplementation) {\\n        if (previousImplementation == null) {\\n            provider.remove(PARSER_PROPERTY);\\n        } else {\\n            provider.put(PARSER_PROPERTY, previousImplementation);\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1488, "output": 1173, "cacheRead": 34304, "cacheWrite": 0, "totalTokens": 36965, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780852370813, "responseId": "resp_0f3e3f7c69a63527016a25a69386a08190b025b0a93c8490b3"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_8awYYlIUZRH4DU4g8xsY6v4O|fc_0f3e3f7c69a63527016a25a69eee448190930b86e57e21f960", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3286 bytes to tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/X509UtilTest.java"}], "isError": false, "timestamp": 1780852391320}]}
