  package org_bouncycastle.bcprov_jdk15on;
  
  import org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BouncyCastlePQCProviderTest {
      @Test
      void registersPqcAlgorithmMappingsOnConstruction() {
          BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();
  
          assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);
          assertThat(provider.getInfo()).contains("Post-Quantum Security Provider");
          assertThat(provider.hasAlgorithm("KeyFactory", "Rainbow")).isTrue();
          assertThat(provider.hasAlgorithm("KeyPairGenerator", "Rainbow")).isTrue();
          assertThat(provider.hasAlgorithm("Signature", "SHA256WITHRainbow")).isTrue();
          assertThat(provider.hasAlgorithm("KeyPairGenerator", "McEliecePKCS")).isTrue();
          assertThat(provider.hasAlgorithm("Cipher", "McElieceKobaraImaiWithSHA256")).isTrue();
      }
  
      @Test
      void exposesConfiguredImplementationClassNames() {
          BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();
  
          assertThat(provider.get("KeyFactory.Rainbow"))
              .isEqualTo("org.bouncycastle.pqc.jcajce.provider.rainbow.RainbowKeyFactorySpi");
          assertThat(provider.get("KeyPairGenerator.McEliecePKCS"))
              .isEqualTo("org.bouncycastle.pqc.jcajce.provider.mceliece.McElieceKeyPairGeneratorSpi$McEliece");
          assertThat(provider.get("Cipher.McElieceKobaraImaiWithSHA256"))
              .isEqualTo("org.bouncycastle.pqc.jcajce.provider.mceliece.McElieceKobaraImaiCipherSpi$McElieceKobaraImai256");
      }
  }
