iece\");\n        assertThat(provider.get(\"Cipher.McElieceKobaraImaiWithSHA256\"))\n            .isEqualTo(\"org.bouncycastle.pqc.jcajce.provider.mceliece.McElieceKobaraImaiCipherSpi$McElieceKobaraImai256\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 612, "output": 1528, "cacheRead": 14848, "cacheWrite": 0, "totalTokens": 16988, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778106040407, "responseId": "resp_0e398141afbd4c2a0169fbbeb8f530819cb7998b7483533734"}}
