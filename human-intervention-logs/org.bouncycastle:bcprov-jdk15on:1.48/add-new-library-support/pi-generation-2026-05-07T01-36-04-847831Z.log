  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.util.Enumeration;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.ASN1ObjectIdentifier;
  import org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PKCS12BagAttributeCarrierImplTest {
      @Test
      void writesAndReadsEmptyBagAttributeState() throws Exception {
          PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();
  
          PKCS12BagAttributeCarrierImpl restored = readCarrier(writeCarrier(original));
  
          assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();
      }
  
      @Test
      void writesAndReadsEncodedBagAttributes() throws Exception {
          ASN1ObjectIdentifier friendlyName = new ASN1ObjectIdentifier("1.2.840.113549.1.9.20");
          ASN1ObjectIdentifier localKeyId = new ASN1ObjectIdentifier("1.2.840.113549.1.9.21");
          ASN1Integer friendlyNameValue = new ASN1Integer(BigInteger.valueOf(42L));
          ASN1Integer localKeyIdValue = new ASN1Integer(BigInteger.valueOf(7L));
          PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();
          original.setBagAttribute(friendlyName, friendlyNameValue);
          original.setBagAttribute(localKeyId, localKeyIdValue);
  
          PKCS12BagAttributeCarrierImpl restored = readCarrier(writeCarrier(original));
  
          assertThat(restored.getBagAttribute(friendlyName)).isEqualTo(friendlyNameValue);
          assertThat(restored.getBagAttribute(localKeyId)).isEqualTo(localKeyIdValue);
          assertThat(attributeKeys(restored)).containsExactly(friendlyName, localKeyId);
      }
  
      private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              carrier.writeObject(output);
          }
          return bytes.toByteArray();
      }
  
      private static PKCS12BagAttributeCarrierImpl readCarrier(byte[] value) throws Exception {
          PKCS12BagAttributeCarrierImpl carrier = new PKCS12BagAttributeCarrierImpl();
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              carrier.readObject(input);
          }
          return carrier;
      }
  
      private static ASN1ObjectIdentifier[] attributeKeys(PKCS12BagAttributeCarrierImpl carrier) {
          ASN1ObjectIdentifier[] keys = new ASN1ObjectIdentifier[2];
          Enumeration<?> enumeration = carrier.getBagAttributeKeys();
          int index = 0;
          while (enumeration.hasMoreElements()) {
              keys[index] = (ASN1ObjectIdentifier) enumeration.nextElement();
              index++;
          }
          assertThat(index).isEqualTo(keys.length);
          return keys;
      }
  }
