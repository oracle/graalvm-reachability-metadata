  package org_bouncycastle.bcprov_jdk15on;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.pkcs.DHParameter;
  import org.bouncycastle.asn1.pkcs.PKCSObjectIdentifiers;
  import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDHPrivateKeyTest {
      private static final BigInteger P = new BigInteger("123456789123456789123456789123456789123456789123456789");
      private static final BigInteger G = BigInteger.valueOf(5L);
      private static final BigInteger X = new BigInteger("123456789123456789");
      private static final int L = 64;
  
      @Test
      public void serializesAndDeserializesDiffieHellmanPrivateKey() throws Exception {
          BCDHPrivateKey originalKey = createPrivateKey();
  
          byte[] serializedKey = serialize(originalKey);
          BCDHPrivateKey restoredKey = deserialize(serializedKey);
  
          assertThat(restoredKey.getX()).isEqualTo(originalKey.getX());
          assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());
          assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());
          assertThat(restoredKey.getParams().getL()).isEqualTo(originalKey.getParams().getL());
      }
  
      private static BCDHPrivateKey createPrivateKey() throws Exception {
          PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(
                  new AlgorithmIdentifier(
                          PKCSObjectIdentifiers.dhKeyAgreement,
                          new DHParameter(P, G, L).toASN1Primitive()),
                  new ASN1Integer(X));
  
          return new BCDHPrivateKey(privateKeyInfo);
      }
  
      private static byte[] serialize(BCDHPrivateKey privateKey) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(privateKey);
          }
          assertThat(bytes.size()).isGreaterThan(0);
          return bytes.toByteArray();
      }
  
      private static BCDHPrivateKey deserialize(byte[] serializedKey) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {
              return (BCDHPrivateKey) input.readObject();
          }
      }
  }
