[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCDSTU4145PrivateKeyTest.java","edits":[{"oldText":"    @Test\n    public void serializesAndDeserializesDstuPrivateKeyWithImplicitParameters() throws Exception {\n        BCDSTU4145PrivateKey originalKey = new BCDSTU4145PrivateKey(new ECPrivateKeySpec(D, null));\n\n        byte[] serializedKey = serialize(originalKey);\n        BCDSTU4145PrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getD()).isEqualTo(originalKey.getD());\n        assertThat(restoredKey.getS()).isEqualTo(originalKey.getS());\n        assertThat(restoredKey.getParams()).isNull();\n        assertThat(restoredKey.getParameters()).isNull();\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n    }\n","newText":"    @Test\n    public void serializesDstuPrivateKeyWithImplicitParameters() throws Exception {\n        BCDSTU4145PrivateKey originalKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(originalKey);\n\n        assertThat(serializedKey).isNotEmpty();\n    }\n\n    @Test\n    public void deserializesDstuPrivateKeyWithImplicitParameters() throws Exception {\n        BCDSTU4145PrivateKey originalKey = createPrivateKey();\n        byte[] serializedKey = serialize(originalKey);\n\n        BCDSTU4145PrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getD()).isEqualTo(originalKey.getD());\n        assertThat(restoredKey.getS()).isEqualTo(originalKey.getS());\n        assertThat(restoredKey.getParams()).isNull();\n        assertThat(restoredKey.getParameters()).isNull();\n        assertThat(restoredKey.getAlgorithm()).isEqualTo(\"DSTU4145\");\n        assertThat(restoredKey.getFormat()).isEqualTo(\"PKCS#8\");\n    }\n\n    private static BCDSTU4145PrivateKey createPrivateKey() {\n        return new BCDSTU4145PrivateKey(new ECPrivateKeySpec(D, null));\n    }\n"}]}
