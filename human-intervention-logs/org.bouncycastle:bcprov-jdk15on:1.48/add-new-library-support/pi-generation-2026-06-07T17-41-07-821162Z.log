          }
          else
          {
              throw new IllegalArgumentException("unknown algorithm type: " + id);
          }
      }
  
      BCDHPrivateKey(
          DHPrivateKeyParameters params)
      {
          this.x = params.getX();
          this.dhSpec = new DHParameterSpec(params.getParameters().getP(), params.getParameters().getG(), params.getParameters().getL());
