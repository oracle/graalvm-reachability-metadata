[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCDHPrivateKeyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.dh.BCDHPrivateKey;\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.KeyFactory;\nimport java.security.PrivateKey;\nimport java.security.Provider;\n\nimport javax.crypto.interfaces.DHPrivateKey;\nimport javax.crypto.spec.DHPrivateKeySpec;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCDHPrivateKeyTest {\n    private static final BigInteger P = new BigInteger(\"123456789123456789123456789123456789123456789123456789\");\n    private static final BigInteger G = BigInteger.valueOf(5L);\n    private static final BigInteger X = new BigInteger(\"123456789123456789\");\n\n    @Test\n    public void serializesAndDeserializesDiffieHellmanPrivateKey() throws Exception {\n        DHPrivateKey originalKey = createPrivateKey();\n\n        byte[] encodedKey = serialize(originalKey);\n        Object restoredKey = deserialize(encodedKey);\n\n        assertThat(restoredKey).isInstanceOf(BCDHPrivateKey.class);\n        DHPrivateKey restoredPrivateKey = (DHPrivateKey) restoredKey;\n        assertThat(restoredPrivateKey.getX()).isEqualTo(originalKey.getX());\n        assertThat(restoredPrivateKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\n        assertThat(restoredPrivateKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\n        assertThat(restoredPrivateKey.getParams().getL()).isEqualTo(originalKey.getParams().getL());\n    }\n\n    private static DHPrivateKey createPrivateKey() throws Exception {\n        Provider provider = new BouncyCastleProvider();\n        KeyFactory keyFactory = KeyFactory.getInstance(\"DH\", provider);\n        PrivateKey privateKey = keyFactory.generatePrivate(new DHPrivateKeySpec(X, P, G));\n\n        assertThat(privateKey).isInstanceOf(BCDHPrivateKey.class);\n        return (DHPrivateKey) privateKey;\n    }\n\n    private static byte[] serialize(DHPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return input.readObject();\n        }\n    }\n}\n"}
