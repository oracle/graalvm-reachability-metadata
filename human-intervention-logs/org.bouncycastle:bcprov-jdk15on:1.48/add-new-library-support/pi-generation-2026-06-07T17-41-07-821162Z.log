[tool-call] delta {"path":"tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BCDHPrivateKeyTest.java","edits":[{"oldText":"import javax.crypto.interfaces.DHPrivateKey;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n","newText":"import static org.assertj.core.api.Assertions.assertThat;\n"},{"oldText":"        DHPrivateKey originalKey = createPrivateKey();\n\n        byte[] encodedKey = serialize(originalKey);\n        Object restoredKey = deserialize(encodedKey);\n\n        assertThat(restoredKey).isInstanceOf(BCDHPrivateKey.class);\n        DHPrivateKey restoredPrivateKey = (DHPrivateKey) restoredKey;\n        assertThat(restoredPrivateKey.getX()).isEqualTo(originalKey.getX());\n        assertThat(restoredPrivateKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\n        assertThat(restoredPrivateKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\n        assertThat(restoredPrivateKey.getParams().getL()).isEqualTo(originalKey.getParams().getL());\n    }\n\n    private static DHPrivateKey createPrivateKey() throws Exception {\n","newText":"        BCDHPrivateKey originalKey = createPrivateKey();\n\n        byte[] serializedKey = serialize(originalKey);\n        BCDHPrivateKey restoredKey = deserialize(serializedKey);\n\n        assertThat(restoredKey.getX()).isEqualTo(originalKey.getX());\n        assertThat(restoredKey.getParams().getP()).isEqualTo(originalKey.getParams().getP());\n        assertThat(restoredKey.getParams().getG()).isEqualTo(originalKey.getParams().getG());\n        assertThat(restoredKey.getParams().getL()).isEqualTo(originalKey.getParams().getL());\n    }\n\n    private static BCDHPrivateKey createPrivateKey() throws Exception {\n"},{"oldText":"    private static byte[] serialize(DHPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(privateKey);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return input.readObject();\n        }\n    }\n","newText":"    private static byte[] serialize(BCDHPrivateKey privateKey) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(privateKey);\n        }\n        assertThat(bytes.size()).isGreaterThan(0);\n        return bytes.toByteArray();\n    }\n\n    private static BCDHPrivateKey deserialize(byte[] serializedKey) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serializedKey))) {\n            return (BCDHPrivateKey) input.readObject();\n        }\n    }\n"}]}
