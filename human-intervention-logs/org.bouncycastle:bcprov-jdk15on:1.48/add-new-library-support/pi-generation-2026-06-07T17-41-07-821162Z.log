  package org_bouncycastle.bcprov_jdk15on;
  
  import org.bouncycastle.i18n.LocalizedMessage;
  import org.junit.jupiter.api.Test;
  
  import java.util.ListResourceBundle;
  import java.util.Locale;
  import java.util.TimeZone;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LocalizedMessageTest {
      private static final String TEST_MESSAGES = TestMessages.class.getName();
      private static final String MESSAGE_ID = "localized.message";
      private static final Locale ENGLISH = Locale.ENGLISH;
      private static final TimeZone UTC = TimeZone.getTimeZone("UTC");
  
      @Test
      public void resolvesEntryWithDefaultClassLoader() throws Exception {
          LocalizedMessage message = new LocalizedMessage(TEST_MESSAGES, MESSAGE_ID);
  
          String title = message.getEntry("title", ENGLISH, UTC);
  
          assertThat(title).isEqualTo("Localized test title");
      }
  
      @Test
      public void resolvesEntryWithConfiguredClassLoader() throws Exception {
          LocalizedMessage message = new LocalizedMessage(TEST_MESSAGES, MESSAGE_ID);
          message.setClassLoader(LocalizedMessageTest.class.getClassLoader());
  
          String text = message.getEntry("text", ENGLISH, UTC);
  
          assertThat(text).isEqualTo("Localized test text");
      }
  
      public static final class TestMessages extends ListResourceBundle {
          @Override
          protected Object[][] getContents() {
              return new Object[][] {
                      {"localized.message.title", "Localized test title"},
                      {"localized.message.text", "Localized test text"}
              };
          }
      }
  }
