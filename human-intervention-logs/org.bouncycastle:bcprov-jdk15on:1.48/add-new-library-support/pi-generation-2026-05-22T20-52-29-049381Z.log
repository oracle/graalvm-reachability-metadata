              return new BCECPublicKey((ECPublicKey)key, configuration);
          }
          else if (key instanceof ECPrivateKey)
          {
              return new BCECPrivateKey((ECPrivateKey)key, configuration);
          }
  
          throw new InvalidKeyException("key type unknown");
      }
  
