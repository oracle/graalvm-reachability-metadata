cycastle.jce.interfaces.GOST3410PrivateKey;\nimport org.bouncycastle.jce.spec.GOST3410PrivateKeySpec;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCGOST3410PrivateKeyTest {\n    @Test\n    void serializesAndDeserializesGost3410PrivateKeyParameters() throws Exception {\n        BigInteger privateValue = BigInteger.valueOf(7L);\n        BCGOST3410PrivateKey original = createPrivateKey(privateValue);\n\n        byte[] serializedKey = serialize(original);\n        ensureSerializationBaseConstructorIsReachable();\n        GOST3410PrivateKey deserialized = (GOST3410PrivateKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(BCGOST3410PrivateKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"PKCS#8\");\n        assertThat(deserialized.getX()).isEqualTo(privateValue);\n        assertThat(deserialized.getParameters().getPublicKeyParamSetOID())\n            .isEqualTo(original.getParameters().getPublicKeyParamSetOID());\n        assertThat(deserialized.getParameters().getDigestParamSetOID())\n            .isEqualTo(original.getParameters().getDigestParamSetOID());\n        assertThat(deserialized.getParameters().getPublicKeyParameters())\n            .isEqualTo(original.getParameters().getPublicKeyParameters());\n        assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());\n    }\n\n    @Test\n    void serializesAndDeserializesExplicitGost3410PrivateKeyParameters() throws Exception {\n        BigInteger privateValue = BigInteger.valueOf(7L);\n        BigInteger p = BigInteger.valueOf(23L);\n        BigInteger q = BigInteger.valueOf(11L);\n        BigInteger a = BigInteger.valueOf(2L);\n        BCGOST3410PrivateKey original = createPrivateKey(privateValue, p, q, a);\n\n        byte[] serializedKey = serialize(original);\n        ensureSerializationBaseConstructorIsReachable();\n        GOST3410PrivateKey deserialized = (GOST3410PrivateKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(BCGOST3410PrivateKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(deserialized.getX()).isEqualTo(privateValue);\n        assertThat(deserialized.getParameters().getPublicKeyParamSetOID()).isNull();\n        assertThat(deserialized.getParameters().getPublicKeyParameters().getP()).isEqualTo(p);\n        assertThat(deserialized.getParameters().getPublicKeyParameters().getQ()).isEqualTo(q);\n        assertThat(deserialized.getParameters().getPublicKeyParameters().getA()).isEqualTo(a);\n    }\n\n    private static BCGOST3410PrivateKey createPrivateKey(BigInteger privateValue) throws Exception {\n        GOST3410PublicKeyAlgParameters parameters = new GOST3410PublicKeyAlgParameters(\n            CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A,\n            CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n            CryptoProObjectIdentifiers.gostR3410_94,\n            parameters.toASN1Primitive());\n        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(\n            algorithmIdentifier,\n            new DEROctetString(toLittleEndianUnsigned(privateValue)));\n        return (BCGOST3410PrivateKey) new KeyFactorySpi().generatePrivate(privateKeyInfo);\n    }\n\n    private static BCGOST3410PrivateKey createPrivateKey(BigInteger privateValue, BigInteger p, BigInteger q,\n        BigInteger a) throws Exception {\n        GOST3410PrivateKeySpec privateKeySpec = new GOST3410PrivateKeySpec(privateValue, p, q, a);\n        return (BCGOST3410PrivateKey) new ExposedKeyFactorySpi().generatePrivateKey(privateKeySpec);\n    }\n\n    private static byte[] toLittleEndianUnsigned(BigInteger value) {\n        byte[] bigEndian = value.toByteArray();\n        int offset = bigEndian[0] == 0 ? 1 : 0;\n        byte[] littleEndian = new byte[bigEndian.length - offset];\n        for (int i = 0; i < littleEndian.length; i++) {\n            littleEndian[i] = bigEndian[bigEndian.length - 1 - i];\n        }\n        return littleEndian;\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static void ensureSerializationBaseConstructorIsReachable() throws Exception {\n        assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();\n    }\n\n    private static Object deserialize(byte[] value) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class ExposedKeyFactorySpi extends KeyFactorySpi {\n        private PrivateKey generatePrivateKey(GOST3410PrivateKeySpec keySpec) throws InvalidKeySpecException {\n            return engineGeneratePrivate(keySpec);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778117010203}, {"role": "toolResult", "toolCallId": "call_WNewWXz0M9ENdT3kpE0vfvgL|fc_0769aab4046aa7850169fbe991bc64819eb7ec709d0381b636", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.security.interfaces.ECPublicKey;\nimport java.util.Arrays;\n\nimport org.bouncycastle.jcajce.provider.asymmetric.ecgost.BCECGOST3410PublicKey;\nimport org.bouncycastle.jce.ECGOST3410NamedCurveTable;\nimport org.bouncycastle.jce.spec.ECNamedCurveParameterSpec;\nimport org.bouncycastle.jce.spec.ECPublicKeySpec;\nimport org.bouncycastle.math.ec.ECPoint;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCECGOST3410PublicKeyTest {\n    private static final String CURVE_NAME = \"GostR3410-2001-CryptoPro-A\";\n\n    @Test\n    void serializesAndDeserializesGost3410PublicKeyEncoding() throws Exception {\n        BCECGOST3410PublicKey original = createPublicKey(BigInteger.valueOf(7L));\n\n        byte[] expectedEncoding = original.getEncoded();\n        assertThat(expectedEncoding).isNotEmpty();\n\n        boolean[] encodedBytesWereWritten = new boolean[1];\n        byte[] serializedKey = serialize(original, expectedEncoding, encodedBytesWereWritten);\n        assertThat(encodedBytesWereWritten[0]).isTrue();\n\n        ensureSerializationBaseConstructorIsReachable();\n        boolean[] encodedBytesWereRead = new boolean[1];\n        ECPublicKey deserialized = (ECPublicKey) deserialize(serializedKey, expectedEncoding, encodedBytesWereRead);\n        assertThat(encodedBytesWereRead[0]).isTrue();\n\n        assertThat(deserialized).isInstanceOf(BCECGOST3410PublicKey.class);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"ECGOST3410\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"X.509\");\n        assertThat(deserialized.getW()).isEqualTo(original.getW());\n        assertThat(deserialized.getParams().getOrder()).isEqualTo(original.getParams().getOrder());\n        assertThat(deserialized.getParams().getCofactor()).isEqualTo(original.getParams().getCofactor());\n        assertThat(deserialized.getParams().getGenerator()).isEqualTo(original.getParams().getGenerator());\n        assertThat(deserialized.getParams().getCurve()).isEqualTo(original.getParams().getCurve());\n        assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(deserialized.toString()).contains(\"EC Public Key\", original.getW().getAffineX().toString(16));\n    }\n\n    private static BCECGOST3410PublicKey createPublicKey(BigInteger multiplier) {\n        ECNamedCurveParameterSpec parameterSpec = ECGOST3410NamedCurveTable.getParameterSpec(CURVE_NAME);\n        assertThat(parameterSpec).isNotNull();\n        ECPoint publicPoint = parameterSpec.getG().multiply(multiplier);\n        ECPublicKeySpec publicKeySpec = new ECPublicKeySpec(publicPoint, parameterSpec);\n        return new BCECGOST3410PublicKey(publicKeySpec);\n    }\n\n    private static byte[] serialize(Object value, byte[] expectedEncoding, boolean[] encodedBytesWereWritten)\n        throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new TrackingObjectOutputStream(\n                bytes,\n                expectedEncoding,\n                encodedBytesWereWritten)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static void ensureSerializationBaseConstructorIsReachable() throws Exception {\n        assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();\n    }\n\n    private static Object deserialize(byte[] value, byte[] expectedEncoding, boolean[] encodedBytesWereRead)\n        throws Exception {\n        try (ObjectInputStream input = new TrackingObjectInputStream(\n                new ByteArrayInputStream(value),\n                expectedEncoding,\n                encodedBytesWereRead)) {\n            return input.readObject();\n        }\n    }\n\n    private static final class TrackingObjectOutputStream extends ObjectOutputStream {\n        private final byte[] expectedEncoding;\n        private final boolean[] encodedBytesWereWritten;\n\n        private TrackingObjectOutputStream(\n                ByteArrayOutputStream output,\n                byte[] expectedEncoding,\n                boolean[] encodedBytesWereWritten)\n            throws IOException {\n            super(output);\n            this.expectedEncoding = expectedEncoding;\n            this.encodedBytesWereWritten = encodedBytesWereWritten;\n            enableReplaceObject(true);\n        }\n\n        @Override\n        protected Object replaceObject(Object value) {\n            if (value instanceof byte[] && Arrays.equals(expectedEncoding, (byte[]) value)) {\n                encodedBytesWereWritten[0] = true;\n            }\n            return value;\n        }\n    }\n\n    private static final class TrackingObjectInputStream extends ObjectInputStream {\n        private final byte[] expectedEncoding;\n        private final boolean[] encodedBytesWereRead;\n\n        private TrackingObjectInputStream(\n                ByteArrayInputStream input,\n                byte[] expectedEncoding,\n                boolean[] encodedBytesWereRead)\n            throws IOException {\n            super(input);\n            this.expectedEncoding = expectedEncoding;\n            this.encodedBytesWereRead = encodedBytesWereRead;\n            enableResolveObject(true);\n        }\n\n        @Override\n        protected Object resolveObject(Object value) {\n            if (value instanceof byte[] && Arrays.equals(expectedEncoding, (byte[]) value)) {\n                encodedBytesWereRead[0] = true;\n            }\n            return value;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778117010203}, {"role": "toolResult", "toolCallId": "call_XytA8QvMsSl1QKntn2hQOF6d|fc_0769aab4046aa7850169fbe991bc6c819e88291914f71207cc", "toolName": "read", "content": [{"type": "text", "text": "ENOENT: no such file or directory, access '/home/vjovanov/c/forge/forge6/graalvm-reachability-metadat