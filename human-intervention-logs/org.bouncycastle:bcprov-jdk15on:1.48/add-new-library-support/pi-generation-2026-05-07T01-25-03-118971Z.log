.asn1.x509.SubjectPublicKeyInfo;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PublicKey;\nimport org.bouncycastle.jcajce.provider.asymmetric.gost.KeyFactorySpi;\nimport org.bouncycastle.jce.interfaces.GOST3410PublicKey;\nimport org.bouncycastle.jce.spec.GOST3410PublicKeySpec;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BCGOST3410PublicKeyTest {\n    @Test\n    void serializesAndDeserializesGost3410PublicKeyParameters() throws Exception {\n        BigInteger publicValue = BigInteger.valueOf(7L);\n        BCGOST3410PublicKey original = createPublicKey(publicValue);\n\n        byte[] serializedKey = serialize(original);\n        GOST3410PublicKey deserialized = (GOST3410PublicKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(BCGOST3410PublicKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"X.509\");\n        assertThat(deserialized.getY()).isEqualTo(publicValue);\n        assertThat(deserialized.getParameters().getPublicKeyParamSetOID())\n            .isEqualTo(original.getParameters().getPublicKeyParamSetOID());\n        assertThat(deserialized.getParameters().getDigestParamSetOID())\n            .isEqualTo(original.getParameters().getDigestParamSetOID());\n        assertThat(deserialized.getParameters().getPublicKeyParameters())\n            .isEqualTo(original.getParameters().getPublicKeyParameters());\n        assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());\n        assertThat(deserialized.toString()).contains(\"GOST3410 Public Key\", publicValue.toString(16));\n    }\n\n    @Test\n    void serializesAndDeserializesExplicitGost3410PublicKeyParameters() throws Exception {\n        BigInteger publicValue = BigInteger.valueOf(13L);\n        BigInteger p = BigInteger.valueOf(23L);\n        BigInteger q = BigInteger.valueOf(11L);\n        BigInteger a = BigInteger.valueOf(2L);\n        BCGOST3410PublicKey original = createPublicKey(publicValue, p, q, a);\n\n        byte[] serializedKey = serialize(original);\n        GOST3410PublicKey deserialized = (GOST3410PublicKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(BCGOST3410PublicKey.class);\n        assertThat(deserialized).isEqualTo(original);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"GOST3410\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"X.509\");\n        assertThat(deserialized.getY()).isEqualTo(publicValue);\n        assertThat(deserialized.getParameters().getPublicKeyParamSetOID()).isNull();\n        assertThat(deserialized.getParameters().getPublicKeyParameters().getP()).isEqualTo(p);\n        assertThat(deserialized.getParameters().getPublicKeyParameters().getQ()).isEqualTo(q);\n        assertThat(deserialized.getParameters().getPublicKeyParameters().getA()).isEqualTo(a);\n        assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());\n    }\n\n    private static BCGOST3410PublicKey createPublicKey(BigInteger publicValue) throws Exception {\n        GOST3410PublicKeyAlgParameters parameters = new GOST3410PublicKeyAlgParameters(\n            CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A,\n            CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet);\n        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n            CryptoProObjectIdentifiers.gostR3410_94,\n            parameters.toASN1Primitive());\n        SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(\n            algorithmIdentifier,\n            new DEROctetString(toLittleEndianUnsigned(publicValue)));\n        return (BCGOST3410PublicKey) new KeyFactorySpi().generatePublic(publicKeyInfo);\n    }\n\n    private static BCGOST3410PublicKey createPublicKey(BigInteger publicValue, BigInteger p, BigInteger q,\n        BigInteger a) throws Exception {\n        GOST3410PublicKeySpec publicKeySpec = new GOST3410PublicKeySpec(publicValue, p, q, a);\n        return (BCGOST3410PublicKey) new ExposedKeyFactorySpi().generatePublicKey(publicKeySpec);\n    }\n\n    private static byte[] toLittleEndianUnsigned(BigInteger value) {\n        byte[] bigEndian = value.toByteArray();\n        int offset = bigEndian[0] == 0 ? 1 : 0;\n        byte[] littleEndian = new byte[bigEndian.length - offset];\n        for (int i = 0; i < littleEndian.length; i++) {\n            littleEndian[i] = bigEndian[bigEndian.length - 1 - i];\n        }\n        return littleEndian;\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] value) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class ExposedKeyFactorySpi extends KeyFactorySpi {\n        private PublicKey generatePublicKey(GOST3410PublicKeySpec keySpec) throws InvalidKeySpecException {\n            return engineGeneratePublic(keySpec);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1353, "output": 1865, "cacheRead": 28160, "cacheWrite": 0, "totalTokens": 31378, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778117050886, "responseId": "resp_0769aab4046aa7850169fbe9bb586c819ea0222192a7fac2ff"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_lVrGgnQzk0j2V79gGNcTYB6i|fc_0769aab4046aa7850169fbe9bfd1e8819eafb8794baa7fb9a7", "toolName": "