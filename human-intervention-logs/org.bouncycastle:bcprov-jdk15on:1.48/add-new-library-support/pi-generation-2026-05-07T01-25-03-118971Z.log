  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.interfaces.DSAPublicKey;
  
  import org.bouncycastle.asn1.ASN1Integer;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.asn1.x509.DSAParameter;
  import org.bouncycastle.asn1.x509.SubjectPublicKeyInfo;
  import org.bouncycastle.asn1.x9.X9ObjectIdentifiers;
  import org.bouncycastle.jcajce.provider.asymmetric.dsa.BCDSAPublicKey;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCDSAPublicKeyTest {
      @Test
      void serializesAndDeserializesDsaPublicKeyParameters() throws Exception {
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger q = BigInteger.valueOf(11L);
          BigInteger g = BigInteger.valueOf(2L);
          BigInteger y = BigInteger.valueOf(13L);
          BCDSAPublicKey original = createPublicKey(y, p, q, g);
  
          byte[] serializedKey = serialize(original);
          DSAPublicKey deserialized = (DSAPublicKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCDSAPublicKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("DSA");
          assertThat(deserialized.getFormat()).isEqualTo("X.509");
          assertThat(deserialized.getY()).isEqualTo(y);
          assertThat(deserialized.getParams().getP()).isEqualTo(p).isInstanceOf(TrackedBigInteger.class);
          assertThat(deserialized.getParams().getQ()).isEqualTo(q).isInstanceOf(TrackedBigInteger.class);
          assertThat(deserialized.getParams().getG()).isEqualTo(g).isInstanceOf(TrackedBigInteger.class);
          assertThat(deserialized.getEncoded()).isNotEmpty();
          assertThat(deserialized.toString()).contains("DSA Public Key", y.toString(16));
      }
  
      private static BCDSAPublicKey createPublicKey(BigInteger y, BigInteger p, BigInteger q, BigInteger g)
          throws Exception {
          DSAParameter dsaParameter = new DSAParameter(p, q, g);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
              X9ObjectIdentifiers.id_dsa,
              dsaParameter.toASN1Primitive());
          SubjectPublicKeyInfo publicKeyInfo = new SubjectPublicKeyInfo(algorithmIdentifier, new ASN1Integer(y));
          return new BCDSAPublicKey(publicKeyInfo);
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new TrackingObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
      }
  
      private static final class TrackingObjectOutputStream extends ObjectOutputStream {
          private TrackingObjectOutputStream(ByteArrayOutputStream output) throws Exception {
              super(output);
              enableReplaceObject(true);
          }
  
          @Override
          protected Object replaceObject(Object value) {
              if (value instanceof BigInteger) {
                  return new TrackedBigInteger(value.toString());
              }
              return value;
          }
      }
  
      private static final class TrackedBigInteger extends BigInteger {
          private static final long serialVersionUID = 1L;
  
          private TrackedBigInteger(String value) {
              super(value);
          }
      }
  }
