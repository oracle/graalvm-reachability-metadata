  package org_bouncycastle.bcprov_jdk15on;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.math.BigInteger;
  import java.security.PrivateKey;
  import java.security.spec.InvalidKeySpecException;
  
  import org.bouncycastle.asn1.DEROctetString;
  import org.bouncycastle.asn1.cryptopro.CryptoProObjectIdentifiers;
  import org.bouncycastle.asn1.cryptopro.GOST3410PublicKeyAlgParameters;
  import org.bouncycastle.asn1.pkcs.PrivateKeyInfo;
  import org.bouncycastle.asn1.x509.AlgorithmIdentifier;
  import org.bouncycastle.jcajce.provider.asymmetric.gost.BCGOST3410PrivateKey;
  import org.bouncycastle.jcajce.provider.asymmetric.gost.KeyFactorySpi;
  import org.bouncycastle.jce.interfaces.GOST3410PrivateKey;
  import org.bouncycastle.jce.spec.GOST3410PrivateKeySpec;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BCGOST3410PrivateKeyTest {
      @Test
      void serializesAndDeserializesGost3410PrivateKeyParameters() throws Exception {
          BigInteger privateValue = BigInteger.valueOf(7L);
          BCGOST3410PrivateKey original = createPrivateKey(privateValue);
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          GOST3410PrivateKey deserialized = (GOST3410PrivateKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCGOST3410PrivateKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("GOST3410");
          assertThat(deserialized.getFormat()).isEqualTo("PKCS#8");
          assertThat(deserialized.getX()).isEqualTo(privateValue);
          assertThat(deserialized.getParameters().getPublicKeyParamSetOID())
              .isEqualTo(original.getParameters().getPublicKeyParamSetOID());
          assertThat(deserialized.getParameters().getDigestParamSetOID())
              .isEqualTo(original.getParameters().getDigestParamSetOID());
          assertThat(deserialized.getParameters().getPublicKeyParameters())
              .isEqualTo(original.getParameters().getPublicKeyParameters());
          assertThat(deserialized.getEncoded()).isEqualTo(original.getEncoded());
      }
  
      @Test
      void serializesAndDeserializesExplicitGost3410PrivateKeyParameters() throws Exception {
          BigInteger privateValue = BigInteger.valueOf(7L);
          BigInteger p = BigInteger.valueOf(23L);
          BigInteger q = BigInteger.valueOf(11L);
          BigInteger a = BigInteger.valueOf(2L);
          BCGOST3410PrivateKey original = createPrivateKey(privateValue, p, q, a);
  
          byte[] serializedKey = serialize(original);
          ensureSerializationBaseConstructorIsReachable();
          GOST3410PrivateKey deserialized = (GOST3410PrivateKey) deserialize(serializedKey);
  
          assertThat(deserialized).isInstanceOf(BCGOST3410PrivateKey.class);
          assertThat(deserialized).isEqualTo(original);
          assertThat(deserialized.getAlgorithm()).isEqualTo("GOST3410");
          assertThat(deserialized.getX()).isEqualTo(privateValue);
          assertThat(deserialized.getParameters().getPublicKeyParamSetOID()).isNull();
          assertThat(deserialized.getParameters().getPublicKeyParameters().getP()).isEqualTo(p);
          assertThat(deserialized.getParameters().getPublicKeyParameters().getQ()).isEqualTo(q);
          assertThat(deserialized.getParameters().getPublicKeyParameters().getA()).isEqualTo(a);
      }
  
      private static BCGOST3410PrivateKey createPrivateKey(BigInteger privateValue) throws Exception {
          GOST3410PublicKeyAlgParameters parameters = new GOST3410PublicKeyAlgParameters(
              CryptoProObjectIdentifiers.gostR3410_94_CryptoPro_A,
              CryptoProObjectIdentifiers.gostR3411_94_CryptoProParamSet);
          AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(
              CryptoProObjectIdentifiers.gostR3410_94,
              parameters.toASN1Primitive());
          PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(
              algorithmIdentifier,
              new DEROctetString(toLittleEndianUnsigned(privateValue)));
          return (BCGOST3410PrivateKey) new KeyFactorySpi().generatePrivate(privateKeyInfo);
      }
  
      private static BCGOST3410PrivateKey createPrivateKey(BigInteger privateValue, BigInteger p, BigInteger q,
          BigInteger a) throws Exception {
          GOST3410PrivateKeySpec privateKeySpec = new GOST3410PrivateKeySpec(privateValue, p, q, a);
          return (BCGOST3410PrivateKey) new ExposedKeyFactorySpi().generatePrivateKey(privateKeySpec);
      }
  
      private static byte[] toLittleEndianUnsigned(BigInteger value) {
          byte[] bigEndian = value.toByteArray();
          int offset = bigEndian[0] == 0 ? 1 : 0;
          byte[] littleEndian = new byte[bigEndian.length - offset];
          for (int i = 0; i < littleEndian.length; i++) {
              littleEndian[i] = bigEndian[bigEndian.length - 1 - i];
          }
          return littleEndian;
      }
  
      private static byte[] serialize(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
          return bytes.toByteArray();
      }
  
      private static void ensureSerializationBaseConstructorIsReachable() throws Exception {
          assertThat(Object.class.getDeclaredConstructor().newInstance()).isNotNull();
      }
  
      private static Object deserialize(byte[] value) throws Exception {
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {
              return input.readObject();
          }
      }
  
      private static final class ExposedKeyFactorySpi extends KeyFactorySpi {
          private PrivateKey generatePrivateKey(GOST3410PrivateKeySpec keySpec) throws InvalidKeySpecException {
              return engineGeneratePrivate(keySpec);
          }
      }
  }
