", "newText": "    @Test\n    void registeredProviderX509StoreLoadsImplementationThroughSecurityProviders() throws Exception {\n        Provider previousProvider = Security.getProvider(PROVIDER_NAME);\n        if (previousProvider != null) {\n            Security.removeProvider(PROVIDER_NAME);\n        }\n\n        try {\n            BouncyCastleProvider provider = new BouncyCastleProvider();\n            Security.addProvider(provider);\n            X509CollectionStoreParameters parameters = new X509CollectionStoreParameters(Collections.emptyList());\n\n            X509Store store = X509Store.getInstance(\"CERTIFICATE/COLLECTION\", parameters);\n\n            assertThat(store.getProvider()).isSameAs(provider);\n            assertThat(store.getMatches(null)).isEmpty();\n        } finally {\n            Security.removeProvider(PROVIDER_NAME);\n            if (previousProvider != null) {\n                Security.addProvider(previousProvider);\n            }\n        }\n    }\n\n    @Test\n    void bootstrapProviderX509StreamParserLoadsImplementationWithClassForName() throws Exception {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1572, "output": 2225, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 45781, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1779479438246, "responseId": "resp_0c5ccc7a2d725f9c016a10b38f02b481908d46d71167de641c"}}
