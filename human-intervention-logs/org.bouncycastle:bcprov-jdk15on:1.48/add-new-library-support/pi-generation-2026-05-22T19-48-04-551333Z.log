          {
              X509Util.Implementation impl = X509Util.getImplementation("X509StreamParser", type, provider);
  
              return createParser(impl);
          }
          catch (NoSuchAlgorithmException e)
          {
              throw new NoSuchParserException(e.getMessage());
          }
