              throw new IllegalStateException("no signature algorithm specified");
          }
  
          sig = X509Util.getSignatureInstance(sigName);
  
          if (random != null)
          {
              sig.initSign(key, random);
          }
          else
          {
              sig.initSign(key);
          }
  
          sig.update(object.toASN1Primitive().getEncoded(ASN1Encoding.DER));
  
          return sig.sign();
      }
  
