      throws InvalidKeySpecException
      {
          if (keySpec instanceof GOST3410PublicKeySpec)
          {
              return new BCGOST3410PublicKey((GOST3410PublicKeySpec)keySpec);
          }
  
          return super.engineGeneratePublic(keySpec);
      }
  
