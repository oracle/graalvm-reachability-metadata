      }
  
      BCGOST3410PrivateKey(
          GOST3410PrivateKey key)
      {
          this.x = key.getX();
          this.gost3410Spec = key.getParameters();
      }
  
      BCGOST3410PrivateKey(
          GOST3410PrivateKeySpec spec)
