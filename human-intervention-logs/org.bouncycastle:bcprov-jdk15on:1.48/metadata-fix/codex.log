{"type":"item.completed","item":{"id":"item_75","type":"agent_message","text":"I found the exact source of the new failure: `BouncyCastleProvider.setup()` reflectively loads fixed algorithm-mapping classes from four static arrays. Rather than chasing these one at a time, I’m adding the whole provider mapping set that 1.48 actually loads, plus the PQC provider mappings used by the dedicated PQC test."}}
{"type":"item.started","item":{"id":"item_76","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BouncyCastlePQCProviderTest.java\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_76","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/BouncyCastlePQCProviderTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport org.bouncycastle.pqc.jcajce.provider.BouncyCastlePQCProvider;\nimport org.bouncycastle.pqc.jcajce.provider.McEliece;\nimport org.bouncycastle.pqc.jcajce.provider.Rainbow;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BouncyCastlePQCProviderTest {\n    @Test\n    void registersPqcAlgorithmMappingsOnConstruction() {\n        ensurePqcMappingsAreReachable();\n\n        BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();\n\n        assertThat(provider.getName()).isEqualTo(BouncyCastlePQCProvider.PROVIDER_NAME);\n        assertThat(provider.getInfo()).contains(\"Post-Quantum Security Provider\");\n        boolean rainbowKeyFactoryRegistered = provider.hasAlgorithm(\"KeyFactory\", \"Rainbow\");\n        boolean mcelieceKeyPairGeneratorRegistered = provider.hasAlgorithm(\"KeyPairGenerator\", \"McEliecePKCS\");\n\n        assertThat(provider.hasAlgorithm(\"KeyPairGenerator\", \"Rainbow\"))\n            .isEqualTo(rainbowKeyFactoryRegistered);\n        assertThat(provider.hasAlgorithm(\"Signature\", \"SHA256WITHRainbow\"))\n            .isEqualTo(rainbowKeyFactoryRegistered);\n        assertThat(provider.hasAlgorithm(\"Cipher\", \"McElieceKobaraImaiWithSHA256\"))\n            .isEqualTo(mcelieceKeyPairGeneratorRegistered);\n    }\n\n    @Test\n    void exposesConfiguredImplementationClassNames() {\n        ensurePqcMappingsAreReachable();\n\n        BouncyCastlePQCProvider provider = new BouncyCastlePQCProvider();\n\n        Object rainbowKeyFactory = provider.get(\"KeyFactory.Rainbow\");\n        if (rainbowKeyFactory == null) {\n            assertThat(provider.get(\"KeyPairGenerator.McEliecePKCS\")).isNull();\n            assertThat(provider.get(\"Cipher.McElieceKobaraImaiWithSHA256\")).isNull();\n        } else {\n            assertThat(rainbowKeyFactory)\n                .isEqualTo(\"org.bouncycastle.pqc.jcajce.provider.rainbow.RainbowKeyFactorySpi\");\n            assertThat(provider.get(\"KeyPairGenerator.McEliecePKCS\"))\n                .isEqualTo(\"org.bouncycastle.pqc.jcajce.provider.mceliece.McElieceKeyPairGeneratorSpi$McEliece\");\n            String sha256KobaraImaiCipher = \"org.bouncycastle.pqc.jcajce.provider.mceliece.\"\n                + \"McElieceKobaraImaiCipherSpi$McElieceKobaraImai256\";\n            assertThat(provider.get(\"Cipher.McElieceKobaraImaiWithSHA256\"))\n                .isEqualTo(sha256KobaraImaiCipher);\n        }\n    }\n\n    private void ensurePqcMappingsAreReachable() {\n        assertThat(new Rainbow.Mappings().getClass().getName())\n            .isEqualTo(\"org.bouncycastle.pqc.jcajce.provider.Rainbow$Mappings\");\n        assertThat(new McEliece.Mappings().getClass().getName())\n            .isEqualTo(\"org.bouncycastle.pqc.jcajce.provider.McEliece$Mappings\");\n    }\n}\n","exit_code":0,"status":"completed"}}
