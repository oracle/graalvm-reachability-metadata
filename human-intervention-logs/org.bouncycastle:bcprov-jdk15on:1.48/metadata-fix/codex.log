{"type":"item.completed","item":{"id":"item_36","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/PKCS12BagAttributeCarrierImplTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.math.BigInteger;\nimport java.util.Enumeration;\n\nimport org.bouncycastle.asn1.ASN1Integer;\nimport org.bouncycastle.asn1.ASN1ObjectIdentifier;\nimport org.bouncycastle.jcajce.provider.asymmetric.util.PKCS12BagAttributeCarrierImpl;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PKCS12BagAttributeCarrierImplTest {\n    @Test\n    void writesAndReadsEmptyBagAttributeState() throws Exception {\n        PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();\n\n        PKCS12BagAttributeCarrierImpl restored = readCarrier(writeCarrier(original));\n\n        assertThat(restored.getBagAttributeKeys().hasMoreElements()).isFalse();\n    }\n\n    @Test\n    void writesAndReadsEncodedBagAttributes() throws Exception {\n        ASN1ObjectIdentifier friendlyName = new ASN1ObjectIdentifier(\"1.2.840.113549.1.9.20\");\n        ASN1ObjectIdentifier localKeyId = new ASN1ObjectIdentifier(\"1.2.840.113549.1.9.21\");\n        ASN1Integer friendlyNameValue = new ASN1Integer(BigInteger.valueOf(42L));\n        ASN1Integer localKeyIdValue = new ASN1Integer(BigInteger.valueOf(7L));\n        PKCS12BagAttributeCarrierImpl original = new PKCS12BagAttributeCarrierImpl();\n        original.setBagAttribute(friendlyName, friendlyNameValue);\n        original.setBagAttribute(localKeyId, localKeyIdValue);\n\n        PKCS12BagAttributeCarrierImpl restored = readCarrier(writeCarrier(original));\n\n        assertThat(restored.getBagAttribute(friendlyName)).isEqualTo(friendlyNameValue);\n        assertThat(restored.getBagAttribute(localKeyId)).isEqualTo(localKeyIdValue);\n        assertThat(attributeKeys(restored)).containsExactly(friendlyName, localKeyId);\n    }\n\n    private static byte[] writeCarrier(PKCS12BagAttributeCarrierImpl carrier) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            carrier.writeObject(output);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static PKCS12BagAttributeCarrierImpl readCarrier(byte[] value) throws Exception {\n        PKCS12BagAttributeCarrierImpl carrier = new PKCS12BagAttributeCarrierImpl();\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {\n            carrier.readObject(input);\n        }\n        return carrier;\n    }\n\n    private static ASN1ObjectIdentifier[] attributeKeys(PKCS12BagAttributeCarrierImpl carrier) {\n        ASN1ObjectIdentifier[] keys = new ASN1ObjectIdentifier[2];\n        Enumeration<?> enumeration = carrier.getBagAttributeKeys();\n        int index = 0;\n        while (enumeration.hasMoreElements()) {\n            keys[index] = (ASN1ObjectIdentifier) enumeration.nextElement();\n            index++;\n        }\n        assertThat(index).isEqualTo(keys.length);\n        return keys;\n    }\n}\n","exit_code":0,"status":"completed"}}
