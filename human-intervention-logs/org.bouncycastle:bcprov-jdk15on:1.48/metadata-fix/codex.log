{"type":"item.completed","item":{"id":"item_160","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/JCEDHPublicKeyTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.ObjectStreamClass;\nimport java.io.Serializable;\nimport java.math.BigInteger;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Arrays;\n\nimport javax.crypto.interfaces.DHPublicKey;\n\nimport org.bouncycastle.jce.provider.JCEDHPublicKey;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JCEDHPublicKeyTest {\n    private static final long JCE_DH_PUBLIC_KEY_SERIAL_VERSION_UID = -216691575254424324L;\n\n    @Test\n    void serializesAndDeserializesLegacyDhPublicKeyParameters() throws Exception {\n        BigInteger p = BigInteger.valueOf(23L);\n        BigInteger g = BigInteger.valueOf(5L);\n        BigInteger y = BigInteger.valueOf(8L);\n        int privateValueLength = 7;\n\n        DHPublicKey original = deserializeLegacyPublicKey(y, p, g, privateValueLength);\n\n        assertThat(original).isInstanceOf(JCEDHPublicKey.class);\n        assertThat(original.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(original.getFormat()).isEqualTo(\"X.509\");\n        assertThat(original.getY()).isEqualTo(y);\n        assertThat(original.getParams().getP()).isEqualTo(p);\n        assertThat(original.getParams().getG()).isEqualTo(g);\n        assertThat(original.getParams().getL()).isEqualTo(privateValueLength);\n        assertThat(original.getEncoded()).isNotEmpty();\n\n        byte[] serializedKey = serialize(original);\n        DHPublicKey deserialized = (DHPublicKey) deserialize(serializedKey);\n\n        assertThat(deserialized).isInstanceOf(JCEDHPublicKey.class);\n        assertThat(deserialized.getAlgorithm()).isEqualTo(\"DH\");\n        assertThat(deserialized.getFormat()).isEqualTo(\"X.509\");\n        assertThat(deserialized.getY()).isEqualTo(y);\n        assertThat(deserialized.getParams().getP()).isEqualTo(p);\n        assertThat(deserialized.getParams().getG()).isEqualTo(g);\n        assertThat(deserialized.getParams().getL()).isEqualTo(privateValueLength);\n        assertThat(deserialized.getEncoded()).isNotEmpty();\n    }\n\n    private static DHPublicKey deserializeLegacyPublicKey(BigInteger y, BigInteger p, BigInteger g, int l)\n        throws Exception {\n        assertThat(ObjectStreamClass.lookup(JCEDHPublicKey.class).getSerialVersionUID())\n            .isEqualTo(JCE_DH_PUBLIC_KEY_SERIAL_VERSION_UID);\n\n        SerializedForm serializedForm = new SerializedForm(y, p, g, l);\n        byte[] serializedKey = serialize(serializedForm);\n        byte[] legacySerializedKey = replaceSerializedClassName(\n            serializedKey,\n            SerializedForm.class.getName(),\n            JCEDHPublicKey.class.getName());\n\n        return (DHPublicKey) deserialize(legacySerializedKey);\n    }\n\n    private static byte[] serialize(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static Object deserialize(byte[] value) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(value))) {\n            return input.readObject();\n        }\n    }\n\n    private static byte[] replaceSerializedClassName(byte[] serializedValue, String oldName, String newName) {\n        byte[] oldNameBytes = oldName.getBytes(StandardCharsets.UTF_8);\n        byte[] newNameBytes = newName.getBytes(StandardCharsets.UTF_8);\n        int oldNameIndex = indexOf(serializedValue, oldNameBytes);\n\n        assertThat(oldNameIndex).isGreaterThan(1);\n        assertThat(serializedValue[oldNameIndex - 2] & 0xff).isEqualTo(oldNameBytes.length >>> 8);\n        assertThat(serializedValue[oldNameIndex - 1] & 0xff).isEqualTo(oldNameBytes.length & 0xff);\n\n        ByteArrayOutputStream rewritten = new ByteArrayOutputStream(\n            serializedValue.length - oldNameBytes.length + newNameBytes.length);\n        rewritten.write(serializedValue, 0, oldNameIndex - 2);\n        rewritten.write((newNameBytes.length >>> 8) & 0xff);\n        rewritten.write(newNameBytes.length & 0xff);\n        rewritten.write(newNameBytes, 0, newNameBytes.length);\n        rewritten.write(\n            serializedValue,\n            oldNameIndex + oldNameBytes.length,\n            serializedValue.length - oldNameIndex - oldNameBytes.length);\n        return rewritten.toByteArray();\n    }\n\n    private static int indexOf(byte[] value, byte[] pattern) {\n        for (int i = 0; i <= value.length - pattern.length; i++) {\n            if (Arrays.equals(Arrays.copyOfRange(value, i, i + pattern.length), pattern)) {\n                return i;\n            }\n        }\n        return -1;\n    }\n\n    private static final class SerializedForm implements Serializable {\n        private static final long serialVersionUID = JCE_DH_PUBLIC_KEY_SERIAL_VERSION_UID;\n\n        private final transient BigInteger y;\n        private final transient BigInteger p;\n        private final transient BigInteger g;\n        private final transient int l;\n\n        private SerializedForm(BigInteger y, BigInteger p, BigInteger g, int l) {\n            this.y = y;\n            this.p = p;\n            this.g = g;\n            this.l = l;\n        }\n\n        private void writeObject(ObjectOutputStream out) throws IOException {\n            out.writeObject(y);\n            out.writeObject(p);\n            out.writeObject(g);\n            out.writeInt(l);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
