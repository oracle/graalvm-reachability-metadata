{"type":"item.completed","item":{"id":"item_37","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/org.bouncycastle/bcprov-jdk15on/1.48/src/test/java/org_bouncycastle/bcprov_jdk15on/X509UtilTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_bouncycastle.bcprov_jdk15on;\n\nimport java.security.Provider;\nimport java.security.Security;\nimport java.util.Collections;\n\nimport org.bouncycastle.jce.provider.BouncyCastleProvider;\nimport org.bouncycastle.jce.provider.X509StoreCertCollection;\nimport org.bouncycastle.x509.X509CollectionStoreParameters;\nimport org.bouncycastle.x509.X509Store;\nimport org.bouncycastle.x509.X509StoreSpi;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class X509UtilTest {\n    private static final String STORE_ALGORITHM = \"CERTIFICATE/COLLECTION\";\n    private static final String STORE_SPI_CLASS_NAME = X509StoreCertCollection.class.getName();\n\n    @Test\n    void x509StoreLoadsBouncyCastleImplementationThroughProviderClassLoader() throws Exception {\n        ensureStoreSpiIsReachable();\n        Provider provider = new BouncyCastleProvider();\n        X509CollectionStoreParameters parameters = new X509CollectionStoreParameters(Collections.emptyList());\n\n        X509Store store = X509Store.getInstance(STORE_ALGORITHM, parameters, provider);\n\n        assertThat(provider.get(\"X509Store.\" + STORE_ALGORITHM)).isEqualTo(STORE_SPI_CLASS_NAME);\n        assertThat(store.getProvider()).isSameAs(provider);\n        assertThat(store.getMatches(null)).isEmpty();\n    }\n\n    @Test\n    void x509StoreLoadsBouncyCastleImplementationThroughClassForNameForBootstrapProvider() throws Exception {\n        ensureStoreSpiIsReachable();\n        Provider bootstrapProvider = findBootstrapProvider();\n        String propertyName = \"X509Store.\" + STORE_ALGORITHM;\n        Object previousValue = bootstrapProvider.put(propertyName, STORE_SPI_CLASS_NAME);\n        X509CollectionStoreParameters parameters = new X509CollectionStoreParameters(Collections.emptyList());\n\n        try {\n            X509Store store = X509Store.getInstance(STORE_ALGORITHM, parameters, bootstrapProvider);\n\n            assertThat(store.getProvider()).isSameAs(bootstrapProvider);\n            assertThat(store.getMatches(null)).isEmpty();\n        } finally {\n            if (previousValue == null) {\n                bootstrapProvider.remove(propertyName);\n            } else {\n                bootstrapProvider.put(propertyName, previousValue);\n            }\n        }\n    }\n\n    private static void ensureStoreSpiIsReachable() {\n        X509StoreSpi spi = new X509StoreCertCollection();\n        assertThat(spi).isInstanceOf(X509StoreCertCollection.class);\n    }\n\n    private static Provider findBootstrapProvider() {\n        for (Provider provider : Security.getProviders()) {\n            if (provider.getClass().getClassLoader() == null) {\n                return provider;\n            }\n        }\n\n        throw new IllegalStateException(\"No bootstrap-loaded security provider is available\");\n    }\n\n}\n","exit_code":0,"status":"completed"}}
