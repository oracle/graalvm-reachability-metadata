y = serialize(original);\n    40\t        ensureSerializationBaseConstructorIsReachable();\n    41\t        DHPrivateKey deserialized = (DHPrivateKey) deserialize(serializedKey);\n    42\t\n    43\t        assertThat(deserialized).isInstanceOf(BCDHPrivateKey.class);\n    44\t        assertThat(deserialized).isEqualTo(original);\n    45\t        assertThat(deserialized.getAlgorithm()).isEqualTo(\"DH\");\n    46\t        assertThat(deserialized.getFormat()).isEqualTo(\"PKCS#8\");\n    47\t        assertThat(deserialized.getX()).isEqualTo(x);\n    48\t        assertThat(deserialized.getParams().getP()).isEqualTo(p);\n    49\t        assertThat(deserialized.getParams().getG()).isEqualTo(g);\n    50\t        assertThat(deserialized.getParams().getL()).isZero();\n    51\t        assertThat(deserialized.getEncoded()).isNotEmpty();\n    52\t    }\n    53\t\n    54\t    private static DHPrivateKey createPrivateKey(BigInteger x, BigInteger p, BigInteger g) throws Exception {\n    55\t        DHParameter dhParameter = new DHParameter(p, g, 0);\n    56\t        AlgorithmIdentifier algorithmIdentifier = new AlgorithmIdentifier(\n    57\t            PKCSObjectIdentifiers.dhKeyAgreement,\n    58\t            dhParameter.toASN1Primitive());\n    59\t        PrivateKeyInfo privateKeyInfo = new PrivateKeyInfo(algorithmIdentifier, new ASN1Integer(x));\n    60\t        return new BCDHPrivateKey(privateKeyInfo);\n    61\t    }\n    62\t\n    63\t    private static byte[] serialize(Object value) throws Exception {\n    64\t        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n    65\t        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n    66\t            output.writeObject(value);\n    67\t        }\n    68\t        return bytes.toByteArray();\n    69\t    }\n    70\t\n    71\t    private static void ensureSerializationBaseConstructorIsReachable() throws Exception {\n    72\t        assertThat(Object.class.getDeclaredConstructor().newInstance()).isNot