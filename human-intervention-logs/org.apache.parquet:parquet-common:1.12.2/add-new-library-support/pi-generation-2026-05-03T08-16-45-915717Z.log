[tool-call] delta {"path":"tests/src/org.apache.parquet/parquet-common/1.12.2/src/test/java/org_apache_parquet/parquet_common/DynConstructorsInnerBuilderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_parquet.parquet_common;\n\nimport org.apache.parquet.util.DynConstructors;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DynConstructorsInnerBuilderTest {\n    @Test\n    void implByClassNameLoadsPublicConstructor() {\n        DynConstructors.Ctor<PublicConstructible> ctor = new DynConstructors.Builder(PublicConstructible.class)\n                .impl(PublicConstructible.class.getName(), String.class)\n                .build();\n\n        PublicConstructible instance = ctor.newInstance(\"loaded by name\");\n\n        assertThat(instance.value()).isEqualTo(\"loaded by name\");\n        assertThat(ctor.getConstructedClass()).isEqualTo(PublicConstructible.class);\n    }\n\n    @Test\n    void hiddenImplByClassNameLoadsNonPublicConstructor() {\n        DynConstructors.Ctor<HiddenConstructible> ctor = new DynConstructors.Builder(HiddenConstructible.class)\n                .hiddenImpl(HiddenConstructible.class.getName(), String.class)\n                .build();\n\n        HiddenConstructible instance = ctor.newInstance(\"hidden by name\");\n\n        assertThat(instance.value()).isEqualTo(\"hidden by name\");\n        assertThat(ctor.getConstructedClass()).isEqualTo(HiddenConstructible.class);\n    }\n\n    public static class PublicConstructible {\n        private final String value;\n\n        public PublicConstructible(String value) {\n            this.value = value;\n        }\n\n        String value() {\n            return value;\n        }\n    }\n\n    public static class HiddenConstructible {\n        private final String value;\n\n        private HiddenConstructible(String value) {\n            this.value = value;\n        }\n\n        String value() {\n            return value;\n        }\n    }\n}\n"}
