lTo(122);\n    }\n\n    @Test\n    public void hiddenImplLoadsNamedClassAndFindsPrivateConstructor() {\n        DynConstructors.Ctor<PrivateConstructorSubject> constructor = new DynConstructors.Builder()\n                .hiddenImpl(PrivateConstructorSubject.class.getName(), String.class)\n                .build();\n\n        PrivateConstructorSubject instance = constructor.newInstance(\"hidden\");\n\n        assertThat(constructor.getConstructedClass()).isEqualTo(PrivateConstructorSubject.class);\n        assertThat(instance.value()).isEqualTo(\"hidden\");\n    }\n}\n\nfinal class PublicConstructorSubject {\n    private final String name;\n    private final int version;\n\n    public PublicConstructorSubject(String name, int version) {\n        this.name = name;\n        this.version = version;\n    }\n\n    String name() {\n        return name;\n    }\n\n    int version() {\n        return version;\n    }\n}\n\nfinal class PrivateConstructorSubject {\n    private final String value;\n\n    private PrivateConstructorSubject(String value) {\n        this.value = value;\n    }\n\n    String value() {\n        return value;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2035, "output": 1077, "cacheRead": 11264, "cacheWrite": 0, "totalTokens": 14376, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777920985404, "responseId": "resp_07ed28c32efde3390169f8ebd9f23881a3a3504fa6ecb02020"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_SPmqsoGEQtpTPeGiESDVwMse|fc_07ed28c32efde3390169f8ebe133f081a3aff2f6df9d1d5e6b", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2115 bytes to tests/src/org.apache.parquet/parquet-common/1.12.2/src/test/java/org_apache_parquet/parquet_common/DynConstructorsInnerBuilderTest.java"}], "isError": false, "timestamp": 1777920996438}]}
