 ParserConfig config = parserConfig();\\n\\n        assertThat(config.getDeserializer(DateTime.class)).isNotNull();\\n        assertThat(config.getDeserializer(HashMultimap.class)).isNotNull();\\n    }\\n\\n    @Test\\n    void scansEnumMethodsForJacksonCompatibility() {\\n        ParserConfig config = parserConfig();\\n        config.setJacksonCompatible(true);\\n\\n        assertThat(config.getDeserializer(PlainEnum.class)).isNotNull();\\n    }\\n\\n    @Test\\n    void instantiatesCustomDeserializerDeclaredOnEnumJsonType() {\\n        ParserConfig config = parserConfig();\\n\\n        ObjectDeserializer deserializer = config.getDeserializer(CustomDeserializedEnum.class);\\n\\n        assertThat(deserializer).isInstanceOf(CustomEnumDeserializer.class);\\n    }\\n\\n    @Test\\n    void resolvesEnumCreatorMethodFromMixin() {\\n        ParserConfig config = parserConfig();\\n        JSON.addMixInAnnotations(MixedCreatorEnum.class, MixedCreatorEnumMixin.class);\\n        try {\\n            MixedCreatorEnum value = JSON.parseObject(\\\"\\\\\\\"bee\\\\\\\"\\\", MixedCreatorEnum.class, config);\\n\\n            assertThat(value).isEqualTo(MixedCreatorEnum.BETA);\\n        } finally {\\n            JSON.removeMixInAnnotations(MixedCreatorEnum.class);\\n        }\\n    }\\n\\n    @Test\\n    void instantiatesCustomDeserializerDeclaredOnBeanJsonType() {\\n        ParserConfig config = new ParserConfig();\\n        config.setAsmEnable(true);\\n\\n        ObjectDeserializer deserializer = config.getDeserializer(CustomDeserializedBean.class);\\n\\n        assertThat(deserializer).isInstanceOf(CustomBeanDeserializer.class);\\n    }\\n\\n    @Test\\n    void scansClassResourceWithConfiguredDefaultClassLoaderDuringAutoTypeCheck() {\\n        ParserConfig config = parserConfig();\\n        config.setDefaultClassLoader(Thread.currentThread().getContextClassLoader());\\n\\n        Class<?> checked = config.checkAutoType(ResourceScannedWithConfiguredLoader.class.getName(), null);\\n\\n        assertThat(checked).isEqualTo(ResourceScannedWithConfiguredLoader.class);\\n    }\\n\\n    @Test\\n    void scansClassResourceWithParserConfigClassLoaderDuringAutoTypeCheck() {\\n        ParserConfig config = parserConfig();\\n\\n        Class<?> checked = config.checkAutoType(ResourceScannedWithParserConfigLoader.class.getName(), null);\\n\\n        assertThat(checked).isEqualTo(ResourceScannedWithParserConfigLoader.class);\\n    }\\n\\n    private static ParserConfig parserConfig() {\\n        ParserConfig config = new ParserConfig();\\n        config.setAsmEnable(false);\\n        return config;\\n    }\\n\\n    public enum PlainEnum {\\n        FIRST\\n    }\\n\\n    @JSONType(deserializer = CustomEnumDeserializer.class)\\n    public enum CustomDeserializedEnum {\\n        FIRST\\n    }\\n\\n    public static class CustomEnumDeserializer implements ObjectDeserializer {\\n        @Override\\n        public <T> T deserialze(DefaultJSONParser parser, Type type, Object fieldName) {\\n            return type instanceof Class<?> ? (T) ((Class<?>) type).getEnumConstants()[0] : null;\\n        }\\n\\n        @Override\\n        public int getFastMatchToken() {\\n            return JSONToken.LITERAL_STRING;\\n        }\\n    }\\n\\n    public enum MixedCreatorEnum {\\n        ALPHA,\\n        BETA;\\n\\n        public static MixedCreatorEnum fromCode(String code) {\\n            return \\\"bee\\\".equals(code) ? BETA : ALPHA;\\n        }\\n    }\\n\\n    public abstract static class MixedCreatorEnumMixin {\\n        @JSONCreator\\n        public static MixedCreatorEnum fromCode(String code) {\\n            return null;\\n        }\\n    }\\n\\n    @JSONType(deserializer = CustomBeanDeserializer.class)\\n    public static class CustomDeserializedBean {\\n        public String name;\\n    }\\n\\n    public static class CustomBeanDeserializer implements ObjectDeserializer {\\n        @Override\\n        public <T> T deserialze(DefaultJSONParser parser, Type type, Object fieldName) {\\n            return null;\\n        }\\n\\n        @Override\\n        public int getFastMatchToken() {\\n            return JSONToken.LBRACE;\\n        }\\n    }\\n\\n    @JSONType\\n    public static class ResourceScannedWithConfiguredLoader {\\n    }\\n\\n    @JSONType\\n    public static class ResourceScannedWithParserConfigLoader {\\n    }\\n}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n{\"type\":\"item.completed\",\"item\":{\"id\":\"item_147\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'export GRAALVM_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home JAVA_HOME=/home/vjovanov/c/graalvm-reachability-metadata/vj/forge/ce/sdk/latest_graalvm_home PATH=$JAVA_HOME/bin:$PATH; javap -classpath tests/src/com.alibaba/fastjson/1.2.83/build/jacoco/effective/fastjson_1_2_83_jar -p -c com.alibaba.fastjson.parser.ParserConfig | sed -n '\\\"'3690,3925p'\\\"\",\"aggregated_output\":\"       929: athrow\\n       930: aload         10\\n       932: areturn\\n       933: iload         7\\n       935: ifne          1135\\n       938: lload         13\\n       940: lstore        18\\n       942: iconst_3\\n       943: istore        20\\n       945: iload         20\\n       947: aload         9\\n       949: invokevirtual #478                // Method java/lang/String.length:()I\\n       952: if_icmpge     1135\\n       955: aload         9\\n       957: iload         20\\n       959: invokevirtual #678                // Method java/lang/String.charAt:(I)C\\n       962: istore        21\\n       964: lload         18\\n       966: iload         21\\n       968: i2l\\n       969: lxor\\n       970: lstore        18\\n       972: lload         18\\n       974: ldc2_w        #720                // long 1099511628211l\\n       977: lmul\\n       978: lstore        18\\n       980: aload_0\\n       981: getfield      #368                // Field denyHashCodes:[J\\n       984: lload         18\\n       9