n    void enumMixinJsonFieldMethodIsResolvedOnTargetEnum() {\n        SerializeConfig config = serializeConfig();\n        JSON.addMixInAnnotations(MixedEnum.class, MixedEnumMixin.class);\n\n        ObjectSerializer writer = config.getObjectWriter(MixedEnum.class);\n\n        assertThat(writer).isNotNull();\n        assertThat(JSON.toJSONString(MixedEnum.SECOND, config)).isEqualTo(\"\\\"two\\\"\");\n    }\n\n    @Test\n    void enumJsonFieldMemberIsDiscoveredFromPublicMethodsAndFields() {\n        SerializeConfig config = serializeConfig();\n\n        assertThat(JSON.toJSONString(MethodAnnotatedEnum.FIRST, config)).isEqualTo(\"\\\"method-one\\\"\");\n        assertThat(JSON.toJSONString(FieldAnnotatedEnum.FIRST, config)).isEqualTo(\"\\\"field-one\\\"\");\n    }\n\n    @Test\n    void customSerializerDeclaredOnJsonTypeIsInstantiated() {\n        CountingObjectSerializer.instances = 0;\n        SerializeConfig config = serializeConfig();\n\n        ObjectSerializer writer = config.getObjectWriter(CustomSerializedBean.class);\n\n        assertThat(writer).isInstanceOf(CountingObjectSerializer.class);\n        assertThat(CountingObjectSerializer.instances).isEqualTo(1);\n    }\n\n    private static SerializeConfig serializeConfig() {\n        SerializeConfig config = new SerializeConfig();\n        config.setAsmEnable(false);\n        return config;\n    }\n\n    public enum MixedEnum {\n        FIRST(\"one\"),\n        SECOND(\"two\");\n\n        private final String code;\n\n        MixedEnum(String code) {\n            this.code = code;\n        }\n\n        public String getCode() {\n            return code;\n        }\n    }\n\n    public abstract static class MixedEnumMixin {\n        @JSONField\n        public abstract String getCode();\n    }\n\n    public enum MethodAnnotatedEnum {\n        FIRST(\"method-one\");\n\n        private final String code;\n\n        MethodAnnotatedEnum(String code) {\n            this.code = code;\n        }\n\n        @JSONField\n        public String code() {\n            return code;\n        }\n    }\n\n    public enum FieldAnnotatedEnum {\n        FIRST(\"field-one\");\n\n        @JSONField\n        public final String code;\n\n        FieldAnnotatedEnum(String code) {\n            this.code = code;\n        }\n    }\n\n    @JSONType(serializer = CountingObjectSerializer.class)\n    public static class CustomSerializedBean {\n        public String name;\n    }\n\n    public static class CountingObjectSerializer implements ObjectSerializer {\n        static int instances;\n\n        public CountingObjectSerializer() {\n            instances++;\n        }\n\n        @Override\n        public void write(JSONSerializer serializer, Object object, Object fieldName, Type fieldType, int features)\n                throws IOException {\n            serializer.write(\"custom\");\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
