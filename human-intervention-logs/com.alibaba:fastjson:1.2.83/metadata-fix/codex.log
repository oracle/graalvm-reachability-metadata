{"type":"item.completed","item":{"id":"item_104","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' /home/vjovanov/c/forge/forge1/graalvm-reachability-metadata/forge/local_repositories/forge_worktrees/2621-2dab8413/tests/src/com.alibaba/fastjson/1.2.83/src/test/java/com_alibaba/fastjson/JSONObjectInnerSecureObjectInputStreamTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_alibaba.fastjson;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.lang.reflect.InvocationHandler;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Proxy;\n\nimport com.alibaba.fastjson.JSONObject;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JSONObjectInnerSecureObjectInputStreamTest {\n    @Test\n    void deserializesJSONObjectWithSecureObjectInputStreamClassAndProxyResolution() throws Exception {\n        JSONObject source = new JSONObject(true);\n        source.put(\"payload\", new Payload(\"secure-stream\"));\n        source.put(\"proxy\", serializableCloneableProxy());\n\n        JSONObject deserialized = deserializeJSONObject(serialize(source));\n\n        assertThat(deserialized.getObject(\"payload\", Payload.class).value).isEqualTo(\"secure-stream\");\n        assertThat(deserialized.get(\"proxy\")).isInstanceOf(Cloneable.class);\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JSONObject deserializeJSONObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (JSONObject) input.readObject();\n        }\n    }\n\n    private static Cloneable serializableCloneableProxy() {\n        ClassLoader classLoader = JSONObjectInnerSecureObjectInputStreamTest.class.getClassLoader();\n        Class<?>[] interfaces = {Cloneable.class};\n        return (Cloneable) Proxy.newProxyInstance(classLoader, interfaces, new SerializableInvocationHandler());\n    }\n\n    private static final class SerializableInvocationHandler implements InvocationHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) {\n            String methodName = method.getName();\n            if (\"toString\".equals(methodName)) {\n                return \"serializable-cloneable-proxy\";\n            }\n            if (\"hashCode\".equals(methodName)) {\n                return System.identityHashCode(proxy);\n            }\n            if (\"equals\".equals(methodName)) {\n                return proxy == args[0];\n            }\n            return null;\n        }\n    }\n\n    public static final class Payload implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        public String value;\n\n        public Payload() {\n        }\n\n        Payload(String value) {\n            this.value = value;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
