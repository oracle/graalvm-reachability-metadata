lues() throws Exception {\n        ParserConfig config = parserConfig();\n\n        PrimitiveFieldBean primitiveBean = createFromMap(config, PrimitiveFieldBean.class, primitiveValues());\n        assertThat(primitiveBean.falseValue).isFalse();\n        assertThat(primitiveBean.trueValue).isTrue();\n        assertThat(primitiveBean.intValue).isEqualTo(12);\n        assertThat(primitiveBean.longValue).isEqualTo(34L);\n        assertThat(primitiveBean.floatNumber).isEqualTo(1.25F);\n        assertThat(primitiveBean.floatString).isEqualTo(2.5F);\n        assertThat(primitiveBean.doubleNumber).isEqualTo(3.5D);\n        assertThat(primitiveBean.doubleString).isEqualTo(4.75D);\n        assertThat(primitiveBean.label).isEqualTo(\"direct\");\n\n        BuilderProduct builderProduct = createFromMap(config, BuilderProduct.class, singletonMap(\"name\", \"fromMap\"));\n        assertThat(builderProduct.name).isEqualTo(\"fromMap\");\n\n        CreatorConstructorBean creatorBean = createFromMap(config, CreatorConstructorBean.class,\n                mapOf(\"id\", 23, \"name\", \"created\"));\n        assertThat(creatorBean.id).isEqualTo(23);\n        assertThat(creatorBean.name).isEqualTo(\"created\");\n\n        KotlinStyleBeanWithDefault kotlinBean = createFromMap(config, KotlinStyleBeanWithDefault.class,\n                new HashMap<String, Object>());\n        assertThat(kotlinBean.name).isNull();\n\n        FactoryValueBean factoryBean = createFromMap(config, FactoryValueBean.class,\n                singletonMap(\"value\", \"factoryMap\"));\n        assertThat(factoryBean.value).isEqualTo(\"factoryMap\");\n    }\n\n    private static ParserConfig parserConfig() {\n        ParserConfig config = new ParserConfig();\n        config.setAsmEnable(false);\n        return config;\n    }\n\n    private static <T> T createFromMap(ParserConfig config, Class<T> type, Map<String, Object> values)\n            throws Exception {\n        ObjectDeserializer objectDeserializer = config.getDeserializer(type);\n        JavaBeanDeserializer deserializer = (JavaBeanDeserializer) objectDeserializer;\n        return type.cast(deserializer.createInstance(values, config));\n    }\n\n    private static <T> T deserializeDirectly(ParserConfig config, Class<T> type, String json) {\n        DefaultJSONParser parser = new DefaultJSONParser(json, config);\n        try {\n            ObjectDeserializer objectDeserializer = config.getDeserializer(type);\n            return type.cast(objectDeserializer.deserialze(parser, type, null));\n        } finally {\n            parser.close();\n        }\n    }\n\n    private static Map<String, Object> primitiveValues() {\n        Map<String, Object> values = new HashMap<String, Object>();\n        values.put(\"falseValue\", Boolean.FALSE);\n        values.put(\"trueValue\", Boolean.TRUE);\n        values.put(\"intValue\", 12);\n        values.put(\"longValue\", 34L);\n        values.put(\"floatNumber\", 1.25D);\n        values.put(\"floatString\", \"2.5\");\n        values.put(\"doubleNumber\", 3.5F);\n        values.put(\"doubleString\", \"4.75\");\n        values.put(\"label\", \"direct\");\n        return values;\n    }\n\n    private static Map<String, Object> singletonMap(String key, Object value) {\n        Map<String, Object> values = new HashMap<String, Object>();\n        values.put(key, value);\n\n[159 more lines in file. Use offset=180 to continue.]"}], "isError": false, "timestamp": 1778489310288}}
