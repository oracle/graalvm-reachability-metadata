eUtilsTest.class.getClassLoader()))\n                .isEqualTo(TypeUtilsTest.class);\n\n        ClassLoader originalContextLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(TypeUtilsTest.class.getClassLoader());\n            assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), null))\n                    .isEqualTo(TypeUtilsTest.class);\n\n            Thread.currentThread().setContextClassLoader(new ClassLoader(null) {\n                @Override\n                public Class<?> loadClass(String name) throws ClassNotFoundException {\n                    throw new ClassNotFoundException(name);\n                }\n            });\n            assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), null)).isEqualTo(TypeUtilsTest.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextLoader);\n        }\n    }\n\n    @Test\n    void checkPrimitiveArrayResolvesGenericPrimitiveArrayType() {\n        GenericArrayType primitiveArrayType = () -> int.class;\n\n        Type resolvedType = TypeUtils.checkPrimitiveArray(primitiveArrayType);\n\n        assertThat(resolvedType).isEqualTo(int[].class);\n    }\n\n    @Test\n    void optionalEmptyLoadsAndInvokesOptionalEmptyFactory() {\n        Object optional = TypeUtils.optionalEmpty(Optional.class);\n\n        assertThat(optional).isEqualTo(Optional.empty());\n    }\n\n    @Test\n    void xmlAccessorTypeDetectionLoadsJaxbAnnotationApi() {\n        assertThat(TypeUtils.isXmlField(XmlFieldBean.class)).isTrue();\n    }\n\n    @Test\n    void oracleStyleDateObjectsUseToJdbcConversionMethods() {\n        assertThat(TypeUtils.castToDate(new TIMESTAMP(new Date(1_234L))))\n                .isEqualTo(new Date(1_234L));\n        assertThat(TypeUtils.castToDate(new DATE(new Date(5_678L))))\n                .isEqualTo(new Date(5_678L));\n    }\n\n    @Test\n    void hibernateInitializationCheckInvokesHi