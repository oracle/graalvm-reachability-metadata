CreatorConstructorsFactoryMethodsAndBuildMethods() {\n        ParserConfig config = parserConfig();\n\n        CreatorConstructorBean creatorBean = JSON.parseObject(\"{\\\"id\\\":7,\\\"name\\\":\\\"ctor\\\"}\",\n                CreatorConstructorBean.class, config);\n        assertThat(creatorBean.id).isEqualTo(7);\n        assertThat(creatorBean.name).isEqualTo(\"ctor\");\n\n        FactoryValueBean factoryBean = JSON.parseObject(\"{\\\"value\\\":\\\"object\\\"}\", FactoryValueBean.class, config);", "newText": "    void parserUsesCreatorConstructorsKotlinDefaultConstructorsFactoryMethodsAndBuildMethods() {\n        ParserConfig config = parserConfig();\n\n        CreatorConstructorBean creatorBean = JSON.parseObject(\"{\\\"id\\\":7,\\\"name\\\":\\\"ctor\\\"}\",\n                CreatorConstructorBean.class, config);\n        assertThat(creatorBean.id).isEqualTo(7);\n        assertThat(creatorBean.name).isEqualTo(\"ctor\");\n\n        KotlinStyleBeanWithDefault kotlinBean = JSON.parseObject(\"{\\\"name\\\":null}\",\n                KotlinStyleBeanWithDefault.class, config);\n        assertThat(kotlinBean.name).isNull();\n\n        FactoryValueBean factoryBean = JSON.parseObject(\"{\\\"value\\\":\\\"object\\\"}\", FactoryValueBean.class, config);"}, {"oldText": "        PrimitiveFieldBean primitiveBean = createFromMap(config, PrimitiveFieldBean.class, primitiveValues());", "newText": "        PrimitiveFieldBean primitiveBean = createPrimitiveFromSyntheticInfo(config, primitiveValues());"}, {"oldText": "    private static <T> T createFromMap(ParserConfig config, Class<T> type, Map<String, Object> values)\n            throws Exception {\n        ObjectDeserializer objectDeserializer = config.getDeserializer(type);\n        JavaBeanDeserializer deserializer = (JavaBeanDeserializer) objectDeserializer;\n        return type.cast(deserializer.createInstance(values, config));\n    }\n\n    private static <T> T deserializeDirectly(ParserConfig config, Class<T> type, String json) {", "newText": "    private static <T> T createFromMap(ParserConfig config, Class<T> type, Map<String, Object> values)\n            throws Exception {\n        ObjectDeserializer objectDeserializer = config.getDeserializer(type);\n        JavaBeanDeserializer deserializer = (JavaBeanDeserializer) objectDeserializer;\n        return type.cast(deserializer.createInstance(values, config));\n    }\n\n    private static PrimitiveFieldBean createPrimitiveFromSyntheticInfo(ParserConfig config, Map<String, Object> values)\n            throws Exception {\n        JavaBeanDeserializer deserializer = syntheticPrimitiveDeserializer(config);\n        return (PrimitiveFieldBean) deserializer.createInstance(values, config);\n    }\n\n    private static JavaBeanDeserializer syntheticPrimitiveDeserializer(ParserConfig config) throws Exception {\n        List<FieldInfo> fields = new ArrayList<FieldInfo>();\n        String[] fieldNames = {\n            \"falseValue\", \"trueValue\", \"intValue\", \"longValue\", \"floatNumber\",\n            \"floatString\", \"doubleNumber\", \"doubleString\", \"label\"\n        };\n        for (String fieldName : fieldNames) {\n            Field field = PrimitiveFieldBean.class.getField(fieldName);\n            fields.add(new FieldInfo(fieldName, null, field.getType(), field.getGenericType(), field, 0, 0, 0));\n        }\n        Constructor<PrimitiveFieldBean> constructor = PrimitiveFieldBean.class.getConstructor();\n        JavaBeanInfo beanInfo = new JavaBeanInfo(PrimitiveFieldBean.class, null, constructor, null, null, null, null,\n                fields);\n        return new JavaBeanDeserializer(config, beanInfo);\n    }\n\n    private static <T> T deserializeDirectly(ParserConfig config, Class<T> type, String json) {"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3414, "output": 1872, "cacheRead": 53248, "cacheWrite": 0, "totalTokens": 58534, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cach