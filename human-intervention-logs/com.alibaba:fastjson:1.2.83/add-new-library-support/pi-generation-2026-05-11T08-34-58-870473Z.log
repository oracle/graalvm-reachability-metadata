alibaba.fastjson;\n\nimport java.lang.annotation.Annotation;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.Field;\nimport java.lang.reflect.GenericArrayType;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Type;\nimport java.util.AbstractSet;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.Collection;\nimport java.util.Collections;\nimport java.util.Date;\nimport java.util.GregorianCalendar;\nimport java.util.HashMap;\nimport java.util.Iterator;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Optional;\nimport java.util.Set;\nimport javax.xml.bind.annotation.XmlAccessType;\nimport javax.xml.bind.annotation.XmlAccessorType;\n\nimport com.alibaba.fastjson.JSON;\nimport com.alibaba.fastjson.annotation.JSONField;\nimport com.alibaba.fastjson.parser.ParserConfig;\nimport com.alibaba.fastjson.util.FieldInfo;\nimport com.alibaba.fastjson.util.TypeUtils;\nimport org.junit.jupiter.api.AfterEach;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypeUtilsTest {\n    @AfterEach\n    void clearMixIns() {\n        JSON.clearMixInAnnotations();\n    }\n\n    @Test\n    void loadClassCoversArrayExplicitLoaderContextLoaderAndForNameFallback() {\n        assertThat(TypeUtils.loadClass(\"[java.lang.Long\", null)).isEqualTo(Long[].class);\n        assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), TypeUtilsTest.class.getClassLoader()))\n                .isEqualTo(TypeUtilsTest.class);\n\n        ClassLoader originalContextLoader = Thread.currentThread().getContextClassLoader();\n        try {\n            Thread.currentThread().setContextClassLoader(TypeUtilsTest.class.getClassLoader());\n            assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), null))\n                    .isEqualTo(TypeUtilsTest.class);\n\n            Thread.currentThread().setContextClassLoader(new ClassLoader(null) {\n                @Override\n                public Class<?> loadClass(String name) throws ClassNotFoundException {\n                    throw new ClassNotFoundException(name);\n                }\n            });\n            assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), null)).isEqualTo(TypeUtilsTest.class);\n        } finally {\n            Thread.currentThread().setContextClassLoader(originalContextLoader);\n        }\n    }\n\n    @Test\n    void checkPrimitiveArrayResolvesGenericPrimitiveArrayType() {\n        GenericArrayType primitiveArrayType = () -> int.class;\n\n        Type resolvedType = TypeUtils.checkPrimitiveArray(primitiveArrayType);\n\n        assertThat(resolvedType).isEqualTo(int[].class);\n    }\n\n    @Test\n    void optionalEmptyLoadsAndInvokesOptionalEmptyFactory() {\n        Object optional = TypeUtils.optionalEmpty(Optional.class);\n\n        assertThat(optional).isEqualTo(Optional.empty());\n    }\n\n    @Test\n    void xmlAccessorTypeDetectionLoadsJaxbAnnotationApi() {\n        assertThat(TypeUtils.isXmlField(XmlFieldBean.class)).isTrue();\n    }\n\n    @Test\n    void computeGettersCoversMethodFieldAndSuperclassScanning() {\n        List<FieldInfo> beanFields = TypeUtils.computeGetters(GetterBean.class, null);\n        assertThat(fieldNames(beanFields)).contains(\"name\", \"publicValue\");\n\n        List<FieldInfo> interfaceFields = TypeUtils.computeGetters(InterfaceGetterBean.class, null);\n        assertThat(fieldNames(interfaceFields)).contains(\"interfaceName\");\n\n        List<FieldInfo> superclassFields = TypeUtils.computeGetters(ConcreteGetterBean.class, null);\n        assertThat(fieldNames(superclassFields)).contains(\"abstractName\");\n    }\n\n    @Test\n    void computeGettersWithFieldBaseScansDeclaredFields() {\n        List<FieldInfo> fields = TypeUtils.computeGettersWithFieldBase(\n                FieldBasedBean.class,\n                null,\n                true,\n                null);\n\n        assertThat(fieldNames(fields)).contains(\"count\", \"name\");\n    }\n\n    @Test\n    void getFieldSearchesSuperclassDeclaredFields() {\n        Field field = TypeUtils.getField(\n                ChildFieldBean.class,\n                \"parentValue\",\n                ChildFieldBean.class.getDeclaredFields());\n\n        assertThat(field).isNotNull();\n        assertThat(field.getDeclaringClass()).isEqualTo(ParentFieldBean.class);\n    }\n\n    @Test\n    void fieldAndMethodAnnotationLookupUsesMixinMembers() throws Exception {\n        JSON.addMixInAnnotations(FieldAnnotationTarget.class, FieldAnnotationMixin.class);\n        Field field = FieldAnnotationTarget.class.getField(\"value\");\n        JSONField fieldAnnotation = TypeUtils.getAnnotation(field, JSONField.class);\n        assertThat(fieldAnnotation.name()).isEqualTo(\"fieldFromMixin\");\n\n        JSON.addMixInAnnotations(MethodAnnotationTarget.class, MethodAnnotationMixin.class);\n        Method method = MethodAnnotationTarget.class.getMethod(\"rename\", String.class);\n        JSONField methodAnnotation = TypeUtils.getAnnotation(method, JSONField.class);\n        assertThat(methodAnnotation.name()).isEqualTo(\"methodFromMixin\");\n    }\n\n    @Test\n    void methodParameterAnnotationsUseMixinMethod() throws Exception {\n        JSON.addMixInAnnotations(MethodParameterTarget.class, MethodParameterMixin.class);\n        Method method = MethodParameterTarget.class.getMethod(\"rename\", String.class);\n\n        Annotation[][] annotations = TypeUtils.getParameterAnnotations(method);\n\n        assertThat(annotations[0]).hasAtLeastOneElementOfType(JSONField.class);\n    }\n\n    @Test\n    void constructorParameterAnnotationsUseTopLevelAndInnerMixinConstructors() throws Exception {\n        JSON.addMixInAnnotations(ConstructorParameterTarget.class, ConstructorParameterMixin.class);\n        Constructor<ConstructorParameterTarget> constructor =\n                ConstructorParameterTarget.class.getDeclaredConstructor(String.class);\n        Annotation[][] annotations = TypeUtils.getParameterAnnotations(constructor);\n        assertThat(annotations.length).isEqualTo(1);\n\n        JSON.addMixInAnnotations(\n                InnerConstructorParameterTarget.class,\n                EnclosingMixin.InnerConstructorParameterMixin.class);\n        Constructor<InnerConstructorParameterTarget> innerConstructor =\n                InnerConstructorParameterTarget.class.getDeclaredConstructor(String.class);\n        Annotation[][] innerAnnotations = TypeUtils.getParameterAnnotations(innerConstructor);\n        assertThat(innerAnnotations.length).isEqualTo(1);\n    }\n\n    @Test\n    void collectionFactoriesInstantiateCustomCollectionTypes() {\n        Set<?> set = TypeUtils.createSet(CustomSet.class);\n        Collection<?> collection = TypeUtils.createCollection(CustomList.class);\n\n        assertThat(set).isInstanceOf(CustomSet.class);\n        assertThat(collection).isInstanceOf(CustomList.class);\n    }\n\n    @Test\n    void castCreatesArraysCalendarsAndInterfaceProxies() {\n        String[] values = TypeUtils.cast(Arrays.asList(\"alpha\", \"beta\"), String[].class, ParserConfig.global);\n        assertThat(values).containsExactly(\"alpha\", \"beta\");\n\n        CustomCalendar calendar = TypeUtils.cast(new Date(9_876L), CustomCalendar.class, ParserConfig.global);\n        assertThat(calendar.getTime()).isEqualTo(new Date(9_876L));\n\n        Map<String, Object> valuesByName = new HashMap<String, Object>();\n        valuesByName.put(\"name\", \"fastjson\");\n        BeanView beanView = TypeUtils.castToJavaBean(valuesByName, BeanView.class, ParserConfig.global);\n        assertThat(beanView.getName()).isEqualTo(\"fastjson\");\n    }\n\n    private static List<String> fieldNames(List<FieldInfo> fields) {\n        List<String> names = new ArrayList<String>();\n        for (FieldInfo field : fields) {\n            names.add(field.name);\n        }\n        return names;\n    }\n\n    @XmlAccessorType(XmlAccessType.FIELD)\n    public static class XmlFieldBean {\n        public String value;\n    }\n\n    public static class GetterBean {\n        public String publicValue;\n\n        public String getName() {\n            return \"fastjson\";\n        }\n    }\n\n    public interface InterfaceAnnotatedGetter {\n        @JSONField(name = \"interfaceName\")\n        String getName();\n    }\n\n    public static class InterfaceGetterBean implements InterfaceAnnotatedGetter {\n        @Override\n        public String getName() {\n            return \"interface\";\n        }\n    }\n\n    public abstract static class AbstractAnnotatedGetter {\n        @JSONField(name = \"abstractName\")\n        public abstract String getName();\n    }\n\n    public static class ConcreteGetterBean extends AbstractAnnotatedGetter {\n        @Override\n        public String getName() {\n            return \"abstract\";\n        }\n    }\n\n    public static class FieldBasedBean {\n        public String name;\n        private int count;\n    }\n\n    public static class ParentFieldBean {\n        private String parentValue;\n    }\n\n    public static class ChildFieldBean extends ParentFieldBean {\n        private String childValue;\n    }\n\n    public static class FieldAnnotationTarget {\n        public String value;\n    }\n\n    public static class FieldAnnotationMixin {\n        @JSONField(name = \"fieldFromMixin\")\n        public String value;\n    }\n\n    public static class MethodAnnotationTarget {\n        public void rename(String value) {\n        }\n    }\n\n    public static class MethodAnnotationMixin {\n        @JSONField(name = \"methodFromMixin\")\n        public void rename(String value) {\n        }\n    }\n\n    public static class MethodParameterTarget {\n        public void rename(String value) {\n        }\n    }\n\n    public static class MethodParameterMixin {\n        public void rename(@JSONField(name = \"parameterFromMixin\") String value) {\n        }\n    }\n\n    public static class ConstructorParameterTarget {\n        public ConstructorParameterTarget(String value) {\n        }\n    }\n\n    public static class ConstructorParameterMixin {\n        public ConstructorParameterMixin(@JSONField(name = \"constructorParameterFromMixin\") String value) {\n        }\n    }\n\n    public static class InnerConstructorParameterTarget {\n        public InnerConstructorParameterTarget(String value) {\n        }\n    }\n\n    public static class EnclosingMixin {\n        public class InnerConstructorParameterMixin {\n            public InnerConstructorParameterMixin(\n                    @JSONField(name = \"innerConstructorParameterFromMixin\") String value) {\n            }\n        }\n    }\n\n    public static class CustomSet<E> extends AbstractSet<E> {\n        @Override\n        public Iterator<E> iterator() {\n            return Collections.<E>emptySet().iterator();\n        }\n\n        @Override\n        public int size() {\n            return 0;\n        }\n    }\n\n    public static class CustomList<E> extends ArrayList<E> {\n    }\n\n    public static class CustomCalendar extends GregorianCalendar {\n    }\n\n    public interface BeanView {\n        String getName();\n    }\n\n}\n"}], "isError": false, "timestamp": 1778488654637}]}
