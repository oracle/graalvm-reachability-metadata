  package com_alibaba.fastjson;
  
  import java.util.ArrayList;
  import java.util.HashMap;
  import java.util.List;
  import java.util.Map;
  import java.util.concurrent.atomic.AtomicBoolean;
  import java.util.concurrent.atomic.AtomicInteger;
  import java.util.concurrent.atomic.AtomicLong;
  
  import com.alibaba.fastjson.JSON;
  import com.alibaba.fastjson.annotation.JSONField;
  import com.alibaba.fastjson.parser.ParserConfig;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FieldDeserializerTest {
      @Test
      void getterOnlyAtomicMapAndCollectionPropertiesAreUpdatedThroughGetterMethods() {
          ParserConfig config = parserConfig();
  
          GetterOnlyBean bean = JSON.parseObject(
                  "{\"atomicInteger\":11,\"atomicLong\":12,\"atomicBoolean\":true,"
                          + "\"values\":{\"one\":1},\"names\":[\"alpha\"]}",
                  GetterOnlyBean.class,
                  config);
  
          assertThat(bean.getAtomicInteger().get()).isEqualTo(11);
          assertThat(bean.getAtomicLong().get()).isEqualTo(12L);
          assertThat(bean.getAtomicBoolean().get()).isTrue();
          assertThat(bean.getValues()).containsEntry("one", 1);
          assertThat(bean.getNames()).containsExactly("alpha");
      }
  
      @Test
      void finalAtomicMapAndCollectionFieldsAreUpdatedThroughReadOnlyFieldAccess() {
          ParserConfig config = parserConfig();
  
          FinalFieldBean bean = JSON.parseObject(
                  "{\"atomicInteger\":21,\"atomicLong\":22,\"atomicBoolean\":true,"
                          + "\"values\":{\"two\":2},\"names\":[\"beta\"]}",
                  FinalFieldBean.class,
                  config);
  
          assertThat(bean.atomicInteger.get()).isEqualTo(21);
          assertThat(bean.atomicLong.get()).isEqualTo(22L);
          assertThat(bean.atomicBoolean.get()).isTrue();
          assertThat(bean.values).containsEntry("two", 2);
          assertThat(bean.names).containsExactly("beta");
      }
  
      @Test
      void ordinarySetterAndFieldAssignmentsUseReflectiveWritePaths() {
          ParserConfig config = parserConfig();
  
          WritableBean bean = JSON.parseObject("{\"name\":\" setter \",\"count\":31}", WritableBean.class, config);
  
          assertThat(bean.name).isEqualTo(" setter ");
          assertThat(bean.count).isEqualTo(31);
      }
  
      @Test
      void getterOnlyNullCollectionFallsBackToBackingFieldAssignment() {
          ParserConfig config = parserConfig();
  
          MutableFallbackBean bean = JSON.parseObject("{\"items\":[\"field\"]}", MutableFallbackBean.class, config);
  
          assertThat(bean.storedItems()).containsExactly("field");
      }
  
      @Test
      void getterOnlyNullCollectionFallsBackToDeclaredSetterAssignment() {
          ParserConfig config = parserConfig();
  
          DeclaredSetterFallbackBean bean = JSON.parseObject(
                  "{\"externalItems\":[\"setter\"]}",
                  DeclaredSetterFallbackBean.class,
                  config);
  
          assertThat(bean.storedItems()).containsExactly("setter");
      }
  
      private static ParserConfig parserConfig() {
          ParserConfig config = new ParserConfig();
          config.setAsmEnable(false);
          return config;
      }
  
      public static class GetterOnlyBean {
          private final AtomicInteger atomicInteger = new AtomicInteger();
          private final AtomicLong atomicLong = new AtomicLong();
          private final AtomicBoolean atomicBoolean = new AtomicBoolean();
          private final Map<String, Integer> values = new HashMap<String, Integer>();
          private final List<String> names = new ArrayList<String>();
  
          public AtomicInteger getAtomicInteger() {
              return atomicInteger;
          }
  
          public AtomicLong getAtomicLong() {
              return atomicLong;
          }
  
          public AtomicBoolean getAtomicBoolean() {
              return atomicBoolean;
          }
  
          public Map<String, Integer> getValues() {
              return values;
          }
  
          public List<String> getNames() {
              return names;
          }
      }
  
      public static class FinalFieldBean {
          public final AtomicInteger atomicInteger = new AtomicInteger();
          public final AtomicLong atomicLong = new AtomicLong();
          public final AtomicBoolean atomicBoolean = new AtomicBoolean();
          public final Map<String, Integer> values = new HashMap<String, Integer>();
          public final List<String> names = new ArrayList<String>();
      }
  
      public static class WritableBean {
          private String name;
          public int count;
  
          public void setName(String name) {
              this.name = name;
          }
      }
  
      public static class MutableFallbackBean {
          private List<String> items;
  
          public List<String> getItems() {
              return null;
          }
  
          public List<String> storedItems() {
              return items;
          }
      }
  
      public static class DeclaredSetterFallbackBean {
          private List<String> items;
  
          @JSONField(name = "externalItems", deserialize = false)
          public List<String> getItemsForDeclaredSetter() {
              return null;
          }
  
          public void setItemsForDeclaredSetter(List<String> items) {
              this.items = items;
          }
  
          public List<String> storedItems() {
              return items;
          }
      }
  }
