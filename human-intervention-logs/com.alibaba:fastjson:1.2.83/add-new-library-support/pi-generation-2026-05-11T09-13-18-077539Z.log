  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.lang.reflect.GenericArrayType;
  import java.lang.reflect.Method;
  import java.lang.reflect.Type;
  import java.util.AbstractSet;
  import java.util.ArrayList;
  import java.util.Arrays;
  import java.util.Collection;
  import java.util.Collections;
  import java.util.Date;
  import java.util.GregorianCalendar;
  import java.util.HashMap;
  import java.util.Iterator;
  import java.util.List;
  import java.util.Map;
  import java.util.Optional;
  import java.util.Set;
  import javax.xml.bind.annotation.XmlAccessType;
  import javax.xml.bind.annotation.XmlAccessorType;
  
  import com.alibaba.fastjson.JSON;
  import com.alibaba.fastjson.annotation.JSONField;
  import com.alibaba.fastjson.parser.ParserConfig;
  import com.alibaba.fastjson.util.FieldInfo;
  import com.alibaba.fastjson.util.TypeUtils;
  import kotlin.Metadata;
  import oracle.sql.DATE;
  import oracle.sql.TIMESTAMP;
  import org.hibernate.Hibernate;
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypeUtilsTest {
      @AfterEach
      void clearMixIns() {
          JSON.clearMixInAnnotations();
      }
  
      @Test
      void loadClassCoversArrayExplicitLoaderContextLoaderAndForNameFallback() {
          assertThat(TypeUtils.loadClass("[java.lang.Long", null)).isEqualTo(Long[].class);
          assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), TypeUtilsTest.class.getClassLoader()))
                  .isEqualTo(TypeUtilsTest.class);
  
          ClassLoader originalContextLoader = Thread.currentThread().getContextClassLoader();
          try {
              Thread.currentThread().setContextClassLoader(TypeUtilsTest.class.getClassLoader());
              assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), null))
                      .isEqualTo(TypeUtilsTest.class);
  
              Thread.currentThread().setContextClassLoader(new ClassLoader(null) {
                  @Override
                  public Class<?> loadClass(String name) throws ClassNotFoundException {
                      throw new ClassNotFoundException(name);
                  }
              });
              assertThat(TypeUtils.loadClass(TypeUtilsTest.class.getName(), null)).isEqualTo(TypeUtilsTest.class);
          } finally {
              Thread.currentThread().setContextClassLoader(originalContextLoader);
          }
      }
  
      @Test
      void checkPrimitiveArrayResolvesGenericPrimitiveArrayType() {
          GenericArrayType primitiveArrayType = () -> int.class;
  
          Type resolvedType = TypeUtils.checkPrimitiveArray(primitiveArrayType);
  
          assertThat(resolvedType).isEqualTo(int[].class);
      }
  
      @Test
      void optionalEmptyLoadsAndInvokesOptionalEmptyFactory() {
          Object optional = TypeUtils.optionalEmpty(Optional.class);
  
          assertThat(optional).isEqualTo(Optional.empty());
      }
  
      @Test
      void xmlAccessorTypeDetectionLoadsJaxbAnnotationApi() {
          assertThat(TypeUtils.isXmlField(XmlFieldBean.class)).isTrue();
      }
  
      @Test
      void oracleStyleDateObjectsUseToJdbcConversionMethods() {
          assertThat(TypeUtils.castToDate(new TIMESTAMP(new Date(1_234L))))
                  .isEqualTo(new Date(1_234L));
          assertThat(TypeUtils.castToDate(new DATE(new Date(5_678L))))
                  .isEqualTo(new Date(5_678L));
      }
  
      @Test
      void hibernateInitializationCheckInvokesHibernateHelperWhenPresent() {
          assertThat(TypeUtils.isHibernateInitialized(new Object())).isFalse();
          assertThat(TypeUtils.isHibernateInitialized(new InitializedEntity())).isTrue();
      }
  
      @Test
      void computeGettersCoversMethodFieldAndSuperclassScanning() {
          List<FieldInfo> beanFields = TypeUtils.computeGetters(GetterBean.class, null);
          assertThat(fieldNames(beanFields)).contains("name", "publicValue");
  
          List<FieldInfo> interfaceFields = TypeUtils.computeGetters(InterfaceGetterBean.class, null);
          assertThat(fieldNames(interfaceFields)).contains("interfaceName");
  
          List<FieldInfo> superclassFields = TypeUtils.computeGetters(ConcreteGetterBean.class, null);
          assertThat(fieldNames(superclassFields)).contains("abstractName");
      }
  
      @Test
      void computeGettersForKotlinStyleBeanUsesKotlinConstructorMetadata() {
          List<FieldInfo> fields = TypeUtils.computeGetters(KotlinStyleBean.class, null);
  
          assertThat(fieldNames(fields)).contains("name");
      }
  
      @Test
      void computeGettersWithFieldBaseScansDeclaredFields() {
          List<FieldInfo> fields = TypeUtils.computeGettersWithFieldBase(
                  FieldBasedBean.class,
                  null,
                  true,
                  null);
  
          assertThat(fieldNames(fields)).contains("count", "name");
      }
  
      @Test
      void getFieldSearchesSuperclassDeclaredFields() {
          Field field = TypeUtils.getField(
                  ChildFieldBean.class,
                  "parentValue",
                  ChildFieldBean.class.getDeclaredFields());
  
          assertThat(field).isNotNull();
          assertThat(field.getDeclaringClass()).isEqualTo(ParentFieldBean.class);
      }
  
      @Test
      void fieldAndMethodAnnotationLookupUsesMixinMembers() throws Exception {
          JSON.addMixInAnnotations(FieldAnnotationTarget.class, FieldAnnotationMixin.class);
          Field field = FieldAnnotationTarget.class.getField("value");
          JSONField fieldAnnotation = TypeUtils.getAnnotation(field, JSONField.class);
          assertThat(fieldAnnotation.name()).isEqualTo("fieldFromMixin");
  
          JSON.addMixInAnnotations(MethodAnnotationTarget.class, MethodAnnotationMixin.class);
          Method method = MethodAnnotationTarget.class.getMethod("rename", String.class);
          JSONField methodAnnotation = TypeUtils.getAnnotation(method, JSONField.class);
          assertThat(methodAnnotation.name()).isEqualTo("methodFromMixin");
      }
  
      @Test
      void methodParameterAnnotationsUseMixinMethod() throws Exception {
          JSON.addMixInAnnotations(MethodParameterTarget.class, MethodParameterMixin.class);
          Method method = MethodParameterTarget.class.getMethod("rename", String.class);
  
          Annotation[][] annotations = TypeUtils.getParameterAnnotations(method);
  
          assertThat(annotations[0]).hasAtLeastOneElementOfType(JSONField.class);
      }
  
      @Test
      void constructorParameterAnnotationsUseTopLevelAndInnerMixinConstructors() throws Exception {
          JSON.addMixInAnnotations(ConstructorParameterTopLevelTarget.class, ConstructorParameterTopLevelMixin.class);
          Constructor<ConstructorParameterTopLevelTarget> constructor =
                  ConstructorParameterTopLevelTarget.class.getDeclaredConstructor(String.class);
          Annotation[][] annotations = TypeUtils.getParameterAnnotations(constructor);
          assertThat(hasJsonFieldAnnotation(annotations)).isTrue();
  
          JSON.addMixInAnnotations(
                  InnerConstructorParameterTopLevelTarget.class,
                  TopLevelEnclosingMixin.InnerConstructorParameterMixin.class);
          Constructor<InnerConstructorParameterTopLevelTarget> innerConstructor =
                  InnerConstructorParameterTopLevelTarget.class.getDeclaredConstructor(String.class);
          Annotation[][] innerAnnotations = TypeUtils.getParameterAnnotations(innerConstructor);
          assertThat(hasJsonFieldAnnotation(innerAnnotations)).isTrue();
      }
  
      @Test
      void collectionFactoriesInstantiateCustomCollectionTypes() {
          Set<?> set = TypeUtils.createSet(CustomSet.class);
          Collection<?> collection = TypeUtils.createCollection(CustomList.class);
  
          assertThat(set).isInstanceOf(CustomSet.class);
          assertThat(collection).isInstanceOf(CustomList.class);
      }
  
      @Test
      void castCreatesArraysCalendarsAndInterfaceProxies() {
          String[] values = TypeUtils.cast(Arrays.asList("alpha", "beta"), String[].class, ParserConfig.global);
          assertThat(values).containsExactly("alpha", "beta");
  
          CustomCalendar calendar = TypeUtils.cast(new Date(9_876L), CustomCalendar.class, ParserConfig.global);
          assertThat(calendar.getTime()).isEqualTo(new Date(9_876L));
  
          Map<String, Object> valuesByName = new HashMap<String, Object>();
          valuesByName.put("name", "fastjson");
          BeanView beanView = TypeUtils.castToJavaBean(valuesByName, BeanView.class, ParserConfig.global);
          assertThat(beanView.getName()).isEqualTo("fastjson");
      }
  
      private static List<String> fieldNames(List<FieldInfo> fields) {
          List<String> names = new ArrayList<String>();
          for (FieldInfo field : fields) {
              names.add(field.name);
          }
          return names;
      }
  
      private static boolean hasJsonFieldAnnotation(Annotation[][] parameterAnnotations) {
          for (Annotation[] annotations : parameterAnnotations) {
              for (Annotation annotation : annotations) {
                  if (annotation instanceof JSONField) {
                      return true;
                  }
              }
          }
          return false;
      }
  
      @XmlAccessorType(XmlAccessType.FIELD)
      public static class XmlFieldBean {
          public String value;
      }
  
      public static class GetterBean {
          public String publicValue;
  
          public String getName() {
              return "fastjson";
          }
      }
  
      public interface InterfaceAnnotatedGetter {
          @JSONField(name = "interfaceName")
          String getName();
      }
  
      public static class InterfaceGetterBean implements InterfaceAnnotatedGetter {
          @Override
          public String getName() {
              return "interface";
          }
      }
  
      public abstract static class AbstractAnnotatedGetter {
          @JSONField(name = "abstractName")
          public abstract String getName();
  
