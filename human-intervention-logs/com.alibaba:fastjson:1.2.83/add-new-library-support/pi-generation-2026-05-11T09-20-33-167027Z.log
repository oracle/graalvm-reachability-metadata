  package com_alibaba.fastjson;
  
  import com.alibaba.fastjson.JSON;
  import com.alibaba.fastjson.JSONObject;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnnotationSerializerTest {
      @Test
      void serializesAnnotationMembersThroughFastjson() {
          SampleAnnotation annotation = AnnotatedType.class.getAnnotation(SampleAnnotation.class);
  
          String json = JSON.toJSONString(annotation);
          JSONObject object = JSON.parseObject(json);
  
          assertThat(object.getString("name")).isEqualTo("fastjson");
          assertThat(object.getIntValue("priority")).isEqualTo(83);
          assertThat(object.getBooleanValue("enabled")).isTrue();
      }
  
      @SampleAnnotation(name = "fastjson", priority = 83)
      private static class AnnotatedType {
      }
  
      private @interface SampleAnnotation {
          String name();
  
          int priority() default 1;
  
          boolean enabled() default true;
      }
  }
