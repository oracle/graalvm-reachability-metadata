nOrEqualTo(1);\n    }\n\n    @Test\n    void parserCreatesInterfaceProxyDefaultConstructedBeansFactoryBeansAndInnerBeans() {\n        ParserConfig config = parserConfig();\n\n        BeanView view = JSON.parseObject(\"{\\\"name\\\":\\\"proxy\\\"}\", BeanView.class, config);\n        assertThat(view).isNotNull();\n\n        DefaultConstructedBean defaultConstructed = JSON.parseObject(\"{\\\"name\\\":\\\"default\\\"}\",\n                DefaultConstructedBean.class, config);\n        assertThat(defaultConstructed.name).isEqualTo(\"default\");\n\n        FactoryNoArgBean factoryBean = JSON.parseObject(\"{}\", FactoryNoArgBean.class, config);\n        assertThat(factoryBean.name).isEqualTo(\"factory\");\n\n        OuterBean outer = JSON.parseObject(\"{\\\"child\\\":{\\\"value\\\":\\\"inner\\\"}}\", OuterBean.class, config);\n        assertThat(outer.child.value).isEqualTo(\"inner\");\n    }\n\n    @Test\n    void parserUsesCreatorConstructorsKotlinDefaultConstructorsFactoryMethodsAndBuildMethods() {\n        ParserConfig config = parserConfig();\n\n        CreatorConstructorBean creatorBean = JSON.parseObject(\"{\\\"id\\\":7,\\\"name\\\":\\\"ctor\\\"}\",\n                CreatorConstructorBean.class, config);\n        assertThat(creatorBean.id).isEqualTo(7);\n        assertThat(creatorBean.name).isEqualTo(\"ctor\");\n\n        KotlinStyleBeanWithDefault kotlinBean = JSON.parseObject(\"{\\\"name\\\":null}\",\n                KotlinStyleBeanWithDefault.class, config);\n        assertThat(kotlinBean.name).isNull();\n\n        FactoryValueBean factoryBean = JSON.parseObject(\"{\\\"value\\\":\\\"object\\\"}\", FactoryValueBean.class, config);\n        assertThat(factoryBean.value).isEqualTo(\"object\");\n\n        BuilderProduct product = JSON.parseObject(\"{\\\"name\\\":\\\"built\\\"}\", BuilderProduct.class, config);\n        assertThat(product.name).isEqualTo(\"built\");\n    }\n\n    @Test\n    void scalarInputUsesSingleArgumentFactoryMethod() {\n        ParserConfig config = parserConfig();\n\n        FactoryValueBean factoryBean = deserializeDirectly(config, FactoryValueBean.class, \"\\\"scalar\\\"\");\n\n        assertThat(factoryBean.value).isEqualTo(\"scalar\");\n    }\n\n    @Test\n    void supportNonPublicFieldScansAndAssignsDeclaredFields() {\n        ParserConfig config = parserConfig();\n\n        PrivateFieldBean bean = JSON.parseObject(\"{\\\"hidden\\\":19}\", PrivateFieldBean.class, config,\n                Feature.SupportNonPublicField);\n\n        assertThat(bean.reveal()).isEqualTo(19);\n    }\n\n    @Test\n    void unwrappedBeanMapAndMethodFieldsReadExistingFieldsAndInvokeMethods() {\n        ParserConfig config = parserConfig();\n\n        UnwrappedNestedContainer nestedContainer = JSON.parseObject(\"{\\\"name\\\":\\\"nested\\\"}\",\n                UnwrappedNestedContainer.class, config);\n        assertThat(nestedContainer.nested.name).isEqualTo(\"nested\");\n\n        UnwrappedMapContainer mapContainer = JSON.parseObject(\"{\\\"dynamic\\\":42}\", UnwrappedMapContainer.class, config);\n        assertThat(mapContainer.values).containsEntry(\"dynamic\", 42);\n\n        UnwrappedMethodContainer methodContainer = JSON.parseObject(\"{\\\"methodValue\\\":\\\"called\\\"}\",\n                UnwrappedMethodContainer.class, config);\n        assertThat(methodContainer.values).containsEntry(\"methodValue\", \"called\");\n    }\n\n    @Test\n    void mapInstanceCreationAssignsPrimitiveObjectBuilderCreatorKotlinAndFactoryValues() throws Exception {\n        ParserConfig config = parserConfig();\n\n        PrimitiveFieldBean primitiveBean = createPrimitiveFromSyntheticInfo(config, primitiveValues());\n        assertThat(primitiveBean.falseValue).isFalse();\n        assertThat(primitiveBean.trueValue).isTrue();\n        assertThat(primitiveBean.intValue).isEqualTo(12);\n        assertThat(primitiveBean.longValue).isEqualTo(34L);\n        assertThat(primitiveBean.floatNumber).isEqualTo(1.25F);\n        assertThat(primitiveBean.floatString).isEqualTo(2.5F);\n        assertThat(primitiveBean.doubleNumber).isEqualTo(3.5D);\n        assertThat(primitiveBean.doubleString).isEqualTo(4.75D);\n        assertThat(primitiveBean.label).isEqualTo(\"direct\");\n\n        BuilderProduct builderProduct = createFromMap(config, BuilderProduct.class, singletonMap(\"name\", \"fromMap\"));\n        assertThat(builderProduct.name).isEqualTo(\"fromMap\");\n\n        CreatorConstructorBean creatorBean = createFromMap(config, CreatorConstructorBean.class,\n                mapOf(\"id\", 23, \"name\", \"created\"));\n        assertThat(creatorBean.id).isEqualTo(23);\n        assertThat(creatorBean.name).isEqualTo(\"created\");\n\n        KotlinStyleBeanWithDefault kotlinBean = createFromMap(config, KotlinStyleBeanWithDefault.class,\n                new HashMap<String, Object>());\n        assertThat(kotlinBean.name).isNull();\n\n        FactoryValueBean factoryBean = createFromMap(config, FactoryValueBean.class,\n                singletonMap(\"value\", \"factoryMap\"));\n        assertThat(factoryBean.value).isEqualTo(\"factoryMap\");\n    }\n\n    private static ParserConfig parserConfig() {\n        ParserConfig config = new ParserConfig();\n        config.setAsmEnable(false);\n        return config;\n    }\n\n    private static <T> T createFromMap(ParserConfig config, Class<T> type, Map<String, Object> values)\n            throws Exception {\n        ObjectDeserializer objectDeserializer = config.getDeserializer(type);\n        JavaBeanDeserializer deserializer = (JavaBeanDeserializer) objectDeserializer;\n        return type.cast(deserializer.createInstance(values, config));\n    }\n\n    private static PrimitiveFieldBean createPrimitiveFromSyntheticInfo(ParserConfig config, Map<String, Object> values)\n            throws Exception {\n        JavaBeanDeserializer deserializer = syntheticPrimitiveDeserializer(config);\n        return (PrimitiveFieldBean) deserializer.createInstance(values, config);\n    }\n\n    private static JavaBeanDeserializer syntheticPrimitiveDeserializer(ParserConfig config) throws Exception {\n        List<FieldInfo> fields = new ArrayList<FieldInfo>();\n        String[] fieldNames = {\n            \"falseValue\", \"trueValue\", \"intValue\", \"longValue\", \"floatNumber\",\n            \"floatString\", \"doubleNumber\", \"doubleString\", \"label\"\n        };\n        for (String fieldName : fieldNames) {\n            Field field = PrimitiveFieldBean.class.getField(fieldName);\n            fields.add(new FieldInfo(fieldName, null, field.getType(), field.getGenericType(), field, 0, 0, 0));\n        }\n        Constructor<PrimitiveFieldBean> constructor = PrimitiveFieldBean.class.getConstructor();\n        JavaBeanInfo beanInfo = new JavaBeanInfo(PrimitiveFieldBean.class, null, constructor, null, null, null, null,\n                fields);\n        return new JavaBeanDeserializer(config, beanInfo);\n    }\n\n    private static <T> T deserializeDirectly(ParserConfig config, Class<T> type, String json) {\n        DefaultJSONParser parser = new DefaultJSONParser(json, config);\n        try {\n            ObjectDeserializer objectDeserializer = config.getDeserializer(type);\n            return type.cast(objectDeserializer.deserialze(parser, type, null));\n        } finally {\n            parser.close();\n        }\n    }\n\n    private static Map<String, Object> primitiveValues() {\n        Map<String, Object> values = new HashMap<String, Object>();\n        values.put(\"falseValue\", Boolean.FALSE);\n        values.put(\"trueValue\", Boolean.TRUE);\n        values.put(\"intValue\", 12);\n        values.put(\"longValue\", 34L);\n        values.put(\"floatNumber\", 1.25D);\n        values.put(\"floatString\", \"2.5\");\n        values.put(\"doubleNumber\", 3.5F);\n        values.put(\"doubleString\", \"4.75\");\n        values.put(\"label\", \"direct\");\n        return values;\n    }\n\n    private static Map<String, Object> singletonMap(String key, Object value) {\n        Map<String, Object> values = new HashMap<String, Object>();\n        values.put(key, value);\n        return values;\n    }\n\n    private static Map<String, Object> mapOf(String firstKey, Object firstValue, String secondKey, Object secondValue) {\n        Map<String, Object> values = new HashMap<String, Object>();\n        values.put(firstKey, firstValue);\n        values.put(secondKey, secondValue);\n        return values;\n    }\n\n    public static class CountingAutoTypeHandler implements ParserConfig.AutoTypeCheckHandler {\n        static int instances;\n\n        public CountingAutoTypeHandler() {\n            instances++;\n        }\n\n        @Override\n        public Class<?> handler(String typeName, Class<?> expectClass, int features) {\n            return null;\n        }\n    }\n\n    @JSONType(autoTypeCheckHandler = CountingAutoTypeHandler.class)\n    public static class AutoTypeHandledBean {\n    }\n\n    public interface BeanView {\n        String getName();\n    }\n\n    public static class DefaultConstructedBean {\n        public String name;\n    }\n\n    public static class FactoryNoArgBean {\n        public final String name;\n\n        private FactoryNoArgBean(String name) {\n            this.name = name;\n        }\n\n        @JSONCreator\n        public static FactoryNoArgBean create() {\n            return new FactoryNoArgBean(\"factory\");\n        }\n    }\n\n    public static class OuterBean {\n        public InnerBean child;\n\n        public class InnerBean {\n            public String value;\n        }\n    }\n\n    public static class CreatorConstructorBean {\n        public final int id;\n        public final String name;\n\n        @JSONCreator\n        public CreatorConstructorBean(@JSONField(name = \"id\") int id, @JSONField(name = \"name\") String name) {\n            this.id = id;\n            this.name = name;\n        }\n    }\n\n    @Metadata\n    public static class KotlinStyleBeanWithDefault {\n      