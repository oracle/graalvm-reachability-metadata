[tool-call] delta {"path":"tests/src/com.alibaba/fastjson/1.2.83/src/test/java/com_alibaba/fastjson/FieldDeserializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_alibaba.fastjson;\n\nimport java.util.ArrayList;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.concurrent.atomic.AtomicBoolean;\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicLong;\n\nimport com.alibaba.fastjson.JSON;\nimport com.alibaba.fastjson.annotation.JSONField;\nimport com.alibaba.fastjson.parser.ParserConfig;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FieldDeserializerTest {\n    @Test\n    void getterOnlyAtomicMapAndCollectionPropertiesAreUpdatedThroughGetterMethods() {\n        ParserConfig config = parserConfig();\n\n        GetterOnlyBean bean = JSON.parseObject(\n                \"{\\\"atomicInteger\\\":11,\\\"atomicLong\\\":12,\\\"atomicBoolean\\\":true,\"\n                        + \"\\\"values\\\":{\\\"one\\\":1},\\\"names\\\":[\\\"alpha\\\"]}\",\n                GetterOnlyBean.class,\n                config);\n\n        assertThat(bean.getAtomicInteger().get()).isEqualTo(11);\n        assertThat(bean.getAtomicLong().get()).isEqualTo(12L);\n        assertThat(bean.getAtomicBoolean().get()).isTrue();\n        assertThat(bean.getValues()).containsEntry(\"one\", 1);\n        assertThat(bean.getNames()).containsExactly(\"alpha\");\n    }\n\n    @Test\n    void finalAtomicMapAndCollectionFieldsAreUpdatedThroughReadOnlyFieldAccess() {\n        ParserConfig config = parserConfig();\n\n        FinalFieldBean bean = JSON.parseObject(\n                \"{\\\"atomicInteger\\\":21,\\\"atomicLong\\\":22,\\\"atomicBoolean\\\":true,\"\n                        + \"\\\"values\\\":{\\\"two\\\":2},\\\"names\\\":[\\\"beta\\\"]}\",\n                FinalFieldBean.class,\n                config);\n\n        assertThat(bean.atomicInteger.get()).isEqualTo(21);\n        assertThat(bean.atomicLong.get()).isEqualTo(22L);\n        assertThat(bean.atomicBoolean.get()).isTrue();\n        assertThat(bean.values).containsEntry(\"two\", 2);\n        assertThat(bean.names).containsExactly(\"beta\");\n    }\n\n    @Test\n    void ordinarySetterAndFieldAssignmentsUseReflectiveWritePaths() {\n        ParserConfig config = parserConfig();\n\n        WritableBean bean = JSON.parseObject(\"{\\\"name\\\":\\\" setter \\\",\\\"count\\\":31}\", WritableBean.class, config);\n\n        assertThat(bean.name).isEqualTo(\" setter \");\n        assertThat(bean.count).isEqualTo(31);\n    }\n\n    @Test\n    void getterOnlyNullCollectionFallsBackToBackingFieldAssignment() {\n        ParserConfig config = parserConfig();\n\n        MutableFallbackBean bean = JSON.parseObject(\"{\\\"items\\\":[\\\"field\\\"]}\", MutableFallbackBean.class, config);\n\n        assertThat(bean.storedItems()).containsExactly(\"field\");\n    }\n\n    @Test\n    void getterOnlyNullCollectionFallsBackToDeclaredSetterAssignment() {\n        ParserConfig config = parserConfig();\n\n        DeclaredSetterFallbackBean bean = JSON.parseObject(\n                \"{\\\"externalItems\\\":[\\\"setter\\\"]}\",\n                DeclaredSetterFallbackBean.class,\n                config);\n\n        assertThat(bean.storedItems()).containsExactly(\"setter\");\n    }\n\n    private static ParserConfig parserConfig() {\n        ParserConfig config = new ParserConfig();\n        config.setAsmEnable(false);\n        return config;\n    }\n\n    public static class GetterOnlyBean {\n        private final AtomicInteger atomicInteger = new AtomicInteger();\n        private final AtomicLong atomicLong = new AtomicLong();\n        private final AtomicBoolean atomicBoolean = new AtomicBoolean();\n        private final Map<String, Integer> values = new HashMap<String, Integer>();\n        private final List<String> names = new ArrayList<String>();\n\n        public AtomicInteger getAtomicInteger() {\n            return atomicInteger;\n        }\n\n        public AtomicLong getAtomicLong() {\n            return atomicLong;\n        }\n\n        public AtomicBoolean getAtomicBoolean() {\n            return atomicBoolean;\n        }\n\n        public Map<String, Integer> getValues() {\n            return values;\n        }\n\n        public List<String> getNames() {\n            return names;\n        }\n    }\n\n    public static class FinalFieldBean {\n        public final AtomicInteger atomicInteger = new AtomicInteger();\n        public final AtomicLong atomicLong = new AtomicLong();\n        public final AtomicBoolean atomicBoolean = new AtomicBoolean();\n        public final Map<String, Integer> values = new HashMap<String, Integer>();\n        public final List<String> names = new ArrayList<String>();\n    }\n\n    public static class WritableBean {\n        private String name;\n        public int count;\n\n        public void setName(String name) {\n            this.name = name;\n        }\n    }\n\n    public static class MutableFallbackBean {\n        private List<String> items;\n\n        public List<String> getItems() {\n            return null;\n        }\n\n        public List<String> storedItems() {\n            return items;\n        }\n    }\n\n    public static class DeclaredSetterFallbackBean {\n        private List<String> items;\n\n        @JSONField(name = \"externalItems\", deserialize = false)\n        public List<String> getItemsForDeclaredSetter() {\n            return null;\n        }\n\n        public void setItemsForDeclaredSetter(List<String> items) {\n            this.items = items;\n        }\n\n        public List<String> storedItems() {\n            return items;\n        }\n    }\n}\n"}
