  package com_alibaba.fastjson;
  
  import java.awt.Point;
  import java.lang.reflect.Type;
  import java.time.LocalDate;
  import java.util.Optional;
  
  import com.alibaba.fastjson.JSON;
  import com.alibaba.fastjson.annotation.JSONCreator;
  import com.alibaba.fastjson.annotation.JSONType;
  import com.alibaba.fastjson.parser.DefaultJSONParser;
  import com.alibaba.fastjson.parser.JSONToken;
  import com.alibaba.fastjson.parser.ParserConfig;
  import com.alibaba.fastjson.parser.deserializer.ObjectDeserializer;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ParserConfigTest {
      @Test
      void registersPlatformAndOptionalDeserializersByClassName() {
          ParserConfig config = parserConfig();
  
          assertThat(config.getDeserializer(Point.class)).isNotNull();
          assertThat(config.getDeserializer(LocalDate.class)).isNotNull();
          assertThat(config.getDeserializer(Optional.class)).isNotNull();
      }
  
      @Test
      void registersOptionalJodaAndGuavaDeserializersByClassName() {
          ParserConfig config = parserConfig();
  
          assertThat(config.getDeserializer(org.joda.time.DateTime.class)).isNotNull();
          assertThat(config.getDeserializer(com.google.common.collect.HashMultimap.class)).isNotNull();
      }
  
      @Test
      void scansEnumMethodsForJacksonCompatibility() {
          ParserConfig config = parserConfig();
          config.setJacksonCompatible(true);
  
          assertThat(config.getDeserializer(PlainEnum.class)).isNotNull();
      }
  
      @Test
      void instantiatesCustomDeserializerDeclaredOnEnumJsonType() {
          ParserConfig config = parserConfig();
  
          ObjectDeserializer deserializer = config.getDeserializer(CustomDeserializedEnum.class);
  
          assertThat(deserializer).isInstanceOf(CustomEnumDeserializer.class);
      }
  
      @Test
      void resolvesEnumCreatorMethodFromMixin() {
          ParserConfig config = parserConfig();
          JSON.addMixInAnnotations(MixedCreatorEnum.class, MixedCreatorEnumMixin.class);
          try {
              MixedCreatorEnum value = JSON.parseObject("\"bee\"", MixedCreatorEnum.class, config);
  
              assertThat(value).isEqualTo(MixedCreatorEnum.BETA);
          } finally {
              JSON.removeMixInAnnotations(MixedCreatorEnum.class);
          }
      }
  
      @Test
      void instantiatesCustomDeserializerDeclaredOnBeanJsonType() {
          ParserConfig config = new ParserConfig();
  
          ObjectDeserializer deserializer = config.getDeserializer(CustomDeserializedBean.class);
  
          assertThat(deserializer).isInstanceOf(CustomBeanDeserializer.class);
      }
  
      @Test
      void scansClassResourceWithConfiguredDefaultClassLoaderDuringAutoTypeCheck() {
          ParserConfig config = parserConfig();
          config.setDefaultClassLoader(Thread.currentThread().getContextClassLoader());
  
          Class<?> checked = config.checkAutoType(ResourceScannedWithConfiguredLoader.class.getName(), null);
  
          assertThat(checked).isEqualTo(ResourceScannedWithConfiguredLoader.class);
      }
  
      @Test
      void scansClassResourceWithParserConfigClassLoaderDuringAutoTypeCheck() {
          ParserConfig config = parserConfig();
  
          Class<?> checked = config.checkAutoType(ResourceScannedWithParserConfigLoader.class.getName(), null);
  
          assertThat(checked).isEqualTo(ResourceScannedWithParserConfigLoader.class);
      }
  
      private static ParserConfig parserConfig() {
          ParserConfig config = new ParserConfig();
          config.setAsmEnable(false);
          return config;
      }
  
      public enum PlainEnum {
          FIRST
      }
  
      @JSONType(deserializer = CustomEnumDeserializer.class)
      public enum CustomDeserializedEnum {
          FIRST
      }
  
      public static class CustomEnumDeserializer implements ObjectDeserializer {
          @Override
          public <T> T deserialze(DefaultJSONParser parser, Type type, Object fieldName) {
              return type instanceof Class<?> ? (T) ((Class<?>) type).getEnumConstants()[0] : null;
          }
  
          @Override
          public int getFastMatchToken() {
              return JSONToken.LITERAL_STRING;
          }
      }
  
      public enum MixedCreatorEnum {
          ALPHA,
          BETA;
  
          public static MixedCreatorEnum fromCode(String code) {
              return "bee".equals(code) ? BETA : ALPHA;
          }
      }
  
      public abstract static class MixedCreatorEnumMixin {
          @JSONCreator
          public static MixedCreatorEnum fromCode(String code) {
              return null;
          }
      }
  
      @JSONType(deserializer = CustomBeanDeserializer.class)
      public static class CustomDeserializedBean {
          public String name;
      }
  
      public static class CustomBeanDeserializer implements ObjectDeserializer {
          @Override
          public <T> T deserialze(DefaultJSONParser parser, Type type, Object fieldName) {
              return null;
          }
  
          @Override
          public int getFastMatchToken() {
              return JSONToken.LBRACE;
          }
      }
  
      @JSONType
      public static class ResourceScannedWithConfiguredLoader {
      }
  
      @JSONType
      public static class ResourceScannedWithParserConfigLoader {
      }
  }
