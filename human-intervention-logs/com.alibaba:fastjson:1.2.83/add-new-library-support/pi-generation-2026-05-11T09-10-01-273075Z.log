  package com_alibaba.fastjson;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Field;
  import java.util.ArrayList;
  import java.util.HashMap;
  import java.util.List;
  import java.util.Map;
  
  import com.alibaba.fastjson.JSON;
  import com.alibaba.fastjson.annotation.JSONCreator;
  import com.alibaba.fastjson.annotation.JSONField;
  import com.alibaba.fastjson.annotation.JSONPOJOBuilder;
  import com.alibaba.fastjson.annotation.JSONType;
  import com.alibaba.fastjson.parser.DefaultJSONParser;
  import com.alibaba.fastjson.parser.Feature;
  import com.alibaba.fastjson.parser.ParserConfig;
  import com.alibaba.fastjson.parser.deserializer.JavaBeanDeserializer;
  import com.alibaba.fastjson.parser.deserializer.ObjectDeserializer;
  import com.alibaba.fastjson.util.FieldInfo;
  import com.alibaba.fastjson.util.JavaBeanInfo;
  import kotlin.Metadata;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaBeanDeserializerTest {
      @Test
      void jsonTypeAutoTypeHandlerIsCreatedWhenDeserializerIsBuilt() {
          CountingAutoTypeHandler.instances = 0;
          ParserConfig config = parserConfig();
  
          AutoTypeHandledBean bean = JSON.parseObject("{}", AutoTypeHandledBean.class, config);
  
          assertThat(bean).isNotNull();
          assertThat(CountingAutoTypeHandler.instances).isGreaterThanOrEqualTo(1);
      }
  
      @Test
      void parserCreatesInterfaceProxyDefaultConstructedBeansFactoryBeansAndInnerBeans() {
          ParserConfig config = parserConfig();
  
          BeanView view = JSON.parseObject("{\"name\":\"proxy\"}", BeanView.class, config);
          assertThat(view).isNotNull();
  
          DefaultConstructedBean defaultConstructed = JSON.parseObject("{\"name\":\"default\"}",
                  DefaultConstructedBean.class, config);
          assertThat(defaultConstructed.name).isEqualTo("default");
  
          FactoryNoArgBean factoryBean = JSON.parseObject("{}", FactoryNoArgBean.class, config);
          assertThat(factoryBean.name).isEqualTo("factory");
  
          OuterBean outer = JSON.parseObject("{\"child\":{\"value\":\"inner\"}}", OuterBean.class, config);
          assertThat(outer.child.value).isEqualTo("inner");
      }
  
      @Test
      void parserUsesCreatorConstructorsKotlinDefaultConstructorsFactoryMethodsAndBuildMethods() {
          ParserConfig config = parserConfig();
  
          CreatorConstructorBean creatorBean = JSON.parseObject("{\"id\":7,\"name\":\"ctor\"}",
                  CreatorConstructorBean.class, config);
          assertThat(creatorBean.id).isEqualTo(7);
          assertThat(creatorBean.name).isEqualTo("ctor");
  
          KotlinStyleBeanWithDefault kotlinBean = JSON.parseObject("{\"name\":null}",
                  KotlinStyleBeanWithDefault.class, config);
          assertThat(kotlinBean.name).isNull();
  
          FactoryValueBean factoryBean = JSON.parseObject("{\"value\":\"object\"}", FactoryValueBean.class, config);
          assertThat(factoryBean.value).isEqualTo("object");
  
          BuilderProduct product = JSON.parseObject("{\"name\":\"built\"}", BuilderProduct.class, config);
          assertThat(product.name).isEqualTo("built");
      }
  
      @Test
      void scalarInputUsesSingleArgumentFactoryMethod() {
          ParserConfig config = parserConfig();
  
          FactoryValueBean factoryBean = deserializeDirectly(config, FactoryValueBean.class, "\"scalar\"");
  
          assertThat(factoryBean.value).isEqualTo("scalar");
      }
  
      @Test
      void supportNonPublicFieldScansAndAssignsDeclaredFields() {
          ParserConfig config = parserConfig();
  
          PrivateFieldBean bean = JSON.parseObject("{\"hidden\":19}", PrivateFieldBean.class, config,
                  Feature.SupportNonPublicField);
  
          assertThat(bean.reveal()).isEqualTo(19);
      }
  
      @Test
      void unwrappedBeanMapAndMethodFieldsReadExistingFieldsAndInvokeMethods() {
          ParserConfig config = parserConfig();
  
          UnwrappedNestedContainer nestedContainer = JSON.parseObject("{\"name\":\"nested\"}",
                  UnwrappedNestedContainer.class, config);
          assertThat(nestedContainer.nested.name).isEqualTo("nested");
  
          UnwrappedMapContainer mapContainer = JSON.parseObject("{\"dynamic\":42}", UnwrappedMapContainer.class, config);
          assertThat(mapContainer.values).containsEntry("dynamic", 42);
  
          UnwrappedMethodContainer methodContainer = JSON.parseObject("{\"methodValue\":\"called\"}",
                  UnwrappedMethodContainer.class, config);
          assertThat(methodContainer.values).containsEntry("methodValue", "called");
      }
  
      @Test
      void mapInstanceCreationAssignsPrimitiveObjectBuilderCreatorKotlinAndFactoryValues() throws Exception {
          ParserConfig config = parserConfig();
  
          PrimitiveFieldBean primitiveBean = createPrimitiveFromSyntheticInfo(config, primitiveValues());
          assertThat(primitiveBean.falseValue).isFalse();
          assertThat(primitiveBean.trueValue).isTrue();
          assertThat(primitiveBean.intValue).isEqualTo(12);
          assertThat(primitiveBean.longValue).isEqualTo(34L);
          assertThat(primitiveBean.floatNumber).isEqualTo(1.25F);
          assertThat(primitiveBean.floatString).isEqualTo(2.5F);
          assertThat(primitiveBean.doubleNumber).isEqualTo(3.5D);
          assertThat(primitiveBean.doubleString).isEqualTo(4.75D);
          assertThat(primitiveBean.label).isEqualTo("direct");
  
          BuilderProduct builderProduct = createFromMap(config, BuilderProduct.class, singletonMap("name", "fromMap"));
          assertThat(builderProduct.name).isEqualTo("fromMap");
  
          CreatorConstructorBean creatorBean = createFromMap(config, CreatorConstructorBean.class,
                  mapOf("id", 23, "name", "created"));
          assertThat(creatorBean.id).isEqualTo(23);
          assertThat(creatorBean.name).isEqualTo("created");
  
          KotlinStyleBeanWithDefault kotlinBean = createFromMap(config, KotlinStyleBeanWithDefault.class,
                  new HashMap<String, Object>());
          assertThat(kotlinBean.name).isNull();
  
          FactoryValueBean factoryBean = createFromMap(config, FactoryValueBean.class,
                  singletonMap("value", "factoryMap"));
          assertThat(factoryBean.value).isEqualTo("factoryMap");
      }
  
      private static ParserConfig parserConfig() {
          ParserConfig config = new ParserConfig();
          config.setAsmEnable(false);
          return config;
      }
  
      private static <T> T createFromMap(ParserConfig config, Class<T> type, Map<String, Object> values)
              throws Exception {
          ObjectDeserializer objectDeserializer = config.getDeserializer(type);
          JavaBeanDeserializer deserializer = (JavaBeanDeserializer) objectDeserializer;
          return type.cast(deserializer.createInstance(values, config));
      }
  
      private static PrimitiveFieldBean createPrimitiveFromSyntheticInfo(ParserConfig config, Map<String, Object> values)
              throws Exception {
          JavaBeanDeserializer deserializer = syntheticPrimitiveDeserializer(config);
          return (PrimitiveFieldBean) deserializer.createInstance(values, config);
      }
  
      private static JavaBeanDeserializer syntheticPrimitiveDeserializer(ParserConfig config) throws Exception {
          List<FieldInfo> fields = new ArrayList<FieldInfo>();
          String[] fieldNames = {
              "falseValue", "trueValue", "intValue", "longValue", "floatNumber",
              "floatString", "doubleNumber", "doubleString", "label"
          };
          for (String fieldName : fieldNames) {
              Field field = PrimitiveFieldBean.class.getField(fieldName);
              fields.add(new FieldInfo(fieldName, null, field.getType(), field.getGenericType(), field, 0, 0, 0));
          }
          Constructor<PrimitiveFieldBean> constructor = PrimitiveFieldBean.class.getConstructor();
          JavaBeanInfo beanInfo = new JavaBeanInfo(PrimitiveFieldBean.class, null, constructor, null, null, null, null,
                  fields);
          return new JavaBeanDeserializer(config, beanInfo);
      }
  
      private static <T> T deserializeDirectly(ParserConfig config, Class<T> type, String json) {
          DefaultJSONParser parser = new DefaultJSONParser(json, config);
          try {
              ObjectDeserializer objectDeserializer = config.getDeserializer(type);
              return type.cast(objectDeserializer.deserialze(parser, type, null));
          } finally {
              parser.close();
          }
      }
  
      private static Map<String, Object> primitiveValues() {
          Map<String, Object> values = new HashMap<String, Object>();
          values.put("falseValue", Boolean.FALSE);
          values.put("trueValue", Boolean.TRUE);
          values.put("intValue", 12);
          values.put("longValue", 34L);
          values.put("floatNumber", 1.25D);
          values.put("floatString", "2.5");
          values.put("doubleNumber", 3.5F);
          values.put("doubleString", "4.75");
          values.put("label", "direct");
          return values;
      }
  
      private static Map<String, Object> singletonMap(String key, Object value) {
          Map<String, Object> values = new HashMap<String, Object>();
          values.put(key, value);
          return values;
      }
  
      private static Map<String, Object> mapOf(String firstKey, Object firstValue, String secondKey, Object secondValue) {
          Map<String, Object> values = new HashMap<String, Object>();
          values.put(firstKey, firstValue);
          values.put(secondKey, secondValue);
          return values;
      }
  
      public static class CountingAutoTypeHandler implements ParserConfig.AutoTypeCheckHandler {
          static int instances;
  
          public CountingAutoTypeHandler() {
              instances++;
          }
  
          @Override
          public Class<?> handler(String typeName, Class<?> expectClass, int features) {
              return null;
          }
      }
  
      @JSONType(autoTypeCheckHandler = CountingAutoTypeHandler.class)
      public static class AutoTypeHandledBean {
      }
  
      public interface BeanView {
          String getName();
      }
  
      public static class DefaultConstructedBean {
          public String name;
      }
  
      public static class FactoryNoArgBean {
          public final String name;
  
          private FactoryNoArgBean(String name) {
              this.name = name;
          }
  
          @JSONCreator
          public static FactoryNoArgBean create() {
              return new FactoryNoArgBean("factory");
          }
      }
  
      public static class OuterBean {
          public InnerBean child;
  
          public class InnerBean {
              public String value;
          }
