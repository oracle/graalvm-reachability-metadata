zed.getObject(\"payload\", Payload.class).value).isEqualTo(\"secure-stream\");\n        assertThat(deserialized.get(\"proxy\")).isInstanceOf(Runnable.class);\n    }\n\n    private static byte[] serialize(Object value) throws IOException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n        return bytes.toByteArray();\n    }\n\n    private static JSONObject deserializeJSONObject(byte[] bytes) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {\n            return (JSONObject) input.readObject();\n        }\n    }\n\n    private static Runnable serializableRunnableProxy() {\n        ClassLoader classLoader = JSONObjectInnerSecureObjectInputStreamTest.class.getClassLoader();\n        Class<?>[] interfaces = {Runnable.class, Serializable.class};\n        return (Runnable) Proxy.newProxyInstance(classLoader, interfaces, new SerializableInvocationHandler());\n    }\n\n    private static final class SerializableInvocationHandler implements InvocationHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) {\n            String methodName = method.getName();\n            if (\"toString\".equals(methodName)) {\n                return \"serializable-runnable-proxy\";\n            }\n            if (\"hashCode\".equals(methodName)) {\n                return System.identityHashCode(proxy);\n            }\n            if (\"equals\".equals(methodName)) {\n                return proxy == args[0];\n            }\n            return null;\n        }\n    }\n\n    public static final class Payload implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        public String value;\n\n        public Payload() {\n        }\n\n        Payload(String value) {\n            this.value = value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 874, "output": 1272, "cacheRead": 37376, "cacheWrite": 0, "totalTokens": 39522, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778490982302, "responseId": "resp_0982407595ec0de7016a019e66d818819f80f5efd513b45ecb"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_w7xvgmdVtvYtbZm5ZqaeSlHT|fc_0982407595ec0de7016a019e713a90819f845bd181f6cbaefb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3171 bytes to tests/src/com.alibaba/fastjson/1.2.83/src/test/java/com_alibaba/fastjson/JSONObjectInnerSecureObjectInputStreamTest.java"}], "isError": false, "timestamp": 1778490996729}]}
