[tool-call] delta {"path":"tests/src/org.apache.maven/maven-resolver-provider/3.9.12/src/test/java/org_apache_maven/maven_resolver_provider/Maven_resolver_providerTest.java","edits":[{"oldText":"    @Test\n    void mavenWorkspaceReaderSuppliesModelWithoutRemoteRepositories() throws Exception {\n        RepositorySystem repositorySystem = newRepositorySystem();\n        DefaultRepositorySystemSession session = newSession(repositorySystem, tempDirectory.resolve(\"workspace-local\"));\n        Model workspaceModel = model(\"com.acme\", \"workspace-demo\", \"1.0.0\");\n        org.apache.maven.model.Dependency dependency = new org.apache.maven.model.Dependency();\n        dependency.setGroupId(\"com.acme\");\n        dependency.setArtifactId(\"workspace-runtime\");\n        dependency.setVersion(\"1.2.3\");\n        dependency.setScope(\"runtime\");\n        workspaceModel.addDependency(dependency);\n        RecordingWorkspaceReader workspaceReader = new RecordingWorkspaceReader(workspaceModel);\n        session.setWorkspaceReader(workspaceReader);\n\n        Artifact artifact = new DefaultArtifact(\"com.acme:workspace-demo:jar:1.0.0\");\n        ArtifactDescriptorRequest request = new ArtifactDescriptorRequest(artifact, List.of(), \"workspace-test\");\n\n        ArtifactDescriptorResult result = repositorySystem.readArtifactDescriptor(session, request);\n\n        assertThat(workspaceReader.findModelCalls().get()).isPositive();\n        assertThat(result.getDependencies())\n                .extracting(Dependency::getArtifact)\n                .extracting(Artifact::toString)\n                .containsExactly(\"com.acme:workspace-runtime:jar:1.2.3\");\n        assertThat(result.getDependencies()).singleElement()\n                .extracting(Dependency::getScope)\n                .isEqualTo(\"runtime\");\n    }\n","newText":"    @Test\n    void mavenWorkspaceReaderExposesWorkspaceRepositoryModelsAndVersions() {\n        Model workspaceModel = model(\"com.acme\", \"workspace-demo\", \"1.0.0\");\n        RecordingWorkspaceReader workspaceReader = new RecordingWorkspaceReader(workspaceModel);\n        Artifact matchingArtifact = new DefaultArtifact(\"com.acme:workspace-demo:pom:1.0.0\");\n        Artifact differentArtifact = new DefaultArtifact(\"com.acme:other:pom:1.0.0\");\n\n        assertThat(workspaceReader.getRepository().getContentType()).isEqualTo(\"workspace\");\n        assertThat(workspaceReader.getRepository().getId()).isEqualTo(\"fixture-workspace\");\n        assertThat(workspaceReader.findModel(matchingArtifact)).isSameAs(workspaceModel);\n        assertThat(workspaceReader.findVersions(matchingArtifact)).containsExactly(\"1.0.0\");\n        assertThat(workspaceReader.findArtifact(matchingArtifact)).isNull();\n        assertThat(workspaceReader.findModel(differentArtifact)).isNull();\n        assertThat(workspaceReader.findVersions(differentArtifact)).isEmpty();\n        assertThat(workspaceReader.findModelCalls().get()).isEqualTo(2);\n    }\n"}]}
