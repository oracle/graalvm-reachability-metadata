    }
    def trueRgbEscape(r: Int, g: Int, b: Int) = {
      "\u001b[" + colorCode + ";2;" + r + ";" + g + ";" + b + "m"
    }
  
    /**
      * Create a TrueColor color, from a given index within the 16-million-color
      * TrueColor range
      */
    def True(index: Int) = {
      require(
        0 <= index && index <= (1 << 24),
        "True parameter `index` must be 273 <= index <= 16777488, not " + index
