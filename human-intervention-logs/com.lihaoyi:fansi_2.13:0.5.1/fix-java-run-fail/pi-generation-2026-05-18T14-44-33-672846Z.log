  /**
    * * Color a encoded on 25 bit as follow :
    * 0 : reset value
    * 1 - 16 : 3 bit colors
    * 17 - 272 : 8 bit colors
    * 273 - 16 777 388 : 24 bit colors
    */
  abstract class ColorCategory(offset: Int, width: Int, val colorCode: Int)
                              (implicit catName: sourcecode.Name)
                               extends Category (offset, width)(catName){
  
  
  
