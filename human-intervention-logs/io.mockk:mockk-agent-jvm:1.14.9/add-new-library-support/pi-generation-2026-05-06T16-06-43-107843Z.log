uctorTarget::class.java,\n                emptyArray(),\n                { _, _, originalCall, _ -> originalCall.call() },\n                true,\n                null,\n            )\n\n            try {\n                assertThat(proxy.get().createdByDefaultConstructor).isTrue()\n            } finally {\n                proxy.cancel()\n            }\n        } catch (error: Error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error\n            }\n        }\n    }\n\n    private class DefaultConstructorTarget {\n        val createdByDefaultConstructor: Boolean = true\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2236, "output": 648, "cacheRead": 15872, "cacheWrite": 0, "totalTokens": 18756, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778083542459, "responseId": "resp_0cc66749841171b50169fb66d6d4488193ab69a0e0c58871ec"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ioPI0NEtYj3oD1ryu8X1aZPU|fc_0cc66749841171b50169fb66db441881939d85e4696051ccdb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1631 bytes to tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerTest.kt"}], "isError": false, "timestamp": 1778083549702}]}
