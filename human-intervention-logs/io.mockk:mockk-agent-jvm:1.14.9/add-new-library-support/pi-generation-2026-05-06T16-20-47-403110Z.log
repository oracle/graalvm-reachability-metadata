ite", "arguments": {"path": "tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/DefaultInterfaceMethodResolverInnerCompanionTest.kt", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\n@file:Suppress(\"INVISIBLE_MEMBER\", \"INVISIBLE_REFERENCE\")\n\npackage io_mockk.mockk_agent_jvm\n\nimport io.mockk.proxy.jvm.util.DefaultInterfaceMethodResolver\nimport org.assertj.core.api.Assertions.assertThat\nimport org.junit.jupiter.api.Test\nimport org.junit.jupiter.api.Timeout\nimport java.lang.reflect.Method\nimport java.util.concurrent.Callable\n\npublic class DefaultInterfaceMethodResolverInnerCompanionTest {\n    @Test\n    @Timeout(60)\n    fun resolvesKotlinInterfaceDefaultImplementationFromDefaultImplsClass(): Unit {\n        val mock: KotlinDefaultMethodContract = object : KotlinDefaultMethodContract {}\n        val interfaceMethod: Method = KotlinDefaultMethodContract::class.java.getMethod(\n            \"defaultMessage\",\n            String::class.java,\n            Int::class.javaPrimitiveType,\n        )\n\n        val defaultImplementation: Callable<Any?>? = DefaultInterfaceMethodResolver\n            .getDefaultImplementationOrNull(mock, interfaceMethod, arrayOf(\"mockk\", 2))\n\n        assertThat(defaultImplementation).isNotNull\n        assertThat(defaultImplementation?.call()).isEqualTo(\"mockk-mockk\")\n    }\n\n    public interface KotlinDefaultMethodContract {\n        public fun defaultMessage(value: String, repetitions: Int): String\n\n        public class DefaultImpls {\n            public companion object {\n                @JvmStatic\n                public fun defaultMessage(\n                    self: KotlinDefaultMethodContract,\n                    value: String,\n                    repetitions: Int,\n                ): String = List(repetitions) { value }.joinToString(\"-\")\n            }\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 594, "output": 1388, "cacheRead": 24064, "cacheWrite": 0, "totalTokens": 26046, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778084355720, "responseId": "resp_00e1032ead48e5a40169fb6a04466081a185914e46daa10987"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_iSvVM6Cu2lyZR0YTXaY0lgDP|fc_00e1032ead48e5a40169fb6a16c98881a19186fbd50f4d342c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1828 bytes to tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/DefaultInterfaceMethodResolverInnerCompanionTest.kt"}], "isError": false, "timestamp": 1778084376616}]}
