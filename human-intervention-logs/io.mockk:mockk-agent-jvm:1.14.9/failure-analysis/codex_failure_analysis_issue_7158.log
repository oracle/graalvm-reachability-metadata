nBootstrapPath(): Unit {\\\\\\\\n+        val factory: JvmMockKAgentFactory = JvmMockKAgentFactory()\\\\\\\\n+\\\\\\\\n+        try {\\\\\\\\n+            factory.init(MockKAgentLogFactory.simpleConsoleLogFactory)\\\\\\\\n+        } catch (error: Error) {\\\\\\\\n+            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\\\\\\\n+                throw error\\\\\\\\n+            }\\\\\\\\n+            return\\\\\\\\n+        }\\\\\\\\n+\\\\\\\\n+        assertThat(factory.proxyMaker).isNotNull()\\\\\\\\n+        assertThat(factory.staticProxyMaker).isNotNull()\\\\\\\\n+        assertThat(factory.constructorProxyMaker).isNotNull()\\\\\\\\n+        assertThat(factory.instantiator).isNotNull()\\\\\\\\n+    }\\\\\\\\n+}\\\\\\\\n\\\\\\\\nFrom 04004b5d76730c7e369c1790e3c75c4bda22f95b Mon Sep 17 00:00:00 2001\\\\\\\\nFrom: Vojin Jovanovic <vojin.jovanovic@oracle.com>\\\\\\\\nDate: Wed, 6 May 2026 18:04:40 +0200\\\\\\\\nSubject: [PATCH 3/9] Dynamic-access coverage for\\\\\\\\n io.mockk.proxy.jvm.ClassLoadingStrategyChooser (6/13)\\\\\\\\n\\\\\\\\n---\\\\\\\\n .../ClassLoadingStrategyChooserTest.kt        | 26 +++++++++++++++++++\\\\\\\\n 1 file changed, 26 insertions(+)\\\\\\\\n create mode 100644 tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ClassLoadingStrategyChooserTest.kt\\\\\\\\n\\\\\\\\ndiff --git a/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ClassLoadingStrategyChooserTest.kt b/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ClassLoadingStrategyChooserTest.kt\\\\\\\\nnew file mode 100644\\\\\\\\nindex 0000000000..895c2ce9da\\\\\\\\n--- /dev/null\\\\\\\\n+++ b/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ClassLoadingStrategyChooserTest.kt\\\\\\\\n@@ -0,0 +1,26 @@\\\\\\\\n+/*\\\\\\\\n+ * Copyright and related rights waived via CC0\\\\\\\\n+ *\\\\\\\\n+ * You should have received a copy of the CC0 legalcode along with this\\\\\\\\n+ * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\\\\\\\n+ */\\\\\\\\n+package io_mockk.mockk_agent_jvm\\\\\\\\n+\\\\\\\\n+import io.mockk.proxy.jvm.ClassLoadingStrategyChooser\\\\\\\\n+import net.bytebuddy.dynamic.loading.ClassLoadingStrategy\\\\\\\\n+import org.assertj.core.api.Assertions.assertThat\\\\\\\\n+import org.junit.jupiter.api.Test\\\\\\\\n+import org.junit.jupiter.api.Timeout\\\\\\\\n+\\\\\\\\n+public class ClassLoadingStrategyChooserTest {\\\\\\\\n+    @Test\\\\\\\\n+    @Timeout(60)\\\\\\\\n+    fun choosesClassLoadingStrategyForApplicationClass(): Unit {\\\\\\\\n+        val strategy: ClassLoadingStrategy<ClassLoader> =\\\\\\\\n+            ClassLoadingStrategyChooser.chooseClassLoadingStrategy(SampleApplicationClass::class.java)\\\\\\\\n+\\\\\\\\n+        assertThat(strategy).isNotNull()\\\\\\\\n+    }\\\\\\\\n+\\\\\\\\n+    private class SampleApplicationClass\\\\\\\\n+}\\\\\\\\n\\\\\\\\nFrom f8278f9e73a6c44a702f40b8f3ab3f139edb5f98 Mon Sep 17 00:00:00 2001\\\\\\\\nFrom: Vojin Jovanovic <vojin.jovanovic@oracle.com>\\\\\\\\nDate: Wed, 6 May 2026 18:08:41 +0200\\\\\\\\nSubject: [PATCH 4/9] Dynamic-access coverage for io.mockk.proxy.jvm.ProxyMaker\\\\\\\\n (9/13)\\\\\\\\n\\\\\\\\n---\\\\\\\\n .../mockk_agent_jvm/ProxyMakerTest.kt         | 59 +++++++++++++++++++\\\\\\\\n 1 file changed, 59 insertions(+)\\\\\\\\n create mode 100644 tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerTest.kt\\\\\\\\n\\\\\\\\ndiff --git a/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerTest.kt b/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerTest.kt\\\\\\\\nnew file mode 100644\\\\\\\\nindex 0000000000..c0cb5b7205\\\\\\\\n--- /dev/null\\\\\\\\n+++ b/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerTest.kt\\\\\\\\n@@ -0,0 +1,59 @@\\\\\\\\n+/*\\\\\\\\n+