 interface KotlinDefaultMethodContract {\\\\\\\\n+        public fun defaultMessage(value: String, repetitions: Int): String\\\\\\\\n+\\\\\\\\n+        public class DefaultImpls {\\\\\\\\n+            public companion object {\\\\\\\\n+                @JvmStatic\\\\\\\\n+                public fun defaultMessage(\\\\\\\\n+                    self: KotlinDefaultMethodContract,\\\\\\\\n+                    value: String,\\\\\\\\n+                    repetitions: Int,\\\\\\\\n+                ): String = List(repetitions) { value }.joinToString(\\\\\\\\\\\\\\\"-\\\\\\\\\\\\\\\")\\\\\\\\n+            }\\\\\\\\n+        }\\\\\\\\n+    }\\\\\\\\n+}\\\\\\\\n\\\\\\\\nFrom a7e7bd4feb95115451191a46ccfaef3a2d2fc87d Mon Sep 17 00:00:00 2001\\\\\\\\nFrom: Vojin Jovanovic <vojin.jovanovic@oracle.com>\\\\\\\\nDate: Wed, 6 May 2026 18:36:34 +0200\\\\\\\\nSubject: [PATCH 7/9] Native metadata for\\\\\\\\n io.mockk.proxy.jvm.util.DefaultInterfaceMethodResolver$Companion__native_batch_5\\\\\\\\n\\\\\\\\n---\\\\\\\\n .../1.14.9/reachability-metadata.json         | 116 ++++++++++++++++++\\\\\\\\n 1 file changed, 116 insertions(+)\\\\\\\\n create mode 100644 metadata/io.mockk/mockk-agent-jvm/1.14.9/reachability-metadata.json\\\\\\\\n\\\\\\\\ndiff --git a/metadata/io.mockk/mockk-agent-jvm/1.14.9/reachability-metadata.json b/metadata/io.mockk/mockk-agent-jvm/1.14.9/reachability-metadata.json\\\\\\\\nnew file mode 100644\\\\\\\\nindex 0000000000..6145394b38\\\\\\\\n--- /dev/null\\\\\\\\n+++ b/metadata/io.mockk/mockk-agent-jvm/1.14.9/reachability-metadata.json\\\\\\\\n@@ -0,0 +1,116 @@\\\\\\\\n+{\\\\\\\\n+  \\\\\\\\\\\\\\\"reflection\\\\\\\\\\\\\\\": [\\\\\\\\n+    {\\\\\\\\n+      \\\\\\\\\\\\\\\"condition\\\\\\\\\\\\\\\": {\\\\\\\\n+        \\\\\\\\\\\\\\\"typeReached\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\"io.mockk.proxy.jvm.JvmMockKAgentFactory\\\\\\\\\\\\\\\"\\\\\\\\n+      },\\\\\\\\n+      \\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\"byte[][]\\\\\\\\\\\\\\\"\\\\\\\\n+    },\\\\\\\\n+