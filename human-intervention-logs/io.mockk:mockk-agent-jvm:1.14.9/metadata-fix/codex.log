     }\\n+\\n+    private fun Throwable.causeSequence(): Sequence<Throwable> =\\n+        generateSequence(this) { current: Throwable -> current.cause }\\n+}\\ndiff --git a/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/Mockk_agent_jvmTest.kt b/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/Mockk_agent_jvmTest.kt\\ndeleted file mode 100644\\nindex 2e636c3663..0000000000\\n--- a/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/Mockk_agent_jvmTest.kt\\n+++ /dev/null\\n@@ -1,16 +0,0 @@\\n-/*\\n- * Copyright and related rights waived via CC0\\n- *\\n- * You should have received a copy of the CC0 legalcode along with this\\n- * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n- */\\n-package io_mockk.mockk_agent_jvm\\n-\\n-import org.junit.jupiter.api.Test\\n-\\n-class Mockk_agent_jvmTest {\\n-    @Test\\n-    fun test() {\\n-        println(\\\"This is just a placeholder, implement your test\\\")\\n-    }\\n-}\\ndiff --git a/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerInnerCompanionTest.kt b/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerInnerCompanionTest.kt\\nindex 23cb5251ce..fce8953999 100644\\n--- a/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerInnerCompanionTest.kt\\n+++ b/tests/src/io.mockk/mockk-agent-jvm/1.14.9/src/test/kotlin/io_mockk/mockk_agent_jvm/ProxyMakerInnerCompanionTest.kt\\n@@ -19,7 +19,6 @@ import io.mockk.proxy.jvm.transformation.SubclassInstrumentation\\n import net.bytebuddy.ByteBuddy\\n import net.bytebuddy.dynamic.scaffold.TypeValidation\\n import org.assertj.core.api.Assertions.assertThat\\n-import org.graalvm.internal.tck.NativeImageSupport\\n import org.junit.jupiter.api.Test\\n import org.junit.jupiter.api.Timeout\\n import java.lang.reflect.Method\\n@@ -53,9 +52,9 @@ publi