ID_PATTERN = \"0.0.0\";\n    private static final String SPI_LOCALE_TAG = \"zz-ZZ\";\n    private static final Locale SPI_LOCALE = Locale.forLanguageTag(SPI_LOCALE_TAG);\n\n    @Test\n    void rejectsNonNumberTypesUsingErrorResourceBundle() {\n        assertThatThrownBy(() -> converterFor(String.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, TEST_PATTERN))\n                .isInstanceOf(CsvBadConverterException.class)\n                .hasMessageContaining(\"Number\");\n    }\n\n    @Test\n    void reportsInvalidReadNumberPatternUsingErrorResourceBundle() {\n        assertThatThrownBy(() -> converterFor(Integer.class, TEST_LOCALE, TEST_LOCALE, INVALID_PATTERN, TEST_PATTERN))\n                .isInstanceOf(CsvBadConverterException.class)\n                .hasCauseInstanceOf(IllegalArgumentException.class);\n    }\n\n    @Test\n    void reportsInvalidWriteNumberPatternUsingErrorResourceBundle() {\n        assertThatThrownBy(() -> converterFor(Integer.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, INVALID_PATTERN))\n                .isInstanceOf(CsvBadConverterException.class)\n                .hasCauseInstanceOf(IllegalArgumentException.class);\n    }\n\n    @Test\n    void reportsUnparsableInputUsingErrorResourceBundle() {\n        ConverterNumber converter = converterFor(Integer.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, TEST_PATTERN);\n\n        assertThatThrownBy(() -> converter.convertToRead(\"not-a-number\"))\n                .isInstanceOf(CsvDataTypeMismatchException.class)\n                .hasCauseInstanceOf(java.text.ParseException.class)\n                .hasMessageContaining(\"not-a-number\");\n    }\n\n    @Test\n    void reportsLocaleNumberFormatThatIsNotDecimalFormatUsingErrorResourceBundle() {\n        assertThatThrownBy(() -> converterFor(Integer.class, SPI_LOCALE_TAG, TEST_LOCALE, TEST_PATTERN, TEST_PATTERN))\n                .isInstanceOf(CsvBadConverterException.class)\n                .hasMessageContaining(\"DecimalFormat\");\n    }\n\n    @Test\n    void convertsBigDecimalWithLocalizedPattern() throws CsvDataTypeMismatchException {\n        ConverterNumber converter = converterFor(BigDecimal.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, \"#,##0.00\");\n\n        Object converted = converter.convertToRead(\"1,234.5\");\n        String formatted = converter.convertToWrite(converted);\n\n        assertThat(converted).isEqualByComparingTo(new BigDecimal(\"1234.5\"));\n        assertThat(formatted).isEqualTo(\"1,234.50\");\n    }\n\n    private static ConverterNumber converterFor(\n            Class<?> type,\n            String locale,\n            String writeLocale,\n            String readPattern,\n            String writePattern) {\n        return new ConverterNumber(type, locale, writeLocale, Locale.US, readPattern, writePattern);\n    }\n\n    public static final class NonDecimalNumberFormatProvider extends NumberFormatProvider {\n        @Override\n        public Locale[] getAvailableLocales() {\n            return new Locale[] {SPI_LOCALE};\n        }\n\n        @Override\n        public NumberFormat getCurrencyInstance(Locale locale) {\n            return new PlainNumberFormat();\n        }\n\n        @Override\n        public NumberFormat getIntegerInstance(Locale locale) {\n            return new PlainNumberFormat();\n        }\n\n        @Override\n        public NumberFormat getNumberInstance(Locale locale) {\n            return new PlainNumberFormat();\n        }\n\n        @Override\n        public NumberFormat getPercentInstance(Locale locale) {\n            return new PlainNumberFormat();\n        }\n    }\n\n    private static final class PlainNumberFormat extends NumberFormat {\n        @Override\n        public StringBuffer format(double number, StringBuffer toAppendTo, FieldPosition pos) {\n            return toAppendTo.append(number);\n        }\n\n        @Override\n        public StringBuffer format(long number, StringBuffer toAppendTo, FieldPosition pos) {\n            return toAppendTo.append(number);\n        }\n\n        @Override\n        public Number parse(String source, ParsePosition parsePosition) {\n            parsePosition.setIndex(source.length());\n            return 0;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1779329162136}]}
