       *                       single input record. The default is {@link CSVReader#DEFAULT_MULTILINE_LIMIT}.
       * @return {@code this}
       */
      public CSVReaderHeaderAwareBuilder withMultilineLimit(int multilineLimit) {
          this.multilineLimit = multilineLimit;
          return this;
      }
  
