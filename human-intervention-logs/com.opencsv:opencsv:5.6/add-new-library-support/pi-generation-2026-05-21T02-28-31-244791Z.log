       * the previously set {@link RowProcessor}.
       *
       * @param rowProcessor {@link RowProcessor} to inject
       * @return {@code this}
       * @since 5.0
       */
      public CSVReaderBuilder withRowProcessor(RowProcessor rowProcessor) {
          this.rowProcessor = rowProcessor;
          return this;
      }
  }
