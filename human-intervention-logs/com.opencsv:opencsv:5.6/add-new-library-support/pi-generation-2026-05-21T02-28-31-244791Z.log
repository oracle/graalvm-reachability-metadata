mit(1)\n                            .withErrorLocale(Locale.US)\n                            .build()) {\n                        reader.readNext();\n                    }\n                })\n                .withMessageContaining(\"more lines than the specified upper limit of 1\")\n                .withMessageContaining(\"row 1\")\n                .withMessageContaining(\"first\")\n                .satisfies(exception -> {\n                    org.assertj.core.api.Assertions.assertThat(exception.getMultilineLimit()).isEqualTo(1);\n                    org.assertj.core.api.Assertions.assertThat(exception.getRow()).isEqualTo(1L);\n                    org.assertj.core.api.Assertions.assertThat(exception.getContext()).isEqualTo(\"first\");\n                });\n    }\n\n    private static CSVReader readerFor(String csv) {\n        return new CSVReaderBuilder(new StringReader(csv))\n                .withErrorLocale(Locale.US)\n                .build();\n    }\n}\n"}
