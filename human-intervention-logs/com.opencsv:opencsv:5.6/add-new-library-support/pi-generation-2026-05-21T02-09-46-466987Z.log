  package com_opencsv.opencsv;
  
  import com.opencsv.bean.ConverterNumber;
  import com.opencsv.exceptions.CsvBadConverterException;
  import com.opencsv.exceptions.CsvDataTypeMismatchException;
  import org.junit.jupiter.api.Test;
  
  import java.math.BigDecimal;
  import java.text.FieldPosition;
  import java.text.NumberFormat;
  import java.text.ParseException;
  import java.text.ParsePosition;
  import java.text.spi.NumberFormatProvider;
  import java.util.Locale;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class ConverterNumberTest {
      static {
          System.setProperty("java.locale.providers", "SPI,CLDR");
      }
  
      private static final String TEST_LOCALE = "en-US";
      private static final String TEST_PATTERN = "#,##0.###";
      private static final String INVALID_PATTERN = "0.0.0";
      private static final String SPI_LOCALE_TAG = "zz-ZZ";
      private static final Locale SPI_LOCALE = Locale.forLanguageTag(SPI_LOCALE_TAG);
  
      @Test
      void rejectsNonNumberTypesUsingErrorResourceBundle() {
          assertThatThrownBy(() -> converterFor(String.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, TEST_PATTERN))
                  .isInstanceOf(CsvBadConverterException.class)
                  .hasMessageContaining("Number");
      }
  
      @Test
      void reportsInvalidReadNumberPatternUsingErrorResourceBundle() {
          assertThatThrownBy(() -> converterFor(Integer.class, TEST_LOCALE, TEST_LOCALE, INVALID_PATTERN, TEST_PATTERN))
                  .isInstanceOf(CsvBadConverterException.class)
                  .hasCauseInstanceOf(IllegalArgumentException.class);
      }
  
      @Test
      void reportsInvalidWriteNumberPatternUsingErrorResourceBundle() {
          assertThatThrownBy(() -> converterFor(Integer.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, INVALID_PATTERN))
                  .isInstanceOf(CsvBadConverterException.class)
                  .hasCauseInstanceOf(IllegalArgumentException.class);
      }
  
      @Test
      void reportsUnparsableInputUsingErrorResourceBundle() {
          ConverterNumber converter = converterFor(Integer.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, TEST_PATTERN);
  
          assertThatThrownBy(() -> converter.convertToRead("not-a-number"))
                  .isInstanceOf(CsvDataTypeMismatchException.class)
                  .hasCauseInstanceOf(ParseException.class)
                  .hasMessageContaining("not-a-number");
      }
  
      @Test
      void reportsLocaleNumberFormatThatIsNotDecimalFormatUsingErrorResourceBundle() {
          assertThatThrownBy(() -> converterFor(Integer.class, SPI_LOCALE_TAG, TEST_LOCALE, TEST_PATTERN, TEST_PATTERN))
                  .isInstanceOf(CsvBadConverterException.class)
                  .hasMessageContaining("DecimalFormat");
      }
  
      @Test
      void convertsBigDecimalWithLocalizedPattern() throws CsvDataTypeMismatchException {
          ConverterNumber converter = converterFor(BigDecimal.class, TEST_LOCALE, TEST_LOCALE, TEST_PATTERN, "#,##0.00");
  
          Object converted = converter.convertToRead("1,234.5");
          String formatted = converter.convertToWrite(converted);
  
          assertThat((BigDecimal) converted).isEqualByComparingTo(new BigDecimal("1234.5"));
          assertThat(formatted).isEqualTo("1,234.50");
      }
  
      private static ConverterNumber converterFor(
              Class<?> type,
              String locale,
              String writeLocale,
              String readPattern,
              String writePattern) {
          return new ConverterNumber(type, locale, writeLocale, Locale.US, readPattern, writePattern);
      }
  
      public static final class NonDecimalNumberFormatProvider extends NumberFormatProvider {
          @Override
          public Locale[] getAvailableLocales() {
              return new Locale[] {SPI_LOCALE};
          }
  
          @Override
          public NumberFormat getCurrencyInstance(Locale locale) {
              return new PlainNumberFormat();
          }
  
          @Override
          public NumberFormat getIntegerInstance(Locale locale) {
              return new PlainNumberFormat();
          }
  
          @Override
          public NumberFormat getNumberInstance(Locale locale) {
              return new PlainNumberFormat();
          }
  
          @Override
          public NumberFormat getPercentInstance(Locale locale) {
              return new PlainNumberFormat();
          }
      }
  
      private static final class PlainNumberFormat extends NumberFormat {
          private static final long serialVersionUID = 1L;
  
          @Override
          public StringBuffer format(double number, StringBuffer toAppendTo, FieldPosition pos) {
              return toAppendTo.append(number);
          }
  
          @Override
          public StringBuffer format(long number, StringBuffer toAppendTo, FieldPosition pos) {
              return toAppendTo.append(number);
          }
  
          @Override
          public Number parse(String source, ParsePosition parsePosition) {
              parsePosition.setIndex(source.length());
              return 0;
          }
      }
  }
