      public CsvToBeanBuilder<T> withMappingStrategy(MappingStrategy<? extends T> mappingStrategy) {
          this.mappingStrategy = mappingStrategy;
          return this;
      }
  
      /**
       * @see CsvToBean#setFilter(com.opencsv.bean.CsvToBeanFilter)
