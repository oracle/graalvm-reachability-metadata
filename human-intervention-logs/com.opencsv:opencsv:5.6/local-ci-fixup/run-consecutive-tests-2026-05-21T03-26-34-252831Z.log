tException if the id or typeId is empty\n   301\t     */\n   302\t    private HijrahChronology(String id, String calType) {\n   303\t        if (id.isEmpty()) {\n   304\t            throw new IllegalArgumentException(\"calendar id is empty\");\n   305\t        }\n   306\t        if (calType.isEmpty()) {\n   307\t            throw new IllegalArgumentException(\"calendar typeId is empty\");\n   308\t        }\n   309\t        this.typeId = id;\n   310\t        this.calendarType = calType;\n   311\t    }\n   312\t\n   313\t    /**\n   314\t     * Check and ensure that the calendar data has been initialized.\n   315\t     * The initialization check is performed at the boundary between\n   316\t     * public and package methods.  If a public calls another public method\n   317\t     * a check is not necessary in the caller.\n   318\t     * The constructors of HijrahDate call {@link #getEpochDay} or\n   319\t     * {@link #getHijrahDateInfo} so every call from HijrahDate to a\n   320\t     * HijrahChronology via package private methods has been checked.\n   321\t     *\n   322\t     * @throws DateTimeException if the calendar data configuration is\n   323\t     *     malformed or IOExceptions occur loading the data\n   324\t     */\n   325\t    private void checkCalendarInit() {\n   326\t        // Keep this short so it can be inlined for performance\n   327\t        if (initComplete == false) {\n   328\t            loadCalendarData();\n   329\t            initComplete = true;\n   330\t        }\n   331\t    }\n   332\t\n   333\t    //-----------------------------------------------------------------------\n   334\t    /**\n   335\t     * Gets the ID of the chronology.\n   336\t     * <p>\n   337\t     * The ID uniquely identifies the {@code Chronology}. It can be used to\n   338\t     * lookup the {@code Chronology} using {@link Chronology#of(String)}.\n   339\t     *\n   340\t     * @return the chronology ID, non-null\n   341\t     * @see #getCalendarType()\n   342\t     */\n   343\t    @Override\n   344\t    public String getId() {\n   345\t        return typeId;\n   346\t    }\n   347\t\n   348\t    /**\n   349\t     * Gets the calendar type of the Islamic calendar.\n   350\t     * <p>\n   351\t     * The calendar type is an identifier defined by the\n   352\t     * <em>Unicode Locale Data Markup Language (LDML)</em> specification.\n   353\t     * It can be used to lookup the {@code Chronology} using {@link Chronology#of(String)}.\n   354\t     *\n   355\t     * @return the calendar system type; non-null if the calendar has\n   356\t     *    a standard type, otherwise null\n   357\t     * @see #getId()\n   358\t     */\n   359\t    @Override\n   360\t    public String getCalendarType() {\n   361\t        return calendarType;\n   362\t    }\n   363\t\n   364\t    //-----------------------------------------------------------------------\n   365\t    /**\n   366\t     * Obtains a local date in Hijrah calendar system from the\n   367\t     * era, year-of-era, month-of-year and day-of-month fields.\n   368\t     *\n   369\t     * @param era  the Hijrah era, not null\n   370\t     * @param yearOfEra  the year-of-era\n   371\t     * @param month  the month-of-year\n   372\t     * @param dayOfMonth  the day-of-month\n   373\t     * @return the Hijrah local date, not null\n   374\t     * @throws DateTimeException if unable to create the date\n   375\t     * @throws ClassCastException if the {@code era} is not a {@code HijrahEra}\n   376\t     */\n   377\t    @Override\n   378\t    public HijrahDate date(Era era, int yearOfEra, int month, int dayOfMonth) {\n   379\t        return date(prolepticYear(era, yearOfEra), month, dayOfMonth);\n   380\t    }\n   381\t\n   382\t    /**\n   383\t     * Obtains a local date in Hijrah calendar system from the\n   384\t     * proleptic-year, month-of-year and day-of-month fields.\n   385\t     *\n   386\t     * @param prolepticYear  the proleptic-year\n   387\t     * @param month  the month-of-year\n  