itly.\n   174\t     * Calendars configured via the Thread's context classloader are local\n   175\t     * to that thread and are ignored.\n   176\t     * <p>\n   177\t     * The initialization is done only once using the registration\n   178\t     * of the IsoChronology as the test and the final step.\n   179\t     * Multiple threads may perform the initialization concurrently.\n   180\t     * Only the first registration of each Chronology is retained by the\n   181\t     * ConcurrentHashMap.\n   182\t     * @return true if the cache was initialized\n   183\t     */\n   184\t    private static boolean initCache() {\n   185\t        if (CHRONOS_BY_ID.get(\"ISO\") == null) {\n   186\t            // Initialization is incomplete\n   187\t\n   188\t            // Register built-in Chronologies\n   189\t            registerChrono(HijrahChronology.INSTANCE);\n   190\t            registerChrono(JapaneseChronology.INSTANCE);\n   191\t            registerChrono(MinguoChronology.INSTANCE);\n   192\t            registerChrono(ThaiBuddhistChronology.INSTANCE);\n   193\t\n   194\t            // Register Chronologies from the ServiceLoader\n   195\t            ServiceLoader<AbstractChronology> loader = ServiceLoader.load(AbstractChronology.class, null);\n   196\t            for (AbstractChronology chrono : loader) {\n   197\t                String id = chrono.getId();\n   198\t                if (id.equals(\"ISO\") || registerChrono(chrono) != null) {\n   199\t                    // Log the attempt to replace an existing Chronology\n   200\t                    PlatformLogger logger = PlatformLogger.getLogger(\"java.time.chrono\");\n   201\t                    logger.warning(\"Ignoring duplicate Chronology, from ServiceLoader configuration \"  + id);\n   202\t                }\n   203\t            }\n   204\t\n   205\t            // finally, register IsoChronology to mark initialization is complete\n   206\t            registerChrono(IsoChronology.INSTANCE);\n   207\t            return true;\n   208\t        }\n   209\t        return false;\n   210\t    }\n   211\t\n   212\t    //-----------------------------------------------------------------------\n   213\t    /**\n   214\t     * Obtains an instance of {@code Chronology} from a locale.\n   215\t     * <p>\n   216\t     * See {@link Chronology#ofLocale(Locale)}.\n   217\t     *\n   218\t     * @param locale  the locale to use to obtain the calendar system, not null\n   219\t     * @return the calendar system associated with the locale, not null\n   220\t     * @throws java.time.DateTimeException if the locale-specified calendar cannot be found\n   221\t     */\n   222\t    static Chronology ofLocale(Locale locale) {\n   223\t        Objects.requireNonNull(locale, \"locale\");\n   224\t        String type = locale.getUnicodeLocaleType(\"ca\");\n   225\t        if (type == null || \"iso\".equals(type) || \"iso8601\".equals(type)) {\n   226\t            return IsoChronology.INSTANCE;\n   227\t        }\n   228\t        // Not pre-defined; lookup by the type\n   229\t        do {\n   230\t            Chronology chrono = CHRONOS_BY_TYPE.get(type);\n","exit_code":0,"status":"completed"}}
