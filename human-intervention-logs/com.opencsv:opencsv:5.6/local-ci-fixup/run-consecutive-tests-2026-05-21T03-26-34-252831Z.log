E ARE DISCLAIMED. IN NO EVENT SHALL THE COPYRIGHT OWNER OR\n    49\t * CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT, INCIDENTAL, SPECIAL,\n    50\t * EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,\n    51\t * PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR\n    52\t * PROFITS; OR BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF\n    53\t * LIABILITY, WHETHER IN CONTRACT, STRICT LIABILITY, OR TORT (INCLUDING\n    54\t * NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE USE OF THIS\n    55\t * SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n    56\t */\n    57\t\n    58\tpackage java.time.chrono;\n    59\t\n    60\timport static java.time.temporal.ChronoField.EPOCH_DAY;\n    61\t\n    62\timport java.io.IOException;\n    63\timport java.io.InputStream;\n    64\timport java.io.InvalidObjectException;\n    65\timport java.io.ObjectInputStream;\n    66\timport java.io.Serializable;\n    67\timport java.nio.file.Files;\n    68\timport java.nio.file.Path;\n    69\timport java.nio.file.StandardOpenOption;\n    70\timport java.time.Clock;\n    71\timport java.time.DateTimeException;\n    72\timport java.time.Instant;\n    73\timport java.time.LocalDate;\n    74\timport java.time.ZoneId;\n    75\timport java.time.format.ResolverStyle;\n    76\timport java.time.temporal.ChronoField;\n    77\timport java.time.temporal.TemporalAccessor;\n    78\timport java.time.temporal.TemporalField;\n    79\timport java.time.temporal.ValueRange;\n    80\timport java.util.Arrays;\n    81\timport java.util.HashMap;\n    82\timport java.util.List;\n    83\timport java.util.Map;\n    84\timport java.util.Properties;\n    85\timport java.util.stream.Stream;\n    86\t\n    87\timport jdk.internal.util.StaticProperty;\n    88\timport sun.util.logging.PlatformLogger;\n    89\t\n    90\t/**\n    91\t * The Hijrah calendar is a lunar calendar supporting Islamic calendars.\n    92\t * <p>\n    93\t * The HijrahChronology follows the rules of the Hijrah calendar system. The Hijrah\n    94\t * calendar has several variants based on differences in when the new moon is\n    95\t * determined to have occurred and where the observation is made.\n    96\t * In some variants the length of each month is\n    97\t * computed algorithmically from the astronomical data for the moon and earth and\n    98\t * in others the length of the month is determined by an authorized sighting\n    99\t * of the new moon. For the algorithmically based calendars the calendar\n   100\t * can project into the future.\n   101\t * For sighting based calendars only historical data from past\n   102\t * sightings is available.\n   103\t * <p>\n   104\t * The length of each month is 29 or 30 days.\n   105\t * Ordinary years have 354 days; leap years have 355 days.\n   106\t *\n   107\t * <p>\n   108\t * CLDR and LDML identify variants:\n   109\t * <table class=\"striped\" style=\"text-align:left\">\n   110\t * <caption style=\"display:none\">Variants of Hijrah Calendars</caption>\n   111\t * <thead>\n   112\t * <tr>\n   113\t * <th scope=\"col\">Chronology ID</th>\n   114\t * <th scope=\"col\">Calendar Type</th>\n   115\t * <th scope=\"col\">Locale extension, see {@link java.util.Locale}</th>\n   116\t * <th scope=\"col\">Description</th>\n   117\t * </tr>\n   118\t * </thead>\n   119\t * <tbody>\n   120\t * <tr>\n   121\t * <th scope=\"row\">Hijrah-umalqura</th>\n   122\t * <td>islamic-umalqura</td>\n   123\t * <td>ca-islamic-umalqura</td>\n   124\t * <td>Islamic - Umm Al-Qura calendar of Saudi Arabia</td>\n   125\t * </tr>\n   126\t * </tbody>\n   127\t * </table>\n   128\t * <p>Additional variants may be available through {@link Chronology#getAvailableChronologies()}.\n   129\t *\n   130\t * <p>Example</p>\n   131\t * <p>\n   132\t * Selecting the chronology from the locale uses {@link Chronology#ofLocale}\n   133\t * to find the Chronology based on Locale supported BCP 47 extension mechanism\n   134\t * to request a specific calendar (\"ca\"). For example,\n   135\t * </p>\n   136\t * <pre>\n   137\t *      Locale locale = Locale.forLanguageTag(\"en-US-u-ca-islamic-umalqura\");\n   138\t *      Chronology chrono = Chronology.ofLocale(locale);\n   139\t * </pre>\n   140\t *\n   141\t * @implSpec\n   142\t * This class is immutable and thread-safe.\n   143\t *\n   144\t * @implNote\n   145\t * Each Hijrah variant is configured individually. Each variant is defined by a\n   146\t * property resource that defines the {@code ID}, the {@code calendar type},\n   147\t * the start of the calendar, the alignment with the\n   148\t * ISO calendar, and the length of each month for a range of years.\n   149\t * The variants are loaded by HijrahChronology as a resource from\n   150\t * hijrah-config-&lt;calendar type&gt;.properties.\n   151\t * <p>\n   152\t * The Hijrah property resource is a set of properties that describe the calendar.\n   153\t * The syntax is defined by {@code java.util.Properties#load(Reader)}.\n   154\t * <table class=\"striped\" style=\"text-align:left\">\n   155\t * <caption style=\"display:none\">Configuration of Hijrah Calendar</caption>\n   156\t * <thead>\n   157\t * <tr>\n   158\t * <th scope=\"col\">Property Name</th>\n   159\t * <th scope=\"col\">Property value</th>\n   160\t * <th scope=\"col\">Description</th>\n   161\t * </tr>\n   162\t * </thead>\n   163\t * <tbody>\n   164\t * <tr>\n   165\t * <th scope=\"row\">id</th>\n   166\t * <td>Chronology Id, for example, \"Hijrah-umalqura\"</td>\n   167\t * <td>The Id of the calendar in common usage</td>\n   168\t * </tr>\n   169\t * <tr>\n   170\t * <th scope=\"row\">type</th>\n   171\t * <td>Calendar type, for example, \"islamic-umalqura\"</td>\n   172\t * <td>LDML defines the calendar types</td>\n   173\t * </tr>\n   174\t * <tr>\n   175\t * <th scope=\"row\">version</th>\n   176\t * <td>Version, for example: \"1.8.0_1\"</td>\n   177\t * <td>The version of the Hijrah variant data</td>\n   178\t * </tr>\n   179\t * <tr>\n   180\t * <th scope=\"row\">iso-start</th>\n   181\t * <td>ISO start date, formatted as {@code yyyy-MM-dd}, for example: \"1900-04-30\"</td>\n   182\t * <td>The ISO date of the first day of the minimum Hijrah year.</td>\n   183\t * </tr>\n   184\t * <tr>\n   185\t * <th scope=\"row\">yyyy - a numeric 4 digit year, for example \"1434\"</th>\n   186\t * <td>The value is a sequence of 12 month lengths,\n   187\t * for example: \"29 30 29 30 29 30 30 30 29 30 29 29\"</td>\n   188\t * <td>The lengths of the 12 months of the year separated by whitespace.\n   189\t * A numeric year property must be present for every year without any gaps.\n   190\t * The month lengths must be between 29-32 inclusive.\n   191\t * </td>\n   192\t * </tr>\n   193\t * </tbody>\n   194\t * </table>\n   195\t * <p>\n   196\t * Additional variants may be added by providing configuration properties files in\n   197\t * {@code <JAVA_HOME>/conf/chronology} directory. The properties\n   198\t * files should follow the naming convention of\n   199\t * {@code hijrah-config-<chronology id>_<calendar type>.properties}.\n   200\t *\n   201\t * @since 1.8\n   202\t */\n   203\tpublic final class HijrahChronology extends AbstractChronology implements Serializable {\n   204\t\n   205\t    /**\n   206\t     * The Hijrah Calendar id.\n   207\t     */\n   208\t    private final transient String typeId;\n   209\t    /**\n   210\t     * The Hijrah calendarType.\n   211\t     */\n   212\t    private final transient String calendarType;\n   213\t    /**\n   214\t     * Serialization version.\n   215\t     */\n   216\t    @java.io.Serial\n   217\t    private static final long serialVersionUID = 3127340209035924785L;\n   218\t    /**\n   219\t     * Singleton instance of the Islamic Umm Al-Qura calendar of Saudi Arabia.\n   220\t     * Other Hijrah chronology variants may be available from\n   221\t     * {@link Chronology#getAvailableChronologies}.\n   222\t     */\n   223\t    public static final HijrahChronology INSTANCE;\n   224\t    /**\n   225\t     * Flag to indicate the initialization of configuration data is complete.\n   226\t     * @see #checkCalendarInit()\n   227\t     */\n   228\t    private transient volatile boolean initComplete;\n   229\t    /**\n   230\t     * Array of epoch days indexed by Hijrah Epoch month.\n   231\t     * Computed by {@link #loadCalendarData}.\n   232\t     */\n   233\t    private transient int[] hijrahEpochMonthStartDays;\n   234\t    /**\n   235\t     * The minimum epoch day of this Hijrah calendar.\n   236\t     * Computed by {@link #loadCalendarData}.\n   237\t     */\n   238\t    private transient int minEpochDay;\n   239\t    /**\n   240\t     * The maximum epoch day for which calendar data is available.\n   241\t     * Computed by {@link #loadCalendarData}.\n   242\t     */\n   243\t    private transient int maxEpochDay;\n   244\t    /**\n   245\t     * The minimum epoch month.\n   246\t     * Computed by {@link #loadCalendarData}.\n   247\t     */\n   248\t    private transient int hijrahStartEpochMonth;\n   249\t    /**\n   250\t     * The minimum length of a month.\n   251\t     * Computed by {@link #createEpochMonths}.\n   252\t     */\n   253\t    private transient int minMonthLength;\n   254\t    /**\n   255\t     * The maximum length of a month.\n   256\t     * Computed by {@link #createEpochMonths}.\n   257\t     */\n   258\t    private transient int maxMonthLength;\n   259\t    /**\n   260\t     * The minimum length of a year in days.\n","exit_code":0,"status":"completed"}}
