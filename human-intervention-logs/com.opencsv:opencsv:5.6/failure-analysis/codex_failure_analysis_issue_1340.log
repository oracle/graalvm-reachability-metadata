                   if (delimiterPos > 1 && delimiterPos < idtype.length() - 1) {\\n  1029\\t                            AbstractChronology.registerChrono(\\n  1030\\t                                new HijrahChronology(\\n  1031\\t                                        idtype.substring(0, delimiterPos),\\n  1032\\t                                        idtype.substring(delimiterPos + 1)));\\n  1033\\t                        } else {\\n  1034\\t                            PlatformLogger.getLogger(\\\"java.time.chrono\\\")\\n  1035\\t                                    .warning(\\\"Hijrah custom config init failed.\\\" +\\n  1036\\t                                            \\\"'<id>_<type>' name convention not followed: \\\" + idtype);\\n  1037\\t                        }\\n  1038\\t                    });\\n  1039\\t            } catch (IOException e) {\\n  1040\\t                PlatformLogger.getLogger(\\\"java.time.chrono\\\")\\n  1041\\t                        .warning(\\\"Hijrah custom config init failed.\\\", e);\\n  1042\\t            }\\n  1043\\t        }\\n  1044\\t    }\\n  1045\\t\\n  1046\\t    //-----------------------------------------------------------------------\\n  1047\\t    /**\\n  1048\\t     * Writes the Chronology using a\\n  1049\\t     * <a href=\\\"{@docRoot}/serialized-form.html#java.time.chrono.Ser\\\">dedicated serialized form</a>.\\n  1050\\t     * @serialData\\n  1051\\t     * <pre>\\n  1052\\t     *  out.writeByte(1);     // identifies a Chronology\\n  1053\\t     *  out.writeUTF(getId());\\n  1054\\t     * </pre>\\n  1055\\t     *\\n  1056\\t     * @return the instance of {@code Ser}, not null\\n  1057\\t     */\\n  1058\\t    @Override\\n  1059\\t    @java.io.Serial\\n  1060\\t    Object writeReplace() {\\n  1061\\t        return super.writeReplace();\\n  1062\\t    }\\n  1063\\t\\n  1064\\t    /**\\n  1065\\t     * Defend against malicious streams.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/home/vjovanov/c/forge/forge2/g