soFields;\\n    80\\timport java.time.temporal.TemporalAccessor;\\n    81\\timport java.time.temporal.TemporalAdjusters;\\n    82\\timport java.time.temporal.TemporalField;\\n    83\\timport java.time.temporal.UnsupportedTemporalTypeException;\\n    84\\timport java.time.temporal.ValueRange;\\n    85\\timport java.util.Calendar;\\n    86\\timport java.util.List;\\n    87\\timport java.util.Locale;\\n    88\\timport java.util.Map;\\n    89\\t\\n    90\\timport sun.util.calendar.CalendarSystem;\\n    91\\timport sun.util.calendar.LocalGregorianCalendar;\\n    92\\t\\n    93\\t/**\\n    94\\t * The Japanese Imperial calendar system.\\n    95\\t * <p>\\n    96\\t * This chronology defines the rules of the Japanese Imperial calendar system.\\n    97\\t * This calendar system is primarily used in Japan.\\n    98\\t * The Japanese Imperial calendar system is the same as the ISO calendar system\\n    99\\t * apart from the era-based year numbering.\\n   100\\t * <p>\\n   101\\t * Japan introduced the Gregorian calendar starting with Meiji 6.\\n   102\\t * Only Meiji and later eras are supported;\\n   103\\t * dates before Meiji 6, January 1 are not supported.\\n   104\\t * <p>\\n   105\\t * The supported {@code ChronoField} instances are:\\n   106\\t * <ul>\\n   107\\t * <li>{@code DAY_OF_WEEK}\\n   108\\t * <li>{@code DAY_OF_MONTH}\\n   109\\t * <li>{@code DAY_OF_YEAR}\\n   110\\t * <li>{@code EPOCH_DAY}\\n   111\\t * <li>{@code MONTH_OF_YEAR}\\n   112\\t * <li>{@code PROLEPTIC_MONTH}\\n   113\\t * <li>{@code YEAR_OF_ERA}\\n   114\\t * <li>{@code YEAR}\\n   115\\t * <li>{@code ERA}\\n   116\\t * </ul>\\n   117\\t *\\n   118\\t * @implSpec\\n   119\\t * This class is immutable and thread-safe.\\n   120\\t *\\n   121\\t * @since 1.8\\n   122\\t */\\n   123\\tpublic final class JapaneseChronology extends AbstractChronology implements Serializable {\\n   124\\t\\n   125\\t    static final LocalGregorianCalendar JCAL =\\n   126\\t        (LocalGregorianCalendar) CalendarSystem.forName(\\\"japanese\\\");\\n   127\\t\\n   128\\t    // Locale for creating a JapaneseImperialCalendar.\\n   129\\t    static final Locale LOCALE = Locale.forLanguageTag(\\\"ja-JP-u-ca-japanese\\\");\\n   130\\t\\n   131\\t    /**\\n   132\\t     * Singleton instance for Japanese chronology.\\n   133\\t     */\\n   134\\t    public static final JapaneseChronology INSTANCE = new JapaneseChronology();\\n   135\\t\\n   136\\t    /**\\n   137\\t     * Serialization version.\\n   138\\t     */\\n   139\\t    @java.io.Serial\\n   140\\t    private static final long serialVersionUID = 459996390165777884L;\\n   141\\t\\n   142\\t    //-----------------------------------------------------------------------\\n   143\\t    /**\\n   144\\t     * Restricted constructor.\\n   145\\t     */\\n   146\\t    private JapaneseChronology() {\\n   147\\t    }\\n   148\\t\\n   149\\t    //-----------------------------------------------------------------------\\n   150\\t    /**\\n   151\\t     * Gets the ID of the chronology - 'Japanese'.\\n   152\\t     * <p>\\n   153\\t     * The ID uniquely identifies the {@code Chronology}.\\n   154\\t     * It can be used to lookup the {@code Chronology} using {@link Chronology#of(String)}.\\n   155\\t     *\\n   156\\t     * @return the chronology ID - 'Japanese'\\n   157\\t     * @see #getCalendarType()\\n   158\\t     */\\n   159\\t    @Override\\n   160\\t    public String getId() {\\n   161\\t        return \\\"Japanese\\\";\\n   162\\t    }\\n   163\\t\\n   164\\t    /**\\n   165\\t     * Gets the calendar type of the underlying calendar system - 'japanese'.\\n   166\\t     * <p>\\n   167\\t     * The calendar type is an identifier defined by the\\n   168\\t     * <em>Unicode Locale Data Markup Language (LDML)</em> specification.\\n   169\\t     * It can be used to lookup the {@code Chronology} using {@link Chronology#of(String)}.\\n   170\\t     * It can also be used as part of a locale, accessible via\\n   171\\t     * {@link Locale#getUnicodeLocaleType(String)} with the key 'ca'.\\n   172\\t     *\\n   173\\t     * @return the calendar system type - 'japanese'\\n   174\\t     * @see #getId()\\n   175\\t     */\\n   176\\t    @Override\\n   177\\t    public String getCalendarType() {\\n   178\\t        return \\\"japanese\\\";\\n   179\\t    }\\n   180\\t\\n   181\\t    //-----------------------------------------------------------------------\\n   182\\t    /**\\n   183\\t     * Obtains a local date in Japanese calendar system from the\\n   184\\t     * era, year-of-era, month-of-year and day-of-month fields.\\n   185\\t     * <p>\\n   186\\t     * The Japanese month and day-of-month are the same as those in the\\n   187\\t     * ISO calendar system. They are not reset when the era changes.\\n   188\\t     * For example:\\n   189\\t     * <pre>\\n   190\\t     *  6th Jan Showa 64 = ISO 1989-01-06\\n   191\\t     *  7th Jan Showa 64 = ISO 1989-01-07\\n   192\\t     *  8th Jan Heisei 1 = ISO 1989-01-08\\n   193\\t     *  9th Jan Heisei 1 = ISO 1989-01-09\\n   194\\t     * </pre>\\n   195\\t     *\\n   196\\t     * @param era  the Japanese era, not null\\n   197\\t     * @param yearOfEra  the year-of-era\\n   198\\t     * @param month  the month-of-year\\n   199\\t     * @param dayOfMonth  the day-of-month\\n   200\\t     * @return the Japanese local date, not null\\n   201\\t     * @throws DateTimeException if unable to create the date\\n   202\\t     * @throws ClassCastException if the {@code era} is not a {@code JapaneseEra}\\n   203\\t     */\\n   204\\t    @Override\\n   205\\t    public JapaneseDate date(Era era, int yearOfEra, int month, int dayOfMonth) {\\n   206\\t        if (!(era instanceof JapaneseEra jera)) {\\n   207\\t            throw new ClassCastException(\\\"Era must be JapaneseEra\\\");\\n   208\\t        }\\n   209\\t        return JapaneseDate.of(jera, yearOfEra, month, dayOfMonth);\\n   210\\t    }\\n   211\\t\\n   212\\t    /**\\n   213\\t     * Obtains a local date in Japanese cal