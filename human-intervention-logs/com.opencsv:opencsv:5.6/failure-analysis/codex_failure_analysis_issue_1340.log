EPOCH_DAY;\\n    61\\t\\n    62\\timport java.io.IOException;\\n    63\\timport java.io.InputStream;\\n    64\\timport java.io.InvalidObjectException;\\n    65\\timport java.io.ObjectInputStream;\\n    66\\timport java.io.Serializable;\\n    67\\timport java.nio.file.Files;\\n    68\\timport java.nio.file.Path;\\n    69\\timport java.nio.file.StandardOpenOption;\\n    70\\timport java.time.Clock;\\n    71\\timport java.time.DateTimeException;\\n    72\\timport java.time.Instant;\\n    73\\timport java.time.LocalDate;\\n    74\\timport java.time.ZoneId;\\n    75\\timport java.time.format.ResolverStyle;\\n    76\\timport java.time.temporal.ChronoField;\\n    77\\timport java.time.temporal.TemporalAccessor;\\n    78\\timport java.time.temporal.TemporalField;\\n    79\\timport java.time.temporal.ValueRange;\\n    80\\timport java.util.Arrays;\\n    81\\timport java.util.HashMap;\\n    82\\timport java.util.List;\\n    83\\timport java.util.Map;\\n    84\\timport java.util.Properties;\\n    85\\timport java.util.stream.Stream;\\n    86\\t\\n    87\\timport jdk.internal.util.StaticProperty;\\n    88\\timport sun.util.logging.PlatformLogger;\\n    89\\t\\n    90\\t/**\\n    91\\t * The Hijrah calendar is a lunar calendar supporting Islamic calendars.\\n    92\\t * <p>\\n    93\\t * The HijrahChronology follows the rules of the Hijrah calendar system. The Hijrah\\n    94\\t * calendar has several variants based on differences in when the new moon is\\n    95\\t * determined to have occurred and where the observation is made.\\n    96\\t * In some variants the length of each month is\\n    97\\t * computed algorithmically from the astronomical data for the moon and earth and\\n    98\\t * in others the length of the month is determined by an authorized sighting\\n    99\\t * of the new moon. For the algorithmically based calendars the calendar\\n   100\\t * can project into the future.\\n   101\\t * For sighting based calendars only historical data from past\\n   102\\t * sightings is available.\\n   103\\t * <p>\\n   104\\t * The length of each month is 29 or 30 days.\\n   105\\t * Ordinary years have 354 days; leap years have 355 days.\\n   106\\t *\\n   107\\t * <p>\\n   108\\t * CLDR and LDML identify variants:\\n   109\\t * <table class=\\\"striped\\\" style=\\\"text-align:left\\\">\\n   110\\t * <caption style=\\\"display:none\\\">Variants of Hijrah Calendars</caption>\\n   111\\t * <thead>\\n   112\\t * <tr>\\n   113\\t * <th scope=\\\"col\\\">Chronology ID</th>\\n   114\\t * <th scope=\\\"col\\\">Calendar Type</th>\\n   115\\t * <th scope=\\\"col\\\">Locale extension, see {@link java.util.Locale}</th>\\n   116\\t * <th scope=\\\"col\\\">Description</th>\\n   117\\t * </tr>\\n   118\\t * </thead>\\n   119\\t * <tbody>\\n   120\\t * <tr>\\n   121\\t * <th scope=\\\"row\\\">Hijrah-umalqura</th>\\n   122\\t * <td>islamic-umalqura</td>\\n   123\\t * <td>ca-islamic-umalqura</td>\\n   124\\t * <td>Islamic - Umm Al-Qura calendar of Saudi Arabia</td>\\n   125\\t * </tr>\\n   126\\t * </tbody>\\n   127\\t * </table>\\n   128\\t * <p>Additional variants may be available through {@link Chronology#getAvailableChronologies()}.\\n   129\\t *\\n   130\\t * <p>Example</p>\\n   131\\t * <p>\\n   132\\t * Selecting the chronology from the locale uses {@link Chronology#ofLocale}\\n   133\\t * to find the Chronology based on Locale supported BCP 47 extension mechanism\\n   134\\t * to request a specific calendar (\\\"ca\\\"). For example,\\n   135\\t * </p>\\n   136\\t * <pre>\\n   137\\t *      Locale locale = Locale.forLanguageTag(\\\"en-US-u-ca-islamic-umalqura\\\");\\n   138\\t *      Chronology chrono = Chronology.ofLocale(locale);\\n   139\\t * </pre>\\n   140\\t *\\n   141\\t * @implSpec\\n   142\\t * This class is immutable and thread-safe.\\n   143\\t *\\n   144\\t * @implNote\\n   145\\t * Each Hijrah variant is configured individually. Each variant is defined by a\\n   146\\t * property resource that defines the {@code ID}, the {@code calendar type},\\n   147\\t * the start of the calendar, the alignment with the\\n   148\\t * ISO calendar, and the length of each month for a range of years.\\n   149\\t * The variants are loaded by HijrahChronology as a resource from\\n   150\\t * hijrah-config-&lt;calendar type&gt;.properties.\\n   151\\t * <p>\\n   152\\t * The Hijrah property resource is a set of properties that describe the calendar.\\n   153\\t * The syntax is defined by {@code java.util.Properties#load(Reader)}.\\n   154\\t * <table class=\\\"striped\\\" style=\\\"text-align:left\\\">\\n   155\\t * <caption style=\\\"display:none\\\">Configuration of Hijrah Calendar</caption>\\n   156\\t * <thead>\\n   157\\t * <tr>\\n   158\\t * <th scope=\\\"col\\\">Property Name</th>\\n   159\\t * <th scope=\\\"col\\\">Property value</th>\\n   160\\t * <th scope=\\\"col\\\">Description</th>\\n   161\\t * </tr>\\n   162\\t * </thead>\\n   163\\t * <tbody>\\n   164\\t * <tr>\\n   165\\t * <th scope=\\\"row\\\">id</th>\\n   166\\t * <td>Chronology Id, for example, \\\"Hijrah-umalqura\\\"</td>\\n   167\\t * <td>The Id of the calendar in common usage</td>\\n   168\\t * </tr>\\n   169\\t * <tr>\\n   170\\t * <th scope=\\\"row\\\">type</th>\\n   171\\t * <td>Calendar type, for example, \\\"islamic-umalqura\\\"</td>\\n   172\\t * <td>LDML defines the calendar types</td>\\n   173\\t * </tr>\\n   174\\t * <tr>\\n   175\\t * <th scope=\\\"row\\\">version</th>\\n   176\\t * <td>Version, for example: \\\"1.8.0_1\\\"</td>\\n   177\\t * <td>The version of the Hijrah variant data</td>\\n   178\\t * </tr>\\n   179\\t * <tr>\\n   180\\t * <th scope=\\\"row\\\">iso-start</th>\\n   181\\t * <td>ISO start date, formatted as {@code yyyy-MM-dd}, for example: \\\"1900-04-30\\\"</td>\\n   182\\t * <td>The ISO date of the first day of the minimum Hijrah year.</td>\\n   183\\t * </tr>\\n   184\\t * <tr>\\n   185\\t * <th scope=\\\"row\\\">yyyy - a numeric 4 digit year, for example \\\"1434\\\"</th>\\n   186\\t * <td>The value is a sequence of 12 month lengths,\\n   187\\t * for example: \\\"29 30 29 30 29 30 30 30 29 30 29 29\\\"</td>\\n   188\\t * <td>The lengths of the 12 months of the year separated by whitespace.\\n   189\\t * A numeric year property must be present for every year without any gaps.\\n   190\\t * The month lengths must be between 29-32 inclusive.\\n   191\\t * </td>\\n   192\\t * </tr>\\n   193\\t * </tbody>\\n   194\\t * </table>\\n   195\\t * <p>\\n   196\\t * Additional variants may be added by providing configuration properties files in\\n   197\\t * {@code <JAVA_HOME>/conf/chronology} directory. The properties\\n   198\\t * files should follow the naming convention of\\n   199\\t * {@code hijrah-config-<chronology id>_<calendar type>.properties}.\\n   200\\t *\\n   201\\t * @since 1.8\\n   202\\t */\\n   203\\tpublic final class HijrahChronology extends AbstractChronology implements Serializable {\\n   204\\t\\n   205\\t    /**\\n   206\\t     * The Hijrah Calendar id.\\n   207\\t     */\\n   208\\t    private final transient String typeId;\\n   209\\t    /**\\n   210\\t     * The Hijrah calendarType.\\n   211\\t     */\\n   212\\t    private final transient String calendarType;\\n   213\\t    /**\\n   214\\t     * Serialization version.\\n   215\\t     */\\n   216\\t    @java.io.Serial\\n   217\\t    private static final long serialVersionUID = 3127340209035924785L;\\n   218\\t    /**\\n   219\\t     * Singleton instance of the Islamic Umm Al-Qura calendar of Saudi Arabia.\\n   220\\t     * Other Hijrah chronology variants may be available from\\n   221\\t     * {@link Chronology#getAvailableChronologies}.\\n   222\\t     */\\n   223\\t    public static final HijrahChronology INSTANCE;\\n   224\\t    /**\\n   225\\t     * Flag to indicate the initialization of configuration data is complete.\\n   226\\t     * @see #checkCalendarInit()\\n   227\\t     */\\n   228\\t    private transient volatile boolean initComplete;\\n   229\\t    /**\\n   230\\t     * Array of epoch days indexed by Hijrah Epoch month.\\n   231\\t     * Computed by {@link #loadCalendarData}.\\n   232\\t     */\\n   233\\t    private transient int[] hijrahEpochMonthStartDays;\\n   234\\t    /**\\n   235\\t     * The minimum epoch day of this Hijrah calendar.\\n   236\\t     * Computed by {@link #loadCalendarData}.\\n   237\\t     */\\n   238\\t    private transient int minEpochDay;\\n   239\\t    /**\\n   240\\t     * The maximum epoch day for which calendar data is available.\\n   241\\t     * Computed by {@link #loadCalendarData}.\\n   242\\t     */\\n   243\\t    private transient int maxEpochDay;\\n   244\\t    /**\\n   245\\t     * The minimum epoch month.\\n   246\\t     * Computed by {@link #loadCalendarData}.\\n   247\\t     */\\n   248\\t    private transient int hijrahStartEpochMonth;\\n   249\\t    /**\\n   250\\t     * The minimum length of a month.\\n   251\\t     * Computed by {@link #createEpochMonths}.\\n   252\\t     */\\n   253\\t    private transient int minMonthLength;\\n   254\\t    /**\\n   255\\t     * The maximum length of a month.\\n   256\\t     * Computed by {@link #createEpochMonths}.\\n   257\\t     */\\n   258\\t    private transient int maxMonthLength;\\n   259\\t    /**\\n   260\\t     * The minimum length of a year in days.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/logs/com.opencsv:opencsv:5.6/local-ci-fixup/run-consecutive-tests-2026-05-21T03-26-34-252831Z.log:103:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_53\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'SRC_ZIP=/home/vjovanov/gdrive/bin/graalvm-jdk-25.0.3+9.1/lib/src.zip; unzip -p \\\"$SRC_ZIP\\\" java.base/java/time/chrono/AbstractChronology.java | nl -ba | sed -n '\\\"'140,230p'\\\"\",\"aggregated_output\":\"   140\\t     * Specifically, not in the constructor of Chronology.\\n   141\\t     *\\n   142\\t     * @param chrono the chronology to register; not null\\n   143\\t     * @return the already registered Chronology if any, may be null\\n   144\\t     */\\n   145\\t    static Chronology registerChrono(Chronology chrono) {\\n   146\\t        return registerChrono(chrono, chrono.getId());\\n   147\\t    }\\n   148\\t\\n   149\\t    /**\\n   150\\t     * Register a Chronology by ID and type for lookup by {@link #of(String)}.\\n   151\\t     * Chronos must not be registered until they are completely constructed.\\n   152\\t     * Specifically, not in the constructor of Chronology.\\n   153\\t     *\\n   154\\t     * @param chrono the chronology to register; not null\\n   155\\t     * @param id the ID to register the chronology; not null\\n   156\\t     * @return the already registered Chronology if any, may be null\\n   157\\t     */\\n   158\\t    static Chronology registerChrono(Chronology chrono, String id) {\\n   159\\t        Chronology prev = CHRONOS_BY_ID.putIfAbsent(id, chrono);\\n   160\\t        if (prev == null) {\\n   161\\t            String type = chrono.getCalendarType();\\n   162\\t            if (type != null) {\\n   163\\t                CHRONOS_BY_TYPE.putIfAbsent(type, chrono);\\n   164\\t            }\\n   165\\t        }\\n   166\\t        return prev;\\n   167\\t    }\\n   168\\t\\n   169\\t    /**\\n   170\\t     * Initialization of the maps from id and type to Chronology.\\n   171\\t     * The ServiceLoader is used to find and register any implementations\\n   172\\t     * of {@link java.time.chrono.AbstractChronology} found in the bootclass loader.\\n   173\\t     * The built-in chronologies are registered explicitly.\\n   174\\t     * Calendars configured via the Thread's context classloader are local\\n   175\\t     * to that thread and are ignored.\\n   176\\t     * <p>\\n   177\\t     * The initialization is done only once using the registration\\n   178\\t     * of the IsoChronology as the test and the final step.\\n   179\\t     * Multiple threads may perform the initialization concurrently.\\n   180\\t     * Only the first registration of each Chronology is retained by the\\n   181\\t     * ConcurrentHashMap.\\n   182\\t     * @return true if the cache was initialized\\n   183\\t     */\\n   184\\t    private static boolean initCache() {\\n   185\\t        if (CHRONOS_BY_ID.get(\\\"ISO\\\") == null) {\\n   186\\t            // Initialization is incomplete\\n   187\\t\\n   188\\t            // Register built-in Chronologies\\n   189\\t            registerChrono(HijrahChronology.INSTANCE);\\n   190\\t            registerChrono(JapaneseChronology.INSTANCE);\\n   191\\t            registerChrono(MinguoChronology.INSTANCE);\\n   192\\t            registerChrono(ThaiBuddhistChronology.INSTANCE);\\n   193\\t\\n   194\\t            // Register Chronologies from the ServiceLoader\\n   195\\t            ServiceLoader<AbstractChronology> loader = ServiceLoader.load(AbstractChronology.class, null);\\n   196\\t            for (AbstractChronology chrono : loader) {\\n   197\\t                String id = chrono.getId();\\n   198\\t                if (id.equals(\\\"ISO\\\") || registerChrono(chrono) != null) {\\n   199\\t                    // Log the attempt to replace an existing Chronology\\n   200\\t                    PlatformLogger logger = PlatformLogger.getLogger(\\\"java.time.chrono\\\");\\n   201\\t                    logger.warning(\\\"Ignoring duplicate Chronology, from ServiceLoader configuration \\\"  + id);\\n   202\\t                }\\n   203\\t            }\\n   204\\t\\n   205\\t            // finally, register IsoChronology to mark initialization is complete\\n   206\\t            registerChrono(IsoChronology.INSTANCE);\\n   207\\t            return true;\\n   208\\t        }\\n   209\\t        return false;\\n   210\\t    }\\n   211\\t\\n   212\\t    //-----------------------------------------------------------------------\\n   213\\t    /**\\n   214\\t     * Obtains an instance of {@code Chronology} from a locale.\\n   215\\t     * <p>\\n   216\\t     * See {@link Chronology#ofLocale(Locale)}.\\n   217\\t     *\\n   218\\t     * @param locale  the locale to use to obtain the calendar system, not null\\n   219\\t     * @return the calendar system associated with the locale, not null\\n   220\\t     * @throws java.time.DateTimeException if the locale-specified calendar cannot be found\\n   221\\t     */\\n   222\\t    static Chronology ofLocale(Locale locale) {\\n   223\\t        Objects.requireNonNull(locale, \\\"locale\\\");\\n   224\\t        String type = locale.getUnicodeLocaleType(\\\"ca\\\");\\n   225\\t        if (type == null || \\\"iso\\\".equals(type) || \\\"iso8601\\\".equals(type)) {\\n   226\\t            return IsoChronology.INSTANCE;\\n   227\\t        }\\n   228\\t        // Not pre-defined; lookup by the type\\n   229\\t        do {\\n   230\\t            Chronology chrono = CHRONOS_BY_TYPE.get(type);\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/logs/com.opencsv:opencsv:5.6/local-ci-fixup/run-consecutive-tests-2026-05-21T03-26-34-252831Z.log:105:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_55\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'SRC_ZIP=/home/vjovanov/gdrive/bin/graalvm-jdk-25.0.3+9.1/lib/src.zip; unzip -p \\\"$SRC_ZIP\\\" java.base/java/time/chrono/HijrahChronology.java | nl -ba | rg -n '\\\"'INSTANCE|hijrah-config|calendarProperties|loadCalendarData|Resource|Properties|conf/chronology'\\\"\",\"aggregated_output\":\"84:    84\\timport java.util.Properties;\\n150:   150\\t * hijrah-config-&lt;calendar type&gt;.properties.\\n153:   153\\t * The syntax is defined by {@code java.util.Properties#load(Reader)}.\\n197:   197\\t * {@code <JAVA_HOME>/conf/chronology} directory. The properties\\n199:   199\\t * {@code hijrah-config-<chronology id>_<calendar type>.properties}.\\n223:   223\\t    public static final HijrahChronology INSTANCE;\\n231:   231\\t     * Computed by {@link #loadCalendarData}.\\n236:   236\\t     * Computed by {@link #loadCalendarData}.\\n241:   241\\t     * Computed by {@link #loadCalendarData}.\\n246:   246\\t     * Computed by {@link #loadCalendarData}.\\n273:   273\\t    private static final String RESOURCE_PREFIX = \\\"hijrah-config-\\\";\\n285:   285\\t        INSTANCE = new HijrahChronology(\\\"Hijrah-umalqura\\\", \\\"islamic-umalqura\\\");\\n287:   287\\t        AbstractChronology.registerChrono(INSTANCE, \\\"Hijrah\\\");\\n288:   288\\t        AbstractChronology.registerChrono(INSTANCE, \\\"islamic\\\");\\n328:   328\\t            loadCalendarData();\\n810:   810\\t     *   \\\"<JAVA_HOME>/conf/chronology/\\\" +\\n811:   811\\t     *   \\\"hijrah-config-\\\" + chronologyId + \\\"_\\\" + calendarType + \\\".properties\\\"\\n816:   816\\t     * @return a Properties containing the properties read from the resource.\\n819:   819\\t    private static Properties readConfigProperties(final String chronologyId, final String calendarType) throws Exception {\\n822:   822\\t                ? HijrahChronology.class.getResourceAsStream(resourceName)\\n827:   827\\t            Properties props = new Properties();\\n844:   844\\t    private void loadCalendarData() {\\n846:   846\\t            Properties props = readConfigProperties(typeId, calendarType);\\n1016:  1016\\t     * <JAVA_HOME>/conf/chronology directory. Then register its chronology, if any.\\n1023:  1023\\t                    .filter(fn -> fn.matches(\\\"hijrah-config-[^\\\\\\\\.]+\\\\\\\\.properties\\\"))\\n1024:  1024\\t                    .map(fn -> fn.replaceAll(\\\"(hijrah-config-|\\\\\\\\.properties)\\\", \\\"\\\"))\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/logs/com.opencsv:opencsv:5.6/local-ci-fixup/run-consecutive-tests-2026-05-21T03-26-34-252831Z.log:107:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_56\",\"type\":\"command_execution\",\"command\":\"/usr/bin/bash -lc 'SRC_ZIP=/home/vjovanov/gdrive/bin/graalvm-jdk-25.0.3+9.1/lib/src.zip; unzip -p \\\"$SRC_ZIP\\\" java.base/java/time/chrono/HijrahChronology.java | nl -ba | sed -n '\\\"'260,420p'\\\"\",\"aggregated_output\":\"   260\\t     * The minimum length of a year in days.\\n   261\\t     * Computed by {@link #createEpochMonths}.\\n   262\\t     */\\n   263\\t    private transient int minYearLength;\\n   264\\t    /**\\n   265\\t     * The maximum length of a year in days.\\n   266\\t     * Computed by {@link #createEpochMonths}.\\n   267\\t     */\\n   268\\t    private transient int maxYearLength;\\n   269\\t\\n   270\\t    /**\\n   271\\t     * Prefix of resource names for Hijrah calendar variants.\\n   272\\t     */\\n   273\\t    private static final String RESOURCE_PREFIX = \\\"hijrah-config-\\\";\\n   274\\t\\n   275\\t    /**\\n   276\\t     * Suffix of resource names for Hijrah calendar variants.\\n   277\\t     */\\n   278\\t    private static final String RESOURCE_SUFFIX = \\\".properties\\\";\\n   279\\t\\n   280\\t    /**\\n   281\\t     * Static initialization of the built-in calendars.\\n   282\\t     * The data is not loaded until it is used.\\n   283\\t     */\\n   284\\t    static {\\n   285\\t        INSTANCE = new HijrahChronology(\\\"Hijrah-umalqura\\\", \\\"islamic-umalqura\\\");\\n   286\\t        // Register it by its aliases\\n   287\\t        AbstractChronology.registerChrono(INSTANCE, \\\"Hijrah\\\");\\n   288\\t        AbstractChronology.registerChrono(INSTANCE, \\\"islamic\\\");\\n   289\\t\\n   290\\t        // custom config chronologies\\n   291\\t        CONF_PATH = Path.of(StaticProperty.javaHome(), \\\"conf\\\", \\\"chronology\\\");\\n   292\\t        registerCustomChrono();\\n   293\\t    }\\n   294\\t\\n   295\\t    /**\\n   296\\t     * Create a HijrahChronology for the named variant and type.\\n   297\\t     *\\n   298\\t     * @param id the id of the calendar\\n   299\\t     * @param calType the typeId of the calendar\\n   300\\t     * @throws IllegalArgumentException if the id or typeId is empty\\n   301\\t     */\\n   302\\t    private HijrahChronology(String id, String calType) {\\n   303\\t        if (id.isEmpty()) {\\n   304\\t            throw new IllegalArgumentException(\\\"calendar id is empty\\\");\\n   305\\t        }\\n   306\\t        if (calType.isEmpty()) {\\n   307\\t            throw new IllegalArgumentException(\\\"calendar typeId is empty\\\");\\n   308\\t        }\\n   309\\t        this.typeId = id;\\n   310\\t        this.calendarType = calType;\\n   311\\t    }\\n   312\\t\\n   313\\t    /**\\n   314\\t     * Check and ensure that the calendar data has been initialized.\\n   315\\t     * The initialization check is performed at the boundary between\\n   316\\t     * public and package methods.  If a public calls another public method\\n   317\\t     * a check is not necessary in the caller.\\n   318\\t     * The constructors of HijrahDate call {@link #getEpochDay} or\\n   319\\t     * {@link #getHijrahDateInfo} so every call from HijrahDate to a\\n   320\\t     * HijrahChronology via package private methods has been checked.\\n   321\\t     *\\n   322\\t     * @throws DateTimeException if the calendar data configuration is\\n   323\\t     *     malformed or IOExceptions occur loading the data\\n   324\\t     */\\n   325\\t    private void checkCalendarInit() {\\n   326\\t        // Keep this short so it can be inlined for performance\\n   327\\t        if (initComplete == false) {\\n   328\\t            loadCalendarData();\\n   329\\t            initComplete = true;\\n   330\\t        }\\n   331\\t    }\\n   332\\t\\n   333\\t    //-----------------------------------------------------------------------\\n   334\\t    /**\\n   335\\t     * Gets the ID of the chronology.\\n   336\\t     * <p>\\n   337\\t     * The ID uniquely identifies the {@code Chronology}. It can be used to\\n   338\\t     * lookup the {@code Chronology} using {@link Chronology#of(String)}.\\n   339\\t     *\\n   340\\t     * @return the chronology ID, non-null\\n   341\\t     * @see #getCalendarType()\\n   342\\t     */\\n   343\\t    @Override\\n   344\\t    public String getId() {\\n   345\\t        return typeId;\\n   346\\t    }\\n   347\\t\\n   348\\t    /**\\n   349\\t     * Gets the calendar type of the Islamic calendar.\\n   350\\t     * <p>\\n   351\\t     * The calendar type is an identifier defined by the\\n   352\\t     * <em>Unicode Locale Data Markup Language (LDML)</em> specification.\\n   353\\t     * It can be used to lookup the {@code Chronology} using {@link Chronology#of(String)}.\\n   354\\t     *\\n   355\\t     * @return the calendar system type; non-null if the calendar has\\n   356\\t     *    a standard type, otherwise null\\n   357\\t     * @see #getId()\\n   358\\t     */\\n   359\\t    @Override\\n   360\\t    public String getCalendarType() {\\n   361\\t        return calendarType;\\n   362\\t    }\\n   363\\t\\n   364\\t    //-----------------------------------------------------------------------\\n   365\\t    /**\\n   366\\t     * Obtains a local date in Hijrah calendar system from the\\n   367\\t     * era, year-of-era, month-of-year and day-of-month fields.\\n   368\\t     *\\n   369\\t     * @param era  the Hijrah era, not null\\n   370\\t     * @param yearOfEra  the year-of-era\\n   371\\t     * @param month  the month-of-year\\n   372\\t     * @param dayOfMonth  the day-of-month\\n   373\\t     * @return the Hijrah local date, not null\\n   374\\t     * @throws DateTimeException if unable to create the date\\n   375\\t     * @throws ClassCastException if the {@code era} is not a {@code HijrahEra}\\n   376\\t     */\\n   377\\t    @Override\\n   378\\t    public HijrahDate date(Era era, int yearOfEra, int month, int dayOfMonth) {\\n   379\\t        return date(prolepticYear(era, yearOfEra), month, dayOfMonth);\\n   380\\t    }\\n   381\\t\\n   382\\t    /**\\n   383\\t     * Obtains a local date in Hijrah calendar system from the\\n   384\\t     * proleptic-year, month-of-year and day-of-month fields.\\n   385\\t     *\\n   386\\t     * @param prolepticYear  the proleptic-year\\n   387\\t     * @param month  the month-of-year\\n   388\\t     * @param dayOfMonth  the day-of-month\\n   389\\t     * @return the Hijrah local date, not null\\n   390\\t     * @throws DateTimeException if unable to create the date\\n   391\\t     */\\n   392\\t    @Override\\n   393\\t    public HijrahDate date(int prolepticYear, int month, int dayOfMonth) {\\n   394\\t        return HijrahDate.of(this, prolepticYear, month, dayOfMonth);\\n   395\\t    }\\n   396\\t\\n   397\\t    /**\\n   398\\t     * Obtains a local date in Hijrah calendar system from the\\n   399\\t     * era, year-of-era and day-of-year fields.\\n   400\\t     *\\n   401\\t     * @param era  the Hijrah era, not null\\n   402\\t     * @param yearOfEra  the year-of-era\\n   403\\t     * @param dayOfYear  the day-of-year\\n   404\\t     * @return the Hijrah local date, not null\\n   405\\t     * @throws DateTimeException if unable to create the date\\n   406\\t     * @throws ClassCastException if the {@code era} is not a {@code HijrahEra}\\n   407\\t     */\\n   408\\t    @Override\\n   409\\t    public HijrahDate dateYearDay(Era era, int yearOfEra, int dayOfYear) {\\n   410\\t        return dateYearDay(prolepticYear(era, yearOfEra), dayOfYear);\\n   411\\t    }\\n   412\\t\\n   413\\t    /**\\n   414\\t     * Obtains a local date in Hijrah calendar system from the\\n   415\\t     * proleptic-year and day-of-year fields.\\n   416\\t     *\\n   417\\t     * @param prolepticYear  the proleptic-year\\n   418\\t     * @param dayOfYear  the day-of-year\\n   419\\t     * @return the Hijrah local date, not null\\n   420\\t     * @throws DateTimeException if the value of the year is out of range,\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n/home/vjovanov/c/forge/forge2/graalvm-reachability-metadata/forge/logs/com.opencsv:opencsv:5.6/local-ci-fixup/run-consecutive-tests-2026-05-21T03-26-