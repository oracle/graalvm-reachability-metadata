(type);\n        OracleTypeADT restored = deserialize(serialized);\n\n        assertThat(restored.getTOID()).containsExactly(toid);\n        assertThat(restored.getTypeVersion()).isEqualTo(42);\n        assertThat(restored.getCharSet()).isEqualTo(873);\n        assertThat(restored.getCharSetForm()).isEqualTo(1);\n    }\n\n    private byte[] serialize(OracleTypeADT type) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(type);\n        }\n        return bytes.toByteArray();\n    }\n\n    private OracleTypeADT deserialize(byte[] serialized) throws Exception {\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (OracleTypeADT) input.readObject();\n        }\n    }\n}\n\n---FILE---\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.sql.SQLException;\nimport java.util.ArrayList;\nimport java.util.Date;\nimport java.util.Properties;\n\nimport oracle.jdbc.OracleConnection;\nimport oracle.jdbc.driver.OracleOCIConnection;\n\nimport org.junit.jupiter.api.Test;\n\npublic class PhysicalConnectionTest {\n    private static final String SQL_TYPE_NAME = \"APP.DATE_TYPE\";\n\n    @Test\n    void exposesConfiguredConnectionProperties() throws Exception {\n        Properties inputProperties = new Properties();\n        inputProperties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_user\");\n        inputProperties.setProperty(OracleConnection.CONNECTION_PROPERTY_AUTOCOMMIT, \"false\");\n        inputProperties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \"37\");\n        inputProperties.setProperty(OracleConnection.CONNECTION_PROPERTY_OCI_SVC_CTX_HANDLE, \"123456789\");\n\n        OracleConnection connection = new TestOracleOciConnection(inputProperties);\n\n        Properties connectionProperties = connection.getProperties();\n\n        assertThat(connectionProperties)\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"METADATA_USER\")\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_AUTOCOMMIT, \"false\")\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \"37\")\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_OCI_SVC_CTX_HANDLE, \"123456789\");\n    }\n\n    @Test\n    void registersSqlTypesByClassNameAndCreatesJavaObjects() throws Exception {\n        OracleConnection connection = new TestOracleOciConnection(new Properties());\n\n        connection.registerSQLType(SQL_TYPE_NAME, Date.class.getName());\n\n        assertThat(connection.getJavaObject(SQL_TYPE_NAME)).isInstanceOf(Date.class);\n    }\n\n    @Test\n    void resolvesClassesForSchemaQualifiedNames() throws Exception {\n        TestOracleOciConnection connection = new TestOracleOciConnection(new Properties());\n\n        Class<?> resolvedClass = connection.classForNameAndSchema(ArrayList.class.getName(), \"APP\");\n\n        assertThat(resolvedClass).isSameAs(ArrayList.class);\n    }\n\n    private static final class TestOracleOciConnection extends OracleOCIConnection {\n        private TestOracleOciConnection(Properties properties) throws SQLException {\n            super(\"jdbc:oracle:oci:@metadata-test\", properties, null);\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
