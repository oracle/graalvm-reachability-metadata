  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.sql.ConverterArchive;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import java.io.File;
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.UUID;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ConverterArchiveTest {
  
      private static final String RESOURCE_OBJECT = "/converter-archive-resource.ser";
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void insertsObjectIntoOpenArchiveAndReadsItBack() throws Exception {
          Path archivePath = temporaryDirectory.resolve("open-archive.zip");
          ConverterArchive archive = new ConverterArchive();
  
          archive.openArchiveforInsert(archivePath.toString());
          archive.insertObj("open-archive-value", "stored-entry.ser");
          archive.closeArchiveforInsert();
  
          assertThat(archive.readObj(archivePath.toString(), "stored-entry.ser")).isEqualTo("open-archive-value");
      }
  
      @Test
      void insertsObjectIntoDirectoryFile() throws Exception {
          ConverterArchive archive = new ConverterArchive();
          String directory = temporaryDirectory.toString() + File.separator;
          String filename = "single-object.ser";
  
          archive.insertObjtoFile(directory, filename, "file-value");
  
          assertThat(Files.size(temporaryDirectory.resolve(filename))).isGreaterThan(0L);
      }
  
      @Test
      void insertsSingleObjectIntoNewArchiveAndReplacesExistingArchive() throws Exception {
          Path archivePath = Path.of("converter-archive-" + UUID.randomUUID() + ".zip").toAbsolutePath();
          Path temporaryZipPath = Path.of("gsstemp.zip").toAbsolutePath();
          Files.deleteIfExists(archivePath);
          Files.deleteIfExists(temporaryZipPath);
  
          ConverterArchive archive = new ConverterArchive();
          try {
              archive.insertSingleObj(archivePath.toString(), "original-value", "original-entry.ser");
              archive.insertSingleObj(archivePath.toString(), "added-value", "added-entry.ser");
  
              assertThat(archive.readObj(archivePath.toString(), "original-entry.ser")).isEqualTo("original-value");
              assertThat(archive.readObj(archivePath.toString(), "added-entry.ser")).isEqualTo("added-value");
          } finally {
              deleteIfExists(archivePath);
              deleteIfExists(temporaryZipPath);
          }
      }
  
      @Test
      void readsSerializedObjectFromClasspathResource() {
          ConverterArchive archive = new ConverterArchive();
  
          assertThat(archive.readObj(RESOURCE_OBJECT)).isEqualTo("resource-object");
      }
  
      private static void deleteIfExists(Path path) throws IOException {
          Files.deleteIfExists(path);
      }
  }
