  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +public class OracleStructTest {
  +
  +    @Test
  +    void toClassInstantiatesOraDataFactory() throws Exception {
  +        OracleStruct oracleStruct = oracleStruct();
  +
  +        Object converted = oracleStruct.toClass(StructDataFactory.class, Map.of());
  +
  +        assertThat(converted).isInstanceOf(CreatedOraData.class);
  +        CreatedOraData createdOraData = (CreatedOraData) converted;
  +        assertThat(createdOraData.datum()).isSameAs(oracleStruct);
  +        assertThat(createdOraData.sqlType()).isEqualTo(Types.STRUCT);
  +    }
  +
  +    private static OracleStruct oracleStruct() throws Exception {
  +        return new OracleStruct(structDescriptor(), new byte[] {1, 2, 3}, connectionProxy());
  +    }
  +
  +    private static StructDescriptor structDescriptor() throws Exception {
  +        OracleConnection connection = (OracleConnection) connectionProxy();
  +        OracleTypeADT oracleTypeADT = new OracleTypeADT(new AttributeDescriptor[0], connection);
  +        return new StructDescriptor(oracleTypeADT, connection);
  +    }
  +
