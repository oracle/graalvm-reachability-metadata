  new file mode 100644
  index 0000000000..cab753218b
  --- /dev/null
  +++ 2/tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/OracleStructTest.java
  @@ -0,0 +1,145 @@
  +/*
  + * Copyright and related rights waived via CC0
  + *
  + * You should have received a copy of the CC0 legalcode along with this
  + * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
  + */
  +package com_oracle_database_jdbc.ojdbc11;
  +
  +import oracle.jdbc.driver.OracleStruct;
  +import oracle.jdbc.internal.OracleConnection;
  +import oracle.jdbc.oracore.OracleTypeADT;
  +import oracle.sql.AttributeDescriptor;
  +import oracle.sql.Datum;
  +import oracle.sql.ORAData;
  +import oracle.sql.ORADataFactory;
  +import oracle.sql.StructDescriptor;
  +import org.junit.jupiter.api.Test;
  +
  +import java.lang.reflect.Proxy;
  +import java.sql.Connection;
  +import java.sql.SQLFeatureNotSupportedException;
  +import java.sql.Types;
  +import java.util.Map;
  +
  +import static org.assertj.core.api.Assertions.assertThat;
  +
  +public class OracleStructTest {
  +
  +    @Test
  +    void toClassInstantiatesOraDataFactory() throws Exception {
  +        OracleStruct oracleStruct = oracleStruct();
  +
  +        Object converted = oracleStruct.toClass(StructDataFactory.class, Map.of());
  +
  +        assertThat(converted).isInstanceOf(CreatedOraData.class);
  +        CreatedOraData createdOraData = (CreatedOraData) converted;
  +        assertThat(createdOraData.datum()).isSameAs(oracleStruct);
  +        assertThat(createdOraData.sqlType()).isEqualTo(Types.STRUCT);
  +    }
  +
  +    private static OracleStruct oracleStruct() throws Exception {
  +        return new OracleStruct(structDescriptor(), new byte[] {1, 2, 3}, connectionProxy());
  +    }
  +
  +    private static StructDescriptor structDescriptor() throws Exception {
  +        OracleConnection connection = (OracleConnection) connectionProxy();
  +        OracleTypeADT oracleTypeADT = new OracleTypeADT(new AttributeDescriptor[0], connection);
  +        return new StructDescriptor(oracleTypeADT, connection);
  +    }
  +
  +    private static Connection connectionProxy() {
  +        Object[] proxyReference = new Object[1];
  +        proxyReference[0] = Proxy.newProxyInstance(
  +                OracleStructTest.class.getClassLoader(),
  +                new Class<?>[] {OracleConnection.class},
  +                (proxy, method, arguments) -> {
  +                    switch (method.getName()) {
  +                        case "physicalConnectionWithin":
  +                        case "getWrapper":
  +                            return proxyReference[0];
  +                        case "isDescriptorSharable":
  +                            return true;
  +                        case "acquireCloseableLock":
  +                            return null;
  +                        case "isWrapperFor":
  +                            return false;
  +                        case "unwrap":
  +                            throw new SQLFeatureNotSupportedException("unwrap is not needed by this test");
  +                        case "toString":
  +                            return "OracleStructTest connection proxy";
  +                        case "hashCode":
  +                            return System.identityHashCode(proxy);
  +                        case "equals":
  +                            return proxy == arguments[0];
  +                        default:
  +                            return defaultValue(method.getReturnType());
  +                    }
  +                });
  +        return (Connection) proxyReference[0];
  +    }
  +
  +    private static Object defaultValue(Class<?> returnType) {
  +        if (!returnType.isPrimitive()) {
  +            return null;
  +        }
  +        if (returnType == boolean.class) {
  +            return false;
  +        }
  +        if (returnType == byte.class) {
  +            return (byte) 0;
  +        }
  +        if (returnType == short.class) {
  +            return (short) 0;
  +        }
  +        if (returnType == int.class) {
  +            return 0;
  +        }
  +        if (returnType == long.class) {
  +            return 0L;
  +        }
  +        if (returnType == float.class) {
  +            return 0.0F;
  +        }
  +        if (returnType == double.class) {
  +            return 0.0D;
  +        }
  +        if (returnType == char.class) {
  +            return (char) 0;
  +        }
  +        return null;
  +    }
  +
  +    public static final class StructDataFactory implements ORADataFactory {
  +        public StructDataFactory() {
  +        }
  +
  +        @Override
  +        public ORAData create(Datum datum, int sqlType) {
  +            return new CreatedOraData(datum, sqlType);
  +        }
  +    }
  +
  +    public static final class CreatedOraData implements ORAData {
  +        private final Datum datum;
  +        private final int sqlType;
  +
  +        private CreatedOraData(Datum datum, int sqlType) {
  +            this.datum = datum;
  +            this.sqlType = sqlType;
  +        }
  +
  +        @Override
  +        public Datum toDatum(Connection connection) {
  +            return datum;
  +        }
  +
  +        private Datum datum() {
  +            return datum;
  +        }
  +
  +        private int sqlType() {
  +            return sqlType;
  +        }
  +    }
  +}
