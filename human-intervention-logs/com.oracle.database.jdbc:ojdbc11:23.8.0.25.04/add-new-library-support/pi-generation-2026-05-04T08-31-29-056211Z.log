  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleConnection;
  import oracle.jdbc.driver.OracleOCIConnection;
  import oracle.jdbc.internal.OracleConnection.BufferCacheStatistics;
  import org.junit.jupiter.api.Test;
  
  import java.sql.SQLException;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class BufferCacheTest {
      private static final int MAX_CACHED_BUFFER_SIZE = 4096;
  
      @Test
      void allocatesBucketSizedCharBufferOnCacheMiss() throws Exception {
          TestPhysicalConnection connection = new TestPhysicalConnection();
  
          char[] buffer = connection.getCharBufferSync(1);
  
          assertThat(buffer).hasSize(MAX_CACHED_BUFFER_SIZE);
          BufferCacheStatistics statistics = connection.getCharBufferCacheStatistics();
          assertThat(statistics.getBufferSizes()).containsExactly(MAX_CACHED_BUFFER_SIZE);
          assertThat(statistics.getCacheMisses(0)).isEqualTo(1);
          assertThat(statistics.getCacheHits(0)).isZero();
      }
  
      @Test
      void allocatesExactSizedCharBufferWhenRequestExceedsLargestBucket() throws Exception {
          TestPhysicalConnection connection = new TestPhysicalConnection();
          int uncachedLength = MAX_CACHED_BUFFER_SIZE + 1;
  
          char[] buffer = connection.getCharBufferSync(uncachedLength);
  
          assertThat(buffer).hasSize(uncachedLength);
          BufferCacheStatistics statistics = connection.getCharBufferCacheStatistics();
          assertThat(statistics.getBufferSizes()).containsExactly(MAX_CACHED_BUFFER_SIZE);
          assertThat(statistics.getCacheMisses(0)).isZero();
          assertThat(statistics.getCacheHits(0)).isZero();
      }
  
      private static final class TestPhysicalConnection extends OracleOCIConnection {
          private TestPhysicalConnection() throws SQLException {
              super("jdbc:oracle:oci:@", connectionProperties(), null);
          }
  
          @Override
          protected void readConnectionProperties(String url, Properties properties) throws SQLException {
              super.readConnectionProperties(url, properties);
          }
  
          private static Properties connectionProperties() {
              Properties properties = new Properties();
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, "metadata_test_user");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, "metadata_test_password");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_MAX_CACHED_BUFFER_SIZE,
                      Integer.toString(MAX_CACHED_BUFFER_SIZE));
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USE_THREADLOCAL_BUFFER_CACHE, "false");
              return properties;
          }
      }
  }
