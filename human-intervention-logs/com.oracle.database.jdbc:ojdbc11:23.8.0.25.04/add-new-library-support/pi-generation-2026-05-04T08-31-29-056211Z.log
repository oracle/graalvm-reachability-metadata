                          MethodType.methodType(Object.class, accessorClass, int.class, Class.class));
                  VarHandle rowData = accessorLookup.findVarHandle(accessorClass, "rowData", byteArrayClass);
                  VarHandle rowOffset = accessorLookup.findVarHandle(accessorClass, "rowOffset", long[].class);
                  VarHandle rowLength = accessorLookup.findVarHandle(accessorClass, "rowLength", int[].class);
                  VarHandle rowNull = accessorLookup.findVarHandle(accessorClass, "rowNull", boolean[].class);
  
