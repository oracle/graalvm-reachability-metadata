  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.sql.CHAR;
  import oracle.sql.CharacterSet;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class T4CConnectionTest {
  
      @Test
      void dumpsOracleObjectFieldsWithoutOpeningDatabaseSession() throws Throwable {
          CHAR oracleCharacter = new CHAR("metadata probe", CharacterSet.make(CharacterSet.AL32UTF8_CHARSET));
          MethodHandle dumpObject = dumpObjectHandle();
  
          String dump = (String) dumpObject.invoke(oracleCharacter, "  ");
  
          assertThat(dump)
                  .contains("  oracle.sql.CHAR { ")
                  .contains("    charSet =")
                  .contains("    oracleId =")
                  .contains("    variableLength =")
                  .endsWith("  }\n");
      }
  
      private static MethodHandle dumpObjectHandle() throws ClassNotFoundException, NoSuchMethodException,
              IllegalAccessException {
          Class<?> t4cConnectionClass = Class.forName("oracle.jdbc.driver.T4CConnection");
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(t4cConnectionClass, MethodHandles.lookup());
          return lookup.findStatic(t4cConnectionClass, "dumpObject",
                  MethodType.methodType(String.class, Object.class, String.class));
