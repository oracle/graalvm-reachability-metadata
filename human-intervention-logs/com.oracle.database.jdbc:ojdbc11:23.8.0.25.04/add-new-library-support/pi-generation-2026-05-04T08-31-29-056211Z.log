  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleConnection;
  import oracle.jdbc.driver.OracleOCIConnection;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.sql.SQLException;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PhysicalConnectionTest {
  
      @Test
      void exposesConnectionPropertiesWithoutOpeningDatabaseSession() throws Exception {
          TestPhysicalConnection connection = new TestPhysicalConnection();
  
          Properties properties = connection.getProperties();
  
          assertThat(properties).isNotEmpty();
          assertThat(properties).containsKey(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH);
          assertThat(properties).containsKey(OracleConnection.CONNECTION_PROPERTY_REPORT_REMARKS);
          assertThat(properties).containsKey(OracleConnection.CONNECTION_PROPERTY_IMPLICIT_STATEMENT_CACHE_SIZE);
      }
  
      @Test
      void registersSqlTypesByClassNameAndCreatesMappedJavaObjects() throws Exception {
          TestPhysicalConnection connection = new TestPhysicalConnection();
          String sqlTypeName = "APP.SAMPLE_SQL_OBJECT";
  
          connection.registerSQLType(sqlTypeName, SampleSqlObject.class.getName());
  
          assertThat(connection.getSQLType(new SampleSqlObject())).isEqualTo(sqlTypeName);
          assertThat(connection.getJavaObject(sqlTypeName)).isInstanceOf(SampleSqlObject.class);
      }
  
      @Test
      void resolvesJavaClassesForSqlObjectSchemas() throws Exception {
          TestPhysicalConnection connection = new TestPhysicalConnection();
  
          Class<?> resolvedClass = connection.classForNameAndSchema(SampleSqlObject.class.getName(), "APP");
  
          assertThat(resolvedClass).isEqualTo(SampleSqlObject.class);
      }
  
      @Test
      void safelyResolvesJavaClassNames() throws Throwable {
          TestPhysicalConnection connection = new TestPhysicalConnection();
          MethodHandle safelyGetClassForName = safelyGetClassForNameHandle(connection);
  
          Class<?> resolvedClass = (Class<?>) safelyGetClassForName.invoke(connection, SampleSqlObject.class.getName());
  
          assertThat(resolvedClass).isEqualTo(SampleSqlObject.class);
      }
  
      private static MethodHandle safelyGetClassForNameHandle(TestPhysicalConnection connection)
              throws NoSuchMethodException, IllegalAccessException {
          Class<?> physicalConnectionClass = physicalConnectionClass(connection.getClass());
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(physicalConnectionClass, MethodHandles.lookup());
          return lookup.findVirtual(physicalConnectionClass, "safelyGetClassForName",
                  MethodType.methodType(Class.class, String.class));
      }
  
      private static Class<?> physicalConnectionClass(Class<?> connectionClass) {
          Class<?> currentClass = connectionClass;
          while (currentClass != null && !"oracle.jdbc.driver.PhysicalConnection".equals(currentClass.getName())) {
              currentClass = currentClass.getSuperclass();
          }
          assertThat(currentClass).isNotNull();
          return currentClass;
      }
  
      public static final class SampleSqlObject {
      }
  
      private static final class TestPhysicalConnection extends OracleOCIConnection {
          private TestPhysicalConnection() throws SQLException {
              super("jdbc:oracle:oci:@", connectionProperties(), null);
          }
  
          @Override
          protected void readConnectionProperties(String url, Properties properties) throws SQLException {
              super.readConnectionProperties(url, properties);
          }
  
          private static Properties connectionProperties() {
              Properties properties = new Properties();
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, "metadata_test_user");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, "metadata_test_password");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, "25");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_EXECUTE_BATCH, "3");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_REPORT_REMARKS, "true");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_IMPLICIT_STATEMENT_CACHE_SIZE, "7");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DIAGNOSTIC_LOGGER_NAME,
                      PhysicalConnectionTest.class.getName());
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DIAGNOSTIC_BUFFER_SIZE, "1000");
              return properties;
          }
      }
