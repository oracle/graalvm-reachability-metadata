              this.newStatement = newStatement;
              this.newVarcharAccessor = newVarcharAccessor;
              this.newSimpleByteArray = newSimpleByteArray;
              this.setCapacity = setCapacity;
              this.getObject = getObject;
              this.rowData = rowData;
              this.rowOffset = rowOffset;
              this.rowLength = rowLength;
              this.rowNull = rowNull;
              this.connectionLifecycle = connectionLifecycle;
              this.connectionVersionNumber = connectionVersionNumber;
          }
  
          private Object newStatement(TestPhysicalConnection connection) throws Throwable {
              connectionLifecycle.set(connection, OPEN_CONNECTION_LIFECYCLE);
              connectionVersionNumber.set(connection, DATABASE_VERSION);
              Object resultSetType = resultSetType("FORWARD_READ_ONLY");
              return newStatement.invoke(connection, resultSetType);
          }
  
          private Object newVarcharAccessor(Object statement) throws Throwable {
              return newVarcharAccessor.invoke(statement, 64, (short) 1, 64, true, false);
          }
  
