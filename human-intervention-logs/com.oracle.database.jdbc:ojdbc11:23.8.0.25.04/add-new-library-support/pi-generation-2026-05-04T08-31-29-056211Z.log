MethodHandle newVarcharAccessor;\n        private final MethodHandle newSimpleByteArray;\n        private final MethodHandle setCapacity;\n        private final MethodHandle getObject;\n        private final VarHandle rowData;\n        private final VarHandle rowOffset;\n        private final VarHandle rowLength;\n        private final VarHandle rowNull;\n\n        private Handles(MethodHandle newStatement, MethodHandle newVarcharAccessor, MethodHandle newSimpleByteArray,\n                MethodHandle setCapacity, MethodHandle getObject, VarHandle rowData, VarHandle rowOffset,\n                VarHandle rowLength, VarHandle rowNull) {\n            this.newStatement = newStatement;\n            this.newVarcharAccessor = newVarcharAccessor;\n            this.newSimpleByteArray = newSimpleByteArray;\n            this.setCapacity = setCapacity;\n            this.getObject = getObject;\n            this.rowData = rowData;\n            this.rowOffset = rowOffset;\n            this.rowLength = rowLength;\n            this.rowNull = rowNull;\n        }\n\n        private Object newStatement(TestPhysicalConnection connection) throws Throwable {\n            Object resultSetType = Enum.valueOf(resultSetTypeClass().asSubclass(Enum.class), \"FORWARD_READ_ONLY\");\n            return newStatement.invoke(connection, resultSetType);\n        }\n\n        private Object newVarcharAccessor(Object statement) throws Throwable {\n            return newVarcharAccessor.invoke(statement, 64, (short) 1, 64, true, false);\n        }\n\n        private void storeVarcharValue(Object accessor, String value) throws Throwable {\n            byte[] bytes = value.getBytes(StandardCharsets.UTF_8);\n            Object byteArray = newSimpleByteArray.invoke(null, bytes);\n\n            setCapacity.invoke(accessor, 1);\n            rowData.set(accessor, byteArray);\n            ((long[]) rowOffset.get(accessor))[ROW_INDEX] = 0L;\n            ((int[]) rowLength.get(accessor))[ROW_INDEX] = bytes.length;\n            ((boolean[]) rowNull.get(accessor))[ROW_INDEX] = false;\n        }\n\n        private MethodHandle getObject() {\n            return getObject;\n        }\n\n        private static Handles create() {\n            try {\n                Class<?> t2cStatementClass = Class.forName(\"oracle.jdbc.driver.T2CStatement\");\n                Class<?> t2cConnectionClass = Class.forName(\"oracle.jdbc.driver.T2CConnection\");\n                Class<?> resultSetTypeClass = resultSetTypeClass();\n                MethodHandles.Lookup statementLookup = MethodHandles.privateLookupIn(t2cStatementClass, LOOKUP);\n                MethodHandle newStatement = statementLookup.findConstructor(t2cStatementClass,\n                        MethodType.methodType(void.class, t2cConnectionClass, resultSetTypeClass));\n\n                Class<?> varcharAccessorClass = Class.forName(\"oracle.jdbc.driver.VarcharAccessor\");\n                Class<?> oracleStatementClass = Class.forName(\"oracle.jdbc.driver.OracleStatement\");\n                MethodHandles.Lookup varcharLookup = MethodHandles.privateLookupIn(varcharAccessorClass, LOOKUP);\n                MethodHandle newVarcharAccessor = varcharLookup.findConstructor(varcharAccessorClass,\n                        MethodType.methodType(void.class, oracleStatementClass, int.class, short.class, int.class,\n                                boolean.class, boolean.class));\n\n                Class<?> simpleByteArrayClass = Class.forName(\"oracle.jdbc.driver.SimpleByteArray\");\n                Class<?> diagnosableClass = Class.forName(\"oracle.jdbc.diagnostics.Diagnosable\");\n                MethodHandles.Lookup byteArrayLookup = MethodHandles.privateLookupIn(simpleByteArrayClass, LOOKUP);\n                MethodHandle newSimpleByteArray = byteArrayLookup.findConstructor(simpleByteArrayClass,\n                        MethodType.methodType(void.class, diagnosableClass, byte[].class));\n\n                Class<?> accessorClass = Class.forName(\"oracle.jdbc.driver.Accessor\");\n                Class<?> byteArrayClass = Class.forName(\"oracle.jdbc.driver.ByteArray\");\n                MethodHandles.Lookup accessorLookup = MethodHandles.privateLookupIn(accessorClass, LOOKUP);\n                MethodHandle setCapacity = accessorLookup.findVirtual(accessorClass, \"setCapacity\",\n                        MethodType.methodType(void.class, int.class));\n                MethodHandle getObject = representationLookup().findVirtual(Representation.class, \"getObject\",\n                        MethodType.methodType(Object.class, accessorClass, int.class, Class.class));\n                VarHandle rowData = accessorLookup.findVarHandle(accessorClass, \"rowData\", byteArrayClass);\n                VarHandle rowOffset = accessorLookup.findVarHandle(accessorClass, \"rowOffset\", long[].class);\n                VarHandle rowLength = accessorLookup.findVarHandle(accessorClass, \"rowLength\", int[].class);\n                VarHandle rowNull = accessorLookup.findVarHandle(accessorClass, \"rowNull\", boolean[].class);\n\n                return new Handles(newStatement, newVarcharAccessor, newSimpleByteArray, setCapacity, getObject,\n                        rowData, rowOffset, rowLength, rowNull);\n            } catch (ClassNotFoundException | NoSuchMethodException | NoSuchFieldException | IllegalAccessException\n                    exception) {\n                throw new ExceptionInInitializerError(exception);\n            }\n        }\n\n        private static MethodHandles.Lookup representationLookup() throws IllegalAccessException {\n            return MethodHandles.privateLookupIn(Representation.class, LOOKUP);\n        }\n\n        private static Class<?> resultSetTypeClass() throws ClassNotFoundException {\n            return Class.forName(\"oracle.jdbc.driver.OracleResultSet$ResultSetType\");\n        }\n    }\n\n    private static final class TestPhysicalConnection extends OracleOCIConnection {\n        private TestPhysicalConnection() throws SQLException {\n            super(\"jdbc:oracle:oci:@\", connectionProperties(), null);\n        }\n\n        @Override\n        protected void readConnectionProperties(String url, Properties properties) throws SQLException {\n            super.readConnectionProperties(url, properties);\n        }\n\n        private static Properties connectionProperties() {\n            Properties properties = new Properties();\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_test_user\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, \"metadata_test_password\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \"1\");\n            return properties;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 417, "output": 2085, "cacheRead": 70656, "cacheWrite": 0, "totalTokens": 73158, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777883361200, "responseId": "resp_0572ad12315b7b340169f858e1c47081a09aeebf864a58ba04"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_TKRq0Vj4jTHCl1GEc14SfVrS|fc_0572ad12315b7b340169f858eabdf481a09848c21aa2167bc0", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 8244 bytes to tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/RedirectorAnonymous3Test.java"}], "isError": false, "timestamp": 1777883379529}]}
