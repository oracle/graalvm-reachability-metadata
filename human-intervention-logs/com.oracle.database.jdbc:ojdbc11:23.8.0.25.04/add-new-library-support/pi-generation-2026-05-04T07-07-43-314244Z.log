  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.driver.DMSFactory;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class DMSFactoryTest {
      private static final String ENABLE_OBSERVABILITY_PROPERTY = "oracle.jdbc.diagnostic.enableObservability";
  
      @Test
      void createsFactoryWithObservabilityEnabled() {
          String previousValue = System.getProperty(ENABLE_OBSERVABILITY_PROPERTY);
          System.setProperty(ENABLE_OBSERVABILITY_PROPERTY, "true");
          try {
              DMSFactory factory = DMSFactory.getInstance();
  
              assertThat(factory).isNotNull();
              assertThat(factory.getClass().getName()).isEqualTo("oracle.jdbc.driver.LiveDMSFactory");
              assertThat(DMSFactory.isDMSEnabled()).isTrue();
              assertThat(DMSFactory.getDMSVersion()).isNotNull();
          } finally {
              restoreObservabilityProperty(previousValue);
          }
      }
  
      private static void restoreObservabilityProperty(String previousValue) {
          if (previousValue == null) {
              System.clearProperty(ENABLE_OBSERVABILITY_PROPERTY);
          } else {
              System.setProperty(ENABLE_OBSERVABILITY_PROPERTY, previousValue);
          }
      }
