n        assertThat(restored).isNotSameAs(original);\n        assertThat(restored.get()).isEqualTo(\"database-password\");\n        assertThat(restored.length()).isEqualTo(original.length());\n    }\n\n    @Test\n    void serializesAndDeserializesNullOpaqueStringValue() throws Exception {\n        OpaqueString original = OpaqueString.NULL;\n\n        byte[] serialized = serialize(original);\n        OpaqueString restored = deserializeOpaqueString(serialized);\n\n        assertThat(restored.isNull()).isTrue();\n        assertThat(restored.get()).isNull();\n    }\n\n    private static byte[] serialize(OpaqueString opaqueString) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(opaqueString);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static OpaqueString deserializeOpaqueString(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            return (OpaqueString) objectInputStream.readObject();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1201, "output": 1073, "cacheRead": 41984, "cacheWrite": 0, "totalTokens": 44258, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777865809405, "responseId": "resp_0c8e01a10bb96fbd0169f81451e5088191870f0d32d5ca6e97"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_o0ZnRO4j9XMYg9aXSi5iaBM6|fc_0c8e01a10bb96fbd0169f81459c99881919bf3e7339f06c7c4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2114 bytes to tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/OpaqueStringT