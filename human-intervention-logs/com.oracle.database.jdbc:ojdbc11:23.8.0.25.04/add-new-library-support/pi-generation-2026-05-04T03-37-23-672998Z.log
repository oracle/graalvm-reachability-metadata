  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleTypes;
  import oracle.jdbc.oracore.OracleTypeOPAQUE;
  import oracle.sql.Datum;
  import oracle.sql.OPAQUE;
  import oracle.sql.ORAData;
  import oracle.sql.ORADataFactory;
  import oracle.sql.OpaqueDescriptor;
  import oracle.sql.SQLName;
  import org.junit.jupiter.api.Test;
  
  import java.sql.Connection;
  import java.sql.SQLException;
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OPAQUETest {
  
      @Test
      void stringValueUsesJdbcValueGetStringValMethod() throws Exception {
          OPAQUE opaque = new JdbcValueOpaque(new GetStringValJdbcValue());
  
          assertThat(opaque.stringValue()).isEqualTo("OPAQUE(jdbc-string)");
      }
  
      @Test
      void stringValueFallsBackToJdbcValueStringValueMethod() throws Exception {
          OPAQUE opaque = new JdbcValueOpaque(new StringValueJdbcValue());
  
          assertThat(opaque.stringValue()).isEqualTo("OPAQUE(fallback-string)");
      }
  
      @Test
      void toClassInstantiatesOraDataFactory() throws Exception {
          OPAQUE opaque = opaque();
  
          Object converted = opaque.toClass(OpaqueDataFactory.class, Map.of());
  
          assertThat(converted).isInstanceOf(CreatedOraData.class);
          CreatedOraData createdOraData = (CreatedOraData) converted;
          assertThat(createdOraData.datum()).isSameAs(opaque);
          assertThat(createdOraData.sqlType()).isEqualTo(OracleTypes.OPAQUE);
      }
  
      private static OPAQUE opaque() throws SQLException {
          return new OPAQUE(opaqueDescriptor(), null, new byte[] {1, 2, 3});
      }
  
      private static OpaqueDescriptor opaqueDescriptor() throws SQLException {
          SQLName sqlName = new SQLName("APP", "OPAQUE_TYPE", null);
          OracleTypeOPAQUE pickler = new OracleTypeOPAQUE(new byte[] {1, 3, 5, 7, 9, 11, 13, 15}, 1, 0,
                  (short) 0, "APP.OPAQUE_TYPE", 0L);
          return new OpaqueDescriptor(sqlName, pickler, null);
      }
  
      public static final class GetStringValJdbcValue {
          public String getStringVal() {
              return "jdbc-string";
          }
      }
  
      public static final class StringValueJdbcValue {
          public String stringValue() {
              return "fallback-string";
          }
      }
  
      public static final class OpaqueDataFactory implements ORADataFactory {
          public OpaqueDataFactory() {
          }
  
          @Override
          public ORAData create(Datum datum, int sqlType) {
              return new CreatedOraData(datum, sqlType);
          }
      }
  
      public static final class CreatedOraData implements ORAData {
          private final Datum datum;
          private final int sqlType;
  
          private CreatedOraData(Datum datum, int sqlType) {
              this.datum = datum;
              this.sqlType = sqlType;
          }
  
          @Override
          public Datum toDatum(Connection connection) {
              return datum;
          }
  
          private Datum datum() {
              return datum;
          }
  
          private int sqlType() {
              return sqlType;
          }
      }
  
      private static final class JdbcValueOpaque extends OPAQUE {
          private final Object jdbcValue;
  
          private JdbcValueOpaque(Object jdbcValue) throws SQLException {
              super(opaqueDescriptor(), null, new byte[] {1, 2, 3});
              this.jdbcValue = jdbcValue;
          }
  
          @Override
          public Object toJdbc() {
              return jdbcValue;
          }
      }
  }
