  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.driver.AbstractShardingConnection;
  import oracle.jdbc.internal.OracleConnection;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.util.ArrayList;
  import java.util.Arrays;
  import java.util.List;
  import java.util.concurrent.ConcurrentHashMap;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AbstractShardingConnectionTest {
      private static final MethodHandle DELEGATES_SETTER_CALLS = methodHandle(
              "delegatesSetterCalls", MethodType.methodType(void.class, OracleConnection.class, boolean.class));
      private static final MethodHandle SETTER_CALL_HISTORY_ENTRY_CONSTRUCTOR = setterCallHistoryEntryConstructor();
  
      @Test
      void replaysDeferredSetterCallsWithNewAndOriginalValues() throws Throwable {
          TestShardingConnection shardingConnection = new TestShardingConnection();
          addSetterCallHistoryEntry(shardingConnection, 4, "setDefaultRowPrefetch", new Class<?>[] { Integer.TYPE }, 16);
          RecordingInvocationHandler invocationHandler = new RecordingInvocationHandler();
          OracleConnection delegate = invocationHandler.createProxy();
  
          DELEGATES_SETTER_CALLS.invoke(shardingConnection, delegate, true);
          DELEGATES_SETTER_CALLS.invoke(shardingConnection, delegate, false);
  
          assertThat(invocationHandler.calls())
                  .anySatisfy(call -> assertRecordedCall(call, "setDefaultRowPrefetch", 16))
                  .anySatisfy(call -> assertRecordedCall(call, "setDefaultRowPrefetch", 4));
      }
  
      @SuppressWarnings("unchecked")
      private static void addSetterCallHistoryEntry(
              TestShardingConnection connection, Object originalValue, String methodName, Class<?>[] argumentTypes,
              Object... arguments) throws Throwable {
          Object setterCallHistoryEntry = SETTER_CALL_HISTORY_ENTRY_CONSTRUCTOR.invoke(
                  originalValue, methodName, argumentTypes, arguments);
          ConcurrentHashMap<String, Object> setterMap = (ConcurrentHashMap<String, Object>) setterMap(connection);
          setterMap.put(methodName, setterCallHistoryEntry);
      }
  
      private static Object setterMap(TestShardingConnection connection) throws Throwable {
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                  AbstractShardingConnection.class, MethodHandles.lookup());
          return lookup.findGetter(AbstractShardingConnection.class, "setterMap", ConcurrentHashMap.class)
                  .invoke(connection);
      }
  
      private static MethodHandle methodHandle(String name, MethodType methodType) {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      AbstractShardingConnection.class, MethodHandles.lookup());
              return lookup.findVirtual(AbstractShardingConnection.class, name, methodType);
          } catch (NoSuchMethodException | IllegalAccessException exception) {
              throw new ExceptionInInitializerError(exception);
          }
      }
  
      private static MethodHandle setterCallHistoryEntryConstructor() {
