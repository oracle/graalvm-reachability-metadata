G_Rvns17UdiomkdcQKERif8CGJHF1-Gl6tNVA7aKghwLZF392oyMQphL_n1wGWjLmTYWDborrHCtc8ojHZj53QJqBbACTMagqOcToK8P-mEccajX13xOmDg80xlGAJTLNmNNTR9GyhSxEC7efqY-bUGhSgWC3zKMd0LeP4pVstQPTpIqdl0-CN5ICTuvyKNqbzLJYpv5Fjwyl8Nj-sDoXgwPworozdWWm-PQcJCOwlQ1kzpq-\",\"summary\":[]}"}, {"type": "toolCall", "id": "call_IxY9myyTlltKSh5rE9q3l5oM|fc_09a2af978a4013a50169f7ca3ac7b8819dbe1e21a1629bf045", "name": "write", "arguments": {"path": "tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/ProxyFactoryTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.proxy.ProxyFactory;\nimport oracle.jdbc.proxy._Proxy_;\nimport oracle.jdbc.proxy.annotation.GetCreator;\nimport oracle.jdbc.proxy.annotation.GetDelegate;\nimport oracle.jdbc.proxy.annotation.ProxyAccess;\nimport oracle.jdbc.proxy.annotation.ProxyFor;\nimport oracle.jdbc.proxy.annotation.SetDelegate;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.ref.WeakReference;\nimport java.util.IdentityHashMap;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProxyFactoryTest {\n\n    @Test\n    void proxyForTypeInstantiatesProxyForRegisteredDelegateType() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ManualProxy.class);\n\n        Object proxy = proxyFactory.proxyForType(SampleDelegate.class);\n\n        assertThat(proxy).isInstanceOf(SampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(extractDelegate(proxy)).isNull();\n    }\n\n    @Test\n    void proxyForCreateInstantiatesProxyWithoutUsingCache() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ManualProxy.class);\n        SampleDelegate delegate = new SampleDelegate();\n\n        Object proxy = proxyFactory.<Object>proxyForCreate(delegate);\n\n        assertThat(proxy).isInstanceOf(SampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @Test\n    void proxyForCacheReturnsProxyAlreadyStoredOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), CachingProxy.class);\n        SampleDelegate delegate = new SampleDelegate();\n        Object cachedProxy = new Object();\n        delegate.setProxyMarker(cachedProxy);\n\n        Object proxy = proxyFactory.<Object>proxyFor(delegate);\n\n        assertThat(proxy).isSameAs(cachedProxy);\n    }\n\n    @Test\n    void proxyForCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), CachingProxy.class);\n        SampleDelegate delegate = new SampleDelegate();\n\n        Object proxy = proxyFactory.<Object>proxyFor(delegate);\n\n        assertThat(proxy).isInstanceOf(SampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(delegate.getProxyMarker()).isSameAs(proxy);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @Test\n    void proxyForCreateCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), CachingProxy.class);\n        SampleDelegate delegate = new SampleDelegate();\n        Map<Object, WeakReference<?>> proxyCache = new IdentityHashMap<>();\n\n        Object proxy = proxyFactory.<Object>proxyForCreateCache(delegate, proxyFactory, proxyCache, null);\n\n        assertThat(proxy).isInstanceOf(SampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(delegate.getProxyMarker()).isSameAs(proxy);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static Object extractDelegate(Object proxy) {\n        return ProxyFactory.extractDelegate((_Proxy_<Object>) proxy);\n    }\n\n    public interface ProxyAccessContract {\n        Object getProxyMarker();\n\n        void setProxyMarker(Object proxy);\n    }\n\n    public interface SampleService extends ProxyAccessContract {\n        String value();\n    }\n\n    public static final class SampleDelegate implements SampleService {\n        private Object proxyMarker;\n\n        @Override\n        public Object getProxyMarker() {\n            return proxyMarker;\n        }\n\n        @Override\n        public void setProxyMarker(Object proxy) {\n            this.proxyMarker = proxy;\n        }\n\n        @Override\n        public String value() {\n            return \"delegate\";\n        }\n    }\n\n    @ProxyFor(SampleService.class)\n    public abstract static class ManualProxy {\n        @GetDelegate\n        protected abstract SampleService getDelegate();\n\n        @SetDelegate\n        protected abstract void setDelegate(SampleService delegate);\n\n        @GetCreator\n        protected abstract Object getCreator();\n    }\n\n    @ProxyFor(SampleService.class)\n    @ProxyAccess(ProxyAccessContract.class)\n    public abstract static class CachingProxy extends ManualProxy {\n    }\n}\n\n@SuppressWarnings(\"checkstyle:TypeName\")\nclass com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryTest$ManualProxy$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryTest$SampleService$$$Proxy\n        extends ProxyFactoryTest.ManualProxy implements ProxyFactoryTest.SampleService, _Proxy_<ProxyFactoryTest.SampleService> {\n    private ProxyFactoryTest.SampleService delegate;\n  