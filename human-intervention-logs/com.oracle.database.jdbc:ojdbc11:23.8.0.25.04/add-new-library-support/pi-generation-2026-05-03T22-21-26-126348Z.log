[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/ProxyFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.proxy.ProxyFactory;\nimport oracle.jdbc.proxy._Proxy_;\nimport oracle.jdbc.proxy.annotation.GetCreator;\nimport oracle.jdbc.proxy.annotation.GetDelegate;\nimport oracle.jdbc.proxy.annotation.ProxyAccess;\nimport oracle.jdbc.proxy.annotation.ProxyFor;\nimport oracle.jdbc.proxy.annotation.SetDelegate;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.ref.WeakReference;\nimport java.util.IdentityHashMap;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProxyFactoryTest {\n\n    @Test\n    void proxyForTypeInstantiatesProxyForRegisteredDelegateType() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryManualProxySuperclass.class);\n\n        Object proxy = proxyFactory.proxyForType(ProxyFactorySampleDelegate.class);\n\n        assertThat(proxy).isInstanceOf(ProxyFactorySampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(extractDelegate(proxy)).isNull();\n    }\n\n    @Test\n    void proxyForCreateInstantiatesProxyWithoutUsingCache() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryManualProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n\n        Object proxy = proxyFactory.<Object>proxyForCreate(delegate);\n\n        assertThat(proxy).isInstanceOf(ProxyFactorySampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @Test\n    void proxyForCacheReturnsProxyAlreadyStoredOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryCachingProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n        Object cachedProxy = new Object();\n        delegate.setProxyMarker(cachedProxy);\n\n        Object proxy = proxyFactory.<Object>proxyFor(delegate);\n\n        assertThat(proxy).isSameAs(cachedProxy);\n    }\n\n    @Test\n    void proxyForCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryCachingProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n\n        Object proxy = proxyFactory.<Object>proxyFor(delegate);\n\n        assertThat(proxy).isInstanceOf(ProxyFactorySampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(delegate.getProxyMarker()).isSameAs(proxy);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @Test\n    void proxyForCreateCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryCachingProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n        Map<Object, WeakReference<?>> proxyCache = new IdentityHashMap<>();\n\n        Object proxy = proxyFactory.<Object>proxyForCreateCache(delegate, proxyFactory, proxyCache, null);\n\n        assertThat(proxy).isInstanceOf(ProxyFactorySampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(delegate.getProxyMarker()).isSameAs(proxy);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static Object extractDelegate(Object proxy) {\n        return ProxyFactory.extractDelegate((_Proxy_<Object>) proxy);\n    }\n}\n\ninterface ProxyFactoryProxyAccessContract {\n    Object getProxyMarker();\n\n    void setProxyMarker(Object proxy);\n}\n\ninterface ProxyFactorySampleService extends ProxyFactoryProxyAccessContract {\n    String value();\n}\n\nfinal class ProxyFactorySampleDelegate implements ProxyFactorySampleService {\n    private Object proxyMarker;\n\n    @Override\n    public Object getProxyMarker() {\n        return proxyMarker;\n    }\n\n    @Override\n    public void setProxyMarker(Object proxy) {\n        this.proxyMarker = proxy;\n    }\n\n    @Override\n    public String value() {\n        return \"delegate\";\n    }\n}\n\n@ProxyFor(ProxyFactorySampleService.class)\nabstract class ProxyFactoryManualProxySuperclass {\n    @GetDelegate\n    protected abstract ProxyFactorySampleService getDelegate();\n\n    @SetDelegate\n    protected abstract void setDelegate(ProxyFactorySampleService delegate);\n\n    @GetCreator\n    protected abstract Object getCreator();\n}\n\n@ProxyFor(ProxyFactorySampleService.class)\n@ProxyAccess(ProxyFactoryProxyAccessContract.class)\nabstract class ProxyFactoryCachingProxySuperclass extends ProxyFactoryManualProxySuperclass {\n}\n\nclass com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryManualProxySuperclass$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactorySampleService$$$Proxy\n        extends ProxyFactoryManualProxySuperclass implements ProxyFactorySampleService, _Proxy_<ProxyFactorySampleService> {\n    private ProxyFactorySampleService delegate;\n    private final Object creator;\n\n    public com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryManualProxySuperclass$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactorySampleService$$$Proxy(\n            ProxyFactorySampleService delegate, Object creator, ProxyFactory proxyFactory,\n            Map<Object, WeakReference<?>> proxyCache, boolean cached) {\n        this.delegate = delegate;\n        this.creator = creator;\n    }\n\n    @Override\n    public ProxyFactorySampleService _getDelegate_() {\n        return delegate;\n    }\n\n    @Override\n    public Object getProxyMarker() {\n        return delegate.getProxyMarker();\n    }\n\n    @Override\n    public void setProxyMarker(Object proxy) {\n        delegate.setProxyMarker(proxy);\n    }\n\n    @Override\n    public String value() {\n        return delegate.value();\n    }\n\n    @Override\n    protected ProxyFactorySampleService getDelegate() {\n        return delegate;\n    }\n\n    @Override\n    protected void setDelegate(ProxyFactorySampleService delegate) {\n        this.delegate = delegate;\n    }\n\n    @Override\n    protected Object getCreator() {\n        return creator;\n    }\n}\n\nclass com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryCachingProxySuperclass$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactorySampleService$$$Proxy\n        extends ProxyFactoryCachingProxySuperclass implements ProxyFactorySampleService, _Proxy_<ProxyFactorySampleService> {\n    private ProxyFactorySampleService delegate;\n    private final Object creator;\n\n    public com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryCachingProxySuperclass$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactorySampleService$$$Proxy(\n            ProxyFactorySampleService delegate, Object creator, ProxyFactory proxyFactory,\n            Map<Object, WeakReference<?>> proxyCache, boolean cached) {\n        this.delegate = delegate;\n        this.creator = creator;\n    }\n\n    @Override\n    public ProxyFactorySampleService _getDelegate_() {\n        return delegate;\n    }\n\n    @Override\n    public Object getProxyMarker() {\n        return delegate.getProxyMarker();\n    }\n\n    @Override\n    public void setProxyMarker(Object proxy)