tractDelegate((_Proxy_<Object>) proxy);\n    }\n\n    public interface ProxyAccessContract {\n        Object getProxyMarker();\n\n        void setProxyMarker(Object proxy);\n    }\n\n    public interface SampleService extends ProxyAccessContract {\n        String value();\n    }\n\n    public static final class SampleDelegate implements SampleService {\n        private Object proxyMarker;\n\n        @Override\n        public Object getProxyMarker() {\n            return proxyMarker;\n        }\n\n        @Override\n        public void setProxyMarker(Object proxy) {\n            this.proxyMarker = proxy;\n        }\n\n        @Override\n        public String value() {\n            return \"delegate\";\n        }\n    }\n\n    @ProxyFor(SampleService.class)\n    public abstract static class ManualProxy {\n        @GetDelegate\n        protected abstract SampleService getDelegate();\n\n        @SetDelegate\n        protected abstract void setDelegate(SampleService delegate);\n\n        @GetCreator\n        protected abstract Object getCreator();\n    }\n\n    @ProxyFor(SampleService.class)\n    @ProxyAccess(ProxyAccessContract.class)\n    public abstract static class CachingProxy extends ManualProxy {\n    }\n}\n\n@SuppressWarnings(\"checkstyle:TypeName\")\nclass com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryTest$ManualProxy$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryTest$SampleService$$$Proxy\n        extends ProxyFactoryTest.ManualProxy implements ProxyFactoryTest.SampleService, _Proxy_<ProxyFactoryTest.SampleService> {\n    private ProxyFactoryTest.SampleService delegate;\n    private final Object creator;\n\n    public com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryTest$ManualProxy$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryTest$SampleService$$$Proxy(\n            ProxyFactoryTest.SampleService delegate, Object creator, ProxyFactory proxyFactory,\n            Map<Object, WeakReference<?>> proxyCache, boolean cached) {\n        this.delegate = delegate;\n