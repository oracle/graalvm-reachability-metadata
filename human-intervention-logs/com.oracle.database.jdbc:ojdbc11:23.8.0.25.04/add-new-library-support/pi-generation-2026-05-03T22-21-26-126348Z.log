  import oracle.jdbc.proxy._Proxy_;
  import oracle.jdbc.replay.driver.TxnReplayableConnection;
  import org.junit.jupiter.api.Test;
  
  import java.lang.ref.WeakReference;
  import java.sql.SQLException;
  import java.util.IdentityHashMap;
  import java.util.Map;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProxyFactoryTest {
  
      @Test
      void proxyForTypeInstantiatesGeneratedProxyForRegisteredJdbcProxySuperclass() throws Exception {
          ProxyFactory proxyFactory = ProxyFactory.createJDBCProxyFactory(TxnReplayableConnection.class);
  
          Object proxy = proxyFactory.proxyForType(TestPhysicalConnection.class);
  
          assertThat(proxy).isInstanceOf(OracleConnection.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(extractDelegate(proxy)).isNull();
      }
  
      @Test
      void proxyForCreateInstantiatesGeneratedProxyWithoutUsingCache() throws Exception {
          ProxyFactory proxyFactory = ProxyFactory.createJDBCProxyFactory(AbstractShardingConnection.class);
          TestPhysicalConnection delegate = new TestPhysicalConnection();
  
          Object proxy = proxyFactory.<Object>proxyForCreate(delegate);
  
          assertThat(proxy).isInstanceOf(OracleConnection.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(extractDelegate(proxy)).isSameAs(delegate);
      }
  
      @Test
      void proxyForCacheReturnsProxyAlreadyStoredOnProxyAccessDelegate() throws Exception {
          ProxyFactory proxyFactory = ProxyFactory.createJDBCProxyFactory(TxnReplayableConnection.class);
          TestPhysicalConnection delegate = new TestPhysicalConnection();
          Object cachedProxy = new Object();
          delegate.setACProxy(cachedProxy);
  
          Object proxy = proxyFactory.<Object>proxyFor(delegate);
  
          assertThat(proxy).isSameAs(cachedProxy);
      }
  
      @Test
      void proxyForCacheInstantiatesGeneratedProxyAndStoresItOnProxyAccessDelegate() throws Exception {
          ProxyFactory proxyFactory = ProxyFactory.createJDBCProxyFactory(TxnReplayableConnection.class);
          TestPhysicalConnection delegate = new TestPhysicalConnection();
  
          Object proxy = proxyFactory.<Object>proxyFor(delegate);
  
          assertThat(proxy).isInstanceOf(OracleConnection.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(delegate.getACProxy()).isSameAs(proxy);
          assertThat(extractDelegate(proxy)).isSameAs(delegate);
      }
  
      @Test
      void proxyForCreateCacheInstantiatesGeneratedProxyAndStoresItOnProxyAccessDelegate() throws Exception {
          ProxyFactory proxyFactory = ProxyFactory.createJDBCProxyFactory(TxnReplayableConnection.class);
          TestPhysicalConnection delegate = new TestPhysicalConnection();
          Map<Object, WeakReference<?>> proxyCache = new IdentityHashMap<>();
  
          Object proxy = proxyFactory.<Object>proxyForCreateCache(delegate, proxyFactory, proxyCache, null);
  
          assertThat(proxy).isInstanceOf(OracleConnection.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(delegate.getACProxy()).isSameAs(proxy);
          assertThat(extractDelegate(proxy)).isSameAs(delegate);
      }
  
      @SuppressWarnings("unchecked")
      private static Object extractDelegate(Object proxy) {
          return ProxyFactory.extractDelegate((_Proxy_<Object>) proxy);
      }
  
      private static final class TestPhysicalConnection extends OracleOCIConnection {
          private TestPhysicalConnection() throws SQLException {
              super("jdbc:oracle:oci:@", connectionProperties(), null);
          }
  
          @Override
          protected void readConnectionProperties(String url, Properties properties) throws SQLException {
              super.readConnectionProperties(url, properties);
          }
  
          private static Properties connectionProperties() {
              Properties properties = new Properties();
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, "metadata_test_user");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, "metadata_test_password");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, "25");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_EXECUTE_BATCH, "3");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_REPORT_REMARKS, "true");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_IMPLICIT_STATEMENT_CACHE_SIZE, "7");
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DIAGNOSTIC_LOGGER_NAME,
                      ProxyFactoryTest.class.getName());
              properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DIAGNOSTIC_BUFFER_SIZE, "1000");
              return properties;
          }
      }
  }
