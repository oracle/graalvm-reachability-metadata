actory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryManualProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n\n        Object proxy = proxyFactory.<Object>proxyForCreate(delegate);\n\n        assertThat(proxy).isInstanceOf(ProxyFactorySampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @Test\n    void proxyForCacheReturnsProxyAlreadyStoredOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryCachingProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n        Object cachedProxy = new Object();\n        delegate.setProxyMarker(cachedProxy);\n\n        Object proxy = proxyFactory.<Object>proxyFor(delegate);\n\n        assertThat(proxy).isSameAs(cachedProxy);\n    }\n\n    @Test\n    void proxyForCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryCachingProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n\n        Object proxy = proxyFactory.<Object>proxyFor(delegate);\n\n        assertThat(proxy).isInstanceOf(ProxyFactorySampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(delegate.getProxyMarker()).isSameAs(proxy);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @Test\n    void proxyForCreateCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ProxyFactoryCachingProxySuperclass.class);\n        ProxyFactorySampleDelegate delegate = new ProxyFactorySampleDelegate();\n        Map<Object, WeakReference<?>> proxyCache = new IdentityHashMap<>();\n\n        Object proxy = proxyFactory.<Object>proxyForCreateCache(delegate, proxyFactory, proxyCache, null);\n\n        assertThat(proxy).isInstanceOf(ProxyFactorySampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(delegate.getProxyMarker()).isSameAs(proxy);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static Object extractDelegate(Object proxy) {\n        return ProxyFactory.extractDelegate((_Proxy_<Object>) proxy);\n    }\n}\n\ninterface ProxyFactoryProxyAccessContract {\n    Object getProxyMarker();\n\n    void setProxyMarker(Object proxy);\n}\n\ninterface ProxyFactorySampleService extends ProxyFactoryProxyAccessContract {\n    String value();\n}\n\nfinal class ProxyFactorySampleDelegate implements ProxyFactorySampleService {\n    private Object proxyMarker;\n\n    @Override\n    public Object getProxyMarker() {\n        return proxyMarker;\n    }\n\n    @Override\n    public void setProxyMarker(Object proxy) {\n        this.proxyMarker = proxy;\n    }\n\n    @Override\n    public String value() {\n        return \"delegate\";\n    }\n}\n\n@ProxyFor(ProxyFactorySampleService.class)\nabstract class ProxyFactoryManualProxySuperclass {\n    @GetDelegate\n    protected abstract ProxyFactorySampleService getDelegate();\n\n    @SetDelegate\n    protected abstract void setDelegate(ProxyFactorySampleService delegate);\n\n    @GetCreator\n    protected abstract Object getCreator();\n}\n\n@ProxyFor(ProxyFactorySampleService.class)\n@ProxyAccess(ProxyFactoryProxyAccessContract.class)\nabstract class ProxyFactoryCachingProxySuperclass extends ProxyFactoryManualProxySuperclass {\n}\n\nclass com_oracle_database_jdbc$1ojdbc11$1ProxyFactoryManualProxySuperclass$2com_oracle_database_jdbc$1ojdbc11$1ProxyFactorySampleService$$$Proxy\n    