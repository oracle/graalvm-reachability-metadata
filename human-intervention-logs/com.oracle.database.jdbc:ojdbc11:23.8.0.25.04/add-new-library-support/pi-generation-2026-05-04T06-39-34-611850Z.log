  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.diagnostics.CommonDiagnosable;
  import oracle.jdbc.internal.OpaqueString;
  import oracle.net.nt.CustomSSLSocketFactory;
  import oracle.security.pki.OraclePKIProvider;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Properties;
  
  import javax.net.ssl.SSLSocketFactory;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CustomSSLSocketFactoryTest {
      private static final int JAVAX_NET_SSL_KEYSTORE_PROPERTY = 8;
      private static final int JAVAX_NET_SSL_KEYSTORE_TYPE_PROPERTY = 9;
      private static final int JAVAX_NET_SSL_KEYSTORE_PASSWORD_PROPERTY = 10;
  
      @TempDir
      Path temporaryDirectory;
  
      @Test
      void loadsKnownSsoProviderWhenCreatingSslSocketFactory() throws Exception {
          Path wallet = temporaryDirectory.resolve("test-wallet.sso");
          Files.write(wallet, new byte[] {0});
  
          Properties properties = new Properties();
          properties.put(JAVAX_NET_SSL_KEYSTORE_PROPERTY, wallet.toString());
          properties.put(JAVAX_NET_SSL_KEYSTORE_TYPE_PROPERTY, "SSO");
          properties.put(JAVAX_NET_SSL_KEYSTORE_PASSWORD_PROPERTY, OpaqueString.EMPTY);
  
          OraclePKIProvider.resetInstanceCount();
          SSLSocketFactory socketFactory = CustomSSLSocketFactory.getSSLSocketFactory(
                  properties,
                  null,
                  CommonDiagnosable.getInstance());
  
          assertThat(socketFactory).isNotNull();
          assertThat(OraclePKIProvider.instanceCount()).isEqualTo(1);
      }
  }
