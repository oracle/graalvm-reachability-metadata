n/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.net.nt.ConnOption;\nimport oracle.net.nt.SdpNTAdapter;\nimport org.junit.jupiter.api.Test;\n\nimport java.net.InetAddress;\nimport java.net.InetSocketAddress;\nimport java.net.ServerSocket;\nimport java.util.Properties;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SdpNTAdapterTest {\n    private static final int CONNECT_TIMEOUT_PROPERTY = 2;\n    private static final int TCP_NIO_PROPERTY = 20;\n\n    @Test\n    void connectUsesReflectivelyOpenedSdpSocket() throws Exception {\n        try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\n            SdpNTAdapter adapter = new SdpNTAdapter(\"sdp\", createConnectionOption(serverSocket), createSocketOptions(false));\n\n            adapter.connect(null);\n            try {\n                assertThat(adapter.getInetAddress()).isEqualTo(InetAddress.getLoopbackAddress());\n                assertThat(adapter.getSocketChannel()).isNull();\n            } finally {\n                adapter.disconnect();\n            }\n        }\n    }\n\n    @Test\n    void connectUsesReflectivelyOpenedSdpSocketChannelWhenNioIsEnabled() throws Exception {\n        try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\n            SdpNTAdapter adapter = new SdpNTAdapter(\"sdp\", createConnectionOption(serverSocket), createSocketOptions(true));\n\n            adapter.connect(null);\n            try {\n                assertThat(adapter.getInetAddress()).isEqualTo(InetAddress.getLoopbackAddress());\n                assertThat(adapter.getSocketChannel()).isNotNull();\n            } finally {\n                adapter.disconnect();\n            }\n        }\n    }\n\n    private static ConnOption createConnectionOption(ServerSocket serverSocket) {\n        ConnOption connectionOption = new ConnOption();\n        connectionOption.host = InetAddress.getLoopbackAddress().getHostAddress();\n        connectionOption.port = serverSocket.getLocalPort();\n        connectionOption.inetSocketAddress = new InetSocketAddress(\n                InetAddress.getLoopbackAddress(),\n                serverSocket.getLocalPort());\n        return connectionOption;\n    }\n\n    private static Properties createSocketOptions(boolean nioEnabled) {\n        Properties socketOptions = new Properties();\n        socketOptions.put(CONNECT_TIMEOUT_PROPERTY, \"2000\");\n        socketOptions.put(TCP_NIO_PROPERTY, Boolean.toString(nioEnabled));\n        return socketOptions;\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 553, "output": 1211, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 27364, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777876650866, "responseId": "resp_09a0314c135e29d00169f83eab7d0481a2a9ea6e1c0c2f314b"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_KJmTOUJrFeiRvq17rd4gTGii|fc_09a0314c135e29d00169f83eb54e3481a2b465ad1f90b41f2a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2719 bytes to tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/SdpNTAdapterTest.java"}], "isError": false, "timestamp": 1777876665219}]}
