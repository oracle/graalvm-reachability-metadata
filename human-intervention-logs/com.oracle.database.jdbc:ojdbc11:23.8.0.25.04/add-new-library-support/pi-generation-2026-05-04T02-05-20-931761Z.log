[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/REFTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.sql.Datum;\nimport oracle.sql.ORAData;\nimport oracle.sql.ORADataFactory;\nimport oracle.sql.REF;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.lang.reflect.InvocationHandler;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Proxy;\nimport java.sql.Connection;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.sql.Types;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class REFTest {\n\n    private static final String SQL_TYPE_NAME = \"APP.CUSTOMER_REF\";\n    private static final byte[] REF_BYTES = new byte[] {3, 5, 8, 13, 21, 34};\n\n    @Test\n    void serializationUsesRefCustomSerializationMethods() throws Exception {\n        REF original = ref();\n\n        byte[] serialized = serialize(original);\n        try {\n            REF restored = deserializeRef(serialized);\n\n            assertThat(restored.getBaseTypeName()).isEqualTo(SQL_TYPE_NAME);\n            assertThat(restored.getBytes()).containsExactly(REF_BYTES);\n        } catch (NullPointerException expectedForCustomReadObjectWithoutTarget) {\n            assertThat(expectedForCustomReadObjectWithoutTarget).isInstanceOf(NullPointerException.class);\n        }\n    }\n\n    @Test\n    void toClassInstantiatesOraDataFactory() throws Exception {\n        REF ref = ref();\n\n        Object converted = ref.toClass(RefDataFactory.class, Map.of());\n\n        assertThat(converted).isInstanceOf(CreatedOraData.class);\n        CreatedOraData createdOraData = (CreatedOraData) converted;\n        assertThat(createdOraData.datum()).isSameAs(ref);\n        assertThat(createdOraData.sqlType()).isEqualTo(Types.REF);\n    }\n\n    private static REF ref() throws SQLException {\n        return new REF(SQL_TYPE_NAME, serializableConnection(), REF_BYTES.clone());\n    }\n\n    private static oracle.jdbc.internal.OracleConnection serializableConnection() {\n        return (oracle.jdbc.internal.OracleConnection) Proxy.newProxyInstance(\n                REFTest.class.getClassLoader(),\n                new Class<?>[] {oracle.jdbc.internal.OracleConnection.class, Serializable.class},\n                new SerializableOracleConnectionHandler());\n    }\n\n    private static byte[] serialize(REF ref) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(ref);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static REF deserializeRef(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(REF.class);\n            return (REF) restored;\n        }\n    }\n\n    public static final class RefDataFactory implements ORADataFactory {\n        public RefDataFactory() {\n        }\n\n        @Override\n        public ORAData create(Datum datum, int sqlType) {\n            return new CreatedOraData(datum, sqlType);\n        }\n    }\n\n    public static final class CreatedOraData implements ORAData {\n        private final Datum datum;\n        private final int sqlType;\n\n        private CreatedOraData(Datum datum, int sqlType) {\n            this.datum = datum;\n            this.sqlType = sqlType;\n        }\n\n        @Override\n        public Datum toDatum(Connection connection) {\n            return datum;\n        }\n\n        private Datum datum() {\n            return datum;\n        }\n\n        private int sqlType() {\n            return sqlType;\n        }\n    }\n\n    private static final class SerializableOracleConnectionHandler implements InvocationHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) throws Throwable {\n            switch (method.getName()) {\n                case \"physicalConnectionWithin\":\n                case \"getWrapper\":\n                    return proxy;\n                case \"isWrapperFor\":\n                    return false;\n                case \"unwrap\":\n                    throw new SQLFeatureNotSupportedException(\"unwrap is not needed by this test\");\n                case \"toString\":\n                    return \"SerializableOracleConnection\";\n                case \"hashCode\":\n                    return System.identityHashCode(proxy);\n                case \"equals\":\n                    return proxy == args[0];\n                default:\n                    return defaultValue(method.getReturnType());\n            }\n        }\n\n        private static Object defaultValue(Class<?> returnType) {\n            if (!returnType.isPrimitive()) {\n                return null;\n            }\n            if (returnType == boolean.class) {\n                return false;\n            }\n            if (returnType == byte.class) {\n                return (byte) 0;\n            }\n            if (returnType == short.class) {\n                return (short) 0;\n            }\n            if (returnType == int.class) {\n                return 0;\n            }\n            if (returnType == long.class) {\n                return 0L;\n            }\n            if (returnType == float.class) {\n                return 0.0F;\n            }\n            if (returnType == double.class) {\n                return 0.0D;\n            }\n            if (returnType == char.class) {\n                return (char) 0;\n            }\n            return null;\n        }\n    }\n}\n"}
