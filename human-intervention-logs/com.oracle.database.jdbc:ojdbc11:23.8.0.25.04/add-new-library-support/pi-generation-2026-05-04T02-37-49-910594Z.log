  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleConnection;
  import oracle.jdbc.OracleConnectionWrapper;
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OracleConnectionWrapperInnerCloseInvocationHandlerTest {
  
      @Test
      void invokesObjectMethodOnWrapper() throws Exception {
          ExposedOracleConnectionWrapper wrapper = new ExposedOracleConnectionWrapper(connectionProxy());
          ConnectionOnlyOperation proxy = wrapper.proxyForConnectionOnlyOperation();
  
          String description = proxy.toString();
  
          assertThat(description).contains(ExposedOracleConnectionWrapper.class.getName());
      }
  
      @Test
      void invokesInterfaceMethodOnWrappedConnectionAfterWrapperRejectedMethod() throws Exception {
          ExposedOracleConnectionWrapper wrapper = new ExposedOracleConnectionWrapper(connectionProxy());
          ConnectionOnlyOperation proxy = wrapper.proxyForConnectionOnlyOperation();
  
          String value = proxy.connectionOnlyValue();
  
          assertThat(value).isEqualTo("wrapped connection");
      }
  
      private static OracleConnection connectionProxy() {
          return (OracleConnection) Proxy.newProxyInstance(
                  OracleConnectionWrapperInnerCloseInvocationHandlerTest.class.getClassLoader(),
                  new Class<?>[] {OracleConnection.class, ConnectionOnlyOperation.class},
                  OracleConnectionWrapperInnerCloseInvocationHandlerTest::invokeConnectionProxy);
      }
  
      private static Object invokeConnectionProxy(Object proxy, Method method, Object[] args) {
          if (method.getDeclaringClass() == ConnectionOnlyOperation.class) {
              return "wrapped connection";
          }
          if (method.getName().equals("toString") && method.getParameterCount() == 0) {
              return "connection proxy";
          }
          return defaultValue(method.getReturnType());
      }
  
      private static Object defaultValue(Class<?> returnType) {
          if (!returnType.isPrimitive() || returnType == void.class) {
              return null;
          }
          if (returnType == boolean.class) {
              return false;
          }
          if (returnType == char.class) {
              return '\0';
          }
          if (returnType == byte.class) {
              return (byte) 0;
          }
          if (returnType == short.class) {
              return (short) 0;
          }
          if (returnType == int.class) {
              return 0;
          }
          if (returnType == long.class) {
              return 0L;
          }
          if (returnType == float.class) {
              return 0.0F;
          }
          return 0.0D;
      }
  
      public interface ConnectionOnlyOperation {
          String connectionOnlyValue();
      }
  
      private static final class ExposedOracleConnectionWrapper extends OracleConnectionWrapper {
          private ExposedOracleConnectionWrapper(OracleConnection connection) {
              this.connection = connection;
          }
  
          private ConnectionOnlyOperation proxyForConnectionOnlyOperation() throws Exception {
              return proxyFor(new Object(), ConnectionOnlyOperation.class);
          }
      }
  }
