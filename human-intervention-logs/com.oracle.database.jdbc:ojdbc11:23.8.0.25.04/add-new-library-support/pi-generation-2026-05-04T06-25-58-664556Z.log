[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/CustomSSLSocketFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.diagnostics.CommonDiagnosable;\nimport oracle.jdbc.internal.OpaqueString;\nimport oracle.net.nt.CustomSSLSocketFactory;\nimport oracle.security.pki.OraclePKIProvider;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Properties;\n\nimport javax.net.ssl.SSLSocketFactory;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CustomSSLSocketFactoryTest {\n    private static final int JAVAX_NET_SSL_KEYSTORE_PROPERTY = 8;\n    private static final int JAVAX_NET_SSL_KEYSTORE_TYPE_PROPERTY = 9;\n    private static final int JAVAX_NET_SSL_KEYSTORE_PASSWORD_PROPERTY = 10;\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void loadsKnownSsoProviderWhenCreatingSslSocketFactory() throws Exception {\n        Path wallet = temporaryDirectory.resolve(\"test-wallet.sso\");\n        Files.write(wallet, new byte[] {0});\n\n        Properties properties = new Properties();\n        properties.put(JAVAX_NET_SSL_KEYSTORE_PROPERTY, wallet.toString());\n        properties.put(JAVAX_NET_SSL_KEYSTORE_TYPE_PROPERTY, \"SSO\");\n        properties.put(JAVAX_NET_SSL_KEYSTORE_PASSWORD_PROPERTY, OpaqueString.EMPTY);\n\n        OraclePKIProvider.resetInstanceCount();\n        SSLSocketFactory socketFactory = CustomSSLSocketFactory.getSSLSocketFactory(\n                properties,\n                null,\n                CommonDiagnosable.getInstance());\n\n        assertThat(socketFactory).isNotNull();\n        assertThat(OraclePKIProvider.instanceCount()).isEqualTo(1);\n    }\n}\n"}
