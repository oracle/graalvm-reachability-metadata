  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.diagnostics.CommonDiagnosable;
  import oracle.net.ano.Ano;
  import oracle.net.ns.ClientProfile;
  import oracle.net.ns.SessionAtts;
  import org.junit.jupiter.api.Test;
  
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnoTest {
  
      @Test
      void initializesConfiguredAdvancedNetworkingServices() throws Exception {
          Ano ano = new Ano();
          SessionAtts session = new SessionAtts(null, 8_192, 8_192, false, false, CommonDiagnosable.getInstance());
          session.profile = new ClientProfile(advancedNetworkingProperties());
  
          ano.init(session, false);
  
          assertThat(session.ano).isSameAs(ano);
          assertThat(ano.getNAFlags()).isPositive();
          assertThat(ano.getEncryptionProvider()).isNull();
          assertThat(ano.getChecksumProvider()).isNull();
      }
  
      private static Properties advancedNetworkingProperties() {
          Properties properties = new Properties();
          properties.setProperty("oracle.net.encryption_client", "REQUESTED");
          properties.setProperty("oracle.net.encryption_types_client", "(AES256)");
          properties.setProperty("oracle.net.crypto_checksum_client", "REQUESTED");
          properties.setProperty("oracle.net.crypto_checksum_types_client", "(SHA256)");
          return properties;
      }
