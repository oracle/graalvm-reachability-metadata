  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleConnection;
  import oracle.jdbc.driver.OracleDriver;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.Timeout;
  
  import java.sql.DriverPropertyInfo;
  import java.sql.SQLException;
  import java.util.Arrays;
  import java.util.Map;
  import java.util.Properties;
  import java.util.function.Function;
  
  import static java.util.stream.Collectors.toMap;
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.junit.jupiter.api.Assertions.assertThrows;
  
  public class OracleDriverTest {
      private static final String UNREACHABLE_THIN_URL = "jdbc:oracle:thin:@127.0.0.1:1/FREEPDB1";
  
      @Test
      void createsPropertyInfoFromOracleConnectionConstants() throws SQLException {
          OracleDriver driver = new OracleDriver();
  
          DriverPropertyInfo[] propertyInfos = driver.getPropertyInfo(UNREACHABLE_THIN_URL, new Properties());
  
          Map<String, DriverPropertyInfo> propertyInfoByName = Arrays.stream(propertyInfos)
                  .collect(toMap(propertyInfo -> propertyInfo.name, Function.identity(), (first, second) -> first));
          assertThat(propertyInfoByName).containsKeys(
                  OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH,
                  OracleConnection.CONNECTION_PROPERTY_THIN_NET_CONNECT_TIMEOUT);
          assertThat(propertyInfoByName.get(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH).value)
                  .isEqualTo(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH_DEFAULT);
      }
  
      @Test
      @Timeout(10)
      void loadsThinDriverExtensionBeforeOpeningNetworkConnection() {
          OracleDriver driver = new OracleDriver();
          Properties properties = new Properties();
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, "metadata_test_user");
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, "metadata_test_password");
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_THIN_NET_CONNECT_TIMEOUT, "1000");
  
          assertThrows(SQLException.class, () -> driver.connect(UNREACHABLE_THIN_URL, properties));
      }
  }
