ect lock = acquireConnectionLock.invoke(connection);\n            try {\n                return newStatement.invoke(connection, resultSetType);\n            } finally {\n                closeConnectionLock.invoke(lock);\n            }\n        }\n\n        private Object newVarcharAccessor(Object statement) throws Throwable {\n            return newVarcharAccessor.invoke(statement, 64, (short) 1, 64, true, false);\n        }\n\n        private void storeVarcharValue(Object accessor, String value) throws Throwable {\n            byte[] bytes = value.getBytes(StandardCharsets.UTF_8);\n            Object byteArray = newSimpleByteArray.invoke(null, bytes);\n\n            setCapacity.invoke(accessor, 1);\n            rowData.set(accessor, byteArray);\n            ((long[]) rowOffset.get(accessor))[ROW_INDEX] = 0L;\n            ((int[]) rowLength.get(accessor))[ROW_INDEX] = bytes.length;\n            ((boolean[]) rowNull.get(accessor))[ROW_INDEX] = false;\n        }\n\n        private MethodHandle getObject() {\n            return getObject;\n        }\n\n        private static Handles create() {\n            try {\n                Class<?> t2cStatementClass = Class.forName(\"oracle.jdbc.driver.T2CStatement\");\n                Class<?> t2cConnectionClass = Class.forName(\"oracle.jdbc.driver.T2CConnection\");\n                Class<?> resultSetTypeClass = resultSetTypeClass();\n                MethodHandles.Lookup statementLookup = MethodHandles.privateLookupIn(t2cStatementClass, LOOKUP);\n                MethodHandle newStatement = statementLookup.findConstructor(t2cStatementClass,\n                        MethodType.methodType(void.class, t2cConnectionClass, resultSetTypeClass));\n\n                Class<?> varcharAccessorClass = Class.forName(\"oracle.jdbc.driver.VarcharAccessor\");\n                Class<?> oracleStatementClass = Class.forName(\"oracle.jdbc.driver.OracleStatement\");\n                MethodHandles.Lookup varcharLookup = MethodHandles.privateLookupIn(v