bject lock = acquireConnectionLock.invoke(connection);\n            try {\n                return newStatement.invoke(connection, resultSetType);\n            } finally {\n                closeConnectionLock.invoke(lock);\n            }\n        }\n\n        private Object newVarcharAccessor(Object statement) throws Throwable {\n            return newVarcharAccessor.invoke(statement, 64, (short) 1, 64, true, false);\n        }\n\n        private void storeVarcharValue(Object accessor, String value) throws Throwable {\n            byte[] bytes = value.getBytes(StandardCharsets.UTF_8);\n            Object byteArray = newSimpleByteArray.invoke(null, bytes);\n\n            setCapacity.invoke(accessor, 1);\n            rowData.set(accessor, byteArray);\n            ((long[]) rowOffset.get(accessor))[ROW_INDEX] = 0L;\n            ((int[]) rowLength.get(accessor))[ROW_INDEX] = bytes.length;\n            ((boolean[]) rowNull.get(accessor))[ROW_INDEX] = false;\n        }\n\n        private MethodHandle getObject() {\n            return getObject;\n        }\n\n        private static Handles create() {\n            try {\n                Class<?> t2cStatementClass = Class.forName(\"oracle.jdbc.driver.T2CStatement\");\n                Class<?> t2cConnectionClass = Class.forName(\"oracle.jdbc.driver.T2CConnection\");\n                Class<?> resultSetTypeClass = resultSetTypeClass();\n                MethodHandles.Lookup statementLookup = MethodHandles.privateLookupIn(t2cStatementClass, LOOKUP);\n                MethodHandle newStatement = statementLookup.findConstructor(t2cStatementClass,\n                        MethodType.methodType(void.class, t2cConnectionClass, resultSetTypeClass));\n\n                Class<?> varcharAccessorClass = Class.forName(\"oracle.jdbc.driver.VarcharAccessor\");\n                Class<?> oracleStatementClass = Class.forName(\"oracle.jdbc.driver.OracleStatement\");\n                MethodHandles.Lookup varcharLookup = MethodHandles.privateLookupIn(varcharAccessorClass, LOOKUP);\n                MethodHandle newVarcharAccessor = varcharLookup.findConstructor(varcharAccessorClass,\n                        MethodType.methodType(void.class, oracleStatementClass, int.class, short.class, int.class,\n                                boolean.class, boolean.class));\n\n                Class<?> simpleByteArrayClass = Class.forName(\"oracle.jdbc.driver.SimpleByteArray\");\n                Class<?> diagnosableClass = Class.forName(\"oracle.jdbc.diagnostics.Diagnosable\");\n                MethodHandles.Lookup byteArrayLookup = MethodHandles.privateLookupIn(simpleByteArrayClass, LOOKUP);\n                MethodHandle newSimpleByteArray = byteArrayLookup.findConstructor(simpleByteArrayClass,\n                        MethodType.methodType(void.class, diagnosableClass, byte[].class));\n\n                Class<?> accessorClass = Class.forName(\"oracle.jdbc.driver.Accessor\");\n                Class<?> byteArrayClass = Class.forName(\"oracle.jdbc.driver.ByteArray\");\n                MethodHandles.Lookup accessorLookup = MethodHandles.privateLookupIn(accessorClass, LOOKUP);\n                MethodHandle setCapacity = accessorLookup.findVirtual(accessorClass, \"setCapacity\",\n                        MethodType.methodType(void.class, int.class));\n                MethodHandle getObject = representationLookup().findVirtual(Representation.class, \"getObject\",\n                        MethodType.methodType(Object.class, accessorClass, int.class, Class.class));\n                VarHandle rowData = accessorLookup.findVarHandle(accessorClass, \"rowData\", byteArrayClass);\n                VarHandle rowOffset = accessorLookup.findVarHandle(accessorClass, \"rowOffset\", long[].class);\n                VarHandle rowLength = accessorLookup.findVarHandle(accessorClass, \"rowLength\", int[].class);\n                VarHandle rowNull = accessorLookup.findVarHandle(accessorClass, \"rowNull\", boolean[].class);\n\n                Class<?> physicalConnectionClass = Class.forName(\"oracle.jdbc.driver.PhysicalConnection\");\n                MethodHandles.Lookup connectionLookup = MethodHandles.privateLookupIn(physicalConnectionClass, LOOKUP);\n                VarHandle connectionLifecycle = connectionLookup.findVarHandle(physicalConnectionClass, \"lifecycle\",\n                        int.class);\n                VarHandle connectionVersionNumber = connectionLookup.findVarHandle(physicalConnectionClass,\n                        \"versionNumber\", short.class);\n                MethodHandle acquireConnectionLock = connectionLookup.findVirtual(physicalConnectionClass,\n                        \"acquireCloseableLock\", MethodType.methodType(closeableLockClass()));\n                MethodHandle closeConnectionLock = LOOKUP.findVirtual(closeableLockClass(), \"close\",\n                        MethodType.methodType(void.class));\n\n                return new Handles(newStatement, newVarcharAccessor, newSimpleByteArray, setCapacity, getObject,\n                        acquireConnectionLock, closeConnectionLock, rowData, rowOffset, rowLength, rowNull,\n                        connectionLifecycle, connectionVersionNumber);\n            } catch (ClassNotFoundException | NoSuchMethodException | NoSuchFieldException | IllegalAccessException\n                    exception) {\n                throw new ExceptionInInitializerError(exception);\n            }\n        }\n\n        private static MethodHandles.Lookup representationLookup() throws IllegalAccessException {\n            return MethodHandles.privateLookupIn(Representation.class, LOOKUP);\n        }\n\n        @SuppressWarnings({ \"rawtypes\", \"unchecked\" })\n        private static Object resultSetType(String name) throws ClassNotFoundException {\n            return Enum.valueOf((Class) resultSetTypeClass(), name);\n        }\n\n        private static Class<?> resultSetTypeClass() throws ClassNotFoundException {\n            return Class.forName(\"oracle.jdbc.driver.OracleResultSet$ResultSetType\");\n        }\n\n        private static Class<?> closeableLockClass() throws ClassNotFoundException {\n            return Class.forName(\"oracle.jdbc.internal.Monitor$CloseableLock\");\n        }\n    }\n\n    private static final class TestPhysicalConnection extends OracleOCIConnection {\n        private TestPhysicalConnection() throws SQLException {\n            super(\"jdbc:oracle:oci:@\", connectionProperties(), null);\n        }\n\n        @Override\n        protected void readConnectionProperties(String url, Properties properties) throws SQLException {\n            super.readConnectionProperties(url, properties);\n        }\n\n        private static Properties connectionProperties() {\n            Properties properties = new Properties();\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_test_user\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, \"metadata_test_password\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \"1\");\n            return properties;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777883761031}}
