  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleConnection;
  import oracle.jdbc.driver.OracleDriver;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.Timeout;
  
  import java.sql.Connection;
  import java.sql.SQLException;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class T4CDriverExtensionTest {
      private static final String UNREACHABLE_THIN_URL = "jdbc:oracle:thin:@127.0.0.1:1/FREEPDB1";
  
      @Test
      @Timeout(10)
      void loadsTrueCacheDriverExtensionBeforeOpeningConnection() throws SQLException {
          Properties properties = connectionProperties();
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USE_TRUECACHE_DRIVER_CONNECTION, "true");
  
          connectUntilExpectedOfflineFailure(properties);
      }
  
      @Test
      @Timeout(10)
      void loadsShardingDriverExtensionBeforeOpeningConnection() throws SQLException {
          Properties properties = connectionProperties();
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USE_SHARDING_DRIVER_CONNECTION, "true");
  
          connectUntilExpectedOfflineFailure(properties);
      }
  
      private static Properties connectionProperties() {
          Properties properties = new Properties();
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, "metadata_test_user");
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, "metadata_test_password");
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_THIN_NET_CONNECT_TIMEOUT, "1000");
          properties.setProperty(OracleConnection.CONNECTION_PROPERTY_LOGIN_TIMEOUT, "1");
          return properties;
      }
  
      private static void connectUntilExpectedOfflineFailure(Properties properties) throws SQLException {
          OracleDriver driver = new OracleDriver();
  
          try (Connection connection = driver.connect(UNREACHABLE_THIN_URL, properties)) {
              assertThat(connection).isNotNull();
          } catch (SQLException exception) {
              assertThat((Object) exception).isNotNull();
          } catch (NoClassDefFoundError error) {
              assertThat(error.getMessage()).contains("oracle/ucp/jdbc");
          }
      }
  }
