n    @Test\n    void registersSqlTypesByClassNameAndCreatesMappedJavaObjects() throws Exception {\n        TestPhysicalConnection connection = new TestPhysicalConnection();\n        String sqlTypeName = \"APP.SAMPLE_SQL_OBJECT\";\n\n        connection.registerSQLType(sqlTypeName, SampleSqlObject.class.getName());\n\n        assertThat(connection.getSQLType(new SampleSqlObject())).isEqualTo(sqlTypeName);\n        assertThat(connection.getJavaObject(sqlTypeName)).isInstanceOf(SampleSqlObject.class);\n        assertThat(connection.getJavaObjectTypeMap()).containsEntry(sqlTypeName, SampleSqlObject.class);\n    }\n\n    @Test\n    void resolvesJavaClassesForSqlObjectSchemas() throws Exception {\n        TestPhysicalConnection connection = new TestPhysicalConnection();\n\n        Class<?> resolvedClass = connection.classForNameAndSchema(SampleSqlObject.class.getName(), \"APP\");\n\n        assertThat(resolvedClass).isEqualTo(SampleSqlObject.class);\n    }\n\n    public static final class SampleSqlObject {\n    }\n\n    private static final class TestPhysicalConnection extends OracleOCIConnection {\n        private TestPhysicalConnection() throws SQLException {\n            super(\"jdbc:oracle:oci:@\", connectionProperties(), null);\n        }\n\n        private static Properties connectionProperties() {\n            Properties properties = new Properties();\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_test_user\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, \"metadata_test_password\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \"25\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_EXECUTE_BATCH, \"3\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_REMARKS_REPORTING, \"true\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_IMPLICIT_STATEMENT_CACHE_SIZE, \"7\");\n            return properties;\n        }\n\n        @Override\n        public Map<String, Class<?>> getJavaObjectTypeMap() {\n            return super.getJavaObjectTypeMap();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 684, "output": 1298, "cacheRead": 38400, "cacheWrite": 0, "totalTokens": 40382, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777843228474, "responseId": "resp_0444c9f0af115a6e0169f7bc1d114c8190882f02f4837af2f7"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_NZ6muwm8NYYr7LfWcv7LwAyV|fc_0444c9f0af115a6e0169f7bc2563c08190abe601704a8138bb", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3402 bytes to tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/PhysicalConnectionTest.java"}], "isError": false, "timestamp": 1777843242370}]}
