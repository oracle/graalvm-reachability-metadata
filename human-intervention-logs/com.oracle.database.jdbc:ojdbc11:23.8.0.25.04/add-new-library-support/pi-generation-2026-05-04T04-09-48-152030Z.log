[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/OracleTypeCOLLECTIONTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.oracore.OracleTypeCOLLECTION;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.sql.Types;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OracleTypeCOLLECTIONTest {\n\n    @Test\n    void serializesAndDeserializesCollectionTypeMetadata() throws Exception {\n        OracleTypeCOLLECTION original = new OracleTypeCOLLECTION(\"APP.NUMBER_LIST\", null);\n\n        byte[] serialized = serialize(original);\n        OracleTypeCOLLECTION restored = deserializeOracleTypeCOLLECTION(serialized);\n\n        assertThat(restored.getTypeCode()).isEqualTo(Types.ARRAY);\n        assertThat(restored.getFullName()).isEqualTo(\"APP.NUMBER_LIST\");\n        assertThat(restored.getMaxLength()).isZero();\n    }\n\n    private static byte[] serialize(OracleTypeCOLLECTION oracleTypeCOLLECTION) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(oracleTypeCOLLECTION);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static OracleTypeCOLLECTION deserializeOracleTypeCOLLECTION(byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(OracleTypeCOLLECTION.class);\n            return (OracleTypeCOLLECTION) restored;\n        }\n    }\n}\n"}
