  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.oracore.OracleTypeADT;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OracleTypeADTTest {
  
      @Test
      void serializesAndDeserializesAdtTypeMetadata() throws Exception {
          byte[] toid = new byte[] {1, 3, 5, 7, 9, 11, 13, 15};
          OracleTypeADT original = new OracleTypeADT(toid, 7, 873, (short) 1, "APP.CUSTOMER_TYPE");
  
          byte[] serialized = serialize(original);
          OracleTypeADT restored = deserializeOracleTypeADT(serialized);
  
          assertThat(restored.getFullName()).isEqualTo("APP.CUSTOMER_TYPE");
          assertThat(restored.getTOID()).containsExactly(toid);
          assertThat(restored.getTypeVersion()).isEqualTo(7);
          assertThat(restored.getCharSet()).isEqualTo(873);
          assertThat(restored.getCharSetForm()).isEqualTo(1);
      }
  
      private static byte[] serialize(OracleTypeADT oracleTypeADT) throws IOException {
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {
              objectOutputStream.writeObject(oracleTypeADT);
          }
          return outputStream.toByteArray();
      }
  
      private static OracleTypeADT deserializeOracleTypeADT(byte[] serialized)
              throws IOException, ClassNotFoundException {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              Object restored = objectInputStream.readObject();
              assertThat(restored).isInstanceOf(OracleTypeADT.class);
              return (OracleTypeADT) restored;
          }
      }
  }
