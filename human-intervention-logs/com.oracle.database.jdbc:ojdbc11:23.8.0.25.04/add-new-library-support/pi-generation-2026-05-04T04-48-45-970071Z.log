ypeName()).isEqualTo(SQL_TYPE_NAME);\n        assertThat(restored.getBytes()).containsExactly(REF_BYTES);\n    }\n\n    @Test\n    void toClassInstantiatesOraDataFactory() throws Exception {\n        OracleRef oracleRef = oracleRef();\n\n        Object converted = oracleRef.toClass(RefDataFactory.class, Map.of());\n\n        assertThat(converted).isInstanceOf(CreatedOraData.class);\n        CreatedOraData createdOraData = (CreatedOraData) converted;\n        assertThat(createdOraData.datum()).isSameAs(oracleRef);\n        assertThat(createdOraData.sqlType()).isEqualTo(Types.REF);\n    }\n\n    private static OracleRef oracleRef() throws SQLException {\n        return new OracleRef(SQL_TYPE_NAME, serializableConnection(), REF_BYTES.clone());\n    }\n\n    private static oracle.jdbc.internal.OracleConnection serializableConnection() {\n        return (oracle.jdbc.internal.OracleConnection) Proxy.newProxyInstance(\n                OracleRefTest.class.getClassLoader(),\n                new Class<?>[] {oracle.jdbc.internal.OracleConnection.class, Serializable.class},\n                new SerializableOracleConnectionHandler());\n    }\n\n    private static byte[] serialize(OracleRef oracleRef) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(oracleRef);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static OracleRef deserializeOracleRef(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(OracleRef.class);\n            return (OracleRef) restored;\n        }\n    }\n\n    public static final class RefDataFactory implements ORADataFactory {\n        public RefDataFactory() {\n        }\n\n        @Override\n        public ORAData create(Datum datum, int sqlType) {\n            return new CreatedOraData(datum, sqlType);\n        }\n    }\n\n    public static final class CreatedOraData implements ORAData {\n        private final Datum datum;\n        private final int sqlType;\n\n        private CreatedOraData(Datum datum, int sqlType) {\n            this.datum = datum;\n            this.sqlType = sqlType;\n        }\n\n        @Override\n        public Datum toDatum(Connection connection) {\n            return datum;\n        }\n\n        private Datum datum() {\n            return datum;\n        }\n\n        private int sqlType() {\n            return sqlType;\n        }\n    }\n\n    private static final class SerializableOracleConnectionHandler implements InvocationHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) throws Throwable {\n            switch (method.getName()) {\n                case \"physicalConnectionWithin\":\n                case \"getWrapper\":\n                    return proxy;\n                case \"isWrapperFor\":\n                    return false;\n                case \"unwrap\":\n                    throw new SQLFeatureNotSupportedException(\"unwrap is not needed by this test\");\n                case \"toString\":\n                    return \"SerializableOracleConnection\";\n                case \"hashCode\":\n                    return System.identityHashCode(proxy);\n                case \"equals\":\n                    return proxy == args[0];\n                default:\n                    return defaultValue(method.getReturnType());\n            }\n        }\n\n        private static Object defaultValue(Class<?> returnType) {\n            if (!returnType.isPrimitive()) {\n                return null;\n            }\n            if (returnType == boolean.class) {\n                return false;\n            }\n            if (returnType == byte.class) {\n                return (byte) 0;\n            }\n            if (returnType == short.class) {\n                return (short) 0;\n            }\n            if (returnType == int.class) {\n                return 0;\n            }\n            if (returnType == long.class) {\n                return 0L;\n            }\n            if (returnType == float.class) {\n                return 0.0F;\n            }\n            if (returnType == double.class) {\n                return 0.0D;\n            }\n            if (returnType == char.class) {\n                return (char) 0;\n            }\n            return null;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777870066215}, {"role": "toolResult", "toolCallId": "call_5Cf2AbwoFo0eDi0ZA3uNkziX|fc_067e1b90a8452cc80169f824f1ee60819e9e4d3432100a8bf6", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport org.junit.jupiter.api.Test;\n\npublic class Ojdbc11Test {\n    @Test\n    void test() throws Exception {\n        System.out.println(\"This is just a placeholder, implement your test\");\n    }\n}\n"}], "isError": false, "timestamp": 1777870066216}]}
