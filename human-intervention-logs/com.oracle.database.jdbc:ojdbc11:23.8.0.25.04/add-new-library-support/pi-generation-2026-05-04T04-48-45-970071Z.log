[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/OraclePooledConnectionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.internal.OracleConnection;\nimport oracle.jdbc.pool.OraclePooledConnection;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.lang.reflect.InvocationHandler;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Proxy;\nimport java.sql.Connection;\nimport java.sql.SQLException;\nimport java.sql.SQLFeatureNotSupportedException;\nimport java.util.Hashtable;\nimport java.util.Properties;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OraclePooledConnectionTest {\n\n    @Test\n    void serializesAndDeserializesPooledConnectionProperties() throws Exception {\n        RecordingOracleConnectionHandler handler = new RecordingOracleConnectionHandler();\n        OraclePooledConnection pooledConnection = new OraclePooledConnection(serializableConnection(handler), false);\n\n        byte[] serialized = serialize(pooledConnection);\n        OraclePooledConnection restored = deserializeOraclePooledConnection(serialized);\n\n        assertThat(serialized).isNotEmpty();\n        assertThat(restored.getPhysicalHandle()).isNull();\n        assertThat(handler.propertyCaptureCount()).isEqualTo(1);\n        assertThat(handler.closeCount()).isEqualTo(1);\n    }\n\n    private static OracleConnection serializableConnection(RecordingOracleConnectionHandler handler) {\n        return (OracleConnection) Proxy.newProxyInstance(\n                OraclePooledConnectionTest.class.getClassLoader(),\n                new Class<?>[] {OracleConnection.class, Serializable.class},\n                handler);\n    }\n\n    private static byte[] serialize(OraclePooledConnection pooledConnection) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(pooledConnection);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static OraclePooledConnection deserializeOraclePooledConnection(byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(OraclePooledConnection.class);\n            return (OraclePooledConnection) restored;\n        }\n    }\n\n    private static final class RecordingOracleConnectionHandler implements InvocationHandler, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private int propertyCaptureCount;\n        private int closeCount;\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) throws SQLException {\n            switch (method.getName()) {\n                case \"getPropertyForPooledConnection\":\n                    OraclePooledConnection pooledConnection = (OraclePooledConnection) args[0];\n                    pooledConnection.setProperties(serializedConnectionProperties());\n                    propertyCaptureCount++;\n                    return null;\n                case \"close\":\n                    closeCount++;\n                    return null;\n                case \"isWrapperFor\":\n                    return false;\n                case \"unwrap\":\n                    throw new SQLFeatureNotSupportedException(\"unwrap is not needed by this test\");\n                case \"toString\":\n                    return \"SerializableOracleConnection\";\n                case \"hashCode\":\n                    return System.identityHashCode(proxy);\n                case \"equals\":\n                    return proxy == args[0];\n                default:\n                    return defaultValue(method.getReturnType());\n            }\n        }\n\n        private static Hashtable<String, Object> serializedConnectionProperties() {\n            Properties connectionProperties = new Properties();\n            connectionProperties.setProperty(OraclePooledConnection.url_string, \"jdbc:not-oracle\");\n            connectionProperties.setProperty(OraclePooledConnection.transaction_isolation,\n                    String.valueOf(Connection.TRANSACTION_READ_COMMITTED));\n            connectionProperties.setProperty(OraclePooledConnection.statement_cache_size, \"0\");\n            connectionProperties.setProperty(OraclePooledConnection.isClearMetaData, \"false\");\n            connectionProperties.setProperty(OraclePooledConnection.ImplicitStatementCachingEnabled, \"false\");\n            connectionProperties.setProperty(OraclePooledConnection.ExplicitStatementCachingEnabled, \"false\");\n            connectionProperties.setProperty(OraclePooledConnection.connect_auto_commit_string, \"true\");\n\n            Hashtable<String, Object> properties = new Hashtable<>();\n            properties.put(OraclePooledConnection.connection_properties_string, connectionProperties);\n            return properties;\n        }\n\n        private int propertyCaptureCount() {\n            return propertyCaptureCount;\n        }\n\n        private int closeCount() {\n            return closeCount;\n        }\n\n        private static Object defaultValue(Class<?> returnType) {\n            if (!returnType.isPrimitive()) {\n                re