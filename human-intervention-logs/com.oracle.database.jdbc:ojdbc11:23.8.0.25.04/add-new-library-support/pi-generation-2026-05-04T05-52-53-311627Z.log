  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.diagnostics.CommonDiagnosable;
  import oracle.jdbc.driver.DMSFactory;
  import oracle.net.ano.Ano;
  import oracle.net.ano.AuthenticationService;
  import oracle.net.ns.ClientProfile;
  import oracle.net.ns.NetException;
  import oracle.net.ns.SessionAtts;
  import oracle.net.nt.NTAdapter;
  import org.junit.jupiter.api.Test;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.net.InetAddress;
  import java.net.SocketException;
  import java.nio.channels.SocketChannel;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class RadiusAuthenticationServiceTest {
  
      @Test
      void loadsConfiguredChallengeResponseHandlerClassName() throws Throwable {
          TestSessionAtts session = new TestSessionAtts();
          session.ano = new Ano();
          session.profile = new ClientProfile(radiusProperties());
          session.setNTAdapter(new TestNTAdapter());
          MethodHandle constructor = radiusAuthenticationServiceConstructor();
  
          assertThatThrownBy(() -> constructor.invoke(session, new AuthenticationService()))
                  .isInstanceOf(NetException.class)
                  .hasCauseInstanceOf(ClassCastException.class)
                  .hasMessageContaining("java.lang.Object");
      }
  
      private static Properties radiusProperties() {
          Properties properties = new Properties();
          properties.setProperty("oracle.net.radius_challenge_response_handler", "java.lang.Object");
          return properties;
      }
  
      private static MethodHandle radiusAuthenticationServiceConstructor() throws ClassNotFoundException,
              NoSuchMethodException, IllegalAccessException {
          Class<?> radiusAuthenticationServiceClass = Class.forName("oracle.net.ano.RadiusAuthenticationService");
          MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(radiusAuthenticationServiceClass,
                  MethodHandles.lookup());
          return lookup.findConstructor(radiusAuthenticationServiceClass,
                  MethodType.methodType(void.class, SessionAtts.class, AuthenticationService.class));
      }
  
      private static final class TestSessionAtts extends SessionAtts {
  
          private TestSessionAtts() {
              super(null, 8_192, 8_192, false, false, CommonDiagnosable.getInstance());
          }
  
          private void setNTAdapter(NTAdapter adapter) {
              nt = adapter;
          }
      }
  
      private static final class TestNTAdapter implements NTAdapter {
  
          @Override
          public NetworkAdapterType getNetworkAdapterType() {
              return NetworkAdapterType.TCP;
          }
  
          @Override
          public void connect(DMSFactory.DMSNoun noun) throws IOException {
              throw new UnsupportedOperationException();
          }
  
          @Override
