[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/ConverterArchiveTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.sql.ConverterArchive;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.io.File;\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.UUID;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ConverterArchiveTest {\n\n    private static final String RESOURCE_OBJECT = \"/converter-archive-resource.ser\";\n\n    @TempDir\n    Path temporaryDirectory;\n\n    @Test\n    void insertsObjectIntoOpenArchiveAndReadsItBack() throws Exception {\n        Path archivePath = temporaryDirectory.resolve(\"open-archive.zip\");\n        ConverterArchive archive = new ConverterArchive();\n\n        archive.openArchiveforInsert(archivePath.toString());\n        archive.insertObj(\"open-archive-value\", \"stored-entry.ser\");\n        archive.closeArchiveforInsert();\n\n        assertThat(archive.readObj(archivePath.toString(), \"stored-entry.ser\")).isEqualTo(\"open-archive-value\");\n    }\n\n    @Test\n    void insertsObjectIntoDirectoryFile() throws Exception {\n        ConverterArchive archive = new ConverterArchive();\n        String directory = temporaryDirectory.toString() + File.separator;\n        String filename = \"single-object.ser\";\n\n        archive.insertObjtoFile(directory, filename, \"file-value\");\n\n        assertThat(Files.size(temporaryDirectory.resolve(filename))).isGreaterThan(0L);\n    }\n\n    @Test\n    void insertsSingleObjectIntoNewArchiveAndReplacesExistingArchive() throws Exception {\n        Path archivePath = Path.of(\"converter-archive-\" + UUID.randomUUID() + \".zip\").toAbsolutePath();\n        Path temporaryZipPath = Path.of(\"gsstemp.zip\").toAbsolutePath();\n        Files.deleteIfExists(archivePath);\n        Files.deleteIfExists(temporaryZipPath);\n\n        ConverterArchive archive = new ConverterArchive();\n        try {\n            archive.insertSingleObj(archivePath.toString(), \"original-value\", \"original-entry.ser\");\n            archive.insertSingleObj(archivePath.toString(), \"added-value\", \"added-entry.ser\");\n\n            assertThat(archive.readObj(archivePath.toString(), \"original-entry.ser\")).isEqualTo(\"original-value\");\n            assertThat(archive.readObj(archivePath.toString(), \"added-entry.ser\")).isEqualTo(\"added-value\");\n        } finally {\n            deleteIfExists(archivePath);\n            deleteIfExists(temporaryZipPath);\n        }\n    }\n\n    @Test\n    void readsSerializedObjectFromClasspathResource() {\n        ConverterArchive archive = new ConverterArchive();\n\n        assertThat(archive.readObj(RESOURCE_OBJECT)).isEqualTo(\"resource-object\");\n    }\n\n    private static void deleteIfExists(Path path) throws IOException {\n        Files.deleteIfExists(path);\n    }\n}\n"}
