nimport oracle.jdbc.proxy.annotation.ProxyFor;\nimport oracle.jdbc.proxy.annotation.SetDelegate;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.ref.WeakReference;\nimport java.util.IdentityHashMap;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ProxyFactoryTest {\n\n    @Test\n    void proxyForTypeInstantiatesProxyForRegisteredDelegateType() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ManualProxy.class);\n\n        Object proxy = proxyFactory.proxyForType(SampleDelegate.class);\n\n        assertThat(proxy).isInstanceOf(SampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(extractDelegate(proxy)).isNull();\n    }\n\n    @Test\n    void proxyForCreateInstantiatesProxyWithoutUsingCache() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), ManualProxy.class);\n        SampleDelegate delegate = new SampleDelegate();\n\n        Object proxy = proxyFactory.<Object>proxyForCreate(delegate);\n\n        assertThat(proxy).isInstanceOf(SampleService.class);\n        assertThat(proxy).isInstanceOf(_Proxy_.class);\n        assertThat(extractDelegate(proxy)).isSameAs(delegate);\n    }\n\n    @Test\n    void proxyForCacheReturnsProxyAlreadyStoredOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(\n                ProxyFactoryTest.class.getPackageName(), CachingProxy.class);\n        SampleDelegate delegate = new SampleDelegate();\n        Object cachedProxy = new Object();\n        delegate.setProxyMarker(cachedProxy);\n\n        Object proxy = proxyFactory.<Object>proxyFor(delegate);\n\n        assertThat(proxy).isSameAs(cachedProxy);\n    }\n\n    @Test\n    void proxyForCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {\n        ProxyFactory proxyFactory = ProxyF