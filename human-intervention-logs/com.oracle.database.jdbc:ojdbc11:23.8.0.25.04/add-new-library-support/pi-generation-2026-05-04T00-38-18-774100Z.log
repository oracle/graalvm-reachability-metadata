[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/OracleRefTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.OracleConnection;\nimport oracle.jdbc.driver.OracleOCIConnection;\nimport oracle.jdbc.driver.OracleRef;\nimport oracle.sql.Datum;\nimport oracle.sql.ORAData;\nimport oracle.sql.ORADataFactory;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.sql.Connection;\nimport java.sql.SQLException;\nimport java.util.Map;\nimport java.util.Properties;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OracleRefTest {\n\n    private static final String SQL_TYPE_NAME = \"APP.CUSTOMER_REF\";\n    private static final byte[] REF_BYTES = new byte[] {1, 2, 5, 8, 13, 21, 34, 55};\n\n    @Test\n    void serializesAndDeserializesRefMetadata() throws Exception {\n        OracleRef original = oracleRef();\n\n        byte[] serialized = serialize(original);\n        OracleRef restored = deserializeOracleRef(serialized);\n\n        assertThat(restored.getBaseTypeName()).isEqualTo(SQL_TYPE_NAME);\n        assertThat(restored.getBytes()).containsExactly(REF_BYTES);\n    }\n\n    @Test\n    void toClassInstantiatesOraDataFactory() throws Exception {\n        OracleRef oracleRef = oracleRef();\n\n        Object converted = oracleRef.toClass(RefDataFactory.class, Map.of());\n\n        assertThat(converted).isInstanceOf(CreatedOraData.class);\n        CreatedOraData createdOraData = (CreatedOraData) converted;\n        assertThat(createdOraData.datum()).isSameAs(oracleRef);\n        assertThat(createdOraData.sqlType()).isEqualTo(2006);\n    }\n\n    private static OracleRef oracleRef() throws SQLException {\n        return new OracleRef(SQL_TYPE_NAME, new TestOracleConnection(), REF_BYTES.clone());\n    }\n\n    private static byte[] serialize(OracleRef oracleRef) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(oracleRef);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static OracleRef deserializeOracleRef(byte[] serialized) throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(OracleRef.class);\n            return (OracleRef) restored;\n        }\n    }\n\n    public static final class RefDataFactory implements ORADataFactory {\n        public RefDataFactory() {\n        }\n\n        @Override\n        public ORAData create(Datum datum, int sqlType) {\n            return new CreatedOraData(datum, sqlType);\n        }\n    }\n\n    public static final class CreatedOraData implements ORAData {\n        private final Datum datum;\n        private final int sqlType;\n\n        private CreatedOraData(Datum datum, int sqlType) {\n            this.datum = datum;\n            this.sqlType = sqlType;\n        }\n\n        @Override\n        public Datum toDatum(Connection connection) {\n            return datum;\n        }\n\n        private Datum datum() {\n            return datum;\n        }\n\n        private int sqlType() {\n            return sqlType;\n        }\n    }\n\n    private static final class TestOracleConnection extends OracleOCIConnection {\n        private TestOracleConnection() throws SQLException {\n            super(\"jdbc:oracle:oci:@\", connectionProperties(), null);\n        }\n\n        @Override\n        protected void readConnectionProperties(String url, Properties properties) throws SQLException {\n            super.readConnectionProperties(url, properties);\n        }\n\n        private static Properties connectionProperties() {\n            Properties properties = new Properties();\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_test_user\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, \"metadata_test_password\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \"25\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_EXECUTE_BATCH, \"3\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DIAGNOSTIC_LOGGER_NAME,\n                    OracleRefTest.class.getName());\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_DIAGNOSTIC_BUFFER_SIZE, \"1000\");\n            return properties;\n        }\n    }\n}\n"}
