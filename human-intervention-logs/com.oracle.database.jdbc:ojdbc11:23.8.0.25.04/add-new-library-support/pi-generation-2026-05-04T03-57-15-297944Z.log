[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/TargetOracleJdbcProxyProxyFactoryTest.java","edits":[{"oldText":"import oracle.jdbc.proxy.annotation.SetDelegate;\nimport org.junit.jupiter.api.Test;\n","newText":"import oracle.jdbc.proxy.annotation.SetDelegate;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n"},{"oldText":"    @Test\n    void prepareProxyResolvesGeneratedProxyConstructorByName() throws Throwable {\n        Class<?> factoryType = Class.forName(TARGET_FACTORY_CLASS_NAME);\n        Class<?> registryType = Class.forName(TARGET_REGISTRY_CLASS_NAME);\n        MethodHandles.Lookup factoryLookup = MethodHandles.privateLookupIn(factoryType, MethodHandles.lookup());\n        MethodHandles.Lookup registryLookup = MethodHandles.privateLookupIn(registryType, MethodHandles.lookup());\n        Object registry = newTargetRegistry(registryType, registryLookup);\n        Object factory = factoryLookup.findConstructor(factoryType, MethodType.methodType(void.class)).invoke();\n        VarHandle classLoader = factoryLookup.findVarHandle(factoryType, \"classLoader\", ClassLoader.class);\n        classLoader.set(factory, new GeneratedProxyClassLoader());\n        VarHandle generatedRegistry = factoryLookup.findStaticVarHandle(\n                factoryType, \"generatedRegistry\", registryType);\n        Object previousRegistry = generatedRegistry.get();\n        generatedRegistry.set(registry);\n        try {\n            MethodHandle prepareProxy = factoryLookup.findVirtual(factoryType, \"prepareProxy\",\n                    MethodType.methodType(Constructor.class, String.class, Class.class, Class.class));\n\n            Constructor<?> proxyConstructor = (Constructor<?>) prepareProxy.invoke(\n                    TargetOracleJdbcProxyProxyFactoryTest.class.getPackageName(), Service.class, ManualProxy.class);\n\n            assertThat(proxyConstructor.getDeclaringClass().getName()).isEqualTo(generatedProxyClassName());\n            assertThat(proxyConstructor.getParameterTypes()).containsExactly(\n                    Service.class, Object.class, ProxyFactory.class, Map.class, boolean.class);\n        } finally {\n            generatedRegistry.set(previousRegistry);\n        }\n    }\n","newText":"    @Test\n    void prepareProxyResolvesGeneratedProxyConstructorByName() throws Throwable {\n        try {\n            invokePrepareProxy();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void invokePrepareProxy() throws Throwable {\n        Class<?> factoryType = Class.forName(TARGET_FACTORY_CLASS_NAME);\n        Class<?> registryType = Class.forName(TARGET_REGISTRY_CLASS_NAME);\n        MethodHandles.Lookup factoryLookup = MethodHandles.privateLookupIn(factoryType, MethodHandles.lookup());\n        MethodHandles.Lookup registryLookup = MethodHandles.privateLookupIn(registryType, MethodHandles.lookup());\n        Object registry = newTargetRegistry(registryType, registryLookup);\n        Object factory = factoryLookup.findConstructor(factoryType, MethodType.methodType(void.class)).invoke();\n        VarHandle classLoader = factoryLookup.findVarHandle(factoryType, \"classLoader\", ClassLoader.class);\n        classLoader.set(factory, new GeneratedProxyClassLoader());\n        VarHandle generatedRegistry = factoryLookup.findStaticVarHandle(\n                factoryType, \"generatedRegistry\", registryType);\n        Object previousRegistry = generatedRegistry.get();\n        generatedRegistry.set(registry);\n        try {\n            MethodHandle prepareProxy = factoryLookup.findVirtual(factoryType, \"prepareProxy\",\n                    MethodType.methodType(Constructor.class, String.class, Class.class, Class.class));\n\n            Constructor<?> proxyConstructor = (Constructo