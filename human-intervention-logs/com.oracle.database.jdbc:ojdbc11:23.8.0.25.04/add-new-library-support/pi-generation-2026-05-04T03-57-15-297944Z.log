okup.findConstructor(registryType, MethodType.methodType(void.class)).invoke();\n        VarHandle registryMap = registryLookup.findVarHandle(registryType, \"registry\", Map.class);\n        registryMap.set(registry, new ConcurrentHashMap<>());\n        return registry;\n    }\n\n    private static String generatedProxyClassName() {\n        String packageName = TargetOracleJdbcProxyProxyFactoryTest.class.getPackageName();\n        String superclassName = ManualProxy.class.getName().replace(\".\", \"$1\");\n        String interfaceName = Service.class.getName().replace(\".\", \"$1\");\n        return packageName + \".\" + superclassName + \"$2\" + interfaceName + \"$$$Proxy\";\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static Object extractDelegate(Object proxy) {\n        return ProxyFactory.extractDelegate((_Proxy_<Object>) proxy);\n    }\n\n    public interface Service {\n        String value();\n    }\n\n    public static final class ServiceDelegate implements Service {\n        private final String value;\n\n        ServiceDelegate(String value) {\n            this.value = value;\n        }\n\n        @Override\n        public String value() {\n            return value;\n        }\n    }\n\n    @ProxyFor(Service.class)\n    public abstract static class ManualProxy {\n        @GetDelegate\n        protected abstract Service getDelegate();\n\n        @SetDelegate\n        protected abstract void setDelegate(Service delegate);\n\n        @GetCreator\n        protected abstract Object getCreator();\n    }\n}\n\n@SuppressWarnings(\"checkstyle:TypeName\")\nclass com_oracle_database_jdbc$1ojdbc11$1TargetOracleJdbcProxyProxyFactoryTest$ManualProxy$2com_oracle_database_jdbc$1ojdbc11$1TargetOracleJdbcProxyProxyFactoryTest$Service$$$Proxy\n        extends TargetOracleJdbcProxyProxyFactoryTest.ManualProxy\n        implements TargetOracleJdbcProxyProxyFactoryTest.Service, _Proxy_<TargetOracleJdbcProxyProxyFactoryTest.Service> {\n    private TargetOracleJdbc