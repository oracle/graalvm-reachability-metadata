  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.proxy.ProxyFactory;
  import oracle.jdbc.proxy._Proxy_;
  import oracle.jdbc.proxy.annotation.GetCreator;
  import oracle.jdbc.proxy.annotation.GetDelegate;
  import oracle.jdbc.proxy.annotation.ProxyFor;
  import oracle.jdbc.proxy.annotation.SetDelegate;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.invoke.VarHandle;
  import java.lang.ref.WeakReference;
  import java.lang.reflect.Constructor;
  import java.util.Map;
  import java.util.concurrent.ConcurrentHashMap;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TargetOracleJdbcProxyProxyFactoryTest {
      private static final String TARGET_FACTORY_CLASS_NAME =
              "oracle.jdbc.nativeimage.Target_oracle_jdbc_proxy_ProxyFactory";
      private static final String TARGET_REGISTRY_CLASS_NAME =
              "oracle.jdbc.nativeimage.Target_oracle_jdbc_proxy_GeneratedProxiesRegistry";
      private static final String TARGET_REGISTRY_KEY_CLASS_NAME =
              "oracle.jdbc.nativeimage.Target_oracle_jdbc_proxy_GeneratedProxiesRegistry_Key";
  
      @Test
      void prepareProxyResolvesGeneratedProxyConstructorByName() throws Throwable {
          Class<?> factoryType = Class.forName(TARGET_FACTORY_CLASS_NAME);
          Class<?> registryType = Class.forName(TARGET_REGISTRY_CLASS_NAME);
          MethodHandles.Lookup factoryLookup = MethodHandles.privateLookupIn(factoryType, MethodHandles.lookup());
          MethodHandles.Lookup registryLookup = MethodHandles.privateLookupIn(registryType, MethodHandles.lookup());
          Object registry = newTargetRegistry(registryType, registryLookup);
          Object factory = factoryLookup.findConstructor(factoryType, MethodType.methodType(void.class)).invoke();
          VarHandle classLoader = factoryLookup.findVarHandle(factoryType, "classLoader", ClassLoader.class);
          classLoader.set(factory, new GeneratedProxyClassLoader());
          VarHandle generatedRegistry = factoryLookup.findStaticVarHandle(
                  factoryType, "generatedRegistry", registryType);
          Object previousRegistry = generatedRegistry.get();
          generatedRegistry.set(registry);
          try {
              MethodHandle prepareProxy = factoryLookup.findVirtual(factoryType, "prepareProxy",
                      MethodType.methodType(Constructor.class, String.class, Class.class, Class.class));
  
              Constructor<?> proxyConstructor = (Constructor<?>) prepareProxy.invoke(
                      TargetOracleJdbcProxyProxyFactoryTest.class.getPackageName(), Service.class, ManualProxy.class);
  
              assertThat(proxyConstructor.getDeclaringClass().getName()).isEqualTo(generatedProxyClassName());
              assertThat(proxyConstructor.getParameterTypes()).containsExactly(
                      Service.class, Object.class, ProxyFactory.class, Map.class, boolean.class);
          } finally {
              generatedRegistry.set(previousRegistry);
          }
      }
  
      @Test
      void proxyForCreateResolvesGeneratedProxyConstructorByName() {
          ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                  TargetOracleJdbcProxyProxyFactoryTest.class.getPackageName(), ManualProxy.class);
          ServiceDelegate delegate = new ServiceDelegate("proxied");
  
          Object proxy = proxyFactory.<Object>proxyForCreate(delegate);
  
          assertThat(proxy).isInstanceOf(Service.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(((Service) proxy).value()).isEqualTo("proxied");
          assertThat(extractDelegate(proxy)).isSameAs(delegate);
      }
  
      private static Object newTargetRegistry(
              Class<?> registryType, MethodHandles.Lookup registryLookup) throws Throwable {
          Object registry = registryLookup.findConstructor(registryType, MethodType.methodType(void.class)).invoke();
          VarHandle registryMap = registryLookup.findVarHandle(registryType, "registry", Map.class);
          registryMap.set(registry, new ConcurrentHashMap<>());
          return registry;
      }
  
      private static String generatedProxyClassName() {
          String packageName = TargetOracleJdbcProxyProxyFactoryTest.class.getPackageName();
          String superclassName = ManualProxy.class.getName().replace(".", "$1");
          String interfaceName = Service.class.getName().replace(".", "$1");
          return packageName + "." + superclassName + "$2" + interfaceName + "$$$Proxy";
      }
  
      @SuppressWarnings("unchecked")
      private static Object extractDelegate(Object proxy) {
          return ProxyFactory.extractDelegate((_Proxy_<Object>) proxy);
      }
  
      private static final class GeneratedProxyClassLoader extends ClassLoader {
          GeneratedProxyClassLoader() {
              super(TargetOracleJdbcProxyProxyFactoryTest.class.getClassLoader());
          }
  
          @Override
          protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (name.startsWith(TARGET_REGISTRY_KEY_CLASS_NAME + "@")) {
                  return Class.forName(generatedProxyClassName(), false, getParent());
              }
              return super.loadClass(name, resolve);
          }
      }
  
      public interface Service {
          String value();
      }
  
      public static final class ServiceDelegate implements Service {
          private final String value;
  
          ServiceDelegate(String value) {
              this.value = value;
          }
  
          @Override
          public String value() {
              return value;
          }
      }
  
      @ProxyFor(Service.class)
  
