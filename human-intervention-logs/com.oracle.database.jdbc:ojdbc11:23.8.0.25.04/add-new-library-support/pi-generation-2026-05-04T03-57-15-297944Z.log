ort java.lang.invoke.MethodType;\nimport java.lang.invoke.VarHandle;\nimport java.lang.ref.WeakReference;\nimport java.lang.reflect.Constructor;\nimport java.util.Map;\nimport java.util.concurrent.ConcurrentHashMap;\n"}, {"oldText": "            assertThat(proxyConstructor.getDeclaringClass().getName()).isEqualTo(generatedProxyClassName());\n", "newText": "            assertThat(proxyConstructor.getDeclaringClass().getName()).startsWith(TARGET_REGISTRY_KEY_CLASS_NAME + \"@\");\n"}, {"oldText": "    private static Class<?> generatedProxyClass() throws ClassNotFoundException {\n        return Class.forName(\n                generatedProxyClassName(), false, TargetOracleJdbcProxyProxyFactoryTest.class.getClassLoader());\n    }\n\n    private static String generatedProxyClassName() {\n        String packageName = TargetOracleJdbcProxyProxyFactoryTest.class.getPackageName();\n        String superclassName = ManualProxy.class.getName().replace(\".\", \"$1\");\n        String interfaceName = Service.class.getName().replace(\".\", \"$1\");\n        return packageName + \".\" + superclassName + \"$2\" + interfaceName + \"$$$Proxy\";\n    }\n\n    @SuppressWarnings(\"unchecked\")\n", "newText": "    @SuppressWarnings(\"unchecked\")\n"}, {"oldText": "        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (name.startsWith(TARGET_REGISTRY_KEY_CLASS_NAME + \"@\")) {\n                return generatedProxyClass();\n            }\n            return super.loadClass(name, resolve);\n        }\n", "newText": "        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (name.startsWith(TARGET_REGISTRY_KEY_CLASS_NAME + \"@\")) {\n                Class<?> proxyClass = findLoadedClass(name);\n                if (proxyClass == null) {\n                    byte[] classBytes = generateProxyConstructorOnlyClass(name);\n                    proxyClass = defineClass(name, classBytes, 0, classBytes.length);\n                }\n                if (resolve) {\n                    resolveClass(proxyClass);\n                }\n                return proxyClass;\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n\n    private static byte[] generateProxyConstructorOnlyClass(String className) {\n        try {\n            ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n            DataOutputStream out = new DataOutputStream(bytes);\n            String internalName = className.replace('.', '/');\n            String constructorDescriptor = \"(L\" + Service.class.getName().replace('.', '/')\n                    + \";Ljava/lang/Object;Loracle/jdbc/proxy/ProxyFactory;Ljava/util/Map;Z)V\";\n\n            out.writeInt(0xCAFEBABE);\n            out.writeShort(0);\n            out.writeShort(52);\n            out.writeShort(10);\n            writeClass(out, 2);\n            writeUtf8(out, internalName);\n            writeClass(out, 4);\n            writeUtf8(out, \"java/lang/Object\");\n            writeUtf8(out, \"<init>\");\n            writeUtf8(out, \"()V\");\n            writeUtf8(out, \"Code\");\n            writeNameAndType(out, 5, 6);\n            writeMethodRef(out, 3, 8);\n            writeUtf8(out, constructorDescriptor);\n\n            out.writeShort(0x0021);\n            out.writeShort(1);\n            out.writeShort(3);\n            out.writeShort(0);\n            out.writeShort(0);\n            out.writeShort(1);\n            out.writeShort(0x0001);\n            out.writeShort(5);\n            out.writeShort(9);\n            out.writeShort(1);\n            out.writeShort(7);\n            out.writeInt(17);\n            out.writeShort(1);\n            out.writeShort(6);\n            out.writeInt(5);\n            out.writeByte(0x2A);\n            out.writeByte(0xB7);\n            out.writeShort(8);\n            out.writeByte(0xB1);\n            out.writeShort(0);\n