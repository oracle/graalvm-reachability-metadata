[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/TypeDescriptorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.internal.OracleConnection;\nimport oracle.sql.SQLName;\nimport oracle.sql.TypeDescriptor;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.lang.reflect.InvocationHandler;\nimport java.lang.reflect.Proxy;\nimport java.sql.Connection;\nimport java.sql.SQLException;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypeDescriptorTest {\n\n    @Test\n    void mapsTypeCodeConstantsToTheirPublicNames() throws Exception {\n        TypeDescriptor descriptor = new SerializableTypeDescriptor(sqlName(), connectionProxy());\n\n        assertThat(descriptor.getTypeCode()).isEqualTo(TypeDescriptor.TYPECODE_OBJECT);\n        assertThat(descriptor.getTypeCodeName()).isEqualTo(\"TYPECODE_OBJECT\");\n    }\n\n    @Test\n    void serializesAndDeserializesTypeDescriptorName() throws Exception {\n        SerializableTypeDescriptor descriptor = new SerializableTypeDescriptor(sqlName(), connectionProxy());\n\n        byte[] serialized = serialize(descriptor);\n        TypeDescriptor restored = deserializeTypeDescriptor(serialized);\n\n        assertThat(restored).isInstanceOf(SerializableTypeDescriptor.class);\n        assertThat(restored.getName()).isEqualTo(\"APP.CUSTOMER_TYPE\");\n        assertThat(restored.getPickler()).isNull();\n    }\n\n    private static SQLName sqlName() throws SQLException {\n        return new SQLName(\"APP\", \"CUSTOMER_TYPE\", null);\n    }\n\n    private static Connection connectionProxy() {\n        Object[] proxyReference = new Object[1];\n        InvocationHandler handler = (proxy, method, arguments) -> {\n            String methodName = method.getName();\n            if (\"physicalConnectionWithin\".equals(methodName)) {\n                return proxyReference[0];\n            }\n            if (\"toString\".equals(methodName)) {\n                return \"TypeDescriptorTest connection proxy\";\n            }\n            if (\"hashCode\".equals(methodName)) {\n                return System.identityHashCode(proxy);\n            }\n            if (\"equals\".equals(methodName)) {\n                return proxy == arguments[0];\n            }\n            throw new UnsupportedOperationException(method.toString());\n        };\n        proxyReference[0] = Proxy.newProxyInstance(\n                TypeDescriptorTest.class.getClassLoader(),\n                new Class<?>[] {OracleConnection.class},\n                handler);\n        return (Connection) proxyReference[0];\n    }\n\n    private static byte[] serialize(TypeDescriptor descriptor) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(descriptor);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static TypeDescriptor deserializeTypeDescriptor(byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(TypeDescriptor.class);\n            return (TypeDescriptor) restored;\n        }\n    }\n\n    private static final class SerializableTypeDescriptor extends TypeDescriptor implements Serializable {\n        private static final long serialVersionUID = 1L;\n\n        private SerializableTypeDescriptor(SQLName sqlName, Connection connection) throws SQLException {\n            super(TypeDescriptor.TYPECODE_OBJECT, sqlName, connection);\n        }\n    }\n}\n"}
