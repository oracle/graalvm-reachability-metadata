[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/AbstractTrueCachePreparedStatementTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.driver.AbstractTrueCacheConnection;\nimport oracle.jdbc.driver.AbstractTrueCachePreparedStatement;\nimport oracle.jdbc.internal.OracleConnection;\nimport oracle.jdbc.internal.OraclePreparedStatement;\nimport org.junit.jupiter.api.Test;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.reflect.InvocationHandler;\nimport java.lang.reflect.Method;\nimport java.lang.reflect.Proxy;\nimport java.sql.Statement;\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AbstractTrueCachePreparedStatementTest {\n    private static final MethodHandle DELEGATES_BIND_BATCH_CALLS = methodHandle(\n            \"delegatesBindBatchCalls\", MethodType.methodType(void.class, OraclePreparedStatement.class));\n    private static final MethodHandle DELEGATES_BEFORE_PREPARED_STATEMENT_EXECUTE_CALLS = methodHandle(\n            \"delegatesBeforePstmtExecuteCalls\", MethodType.methodType(void.class, OraclePreparedStatement.class));\n\n    @Test\n    void replaysDeferredBindAndBeforeExecuteCallsToPreparedStatementDelegate() throws Throwable {\n        TestTrueCachePreparedStatement preparedStatement = new TestTrueCachePreparedStatement();\n        preparedStatement.setInt(1, 11);\n        preparedStatement.setString(2, \"single\");\n        preparedStatement.setString(1, \"updated\");\n        preparedStatement.addBatch();\n        preparedStatement.setCheckBindTypes(false);\n        preparedStatement.setCheckBindTypes(true);\n        RecordingInvocationHandler invocationHandler = new RecordingInvocationHandler();\n        OraclePreparedStatement delegate = invocationHandler.createProxy();\n\n        DELEGATES_BIND_BATCH_CALLS.invoke(preparedStatement, delegate);\n        DELEGATES_BEFORE_PREPARED_STATEMENT_EXECUTE_CALLS.invoke(preparedStatement, delegate);\n\n        assertThat(invocationHandler.calls())\n                .anySatisfy(call -> assertRecordedCall(call, \"setInt\", 1, 11))\n                .anySatisfy(call -> assertRecordedCall(call, \"setString\", 2, \"single\"))\n                .anySatisfy(call -> assertRecordedCall(call, \"setString\", 1, \"updated\"))\n                .anySatisfy(call -> assertRecordedCall(call, \"addBatch\"))\n                .anySatisfy(call -> assertRecordedCall(call, \"setCheckBindTypes\", false));\n    }\n\n    private static MethodHandle methodHandle(String name, MethodType methodType) {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(\n                    AbstractTrueCachePreparedStatement.class, MethodHandles.lookup());\n            return lookup.findVirtual(AbstractTrueCachePreparedStatement.class, name, methodType);\n        } catch (NoSuchMethodException | IllegalAccessException exception) {\n            throw new ExceptionInInitializerError(exception);\n        }\n    }\n\n    private static void assertRecordedCall(RecordedCall call, String methodName, Object... arguments) {\n        assertThat(call.methodName()).isEqualTo(methodName);\n        assertThat(call.arguments()).containsExactly(arguments);\n    }\n\n    private static final class TestTrueCachePreparedStatement extends AbstractTrueCachePreparedStatement {\n        private final TestTrueCacheConnection connection = new TestTrueCacheConnection();\n        private Statement delegate;\n\n        @Override\n        protected Object getCreator() {\n            return connection;\n        }\n\n        @Override\n        protected Statement getDelegate() {\n            return delegate;\n        }\n\n        @Override\n        protected void setDelegate(Statement delegate) {\n            this.delegate = delegate;\n        }\n    }\n\n    private static final class TestTrueCacheConnection extends AbstractTrueCacheConnection {\n        private OracleConnection delegate;\n\n        @Override\n        protected Object getCreator() {\n            return this;\n        }\n\n        @Override\n        protected OracleConnection getDelegate() {\n            return delegate;\n        }\n\n        @Override\n        protected void setDelegate(OracleConnection delegate) {\n            this.delegate = delegate;\n        }\n    }\n\n    private static final class RecordingInvocationHandler implements InvocationHandler {\n        private final List<RecordedCall> calls = new ArrayList<>();\n\n        OraclePreparedStatement createProxy() {\n            ClassLoader classLoader = AbstractTrueCachePreparedStatementTest.class.getClassLoader();\n            Class<?>[] interfaces = { OraclePreparedStatement.class };\n            Object proxy = Proxy.newProxyInstance(classLoader, interfaces, this);\n            return OraclePreparedStatement.class.cast(proxy);\n        }\n\n        List<RecordedCall> calls() {\n            return calls;\n        }\n\n        @Override\n        public Object invoke(Object proxy, Method method, Object[] args) {\n            if (method.getDeclaringClass().equals(Object.class)) {\n                return invokeObjectMethod(proxy, method, args);\n            }\n            Object[] copiedArgs = args == null ? new Object[0] : Arrays.copyOf(args, args.length);\n            calls.add(new RecordedCall(method.getName(), copiedArgs));\n            return defaultValue(method.getReturnType());\n        }\n\n        private static Object invokeObjectMethod(Object proxy, Method method, Object[] args) {\n            return switch (method.getName()) {\n                case \"equals\" -> proxy == args[0];\n                case \"hashCode\" -> System.identityHashCode(proxy);\n                case \"toString\" -> \"RecordingOraclePreparedStatement\";\n                default -> throw new UnsupportedOperationException(method.getName());\n            };\n        }\n\n        private static Object defaultValue(Class<?> type) {\n            if (!type.isPrimitive() || type.equals(Void.TYPE)) {\n                return null;\n            }\n            if (type.equals(Boolean.TYPE)) {\n                return false;\n            }\n            if (type.equals(Character.TYPE)) {\n                return '\\0';\n            }\n            if (type.equals(Byte.TYPE)) {\n                return (byte) 0;\n            }\n            if (type.equals(Short.TYPE)) {\n                return (short) 0;\n            }\n            if (type.equals(Integer.TYPE)) {\n                return 0;\n            }\n            if (type.equals(Long.TYPE)) {\n                return 0L;\n            }\n            if (type.equals(Float.TYPE)) {\n                return 0F;\n            }\n            if (type.equals(Double.TYPE)) {\n                return 0D;\n            }\n            throw new IllegalArgumentException(\"Unsupported primitive type: \" + type);\n        }\n    }\n\n    private record RecordedCall(String methodName, Object... arguments) {\n    }\n}\n"}
