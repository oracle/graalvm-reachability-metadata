[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/OracleTypeUPTTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.oracore.OracleType;\nimport oracle.jdbc.oracore.OracleTypeUPT;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class OracleTypeUPTTest {\n\n    @Test\n    void serializesAndDeserializesUserDefinedPolymorphicTypeMetadata() throws Exception {\n        OracleTypeUPT original = new OracleTypeUPT(\"APP.POLYMORPHIC_TYPE\", null);\n\n        byte[] serialized = serialize(original);\n        OracleTypeUPT restored = deserializeOracleTypeUPT(serialized);\n\n        OracleType realType = restored.getRealType();\n        assertThat(restored.getFullName()).isEqualTo(\"APP.POLYMORPHIC_TYPE\");\n        assertThat(realType).isNull();\n    }\n\n    private static byte[] serialize(OracleTypeUPT oracleTypeUPT) throws IOException {\n        ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n        try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {\n            objectOutputStream.writeObject(oracleTypeUPT);\n        }\n        return outputStream.toByteArray();\n    }\n\n    private static OracleTypeUPT deserializeOracleTypeUPT(byte[] serialized)\n            throws IOException, ClassNotFoundException {\n        try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {\n            Object restored = objectInputStream.readObject();\n            assertThat(restored).isInstanceOf(OracleTypeUPT.class);\n            return (OracleTypeUPT) restored;\n        }\n    }\n}\n"}
