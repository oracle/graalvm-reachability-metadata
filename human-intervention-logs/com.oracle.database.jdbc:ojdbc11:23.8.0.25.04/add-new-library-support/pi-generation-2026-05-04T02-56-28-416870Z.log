CACHED_BUFFER_SIZE = 4096;\n\n    @Test\n    void allocatesBucketSizedCharBufferOnCacheMiss() throws Exception {\n        TestPhysicalConnection connection = new TestPhysicalConnection();\n\n        char[] buffer = connection.getCharBufferSync(1);\n\n        assertThat(buffer).hasSize(MAX_CACHED_BUFFER_SIZE);\n        BufferCacheStatistics statistics = connection.getCharBufferCacheStatistics();\n        assertThat(statistics.getBufferSizes()).containsExactly(MAX_CACHED_BUFFER_SIZE);\n        assertThat(statistics.getCacheMisses(0)).isEqualTo(1);\n        assertThat(statistics.getCacheHits(0)).isZero();\n    }\n\n    @Test\n    void allocatesExactSizedCharBufferWhenRequestExceedsLargestBucket() throws Exception {\n        TestPhysicalConnection connection = new TestPhysicalConnection();\n        int uncachedLength = MAX_CACHED_BUFFER_SIZE + 1;\n\n        char[] buffer = connection.getCharBufferSync(uncachedLength);\n\n        assertThat(buffer).hasSize(uncachedLength);\n        BufferCacheStatistics statistics = connection.getCharBufferCacheStatistics();\n        assertThat(statistics.getBufferSizes()).containsExactly(MAX_CACHED_BUFFER_SIZE);\n        assertThat(statistics.getCacheMisses(0)).isZero();\n        assertThat(statistics.getCacheHits(0)).isZero();\n    }\n\n    private static final class TestPhysicalConnection extends OracleOCIConnection {\n        private TestPhysicalConnection() throws SQLException {\n            super(\"jdbc:oracle:oci:@\", connectionProperties(), null);\n        }\n\n        @Override\n        protected void readConnectionProperties(String url, Properties properties) throws SQLException {\n            super.readConnectionProperties(url, properties);\n        }\n\n        private static Properties connectionProperties() {\n            Properties properties = new Properties();\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_test_user\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, \"metadata_test_password\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_MAX_CACHED_BUFFER_SIZE,\n                    Integer.toString(MAX_CACHED_BUFFER_SIZE));\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USE_THREADLOCAL_BUFFER_CACHE, \"false\");\n            return properties;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777863381818}]}
