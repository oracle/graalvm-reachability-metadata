MethodHandles;\nimport java.lang.invoke.MethodType;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class RedirectorTest {\n    private static final MethodHandle GET_REDIRECTOR = getRedirectorHandle();\n\n    @Test\n    void createsRedirectorForPublicValueOfTarget() throws Throwable {\n        Object redirector = GET_REDIRECTOR.invoke(Representation.CHAR, ValueOfTarget.class);\n\n        assertThat(redirector).hasToStringContaining(ValueOfTarget.class.getName());\n    }\n\n    private static MethodHandle getRedirectorHandle() {\n        try {\n            MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(Representation.class, MethodHandles.lookup());\n            return lookup.findVirtual(Representation.class, \"getRedirector\",\n                    MethodType.methodType(redirectorClass(), Class.class));\n        } catch (NoSuchMethodException | IllegalAccessException exception) {\n            throw new ExceptionInInitializerError(exception);\n        }\n    }\n\n    private static Class<?> redirectorClass() {\n        try {\n            return Class.forName(\"oracle.jdbc.driver.Redirector\");\n        } catch (ClassNotFoundException exception) {\n            throw new ExceptionInInitializerError(exception);\n        }\n    }\n\n    public static final class ValueOfTarget {\n        private final String value;\n\n        private ValueOfTarget(String value) {\n            this.value = value;\n        }\n\n        public static ValueOfTarget valueOf(String value) {\n            return new ValueOfTarget(value);\n        }\n\n        String value() {\n            return value;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 4365, "output": 1652, "cacheRead": 48640, "cacheWrite": 0, "totalTokens": 54657, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777882422797, "responseId": "resp_04aa0d3a04dec988016