  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleConnectionWrapper;
  import oracle.jdbc.dcn.DatabaseChangeRegistration;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class OracleConnectionWrapperTest {
  
      @Test
      void createsInterfaceProxyForUnwrappedConnectionObject() throws Exception {
          TestOracleConnectionWrapper wrapper = new TestOracleConnectionWrapper();
  
          DatabaseChangeRegistration proxy = wrapper.proxyForDatabaseChangeRegistration(new Object());
  
          assertThat(proxy).isInstanceOf(DatabaseChangeRegistration.class);
      }
  
      private static final class TestOracleConnectionWrapper extends OracleConnectionWrapper {
          private DatabaseChangeRegistration proxyForDatabaseChangeRegistration(Object unwrapped) throws Exception {
              return proxyFor(unwrapped, DatabaseChangeRegistration.class);
          }
      }
  }
