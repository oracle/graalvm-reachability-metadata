  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.OracleConnection;
  import oracle.jdbc.driver.OracleOCIConnection;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.sql.SQLException;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class PhysicalConnectionTest {
  
      @Test
      void exposesConnectionPropertiesWithoutOpeningDatabaseSession() throws Exception {
          TestPhysicalConnection connection = new TestPhysicalConnection();
  
          Properties properties = connection.getProperties();
  
          assertThat(properties).isNotEmpty();
          assertThat(properties).containsKey(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH);
          assertThat(properties).containsKey(OracleConnection.CONNECTION_PROPERTY_REPORT_REMARKS);
          assertThat(properties).containsKey(OracleConnection.CONNECTION_PROPERTY_IMPLICIT_STATEMENT_CACHE_SIZE);
      }
  
      @Test
      void registersSqlTypesByClassNameAndCreatesMappedJavaObjects() throws Exception {
          TestPhysicalConnection connection = new TestPhysicalConnection();
          String sqlTypeName = "APP.SAMPLE_SQL_OBJECT";
  
