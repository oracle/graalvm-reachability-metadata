  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.replay.driver.TxnReplayableResultSet;
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.sql.Array;
  import java.sql.Clob;
  import java.sql.ResultSet;
  import java.sql.SQLException;
  import java.util.Arrays;
  import java.util.Map;
  
  import javax.sql.rowset.serial.SerialClob;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TxnReplayableResultSetTest {
  
      @Test
      void delegatesLobAndArrayAccessorsThroughCachedOracleResultSetMethods() throws Exception {
          Clob clob = new SerialClob("oracle-result-set-clob".toCharArray());
          Array array = new StubArray("VARCHAR", new Object[] {"oracle-result-set-array"});
          ExposedTxnReplayableResultSet resultSet = new ExposedTxnReplayableResultSet(resultSetProxy(clob, array));
  
          Clob actualClob = resultSet.getClob(1);
          Array actualArray = resultSet.getArray("DATA");
  
          assertThat(actualClob).isSameAs(clob);
          assertThat(actualArray).isSameAs(array);
      }
  
      private static ResultSet resultSetProxy(Clob clob, Array array) {
          return (ResultSet) Proxy.newProxyInstance(
                  TxnReplayableResultSetTest.class.getClassLoader(),
                  new Class<?>[] {ResultSet.class},
                  (proxy, method, args) -> invokeResultSetProxy(method, clob, array));
      }
  
      private static Object invokeResultSetProxy(Method method, Clob clob, Array array) {
          if (method.getName().equals("getClob")) {
              return clob;
          }
          if (method.getName().equals("getArray")) {
              return array;
          }
          if (method.getName().equals("toString") && method.getParameterCount() == 0) {
              return "txn replay result set delegate";
          }
          return defaultValue(method.getReturnType());
      }
  
      private static Object defaultValue(Class<?> returnType) {
          if (!returnType.isPrimitive() || returnType == void.class) {
              return null;
          }
          if (returnType == boolean.class) {
              return false;
          }
          if (returnType == char.class) {
              return '\0';
          }
          if (returnType == byte.class) {
              return (byte) 0;
          }
          if (returnType == short.class) {
              return (short) 0;
          }
          if (returnType == int.class) {
              return 0;
          }
          if (returnType == long.class) {
              return 0L;
          }
          if (returnType == float.class) {
              return 0.0F;
