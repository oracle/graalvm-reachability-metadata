  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.oracore.Util;
  import org.junit.jupiter.api.Test;
  
  import java.io.Serializable;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class UtilTest {
  
      @Test
      void serializesAndDeserializesObjects() throws Exception {
          SerializableValue value = new SerializableValue("oracle-jdbc-serialization-value", 23);
  
          byte[] serializedValue = Util.serializeObject(value);
          Object deserializedValue = Util.deserializeObject(serializedValue);
  
          assertThat(serializedValue).isNotEmpty();
          assertThat(deserializedValue).isEqualTo(value);
      }
  
      private static final class SerializableValue implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private final String name;
          private final int code;
  
          private SerializableValue(String name, int code) {
              this.name = name;
              this.code = code;
          }
  
          @Override
          public boolean equals(Object other) {
              if (this == other) {
                  return true;
              }
              if (!(other instanceof SerializableValue otherValue)) {
                  return false;
              }
              return code == otherValue.code && name.equals(otherValue.name);
          }
  
          @Override
          public int hashCode() {
              return 31 * name.hashCode() + code;
          }
      }
  }
