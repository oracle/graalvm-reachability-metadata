  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.internal.OracleConnection;
  import oracle.sql.SQLName;
  import oracle.sql.TypeDescriptor;
  import org.junit.jupiter.api.Test;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.IOException;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.io.Serializable;
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Proxy;
  import java.sql.Connection;
  import java.sql.SQLException;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypeDescriptorTest {
  
      @Test
      void mapsTypeCodeConstantsToTheirPublicNames() throws Exception {
          TypeDescriptor descriptor = new SerializableTypeDescriptor(sqlName(), connectionProxy());
  
          assertThat(descriptor.getTypeCode()).isEqualTo(TypeDescriptor.TYPECODE_OBJECT);
          assertThat(descriptor.getTypeCodeName()).isEqualTo("TYPECODE_OBJECT");
      }
  
      @Test
      void serializesAndDeserializesTypeDescriptorName() throws Exception {
          SerializableTypeDescriptor descriptor = new SerializableTypeDescriptor(sqlName(), connectionProxy());
  
          byte[] serialized = serialize(descriptor);
          TypeDescriptor restored = deserializeTypeDescriptor(serialized);
  
          assertThat(restored).isInstanceOf(SerializableTypeDescriptor.class);
          assertThat(restored.getName()).isEqualTo("APP.CUSTOMER_TYPE");
          assertThat(restored.getPickler()).isNull();
      }
  
      private static SQLName sqlName() throws SQLException {
          return new SQLName("APP", "CUSTOMER_TYPE", null);
      }
  
      private static Connection connectionProxy() {
          Object[] proxyReference = new Object[1];
          InvocationHandler handler = (proxy, method, arguments) -> {
              String methodName = method.getName();
              if ("physicalConnectionWithin".equals(methodName)) {
                  return proxyReference[0];
              }
              if ("toString".equals(methodName)) {
                  return "TypeDescriptorTest connection proxy";
              }
              if ("hashCode".equals(methodName)) {
                  return System.identityHashCode(proxy);
              }
              if ("equals".equals(methodName)) {
                  return proxy == arguments[0];
              }
              throw new UnsupportedOperationException(method.toString());
          };
          proxyReference[0] = Proxy.newProxyInstance(
                  TypeDescriptorTest.class.getClassLoader(),
                  new Class<?>[] {OracleConnection.class},
                  handler);
          return (Connection) proxyReference[0];
      }
  
      private static byte[] serialize(TypeDescriptor descriptor) throws IOException {
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
          try (ObjectOutputStream objectOutputStream = new ObjectOutputStream(outputStream)) {
              objectOutputStream.writeObject(descriptor);
          }
          return outputStream.toByteArray();
      }
  
      private static TypeDescriptor deserializeTypeDescriptor(byte[] serialized)
              throws IOException, ClassNotFoundException {
          try (ObjectInputStream objectInputStream = new ObjectInputStream(new ByteArrayInputStream(serialized))) {
              Object restored = objectInputStream.readObject();
              assertThat(restored).isInstanceOf(TypeDescriptor.class);
              return (TypeDescriptor) restored;
          }
      }
  
      private static final class SerializableTypeDescriptor extends TypeDescriptor implements Serializable {
          private static final long serialVersionUID = 1L;
  
          private SerializableTypeDescriptor(SQLName sqlName, Connection connection) throws SQLException {
              super(TypeDescriptor.TYPECODE_OBJECT, sqlName, connection);
          }
      }
  }
