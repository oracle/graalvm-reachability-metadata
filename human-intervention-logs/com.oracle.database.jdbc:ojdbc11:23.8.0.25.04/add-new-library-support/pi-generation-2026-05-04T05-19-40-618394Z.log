      void proxyForCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {
          ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                  ProxyFactoryTest.class.getPackageName(), CachingProxy.class);
          SampleDelegate delegate = new SampleDelegate();
  
          Object proxy = proxyFactory.<Object>proxyFor(delegate);
  
          assertThat(proxy).isInstanceOf(SampleService.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(delegate.getProxyMarker()).isSameAs(proxy);
          assertThat(extractDelegate(proxy)).isSameAs(delegate);
      }
  
