  package com_oracle_database_jdbc.ojdbc11;
  
  import org.junit.jupiter.api.Test;
  
  import java.lang.reflect.Constructor;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class GeneratedProxiesRegistryInnerKeyTest {
  
      @Test
      void parsesSuperclassAndInterfaceFromGeneratedProxyName() throws Exception {
          String proxyPackage = GeneratedProxiesRegistryInnerKeyTest.class.getPackageName() + ".";
          String generatedProxyName = generatedProxyName(proxyPackage, SampleSuperclass.class, SampleInterface.class);
          Class<?> keyClass = Class.forName("oracle.jdbc.proxy.GeneratedProxiesRegistry$Key");
          Constructor<?> constructor = keyClass.getDeclaredConstructor(String.class, String.class);
          constructor.setAccessible(true);
  
          Object key = constructor.newInstance(proxyPackage, generatedProxyName);
  
          assertThat(key).hasToString(generatedProxyName);
      }
  
      private static String generatedProxyName(String proxyPackage, Class<?> superclass, Class<?> proxyInterface) {
          return proxyPackage
                  + superclass.getName().replace(".", "$1")
                  + "$2"
                  + proxyInterface.getName().replace(".", "$1")
                  + "$$$Proxy";
      }
  
      public interface SampleInterface {
      }
  
      public static class SampleSuperclass {
      }
  }
