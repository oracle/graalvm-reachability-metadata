  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.proxy.ProxyFactory;
  import oracle.jdbc.proxy._Proxy_;
  import oracle.jdbc.proxy.annotation.GetCreator;
  import oracle.jdbc.proxy.annotation.GetDelegate;
  import oracle.jdbc.proxy.annotation.ProxyAccess;
  import oracle.jdbc.proxy.annotation.ProxyFor;
  import oracle.jdbc.proxy.annotation.SetDelegate;
  import org.junit.jupiter.api.Test;
  
  import java.lang.ref.WeakReference;
  import java.util.IdentityHashMap;
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ProxyFactoryTest {
  
      @Test
      void proxyForTypeInstantiatesProxyForRegisteredDelegateType() {
          ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                  ProxyFactoryTest.class.getPackageName(), ManualProxy.class);
  
          Object proxy = proxyFactory.proxyForType(SampleDelegate.class);
  
          assertThat(proxy).isInstanceOf(SampleService.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(extractDelegate(proxy)).isNull();
      }
  
      @Test
      void proxyForCreateInstantiatesProxyWithoutUsingCache() {
          ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                  ProxyFactoryTest.class.getPackageName(), ManualProxy.class);
          SampleDelegate delegate = new SampleDelegate();
  
          Object proxy = proxyFactory.<Object>proxyForCreate(delegate);
  
          assertThat(proxy).isInstanceOf(SampleService.class);
          assertThat(proxy).isInstanceOf(_Proxy_.class);
          assertThat(extractDelegate(proxy)).isSameAs(delegate);
      }
  
      @Test
      void proxyForCacheReturnsProxyAlreadyStoredOnProxyAccessDelegate() {
          ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                  ProxyFactoryTest.class.getPackageName(), CachingProxy.class);
          SampleDelegate delegate = new SampleDelegate();
          Object cachedProxy = new Object();
          delegate.setProxyMarker(cachedProxy);
  
          Object proxy = proxyFactory.<Object>proxyFor(delegate);
  
          assertThat(proxy).isSameAs(cachedProxy);
      }
  
      @Test
      void proxyForCacheInstantiatesProxyAndStoresItOnProxyAccessDelegate() {
          ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                  ProxyFactoryTest.class.getPackageName(), CachingProxy.class);
          SampleDelegate delegate = new SampleDelegate();
  
