rk. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.proxy.ProxyExport;\nimport oracle.jdbc.proxy.annotation.GetDelegate;\nimport oracle.jdbc.proxy.annotation.ProxyFor;\nimport oracle.jdbc.proxy.annotation.ProxyResult;\nimport oracle.jdbc.proxy.annotation.ProxyResultPolicy;\nimport oracle.jdbc.proxy.annotation.SetDelegate;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.List;\nimport java.util.stream.Stream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationsRegistryInnerValueTest {\n\n    @Test\n    void proxyExportGeneratesBytecodeForMethodSpecificResultPolicy(@TempDir Path tempDir) throws Exception {\n        ProxyExport.main(new String[] {\n                \"-p\",\n                AnnotationsRegistryInnerValueTest.class.getPackageName(),\n                \"-d\",\n                tempDir.toString(),\n                DynamicServiceProxy.class.getName(),\n                DynamicResultProxy.class.getName()\n        });\n\n        try (Stream<Path> paths = Files.walk(tempDir)) {\n            List<Path> generatedClasses = paths\n                    .filter(path -> path.getFileName().toString().endsWith(\".class\"))\n                    .toList();\n\n            assertThat(generatedClasses).hasSize(2);\n            assertThat(generatedClasses).allSatisfy(path -> assertThat(Files.size(path)).isPositive());\n        }\n    }\n\n    public interface PrimaryService {\n        ResultService child();\n    }\n\n    public interface ResultService {\n        String value();\n    }\n\n    @ProxyFor(PrimaryService.class)\n    public abstract static class DynamicServiceProxy {\n        @GetDelegate\n        protected abstract PrimaryService getDelegate();\n\n        @SetDelegate\n        protected abstract void setDelegate(PrimaryService delegate);\n\n        @ProxyResult(ProxyResultPolicy.CREATE)\n        public abstract ResultService child();\n    }\n\n    @ProxyFor(ResultService.class)\n    public abstract static class DynamicResultProxy {\n        @GetDelegate\n        protected abstract ResultService getDelegate();\n\n        @SetDelegate\n        protected abstract void setDelegate(ResultService delegate);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 3433, "output": 1312, "cacheRead": 64512, "cacheWrite": 0, "totalTokens": 69257, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777870970896, "responseId": "resp_049e163683d799200169f8287b7a5c819187e7e5661987c419"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_y5V0G8nFW1ImcSlzLVSVpdSB|fc_049e163683d799200169f828883df08191a1011554c86b91f4", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2428 bytes to tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/AnnotationsRegistryInnerValueTest.java"}], "isError": false, "timestamp": 1777870986090}]}
