  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.proxy.ProxyFactory;
  import oracle.jdbc.proxy._Proxy_;
  import oracle.jdbc.proxy.annotation.GetDelegate;
  import oracle.jdbc.proxy.annotation.ProxyFor;
  import oracle.jdbc.proxy.annotation.ProxyResult;
  import oracle.jdbc.proxy.annotation.ProxyResultPolicy;
  import oracle.jdbc.proxy.annotation.SetDelegate;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnnotationsRegistryInnerValueTest {
  
      @Test
      void generatedProxyUsesMethodSpecificResultPolicyForProxyableReturnValue() {
          try {
              ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                      AnnotationsRegistryInnerValueTest.class.getPackageName(),
                      DynamicServiceProxy.class,
                      DynamicResultProxy.class);
              ResultDelegate resultDelegate = new ResultDelegate("generated");
              ServiceDelegate serviceDelegate = new ServiceDelegate(resultDelegate);
              PrimaryService proxy = proxyFactory.proxyForCreate(serviceDelegate);
              ResultService result = proxy.child();
  
              assertThat(result.value()).isEqualTo("generated");
              assertThat(result).isInstanceOf(_Proxy_.class);
              assertThat(extractDelegate(result)).isSameAs(resultDelegate);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @SuppressWarnings("unchecked")
      private static ResultService extractDelegate(ResultService proxy) {
          return ProxyFactory.extractDelegate((_Proxy_<ResultService>) proxy);
      }
  
      public interface PrimaryService {
          ResultService child();
      }
  
      public interface ResultService {
          String value();
      }
  
      public static final class ServiceDelegate implements PrimaryService {
          private final ResultService child;
  
          ServiceDelegate(ResultService child) {
              this.child = child;
          }
  
          @Override
          public ResultService child() {
              return child;
          }
      }
  
      public static final class ResultDelegate implements ResultService {
          private final String value;
  
          ResultDelegate(String value) {
              this.value = value;
          }
  
          @Override
          public String value() {
              return value;
          }
      }
  
      @ProxyFor(PrimaryService.class)
      public abstract static class DynamicServiceProxy {
          @GetDelegate
          protected abstract PrimaryService getDelegate();
  
          @SetDelegate
          protected abstract void setDelegate(PrimaryService delegate);
  
          @ProxyResult(ProxyResultPolicy.CREATE)
          public abstract ResultService child();
      }
  
      @ProxyFor(ResultService.class)
      public abstract static class DynamicResultProxy {
          @GetDelegate
          protected abstract ResultService getDelegate();
  
          @SetDelegate
          protected abstract void setDelegate(ResultService delegate);
      }
  }
