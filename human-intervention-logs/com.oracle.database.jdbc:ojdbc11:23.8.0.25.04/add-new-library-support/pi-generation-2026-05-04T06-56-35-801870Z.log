TcpFastOpenNativeLibraryFromDriverResource(@TempDir Path tempDir) throws Exception {\n        ByteArrayOutputStream outputBytes = new ByteArrayOutputStream();\n        PrintStream originalOut = System.out;\n\n        try (PrintStream capturedOut = new PrintStream(outputBytes, true, StandardCharsets.UTF_8)) {\n            System.setOut(capturedOut);\n            OracleDriver.main(new String[] {\"installTFOLib\", tempDir.toString()});\n        } finally {\n            System.setOut(originalOut);\n        }\n\n        String output = outputBytes.toString(StandardCharsets.UTF_8);\n        Path installedLibrary = tempDir.resolve(TCP_FAST_OPEN_LIBRARY_NAME);\n        if (output.contains(\"Unsupported platform\")) {\n            assertThat(Files.exists(installedLibrary)).isFalse();\n        } else {\n            assertThat(output).contains(\"Installed\", TCP_FAST_OPEN_LIBRARY_NAME);\n            assertThat(installedLibrary).isRegularFile();\n            assertThat(Files.size(installedLibrary)).isPositive();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1223, "output": 1154, "cacheRead": 53248, "cacheWrite": 0, "totalTokens": 55625, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1777877749407, "responseId": "resp_0d4a3f9f1f27e5230169f842f633e881a2b3dd073ec8ddfdb8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_DuzfnGBYqgY9rMFQBxzGXr1G|fc_0d4a3f9f1f27e5230169f843024adc81a281a3565594bd8e3e", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1798 bytes to tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/TcpFastOpenLibraryInstallerTest.java"}], "isError": false, "timestamp": 1777877763805}]}
