 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"com.oracle.database.jdbc:ojdbc11:$libraryVersion\"\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n    testImplementation 'org.ow2.asm:asm:9.7.1'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1777877713736}, {"role": "toolResult", "toolCallId": "call_ziXtQEGJ7aHW3xhWa617oafb|fc_0d4a3f9f1f27e5230169f842d1825481a29108d54bbeffaff0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.OracleConnection;\nimport oracle.jdbc.driver.OracleDriver;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.Timeout;\n\nimport java.sql.DriverPropertyInfo;\nimport java.sql.SQLException;\nimport java.util.Arrays;\nimport java.util.Map;\nimport java.util.Properties;\nimport java.util.function.Function;\n\nimport static java.util.stream.Collectors.toMap;\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\npublic class OracleDriverTest {\n    private static final String UNREACHABLE_THIN_URL = \"jdbc:oracle:thin:@127.0.0.1:1/FREEPDB1\";\n\n    @Test\n    void createsPropertyInfoFromOracleConnectionConstants() throws SQLException {\n        OracleDriver driver = new OracleDriver();\n\n        DriverPropertyInfo[] propertyInfos = driver.getPropertyInfo(UNREACHABLE_THIN_URL, new Properties());\n\n        Map<String, DriverPropertyInfo> propertyInfoByName = Arrays.stream(propertyInfos)\n                .collect(toMap(propertyInfo -> propertyInfo.name, Function.identity(), (first, second) -> first));\n        assertThat(propertyInfoByName).containsKeys(\n                OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH,\n                OracleConnection.CONNECTION_PROPERTY_THIN_NET_CONNECT_TIMEOUT);\n        assertThat(propertyInfoByName.get(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH).value)\n                .isEqualTo(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH_DEFAULT);\n    }\n\n    @Test\n    @Timeout(10)\n    void loadsThinDriverExtensionBeforeOpeningNetworkConnection() {\n        OracleDriver driver = new OracleDriver();\n        Properties properties = new Properties();\n        properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_test_user\");\n        properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, \"metadata_test_password\");\n        properties.setProperty(OracleConnection.CONNECTION_PROPERTY_THIN_NET_CONNECT_TIMEOUT, \"1000\");\n\n        assertThrows(SQLException.class, () -> driver.connect(UNREACHABLE_THIN_URL, properties));\n    }\n}\n"}], "isError": false, "timestamp": 1777877713736}, {"role": "toolResult", "toolCallId": "call_LGqDiptQm6vpRArHtDE55Jl9|fc_0d4a3f9f1f27e5230169f842d1825c81a29527411c1cfa6081", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.net.nt.ConnOption;\nimport oracle.net.nt.SdpNTAdapter;\nimport org.junit.jupiter.api.Test;\n\nimport java.net.InetAddress;\nimport java.net.InetSocketAddress;\nimport java.net.ServerSocket;\nimport java.util.Properties;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class SdpNTAdapterTest {\n    private static final int CONNECT_TIMEOUT_PROPERTY = 2;\n    private static final int TCP_NIO_PROPERTY = 20;\n\n    @Test\n    void connectUsesReflectivelyOpenedSdpSocket() throws Exception {\n        try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\n            SdpNTAdapter adapter = new SdpNTAdapter(\n                    \"sdp\",\n                    createConnectionOption(serverSocket),\n                    createSocketOptions(false));\n\n            adapter.connect(null);\n            try {\n                assertThat(adapter.getInetAddress()).isEqualTo(InetAddress.getLoopbackAddress());\n                assertThat(adapter.getSocketChannel()).isNull();\n            } finally {\n                adapter.disconnect();\n            }\n        }\n    }\n\n    @Test\n    void connectUsesReflectivelyOpenedSdpSocketChannelWhenNioIsEnabled() throws Exception {\n        try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {\n            SdpNTAdapter adapter = new SdpNTAdapter(\n                    \"sdp\",\n                    createConnectionOption(serverSocket),\n                    createSocketOptions(true));\n\n            adapter.connect(null);\n            try {\n                assertThat(adapter.getInetAddress()).isEqualTo(InetAddress.getLoopbackAddress());\n                assertThat(adapter.getSocketChannel()).isNotNull();\n            } finally {\n                adapter.disconnect();\n            }\n        }\n    }\n\n    private static ConnOption createConnectionOption(ServerSocket serverSocket) {\n        ConnOption connectionOption = new ConnOption();\n        connectionOption.host = InetAddress.getLoopbackAddress().getHostAddress();\n        connectionOption.port = serverSocket.getLocalPort();\n        connectionOption.inetSocketAddress = new InetSocketAddress(\n                InetAddress.getLoopbackAddress(),\n                serverSocket.getLocalPort());\n        return connectionOption;\n    }\n\n    private static Properties createSocketOptions(boolean nioEnabled) {\n        Properties socketOptions = new Properties();\n        socketOptions.put(CONNECT_TIMEOUT_PROPERTY, \"2000\");\n        socketOptions.put(TCP_NIO_PROPERTY, Boolean.toString(nioEnabled));\n        return socketOptions;\n    }\n}\n"}], "isError": false, "timestamp": 1777877713736}, {"role": "toolResult", "toolCallId": "call_XTqWZV75Ux5bCARwb25WVXBh|fc_0d4a3f9f1f27e5230169f842d1826481a28701534e70d1b922", "toolName": "read", "content": [{"type": "text", "text": "{\n  \"classes\" : [ {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"oracle.jdbc.nativeimage.Target_oracle_jdbc_proxy_ProxyFactory.prepareProxy(SubstitutedMethods.java:85)\",\n      \"line\" : 85,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#forName(java.lang.String, boolean, java.lang.ClassLoader)\"\n    }, {\n      \"covered\" : false,\n      \"frame\" : \"oracle.jdbc.nativeimage.Target_oracle_jdbc_proxy_ProxyFactory.prepareProxy(SubstitutedMethods.java:98)\",\n      \"line\" : 98,\n      \"metadataType\" : \"reflection\",\n      \"trackedApi\" : \"java.lang.Class#getConstructor(java.lang.Class[])\"\n    } ],\n    \"className\" : \"oracle.jdbc.nativeimage.Target_oracle_jdbc_proxy_ProxyFactory\",\n    \"coveredCalls\" : 0,\n    \"sourceFile\" : \"SubstitutedMethods.java\",\n    \"totalCalls\" : 2\n  }, {\n    \"callSites\" : [ {\n      \"covered\" : false,\n      \"frame\" : \"oracle.jdbc.TcpFastOpenLibraryInstaller.installInternal(TcpFastOpenLibraryInstaller.java:59)\",\n      \"line\" : 59,\n      \"metadataType\" : \"resources\",\n      \"trackedApi\" : \"java.lang.Class#getResourceAsStream(java.lang.String)\"\n    } ],\n    \"className\" : \"oracle.jdbc.TcpFastOpenLibraryInstaller\",\n    \"coveredCalls\" : 0,\n    \"sourc