[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/TcpFastOpenLibraryInstallerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.OracleDriver;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.Timeout;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport java.io.ByteArrayOutputStream;\nimport java.io.PrintStream;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TcpFastOpenLibraryInstallerTest {\n    private static final String TCP_FAST_OPEN_LIBRARY_NAME = \"libtfojdbc1.so\";\n\n    @Test\n    @Timeout(10)\n    void installsTcpFastOpenNativeLibraryFromDriverResource(@TempDir Path tempDir) throws Exception {\n        ByteArrayOutputStream outputBytes = new ByteArrayOutputStream();\n        PrintStream originalOut = System.out;\n\n        try (PrintStream capturedOut = new PrintStream(outputBytes, true, StandardCharsets.UTF_8)) {\n            System.setOut(capturedOut);\n            OracleDriver.main(new String[] {\"installTFOLib\", tempDir.toString()});\n        } finally {\n            System.setOut(originalOut);\n        }\n\n        String output = outputBytes.toString(StandardCharsets.UTF_8);\n        Path installedLibrary = tempDir.resolve(TCP_FAST_OPEN_LIBRARY_NAME);\n        if (output.contains(\"Unsupported platform\")) {\n            assertThat(Files.exists(installedLibrary)).isFalse();\n        } else {\n            assertThat(output).contains(\"Installed\", TCP_FAST_OPEN_LIBRARY_NAME);\n            assertThat(installedLibrary).isRegularFile();\n            assertThat(Files.size(installedLibrary)).isPositive();\n        }\n    }\n}\n"}
