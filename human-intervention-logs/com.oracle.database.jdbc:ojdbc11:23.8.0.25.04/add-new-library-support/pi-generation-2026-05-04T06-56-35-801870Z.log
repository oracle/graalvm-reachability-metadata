  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.net.nt.ConnOption;
  import oracle.net.nt.SdpNTAdapter;
  import org.junit.jupiter.api.Test;
  
  import java.net.InetAddress;
  import java.net.InetSocketAddress;
  import java.net.ServerSocket;
  import java.util.Properties;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class SdpNTAdapterTest {
      private static final int CONNECT_TIMEOUT_PROPERTY = 2;
      private static final int TCP_NIO_PROPERTY = 20;
  
      @Test
      void connectUsesReflectivelyOpenedSdpSocket() throws Exception {
          try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {
              SdpNTAdapter adapter = new SdpNTAdapter(
                      "sdp",
                      createConnectionOption(serverSocket),
                      createSocketOptions(false));
  
              adapter.connect(null);
              try {
                  assertThat(adapter.getInetAddress()).isEqualTo(InetAddress.getLoopbackAddress());
                  assertThat(adapter.getSocketChannel()).isNull();
              } finally {
                  adapter.disconnect();
              }
          }
      }
  
      @Test
      void connectUsesReflectivelyOpenedSdpSocketChannelWhenNioIsEnabled() throws Exception {
          try (ServerSocket serverSocket = new ServerSocket(0, 1, InetAddress.getLoopbackAddress())) {
              SdpNTAdapter adapter = new SdpNTAdapter(
                      "sdp",
                      createConnectionOption(serverSocket),
                      createSocketOptions(true));
  
              adapter.connect(null);
              try {
                  assertThat(adapter.getInetAddress()).isEqualTo(InetAddress.getLoopbackAddress());
                  assertThat(adapter.getSocketChannel()).isNotNull();
              } finally {
                  adapter.disconnect();
              }
          }
      }
  
      private static ConnOption createConnectionOption(ServerSocket serverSocket) {
          ConnOption connectionOption = new ConnOption();
          connectionOption.host = InetAddress.getLoopbackAddress().getHostAddress();
          connectionOption.port = serverSocket.getLocalPort();
          connectionOption.inetSocketAddress = new InetSocketAddress(
                  InetAddress.getLoopbackAddress(),
                  serverSocket.getLocalPort());
          return connectionOption;
      }
  
      private static Properties createSocketOptions(boolean nioEnabled) {
          Properties socketOptions = new Properties();
          socketOptions.put(CONNECT_TIMEOUT_PROPERTY, "2000");
          socketOptions.put(TCP_NIO_PROPERTY, Boolean.toString(nioEnabled));
          return socketOptions;
      }
  }
