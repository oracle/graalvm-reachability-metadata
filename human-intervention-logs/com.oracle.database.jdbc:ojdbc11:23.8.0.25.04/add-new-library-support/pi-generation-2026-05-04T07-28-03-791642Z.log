[tool-call] delta {"path":"tests/src/com.oracle.database.jdbc/ojdbc11/23.8.0.25.04/src/test/java/com_oracle_database_jdbc/ojdbc11/DirectPathBufferMarshalerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_oracle_database_jdbc.ojdbc11;\n\nimport oracle.jdbc.OracleConnection;\nimport oracle.jdbc.driver.OracleOCIConnection;\nimport org.junit.jupiter.api.Test;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.reflect.Array;\nimport java.sql.SQLException;\nimport java.util.Properties;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class DirectPathBufferMarshalerTest {\n    private static final int DIRECT_PATH_PIECE_PAYLOAD_SIZE = 65_513;\n\n    @Test\n    void preparesPlanForStreamBindSplitAcrossMorePiecesThanRows() throws Throwable {\n        TestPhysicalConnection connection = new TestPhysicalConnection();\n        byte[] streamBytes = new byte[(DIRECT_PATH_PIECE_PAYLOAD_SIZE * 2) + 16];\n        InputStream[][] bindStreams = { { new ByteArrayInputStream(streamBytes) } };\n        DirectPathBufferMarshalerHandles handles = DirectPathBufferMarshalerHandles.create(connection);\n\n        Object planner = handles.createBufferPlanner.invoke(\n                1,\n                1,\n                null,\n                new long[0],\n                new int[0],\n                bindStreams,\n                handles.emptyAccessorArray(),\n                connection);\n        int plannedBytes = (int) handles.preparePlan.invoke(planner);\n\n        assertThat(plannedBytes).isGreaterThan(streamBytes.length);\n        assertThat((boolean) handles.isComplete.invoke(planner)).isTrue();\n    }\n\n    private record DirectPathBufferMarshalerHandles(\n            MethodHandle createBufferPlanner,\n            MethodHandle preparePlan,\n            MethodHandle isComplete,\n            Class<?> accessorClass) {\n\n        private static DirectPathBufferMarshalerHandles create(TestPhysicalConnection connection)\n                throws ClassNotFoundException, NoSuchMethodException, IllegalAccessException {\n            Class<?> marshalerClass = Class.forName(\"oracle.jdbc.driver.DirectPathBufferMarshaler\");\n            Class<?> bufferPlannerClass = Class.forName(\"oracle.jdbc.driver.DirectPathBufferMarshaler$BufferPlanner\");\n            Class<?> byteArrayClass = Class.forName(\"oracle.jdbc.driver.ByteArray\");\n            Class<?> accessorClass = Class.forName(\"oracle.jdbc.driver.Accessor\");\n            Class<?> accessorArrayClass = Array.newInstance(accessorClass, 0).getClass();\n            Class<?> physicalConnectionClass = physicalConnectionClass(connection.getClass());\n            MethodHandles.Lookup marshalerLookup = MethodHandles.privateLookupIn(marshalerClass, MethodHandles.lookup());\n            MethodHandles.Lookup plannerLookup = MethodHandles.privateLookupIn(bufferPlannerClass, MethodHandles.lookup());\n            MethodHandle createBufferPlanner = marshalerLookup.findStatic(\n                    marshalerClass,\n                    \"createBufferPlanner\",\n                    MethodType.methodType(\n                            bufferPlannerClass,\n                            int.class,\n                            int.class,\n                            byteArrayClass,\n                            long[].class,\n                            int[].class,\n                            InputStream[][].class,\n                            accessorArrayClass,\n                            physicalConnectionClass));\n            MethodHandle preparePlan = plannerLookup.findVirtual(\n                    bufferPlannerClass, \"preparePlan\", MethodType.methodType(int.class));\n            MethodHandle isComplete = plannerLookup.findVirtual(\n                    bufferPlannerClass, \"isComplete\", MethodType.methodType(boolean.class));\n            return new DirectPathBufferMarshalerHandles(createBufferPlanner, preparePlan, isComplete, accessorClass);\n        }\n\n        private Object emptyAccessorArray() {\n            return Array.newInstance(accessorClass, 0);\n        }\n    }\n\n    private static Class<?> physicalConnectionClass(Class<?> connectionClass) {\n        Class<?> currentClass = connectionClass;\n        while (currentClass != null && !\"oracle.jdbc.driver.PhysicalConnection\".equals(currentClass.getName())) {\n            currentClass = currentClass.getSuperclass();\n        }\n        assertThat(currentClass).isNotNull();\n        return currentClass;\n    }\n\n    private static final class TestPhysicalConnection extends OracleOCIConnection {\n        private TestPhysicalConnection() throws SQLException {\n            super(\"jdbc:oracle:oci:@\", connectionProperties(), null);\n        }\n\n        @Override\n        protected void readConnectionProperties(String url, Properties properties) throws SQLException {\n            super.readConnectionProperties(url, properties);\n        }\n\n        private static Properties connectionProperties() {\n            Properties properties = new Properties();\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \"metadata_test_user\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_PASSWORD, \"metadata_test_password\");\n            properties.setProperty(OracleConnection.CONNECTION_PROPERTY_USE_THREADLOCAL_BUFFER_CACHE, \"false\");\n            return properties;\n        }\n    }\n}\n"}
