  package com_oracle_database_jdbc.ojdbc11;
  
  import oracle.jdbc.driver.AbstractShardingConnection;
  import oracle.jdbc.driver.AbstractShardingPreparedStatement;
  import oracle.jdbc.internal.OracleConnection;
  import oracle.jdbc.internal.OraclePreparedStatement;
  import oracle.jdbc.proxy.ProxyFactory;
  import org.junit.jupiter.api.Test;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.InvocationHandler;
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.util.ArrayList;
  import java.util.Arrays;
  import java.util.List;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AbstractShardingPreparedStatementTest {
      private static final MethodHandle DELEGATES_BIND_BATCH_CALLS = methodHandle(
              "delegatesBindBatchCalls", MethodType.methodType(void.class, OraclePreparedStatement.class));
      private static final MethodHandle DELEGATES_BEFORE_PREPARED_STATEMENT_EXECUTE_CALLS = methodHandle(
              "delegatesBeforePstmtExecuteCalls", MethodType.methodType(void.class, OraclePreparedStatement.class));
  
      @Test
      void replaysDeferredBindAndBeforeExecuteCallsToPreparedStatementDelegate() throws Throwable {
          AbstractShardingPreparedStatement shardingPreparedStatement = newShardingPreparedStatement();
          shardingPreparedStatement.setInt(1, 11);
          shardingPreparedStatement.setString(2, "first");
          shardingPreparedStatement.setString(2, "second");
          shardingPreparedStatement.addBatch();
          shardingPreparedStatement.setCheckBindTypes(true);
          shardingPreparedStatement.clearWarnings();
          RecordingInvocationHandler invocationHandler = new RecordingInvocationHandler();
          OraclePreparedStatement delegate = invocationHandler.createProxy();
  
          DELEGATES_BIND_BATCH_CALLS.invoke(shardingPreparedStatement, delegate);
          DELEGATES_BEFORE_PREPARED_STATEMENT_EXECUTE_CALLS.invoke(shardingPreparedStatement, delegate);
  
          assertThat(invocationHandler.calls())
                  .extracting(RecordedCall::methodName)
                  .contains("setInt", "setString", "addBatch", "setCheckBindTypes");
          assertThat(invocationHandler.calls())
                  .anySatisfy(call -> assertRecordedCall(call, "setInt", 1, 11))
                  .anySatisfy(call -> assertRecordedCall(call, "setString", 2, "first"))
                  .anySatisfy(call -> assertRecordedCall(call, "setString", 2, "second"))
                  .anySatisfy(call -> assertRecordedCall(call, "setCheckBindTypes", true));
      }
  
      private static AbstractShardingPreparedStatement newShardingPreparedStatement() {
          ProxyFactory proxyFactory = ProxyFactory.createProxyFactory(
                  AbstractShardingPreparedStatement.class, AbstractShardingConnection.class);
          Object shardingConnection = proxyFactory.proxyForType(OracleConnection.class);
          Object shardingPreparedStatement = proxyFactory.proxyForType(OraclePreparedStatement.class, shardingConnection);
          return AbstractShardingPreparedStatement.class.cast(shardingPreparedStatement);
      }
  
      private static MethodHandle methodHandle(String name, MethodType methodType) {
          try {
              MethodHandles.Lookup lookup = MethodHandles.privateLookupIn(
                      AbstractShardingPreparedStatement.class, MethodHandles.lookup());
              return lookup.findVirtual(AbstractShardingPreparedStatement.class, name, methodType);
          } catch (NoSuchMethodException | IllegalAccessException exception) {
              throw new ExceptionInInitializerError(exception);
          }
      }
  
      private static void assertRecordedCall(RecordedCall call, String methodName, Object... arguments) {
          assertThat(call.methodName()).isEqualTo(methodName);
          assertThat(call.arguments()).containsExactly(arguments);
      }
  
      private static final class RecordingInvocationHandler implements InvocationHandler {
          private final List<RecordedCall> calls = new ArrayList<>();
  
          OraclePreparedStatement createProxy() {
              ClassLoader classLoader = AbstractShardingPreparedStatementTest.class.getClassLoader();
              Class<?>[] interfaces = { OraclePreparedStatement.class };
              Object proxy = Proxy.newProxyInstance(classLoader, interfaces, this);
              return OraclePreparedStatement.class.cast(proxy);
          }
  
          List<RecordedCall> calls() {
              return calls;
          }
  
          @Override
          public Object invoke(Object proxy, Method method, Object[] args) {
              if (method.getDeclaringClass().equals(Object.class)) {
                  return invokeObjectMethod(proxy, method, args);
              }
              Object[] copiedArgs = args == null ? new Object[0] : Arrays.copyOf(args, args.length);
              calls.add(new RecordedCall(method.getName(), copiedArgs));
