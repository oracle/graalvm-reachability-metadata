ON_PROPERTY_USER_NAME, \\\"metadata_user\\\");\\n        inputProperties.setProperty(OracleConnection.CONNECTION_PROPERTY_AUTOCOMMIT, \\\"false\\\");\\n        inputProperties.setProperty(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \\\"37\\\");\\n        inputProperties.setProperty(OracleConnection.CONNECTION_PROPERTY_OCI_SVC_CTX_HANDLE, \\\"123456789\\\");\\n\\n        OracleConnection connection = new TestOracleOciConnection(inputProperties);\\n\\n        Properties connectionProperties = connection.getProperties();\\n\\n        assertThat(connectionProperties)\\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_USER_NAME, \\\"metadata_user\\\")\\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_AUTOCOMMIT, \\\"false\\\")\\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_DEFAULT_ROW_PREFETCH, \\\"37\\\")\\n                .containsEntry(OracleConnection.CONNECTION_PROPERTY_OCI_SVC_CTX_HANDLE, \\\"123456789\\\");\\n    }\\n\\n    @Test\\n    void registersSqlTypesByClassNameAndCreatesJavaObjects() throws Exception {\\n        OracleConnection connection = new TestOracleOciConnection(new Properties());\\n\\n        connection.registerSQLType(SQL_TYPE_NAME, Date.class.getName());\\n\\n        assertThat(connection.getJavaObject(SQL_TYPE_NAME)).isInstanceOf(Date.class);\\n    }\\n\\n    @Test\\n    void resolvesClassesForSchemaQualifiedNames() throws Exception {\\n        TestOracleOciConnection connection = new TestOracleOciConnection(new Properties());\\n\\n        Class<?> resolvedClass = connection.classForNameAndSchema(ArrayList.class.getName(), \\\"APP\\\");\\n\\n        assertThat(resolvedClass).isSameAs(ArrayList.class);\\n    }\\n\\n    private static final class TestOracleOciConnection extends OracleOCIConnection {\\n        private TestOracleOciConnection(Properties properties) throws SQLException {\\n            super(\\\"jdbc:oracle:oci:@metadata-test\\\", properties, null);\\n       