class);\n        application.setBannerMode(Banner.Mode.OFF);\n        application.setLogStartupInfo(false);\n        application.setRegisterShutdownHook(false);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        return application.run();\n    }\n\n    public static class ClearingClassLoader extends ClassLoader {\n\n        private int clearCacheCount;\n\n        ClearingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public void clearCache() {\n            this.clearCacheCount++;\n        }\n\n        int getClearCacheCount() {\n            return this.clearCacheCount;\n        }\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class TestApplication {\n\n    }\n\n}\n=== tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/DurationToNumberConverterTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.math.BigInteger;\nimport java.time.Duration;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.convert.ApplicationConversionService;\nimport org.springframework.core.convert.ConversionService;\n\npublic class DurationToNumberConverterTest {\n\n    @Test\n    void conversionServiceConvertsDurationToNumberSubtype() {\n        ConversionService conversionService = new ApplicationConversionService();\n\n        BigInteger converted = conversionService.convert(Duration.ofSeconds(2), BigInteger.class);\n\n        assertThat(converted).isEqualTo(BigInteger.valueOf(2000));\n    }\n\n}\n=== tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/EnvironmentConverterTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.ApplicationContextFactory;\nimport org.springframework.boot.Banner;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringBootConfiguration;\nimport org.springframework.boot.WebApplicationType;\nimport org.springframework.context.ConfigurableApplicationContext;\nimport org.springframework.context.annotation.AnnotationConfigApplicationContext;\nimport org.springframework.core.env.ConfigurableEnvironment;\nimport org.springframework.core.env.StandardEnvironment;\n\npublic class EnvironmentConverterTest {\n\n    @Test\n    void runConvertsDefaultApplicationEnvironmentToFactoryEnvironmentType() {\n        SpringApplication application = new SpringApplication(TestApplication.class);\n        application.setApplicationContextFactory(new StandardEnvironmentContextFactory());\n        application.setBannerMode(Banner.Mode.OFF);\n        application.setLogStartupInfo(false);\n        application.setRegisterShutdownHook(false);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        application.setAdditionalProfiles(\"converted\");\n\n        try (ConfigurableApplicationContext context = application.run(\"--sample.value=from-argument\")) {\n            ConfigurableEnvironment environment = context.getEnvironment();\n            assertThat(environment).isExactlyInstanceOf(StandardEnvironment.class);\n            assertThat(environment.getActiveProfiles()).containsExactly(\"converted\");\n            assertThat(environment.getProperty(\"sample.value\")).isEqualTo(\"from-argument\");\n        }\n    }\n\n    private static final class StandardEnvironmentContextFactory implements ApplicationContextFactory {\n\n        @Override\n        public Class<? extends ConfigurableEnvironment> getEnvironmentType(WebApplicationType webApplicationType) {\n            return StandardEnvironment.class;\n        }\n\n        @Override\n        public ConfigurableApplicationContext create(WebApplicationType webApplicationType) {\n            return new AnnotationConfigApplicationContext();\n        }\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class TestApplication {\n\n    }\n\n}\n=== tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/JavaBeanBinderInnerBeanPropertyTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.context.properties.bind.Bindable;\nimport org.springframework.boot.context.properties.bind.Binder;\nimport org.springframework.boot.context.properties.source.MapConfigurationPropertySource;\n\npublic class JavaBeanBinderInnerBeanPropertyTest {\n\n    @Test\n    void bindUpdatesJavaBeanUsingPropertyAccessors() {\n        MutableProperties properties = new MutableProperties();\n        properties.getNames().add(\"before\");\n        Map<String, String> values = Map.of(\n                \"example.names[0]\", \"alpha\",\n                \"example.names[1]\", \"bravo\",\n                \"example.port\", \"8080\");\n        Binder binder = new Binder(new MapConfigurationPropertySource(values));\n\n        MutableProperties bound = binder.bind(\"example\", Bindable.of(MutableProperties.class).withExistingValue(properties))\n            .get();\n\n        assertThat(bound).isSameAs(properties);\n        assertThat(bound.getNames()).containsExactly(\"alpha\", \"bravo\");\n        assertThat(bound.getPort()).isEqualTo(8080);\n    }\n\n    public static class MutableProperties {\n\n        private final List<String> names = new ArrayList<>();\n\n        private int port;\n\n        public List<String> getNames() {\n            return this.names;\n        }\n\n        public int getPort() {\n            return this.port;\n        }\n\n        public void setPort(int port) {\n            this.port = port;\n        }\n\n    }\n\n}\n=== tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/SpringApplicationAotProcessorTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.file.Path;\nimport java.util.Arrays;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.springframework.boot.Banner;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringApplicationAotProcessor;\nimport org.springframework.boot.SpringBootConfiguration;\nimport org.springframework.boot.WebApplicationType;\n\npublic class SpringApplicationAotProcessorTest {\n\n    @Test\n    void mainProcessesApplicationWithStringArrayMainMethod(@TempDir Path tempDir) throws Exception {\n        StringMainApplication.receivedArguments = null;\n\n        process(StringMainApplication.class, tempDir, \"--sample.value=from-argument\");\n\n        assertThat(StringMainApplication.receivedArguments).containsExactly(\"--sample.value=from-argument\");\n    }\n\n    @Test\n    void mainProcessesApplicationWithNoArgumentMainMethod(@TempDir Path tempDir) throws Exception {\n        NoArgsMainApplication.invoked = false;\n\n        process(NoArgsMainApplication.class, tempDir);\n\n        assertThat(NoArgsMainApplication.invoked).isTrue();\n    }\n\n    private static void process(Class<?> applicationClass, Path tempDir, String... applicationArgs) throws Exception {\n        String[] processorArgs = new String[6 + applicationArgs.length];\n        processorArgs[0] = applicationClass.getName();\n        processorArgs[1] = tempDir.resolve(\"source\").toString();\n        processorArgs[2] = tempDir.resolve(\"resources\").toString();\n        processorArgs[3] = tempDir.resolve(\"classes\").toString();\n        processorArgs[4] = \"org.example\";\n        processorArgs[5] = \"spring-application-aot-processor-test\";\n        System.arraycopy(applicationArgs, 0, processorArgs, 6, applicationArgs.length);\n        SpringApplicationAotProcessor.main(processorArgs);\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class StringMainApplication {\n\n        static String[] receivedArguments;\n\n        public static void main(String[] args) {\n            receivedArguments = Arrays.copyOf(args, args.length);\n            runApplication(StringMainApplication.class, args);\n        }\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class NoArgsMainApplication {\n\n        static boolean invoked;\n\n        public static void main() {\n            invoked = true;\n            runApplication(NoArgsMainApplication.class);\n        }\n\n    }\n\n    private static void runApplication(Class<?> applicationClass, String... args) {\n        SpringApplication application = new SpringApplication(applicationClass);\n        application.setBannerMode(Banner.Mode.OFF);\n        application.setRegisterShutdownHook(false);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        application.run(args);\n    }\n\n}\n","exit_code":0,"status":"completed"}}
