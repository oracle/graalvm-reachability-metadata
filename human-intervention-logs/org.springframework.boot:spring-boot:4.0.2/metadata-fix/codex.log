{"type":"item.completed","item":{"id":"item_50","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,220p' tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/AnsiOutputTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.fail;\n\nimport java.lang.management.ManagementFactory;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Path;\nimport java.time.Duration;\nimport java.util.ArrayList;\nimport java.util.List;\nimport java.util.Locale;\nimport java.util.concurrent.TimeUnit;\nimport java.util.stream.Collectors;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.ansi.AnsiColor;\nimport org.springframework.boot.ansi.AnsiOutput;\nimport org.springframework.boot.ansi.AnsiOutput.Enabled;\n\npublic class AnsiOutputTest {\n\n    private static final String CHILD_MODE = \"ansi-output-detect-child\";\n\n    private static final String CHILD_MARKER = \"ansi-detect-child-ok\";\n\n    private static final Duration CHILD_TIMEOUT = Duration.ofSeconds(30);\n\n    @Test\n    void detectModeChecksWhetherTheConsoleIsATerminal() throws Exception {\n        Process process = new ProcessBuilder(scriptCommand()).redirectErrorStream(true).start();\n        boolean exited = process.waitFor(CHILD_TIMEOUT.toSeconds(), TimeUnit.SECONDS);\n        if (!exited) {\n            process.destroyForcibly();\n            fail(\"Timed out waiting for ANSI detection child process\");\n        }\n        String output = new String(process.getInputStream().readAllBytes(), StandardCharsets.UTF_8);\n        assertThat(process.exitValue()).as(output).isZero();\n        assertThat(output).contains(CHILD_MARKER);\n    }\n\n    public static void main(String[] args) {\n        if (args.length != 1 || !CHILD_MODE.equals(args[0])) {\n            throw new IllegalArgumentException(\"Expected child mode argument\");\n        }\n        AnsiOutput.setEnabled(Enabled.DETECT);\n        AnsiOutput.setConsoleAvailable(null);\n        String output = AnsiOutput.toString(AnsiColor.GREEN, CHILD_MARKER);\n        if (!output.contains(\"\\u001B[\") || !output.contains(CHILD_MARKER)) {\n            throw new AssertionError(\"ANSI output was not enabled by console terminal detection: \" + output);\n        }\n        System.out.println(CHILD_MARKER);\n    }\n\n    private static List<String> scriptCommand() {\n        List<String> javaCommand = new ArrayList<>();\n        javaCommand.add(javaExecutable().toString());\n        javaCommand.addAll(currentJavaAgents());\n        javaCommand.add(\"-cp\");\n        javaCommand.add(System.getProperty(\"java.class.path\"));\n        javaCommand.add(AnsiOutputTest.class.getName());\n        javaCommand.add(CHILD_MODE);\n        String quotedJavaCommand = javaCommand.stream()\n            .map(AnsiOutputTest::quoteForShell)\n            .collect(Collectors.joining(\" \"));\n        return List.of(\"script\", \"-q\", \"-e\", \"-c\", quotedJavaCommand, \"/dev/null\");\n    }\n\n    private static List<String> currentJavaAgents() {\n        return ManagementFactory.getRuntimeMXBean()\n            .getInputArguments()\n            .stream()\n            .filter(argument -> argument.startsWith(\"-javaagent:\"))\n            .filter(argument -> argument.toLowerCase(Locale.ROOT).contains(\"jacoco\"))\n            .toList();\n    }\n\n    private static Path javaExecutable() {\n        boolean windows = System.getProperty(\"os.name\").toLowerCase(Locale.ROOT).contains(\"win\");\n        String executable = windows ? \"java.exe\" : \"java\";\n        return Path.of(System.getProperty(\"java.home\"), \"bin\", executable);\n    }\n\n    private static String quoteForShell(String value) {\n        return \"'\" + value.replace(\"'\", \"'\\\\''\") + \"'\";\n    }\n\n}\n","exit_code":0,"status":"completed"}}
