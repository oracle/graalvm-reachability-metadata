  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.Banner;
  import org.springframework.boot.SpringApplication;
  import org.springframework.boot.SpringBootConfiguration;
  import org.springframework.boot.WebApplicationType;
  import org.springframework.context.ConfigurableApplicationContext;
  
  public class ClearCachesApplicationListenerTest {
  
      @Test
      void runningApplicationClearsCachesOnContextClassLoader() {
          Thread currentThread = Thread.currentThread();
          ClassLoader originalClassLoader = currentThread.getContextClassLoader();
          ClearingClassLoader clearingClassLoader = new ClearingClassLoader(originalClassLoader);
          currentThread.setContextClassLoader(clearingClassLoader);
          try (ConfigurableApplicationContext context = runApplication()) {
              assertThat(context.isActive()).isTrue();
              assertThat(clearingClassLoader.getClearCacheCount()).isPositive();
          }
          finally {
              currentThread.setContextClassLoader(originalClassLoader);
          }
      }
  
      private static ConfigurableApplicationContext runApplication() {
          SpringApplication application = new SpringApplication(TestApplication.class);
          application.setBannerMode(Banner.Mode.OFF);
          application.setLogStartupInfo(false);
          application.setRegisterShutdownHook(false);
          application.setWebApplicationType(WebApplicationType.NONE);
          return application.run();
      }
  
      public static class ClearingClassLoader extends ClassLoader {
  
          private int clearCacheCount;
  
          ClearingClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          public void clearCache() {
              this.clearCacheCount++;
          }
  
          int getClearCacheCount() {
              return this.clearCacheCount;
          }
  
      }
  
      @SpringBootConfiguration(proxyBeanMethods = false)
      public static class TestApplication {
  
      }
  
