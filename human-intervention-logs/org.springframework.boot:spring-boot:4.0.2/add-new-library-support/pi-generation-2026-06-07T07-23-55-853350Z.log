4146b016a251c587a148195aa14a134a46cf7f0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.info.ProcessInfo;\n\npublic class ProcessInfoTest {\n\n    @Test\n    void exposesCurrentProcessAndVirtualThreadInformationWhenAvailable() {\n        ProcessInfo processInfo = new ProcessInfo();\n\n        assertThat(processInfo.getPid()).isEqualTo(ProcessHandle.current().pid());\n        assertThat(processInfo.getCpus()).isPositive();\n\n        ProcessInfo.VirtualThreadsInfo virtualThreads = processInfo.getVirtualThreads();\n        if (virtualThreads != null) {\n            assertThat(virtualThreads.getMounted()).isGreaterThanOrEqualTo(0);\n            assertThat(virtualThreads.getQueued()).isGreaterThanOrEqualTo(0);\n            assertThat(virtualThreads.getParallelism()).isPositive();\n            assertThat(virtualThreads.getPoolSize()).isGreaterThanOrEqualTo(0);\n        }\n    }\n\n}\n"}], "isError": false, "timestamp": 1780816984793}, {"role": "toolResult", "toolCallId": "call_hiv0pEJAADnqKTpsnJ3SGozR|fc_0758cfe8fdc4146b016a251c587a1c8195bbd0dbc3d9f373b3", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.context.properties.bind.Binder;\nimport org.springframework.boot.context.properties.source.MapConfigurationPropertySource;\n\npublic class JavaBeanBinderInnerBeanPropertyTest {\n\n    @Test\n    void bindsMutableJavaBeanPropertyUsingSetter() {\n        Binder binder = new Binder(new MapConfigurationPropertySource(Map.of(\"sample.message\", \"configured\")));\n\n        MutableProperties properties = binder.bind(\"sample\", MutableProperties.class).get();\n\n        assertThat(properties.getMessage()).isEqualTo(\"configured\");\n    }\n\n    @Test\n    void bindsReadOnlyJavaBeanPropertyUsingGetterValue() {\n        Binder binder = new Binder(new MapConfigurationPropertySource(Map.of(\"sample.message\", \"unchanged\")));\n\n        ReadOnlyProperties properties = binder.bind(\"sample\", ReadOnlyProperties.class).get();\n\n        assertThat(properties.getMessage()).isEqualTo(\"unchanged\");\n    }\n\n    public static class MutableProperties {\n\n        private String message = \"default\";\n\n        public String getMessage() {\n            return this.message;\n        }\n\n        public void setMessage(String message) {\n            this.message = message;\n        }\n\n    }\n\n    public static class ReadOnlyProperties {\n\n        private final String message = \"unchanged\";\n\n        public String getMessage() {\n            return this.message;\n        }\n\n    }\n\n}\n"}], "isError": false, "timestamp": 1780816984794}]}
