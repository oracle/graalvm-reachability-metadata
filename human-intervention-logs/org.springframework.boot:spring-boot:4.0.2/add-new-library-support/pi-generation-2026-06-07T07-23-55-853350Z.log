  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.info.ProcessInfo;
  
  public class ProcessInfoTest {
  
      @Test
      void exposesCurrentProcessAndVirtualThreadInformationWhenAvailable() {
          ProcessInfo processInfo = new ProcessInfo();
  
          assertThat(processInfo.getPid()).isEqualTo(ProcessHandle.current().pid());
          assertThat(processInfo.getCpus()).isPositive();
  
          ProcessInfo.VirtualThreadsInfo virtualThreads = processInfo.getVirtualThreads();
          if (virtualThreads != null) {
              assertThat(virtualThreads.getMounted()).isGreaterThanOrEqualTo(0);
              assertThat(virtualThreads.getQueued()).isGreaterThanOrEqualTo(0);
              assertThat(virtualThreads.getParallelism()).isPositive();
              assertThat(virtualThreads.getPoolSize()).isGreaterThanOrEqualTo(0);
          }
      }
  
  }
