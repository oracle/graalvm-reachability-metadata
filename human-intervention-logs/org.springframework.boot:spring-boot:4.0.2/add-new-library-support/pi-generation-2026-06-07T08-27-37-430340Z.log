  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.context.properties.bind.Binder;
  import org.springframework.boot.context.properties.source.MapConfigurationPropertySource;
  
  public class JavaBeanBinderInnerBeanPropertyTest {
  
      @Test
      void bindsMutableJavaBeanPropertyUsingSetter() {
          Binder binder = new Binder(new MapConfigurationPropertySource(Map.of("sample.message", "configured")));
  
          MutableProperties properties = binder.bind("sample", MutableProperties.class).get();
  
          assertThat(properties.getMessage()).isEqualTo("configured");
      }
  
      @Test
      void bindsReadOnlyJavaBeanPropertyUsingGetterValue() {
          Binder binder = new Binder(new MapConfigurationPropertySource(Map.of("sample.message", "unchanged")));
  
          ReadOnlyProperties properties = binder.bind("sample", ReadOnlyProperties.class).get();
  
          assertThat(properties.getMessage()).isEqualTo("unchanged");
      }
  
      public static class MutableProperties {
  
          private String message = "default";
  
          public String getMessage() {
              return this.message;
          }
  
          public void setMessage(String message) {
              this.message = message;
          }
  
      }
  
      public static class ReadOnlyProperties {
  
          private final String message = "unchanged";
  
          public String getMessage() {
              return this.message;
          }
  
      }
  
  }
