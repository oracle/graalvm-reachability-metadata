sorArgs[1] = tempDir.resolve(\"source\").toString();\n        processorArgs[2] = tempDir.resolve(\"resources\").toString();\n        processorArgs[3] = tempDir.resolve(\"classes\").toString();\n        processorArgs[4] = \"org.example\";\n        processorArgs[5] = \"spring-application-aot-processor-test\";\n        System.arraycopy(applicationArgs, 0, processorArgs, 6, applicationArgs.length);\n        SpringApplicationAotProcessor.main(processorArgs);\n    }\n\n    @SpringBootConfiguration\n    public static class StringMainApplication {\n\n        static String[] receivedArguments;\n\n        public static void main(String[] args) {\n            receivedArguments = Arrays.copyOf(args, args.length);\n            runApplication(StringMainApplication.class, args);\n        }\n\n    }\n\n    @SpringBootConfiguration\n    public static class NoArgsMainApplication {\n\n        static boolean invoked;\n\n        public static void main() {\n            invoked = true;\n            runApplication(NoArgsMainApplication.class);\n        }\n\n    }\n\n    private static void runApplication(Class<?> applicationClass, String... args) {\n        SpringApplication application = new SpringApplication(applicationClass);\n        application.setBannerMode(Banner.Mode.OFF);\n        application.setRegisterShutdownHook(false);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        application.run(args);\n    }\n\n}\n"}
