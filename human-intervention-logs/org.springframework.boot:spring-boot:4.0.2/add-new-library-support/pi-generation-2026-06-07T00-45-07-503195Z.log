[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/SpringApplicationAotProcessorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.nio.file.Path;\nimport java.util.Arrays;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.springframework.boot.Banner;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringApplicationAotProcessor;\nimport org.springframework.boot.SpringBootConfiguration;\nimport org.springframework.boot.WebApplicationType;\n\npublic class SpringApplicationAotProcessorTest {\n\n    @Test\n    void mainProcessesApplicationWithStringArrayMainMethod(@TempDir Path tempDir) throws Exception {\n        StringMainApplication.receivedArguments = null;\n\n        process(StringMainApplication.class, tempDir, \"--sample.value=from-argument\");\n\n        assertThat(StringMainApplication.receivedArguments).containsExactly(\"--sample.value=from-argument\");\n    }\n\n    @Test\n    void mainProcessesApplicationWithNoArgumentMainMethod(@TempDir Path tempDir) throws Exception {\n        NoArgsMainApplication.invoked = false;\n\n        process(NoArgsMainApplication.class, tempDir);\n\n        assertThat(NoArgsMainApplication.invoked).isTrue();\n    }\n\n    private static void process(Class<?> applicationClass, Path tempDir, String... applicationArgs) throws Exception {\n        String[] processorArgs = new String[6 + applicationArgs.length];\n        processorArgs[0] = applicationClass.getName();\n        processorArgs[1] = tempDir.resolve(\"source\").toString();\n        processorArgs[2] = tempDir.resolve(\"resources\").toString();\n        processorArgs[3] = tempDir.resolve(\"classes\").toString();\n        processorArgs[4] = \"org.example\";\n        processorArgs[5] = \"spring-application-aot-processor-test\";\n        System.arraycopy(applicationArgs, 0, processorArgs, 6, applicationArgs.length);\n        SpringApplicationAotProcessor.main(processorArgs);\n    }\n\n    @SpringBootConfiguration\n    public static class StringMainApplication {\n\n        static String[] receivedArguments;\n\n        public static void main(String[] args) {\n            receivedArguments = Arrays.copyOf(args, args.length);\n            runApplication(StringMainApplication.class, args);\n        }\n\n    }\n\n    @SpringBootConfiguration\n    public static class NoArgsMainApplication {\n\n        static boolean invoked;\n\n        public static void main() {\n            invoked = true;\n            runApplication(NoArgsMainApplication.class);\n        }\n\n    }\n\n    private static void runApplication(Class<?> applicationClass, String... args) {\n        SpringApplication application = new SpringApplication(applicationClass);\n        application.setBannerMode(Banner.Mode.OFF);\n        application.setRegisterShutdownHook(false);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        application.run(args);\n    }\n\n}\n"}
