commons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_springframework_boot.spring_boot;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.util.Map;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.springframework.boot.context.properties.bind.Binder;\\nimport org.springframework.boot.context.properties.source.MapConfigurationPropertySource;\\n\\npublic class DefaultBindConstructorProviderInnerConstructorsTest {\\n\\n    @Test\\n    void bindsExistingNonStaticInnerJavaBeanProperty() {\\n        Binder binder = new Binder(\\n                new MapConfigurationPropertySource(Map.of(\\\"sample.nested.message\\\", \\\"configured\\\")));\\n\\n        OuterProperties properties = binder.bind(\\\"sample\\\", OuterProperties.class).get();\\n\\n        assertThat(properties.getNested().getMessage()).isEqualTo(\\\"configured\\\");\\n    }\\n\\n    public static class OuterProperties {\\n\\n        private final InnerProperties nested = new InnerProperties();\\n\\n        public InnerProperties getNested() {\\n            return this.nested;\\n        }\\n\\n        public class InnerProperties {\\n\\n            private String message = \\\"default\\\";\\n\\n            public String getMessage() {\\n                return this.message;\\n            }\\n\\n            public void setMessage(String message) {\\n                this.message = message;\\n            }\\n\\n        }\\n\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1859, "output": 1150, "cacheRead": 29184, "cacheWrite": 0, "totalTokens": 32193, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780821093646, "responseId": "resp_0acdf4a2616307f4016a252c6650c88195b54d34766f8cd4e8"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_4oBalt6tuRznbIYVxKo7SmVJ|fc_0acdf4a2616307f4016a252c7cf2a081958528fadaf9bb61a8", "toolName": "write", "conten