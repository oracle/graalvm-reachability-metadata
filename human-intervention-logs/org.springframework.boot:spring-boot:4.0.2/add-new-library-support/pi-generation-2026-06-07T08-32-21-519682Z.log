  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.context.properties.bind.Binder;
  import org.springframework.boot.context.properties.source.MapConfigurationPropertySource;
  
  public class ArrayBinderTest {
  
      @Test
      void bindsIndexedPropertiesToArray() {
          Map<String, String> properties = Map.of("sample[0]", "alpha", "sample[1]", "bravo");
          Binder binder = new Binder(new MapConfigurationPropertySource(properties));
  
          String[] values = binder.bind("sample", String[].class).get();
  
          assertThat(values).containsExactly("alpha", "bravo");
