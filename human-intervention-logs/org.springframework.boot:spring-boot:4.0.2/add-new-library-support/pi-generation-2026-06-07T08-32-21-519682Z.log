_boot/DefaultBindConstructorProviderInnerConstructorsTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.context.properties.bind.Binder;\nimport org.springframework.boot.context.properties.source.MapConfigurationPropertySource;\n\npublic class DefaultBindConstructorProviderInnerConstructorsTest {\n\n    @Test\n    void bindsExistingNonStaticInnerJavaBeanProperty() {\n        Binder binder = new Binder(\n                new MapConfigurationPropertySource(Map.of(\"sample.nested.message\", \"configured\")));\n\n        OuterProperties properties = binder.bind(\"sample\", OuterProperties.class).get();\n\n        assertThat(properties.getNested().getMessage()).isEqualTo(\"configured\");\n    }\n\n    public static class OuterProperties {\n\n        private final InnerProperties nested = new InnerProperties();\n\n        public InnerProperties getNested() {\n            return this.nested;\n        }\n\n        public class InnerProperties {\n\n            private String message = \"default\";\n\n            public String getMessage() {\n                return this.message;\n            }\n\n            public void setMessage(String message) {\n                this.message = message;\n            }\n\n        }\n\n    }\n\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/DefaultBindConstructorProviderInnerConstructorsTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_springframework_boot.spring_boot;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.util.Map;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.springframework.boot.context.properties.bind.Binder;\\nimport org.springframework.boot.context.properties.source.MapConfigurationPropertySource;\\n\\npublic class DefaultBindConstructorProviderInnerConstructorsTest {\\n\\n    @Test\\n    void bindsExistingNonStaticInnerJavaBeanProperty() {\\n        Binder binder = new Binder(\\n                new MapConfigurationPropertySource(Map.of(\\\"sample.nested.message\\\", \\\"configured\\\")));\\n\\n        OuterProperties properties = binder.bind(\\\"sample\\\", OuterProperties.class).get();\\n\\n        assertThat(properties.getNested().getMessage()).isEqualTo(\\\"configured\\\");\\n    }\\n\\n    public static class OuterProperties {\\n\\n        private final InnerProperties nested = new InnerProperties();\\n\\n        public InnerProperties getNested() {\\n            return this.nested;\\n        }\\n\\n        public class InnerProperties {\\n\\n            private String message = \\\"default\\\";\\n\\n            public String getMessage() {\\n                return this.message;\\n            }\\n\\n            public void setMessage(String message) {\\n                this.message = message;\\n            }\\n\\n        }\\n\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 1859, "output": 1150, "cacheRead": 29184, "cacheWrite": 0, "totalTokens": 32193, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780821093646, "responseId": "resp_0acdf4a2616307f4016a252c6650c88195b54d34766f8cd4e8"}}
