  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.stream.Stream;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.springframework.boot.SpringApplication;
  import org.springframework.boot.SpringApplicationAotProcessor;
  import org.springframework.boot.SpringBootConfiguration;
  import org.springframework.context.ConfigurableApplicationContext;
  
  public class SpringApplicationAotProcessorTest {
  
      @TempDir
      Path tempDir;
  
      @Test
      void processesApplicationWithStringArrayMainMethod() throws Exception {
          Path sourceOutput = process(StringArrayMainApplication.class, "--app.message=hello");
  
          assertThat(containsAnyFile(sourceOutput)).isTrue();
      }
  
      @Test
      void processesApplicationWithNoArgumentMainMethod() throws Exception {
          Path sourceOutput = process(NoArgumentMainApplication.class);
  
          assertThat(containsAnyFile(sourceOutput)).isTrue();
      }
  
      private Path process(Class<?> applicationClass, String... applicationArgs) throws Exception {
          Path output = this.tempDir.resolve(applicationClass.getSimpleName());
          Path sourceOutput = output.resolve("source");
          Path resourceOutput = output.resolve("resources");
          Path classOutput = output.resolve("classes");
          Files.createDirectories(sourceOutput);
          Files.createDirectories(resourceOutput);
          Files.createDirectories(classOutput);
  
          String[] processorArgs = new String[6 + applicationArgs.length];
          processorArgs[0] = applicationClass.getName();
          processorArgs[1] = sourceOutput.toString();
          processorArgs[2] = resourceOutput.toString();
          processorArgs[3] = classOutput.toString();
