  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.Set;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.Banner;
  import org.springframework.boot.SpringApplication;
  import org.springframework.boot.WebApplicationType;
  import org.springframework.context.ConfigurableApplicationContext;
  
  public class BeanDefinitionLoaderTest {
  
      @Test
      void loadsPackageSourceFromPackageName() {
          SpringApplication application = new SpringApplication();
          application.setSources(Set.of("org_springframework_boot.spring_boot.beandefinitionloaderfixture"));
          application.setWebApplicationType(WebApplicationType.NONE);
          application.setBannerMode(Banner.Mode.OFF);
          application.setLogStartupInfo(false);
  
          try (ConfigurableApplicationContext context = application.run()) {
              assertThat(context.getBean("packageLoadedMarker", String.class)).isEqualTo("package loaded");
          }
      }
  
  }
