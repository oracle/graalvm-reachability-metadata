d": "call_SzdiQWQ1qGK9ZqziRXlz8fAL|fc_09bbfa71891ce904016a251d4de2dc81968b4d7e14fac99d7a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.stream.Stream;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringApplicationAotProcessor;\nimport org.springframework.boot.SpringBootConfiguration;\nimport org.springframework.context.ConfigurableApplicationContext;\n\npublic class SpringApplicationAotProcessorTest {\n\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void processesApplicationWithStringArrayMainMethod() throws Exception {\n        Path sourceOutput = process(StringArrayMainApplication.class, \"--app.message=hello\");\n\n        assertThat(containsAnyFile(sourceOutput)).isTrue();\n    }\n\n    @Test\n    void processesApplicationWithNoArgumentMainMethod() throws Exception {\n        Path sourceOutput = process(NoArgumentMainApplication.class);\n\n        assertThat(containsAnyFile(sourceOutput)).isTrue();\n    }\n\n    private Path process(Class<?> applicationClass, String... applicationArgs) throws Exception {\n        Path output = this.tempDir.resolve(applicationClass.getSimpleName());\n        Path sourceOutput = output.resolve(\"source\");\n        Path resourceOutput = output.resolve(\"resources\");\n        Path classOutput = output.resolve(\"classes\");\n        Files.createDirectories(sourceOutput);\n        Files.createDirectories(resourceOutput);\n        Files.createDirectories(classOutput);\n\n        String[] processorArgs = new String[6 + applicationArgs.length];\n        processorArgs[0] = applicationClass.getName();\n        processorArgs[1] = sourceOutput.toString();\n        processorArgs[2] = resourceOutput.toString();\n        processorArgs[3] = classOutput.toString();\n        processorArgs[4] = \"org.example\";\n        processorArgs[5] = \"spring-application-aot-processor-test\";\n        System.arraycopy(applicationArgs, 0, processorArgs, 6, applicationArgs.length);\n        SpringApplicationAotProcessor.main(processorArgs);\n        return sourceOutput;\n    }\n\n    private static boolean containsAnyFile(Path directory) throws IOException {\n        try (Stream<Path> paths = Files.walk(directory)) {\n            return paths.anyMatch(Files::isRegularFile);\n        }\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class StringArrayMainApplication {\n\n        public static void main(String[] args) {\n            try (ConfigurableApplicationContext context = SpringApplication.run(\n                    StringArrayMainApplication.class, args)) {\n                context.getStartupDate();\n            }\n        }\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class NoArgumentMainApplication {\n\n        public static void main() {\n            try (ConfigurableApplicationContext context = SpringApplication.run(\n                    NoArgumentMainApplication.class)) {\n                context.getStartupDate();\n            }\n        }\n\n    }\n\n}\n"}], "isError": false, "timestamp": 1780817230250}, {"role": "toolResult", "toolCallId": "call_OefRj7Qf8rgrBZKMvhRUudlr|fc_09bbfa71891ce904016a251d4de2e481969c57e2279bdf5a14", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.Map;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.ApplicationContextFactory;\nimport org.springframework.boot.Banner;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringBootConfiguration;\nimport org.springframework.boot.WebApplicationType;\nimport org.springframework.context.ConfigurableApplicationContext;\nimport org.springframework.context.annotation.AnnotationConfigApplicationContext;\nimport org.springframework.core.env.ConfigurableEnvironment;\nimport org.springframework.core.env.MapPropertySource;\nimport org.springframework.core.env.StandardEnvironment;\n\npublic class EnvironmentConverterTest {\n\n    @Test\n    void convertsFactoryEnvironmentToRequestedEnvironmentType() {\n        SpringApplication application = new SpringApplication(EnvironmentConversionApplication.class);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        application.setBannerMode(Banner.Mode.OFF);\n        application.setApplicationContextFactory(new ConvertingApplicationContextFactory());\n\n        try (ConfigurableApplicationContext context = application.run()) {\n            ConfigurableEnvironment environment = context.getEnvironment();\n\n            assertThat(environment).isInstanceOf(ConvertedEnvironment.class);\n            assertThat(environment.getActiveProfiles()).containsExactly(\"conversion-test\");\n            assertThat(environment.getProperty(\"environment.converter.message\")).isEqualTo(\"converted\");\n        }\n    }\n\n    private static final class ConvertingApplicationContextFactory implements ApplicationContextFactory {\n\n        @Override\n        public Class<? extends ConfigurableEnvironment> getEnvironmentType(WebApplicationType webApplicationType) {\n            return ConvertedEnvironment.class;\n        }\n\n        @Override\n        public ConfigurableEnvironment createEnvironment(WebApplicationType webApplicationType) {\n            StandardEnvironment environment = new StandardEnvironment();\n            environment.setActiveProfiles(\"conversion-test\");\n            MapPropertySource propertySource = new MapPropertySource(\"conversion-test\",\n                    Map.of(\"environment.converter.message\", \"converted\"));\n            environment.getPropertySources().addFirst(propertySource);\n            return environment;\n        }\n\n        @Override\n        public ConfigurableApplicationContext create(WebApplicationType webApplicationType) {\n            return new AnnotationConfigApplicationContext();\n        }\n\n    }\n\n    public static class ConvertedEnvironment extends StandardEnvironment {\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class EnvironmentConversionApplication {\n\n    }\n\n}\n"}], "isError": false, "timestamp": 1780817230251}]}
