  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.util.List;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.SpringApplication;
  import org.springframework.context.ApplicationContext;
  import org.springframework.context.annotation.AnnotationConfigApplicationContext;
  
  public class BeanDefinitionLoaderTest {
  
      @Test
      void loadsPackageSourceFromPackageName() {
          String packageName = findUndefinedSpringBootPackage();
          try (AnnotationConfigApplicationContext context = loadPackageSource(packageName)) {
              Package loadedPackage = SpringApplication.class.getClassLoader()
                  .getDefinedPackage(packageName);
              assertThat(loadedPackage).isNotNull();
          }
      }
  
      private static String findUndefinedSpringBootPackage() {
          ClassLoader classLoader = SpringApplication.class.getClassLoader();
          List<String> packageNames = List.of("org.springframework.boot.logging.structured",
                  "org.springframework.boot.diagnostics.analyzer",
                  "org.springframework.boot.cloud");
          for (String packageName : packageNames) {
              if (classLoader.getDefinedPackage(packageName) == null) {
                  return packageName;
              }
          }
          return packageNames.get(0);
      }
  
      private static AnnotationConfigApplicationContext loadPackageSource(String packageName) {
          AnnotationConfigApplicationContext context = new AnnotationConfigApplicationContext();
          try {
              TestSpringApplication application = new TestSpringApplication();
              application.loadSources(context, packageName);
              return context;
          }
          catch (RuntimeException ex) {
              context.close();
              throw ex;
          }
      }
  
      private static final class TestSpringApplication extends SpringApplication {
  
          void loadSources(ApplicationContext context, Object... sources) {
              load(context, sources);
          }
  
      }
  
  }
