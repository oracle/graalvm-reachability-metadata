ts are ignored\n                com.example.FirstImport\n                com.example.SecondImport # trailing comments are ignored\n                \"\"\");\n        Path secondImports = writeImports(\"second.imports\", \"\"\"\n\n                com.example.ThirdImport\n                \"\"\");\n        ImportCandidates candidates = ImportCandidates.load(TestImportAnnotation.class,\n                new ImportsClassLoader(TestImportAnnotation.class, List.of(firstImports.toUri().toURL(),\n                        secondImports.toUri().toURL())));\n\n        assertThat(candidates.getCandidates()).containsExactly(\"com.example.FirstImport\", \"com.example.SecondImport\",\n                \"com.example.ThirdImport\");\n    }\n\n    private Path writeImports(String name, String content) throws IOException {\n        Path imports = this.tempDirectory.resolve(name);\n        Files.writeString(imports, content, StandardCharsets.UTF_8);\n        return imports;\n    }\n\n    private @interface TestImportAnnotation {\n\n    }\n\n    private static final class ImportsClassLoader extends ClassLoader {\n\n        private final String importsLocation;\n\n        private final List<URL> importsUrls;\n\n        private ImportsClassLoader(Class<?> annotation, List<URL> importsUrls) {\n            super(null);\n            this.importsLocation = \"META-INF/spring/\" + annotation.getName() + \".imports\";\n            this.importsUrls = importsUrls;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) {\n            if (!this.importsLocation.equals(name)) {\n                return Collections.emptyEnumeration();\n            }\n            return Collections.enumeration(this.importsUrls);\n        }\n\n    }\n\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/ImportCandidatesTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * 