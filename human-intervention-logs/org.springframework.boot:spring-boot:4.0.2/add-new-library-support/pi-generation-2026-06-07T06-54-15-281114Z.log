o/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.math.BigInteger;\nimport java.time.Duration;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.convert.ApplicationConversionService;\n\npublic class DurationToNumberConverterTest {\n\n    @Test\n    void convertsDurationToNumberUsingApplicationConversionService() {\n        ApplicationConversionService conversionService = new ApplicationConversionService();\n\n        BigInteger converted = conversionService.convert(Duration.ofSeconds(2).plusMillis(345), BigInteger.class);\n\n        assertThat(converted).isEqualTo(BigInteger.valueOf(2345));\n    }\n\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/DurationToNumberConverterTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_springframework_boot.spring_boot;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport java.math.BigInteger;\\nimport java.time.Duration;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.springframework.boot.convert.ApplicationConversionService;\\n\\npublic class DurationToNumberConverterTest {\\n\\n    @Test\\n    void convertsDurationToNumberUsingApplicationConversionService() {\\n        ApplicationConversionService conversionService = new ApplicationConversionService();\\n\\n        BigInteger converted = conversionService.convert(Duration.ofSeconds(2).plusMillis(345), BigInteger.class);\\n\\n        assertThat(converted).isEqualTo(BigInteger.valueOf(2345));\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 817, "output": 708, "cacheRead": 20992, "cacheWrite": 0, "to