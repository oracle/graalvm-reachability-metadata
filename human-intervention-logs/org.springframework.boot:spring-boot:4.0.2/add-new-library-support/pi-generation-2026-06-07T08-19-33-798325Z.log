  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.BeforeEach;
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.logging.LoggingSystem;
  
  public class LoggingSystemTest {
  
      private String previousLoggingSystemProperty;
  
      @BeforeEach
      void recordLoggingSystemProperty() {
          this.previousLoggingSystemProperty = System.getProperty(LoggingSystem.SYSTEM_PROPERTY);
      }
  
      @AfterEach
      void restoreLoggingSystemProperty() {
          if (this.previousLoggingSystemProperty != null) {
              System.setProperty(LoggingSystem.SYSTEM_PROPERTY, this.previousLoggingSystemProperty);
          }
          else {
              System.clearProperty(LoggingSystem.SYSTEM_PROPERTY);
          }
      }
  
      @Test
      void getInstantiatesConfiguredLoggingSystem() {
