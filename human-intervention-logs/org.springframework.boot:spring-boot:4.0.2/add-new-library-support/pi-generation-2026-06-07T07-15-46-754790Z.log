cationContext;\n\npublic class ClearCachesApplicationListenerTest {\n\n    @Test\n    void clearsCachesOnThreadContextClassLoaderWhenApplicationContextRefreshes() {\n        ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();\n        ClearCacheClassLoader classLoader = new ClearCacheClassLoader(previousClassLoader);\n        Thread.currentThread().setContextClassLoader(classLoader);\n        try (ConfigurableApplicationContext context = new SpringApplicationBuilder(CacheClearingApplication.class)\n                .web(WebApplicationType.NONE)\n                .bannerMode(Banner.Mode.OFF)\n                .run()) {\n            assertThat(context.isActive()).isTrue();\n            assertThat(classLoader.isCacheCleared()).isTrue();\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    public static final class ClearCacheClassLoader extends ClassLoader {\n\n        private boolean cacheCleared;\n\n        ClearCacheClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public void clearCache() {\n            this.cacheCleared = true;\n        }\n\n        boolean isCacheCleared() {\n            return this.cacheCleared;\n        }\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class CacheClearingApplication {\n\n    }\n\n}\n"}], "isError": false, "timestamp": 1780816497774}, {"role": "toolResult", "toolCallId": "call_DETJKzLiLRFCLk9vrgsoxyK9|fc_0ac8cadf0c9e3ebc016a251a716a94819385605216af661e17", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.ApplicationRunner;\nimport org.springframework.boot.Banner;\nimport org.springframework.boot.SpringApplication;\nimport org.springframework.boot.SpringBootConfiguration;\nimport org.springframework.boot.WebApplicationType;\nimport org.springframework.context.annotation.Bean;\n\npublic class NoSuchMethodFailureAnalyzerTest {\n\n    @Test\n    void analyzesNoSuchMethodErrorDuringApplicationStartup() {\n        SpringApplication application = new SpringApplication(NoSuchMethodFailureApplication.class);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        application.setBannerMode(Banner.Mode.OFF);\n\n        assertThatThrownBy(() -> application.run())\n                .isInstanceOf(IllegalStateException.class)\n                .hasRootCauseInstanceOf(NoSuchMethodError.class);\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class NoSuchMethodFailureApplication {\n\n        @Bean\n        ApplicationRunner noSuchMethodFailureRunner() {\n            return (args) -> MissingMethodCaller.callMissingMethod();\n        }\n\n    }\n\n    static final class MissingMethodCaller {\n\n        private MissingMethodCaller() {\n        }\n\n        static void callMissingMethod() {\n            String missingMethodDescriptor = MissingMethodTarget.class.getName() + \".missing()V\";\n            NoSuchMethodError error = new NoSuchMethodError(missingMethodDescriptor);\n            error.setStackTrace(new StackTraceElement[] { new StackTraceElement(\n                    MissingMethodCaller.class.getName(), \"callMissingMethod\",\n                    \"NoSuchMethodFailureAnalyzerTest.java\", 47) });\n            throw error;\n        }\n\n    }\n\n    static final class MissingMethodTarget {\n\n        private MissingMethodTarget() {\n        }\n\n    }\n\n}\n"}], "isError": false, "timestamp": 1780816497775}]}
