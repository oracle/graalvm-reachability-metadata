[tool-call] delta {"path":"tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/ProcessInfoTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.info.ProcessInfo;\n\npublic class ProcessInfoTest {\n\n    @Test\n    void exposesCurrentProcessAndVirtualThreadInformationWhenAvailable() {\n        ProcessInfo processInfo = new ProcessInfo();\n\n        assertThat(processInfo.getPid()).isEqualTo(ProcessHandle.current().pid());\n        assertThat(processInfo.getCpus()).isPositive();\n\n        ProcessInfo.VirtualThreadsInfo virtualThreads = processInfo.getVirtualThreads();\n        if (virtualThreads != null) {\n            assertThat(virtualThreads.getMounted()).isGreaterThanOrEqualTo(0);\n            assertThat(virtualThreads.getQueued()).isGreaterThanOrEqualTo(0);\n            assertThat(virtualThreads.getParallelism()).isPositive();\n            assertThat(virtualThreads.getPoolSize()).isGreaterThanOrEqualTo(0);\n        }\n    }\n\n}\n"}
