ents": {"path": "tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/ClearCachesApplicationListenerTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_springframework_boot.spring_boot;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.junit.jupiter.api.Test;\nimport org.springframework.boot.SpringApplicationBuilder;\nimport org.springframework.boot.SpringBootConfiguration;\nimport org.springframework.boot.WebApplicationType;\nimport org.springframework.context.ConfigurableApplicationContext;\n\npublic class ClearCachesApplicationListenerTest {\n\n    @Test\n    void clearsCachesOnThreadContextClassLoaderWhenApplicationContextRefreshes() {\n        ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();\n        ClearCacheClassLoader classLoader = new ClearCacheClassLoader(previousClassLoader);\n        Thread.currentThread().setContextClassLoader(classLoader);\n        try (ConfigurableApplicationContext context = new SpringApplicationBuilder(CacheClearingApplication.class)\n                .web(WebApplicationType.NONE)\n                .bannerMode(org.springframework.boot.Banner.Mode.OFF)\n                .run()) {\n            assertThat(context.isActive()).isTrue();\n            assertThat(classLoader.isCacheCleared()).isTrue();\n        }\n        finally {\n            Thread.currentThread().setContextClassLoader(previousClassLoader);\n        }\n    }\n\n    public static final class ClearCacheClassLoader extends ClassLoader {\n\n        private boolean cacheCleared;\n\n        ClearCacheClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public void clearCache() {\n            this.cacheCleared = true;\n        }\n\n        boolean isCacheCleared() {\n            return this.cacheCleared;\n        }\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class CacheClearingApplication {\n\n    }\n\n}\n"}, "partialJson": "{\"path\":\"tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/ClearCachesApplicationListenerTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_springframework_boot.spring_boot;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.springframework.boot.SpringApplicationBuilder;\\nimport org.springframework.boot.SpringBootConfiguration;\\nimport org.springframework.boot.WebApplicationType;\\nimport org.springframework.context.ConfigurableApplicationContext;\\n\\npublic class ClearCachesApplicationListenerTest {\\n\\n    @Test\\n    void clearsCachesOnThreadContextClassLoaderWhenApplicationContextRefreshes() {\\n        ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();\\n        ClearCacheClassLoader classLoader = new ClearCacheClassLoader(previousClassLoader);\\n        Thread.currentThread().setContextClassLoader(classLoader);\\n        try (ConfigurableApplicationContext context = new SpringApplicationBuilder(CacheClearingApplication.class)\\n                .web(WebApplicationType.NONE)\\n                .bannerMode(org.springframework.boot.Banner.Mode.OFF)\\n                .run()) {\\n            assertThat(context.isActive()).isTrue();\\n            assertThat(classLoader.isCacheCleared()).isTrue();\\n        }\\n        finally {\\n            Thread.currentThread().setContextClassLoader(previousClassLoader);\\n        }\\n    }\\n\\n    public static final class ClearCacheClassLoader extends ClassLoader {\\n\\n        private boolean cacheCleared;\\n\\n        ClearCacheClassLoader(ClassLoader parent) {\\n            super(parent);\\n        }\\n\\n        public void clearCache() {\\n            this.cacheCleared = true;\\n        }\\n\\n        boolean isCacheCleared() {\\n            return this.cacheCleared;\\n        }\\n\\n    }\\n\\n    @SpringBootConfiguration(proxyBeanMethods = false)\\n    public static class CacheClearingApplication {\\n\\n    }\\n\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 704, "output": 1227, "cacheRead": 15360, "cacheWrite": 0, "totalTokens": 17291, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780814423171, "responseId": "resp_0da5d4f2fbda51b3016a25125796888194a0437ca13b589544"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_m88ywSCczCCeI8gmCfbqT01z|fc_0da5d4f2fbda51b3016a251269823c81948d027abe4208d640", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1964 bytes to tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/ClearCachesApplicationListenerTest.java"}], "isError": false, "timestamp": 1780814446416}]}
