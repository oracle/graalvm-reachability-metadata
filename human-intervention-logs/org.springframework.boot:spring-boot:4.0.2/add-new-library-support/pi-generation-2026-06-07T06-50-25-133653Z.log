  import org.springframework.boot.WebApplicationType;
  import org.springframework.boot.builder.SpringApplicationBuilder;
  import org.springframework.context.ConfigurableApplicationContext;
  
  public class ClearCachesApplicationListenerTest {
  
      @Test
      void clearsCachesOnThreadContextClassLoaderWhenApplicationContextRefreshes() {
          ClassLoader previousClassLoader = Thread.currentThread().getContextClassLoader();
          ClearCacheClassLoader classLoader = new ClearCacheClassLoader(previousClassLoader);
          Thread.currentThread().setContextClassLoader(classLoader);
          try (ConfigurableApplicationContext context = new SpringApplicationBuilder(CacheClearingApplication.class)
                  .web(WebApplicationType.NONE)
                  .bannerMode(Banner.Mode.OFF)
                  .run()) {
              assertThat(context.isActive()).isTrue();
              assertThat(classLoader.isCacheCleared()).isTrue();
          }
          finally {
              Thread.currentThread().setContextClassLoader(previousClassLoader);
          }
      }
  
      public static final class ClearCacheClassLoader extends ClassLoader {
  
          private boolean cacheCleared;
  
          ClearCacheClassLoader(ClassLoader parent) {
              super(parent);
          }
  
          public void clearCache() {
              this.cacheCleared = true;
          }
  
          boolean isCacheCleared() {
              return this.cacheCleared;
          }
  
      }
  
      @SpringBootConfiguration(proxyBeanMethods = false)
      public static class CacheClearingApplication {
  
      }
  
  }
