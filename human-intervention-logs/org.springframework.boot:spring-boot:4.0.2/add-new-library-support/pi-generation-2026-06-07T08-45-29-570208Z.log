  /*
   * Copyright and related rights waived via CC0
   *
   * You should have received a copy of the CC0 legalcode along with this
   * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.
   */
  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatCode;
  
  import java.util.Map;
  
  import org.junit.jupiter.api.Test;
  import org.springframework.boot.context.properties.bind.BindConstructorProvider;
  import org.springframework.boot.context.properties.bind.Binder;
  import org.springframework.boot.context.properties.source.MapConfigurationPropertySource;
  import org.springframework.boot.info.SslInfo;
  
  public class DefaultBindConstructorProviderInnerConstructorsTest {
  
      @Test
      void defaultProviderInspectsLibraryNonStaticInnerClassConstructor() {
          Class<?> innerClass = SslInfo.BundleInfo.class;
  
          assertThatCode(() -> BindConstructorProvider.DEFAULT.getBindConstructor(innerClass, false))
              .doesNotThrowAnyException();
      }
  
      @Test
      void defaultProviderInspectsUserNonStaticInnerClassConstructor() {
          Class<?> innerClass = OuterProperties.InnerProperties.class;
  
          assertThatCode(() -> BindConstructorProvider.DEFAULT.getBindConstructor(innerClass, false))
              .doesNotThrowAnyException();
      }
  
      @Test
      void bindsExistingNonStaticInnerJavaBeanProperty() {
          Binder binder = new Binder(
                  new MapConfigurationPropertySource(Map.of("sample.nested.message", "configured")));
  
          OuterProperties properties = binder.bind("sample", OuterProperties.class).get();
  
          assertThat(properties.getNested().getMessage()).isEqualTo("configured");
      }
  
      public static class OuterProperties {
  
          private final InnerProperties nested = new InnerProperties();
  
          public InnerProperties getNested() {
              return this.nested;
          }
  
          public class InnerProperties {
  
              private String message = "default";
  
              public String getMessage() {
                  return this.message;
              }
  
              public void setMessage(String message) {
                  this.message = message;
              }
  
          }
  
      }
  
  }
