= currentThread.getContextClassLoader();\n        ClearingClassLoader clearingClassLoader = new ClearingClassLoader(originalClassLoader);\n        currentThread.setContextClassLoader(clearingClassLoader);\n        try (ConfigurableApplicationContext context = runApplication()) {\n            assertThat(context.isActive()).isTrue();\n            assertThat(clearingClassLoader.getClearCacheCount()).isPositive();\n        }\n        finally {\n            currentThread.setContextClassLoader(originalClassLoader);\n        }\n    }\n\n    private static ConfigurableApplicationContext runApplication() {\n        SpringApplication application = new SpringApplication(TestApplication.class);\n        application.setBannerMode(Banner.Mode.OFF);\n        application.setLogStartupInfo(false);\n        application.setRegisterShutdownHook(false);\n        application.setWebApplicationType(WebApplicationType.NONE);\n        return application.run();\n    }\n\n    public static class ClearingClassLoader extends ClassLoader {\n\n        private int clearCacheCount;\n\n        ClearingClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        public void clearCache() {\n            this.clearCacheCount++;\n        }\n\n        int getClearCacheCount() {\n            return this.clearCacheCount;\n        }\n\n    }\n\n    @SpringBootConfiguration(proxyBeanMethods = false)\n    public static class TestApplication {\n\n    }\n\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 795, "output": 778, "cacheRead": 27648, "cacheWrite": 0, "totalTokens": 29221, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780793197545, "responseId": "resp_00896739ecccdb4b016a24bf6dfea88190907f86d96598dd2a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_XMHoQhEaoaEcsvNh9ZQVoSZr|fc_00896739ecccdb4b016a24bf75c8fc81908f8a6509952e5532", "toolName": "write"