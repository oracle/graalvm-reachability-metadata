  package org_springframework_boot.spring_boot;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.nio.file.Path;
  import java.util.Arrays;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import org.springframework.boot.Banner;
  import org.springframework.boot.SpringApplication;
  import org.springframework.boot.SpringApplicationAotProcessor;
  import org.springframework.boot.SpringBootConfiguration;
  import org.springframework.boot.WebApplicationType;
  
  public class SpringApplicationAotProcessorTest {
  
      @Test
      void mainProcessesApplicationWithStringArrayMainMethod(@TempDir Path tempDir) throws Exception {
          StringMainApplication.receivedArguments = null;
  
          process(StringMainApplication.class, tempDir, "--sample.value=from-argument");
  
          assertThat(StringMainApplication.receivedArguments).containsExactly("--sample.value=from-argument");
      }
  
      @Test
      void mainProcessesApplicationWithNoArgumentMainMethod(@TempDir Path tempDir) throws Exception {
          NoArgsMainApplication.invoked = false;
  
          process(NoArgsMainApplication.class, tempDir);
  
          assertThat(NoArgsMainApplication.invoked).isTrue();
      }
  
      private static void process(Class<?> applicationClass, Path tempDir, String... applicationArgs) throws Exception {
          String[] processorArgs = new String[6 + applicationArgs.length];
          processorArgs[0] = applicationClass.getName();
          processorArgs[1] = tempDir.resolve("source").toString();
          processorArgs[2] = tempDir.resolve("resources").toString();
          processorArgs[3] = tempDir.resolve("classes").toString();
          processorArgs[4] = "org.example";
          processorArgs[5] = "spring-application-aot-processor-test";
          System.arraycopy(applicationArgs, 0, processorArgs, 6, applicationArgs.length);
          SpringApplicationAotProcessor.main(processorArgs);
      }
  
      @SpringBootConfiguration(proxyBeanMethods = false)
      public static class StringMainApplication {
  
          static String[] receivedArguments;
  
          public static void main(String[] args) {
              receivedArguments = Arrays.copyOf(args, args.length);
              runApplication(StringMainApplication.class, args);
          }
  
      }
  
      @SpringBootConfiguration(proxyBeanMethods = false)
      public static class NoArgsMainApplication {
  
          static boolean invoked;
  
          public static void main() {
              invoked = true;
              runApplication(NoArgsMainApplication.class);
          }
  
      }
  
      private static void runApplication(Class<?> applicationClass, String... args) {
          SpringApplication application = new SpringApplication(applicationClass);
          application.setBannerMode(Banner.Mode.OFF);
  
