InnerJavaBeanProperty() {\\n        Binder binder = new Binder(\\n                new MapConfigurationPropertySource(Map.of(\\\"sample.nested.message\\\", \\\"configured\\\")));\\n\\n        OuterProperties properties = binder.bind(\\\"sample\\\", OuterProperties.class).get();\\n\\n        assertThat(properties.getNested().getMessage()).isEqualTo(\\\"configured\\\");\\n    }\\n\\n    public static class OuterProperties {\\n\\n        private final InnerProperties nested = new InnerProperties();\\n\\n        public InnerProperties getNested() {\\n            return this.nested;\\n        }\\n\\n        public class InnerProperties {\\n\\n            private String message = \\\"default\\\";\\n\\n            public String getMessage() {\\n                return this.message;\\n            }\\n\\n            public void setMessage(String message) {\\n                this.message = message;\\n            }\\n\\n        }\\n\\n    }\\n\\n}\\n\"}\n../7685-93742acd/human-intervention-logs/org.springframework.boot:spring-boot:4.0.2/add-new-library-support/pi-generation-2026-06-07T08-32-21-519682Z.log:2583:[recv] {\"type\": \"message_end\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"thinking\", \"thinking\": \"**Considering report mapping**\\n\\nI'm thinking about how I need a one-to-one mapping with a dynamic report class. It seems like there's no existing file to reference, so I'll need to write one from scratch. I want to make sure that everything is clearly defined in the report. This will help ensure consistency and clarity in the final output. It feels a bit daunting, but I think I can figure it out with some effort!\", \"thinkingSignature\": \"{\\\"id\\\":\\\"rs_0acdf4a2616307f4016a252c66fe9481959e90e7bf63f1b6e1\\\",\\\"type\\\":\\\"reasoning\\\",\\\"content\\\":[],\\\"encrypted_content\\\":\\\"gAAAAABqJSx81GO-xTUcn2ZYpzFonw66Q1L8Ikkmjbmmu7qGWRzo64KAN4SVDGCOptehdrzlbbqWeWjv5t-zxZ3ve6l4uGXZTM33ZyDP-LDbfWTBM75Ksf-kAr3HUz0OXHUMbBQsGoY-NGkL655nEfshm