s.\\\"},{\\\"type\\\":\\\"summary_text\\\",\\\"text\\\":\\\"**Creating environment type overrides**\\\\n\\\\nI’m thinking about how to override `getEnvironmentType` and create an anonymous class for the test. Although, naming it a test class might not be ideal. It seems like a dynamic-access one-to-one mapping could work, especially if I use a `private static final class StandardEnvironmentContextFactory`. Making it public should be fine, but do I need to import `AnnotationConfigApplicationContext`? The `spring-context` dependency should handle that transitively, so I might just proceed with `ConfigurableApplicationContext`. There are a lot of details to keep in mind!\\\"}]}\"}, {\"type\": \"toolCall\", \"id\": \"call_gGhb0VGLeisgQYhmrENnF1Xo|fc_0bd5a8a2ad588708016a24c0120ea481969609aa7c0a91de83\", \"name\": \"write\", \"arguments\": {\"path\": \"tests/src/org.springframework.boot/spring-boot/4.0.2/src/test/java/org_springframework_boot/spring_boot/EnvironmentConverterTest.java\", \"content\": \"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_springframework_boot.spring_boot;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.springframework.boot.ApplicationContextFactory;\\nimport org.springframework.boot.Banner;\\nimport org.springframework.boot.SpringApplication;\\nimport org.springframework.boot.SpringBootConfiguration;\\nimport org.springframework.boot.WebApplicationType;\\nimport org.springframework.context.ConfigurableApplicationContext;\\nimport org.springframework.context.annotation.AnnotationConfigApplicationContext;\\nimport org.springframework.core.env.ConfigurableEnvironment;\\nimport org.springframework.core.env.StandardEnvironment;\\n\\npublic class EnvironmentConverterTest {\\n\\n    @Test\\n    void runConvertsDefaultApplicationEnvironmentToFactoryEnvironmentType() {\\n        SpringApplication application = new SpringApplication(TestApplication.class);\\n        application.setApplicationContextFactory(new StandardEnvironmentContextFactory());\\n        application.setBannerMode(Banner.Mode.OFF);\\n        application.setLogStartupInfo(false);\\n        application.setRegisterShutdownHook(false);\\n        application.setWebApplicationType(WebApplicationType.NONE);\\n        application.setAdditionalProfiles(\\\"converted\\\");\\n\\n        try (ConfigurableApplicationContext context = application.run(\\\"--sample.value=from-argument\\\")) {\\n            ConfigurableEnvironment environment = context.getEnvironment();\\n            assertThat(environment).isExactlyInstanceOf(StandardEnvironment.class);\\n            assertThat(environment.getActiveProfiles()).containsExactly(\\\"converted\\\");\\n            assertThat(environment.getProperty(\\\"sample.value\\\")).isEqualTo(\\\"from-argument\\\");\\n        }\\n    }\\n\\n    private static final class StandardEnvironmentContextFactory implements ApplicationContextFactory {\\n\\n        @Override\\n        public Class<? extends ConfigurableEnvironment> getEnvironmentType(WebApplicationType webApplicationType) {\\n            return StandardEnvironment.class;\\n        }\\n\\n        @Override\\n        public ConfigurableApplicationContext create(WebApplicationType webApplicationType) {\\n            return new AnnotationConfigApplicationContext();\\n        }\\n\\n    }\\n\\n    @SpringBootConfiguration(proxyBeanMethods = false)\\n    public static class TestApplication {\\n\\n    }\\n\\n}\\n\"}}], \"api\": \"openai-responses\", \"provider\": \"OCA\", \"model\": \"oca/gpt-5.5\", \"usage\": {\"input\": 1183, \"output\": 1399, \"cacheRead\": 26112, \"cacheWrite\": 0, \"totalTokens\": 28694, \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0, \"total\": 0}}, \"stopReason\": \"toolUse\", \"timest