                  if (!statements.isEmpty()) {
                      BlockStatement closureBlock = (BlockStatement) statements.get(0);
  
                      performSubstitutions(context, closureBlock);
  
                      return (T) getMacroValue(closureBlock, asIs);
                  }
              }
              if (node instanceof ClassNode) {
