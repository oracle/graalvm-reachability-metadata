          )
  
          AstAssert.assertSyntaxTree([expected], [result])
          '''
      }
  
      void testCompileStatic() {
          assertScript '''
          import groovy.transform.CompileStatic
          import org.codehaus.groovy.ast.stmt.ReturnStatement;
