              for (item in [1, 2, 3]) {
                  total += item
              }
              total
          }''', [], BlockStatement)
          Expression pattern = MacroBuilder.INSTANCE.macro('{ total += _ }', [], Expression)
  
          List<TreeContext> matches = ASTMatcher.find(block, pattern)
  
