at(parts).hasSize(1);\\n        Request.Part part = parts.iterator().next();\\n        assertThat(part.getName()).isEqualTo(\\\"message\\\");\\n        assertThat(part.getFileName()).isNull();\\n        assertThat(part.getHeader(\\\"Content-Type\\\").firstValue())\\n                .isEqualTo(\\\"text/plain; charset=UTF-8\\\");\\n        assertThat(part.getBody().asString()).isEqualTo(\\\"hello from multipart\\\");\\n    }\\n}\\n=== tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/Jetty11HttpUtilsTest.java ===\\n/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage org_wiremock.wiremock;\\n\\nimport com.github.tomakehurst.wiremock.WireMockServer;\\nimport com.github.tomakehurst.wiremock.http.Fault;\\nimport java.io.IOException;\\nimport java.net.URL;\\nimport java.security.SecureRandom;\\nimport java.security.cert.X509Certificate;\\nimport javax.net.ssl.HttpsURLConnection;\\nimport javax.net.ssl.SSLContext;\\nimport javax.net.ssl.TrustManager;\\nimport javax.net.ssl.X509TrustManager;\\nimport org.junit.jupiter.api.Test;\\n\\nimport static com.github.tomakehurst.wiremock.client.WireMock.aResponse;\\nimport static com.github.tomakehurst.wiremock.client.WireMock.get;\\nimport static com.github.tomakehurst.wiremock.client.WireMock.urlEqualTo;\\nimport static com.github.tomakehurst.wiremock.core.WireMockConfiguration.wireMockConfig;\\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\\n\\npublic class Jetty11HttpUtilsTest {\\n    private static final int TIMEOUT_MILLIS = 5_000;\\n\\n    @Test\\n    void unwrapsTlsSocketWhenApplyingHttpsFault() throws Exception {\\n        WireMockServer server = new WireMockServer(wireMockConfig()\\n                .httpDisabled(true)\\n                .dynamicHttpsPort()\\n                .http2TlsDisabled(true));\\n        server.start();\\n        try {\\n            server.stubFor(get(urlEqualTo(\\\"/tls-fault\\\"))\\n                    .willReturn(aResponse().withFault(Fault.EMPTY_RESPONSE)));\\n\\n            HttpsURLConnection connection = openTrustedHttpsConnection(\\n                    new URL(\\\"https://localhost:\\\" + server.httpsPort() + \\\"/tls-fault\\\"));\\n            try {\\n                assertThatThrownBy(connection::getResponseCode)\\n                        .isInstanceOf(IOException.class);\\n            } finally {\\n                connection.disconnect();\\n            }\\n        } finally {\\n            server.stop();\\n        }\\n    }\\n\\n    private static HttpsURLConnection openTrustedHttpsConnection(URL url) throws Exception {\\n        SSLContext sslContext = SSLContext.getInstance(\\\"TLS\\\");\\n        sslContext.init(null, new TrustManager[] {trustAllCertificates()}, new SecureRandom());\\n\\n        HttpsURLConnection connection = (HttpsURLConnection) url.openConnection();\\n        connection.setSSLSocketFactory(sslContext.getSocketFactory());\\n        connection.setHostnameVerifier((hostname, session) -> true);\\n        connection.setConnectTimeout(TIMEOUT_MILLIS);\\n        connection.setReadTimeout(TIMEOUT_MILLIS);\\n        connection.setRequestMethod(\\\"GET\\\");\\n        return connection;\\n    }\\n\\n    private static X509TrustManager trustAllCertificates() {\\n        return new X509TrustManager() {\\n            @Override\\n            public void checkClientTrusted(X509Certificate[] chain, String authType) {\\n            }\\n\\n            @Override\\n            public void checkServerTrusted(X509Certificate[] chain, String authType) {\\n            }\\n\\n            @Override\\n            public X509Certificate[] getAcceptedIssuers() {\\n                return new X509Certificate[0];\\n            }\\n        };\\n    }\\n}\\n=== tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/JettyHttpUtilsTest.j