  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.common.ssl.KeyStoreSource;
  import com.github.tomakehurst.wiremock.common.ssl.KeyStoreSourceFactory;
  import com.github.tomakehurst.wiremock.common.ssl.ReadOnlyFileOrClasspathKeyStoreSource;
  import com.github.tomakehurst.wiremock.jetty11.WritableFileOrClasspathKeyStoreSource;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class KeyStoreSourceFactoryTest {
      @Test
      void createsWritableKeyStoreSourceWhenJettyImplementationIsAvailable() {
          String path = "target/generated-test-keystores/wiremock-test-keystore.jks";
          String keyStoreType = "JKS";
          char[] password = "changeit".toCharArray();
  
          KeyStoreSource keyStoreSource = KeyStoreSourceFactory.getAppropriateForJreVersion(path, keyStoreType, password);
  
          assertThat(keyStoreSource).isInstanceOf(WritableFileOrClasspathKeyStoreSource.class);
          ReadOnlyFileOrClasspathKeyStoreSource fileSource = (ReadOnlyFileOrClasspathKeyStoreSource) keyStoreSource;
          assertThat(fileSource.getPath()).isEqualTo(path);
          assertThat(fileSource.getKeyStoreType()).isEqualTo(keyStoreType);
          assertThat(fileSource.getKeyStorePassword()).isEqualTo("changeit");
      }
  }
