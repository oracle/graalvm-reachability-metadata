  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.http.HttpServerFactory;
  import com.github.tomakehurst.wiremock.jetty.JettyHttpServerFactory;
  import com.github.tomakehurst.wiremock.standalone.CommandLineOptions;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class CommandLineOptionsTest {
      @Test
      void createsDefaultJettyHttpServerFactoryFromStandaloneOptions() {
          CommandLineOptions options = new CommandLineOptions("--port", "0");
  
          HttpServerFactory httpServerFactory = options.httpServerFactory();
  
          assertThat(httpServerFactory).isInstanceOf(JettyHttpServerFactory.class);
          assertThat(options.hasDefaultHttpServerFactory()).isTrue();
      }
  }
