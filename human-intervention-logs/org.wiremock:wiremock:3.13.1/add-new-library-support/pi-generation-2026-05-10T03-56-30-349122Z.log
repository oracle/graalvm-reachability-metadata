[tool-call] delta {"path":"tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/CommandLineOptionsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.http.HttpServerFactory;\nimport com.github.tomakehurst.wiremock.jetty.JettyHttpServerFactory;\nimport com.github.tomakehurst.wiremock.standalone.CommandLineOptions;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class CommandLineOptionsTest {\n    @Test\n    void createsDefaultJettyHttpServerFactoryFromStandaloneOptions() {\n        CommandLineOptions options = new CommandLineOptions(\"--port\", \"0\");\n\n        HttpServerFactory httpServerFactory = options.httpServerFactory();\n\n        assertThat(httpServerFactory).isInstanceOf(JettyHttpServerFactory.class);\n        assertThat(options.hasDefaultHttpServerFactory()).isTrue();\n    }\n}\n"}
