  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.common.ArrayFunctions;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ArrayFunctionsTest {
      @Test
      void prependsElementToTypedArray() {
          String[] original = new String[] {"second", "third"};
  
          String[] prepended = ArrayFunctions.prepend("first", original);
  
          assertThat(prepended)
                  .containsExactly("first", "second", "third");
          assertThat(prepended.getClass().getComponentType())
                  .isEqualTo(String.class);
          assertThat(original)
                  .containsExactly("second", "third");
      }
  }
