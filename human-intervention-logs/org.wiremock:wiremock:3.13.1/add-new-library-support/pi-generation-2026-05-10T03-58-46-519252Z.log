[tool-call] delta {"path":"tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/AdminRoutesInnerRouteBuilderTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.admin.AdminRoutes;\nimport com.github.tomakehurst.wiremock.admin.AdminTask;\nimport com.github.tomakehurst.wiremock.admin.Router;\nimport com.github.tomakehurst.wiremock.admin.tasks.GetVersionTask;\nimport com.github.tomakehurst.wiremock.core.WireMockConfiguration;\nimport com.github.tomakehurst.wiremock.extension.AdminApiExtension;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\nimport static com.github.tomakehurst.wiremock.http.RequestMethod.GET;\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AdminRoutesInnerRouteBuilderTest {\n    @Test\n    void createsAdminTaskFromClassContributedByExtension() {\n        WireMockConfiguration options = WireMockConfiguration.options();\n        AdminRoutes adminRoutes = AdminRoutes.forServer(\n                List.of(new ClassBasedAdminRouteExtension()),\n                options.getStores());\n\n        AdminTask task = adminRoutes.taskFor(GET, \"/extension-version\");\n\n        assertThat(task).isInstanceOf(GetVersionTask.class);\n    }\n\n    public static class ClassBasedAdminRouteExtension implements AdminApiExtension {\n        @Override\n        public String getName() {\n            return \"class-based-admin-route-extension\";\n        }\n\n        @Override\n        public void contributeAdminApiRoutes(Router router) {\n            router.add(GET, \"/extension-version\", GetVersionTask.class);\n        }\n    }\n}\n"}
