  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.core.WireMockConfiguration;
  import com.github.tomakehurst.wiremock.extension.Extension;
  import com.github.tomakehurst.wiremock.extension.ExtensionFactory;
  import com.github.tomakehurst.wiremock.extension.Extensions;
  import com.github.tomakehurst.wiremock.extension.WireMockServices;
  import java.util.List;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExtensionsTest {
      @Test
      void loadsDeclaredExtensionsAndFactoryClasses() {
          WireMockConfiguration options = WireMockConfiguration.options()
                  .templatingEnabled(false)
                  .extensions(NamedExtensionLoadedByClassName.class.getName())
                  .extensions(NamedExtensionLoadedByClass.class)
                  .extensionFactories(DeclaredExtensionFactory.class);
          Extensions extensions = new Extensions(
                  options.getDeclaredExtensions(),
                  null,
                  options,
                  options.getStores(),
                  options.filesRoot());
  
          extensions.load();
  
          assertThat(extensions.getAllExtensionNames())
                  .contains(
                          "named-extension-loaded-by-class-name",
                          "named-extension-loaded-by-class",
                          "extension-created-by-declared-factory");
      }
  
      public static class NamedExtensionLoadedByClassName implements Extension {
          @Override
          public String getName() {
              return "named-extension-loaded-by-class-name";
          }
      }
  
      public static class NamedExtensionLoadedByClass implements Extension {
          @Override
          public String getName() {
              return "named-extension-loaded-by-class";
          }
      }
  
      public static class DeclaredExtensionFactory implements ExtensionFactory {
          @Override
          public List<Extension> create(WireMockServices services) {
              return List.of(new ExtensionCreatedByDeclaredFactory());
          }
      }
  
      public static class ExtensionCreatedByDeclaredFactory implements Extension {
          @Override
          public String getName() {
              return "extension-created-by-declared-factory";
          }
      }
  }
