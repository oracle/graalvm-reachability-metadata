  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.extension.Extension;
  import com.github.tomakehurst.wiremock.extension.ExtensionLoader;
  import java.util.Map;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ExtensionLoaderTest {
      @Test
      void loadsExtensionByClassName() {
          Map<String, Extension> extensions = ExtensionLoader.load(ByClassNameExtension.class.getName());
  
          assertThat(extensions)
                  .containsOnlyKeys("extension-loader-by-class-name");
          assertThat(extensions.get("extension-loader-by-class-name"))
                  .isInstanceOf(ByClassNameExtension.class);
      }
  
      @Test
      void loadsExtensionByClassLiteral() {
          Map<String, Extension> extensions = ExtensionLoader.load(ByClassLiteralExtension.class);
  
          assertThat(extensions)
                  .containsOnlyKeys("extension-loader-by-class-literal");
          assertThat(extensions.get("extension-loader-by-class-literal"))
                  .isInstanceOf(ByClassLiteralExtension.class);
      }
  
      public static class ByClassNameExtension implements Extension {
          @Override
          public String getName() {
              return "extension-loader-by-class-name";
          }
      }
  
      public static class ByClassLiteralExtension implements Extension {
          @Override
          public String getName() {
              return "extension-loader-by-class-literal";
          }
      }
  }
