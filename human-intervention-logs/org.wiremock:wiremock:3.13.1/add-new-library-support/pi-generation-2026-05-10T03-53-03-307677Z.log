nsions.getAllExtensionNames())\n                .contains(\n                        \"named-extension-loaded-by-class-name\",\n                        \"named-extension-loaded-by-class\",\n                        \"extension-created-by-declared-factory\");\n    }\n\n    public static class NamedExtensionLoadedByClassName implements Extension {\n        @Override\n        public String getName() {\n            return \"named-extension-loaded-by-class-name\";\n        }\n    }\n\n    public static class NamedExtensionLoadedByClass implements Extension {\n        @Override\n        public String getName() {\n            return \"named-extension-loaded-by-class\";\n        }\n    }\n\n    public static class DeclaredExtensionFactory implements ExtensionFactory {\n        @Override\n        public List<Extension> create(WireMockServices services) {\n            return List.of(new ExtensionCreatedByDeclaredFactory());\n        }\n    }\n\n    public static class ExtensionCreatedByDeclaredFactory implements Extension {\n        @Override\n        public String getName() {\n            return \"extension-created-by-declared-factory\";\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 547, "output": 1244, "cacheRead": 19968, "cacheWrite": 0, "totalTokens": 21759, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778385128296, "responseId": "resp_0bedfeefd311fd52016a0000e8e80c81909927bf88ebe4741e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_L2hD48m8Aim9zC4MpJ96JPwb|fc_0bedfeefd311fd52016a0000f336fc81908824bdf31dcb9fbd", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2483 bytes to tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/ExtensionsTest.java"}], "isError": false, "timestamp": 1778385145023}]}
