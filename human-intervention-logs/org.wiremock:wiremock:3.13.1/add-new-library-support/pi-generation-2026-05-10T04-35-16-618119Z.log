  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.common.Json;
  import com.github.tomakehurst.wiremock.matching.ContainsPattern;
  import com.github.tomakehurst.wiremock.matching.StringValuePattern;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class StringValuePatternJsonDeserializerTest {
      @Test
      void deserializesConstructorBackedStringValuePattern() {
          StringValuePattern pattern = Json.read("""
                  {
                    "contains": "expected fragment"
                  }
                  """, StringValuePattern.class);
  
          assertThat(pattern)
                  .isInstanceOf(ContainsPattern.class);
          assertThat(((ContainsPattern) pattern).getContains())
                  .isEqualTo("expected fragment");
          assertThat(pattern.match("prefix expected fragment suffix").isExactMatch())
                  .isTrue();
          assertThat(pattern.match("different value").isExactMatch())
                  .isFalse();
      }
  }
