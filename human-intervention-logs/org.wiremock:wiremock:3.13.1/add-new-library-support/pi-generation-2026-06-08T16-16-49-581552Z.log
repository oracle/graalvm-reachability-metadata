    }
  
    @Override
    public Body getBody() {
      return Body.ofBinaryOrText(fileItem.get(), new ContentTypeHeader(fileItem.getContentType()));
    }
  
    public static final Function<FileItem, Request.Part> TO_PARTS = FileItemPartAdapter::new;
  }
