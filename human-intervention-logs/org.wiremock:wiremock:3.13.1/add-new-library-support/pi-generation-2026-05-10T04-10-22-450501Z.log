[tool-call] delta {"path":"tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/XmlDomNodeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.common.xml.XmlDomNode;\nimport java.io.ByteArrayInputStream;\nimport java.nio.charset.StandardCharsets;\nimport javax.xml.parsers.DocumentBuilder;\nimport javax.xml.parsers.DocumentBuilderFactory;\nimport org.junit.jupiter.api.Test;\nimport org.w3c.dom.Document;\nimport org.w3c.dom.Element;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class XmlDomNodeTest {\n    @Test\n    void rendersElementNodeUsingDom2SaxTransformSourceWhenAvailable() throws Exception {\n        DocumentBuilderFactory documentBuilderFactory = DocumentBuilderFactory.newInstance();\n        documentBuilderFactory.setNamespaceAware(true);\n        DocumentBuilder documentBuilder = documentBuilderFactory.newDocumentBuilder();\n        Document document = documentBuilder.parse(new ByteArrayInputStream(\"\"\"\n                <root xmlns=\"urn:test\" id=\"123\">\n                    <child>value</child>\n                </root>\n                \"\"\".getBytes(StandardCharsets.UTF_8)));\n        Element root = document.getDocumentElement();\n\n        XmlDomNode node = new XmlDomNode(root);\n\n        String renderedXml = node.toString();\n\n        assertThat(renderedXml)\n                .contains(\"<root\")\n                .contains(\"id=\\\"123\\\"\")\n                .contains(\"<child>value</child>\");\n    }\n}\n"}
