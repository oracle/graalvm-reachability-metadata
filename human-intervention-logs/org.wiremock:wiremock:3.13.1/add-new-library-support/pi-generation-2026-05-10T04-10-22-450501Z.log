nAvailable() throws Exception {\n        DocumentBuilderFactory documentBuilderFactory = DocumentBuilderFactory.newInstance();\n        documentBuilderFactory.setNamespaceAware(true);\n        DocumentBuilder documentBuilder = documentBuilderFactory.newDocumentBuilder();\n        Document document = documentBuilder.parse(new ByteArrayInputStream(\"\"\"\n                <root xmlns=\"urn:test\" id=\"123\">\n                    <child>value</child>\n                </root>\n                \"\"\".getBytes(StandardCharsets.UTF_8)));\n        Element root = document.getDocumentElement();\n\n        XmlDomNode node = new XmlDomNode(root);\n\n        String renderedXml = node.toString();\n\n        assertThat(renderedXml)\n                .contains(\"<root\")\n                .contains(\"id=\\\"123\\\"\")\n                .contains(\"<child>value</child>\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 378, "output": 943, "cacheRead": 16896, "cacheWrite": 0, "totalTokens": 18217, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778386208012, "responseId": "resp_0bf194598b56bb95016a00052089f08191902ff2d0750f40dd"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_UrK9YVP2mAcqBKe9g6rmH0IA|fc_0bf194598b56bb95016a0005282e6c81918a68a4d59abe7094", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1551 bytes to tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/XmlDomNodeTest.java"}], "isError": false, "timestamp": 1778386217326}]}
