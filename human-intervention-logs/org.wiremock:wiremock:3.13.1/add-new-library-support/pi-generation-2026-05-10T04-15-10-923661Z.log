  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.admin.AdminRoutes;
  import com.github.tomakehurst.wiremock.admin.AdminTask;
  import com.github.tomakehurst.wiremock.admin.Router;
  import com.github.tomakehurst.wiremock.admin.tasks.GetVersionTask;
  import com.github.tomakehurst.wiremock.core.WireMockConfiguration;
  import com.github.tomakehurst.wiremock.extension.AdminApiExtension;
  import java.util.List;
  import org.junit.jupiter.api.Test;
  
  import static com.github.tomakehurst.wiremock.http.RequestMethod.GET;
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AdminRoutesInnerRouteBuilderTest {
      @Test
      void createsAdminTaskFromClassContributedByExtension() {
          WireMockConfiguration options = WireMockConfiguration.options();
          AdminRoutes adminRoutes = AdminRoutes.forServer(
                  List.of(new ClassBasedAdminRouteExtension()),
                  options.getStores());
  
          AdminTask task = adminRoutes.taskFor(GET, "/extension-version");
  
          assertThat(task).isInstanceOf(GetVersionTask.class);
      }
  
      public static class ClassBasedAdminRouteExtension implements AdminApiExtension {
          @Override
          public String getName() {
              return "class-based-admin-route-extension";
          }
  
          @Override
          public void contributeAdminApiRoutes(Router router) {
              router.add(GET, "/extension-version", GetVersionTask.class);
          }
      }
