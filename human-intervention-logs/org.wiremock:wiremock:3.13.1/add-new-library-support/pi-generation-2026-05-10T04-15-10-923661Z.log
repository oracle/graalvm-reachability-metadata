  package org_wiremock.wiremock;
  
  import com.github.tomakehurst.wiremock.http.ImmutableRequest;
  import com.github.tomakehurst.wiremock.http.Request;
  import com.github.tomakehurst.wiremock.http.RequestMethod;
  import com.github.tomakehurst.wiremock.http.multipart.PartParser;
  import java.nio.charset.StandardCharsets;
  import java.util.Collection;
  import org.junit.jupiter.api.Test;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class FileUploadInnerFileItemIteratorImplInnerFileItemStreamImplTest {
      @Test
      void parsesMultipartFormDataPartContent() {
          String boundary = "wiremock-boundary";
          String multipartBody = """
                  --wiremock-boundary
  
                  Content-Disposition: form-data; name="message"
  
                  Content-Type: text/plain; charset=UTF-8
  
                  
  
                  hello from multipart
  
                  --wiremock-boundary--
  
                  """.replace("\n", "");
          Request request = ImmutableRequest.create()
                  .withAbsoluteUrl("http://localhost/upload")
                  .withMethod(RequestMethod.POST)
                  .withProtocol("HTTP/1.1")
                  .withClientIp("127.0.0.1")
                  .withHeader("Content-Type", "multipart/form-data; boundary=" + boundary)
                  .withBody(multipartBody.getBytes(StandardCharsets.UTF_8))
                  .withMultipart(true)
                  .build();
  
          Collection<Request.Part> parts = PartParser.parseFrom(request);
  
          assertThat(parts).hasSize(1);
          Request.Part part = parts.iterator().next();
          assertThat(part.getName()).isEqualTo("message");
          assertThat(part.getFileName()).isNull();
          assertThat(part.getHeader("Content-Type").firstValue()).isEqualTo("text/plain; charset=UTF-8");
          assertThat(part.getBody().asString()).isEqualTo("hello from multipart");
      }
  }
