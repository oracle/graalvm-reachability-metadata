ce childSource = fileSource.child(\"nested\");\n        List<String> fileContents = fileSource.listFilesRecursively().stream()\n                .map(TextFile::readContentsAsString)\n                .toList();\n\n        assertThat(fileSource.exists()).isTrue();\n        assertThat(fileSource.getPath()).isEqualTo(rootDirectory.toString());\n        assertThat(fileSource.getUri()).isEqualTo(rootDirectory.toUri());\n        assertThat(fileSource.getTextFileNamed(\"root.txt\").readContentsAsString()).isEqualTo(\"root file\");\n        assertThat(childSource.exists()).isTrue();\n        assertThat(childSource.getTextFileNamed(\"child.txt\").readContentsAsString()).isEqualTo(\"child file\");\n        assertThat(fileContents).containsExactlyInAnyOrder(\"root file\", \"child file\");\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2620, "output": 1033, "cacheRead": 17408, "cacheWrite": 0, "totalTokens": 21061, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1780937267529, "responseId": "resp_067028d64b2d056a016a26f233f5ac81938cabbdbbb2f3ba3d"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_m9Wd8ZcFc5kh2oATVBQ2FEs3|fc_067028d64b2d056a016a26f24357a08193a722f4a203b09c5d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1959 bytes to tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/ClasspathFileSourceTest.java"}], "isError": false, "timestamp": 1780937289487}]}
