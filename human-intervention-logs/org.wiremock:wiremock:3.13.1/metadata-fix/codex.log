quals;\nimport static org.junit.jupiter.api.Assertions.assertInstanceOf;\n\npublic class ExtensionLoaderTest {\n    @Test\n    void loadsExtensionByClassName() {\n        Map<String, Extension> extensions = ExtensionLoader.load(ByClassNameExtension.class.getName());\n\n        assertEquals(Set.of(\"extension-loader-by-class-name\"), extensions.keySet());\n        assertInstanceOf(ByClassNameExtension.class, extensions.get(\"extension-loader-by-class-name\"));\n    }\n\n    @Test\n    void loadsExtensionByClassLiteral() {\n        Map<String, Extension> extensions = ExtensionLoader.load(ByClassLiteralExtension.class);\n\n        assertEquals(Set.of(\"extension-loader-by-class-literal\"), extensions.keySet());\n        assertInstanceOf(ByClassLiteralExtension.class, extensions.get(\"extension-loader-by-class-literal\"));\n    }\n\n    public static class ByClassNameExtension implements Extension {\n        @Override\n        public String getName() {\n            return \"extension-loader-by-class-name\";\n        }\n    }\n\n    public static class ByClassLiteralExtension implements Extension {\n        @Override\n        public String getName() {\n            return \"extension-loader-by-class-literal\";\n        }\n    }\n}\n=== tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/ExtensionsTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.core.WireMockConfiguration;\nimport com.github.tomakehurst.wiremock.extension.Extension;\nimport com.github.tomakehurst.wiremock.extension.ExtensionFactory;\nimport com.github.tomakehurst.wiremock.extension.Extensions;\nimport com.github.tomakehurst.wiremock.extension.WireMockServices;\nimport java.util.List;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ExtensionsTest {\n    @Test\n    void loadsDeclaredExtensionsAndFactoryClasses() {\n        WireMockConfiguration options = WireMockConfiguration.options()\n                .templatingEnabled(false)\n                .extensions(NamedExtensionLoadedByClassName.class.getName())\n                .extensions(NamedExtensionLoadedByClass.class)\n                .extensionFactories(DeclaredExtensionFactory.class);\n        Extensions extensions = new Extensions(\n                options.getDeclaredExtensions(),\n                null,\n                options,\n                options.getStores(),\n                options.filesRoot());\n\n        extensions.load();\n\n        assertThat(extensions.getAllExtensionNames())\n                .contains(\n                        \"named-extension-loaded-by-class-name\",\n                        \"named-extension-loaded-by-class\",\n                        \"extension-created-by-declared-factory\");\n    }\n\n    public static class NamedExtensionLoadedByClassName implements Extension {\n        @Override\n        public String getName() {\n            return \"named-extension-loaded-by-class-name\";\n        }\n    }\n\n    public static class NamedExtensionLoadedByClass implements Extension {\n        @Override\n        public String getName() {\n            return \"named-extension-loaded-by-class\";\n        }\n    }\n\n    public static class DeclaredExtensionFactory implements ExtensionFactory {\n        @Override\n        public List<Extension> create(WireMockServices services) {\n            return List.of(new ExtensionCreatedByDeclaredFactory());\n        }\n    }\n\n    public static class ExtensionCreatedByDeclaredFactory implements Extension {\n        @Override\n        public String getName() {\n            return \"extension-created-by-declared-factory\";\n        }\n    }\n}\n=== tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/FileUploadInnerFileItemIteratorImplInnerFileItemStreamImplTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.http.ImmutableRequest;\nimport com.github.tomakehurst.wiremock.http.Request;\nimport com.github.tomakehurst.wiremock.http.RequestMethod;\nimport com.github.tomakehurst.wiremock.http.multipart.PartParser;\nimport java.nio.charset.StandardCharsets;\nimport java.util.Collection;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class FileUploadInnerFileItemIteratorImplInnerFileItemStreamImplTest {\n    @Test\n    void parsesMultipartFormDataPartContent() {\n        String boundary = \"wiremock-boundary\";\n        String multipartBody = \"--\" + boundary + \"\\r\\n\"\n                + \"Content-Disposition: form-data; name=\\\"message\\\"\\r\\n\"\n                + \"Content-Type: text/plain; charset=UTF-8\\r\\n\"\n                + \"\\r\\n\"\n                + \"hello from multipart\\r\\n\"\n                + \"--\" + boundary + \"--\\r\\n\";\n        Request request = ImmutableRequest.create()\n                .withAbsoluteUrl(\"http://localhost/upload\")\n                .withMethod(RequestMethod.POST)\n                .withProtocol(\"HTTP/1.1\")\n                .withClientIp(\"127.0.0.1\")\n                .withHeader(\"Content-Type\", \"multipart/form-data; boundary=\" + boundary)\n                .withBody(multipartBody.getBytes(StandardCharsets.UTF_8))\n                .withMultipart(true)\n                .build();\n\n        Collection<Request.Part> parts = PartParser.parseFrom(request);\n\n        assertThat(parts).hasSize(1);\n        Request.Part part = parts.iterator().next();\n        assertThat(part.getName()).isEqualTo(\"message\");\n        assertThat(part.getFileName()).isNull();\n        assertThat(part.getHeader(\"Content-Type\").firstValue())\n                .isEqualTo(\"text/plain; charset=UTF-8\");\n        assertThat(part.getBody().asString()).isEqualTo(\"hello from multipart\");\n    }\n}\n=== tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/Jetty11HttpUtilsTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.WireMockServer;\nimport com.github.tomakehurst.wiremock.http.Fault;\nimport java.io.IOException;\nimport java.net.URL;\nimport java.security.SecureRandom;\nimport java.security.cert.X509Certificate;\nimport javax.net.ssl.HttpsURLConnection;\nimport javax.net.ssl.SSLContext;\nimport javax.net.ssl.TrustManager;\nimport javax.net.ssl.X509TrustManager;\nimport org.junit.jupiter.api.Test;\n\nimport static com.github.tomakehurst.wiremock.client.WireMock.aResponse;\nimport static com.github.tomakehurst.wiremock.client.WireMock.get;\nimport static com.github.tomakehurst.wiremock.client.WireMock.urlEqualTo;\nimport static com.github.tomakehurst.wiremock.core.WireMockConfiguration.wireMockConfig;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class Jetty11HttpUtilsTest {\n    private static final int TIMEOUT_MILLIS = 5_000;\n\n    @Test\n    void unwrapsTlsSocketWhenApplyingHttpsFault() throws Exception {\n        WireMockServer server = new WireMockServer(wireMockConfig()\n                .httpDisabled(true)\n                .dynamicHttpsPort()\n                .http2TlsDisabled(true));\n        server.start();\n        try {\n            server.stubFor(get(urlEqualTo(\"/tls-fault\"))\n                    .willReturn(aResponse().withFault(Fault.EMPTY_RESPONSE)));\n\n            HttpsURLConnection connection = openTrustedHttpsConnection(\n                    new URL(\"https://localhost:\" + server.httpsPort() + \"/tls-fault\"));\n            try {\n                assertThatThrownBy(connection::getResponseCode)\n                        .isInstanceOf(IOException.class);\n            } finally {\n                connection.disconnect();\n            }\n        } finally {\n            server.stop();\n        }\n    }\n\n    private static HttpsURLConnection openTrustedHttpsConnection(URL url) throws Exception {\n        SSLContext sslContext = SSLContext.getInstance(\"TLS\");\n        sslContext.init(null, new TrustManager[] {trustAllCertificates()}, new SecureRandom());\n\n        HttpsURLConnection connection = (HttpsURLConnection) url.openConnection();\n        connection.setSSLSocketFactory(sslContext.getSocketFactory());\n        connection.setHostnameVerifier((hostname, session) -> true);\n        connection.setConnectTimeout(TIMEOUT_MILLIS);\n        connection.setReadTimeout(TIMEOUT_MILLIS);\n        connection.setRequestMethod(\"GET\");\n        return connection;\n    }\n\n    private static X509TrustManager trustAllCertificates() {\n        return new X509TrustManager() {\n            @Override\n            public void checkClientTrusted(X509Certificate[] chain, String authType) {\n            }\n\n            @Override\n            public void checkServerTrusted(X509Certificate[] chain, String authType) {\n            }\n\n            @Override\n            public X509Certificate[] getAcceptedIssuers() {\n                return new X509Certificate[0];\n            }\n        };\n    }\n}\n=== tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/JettyHttpUtilsTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.jetty.JettyHttpUtils;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class JettyHttpUtilsTest {\n    @Test\n    void detectsJettyServerClassesOnClasspath() {\n        assertThat(JettyHttpUtils.isJetty()).isTrue();\n    }\n}\n=== tests/src/org.wiremock/wiremock/3.13.1/src/test/java/org_wiremock/wiremock/KeyStoreSourceFactoryTest.java ===\n/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_wiremock.wiremock;\n\nimport com.github.tomakehurst.wiremock.common.ssl.KeyStoreSource;\nimport com.github.tomakehurst.wiremock.common.ssl.KeyStoreSourceFactory;\nimport com.github.tomakehurst.wiremock.common.ssl.ReadOnlyFileOrClasspathKeyStoreSource;\nimport com.github.tomakehurst.wiremock.jetty11.WritableFileOrClasspathKeyStoreSource;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class KeyStoreSourceFactoryTest {\n    @Test\n    void createsWritableKeyStoreSourceWhenJettyImplementationIsAvailable() {\n        String path = \"target/generated-test-keystores/wiremock-test-keystore.jks\";\n        String keyStoreType = \"JKS\";\n        char[] password = \"changeit\".toCharArray();\n\n        KeyStoreSource keyStoreSource =\n                KeyStoreSourceFactory.getAppropriateForJreVersion(path, keyStoreType, password);\n\n        assertThat(keyStoreSource).isInstanceOf(WritableFileOrClasspathKeyStoreSource.class);\n        ReadOnlyFileOrClasspathKeyStoreSource fileSource = (ReadOnlyFileOrClasspathKeyStoreSource) keyStoreSource;\n        assertThat(fileSource.getPath()).isEqualTo(path);\n        assertThat(fileSource.getKeyStoreType()).isEqualTo(keyStoreType);\n        assertThat(fileSource.getKeyStorePassword()).isEqualTo(\"changeit\");\n    }\n}\n=== tests/src/org.wiremock/wiremock/3.13.1/