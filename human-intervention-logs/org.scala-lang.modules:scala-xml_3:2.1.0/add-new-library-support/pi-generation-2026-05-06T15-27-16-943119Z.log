That((document.docElem \\ \"from\").text).isEqualTo(\"Bob\")\n      assertThat((document.docElem \\ \"body\").text).isEqualTo(\"Hello\")\n      assertThat(document.docElem.attribute(\"priority\").map(_.text)).isEqualTo(Some(\"high\"))\n      assertThat(dtdElementNames.asJava).containsExactlyInAnyOrder(\"note\", \"to\", \"from\", \"body\")\n      assertThat(noteAttributes.map(_.name).asJava).containsExactly(\"priority\")\n      assertThat(noteAttributes.head.tpe).isEqualTo(\"CDATA\")\n      assertThat(document.allDeclarationsProcessed).isTrue\n    } finally {\n      source.close()\n    }\n  }\n\n  @Test\n  def transformsTreesWithRewriteRules(): Unit = {\n"}]}
