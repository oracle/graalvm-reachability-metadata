arguments": {"path": "tests/src/org.scala-lang.modules/scala-xml_3/2.1.0/src/test/scala/org_scala_lang_modules/scala_xml_3/Scala_xml_3Test.scala", "edits": [{"oldText": "import scala.xml.Comment\nimport scala.xml.Elem\nimport scala.xml.MinimizeMode\n", "newText": "import scala.xml.Comment\nimport scala.xml.Document\nimport scala.xml.Elem\nimport scala.xml.MinimizeMode\n"}, {"oldText": "import scala.xml.dtd.PublicID\nimport scala.xml.dtd.SystemID\nimport scala.xml.parsing.XhtmlParser\n", "newText": "import scala.xml.dtd.PublicID\nimport scala.xml.dtd.SystemID\nimport scala.xml.parsing.ConstructingParser\nimport scala.xml.parsing.XhtmlParser\n"}, {"oldText": "  @Test\n  def transformsTreesWithRewriteRules(): Unit = {\n", "newText": "  @Test\n  def constructsDocumentsWithXmlDeclarationsAndInternalDtds(): Unit = {\n    val source: Source = Source.fromString(\n      \"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n        |<!DOCTYPE note [\n        |  <!ELEMENT note (to,from,body)>\n        |  <!ELEMENT to (#PCDATA)>\n        |  <!ELEMENT from (#PCDATA)>\n        |  <!ELEMENT body (#PCDATA)>\n        |  <!ATTLIST note priority CDATA \"normal\">\n        |]>\n        |<note priority=\"high\"><to>Alice</to><from>Bob</from><body>Hello</body></note>\"\"\".stripMargin\n    )\n\n    try {\n      val document: Document = ConstructingParser.fromSource(source, preserveWS = false).document()\n      val dtdElementNames: Set[String] = document.dtd.elem.keySet.toSet\n      val noteAttributes = document.dtd.attr(\"note\").attrs\n\n      assertThat(document.version).isEqualTo(Some(\"1.0\"))\n      assertThat(document.encoding).isEqualTo(Some(\"UTF-8\"))\n      assertThat(document.standAlone).isEqualTo(Some(true))\n      assertThat(document.docElem.label).isEqualTo(\"note\")\n      assertThat((document.docElem \\ \"to\").text).isEqualTo(\"Alice\")\n      assertThat((document.docElem \\ \"from\").text).isEqualTo(\"Bob\")\n      assertThat((document.docElem \\ \"body\").text).isEqualTo(\"Hello\")\n      assertThat(document.docElem.attribute(\"priority\").map(_.text)).isEqualTo(Some(\"high\"))\n      assertThat(dtdElementNames.asJava).containsExactlyInAnyOrder(\"note\", \"to\", \"from\", \"body\")\n      assertThat(noteAttributes.map(_.name).asJava).containsExactly(\"priority\")\n      assertThat(noteAttributes.head.tpe).isEqualTo(\"CDATA\")\n      assertThat(document.allDeclarationsProcessed).isTrue\n    } finally {\n      source.close()\n    }\n  }\n\n  @Test\n  def transformsTreesWithRewriteRules(): Unit = {\n"}]}}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 578, "output": 1538, "cacheRead": 34304, "cacheWrite": 0, "totalTokens": 36420, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778081161765, "responseId": "resp_0e9b15da044e72550169fb5d8aa4bc81a19373675ffb1d4d5c"}}
