ies;\\n    27\\timport java.util.UUID;\\n    28\\t\\n    29\\timport org.awaitility.Awaitility;\\n    30\\timport org.junit.jupiter.api.AfterAll;\\n    31\\timport org.junit.jupiter.api.BeforeAll;\\n    32\\timport org.junit.jupiter.api.Test;\\n    33\\t\\n    34\\timport static org.assertj.core.api.Assertions.assertThat;\\n    35\\t\\n    36\\t/**\\n    37\\t * This test uses docker to start a postgresql database to test against.\\n    38\\t */\\n    39\\tpublic class PostgresqlTests {\\n    40\\t\\n    41\\t    private static final String USERNAME = \\\"fred\\\";\\n    42\\t\\n    43\\t    private static final String PASSWORD = \\\"secret\\\";\\n    44\\t\\n    45\\t    private static final String DATABASE = \\\"test\\\";\\n    46\\t\\n    47\\t    private static final String JDBC_URL = \\\"jdbc:postgresql://localhost/\\\" + DATABASE;\\n    48\\t\\n    49\\t    private static Process process;\\n    50\\t\\n    51\\t    private static Connection openConnection() throws SQLException {\\n    52\\t        Properties props = new Properties();\\n    53\\t        props.setProperty(\\\"user\\\", USERNAME);\\n    54\\t        props.setProperty(\\\"password\\\", PASSWORD);\\n    55\\t        return DriverManager.getConnection(JDBC_URL, props);\\n    56\\t    }\\n    57\\t\\n    58\\t    @BeforeAll\\n    59\\t    static void beforeAll() throws IOException {\\n    60\\t        System.out.println(\\\"Starting PostgreSQL ...\\\");\\n    61\\t        process = new ProcessBuilder(\\n    62\\t                \\\"docker\\\", \\\"run\\\", \\\"--rm\\\", \\\"-p\\\", \\\"5432:5432\\\", \\\"-e\\\", \\\"POSTGRES_DB=\\\" + DATABASE, \\\"-e\\\", \\\"POSTGRES_USER=\\\" + USERNAME,\\n    63\\t                \\\"-e\\\", \\\"POSTGRES_PASSWORD=\\\" + PASSWORD, \\\"postgres:18-alpine\\\").redirectOutput(new File(\\\"postgres-stdout.txt\\\"))\\n    64\\t                .redirectError(new File(\\\"postgres-stderr.txt\\\")).start();\\n    65\\t\\n    66\\t        // Wait until connection can be es