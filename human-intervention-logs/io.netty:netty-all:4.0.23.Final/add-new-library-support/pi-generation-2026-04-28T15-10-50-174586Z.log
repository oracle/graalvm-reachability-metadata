                  f = toDirectory(System.getenv("TEMP"));
                  if (f != null) {
                      logger.debug("-Dio.netty.tmpdir: " + f + " (%TEMP%)");
                      return f;
                  }
  
                  String userprofile = System.getenv("USERPROFILE");
                  if (userprofile != null) {
                      f = toDirectory(userprofile + "\\AppData\\Local\\Temp");
                      if (f != null) {
