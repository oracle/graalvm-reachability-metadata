[recv] {"type": "message_start", "message": {"role": "toolResult", "toolCallId": "call_ZX0TI46pqva39AmgV7CdzWKI|fc_002b0d3570c69a040169f0ce515b58819c8819924336145ba2", "toolName": "bash", "content": [{"type": "text", "text": "99f383431d (HEAD -> ai/add-lib-support-io.netty-netty-all-4.0.23.Final) Add Netty native library loader coverage\nba0a96e9ea Add Netty ForkJoinPool common pool coverage\n55d303208f Open Unsafe package for Netty platform discovery\n     1\t/*\n     2\t * Copyright and related rights waived via CC0\n     3\t *\n     4\t * You should have received a copy of the CC0 legalcode along with this\n     5\t * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n     6\t */\n     7\tpackage io_netty.netty_all;\n     8\t\n     9\timport io.netty.util.internal.NativeLibraryLoader;\n    10\timport org.junit.jupiter.api.AfterAll;\n    11\timport org.junit.jupiter.api.Assertions;\n    12\timport org.junit.jupiter.api.Test;\n    13\t\n    14\timport java.net.URL;\n    15\timport java.util.ArrayList;\n    16\timport java.util.List;\n    17\t\n    18\tpublic class NativeLibraryLoaderTest {\n    19\t    private static final String LIBRARY_NAME = \"netty_resource_probe\";\n    20\t    private static final String ORIGINAL_OS_NAME = System.getProperty(\"os.name\");\n    21\t\n    22\t    static {\n    23\t        System.setProperty(\"os.name\", \"Mac OS X\");\n    24\t    }\n    25\t\n    26\t    @AfterAll\n    27\t    static void restoreOsName() {\n    28\t        if (ORIGINAL_OS_NAME == null) {\n    29\t            System.clearProperty(\"os.name\");\n    30\t        } else {\n    31\t            System.setProperty(\"os.name\", ORIGINAL_OS_NAME);\n    32\t        }\n    33\t    }\n    34\t\n    35\t    @Test\n    36\t    void loadSearchesForPackagedNativeLibraryResourcesBeforeFallingBackToSystemLoader() {\n    37\t        RecordingClassLoader loader = new RecordingClassLoader();\n    38\t\n    39\t        Assertions.assertThrows(\n    40\t                UnsatisfiedLinkError.class,\n    41\t                () -> NativeLibraryLoader.load(LIBRARY_NAME, loader));\n    42\t\n    43\t        String mappedLibraryResource = \"META-INF/native/\" + System.mapLibraryName(LIBRARY_NAME);\n    44\t        String macFallbackResource = macFallbackResource(mappedLibraryResource);\n    45\t\n    46\t        Assertions.assertTrue(loader.resourceNames().contains(mappedLibraryResource));\n    47\t        Assertions.assertTrue(loader.resourceNames().contains(macFallbackResource));\n    48\t    }\n    49\t\n    50\t    private static String macFallbackResource(String mappedLibraryResource) {\n    51\t        if (mappedLibraryResource.endsWith(\".jnilib\")) {\n    52\t            return \"META-INF/native/lib\" + LIBRARY_NAME + \".dynlib\";\n    53\t        }\n    54\t        return \"META-INF/native/lib\" + LIBRARY_NAME + \".jnilib\";\n    55\t    }\n    56\t\n    57\t    private static final class RecordingClassLoader extends ClassLoader {\n    58\t        private final List<String> resourceNames = new ArrayList<String>();\n    59\t\n    60\t        private RecordingClassLoader() {\n    61\t            super(NativeLibraryLoaderTest.class.getClassLoader());\n    62\t        }\n    63\t\n    64\t        @Override\n    65\t        public URL getResource(String name) {\n    66\t            resourceNames.add(name);\n    67\t            return null;\n    68\t        }\n    69\t\n    70\t        private List<String> resourceNames() {\n    71\t            return resourceNames;\n    72\t        }\n    73\t    }\n    74\t}\n"}], "isError": false, "timestamp": 1777389137855}}
