t\n\t\ttry {\n\t\t\tbsh.eval( reader, bsh.getNameSpace(), resName );\n\t\t} catch ( TargetError e ) {\n\t\t\tSystem.out.println(\"Script threw exception: \"+e);\n\t\t\tif ( e.inNativeCode() )\n\t\t\t\te.printStackTrace( System.err );\n\t\t} catch ( EvalError e ) {\n\t\t\tSystem.out.println(\"Evaluation Error: \"+e);\n\t\t}\n\t}\n}\n"}], "isError": false, "timestamp": 1777360420119}}
