[tool-call] delta {"path":"tests/src/org.apache-extras.beanshell/bsh/2.0b6/src/test/java/org_apache_extras_beanshell/bsh/BSHArrayInitializerTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage org_apache_extras_beanshell.bsh;\n\nimport bsh.Interpreter;\nimport org.junit.jupiter.api.Test;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class BSHArrayInitializerTest {\n\n    @Test\n    public void primitiveArrayInitializerCreatesArrayWithConvertedValues() throws Exception {\n        Interpreter interpreter = new Interpreter();\n\n        Object result = interpreter.eval(\"\"\"\n                values = new int[] { 1, 2, 'A' };\n                return values;\n                \"\"\");\n\n        int[] values = (int[]) result;\n        assertThat(values).containsExactly(1, 2, 65);\n    }\n\n    @Test\n    public void nestedObjectArrayInitializerCreatesMultiDimensionalArray() throws Exception {\n        Interpreter interpreter = new Interpreter();\n\n        Object result = interpreter.eval(\"\"\"\n                values = new String[][] {\n                    { \"alpha\", \"beta\" },\n                    { \"gamma\", \"delta\" }\n                };\n                return values;\n                \"\"\");\n\n        String[][] values = (String[][]) result;\n        assertThat(values)\n                .hasDimensions(2, 2)\n                .containsExactly(new String[] {\"alpha\", \"beta\"}, new String[] {\"gamma\", \"delta\"});\n    }\n}\n"}
