d, server.uriWithUserInfo());\n            }\n\n            assertThat(authorization.get()).isEqualTo(EXPECTED_AUTHORIZATION);\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause();\n            if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            throw exception;\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static URL wrapperCodeSourceUrl() {\n        CodeSource codeSource = Download.class.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static final class Base64HidingWrapperClassLoader extends URLClassLoader {\n        private Base64HidingWrapperClassLoader(URL wrapperLocation) {\n            super(new URL[] { wrapperLocation }, OrgGradleWrapperDownloadTest.class.getClassLoader());\n        }\n\n        @Override\n        public Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (name.equals(\"java.util.Base64\") || name.equals(\"java.util.Base64$Encoder\")) {\n                throw new ClassNotFoundException(name);\n            }\n            if (name.startsWith(\"org.gradle.wrapper.\")) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n\n    private static final class LocalHeadServer implements AutoCloseable {\n        private final HttpServer server;\n        private final ExecutorService executor;\n\n        private LocalHeadServer(HttpServer server, ExecutorService executor) {\n            this.server = server;\n            this.executor = executor;\n        }\n\n        private static LocalHeadServer start(AtomicReference<String> authorization) throws Exception {\n            InetSocketAddress loopbackAddress = new InetSocketAddress(InetAddress.getLoopbackAddress(), 0);\n            HttpServer server = HttpServer.create(loopbackAddress, 0);\n            ExecutorService executor = Executors.newSingleThreadExecutor();\n            server.setExecutor(executor);\n            server.createContext(\"/distribution.zip\", exchange -> {\n                try (exchange) {\n                    authorization.set(exchange.getRequestHeaders().getFirst(AUTHORIZATION_HEADER));\n                    assertThat(exchange.getRequestMethod()).isEqualTo(\"HEAD\");\n                    exchange.sendResponseHeaders(200, -1);\n                }\n            });\n            server.start();\n            return new LocalHeadServer(server, executor);\n        }\n\n        private URI uriWithUserInfo() {\n            InetSocketAddress address = server.getAddress();\n            return URI.create(\"http://user:pass@\" + address.getHostString() + \":\" + address.getPort()\n                    + \"/distribution.zip\");\n        }\n\n        @Override\n        public void close() throws Exception {\n            server.stop(0);\n            executor.shutdownNow();\n            assertThat(executor.awaitTermination(SERVER_SHUTDOWN_TIMEOUT.toMillis(), TimeUnit.MILLISECONDS)).isTrue();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2982, "output": 1535, "cacheRead": 34816, "cacheWrite": 0, "totalTokens": 39333, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse"