  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.net.InetAddress;
  import java.net.InetSocketAddress;
  import java.net.URI;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.security.CodeSource;
  import java.time.Duration;
  import java.util.concurrent.ExecutorService;
  import java.util.concurrent.Executors;
  import java.util.concurrent.TimeUnit;
  import java.util.concurrent.atomic.AtomicReference;
  
  import com.sun.net.httpserver.HttpServer;
  
  import org.gradle.wrapper.Download;
  import org.gradle.wrapper.Logger;
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleWrapperDownloadTest {
      private static final String AUTHORIZATION_HEADER = "Authorization";
      private static final String EXPECTED_AUTHORIZATION = "Basic dXNlcjpwYXNz";
      private static final Duration SERVER_SHUTDOWN_TIMEOUT = Duration.ofSeconds(5);
  
      @Test
      void sendHeadRequestAddsBasicAuthenticationUsingJdkBase64() throws Exception {
          AtomicReference<String> authorization = new AtomicReference<>();
          try (LocalHeadServer server = LocalHeadServer.start(authorization)) {
              Download download = new Download(new Logger(true), "gradle-wrapper", "test", 2_000);
  
              download.sendHeadRequest(server.uriWithUserInfo());
          }
  
          assertThat(authorization.get()).isEqualTo(EXPECTED_AUTHORIZATION);
      }
  
      @Test
      void sendHeadRequestFallsBackToDatatypeConverterWhenJdkBase64IsUnavailable() throws Exception {
          try {
              AtomicReference<String> authorization = new AtomicReference<>();
              try (LocalHeadServer server = LocalHeadServer.start(authorization);
                      URLClassLoader classLoader = new Base64HidingWrapperClassLoader(wrapperCodeSourceUrl())) {
                  Class<?> loggerClass = classLoader.loadClass("org.gradle.wrapper.Logger");
                  Object logger = loggerClass.getConstructor(boolean.class).newInstance(true);
                  Class<?> downloadClass = classLoader.loadClass("org.gradle.wrapper.Download");
                  Constructor<?> constructor = downloadClass.getConstructor(
                          loggerClass, String.class, String.class, int.class);
                  Object download = constructor.newInstance(logger, "gradle-wrapper", "test", 2_000);
                  Method sendHeadRequest = downloadClass.getMethod("sendHeadRequest", URI.class);
  
                  sendHeadRequest.invoke(download, server.uriWithUserInfo());
              }
  
              assertThat(authorization.get()).isEqualTo(EXPECTED_AUTHORIZATION);
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getCause();
              if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return;
              }
              throw exception;
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static URL wrapperCodeSourceUrl() {
          CodeSource codeSource = Download.class.getProtectionDomain().getCodeSource();
          assertThat(codeSource).isNotNull();
          return codeSource.getLocation();
      }
  
      private static final class Base64HidingWrapperClassLoader extends URLClassLoader {
          private Base64HidingWrapperClassLoader(URL wrapperLocation) {
              super(new URL[] { wrapperLocation }, OrgGradleWrapperDownloadTest.class.getClassLoader());
          }
  
          @Override
          public Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {
              if (name.equals("java.util.Base64") || name.equals("java.util.Base64$Encoder")) {
                  throw new ClassNotFoundException(name);
              }
              if (name.startsWith("org.gradle.wrapper.")) {
                  synchronized (getClassLoadingLock(name)) {
                      Class<?> loadedClass = findLoadedClass(name);
                      if (loadedClass == null) {
                          loadedClass = findClass(name);
                      }
                      if (resolve) {
                          resolveClass(loadedClass);
                      }
                      return loadedClass;
                  }
              }
