  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.reflect.Method;
  import java.util.List;
  
  import org.gradle.internal.impldep.com.google.common.base.Throwables;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalImpldepComGoogleCommonBaseThrowablesTest {
      @Test
      void invokesAccessibleMethodThroughThrowablesHelper() throws Throwable {
          GreetingService service = new GreetingService("hello");
          Method greetMethod = GreetingService.class.getMethod("greet", String.class);
  
          Object result = invokeAccessibleNonThrowingMethod().invoke(greetMethod, service, new Object[] { "Gradle" });
  
          assertThat(result).isEqualTo("hello, Gradle");
      }
  
      @Test
      void lazyStackTraceExposesTheThrowableStackTrace() {
          RuntimeException failure = new RuntimeException("expected");
  
          List<StackTraceElement> lazyStackTrace = Throwables.lazyStackTrace(failure);
  
          assertThat(lazyStackTrace).containsExactly(failure.getStackTrace());
      }
  
      private static MethodHandle invokeAccessibleNonThrowingMethod() throws Exception {
          Class<Throwables> throwablesClass = Throwables.class;
          return MethodHandles.privateLookupIn(throwablesClass, MethodHandles.lookup())
                  .findStatic(
                          throwablesClass,
                          "invokeAccessibleNonThrowingMethod",
                          MethodType.methodType(Object.class, Method.class, Object.class, Object[].class));
      }
  
      public static class GreetingService {
          private final String greeting;
  
          public GreetingService(String greeting) {
              this.greeting = greeting;
          }
  
          public String greet(String name) {
              return greeting + ", " + name;
          }
      }
  }
