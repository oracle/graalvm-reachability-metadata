[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonUtilConcurrentFuturesGetCheckedTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.junit.jupiter.api.Assertions.assertThrows;\n\nimport java.io.IOException;\n\nimport org.gradle.internal.impldep.com.google.common.util.concurrent.Futures;\nimport org.gradle.internal.impldep.com.google.common.util.concurrent.ListenableFuture;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonUtilConcurrentFuturesGetCheckedTest {\n    @Test\n    void wrapsCheckedFutureFailureInTheRequestedExceptionType() {\n        IOException sourceFailure = new IOException(\"download failed\");\n        ListenableFuture<String> failedFuture = Futures.immediateFailedFuture(sourceFailure);\n\n        ExpectedCheckedException thrown = assertThrows(\n                ExpectedCheckedException.class,\n                () -> Futures.getChecked(failedFuture, ExpectedCheckedException.class));\n\n        assertThat(thrown)\n                .hasMessageContaining(sourceFailure.toString())\n                .hasCause(sourceFailure);\n    }\n\n    public static final class ExpectedCheckedException extends Exception {\n        public ExpectedCheckedException(String message, Throwable cause) {\n            super(message, cause);\n        }\n    }\n}\n"}
