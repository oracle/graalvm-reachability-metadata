[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleToolingInternalAdapterTypeInspectorTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.List;\n\nimport org.gradle.tooling.internal.adapter.ProtocolToModelAdapter;\nimport org.gradle.tooling.internal.adapter.ViewBuilder;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleToolingInternalAdapterTypeInspectorTest {\n    @Test\n    void inspectsReachableMethodsWhenRestrictingMixinToViewType() {\n        ProtocolToModelAdapter adapter = new ProtocolToModelAdapter();\n        ViewBuilder<GradleProjectView> builder = adapter.builder(GradleProjectView.class);\n        GradleProjectView view = builder\n                .mixInTo(GradleProjectView.class, new ProjectMixin(\"quarkus\", List.of(\"bootstrap\", \"gradle\")))\n                .build(new ProjectProtocolModel(\"3.33\"));\n\n        assertThat(view.getName()).isEqualTo(\"quarkus\");\n        assertThat(view.getVersion()).isEqualTo(\"3.33\");\n        assertThat(view.getTags()).containsExactly(\"bootstrap\", \"gradle\");\n    }\n\n    public interface GradleProjectView {\n        String getName();\n\n        String getVersion();\n\n        List<String> getTags();\n    }\n\n    public static final class ProjectProtocolModel {\n        private final String version;\n\n        public ProjectProtocolModel(String version) {\n            this.version = version;\n        }\n\n        public String getVersion() {\n            return version;\n        }\n    }\n\n    public static final class ProjectMixin {\n        private final String name;\n        private final List<String> tags;\n\n        public ProjectMixin(String name, List<String> tags) {\n            this.name = name;\n            this.tags = tags;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public List<String> getTags() {\n            return tags;\n        }\n    }\n}\n"}
