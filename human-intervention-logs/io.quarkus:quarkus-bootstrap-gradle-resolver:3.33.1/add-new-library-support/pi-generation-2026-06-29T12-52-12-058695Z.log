          byte[] bytes = Base64.getMimeDecoder().decode(SERIALIZED_COMPACT_HASH_SET);
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return input.readObject();
          }
