[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomListMultimapTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.util.ArrayList;\nimport java.util.Collection;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\n\nimport org.gradle.internal.impldep.com.google.common.base.Supplier;\nimport org.gradle.internal.impldep.com.google.common.collect.ListMultimap;\nimport org.gradle.internal.impldep.com.google.common.collect.Multimaps;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomListMultimapTest {\n    @Test\n    void serializesFactoryAndBackingMapForCustomListMultimap() throws Exception {\n        Map<String, Collection<String>> backingMap = new LinkedHashMap<>();\n        ListMultimap<String, String> original = Multimaps.newListMultimap(\n                backingMap,\n                new SerializableArrayListSupplier());\n        original.put(\"letters\", \"a\");\n        original.put(\"letters\", \"b\");\n        original.put(\"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(original);\n\n        assertThat(roundTripped.getClass().getName())\n                .isEqualTo(\"org.gradle.internal.impldep.com.google.common.collect.Multimaps$CustomListMultimap\");\n        @SuppressWarnings(\"unchecked\")\n        ListMultimap<String, String> deserialized = (ListMultimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        deserialized.put(\"letters\", \"c\");\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\", \"c\");\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class SerializableArrayListSupplier implements Supplier<List<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public List<String> get() {\n            return new ArrayList<>();\n        }\n    }\n}\n"}
