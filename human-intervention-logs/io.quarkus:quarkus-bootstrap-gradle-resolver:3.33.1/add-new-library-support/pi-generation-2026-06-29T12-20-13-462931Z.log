 org.assertj.core.api.Assertions.assertThat;\n\nimport java.sql.Driver;\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport org.gradle.internal.dispatch.Dispatch;\nimport org.gradle.internal.dispatch.MethodInvocation;\nimport org.gradle.internal.dispatch.ProxyDispatchAdapter;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalDispatchProxyDispatchAdapterTest {\n    @Test\n    void createsProxyForPrimaryInterface() {\n        List<MethodInvocation> invocations = new ArrayList<>();\n        Dispatch<MethodInvocation> dispatch = invocation -> invocations.add(invocation);\n\n        ProxyDispatchAdapter<MessageSink> adapter = new ProxyDispatchAdapter<>(dispatch, MessageSink.class);\n\n        assertThat(adapter.getType()).isEqualTo(MessageSink.class);\n        MessageSink source = adapter.getSource();\n        source.message(\"primary\");\n\n        assertThat(invocations).singleElement().satisfies(invocation -> {\n            assertThat(invocation.getMethodName()).isEqualTo(\"message\");\n            assertThat(invocation.getArguments()).containsExactly(\"primary\");\n        });\n    }\n\n    @Test\n    void createsProxyForPrimaryAndExtraInterfaces() {\n        List<MethodInvocation> invocations = new ArrayList<>();\n        Dispatch<MethodInvocation> dispatch = invocation -> invocations.add(invocation);\n\n        ProxyDispatchAdapter<MessageSink> adapter = new ProxyDispatchAdapter<>(dispatch, MessageSink.class, Driver.class);\n\n        MessageSink source = adapter.getSource();\n        assertThat(source).isInstanceOf(MessageSink.class).isInstanceOf(Driver.class);\n        source.message(\"with extra interface\");\n\n        assertThat(invocations).singleElement().satisfies(invocation -> {\n            assertThat(invocation.getMethodName()).isEqualTo(\"message\");\n            assertThat(invocation.getArguments()).containsExactly(\"with extra interface\");\n        });\n    }\n\n    public interface MessageSink {\n        void message(String value);\n    }\n}\n"}], "isError": false, "timestamp": 1782735687031}]}
