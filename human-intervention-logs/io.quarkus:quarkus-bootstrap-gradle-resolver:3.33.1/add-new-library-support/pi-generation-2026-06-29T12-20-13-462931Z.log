leElement().satisfies(invocation -> {\n            assertThat(invocation.getMethodName()).isEqualTo(\"message\");\n            assertThat(invocation.getArguments()).containsExactly(\"primary\");\n        });\n    }\n\n    @Test\n    void createsProxyForPrimaryAndExtraInterfaces() {\n        List<MethodInvocation> invocations = new ArrayList<>();\n        Dispatch<MethodInvocation> dispatch = invocation -> invocations.add(invocation);\n\n        ProxyDispatchAdapter<MessageSink> adapter = new ProxyDispatchAdapter<>(dispatch, MessageSink.class, Driver.class);\n\n        MessageSink source = adapter.getSource();\n        assertThat(source).isInstanceOf(MessageSink.class).isInstanceOf(Driver.class);\n        source.message(\"with extra interface\");\n\n        assertThat(invocations).singleElement().satisfies(invocation -> {\n            assertThat(invocation.getMethodName()).isEqualTo(\"message\");\n            assertThat(invocation.getArguments()).containsExactly(\"with extra interface\");\n        });\n    }\n\n    public interface MessageSink {\n        void message(String value);\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1974, "output": 1322, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 23776, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782735572008, "responseId": "resp_0a7137ada349f8ba016a4262d47d0c8197acede191a40f010a"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_iuQaFX4XSFapM7vym154QEUO|fc_0a7137ada349f8ba016a4262e1ba1081979a007cc28ddfa48a", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2233 bytes to tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalDispatchProxyDispatchAdapterTest.java"}], "isError": false, "timestamp": 1782735590552}]}
