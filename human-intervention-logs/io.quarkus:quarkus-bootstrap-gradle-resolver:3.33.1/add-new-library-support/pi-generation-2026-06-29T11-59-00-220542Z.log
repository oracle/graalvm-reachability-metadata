rg.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomSetMultimapTest {\n    @Test\n    void serializesFactoryAndBackingMapForCustomSetMultimap() throws Exception {\n        Map<String, Collection<String>> backingMap = new LinkedHashMap<>();\n        SetMultimap<String, String> original = Multimaps.newSetMultimap(\n                backingMap,\n                new SerializableLinkedHashSetSupplier());\n        original.put(\"letters\", \"a\");\n        original.put(\"letters\", \"b\");\n        original.put(\"letters\", \"a\");\n        original.put(\"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(original);\n\n        assertThat(roundTripped.getClass().getName())\n                .isEqualTo(\"org.gradle.internal.impldep.com.google.common.collect.Multimaps$CustomSetMultimap\");\n        @SuppressWarnings(\"unchecked\")\n        SetMultimap<String, String> deserialized = (SetMultimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.keySet()).containsExactly(\"letters\", \"numbers\");\n\n        deserialized.put(\"created-after-deserialization\", \"uses-restored-factory\");\n        deserialized.put(\"created-after-deserialization\", \"second-value\");\n        deserialized.put(\"created-after-deserialization\", \"uses-restored-factory\");\n        assertThat(deserialized.get(\"created-after-deserialization\"))\n                .containsExactly(\"uses-restored-factory\", \"second-value\");\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class SerializableLinkedHashSetSupplier implements Supplier<Set<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Set<String> get() {\n            return new LinkedHashSet<>();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2534, "output": 1072, "cacheRead": 12800, "cacheWrite": 0, "totalTokens": 16406, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782734312200, "responseId": "resp_0cc19ec3094e3eca016a425de88a0881968b105b136e42cedf"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_gUct1f6NYX1Hxjksvm8TkvfG|fc_0cc19ec3094e3eca016a425def72788196bdb9177d15aba22c", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3145 bytes to tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomSetMultimapTest.java"}], "isError": false, "timestamp": 1782734326078}]}
