[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleToolingInternalAdapterProtocolToModelAdapterInnerMethodInvocationCacheTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport org.gradle.tooling.internal.adapter.ProtocolToModelAdapter;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleToolingInternalAdapterProtocolToModelAdapterInnerMethodInvocationCacheTest {\n    @Test\n    void resolvesProtocolMethodThroughInvocationCache() {\n        ProtocolToModelAdapter adapter = new ProtocolToModelAdapter();\n        SampleView view = adapter.adapt(SampleView.class, new SampleProtocolModel(\"quarkus\", 33));\n\n        assertThat(view.getName()).isEqualTo(\"quarkus\");\n        assertThat(view.describe(\"Gradle\")).isEqualTo(\"Gradle: quarkus-33\");\n    }\n\n    public interface SampleView {\n        String getName();\n\n        String describe(String prefix);\n    }\n\n    public static final class SampleProtocolModel {\n        private final String name;\n        private final int revision;\n\n        public SampleProtocolModel(String name, int revision) {\n            this.name = name;\n            this.revision = revision;\n        }\n\n        public String getName() {\n            return name;\n        }\n\n        public String describe(String prefix) {\n            return prefix + \": \" + name + \"-\" + revision;\n        }\n    }\n}\n"}
