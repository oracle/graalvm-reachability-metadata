  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.File;
  import java.util.Map;
  
  import org.gradle.tooling.BuildAction;
  import org.gradle.tooling.internal.consumer.connection.InternalBuildActionAdapter;
  import org.gradle.tooling.internal.consumer.connection.ToolingParameterProxy;
  import org.gradle.tooling.internal.consumer.versioning.VersionDetails;
  import org.gradle.tooling.internal.protocol.BuildResult;
  import org.gradle.tooling.internal.protocol.InternalBuildControllerVersion2;
  import org.gradle.tooling.internal.protocol.ModelIdentifier;
  import org.gradle.util.GradleVersion;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleToolingInternalConsumerConnectionToolingParameterProxyTest {
      @Test
      void validatesCreatesAndUnpacksParameterizedToolingModelParameters() {
          BuildAction<Boolean> action = controller -> {
              try {
                  controller.getModel(Void.class, SampleToolingParameter.class, parameter -> {
                      parameter.setMessage("configured through proxy");
                      parameter.setEnabled(true);
                  });
                  return false;
              } catch (ParameterObservedException e) {
                  assertThat(e.properties)
                          .containsEntry("message", "configured through proxy")
                          .containsEntry("enabled", true);
                  return true;
              }
          };
  
          InternalBuildActionAdapter<Boolean> adapter = new InternalBuildActionAdapter<>(
                  action,
                  new File("."),
                  VersionDetails.from(GradleVersion.current()));
  
          assertThat(adapter.execute(new RecordingBuildController())).isTrue();
      }
  
      public interface SampleToolingParameter {
          String getMessage();
  
          void setMessage(String message);
  
          boolean isEnabled();
  
          void setEnabled(boolean enabled);
      }
  
      private static final class RecordingBuildController implements InternalBuildControllerVersion2 {
          @Override
          public BuildResult<?> getModel(Object target, ModelIdentifier modelIdentifier, Object parameter) {
              assertThat(target).isNull();
              assertThat(modelIdentifier.getName()).isEqualTo(ModelIdentifier.NULL_MODEL);
  
              Map<String, Object> properties = ToolingParameterProxy.unpackProperties(parameter);
              throw new ParameterObservedException(properties);
          }
      }
  
      private static final class ParameterObservedException extends RuntimeException {
          private final Map<String, Object> properties;
  
          private ParameterObservedException(Map<String, Object> properties) {
              this.properties = properties;
          }
      }
  }
