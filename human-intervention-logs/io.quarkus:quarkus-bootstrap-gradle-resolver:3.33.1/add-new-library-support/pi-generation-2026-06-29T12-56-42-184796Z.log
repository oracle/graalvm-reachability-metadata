[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonReflectReflectionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.InvocationHandler;\n\nimport org.gradle.internal.impldep.com.google.common.reflect.Reflection;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonReflectReflectionTest {\n    private static final String INITIALIZED_PROPERTY =\n            OrgGradleInternalImpldepComGoogleCommonReflectReflectionTest.class.getName() + \".initialized\";\n\n    @Test\n    void initializeForcesClassInitialization() {\n        System.clearProperty(INITIALIZED_PROPERTY);\n\n        Reflection.initialize(InitializationTarget.class);\n\n        assertThat(System.getProperty(INITIALIZED_PROPERTY)).isEqualTo(\"true\");\n    }\n\n    @Test\n    void newProxyCreatesProxyForInterface() {\n        InvocationHandler handler = (proxy, method, arguments) -> {\n            if (method.getDeclaringClass() == Object.class) {\n                return method.invoke(this, arguments);\n            }\n            return \"hello, \" + arguments[0];\n        };\n\n        GreetingService proxy = Reflection.newProxy(GreetingService.class, handler);\n\n        assertThat(proxy).isInstanceOf(GreetingService.class);\n        assertThat(proxy.greet(\"Gradle\")).isEqualTo(\"hello, Gradle\");\n    }\n\n    public interface GreetingService {\n        String greet(String name);\n    }\n\n    public static class InitializationTarget {\n        static {\n            System.setProperty(INITIALIZED_PROPERTY, \"true\");\n        }\n    }\n}\n"}
