  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.sql.Driver;
  import java.util.ArrayList;
  import java.util.List;
  
  import org.gradle.internal.dispatch.Dispatch;
  import org.gradle.internal.dispatch.MethodInvocation;
  import org.gradle.internal.dispatch.ProxyDispatchAdapter;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalDispatchProxyDispatchAdapterTest {
      @Test
      void createsProxyForPrimaryInterface() {
          List<MethodInvocation> invocations = new ArrayList<>();
          Dispatch<MethodInvocation> dispatch = invocation -> invocations.add(invocation);
  
          ProxyDispatchAdapter<MessageSink> adapter = new ProxyDispatchAdapter<>(dispatch, MessageSink.class);
  
          assertThat(adapter.getType()).isEqualTo(MessageSink.class);
          MessageSink source = adapter.getSource();
          source.message("primary");
  
          assertThat(invocations).singleElement().satisfies(invocation -> {
              assertThat(invocation.getMethodName()).isEqualTo("message");
              assertThat(invocation.getArguments()).containsExactly("primary");
          });
      }
  
      @Test
      void createsProxyForPrimaryAndExtraInterfacesUsingExtraTypeClassLoader() {
          List<MethodInvocation> invocations = new ArrayList<>();
          Dispatch<MethodInvocation> dispatch = invocation -> invocations.add(invocation);
  
          ProxyDispatchAdapter<Driver> adapter = new ProxyDispatchAdapter<>(dispatch, Driver.class, MessageSink.class);
  
          Driver source = adapter.getSource();
          assertThat(source).isInstanceOf(Driver.class).isInstanceOf(MessageSink.class);
          ((MessageSink) source).message("with extra interface");
  
          assertThat(invocations).singleElement().satisfies(invocation -> {
              assertThat(invocation.getMethodName()).isEqualTo("message");
              assertThat(invocation.getArguments()).containsExactly("with extra interface");
          });
      }
  
      public interface MessageSink {
          void message(String value);
      }
  }
