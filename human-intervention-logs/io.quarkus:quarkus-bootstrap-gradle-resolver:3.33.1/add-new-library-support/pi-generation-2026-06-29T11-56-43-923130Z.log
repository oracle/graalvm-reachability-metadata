ier;\nimport org.gradle.internal.impldep.com.google.common.collect.Multimap;\nimport org.gradle.internal.impldep.com.google.common.collect.Multimaps;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomMultimapTest {\n    @Test\n    void serializesFactoryAndBackingMapForCustomMultimap() throws Exception {\n        Map<String, Collection<String>> backingMap = new LinkedHashMap<>();\n        Multimap<String, String> original = Multimaps.newMultimap(\n                backingMap,\n                new SerializableArrayDequeSupplier());\n        original.put(\"letters\", \"a\");\n        original.put(\"letters\", \"b\");\n        original.put(\"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(original);\n\n        assertThat(roundTripped.getClass().getName())\n                .isEqualTo(\"org.gradle.internal.impldep.com.google.common.collect.Multimaps$CustomMultimap\");\n        @SuppressWarnings(\"unchecked\")\n        Multimap<String, String> deserialized = (Multimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.keySet()).containsExactly(\"letters\", \"numbers\");\n\n        deserialized.put(\"created-after-deserialization\", \"uses-restored-factory\");\n        deserialized.put(\"created-after-deserialization\", \"second-value\");\n        assertThat(deserialized.get(\"created-after-deserialization\"))\n                .containsExactly(\"uses-restored-factory\", \"second-value\");\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class SerializableArrayDequeSupplier implements Supplier<Collection<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Collection<String> get() {\n            return new ArrayDeque<>();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 878, "output": 898, "cacheRead": 25088, "cacheWrite": 0, "totalTokens": 26864, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782734176569, "responseId": "resp_03b2caf9294757a6016a425d613b2481939392d99f60d57f85"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_shyjFRhgMemGG7a0iuAWxwMe|fc_03b2caf9294757a6016a425d6539e881938997357840ca77ac", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2979 bytes to tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomMultimapTest.java"}], "isError": false, "timestamp": 1782734186404}]}
