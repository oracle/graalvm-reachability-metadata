              serializationMethod("populateMap", MethodType.methodType(void.class, Map.class, ObjectInputStream.class))
                      .invoke(deserialized, input);
          }
  
          assertThat(deserialized).containsExactlyEntriesOf(source);
      }
  
      @Test
      void populatesMutableListMultimapFromSerializedEntries() throws Throwable {
          Map<String, Collection<String>> backingMap = new LinkedHashMap<>();
          Supplier<List<String>> valueSupplier = ArrayList::new;
          Multimap<String, String> multimap = Multimaps.newListMultimap(backingMap, valueSupplier);
  
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeInt(2);
              output.writeObject("letters");
              output.writeInt(2);
              output.writeObject("a");
              output.writeObject("b");
              output.writeObject("numbers");
              output.writeInt(1);
              output.writeObject("one");
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              serializationMethod(
                      "populateMultimap",
                      MethodType.methodType(void.class, Multimap.class, ObjectInputStream.class)).invoke(multimap, input);
          }
  
          assertThat(multimap.get("letters")).containsExactly("a", "b");
          assertThat(multimap.get("numbers")).containsExactly("one");
          assertThat(multimap.size()).isEqualTo(3);
      }
  
      @Test
      void serializesAndDeserializesMultisetWithDistinctElementCounts() throws Exception {
