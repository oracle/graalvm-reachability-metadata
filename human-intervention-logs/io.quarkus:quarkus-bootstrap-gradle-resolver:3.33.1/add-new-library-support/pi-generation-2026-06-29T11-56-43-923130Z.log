  public class OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest {
      private static final String SERIALIZATION_CLASS_NAME =
              "org.gradle.internal.impldep.com.google.common.collect.Serialization";
  
      @Test
      void writesAndPopulatesMapEntries() throws Throwable {
          Map<String, String> source = new LinkedHashMap<>();
          source.put("first", "one");
          source.put("second", "two");
  
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              serializationMethod("writeMap", MethodType.methodType(void.class, Map.class, ObjectOutputStream.class))
