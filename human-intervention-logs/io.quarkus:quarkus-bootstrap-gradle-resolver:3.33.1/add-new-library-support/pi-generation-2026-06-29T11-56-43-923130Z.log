n            output.writeObject(\"one\");\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            serializationMethod(\n                    \"populateMultimap\",\n                    MethodType.methodType(void.class, Multimap.class, ObjectInputStream.class)).invoke(multimap, input);\n        }\n\n        assertThat(multimap.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(multimap.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(multimap.size()).isEqualTo(3);\n    }\n\n    @Test\n    void serializesAndDeserializesMultisetWithDistinctElementCounts() throws Exception {\n        HashMultiset<String> multiset = HashMultiset.create();\n        multiset.add(\"red\", 3);\n        multiset.add(\"blue\", 2);\n\n        Object roundTripped = roundTrip(multiset);\n\n        assertThat(roundTripped).isInstanceOf(HashMultiset.class);\n        HashMultiset<?> deserialized = (HashMultiset<?>) roundTripped;\n        assertThat(deserialized.count(\"red\")).isEqualTo(3);\n        assertThat(deserialized.count(\"blue\")).isEqualTo(2);\n        assertThat(deserialized.entrySet()).hasSize(2);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableListMultimapEntries() throws Exception {\n        ImmutableListMultimap<String, String> multimap = ImmutableListMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableListMultimap.class);\n        @SuppressWarnings(\"unchecked\")\n        ImmutableListMultimap<String, String> deserialized = (ImmutableListMultimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableSetMultimapEntries() throws Exception {\n        ImmutableSetMultimap<String, String> multimap = ImmutableSetMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableSetMultimap.class);\n        @SuppressWarnings(\"unchecked\")\n        ImmutableSetMultimap<String, String> deserialized = (ImmutableSetMultimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactlyInAnyOrder(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    private static MethodHandle serializationMethod(String methodName, MethodType methodType) throws Exception {\n        Class<?> serializationClass = Class.forName(SERIALIZATION_CLASS_NAME);\n        return MethodHandles.privateLookupIn(serializationClass, MethodHandles.lookup())\n                .findStatic(serializationClass, methodName, methodType);\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782734155993}, {"role": "toolResult", "toolCallId": "call_HP1oroa6LbTvBQ84UWW1Af2X|fc_03b2caf9294757a6016a425d4bc3b88193bf2a0a2bbe4f203c", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.util.ArrayList;\nimport java.util.Collection;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\n\nimport org.gradle.internal.impldep.com.google.common.base.Supplier;\nimport org.gradle.internal.impldep.com.google.common.collect.ListMultimap;\nimport org.gradle.internal.impldep.com.google.common.collect.Multimaps;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomListMultimapTest {\n    @Test\n    void serializesFactoryAndBackingMapForCustomListMultimap() throws Exception {\n        Map<String, Collection<String>> backingMap = new LinkedHashMap<>();\n        ListMultimap<String, String> original = Multimaps.newListMultimap(\n                backingMap,\n                new SerializableArrayListSupplier());\n        original.put(\"letters\", \"a\");\n        original.put(\"letters\", \"b\");\n        original.put(\"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(original);\n\n        assertThat(roundTripped.getClass().getName())\n                .isEqualTo(\"org.gradle.internal.impldep.com.google.common.collect.Multimaps$CustomListMultimap\");\n        @SuppressWarnings(\"unchecked\")\n        ListMultimap<String, String> deserialized = (ListMultimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        deserialized.put(\"letters\", \"c\");\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\", \"c\");\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n\n    private static final class SerializableArrayListSupplier implements Supplier<List<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public List<String> get() {\n            return new ArrayList<>();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782734155993}, {"role": "toolResult", "toolCallId": "call_32emcCw7VO9474fYb7Q4eDUw|fc_03b2caf9294757a6016a425d4bc3c0819381b7c040770a8a23", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage com_google_guava.guava;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.google.common.base.Supplier;\nimport com.google.common.collect.Multimap;\nimport com.google.common.collect.Multimaps;\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.IOException;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.io.Serializable;\nimport java.util.ArrayDeque;\nimport java.util.Collection;\nimport java.util.LinkedHashMap;\nimport java.util.Map;\nimport org.junit.jupiter.api.Test;\n\npublic class MultimapsInnerCustomMultimapTest {\n    @Test\n    void serializesCustomMultimapFactoryAndBackingMap() throws Exception {\n        Map<String, Collection<String>> backingMap =\n                new LinkedHashMap<String, Collection<String>>();\n        Multimap<String, String> original = Multimaps.newMultimap(\n                backingMap,\n                new SerializableArrayDequeSupplier());\n        original.put(\"letters\", \"a\");\n        original.put(\"letters\", \"b\");\n        original.put(\"numbers\", \"one\");\n\n        Multimap<String, String> copy = roundTrip(original);\n\n        assertThat(copy.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(copy.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(copy.keySet()).containsExactly(\"letters\", \"numbers\");\n\n        copy.put(\"created-after-deserialization\", \"uses-restored-factory\");\n        copy.put(\"created-after-deserialization\", \"second-value\");\n        assertThat(copy.get(\"created-after-deserialization\"))\n                .containsExactly(\"uses-restored-factory\", \"second-value\");\n    }\n\n    @SuppressWarnings(\"unchecked\")\n    private static <T> T roundTrip(T value) throws IOException, ClassNotFoundException {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        ByteArrayInputStream inputBytes = new ByteArrayInputStream(bytes.toByteArray());\n        try (ObjectInputStream input = new ObjectInputStream(inputBytes)) {\n            return (T) input.readObject();\n        }\n    }\n\n    private static final class SerializableArrayDequeSupplier\n            implements Supplier<Collection<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public Collection<String> get() {\n            return new ArrayDeque<String>();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782734155993}]}
