  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.URL;
  import java.nio.charset.StandardCharsets;
  import java.nio.file.Files;
  import java.nio.file.Path;
  
  import org.gradle.internal.impldep.org.apache.commons.io.IOUtils;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class OrgGradleInternalImpldepOrgApacheCommonsIoIOUtilsTest {
      private static final String RESOURCE_NAME = "org-gradle-impldep-commons-io-utils-resource.txt";
  
      @TempDir
      Path tempDir;
  
      @Test
      void resourceToURLUsesOwningClassWhenNoClassLoaderIsSupplied() throws Exception {
          URL resourceUrl = IOUtils.resourceToURL("/" + RESOURCE_NAME);
  
          assertThat(resourceUrl).isNotNull();
          assertThat(IOUtils.toString(resourceUrl, StandardCharsets.UTF_8)).contains("loaded by IOUtils");
      }
  
      @Test
      void resourceToURLUsesSuppliedClassLoader() throws Exception {
          String resourceName = "io-utils/supplied-class-loader-resource.txt";
          Path resource = tempDir.resolve(resourceName);
          Files.createDirectories(resource.getParent());
          Files.writeString(resource, "loaded by supplied class loader", StandardCharsets.UTF_8);
          URL expectedUrl = resource.toUri().toURL();
          ClassLoader classLoader = new SingleResourceClassLoader(resourceName, expectedUrl);
  
          URL resourceUrl = IOUtils.resourceToURL(resourceName, classLoader);
  
          assertThat(resourceUrl).isEqualTo(expectedUrl);
      }
  
      private static final class SingleResourceClassLoader extends ClassLoader {
          private final String resourceName;
          private final URL resourceUrl;
  
          private SingleResourceClassLoader(String resourceName, URL resourceUrl) {
              super(OrgGradleInternalImpldepOrgApacheCommonsIoIOUtilsTest.class.getClassLoader());
              this.resourceName = resourceName;
              this.resourceUrl = resourceUrl;
          }
  
          @Override
          public URL getResource(String name) {
              if (resourceName.equals(name)) {
                  return resourceUrl;
              }
              return super.getResource(name);
          }
