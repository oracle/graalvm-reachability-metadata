  public class OrgGradleWrapperDownloadTest {
      private static final String AUTHORIZATION_HEADER = "Authorization";
      private static final String EXPECTED_AUTHORIZATION = "Basic dXNlcjpwYXNz";
      private static final Duration SERVER_SHUTDOWN_TIMEOUT = Duration.ofSeconds(5);
  
      @Test
      void sendHeadRequestAddsBasicAuthenticationUsingJdkBase64() throws Exception {
          AtomicReference<String> authorization = new AtomicReference<>();
          try (LocalHeadServer server = LocalHeadServer.start(authorization)) {
              Download download = new Download(new Logger(true), "gradle-wrapper", "test", 2_000);
  
              download.sendHeadRequest(server.uriWithUserInfo());
          }
  
          assertThat(authorization.get()).isEqualTo(EXPECTED_AUTHORIZATION);
      }
  
      @Test
