  +import org.graalvm.internal.tck.NativeImageSupport;
  +import org.junit.jupiter.api.Test;
  +import org.junit.jupiter.api.io.TempDir;
  +
  +public class OrgGradleWrapperBootstrapMainStarterTest {
  +    private static final String GRADLE_MAIN_ARGS_PROPERTY = "org.gradle.wrapper.BootstrapMainStarterTest.args";
  +    private static final String GRADLE_MAIN_CLASS_ENTRY = "org/gradle/launcher/GradleMain.class";
  +    private static final String GRADLE_MAIN_CLASS_BYTES = """
  +            yv66vgAAADQAHwoAAgADBwAEDAAFAAYBABBqYXZhL2xhbmcvT2JqZWN0AQAGPGluaXQ+AQADKClWCAAIAQAwb3JnLmdyYWRsZS53
