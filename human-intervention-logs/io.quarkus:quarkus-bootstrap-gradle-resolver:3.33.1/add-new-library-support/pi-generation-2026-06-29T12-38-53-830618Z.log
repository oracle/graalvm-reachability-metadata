  +            ABkAAAApAAMAAQAAAA0SBxIJKrgAC7gAEVexAAAAAQAaAAAACgACAAAACAAMAAkAAQAdAAAAAgAe
  +            """;
  +
  +    @TempDir
  +    Path temporaryDirectory;
  +
  +    @Test
  +    void startLoadsGradleMainFromLauncherJarAndInvokesMainMethod() throws Exception {
  +        Path gradleHome = createMinimalGradleHome();
  +        ClassLoader previousContextClassLoader = Thread.currentThread().getContextClassLoader();
  +        System.clearProperty(GRADLE_MAIN_ARGS_PROPERTY);
  +        try {
  +            new BootstrapMainStarter().start(new String[] { "help", "--quiet" }, gradleHome.toFile());
  +        } catch (Error error) {
  +            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
  +                throw error;
  +            }
  +            return;
  +        } finally {
  +            Thread.currentThread().setContextClassLoader(previousContextClassLoader);
  +        }
  +
  +        assertThat(System.getProperty(GRADLE_MAIN_ARGS_PROPERTY)).isEqualTo("help\n--quiet");
  +    }
  +
  +    private Path createMinimalGradleHome() throws Exception {
  +        Path libDirectory = Files.createDirectories(temporaryDirectory.resolve("lib"));
  +        Path launcherJar = libDirectory.resolve("gradle-launcher-test.jar");
  +        try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(launcherJar))) {
  +            jarOutputStream.putNextEntry(new JarEntry(GRADLE_MAIN_CLASS_ENTRY));
  +            jarOutputStream.write(Base64.getMimeDecoder().decode(GRADLE_MAIN_CLASS_BYTES));
  +            jarOutputStream.closeEntry();
  +        }
  +        return temporaryDirectory;
  +    }
