                  Object download = constructor.newInstance(logger, "gradle-wrapper", "test", 2_000);
                  Method sendHeadRequest = downloadClass.getMethod("sendHeadRequest", URI.class);
  
                  sendHeadRequest.invoke(download, server.uriWithUserInfo());
              }
  
