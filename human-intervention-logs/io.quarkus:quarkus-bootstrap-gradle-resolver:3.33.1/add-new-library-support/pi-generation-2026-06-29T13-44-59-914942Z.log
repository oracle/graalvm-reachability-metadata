  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.IOException;
  import java.net.URL;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  
  import org.gradle.internal.classloader.FilteringClassLoader;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class OrgGradleInternalClassloaderFilteringClassLoaderTest {
      private static final String ALLOWED_RESOURCE = "gradle/filtering-classloader/allowed-resource.txt";
      private static final String PLATFORM_RESOURCE = "java/lang/String.class";
  
      @TempDir
      Path tempDir;
  
      @Test
      void loadsPlatformClassBeforeApplyingFilters() throws Exception {
          FilteringClassLoader.Spec spec = new FilteringClassLoader.Spec();
          FilteringClassLoader classLoader = new FilteringClassLoader(getClass().getClassLoader(), spec);
  
          Class<?> loadedClass = classLoader.loadClass(String.class.getName());
  
          assertThat(loadedClass).isSameAs(String.class);
      }
  
      @Test
      void delegatesAllowedResourceLookupToParentClassLoader() throws Exception {
          URL resourceUrl = createResource(ALLOWED_RESOURCE);
          FilteringClassLoader.Spec spec = new FilteringClassLoader.Spec();
          spec.allowResource(ALLOWED_RESOURCE);
          FilteringClassLoader classLoader = new FilteringClassLoader(
                  new SingleResourceClassLoader(ALLOWED_RESOURCE, resourceUrl), spec);
  
          URL loadedResource = classLoader.getResource(ALLOWED_RESOURCE);
          List<URL> loadedResources = Collections.list(classLoader.getResources(ALLOWED_RESOURCE));
  
          assertThat(loadedResource).isEqualTo(resourceUrl);
          assertThat(loadedResources).containsExactly(resourceUrl);
      }
  
      @Test
      void delegatesDisallowedResourceLookupToPlatformClassLoader() throws Exception {
          URL parentResource = createResource(PLATFORM_RESOURCE);
          FilteringClassLoader.Spec spec = new FilteringClassLoader.Spec();
          FilteringClassLoader classLoader = new FilteringClassLoader(
                  new SingleResourceClassLoader(PLATFORM_RESOURCE, parentResource), spec);
  
          URL loadedResource = classLoader.getResource(PLATFORM_RESOURCE);
          Enumeration<URL> loadedResources = classLoader.getResources(PLATFORM_RESOURCE);
  
          assertThat(loadedResource).isNotEqualTo(parentResource);
          assertThat(loadedResources).isNotNull();
      }
  
      private URL createResource(String resourceName) throws Exception {
          Path resource = tempDir.resolve(resourceName);
          Files.createDirectories(resource.getParent());
          Files.writeString(resource, "loaded by filtering class loader test");
          return resource.toUri().toURL();
      }
  
      private static final class SingleResourceClassLoader extends ClassLoader {
          private final String resourceName;
          private final URL resourceUrl;
  
          private SingleResourceClassLoader(String resourceName, URL resourceUrl) {
              super(OrgGradleInternalClassloaderFilteringClassLoaderTest.class.getClassLoader());
              this.resourceName = resourceName;
              this.resourceUrl = resourceUrl;
          }
  
          @Override
          public URL getResource(String name) {
              if (resourceName.equals(name)) {
                  return resourceUrl;
              }
              return super.getResource(name);
          }
  
          @Override
          public Enumeration<URL> getResources(String name) throws IOException {
              if (resourceName.equals(name)) {
                  return Collections.enumeration(List.of(resourceUrl));
              }
              return super.getResources(name);
          }
      }
  }
