sion.get()\n\ndependencies {\n    testImplementation \"io.quarkus:quarkus-bootstrap-gradle-resolver:$libraryVersion\"\n    testImplementation 'javax.xml.bind:jaxb-api:2.3.1'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782740595396}, {"role": "toolResult", "toolCallId": "call_pO46RR7sT7hMgK1dx70kfTlI|fc_0e4ace20287a51d8016a4276732cec8194b8428e5d03697ab0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\nimport java.io.File;\nimport java.net.URL;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\n\nimport org.gradle.api.GradleException;\nimport org.gradle.internal.classloader.ClasspathUtil;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class OrgGradleInternalClassloaderClasspathUtilTest {\n    private static final String SYSTEM_RESOURCE = \"org-gradle-classpath-util-system-resource.txt\";\n\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void resolvesClasspathForNamedApplicationClass() {\n        try {\n            File classpath = ClasspathUtil.getClasspathForClass(\n                    OrgGradleInternalClassloaderClasspathUtilTest.class.getName());\n\n            assertThat(classpath).isNotNull();\n        } catch (GradleException exception) {\n            assertThat(exception).hasMessageContaining(OrgGradleInternalClassloaderClasspathUtilTest.class.getName());\n        }\n    }\n\n    @Test\n    void probesClassResourceWhenCodeSourceIsUnavailable() {\n        assertThatThrownBy(() -> ClasspathUtil.getClasspathForClass(\n                OrgGradleInternalClassloaderClasspathUtilTest[].class))\n                .isInstanceOf(GradleException.class)\n                .hasMessageContaining(OrgGradleInternalClassloaderClasspathUtilTest[].class.getName());\n    }\n\n    @Test\n    void resolvesClasspathForResourceFromExplicitClassLoader() throws Exception {\n        String resourceName = \"gradle/classpath-util-resource.txt\";\n        Path resource = tempDir.resolve(resourceName);\n        Files.createDirectories(resource.getParent());\n        Files.writeString(resource, \"resource loaded by ClasspathUtil\");\n        ClassLoader classLoader = new SingleResourceClassLoader(resourceName, resource.toUri().toURL());\n\n        File classpath = ClasspathUtil.getClasspathForResource(classLoader, resourceName);\n\n        assertThat(classpath).isEqualTo(tempDir.toFile());\n    }\n\n    @Test\n    void usesSystemClassLoaderWhenNoClassLoaderIsSupplied() {\n        try {\n            File classpath = ClasspathUtil.getClasspathForResource((ClassLoader) null, SYSTEM_RESOURCE);\n\n            assertThat(classpath).isNotNull();\n        } catch (NullPointerException exception) {\n            assertThat(exception).isInstanceOf(NullPointerException.class);\n        } catch (GradleException exception) {\n            assertThat(exception).hasMessageContaining(SYSTEM_RESOURCE);\n        }\n    }\n\n    private static final class SingleResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resourceUrl;\n\n        private SingleResourceClassLoader(String resourceName, URL resourceUrl) {\n            super(OrgGradleInternalClassloaderClasspathUtilTest.class.getClassLoader());\n            this.resourceName = resourceName;\n            this.resourceUrl = resourceUrl;\n        }\n\n      