  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.reflect.Type;
  import java.lang.reflect.TypeVariable;
  
  import org.gradle.internal.impldep.com.google.common.reflect.TypeResolver;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalImpldepComGoogleCommonReflectTypesInnerTypeVariableInvocationHandlerTest {
      @Test
      void resolveTypeVariableWithResolvedBoundsCreatesProxyBackedTypeVariable() {
          TypeVariable<?> sourceVariable = Outer.class.getTypeParameters()[0];
          TypeVariable<?> boundedVariable = Outer.Inner.class.getTypeParameters()[0];
  
          Type resolvedType = new TypeResolver()
                  .where(sourceVariable, String.class)
                  .resolveType(boundedVariable);
  
          assertThat(resolvedType).isInstanceOf(TypeVariable.class);
          TypeVariable<?> resolvedVariable = (TypeVariable<?>) resolvedType;
          assertThat(resolvedVariable.getName()).isEqualTo("Bounded");
          assertThat(resolvedVariable.getGenericDeclaration()).isEqualTo(Outer.Inner.class);
          assertThat(resolvedVariable.getBounds()).containsExactly(String.class);
          assertThat(resolvedVariable.toString()).isEqualTo("Bounded");
      }
  
      static class Outer<Source> {
          class Inner<Bounded extends Source> {
          }
      }
  }
