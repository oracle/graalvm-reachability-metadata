n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.reflect.InvocationHandler;\n\nimport org.gradle.internal.impldep.com.google.common.reflect.Reflection;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonReflectReflectionTest {\n    @Test\n    void initializeLoadsTheRequestedClass() {\n        Reflection.initialize(InitializationTarget.class);\n\n        assertThat(InitializationTarget.initialized).isTrue();\n    }\n\n    @Test\n    void newProxyCreatesProxyForInterface() {\n        InvocationHandler handler = (proxy, method, arguments) -> {\n            if (method.getDeclaringClass() == Object.class) {\n                return switch (method.getName()) {\n                    case \"equals\" -> proxy == arguments[0];\n                    case \"hashCode\" -> System.identityHashCode(proxy);\n                    case \"toString\" -> \"GreetingService proxy\";\n                    default -> throw new UnsupportedOperationException(method.getName());\n                };\n            }\n            return \"hello, \" + arguments[0];\n        };\n\n        GreetingService proxy = Reflection.newProxy(GreetingService.class, handler);\n\n        assertThat(proxy).isInstanceOf(GreetingService.class);\n        assertThat(proxy.greet(\"Gradle\")).isEqualTo(\"hello, Gradle\");\n    }\n\n    public interface GreetingService {\n        String greet(String name);\n    }\n\n    public static class InitializationTarget {\n        static boolean initialized;\n\n        static {\n            initialized = true;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782742327367}, {"role": "toolResult", "toolCallId": "call_fWhNFpvAfixNyOvaBdl3PG69|fc_0214e04f7b400586016a427d37130081909fc3f3f6cfe61afb", "to