  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  File gradleLibDir = new File(gradle.gradleHomeDir, "lib")
  File[] installationBeaconJars = gradleLibDir.listFiles({ File directory, String name ->
      name.startsWith("gradle-installation-beacon-") && name.endsWith(".jar")
  } as FilenameFilter)
  if (installationBeaconJars == null || installationBeaconJars.length != 1) {
      throw new GradleException("Expected exactly one Gradle installation beacon JAR in ${gradleLibDir}")
  }
  
  dependencies {
      testImplementation "io.quarkus:quarkus-bootstrap-gradle-resolver:$libraryVersion"
      testImplementation 'javax.xml.bind:jaxb-api:2.3.1'
      testImplementation 'org.assertj:assertj-core:3.22.0'
      testRuntimeOnly files(installationBeaconJars[0])
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
      binaries {
          test {
              buildArgs.add('--enable-url-protocols=http,jar')
          }
