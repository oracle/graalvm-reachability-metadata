core.api.Assertions.assertThat;\n\nimport org.gradle.internal.reflect.DirectInstantiator;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalReflectDirectInstantiatorTest {\n    @Test\n    void createsInstanceWithMatchingPublicConstructor() {\n        ConstructedValue value = DirectInstantiator.instantiate(\n                ConstructedValue.class,\n                \"configured by DirectInstantiator\",\n                7);\n\n        assertThat(value.description()).isEqualTo(\"configured by DirectInstantiator\");\n        assertThat(value.priority()).isEqualTo(7);\n    }\n\n    public static final class ConstructedValue {\n        private final String description;\n        private final int priority;\n\n        public ConstructedValue(CharSequence description, int priority) {\n            this.description = description.toString();\n            this.priority = priority;\n        }\n\n        private String description() {\n            return description;\n        }\n\n        private int priority() {\n            return priority;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2452, "output": 857, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 33005, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782744241325, "responseId": "resp_0b740981ebfa42c6016a4284b1f5208196b99e4d2b657d13bc"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_QFH22YISsDHVf2Bi8vkmZuQX|fc_0b740981ebfa42c6016a4284bbc67c81968802a3439b10ef45", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1329 bytes to tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalReflectDirectInstantiatorTest.java"}], "isError": false, "timestamp": 1782744254008}]}
