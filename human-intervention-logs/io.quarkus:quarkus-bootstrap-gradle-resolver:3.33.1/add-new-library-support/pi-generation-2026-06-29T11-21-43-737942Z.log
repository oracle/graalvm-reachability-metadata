[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.gradle.internal.impldep.com.google.common.collect.HashMultiset;\nimport org.gradle.internal.impldep.com.google.common.collect.ImmutableListMultimap;\nimport org.gradle.internal.impldep.com.google.common.collect.ImmutableSetMultimap;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest {\n    @Test\n    void serializesAndDeserializesMultisetWithDistinctElementCounts() throws Exception {\n        HashMultiset<String> multiset = HashMultiset.create();\n        multiset.add(\"red\", 3);\n        multiset.add(\"blue\", 2);\n\n        Object roundTripped = roundTrip(multiset);\n\n        assertThat(roundTripped).isInstanceOf(HashMultiset.class);\n        HashMultiset<?> deserialized = (HashMultiset<?>) roundTripped;\n        assertThat(deserialized.count(\"red\")).isEqualTo(3);\n        assertThat(deserialized.count(\"blue\")).isEqualTo(2);\n        assertThat(deserialized.entrySet()).hasSize(2);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableListMultimapEntries() throws Exception {\n        ImmutableListMultimap<String, String> multimap = ImmutableListMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableListMultimap.class);\n        ImmutableListMultimap<?, ?> deserialized = (ImmutableListMultimap<?, ?>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableSetMultimapEntries() throws Exception {\n        ImmutableSetMultimap<String, String> multimap = ImmutableSetMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableSetMultimap.class);\n        ImmutableSetMultimap<?, ?> deserialized = (ImmutableSetMultimap<?, ?>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactlyInAnyOrder(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n}\n"}
[tool-call] end id=call_sgGrNiIiHXLiddKKuHBtZvkB|fc_0489047279438c7a016a42552310ec8196a29e7ce5f80f0f1f name=write args={"path": "tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\n\nimport org.gradle.internal.impldep.com.google.common.collect.HashMultiset;\nimport org.gradle.internal.impldep.com.google.common.collect.ImmutableListMultimap;\nimport org.gradle.internal.impldep.com.google.common.collect.ImmutableSetMultimap;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest {\n    @Test\n    void serializesAndDeserializesMultisetWithDistinctElementCounts() throws Exception {\n        HashMultiset<String> multiset = HashMultiset.create();\n        multiset.add(\"red\", 3);\n        multiset.add(\"blue\", 2);\n\n        Object roundTripped = roundTrip(multiset);\n\n        assertThat(roundTripped).isInstanceOf(HashMultiset.class);\n        HashMultiset<?> deserialized = (HashMultiset<?>) roundTripped;\n        assertThat(deserialized.count(\"red\")).isEqualTo(3);\n        assertThat(deserialized.count(\"blue\")).isEqualTo(2);\n        assertThat(deserialized.entrySet()).hasSize(2);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableListMultimapEntries() throws Exception {\n        ImmutableListMultimap<String, String> multimap = ImmutableListMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableListMultimap.class);\n        ImmutableListMultimap<?, ?> deserialized = (ImmutableListMultimap<?, ?>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableSetMultimapEntries() throws Exception {\n        ImmutableSetMultimap<String, String> multimap = ImmutableSetMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableSetMultimap.class);\n        ImmutableSetMultimap<?, ?> deserialized = (ImmutableSetMultimap<?, ?>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactlyInAnyOrder(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n}\n"}
