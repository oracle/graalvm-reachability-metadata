  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.util.ArrayList;
  import java.util.Collection;
  import java.util.LinkedHashMap;
  import java.util.List;
  import java.util.Map;
  
  import org.gradle.internal.impldep.com.google.common.base.Supplier;
  import org.gradle.internal.impldep.com.google.common.collect.HashMultiset;
  import org.gradle.internal.impldep.com.google.common.collect.ImmutableListMultimap;
  import org.gradle.internal.impldep.com.google.common.collect.ImmutableSetMultimap;
  import org.gradle.internal.impldep.com.google.common.collect.Multimap;
  import org.gradle.internal.impldep.com.google.common.collect.Multimaps;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest {
      private static final String SERIALIZATION_CLASS_NAME =
              "org.gradle.internal.impldep.com.google.common.collect.Serialization";
  
      @Test
      void writesAndPopulatesMapEntries() throws Throwable {
          Map<String, String> source = new LinkedHashMap<>();
          source.put("first", "one");
          source.put("second", "two");
  
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              serializationMethod("writeMap", MethodType.methodType(void.class, Map.class, ObjectOutputStream.class))
                      .invoke(source, output);
          }
  
          Map<String, String> deserialized = new LinkedHashMap<>();
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              serializationMethod("populateMap", MethodType.methodType(void.class, Map.class, ObjectInputStream.class))
                      .invoke(deserialized, input);
          }
  
          assertThat(deserialized).containsExactlyEntriesOf(source);
      }
  
      @Test
      void populatesMutableListMultimapFromSerializedEntries() throws Throwable {
          Map<String, Collection<String>> backingMap = new LinkedHashMap<>();
          Supplier<List<String>> valueSupplier = ArrayList::new;
          Multimap<String, String> multimap = Multimaps.newListMultimap(backingMap, valueSupplier);
  
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeInt(2);
              output.writeObject("letters");
              output.writeInt(2);
              output.writeObject("a");
              output.writeObject("b");
              output.writeObject("numbers");
              output.writeInt(1);
              output.writeObject("one");
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              serializationMethod(
                      "populateMultimap",
                      MethodType.methodType(void.class, Multimap.class, ObjectInputStream.class)).invoke(multimap, input);
          }
  
          assertThat(multimap.get("letters")).containsExactly("a", "b");
          assertThat(multimap.get("numbers")).containsExactly("one");
          assertThat(multimap.size()).isEqualTo(3);
      }
  
      @Test
      void serializesAndDeserializesMultisetWithDistinctElementCounts() throws Exception {
          HashMultiset<String> multiset = HashMultiset.create();
          multiset.add("red", 3);
          multiset.add("blue", 2);
  
          Object roundTripped = roundTrip(multiset);
  
          assertThat(roundTripped).isInstanceOf(HashMultiset.class);
          HashMultiset<?> deserialized = (HashMultiset<?>) roundTripped;
          assertThat(deserialized.count("red")).isEqualTo(3);
          assertThat(deserialized.count("blue")).isEqualTo(2);
          assertThat(deserialized.entrySet()).hasSize(2);
      }
  
      @Test
      void serializesAndDeserializesImmutableListMultimapEntries() throws Exception {
          ImmutableListMultimap<String, String> multimap = ImmutableListMultimap.of(
                  "letters", "a",
                  "letters", "b",
                  "numbers", "one");
  
          Object roundTripped = roundTrip(multimap);
  
          assertThat(roundTripped).isInstanceOf(ImmutableListMultimap.class);
          @SuppressWarnings("unchecked")
          ImmutableListMultimap<String, String> deserialized = (ImmutableListMultimap<String, String>) roundTripped;
          assertThat(deserialized.get("letters")).containsExactly("a", "b");
          assertThat(deserialized.get("numbers")).containsExactly("one");
          assertThat(deserialized.size()).isEqualTo(3);
      }
  
      @Test
      void serializesAndDeserializesImmutableSetMultimapEntries() throws Exception {
          ImmutableSetMultimap<String, String> multimap = ImmutableSetMultimap.of(
                  "letters", "a",
                  "letters", "b",
                  "numbers", "one");
  
          Object roundTripped = roundTrip(multimap);
  
          assertThat(roundTripped).isInstanceOf(ImmutableSetMultimap.class);
          @SuppressWarnings("unchecked")
          ImmutableSetMultimap<String, String> deserialized = (ImmutableSetMultimap<String, String>) roundTripped;
          assertThat(deserialized.get("letters")).containsExactlyInAnyOrder("a", "b");
          assertThat(deserialized.get("numbers")).containsExactly("one");
          assertThat(deserialized.size()).isEqualTo(3);
      }
  
      private static MethodHandle serializationMethod(String methodName, MethodType methodType) throws Exception {
          Class<?> serializationClass = Class.forName(SERIALIZATION_CLASS_NAME);
          return MethodHandles.privateLookupIn(serializationClass, MethodHandles.lookup())
                  .findStatic(serializationClass, methodName, methodType);
      }
  
      private static Object roundTrip(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return input.readObject();
          }
      }
