 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.net.URL;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport org.gradle.internal.service.DefaultServiceLocator;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\npublic class OrgGradleInternalServiceDefaultServiceLocatorTest {\n    @TempDir\n    Path tempDir;\n\n    @Test\n    void discoversImplementationClassesFromServiceDescriptor() throws Exception {\n        String descriptorName = \"META-INF/services/\" + SampleService.class.getName();\n        Path descriptor = tempDir.resolve(\"service-descriptor.txt\");\n        Files.writeString(descriptor, \"\"\"\n                # Comment lines are ignored by DefaultServiceLocator.\n                %s # inline comments are ignored too\n                \"\"\".formatted(SampleServiceImpl.class.getName()));\n        ClassLoader serviceClassLoader = new ServiceDescriptorClassLoader(\n                descriptorName,\n                descriptor.toUri().toURL());\n        DefaultServiceLocator locator = new DefaultServiceLocator(false, serviceClassLoader);\n\n        List<Class<? extends SampleService>> implementations = locator.implementationsOf(SampleService.class);\n\n        assertThat(implementations).containsExactly(SampleServiceImpl.class);\n    }\n\n    public interface SampleService {\n    }\n\n    public static final class SampleServiceImpl implements SampleService {\n    }\n\n    private static final class ServiceDescriptorClassLoader extends ClassLoader {\n        private final String descriptorName;\n        private final URL descriptorUrl;\n\n        private ServiceDescriptorClassLoader(String descriptorName, URL descriptorUrl) {\n            super(OrgGradleInternalServiceDefaultServiceLocatorTest.class.getClassLoader());\n            this.descriptorName = descriptorName;\n            this.descriptorUrl = descriptorUrl;\n        }\n\n        @Override\n        public Enumeration<URL> getResources(String name) {\n            if (descriptorName.equals(name)) {\n                return Collections.enumeration(List.of(descriptorUrl));\n            }\n            return Collections.emptyEnumeration();\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1265, "output": 1614, "cacheRead": 40960, "cacheWrite": 0, "totalTokens": 43839, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782739935698, "responseId": "resp_06efdeaaebd26dd2016a4273e041f48194891862c5ea0689c9"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_oMLh2HlRYAOYQDZF1l5RCw5B|fc_06efdeaaebd26dd2016a4273f410648194884ca28101cd3e65", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2498 bytes to tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalServiceDefaultServiceLocatorTest.java"}], "isError": false, "timestamp": 1782739963026}]}
