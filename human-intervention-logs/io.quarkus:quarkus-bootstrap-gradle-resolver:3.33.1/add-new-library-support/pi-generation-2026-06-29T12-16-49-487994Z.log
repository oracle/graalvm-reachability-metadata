CollectMultimapsInnerCustomSortedSetMultimapTest {\n    @Test\n    void serializesComparatorAndBackingMapForCustomSortedSetMultimap() throws Exception {\n        Map<String, Collection<String>> backingMap = new LinkedHashMap<>();\n        SortedSetMultimap<String, String> original = Multimaps.newSortedSetMultimap(\n                backingMap,\n                new SerializableTreeSetSupplier());\n        original.put(\"letters\", \"bb\");\n        original.put(\"letters\", \"a\");\n        original.put(\"letters\", \"bb\");\n        original.put(\"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(original);\n\n        assertThat(roundTripped.getClass().getName())\n                .isEqualTo(\"org.gradle.internal.impldep.com.google.common.collect.Multimaps$CustomSortedSetMultimap\");\n        @SuppressWarnings(\"unchecked\")\n        SortedSetMultimap<String, String> deserialized = (SortedSetMultimap<String, String>) roundTripped;\n        assertThat(deserialized.valueComparator()).isEqualTo(LengthThenNaturalComparator.INSTANCE);\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"bb\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.keySet()).containsExactly(\"letters\", \"numbers\");\n\n        deserialized.put(\"created-after-deserialization\", \"ccc\");\n        deserialized.put(\"created-after-deserialization\", \"b\");\n        deserialized.put(\"created-after-deserialization\", \"aa\");\n        assertThat(deserialized.get(\"created-after-deserialization\"))\n                .containsExactly(\"b\", \"aa\", \"ccc\");\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n\n    private enum LengthThenNaturalComparator implements Comparator<String> {\n        INSTANCE;\n\n        @Override\n        public int compare(String first, String second) {\n            int lengthComparison = Integer.compare(first.length(), second.length());\n            if (lengthComparison != 0) {\n                return lengthComparison;\n            }\n            return first.compareTo(second);\n        }\n    }\n\n    private static final class SerializableTreeSetSupplier implements Supplier<SortedSet<String>>, Serializable {\n        private static final long serialVersionUID = 1L;\n\n        @Override\n        public SortedSet<String> get() {\n            return new TreeSet<>(LengthThenNaturalComparator.INSTANCE);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1599, "output": 1465, "cacheRead": 20480, "cacheWrite": 0, "totalTokens": 23544, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782735382177, "responseId": "resp_00417d1896fa68fb016a426216c53881969b605c5df3e83b8f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_dKOdMLUYDKmBSQEcxUfZhj0c|fc_00417d1896fa68fb016a42621f5aa48196aca4e0ed2a2586c2", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 3701 bytes to tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomSortedSetMultimapTest.java"}], "isError": false, "timestamp": 1782735398925}]}
