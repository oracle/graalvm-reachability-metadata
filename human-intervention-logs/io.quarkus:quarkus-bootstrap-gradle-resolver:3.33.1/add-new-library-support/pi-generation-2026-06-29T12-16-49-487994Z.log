  public class OrgGradleInternalImpldepComGoogleCommonCollectMultimapsInnerCustomSetMultimapTest {
      @Test
      void serializesFactoryAndBackingMapForCustomSetMultimap() throws Exception {
          Map<String, Collection<String>> backingMap = new LinkedHashMap<>();
          SetMultimap<String, String> original = Multimaps.newSetMultimap(
                  backingMap,
                  new SerializableLinkedHashSetSupplier());
          original.put("letters", "a");
          original.put("letters", "b");
          original.put("letters", "a");
          original.put("numbers", "one");
  
