  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.io.ByteArrayInputStream;
  import java.io.ByteArrayOutputStream;
  import java.io.ObjectInputStream;
  import java.io.ObjectOutputStream;
  import java.util.Base64;
  import java.util.List;
  import java.util.Set;
  
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalImpldepComGoogleCommonCollectCompactHashSetTest {
      private static final String COMPACT_HASH_SET_CLASS_NAME =
              "org.gradle.internal.impldep.com.google.common.collect.CompactHashSet";
  
      private static final String SERIALIZED_COMPACT_HASH_SET = """
              rO0ABXNyAERvcmcuZ3JhZGxlLmludGVybmFsLmltcGxkZXAuY29tLmdvb2dsZS5jb21tb24uY29s
              bGVjdC5Db21wYWN0SGFzaFNldCmoKv7Sc6q0AwAAeHB3BAAAAAN0AAVhbHBoYXQABGJldGF0AAVn
              YW1tYXg=
              """;
  
      @Test
      void serializesAndDeserializesCompactHashSetElements() throws Exception {
          Object deserialized = readSerializedCompactHashSet();
  
          assertCompactHashSet(deserialized);
  
          Object roundTripped = roundTrip(deserialized);
  
          assertCompactHashSet(roundTripped);
      }
  
      private static void assertCompactHashSet(Object value) {
          assertThat(value).isInstanceOf(Set.class);
          assertThat(value.getClass().getName()).isEqualTo(COMPACT_HASH_SET_CLASS_NAME);
  
          Set<?> values = (Set<?>) value;
          assertThat(values).hasSize(3);
          assertThat(values.containsAll(List.of("alpha", "beta", "gamma"))).isTrue();
      }
  
      private static Object readSerializedCompactHashSet() throws Exception {
          byte[] bytes = Base64.getMimeDecoder().decode(SERIALIZED_COMPACT_HASH_SET);
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes))) {
              return input.readObject();
          }
      }
  
      private static Object roundTrip(Object value) throws Exception {
          ByteArrayOutputStream bytes = new ByteArrayOutputStream();
          try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {
              output.writeObject(value);
          }
  
          try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {
              return input.readObject();
          }
      }
  }
