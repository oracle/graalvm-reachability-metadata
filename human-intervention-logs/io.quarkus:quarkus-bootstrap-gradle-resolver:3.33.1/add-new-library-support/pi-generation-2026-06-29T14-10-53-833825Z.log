  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.lang.annotation.ElementType;
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  import java.lang.annotation.Target;
  import java.lang.reflect.Field;
  
  import org.gradle.internal.impldep.com.google.common.base.Enums;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalImpldepComGoogleCommonBaseEnumsTest {
      @Test
      void getFieldReturnsTheDeclaringEnumConstantField() {
          Field field = Enums.getField(ResolverMode.OFFLINE);
  
          assertThat(field.getName()).isEqualTo("OFFLINE");
          assertThat(field.getDeclaringClass()).isSameAs(ResolverMode.class);
          assertThat(field.getDeclaredAnnotationsByType(Label.class)[0].value()).isEqualTo("offline resolver mode");
      }
  
      private enum ResolverMode {
          ONLINE,
  
          @Label("offline resolver mode")
          OFFLINE
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      @Target(ElementType.FIELD)
      private @interface Label {
          String value();
      }
  }
