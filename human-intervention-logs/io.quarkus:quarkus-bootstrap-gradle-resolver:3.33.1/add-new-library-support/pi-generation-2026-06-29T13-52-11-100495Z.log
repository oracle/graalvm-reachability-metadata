  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.gradle.tooling.internal.adapter.ProtocolToModelAdapter;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleToolingInternalAdapterProtocolToModelAdapterInnerMethodInvocationCacheTest {
      @Test
      void resolvesProtocolMethodThroughInvocationCache() {
          ProtocolToModelAdapter adapter = new ProtocolToModelAdapter();
          SampleView view = adapter.adapt(SampleView.class, new SampleProtocolModel("quarkus", 33));
  
          assertThat(view.getName()).isEqualTo("quarkus");
          assertThat(view.describe("Gradle")).isEqualTo("Gradle: quarkus-33");
      }
  
      public interface SampleView {
          String getName();
  
          String describe(String prefix);
      }
  
      public static final class SampleProtocolModel {
          private final String name;
          private final int revision;
  
          public SampleProtocolModel(String name, int revision) {
              this.name = name;
              this.revision = revision;
          }
  
          public String getName() {
              return name;
          }
  
          public String describe(String prefix) {
              return prefix + ": " + name + "-" + revision;
          }
      }
  }
