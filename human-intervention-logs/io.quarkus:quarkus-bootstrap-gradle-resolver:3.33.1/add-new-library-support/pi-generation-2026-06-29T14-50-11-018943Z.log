  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.gradle.internal.service.DefaultServiceRegistry;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalServiceDefaultServiceRegistryInnerConstructorServiceTest {
      @Test
      void constructsRegisteredServiceClassOnLookup() {
          DefaultServiceRegistry registry = new DefaultServiceRegistry("constructor-backed services");
          registry.register(registration -> registration.add(ConstructedService.class));
  
          ConstructedService service = registry.get(ConstructedService.class);
  
          assertThat(service.message()).isEqualTo("constructed by DefaultServiceRegistry");
          assertThat(registry.get(ConstructedService.class)).isSameAs(service);
      }
  
      public static final class ConstructedService {
          private final String message;
  
          public ConstructedService() {
              this.message = "constructed by DefaultServiceRegistry";
          }
  
          public String message() {
              return message;
          }
      }
  }
