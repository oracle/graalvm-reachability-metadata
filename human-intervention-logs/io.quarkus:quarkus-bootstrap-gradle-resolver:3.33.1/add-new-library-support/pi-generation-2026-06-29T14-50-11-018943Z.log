  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import java.net.URL;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.util.Collections;
  import java.util.Enumeration;
  import java.util.List;
  
  import org.gradle.internal.service.DefaultServiceLocator;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class OrgGradleInternalServiceDefaultServiceLocatorTest {
      @TempDir
      Path tempDir;
  
      @Test
      void discoversImplementationClassesFromServiceDescriptor() throws Exception {
          String descriptorName = "META-INF/services/" + SampleService.class.getName();
          Path descriptor = tempDir.resolve("service-descriptor.txt");
          Files.writeString(descriptor, """
                  # Comment lines are ignored by DefaultServiceLocator.
                  %s # inline comments are ignored too
                  """.formatted(SampleServiceImpl.class.getName()));
          ClassLoader serviceClassLoader = new ServiceDescriptorClassLoader(
                  descriptorName,
                  descriptor.toUri().toURL());
          DefaultServiceLocator locator = new DefaultServiceLocator(false, serviceClassLoader);
  
          List<Class<? extends SampleService>> implementations = locator.implementationsOf(SampleService.class);
  
          assertThat(implementations).containsExactly(SampleServiceImpl.class);
      }
  
      public interface SampleService {
      }
  
      public static final class SampleServiceImpl implements SampleService {
      }
  
      private static final class ServiceDescriptorClassLoader extends ClassLoader {
          private final String descriptorName;
          private final URL descriptorUrl;
  
          private ServiceDescriptorClassLoader(String descriptorName, URL descriptorUrl) {
              super(OrgGradleInternalServiceDefaultServiceLocatorTest.class.getClassLoader());
              this.descriptorName = descriptorName;
              this.descriptorUrl = descriptorUrl;
          }
  
          @Override
          public Enumeration<URL> getResources(String name) {
              if (descriptorName.equals(name)) {
                  return Collections.enumeration(List.of(descriptorUrl));
              }
              return Collections.emptyEnumeration();
          }
      }
  }
