  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.gradle.internal.impldep.com.google.common.collect.ObjectArrays;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalImpldepComGoogleCommonCollectObjectArraysTest {
      @Test
      void concatAllocatesArrayForExplicitComponentType() {
          Number[] first = { 1, 2L };
          Number[] second = { 3.5D, 4 };
  
          Number[] combined = ObjectArrays.concat(first, second, Number.class);
  
          assertThat(combined).containsExactly(1, 2L, 3.5D, 4);
          assertThat(combined.getClass().getComponentType()).isSameAs(Number.class);
      }
  }
