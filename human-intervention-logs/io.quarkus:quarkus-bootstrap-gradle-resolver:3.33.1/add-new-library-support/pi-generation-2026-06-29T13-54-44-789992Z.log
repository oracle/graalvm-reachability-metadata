[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalEventBroadcastDispatchTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatIllegalArgumentException;\n\nimport java.util.ArrayList;\nimport java.util.List;\n\nimport org.gradle.api.Action;\nimport org.gradle.internal.event.BroadcastDispatch;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalEventBroadcastDispatchTest {\n    @Test\n    void addsActionListenerForNamedListenerMethod() {\n        BroadcastDispatch<MessageListener> dispatch = BroadcastDispatch.empty(MessageListener.class);\n        List<String> messages = new ArrayList<>();\n        Action<String> action = messages::add;\n\n        BroadcastDispatch<MessageListener> updated = dispatch.add(\"message\", action);\n\n        assertThat(updated.getType()).isEqualTo(MessageListener.class);\n        assertThat(updated.isEmpty()).isFalse();\n        assertThat(updated.size()).isEqualTo(1);\n        assertThat(messages).isEmpty();\n    }\n\n    @Test\n    void rejectsActionListenerForUnknownMethodName() {\n        BroadcastDispatch<MessageListener> dispatch = BroadcastDispatch.empty(MessageListener.class);\n        Action<String> action = value -> {\n        };\n\n        assertThatIllegalArgumentException()\n                .isThrownBy(() -> dispatch.add(\"missing\", action))\n                .withMessage(\"Method missing() not found for listener type MessageListener.\");\n    }\n\n    public interface MessageListener {\n        void message(String value);\n    }\n}\n"}
