er;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport com.sun.net.httpserver.HttpServer;\nimport java.lang.reflect.Constructor;\nimport java.lang.reflect.InvocationTargetException;\nimport java.lang.reflect.Method;\nimport java.net.InetAddress;\nimport java.net.InetSocketAddress;\nimport java.net.URI;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.CodeSource;\nimport java.time.Duration;\nimport java.util.concurrent.ExecutorService;\nimport java.util.concurrent.Executors;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicReference;\nimport org.gradle.wrapper.Download;\nimport org.gradle.wrapper.Logger;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleWrapperDownloadTest {\n    private static final String AUTHORIZATION_HEADER = \"Authorization\";\n    private static final String EXPECTED_AUTHORIZATION = \"Basic dXNlcjpwYXNz\";\n    private static final Duration SERVER_SHUTDOWN_TIMEOUT = Duration.ofSeconds(5);\n\n    @Test\n    void sendHeadRequestAddsBasicAuthenticationUsingJdkBase64() throws Exception {\n        AtomicReference<String> authorization = new AtomicReference<>();\n        try (LocalHeadServer server = LocalHeadServer.start(authorization)) {\n            Download download = new Download(new Logger(true), \"gradle-wrapper\", \"test\", 2_000);\n\n            download.sendHeadRequest(server.uriWithUserInfo());\n        }\n\n        assertThat(authorization.get()).isEqualTo(EXPECTED_AUTHORIZATION);\n    }\n\n    @Test\n    void sendHeadRequestFallsBackToDatatypeConverterWhenJdkBase64IsUnavailable() throws Exception {\n        try {\n            AtomicReference<String> authorization = new AtomicReference<>();\n            try (LocalHeadServer server = LocalHeadServer.start(authorization);\n                    URLClassLoader classLoader = new Base64HidingWrapperClassLoader(wrapperCodeSourceUrl())) {\n                Class<?> loggerClass = classLoader.loadClass(\"org.gradle.wrapper.Logger\");\n                Object logger = loggerClass.getConstructor(boolean.class).newInstance(true);\n                Class<?> downloadClass = classLoader.loadClass(\"org.gradle.wrapper.Download\");\n                Constructor<?> constructor = downloadClass.getConstructor(\n                        loggerClass, String.class, String.class, int.class);\n                Object download = constructor.newInstance(logger, \"gradle-wrapper\", \"test\", 2_000);\n                Method sendHeadRequest = downloadClass.getMethod(\"sendHeadRequest\", URI.class);\n\n                sendHeadRequest.invoke(download, server.uriWithUserInfo());\n            }\n\n            assertThat(authorization.get()).isEqualTo(EXPECTED_AUTHORIZATION);\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause();\n            if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            throw exception;\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static URL wrapperCodeSourceUrl() {\n        CodeSource codeSource = Download.class.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).isNotNull();\n        return codeSource.getLocation();\n    }\n\n    private static final class Base64HidingWrapperClassLoader extends URLClassLoader {\n        private Base64HidingWrapperClassLoader(URL wrapperLocation) {\n            super(new URL[] { wrapperLocation }, OrgGradleWrapperDownloadTest.class.getClassLoader());\n        }\n\n        @Override\n        public Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            if (name.equals(\"java.util.Base64\") || name.equals(\"java.util.Base64$Encoder\")) {\n                throw new ClassNotFoundException(name);\n            }\n            if (name.startsWith(\"org.gradle.wrapper.\")) {\n                synchronized (getClassLoadingLock(name)) {\n                    Class<?> loadedClass = findLoadedClass(name);\n                    if (loadedClass == null) {\n                        loadedClass = findClass(name);\n                    }\n                    if (resolve) {\n                        resolveClass(loadedClass);\n                    }\n                    return loadedClass;\n                }\n            }\n            return super.loadClass(name, resolve);\n        }\n    }\n\n    private static final class LocalHeadServer implements AutoCloseable {\n        private final HttpServer server;\n        private final ExecutorService executor;\n\n        private LocalHeadServer(HttpServer server, ExecutorService executor) {\n            this.server = server;\n            this.executor = executor;\n        }\n\n        private static LocalHeadServer start(AtomicReference<String> authorization) throws Exception {\n            InetSocketAddress loopbackAddress = new InetSocketAddress(InetAddress.getLoopbackAddress(), 0);\n            HttpServer server = HttpServer.create(loopbackAddress, 0);\n            ExecutorService executor = Executors.newSingleThreadExecutor();\n            server.setExecutor(executor);\n            server.createContext(\"/distribution.zip\", exchange -> {\n                try (exchange) {\n                    authorization.set(exchange.getRequestHeaders().getFirst(AUTHORIZATION_HEADER));\n                    assertThat(exchange.getRequestMethod()).isEqualTo(\"HEAD\");\n                    exchange.sendResponseHeaders(200, -1);\n                }\n            });\n            server.start();\n            return new LocalHeadServer(server, executor);\n        }\n\n        private URI uriWithUserInfo() {\n            InetSocketAddress address = server.getAddress();\n            return URI.create(\"http://user:pass@\" + address.getHostString() + \":\" + address.getPort()\n                    + \"/distribution.zip\");\n        }\n\n        @Override\n        public void close() throws Exception {\n            server.stop(0);\n            executor.shutdownNow();\n            assertThat(executor.awaitTermination(SERVER_SHUTDOWN_TIMEOUT.toMillis(), TimeUnit.MILLISECONDS)).isTrue();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782732736914}, {"role": "toolResult", "toolCallId": "call_bbOCAtbakcBe2DP89PFYsrYl|fc_0bdb746fda50c06e016a4257c0a9ac81938b1e9b6761630f00", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.ByteArrayOutputStream;\nimport java.io.ObjectInputStream;\nimport java.io.ObjectOutputStream;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.util.ArrayList;\nimport java.util.Collection;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\n\nimport org.gradle.internal.impldep.com.google.common.base.Supplier;\nimport org.gradle.internal.impldep.com.google.common.collect.HashMultiset;\nimport org.gradle.internal.impldep.com.google.common.collect.ImmutableListMultimap;\nimport org.gradle.internal.impldep.com.google.common.collect.ImmutableSetMultimap;\nimport org.gradle.internal.impldep.com.google.common.collect.Multimap;\nimport org.gradle.internal.impldep.com.google.common.collect.Multimaps;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest {\n    private static final String SERIALIZATION_CLASS_NAME =\n            \"org.gradle.internal.impldep.com.google.common.collect.Serialization\";\n\n    @Test\n    void writesAndPopulatesMapEntries() throws Throwable {\n        Map<String, String> source = new LinkedHashMap<>();\n        source.put(\"first\", \"one\");\n        source.put(\"second\", \"two\");\n\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            serializationMethod(\"writeMap\", MethodType.methodType(void.class, Map.class, ObjectOutputStream.class))\n                    .invoke(source, output);\n        }\n\n        Map<String, String> deserialized = new LinkedHashMap<>();\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            serializationMethod(\"populateMap\", MethodType.methodType(void.class, Map.class, ObjectInputStream.class))\n                    .invoke(deserialized, input);\n        }\n\n        assertThat(deserialized).containsExactlyEntriesOf(source);\n    }\n\n    @Test\n    void populatesMutableListMultimapFromSerializedEntries() throws Throwable {\n        Map<String, Collection<String>> backingMap = new LinkedHashMap<>();\n        Supplier<List<String>> valueSupplier = ArrayList::new;\n        Multimap<String, String> multimap = Multimaps.newListMultimap(backingMap, valueSupplier);\n\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeInt(2);\n            output.writeObject(\"letters\");\n            output.writeInt(2);\n            output.writeObject(\"a\");\n            output.writeObject(\"b\");\n            output.writeObject(\"numbers\");\n            output.writeInt(1);\n            output.writeObject(\"one\");\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            serializationMethod(\n                    \"populateMultimap\",\n                    MethodType.methodType(void.class, Multimap.class, ObjectInputStream.class)).invoke(multimap, input);\n        }\n\n        assertThat(multimap.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(multimap.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(multimap.size()).isEqualTo(3);\n    }\n\n    @Test\n    void serializesAndDeserializesMultisetWithDistinctElementCounts() throws Exception {\n        HashMultiset<String> multiset = HashMultiset.create();\n        multiset.add(\"red\", 3);\n        multiset.add(\"blue\", 2);\n\n        Object roundTripped = roundTrip(multiset);\n\n        assertThat(roundTripped).isInstanceOf(HashMultiset.class);\n        HashMultiset<?> deserialized = (HashMultiset<?>) roundTripped;\n        assertThat(deserialized.count(\"red\")).isEqualTo(3);\n        assertThat(deserialized.count(\"blue\")).isEqualTo(2);\n        assertThat(deserialized.entrySet()).hasSize(2);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableListMultimapEntries() throws Exception {\n        ImmutableListMultimap<String, String> multimap = ImmutableListMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableListMultimap.class);\n        @SuppressWarnings(\"unchecked\")\n        ImmutableListMultimap<String, String> deserialized = (ImmutableListMultimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactly(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    @Test\n    void serializesAndDeserializesImmutableSetMultimapEntries() throws Exception {\n        ImmutableSetMultimap<String, String> multimap = ImmutableSetMultimap.of(\n                \"letters\", \"a\",\n                \"letters\", \"b\",\n                \"numbers\", \"one\");\n\n        Object roundTripped = roundTrip(multimap);\n\n        assertThat(roundTripped).isInstanceOf(ImmutableSetMultimap.class);\n        @SuppressWarnings(\"unchecked\")\n        ImmutableSetMultimap<String, String> deserialized = (ImmutableSetMultimap<String, String>) roundTripped;\n        assertThat(deserialized.get(\"letters\")).containsExactlyInAnyOrder(\"a\", \"b\");\n        assertThat(deserialized.get(\"numbers\")).containsExactly(\"one\");\n        assertThat(deserialized.size()).isEqualTo(3);\n    }\n\n    private static MethodHandle serializationMethod(String methodName, MethodType methodType) throws Exception {\n        Class<?> serializationClass = Class.forName(SERIALIZATION_CLASS_NAME);\n        return MethodHandles.privateLookupIn(serializationClass, MethodHandles.lookup())\n                .findStatic(serializationClass, methodName, methodType);\n    }\n\n    private static Object roundTrip(Object value) throws Exception {\n        ByteArrayOutputStream bytes = new ByteArrayOutputStream();\n        try (ObjectOutputStream output = new ObjectOutputStream(bytes)) {\n            output.writeObject(value);\n        }\n\n        try (ObjectInputStream input = new ObjectInputStream(new ByteArrayInputStream(bytes.toByteArray()))) {\n            return input.readObject();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1782732736914}, {"role": "toolResult", "toolCallId": "call_d2zPSL7hvWLbnCvP5RyhyFkQ|fc_0bdb746fda50c06e016a4257c0a9bc8193b5968baaf54b9af8", "toolName": "bash", "content": [{"type": "text", "text": "tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/build/classes/java/test/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonCollectSerializationTest.class\ntests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/build/classes/java/test/io_quarkus/quarkus_boot