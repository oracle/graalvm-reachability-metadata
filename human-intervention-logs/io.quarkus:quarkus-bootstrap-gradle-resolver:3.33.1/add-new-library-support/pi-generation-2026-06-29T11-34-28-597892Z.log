;\n        Path resource = tempDir.resolve(resourceName);\n        Files.createDirectories(resource.getParent());\n        Files.writeString(resource, \"resource loaded by ClasspathUtil\");\n        ClassLoader classLoader = new SingleResourceClassLoader(resourceName, resource.toUri().toURL());\n\n        File classpath = ClasspathUtil.getClasspathForResource(classLoader, resourceName);\n\n        assertThat(classpath).isEqualTo(tempDir.toFile());\n    }\n\n    @Test\n    void usesSystemClassLoaderWhenNoClassLoaderIsSupplied() {\n        assertThatThrownBy(() -> ClasspathUtil.getClasspathForResource(null, MISSING_RESOURCE))\n                .isInstanceOf(NullPointerException.class);\n    }\n\n    private static final class SingleResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resourceUrl;\n\n        private SingleResourceClassLoader(String resourceName, URL resourceUrl) {\n            super(ClasspathUtilTest.class.getClassLoader());\n            this.resourceName = resourceName;\n            this.resourceUrl = resourceUrl;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (resourceName.equals(name)) {\n                return resourceUrl;\n            }\n            return super.getResource(name);\n        }\n    }\n}\n"}
