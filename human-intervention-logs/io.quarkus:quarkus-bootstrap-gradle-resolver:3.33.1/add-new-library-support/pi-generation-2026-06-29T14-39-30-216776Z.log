  import java.nio.file.Path;
  
  import org.gradle.api.GradleException;
  import org.gradle.internal.classloader.ClasspathUtil;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  public class OrgGradleInternalClassloaderClasspathUtilTest {
      private static final String SYSTEM_RESOURCE = "org-gradle-classpath-util-system-resource.txt";
  
      @TempDir
      Path tempDir;
  
      @Test
      void resolvesClasspathForNamedApplicationClass() {
          try {
              File classpath = ClasspathUtil.getClasspathForClass(
                      OrgGradleInternalClassloaderClasspathUtilTest.class.getName());
  
              assertThat(classpath).isNotNull();
          } catch (GradleException exception) {
              assertThat(exception).hasMessageContaining(OrgGradleInternalClassloaderClasspathUtilTest.class.getName());
          }
      }
  
      @Test
      void probesClassResourceWhenCodeSourceIsUnavailable() {
          if (isNativeImageRuntime()) {
              File classpath = ClasspathUtil.getClasspathForClass(OrgGradleInternalClassloaderClasspathUtilTest[].class);
  
              assertThat(classpath).isNotNull();
              return;
          }
  
          assertThatThrownBy(() -> ClasspathUtil.getClasspathForClass(
                  OrgGradleInternalClassloaderClasspathUtilTest[].class))
                  .isInstanceOf(GradleException.class)
                  .hasMessageContaining(OrgGradleInternalClassloaderClasspathUtilTest[].class.getName());
      }
  
      @Test
      void resolvesClasspathForResourceFromExplicitClassLoader() throws Exception {
          String resourceName = "gradle/classpath-util-resource.txt";
          Path resource = tempDir.resolve(resourceName);
          Files.createDirectories(resource.getParent());
          Files.writeString(resource, "resource loaded by ClasspathUtil");
          ClassLoader classLoader = new SingleResourceClassLoader(resourceName, resource.toUri().toURL());
  
          File classpath = ClasspathUtil.getClasspathForResource(classLoader, resourceName);
  
          assertThat(classpath).isEqualTo(tempDir.toFile());
      }
  
      @Test
      void usesSystemClassLoaderWhenNoClassLoaderIsSupplied() {
          try {
              File classpath = ClasspathUtil.getClasspathForResource((ClassLoader) null, SYSTEM_RESOURCE);
  
              assertThat(classpath).isNotNull();
          } catch (NullPointerException exception) {
              assertThat(exception).isInstanceOf(NullPointerException.class);
          } catch (GradleException exception) {
              assertThat(exception).hasMessageContaining(SYSTEM_RESOURCE);
          }
      }
  
      private static final class SingleResourceClassLoader extends ClassLoader {
          private final String resourceName;
          private final URL resourceUrl;
  
          private SingleResourceClassLoader(String resourceName, URL resourceUrl) {
              super(OrgGradleInternalClassloaderClasspathUtilTest.class.getClassLoader());
              this.resourceName = resourceName;
              this.resourceUrl = resourceUrl;
          }
  
          @Override
          public URL getResource(String name) {
              if (resourceName.equals(name)) {
                  return resourceUrl;
              }
              return super.getResource(name);
          }
      }
  
      private static boolean isNativeImageRuntime() {
          return "runtime".equals(System.getProperty("org.graalvm.nativeimage.imagecode"));
      }
  }
