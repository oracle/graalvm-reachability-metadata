 waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.reflect.Method;\nimport java.util.List;\n\nimport org.gradle.internal.impldep.com.google.common.base.Throwables;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleInternalImpldepComGoogleCommonBaseThrowablesTest {\n    @Test\n    void invokesAccessibleMethodThroughThrowablesHelper() throws Throwable {\n        GreetingService service = new GreetingService(\"hello\");\n        Method greetMethod = GreetingService.class.getMethod(\"greet\", String.class);\n\n        Object result = invokeAccessibleNonThrowingMethod().invoke(greetMethod, service, new Object[] { \"Gradle\" });\n\n        assertThat(result).isEqualTo(\"hello, Gradle\");\n    }\n\n    @Test\n    void lazyStackTraceFallsBackToThrowableStackTraceWhenJdkInternalAccessIsUnavailable() {\n        RuntimeException failure = new RuntimeException(\"expected\");\n\n        List<StackTraceElement> lazyStackTrace = Throwables.lazyStackTrace(failure);\n\n        assertThat(Throwables.lazyStackTraceIsLazy()).isFalse();\n        assertThat(lazyStackTrace).containsExactly(failure.getStackTrace());\n    }\n\n    private static MethodHandle invokeAccessibleNonThrowingMethod() throws Exception {\n        Class<Throwables> throwablesClass = Throwables.class;\n        return MethodHandles.privateLookupIn(throwablesClass, MethodHandles.lookup())\n                .findStatic(\n                        throwablesClass,\n                        \"invokeAccessibleNonThrowingMethod\",\n                        MethodType.methodType(Object.class, Method.class, Object.class, Object[].class));\n    }\n\n    public static class GreetingService {\n        private final String greeting;\n\n        public GreetingService(String greeting) {\n            this.greeting = greeting;\n        }\n\n        public String greet(String name) {\n            return greeting + \", \" + name;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1117, "output": 1406, "cacheRead": 40448, "cacheWrite": 0, "totalTokens": 42971, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1782737062472, "responseId": "resp_07967c35b4b391cf016a4268a6f5ac8194ba89e03da42d3084"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_vrT8mEce7eCmHOXJG09gnVmJ|fc_07967c35b4b391cf016a4268b5da5481949ee9af4db4efc6c6", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2254 bytes to tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleInternalImpldepComGoogleCommonBaseThrowablesTest.java"}], "isError": false, "timestamp": 1782737082238}]}
