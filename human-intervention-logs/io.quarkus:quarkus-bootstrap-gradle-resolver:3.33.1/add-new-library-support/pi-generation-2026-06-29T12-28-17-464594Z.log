[tool-call] delta {"path":"tests/src/io.quarkus/quarkus-bootstrap-gradle-resolver/3.33.1/src/test/java/io_quarkus/quarkus_bootstrap_gradle_resolver/OrgGradleToolingInternalConsumerConnectionToolingParameterProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_quarkus.quarkus_bootstrap_gradle_resolver;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.io.File;\nimport java.util.Map;\n\nimport org.gradle.tooling.BuildAction;\nimport org.gradle.tooling.internal.consumer.connection.InternalBuildActionAdapter;\nimport org.gradle.tooling.internal.consumer.connection.ToolingParameterProxy;\nimport org.gradle.tooling.internal.consumer.versioning.VersionDetails;\nimport org.gradle.tooling.internal.protocol.BuildResult;\nimport org.gradle.tooling.internal.protocol.InternalBuildControllerVersion2;\nimport org.gradle.tooling.internal.protocol.ModelIdentifier;\nimport org.gradle.util.GradleVersion;\nimport org.junit.jupiter.api.Test;\n\npublic class OrgGradleToolingInternalConsumerConnectionToolingParameterProxyTest {\n    @Test\n    void validatesCreatesAndUnpacksParameterizedToolingModelParameters() {\n        BuildAction<Boolean> action = controller -> {\n            try {\n                controller.getModel(Void.class, SampleToolingParameter.class, parameter -> {\n                    parameter.setMessage(\"configured through proxy\");\n                    parameter.setEnabled(true);\n                });\n                return false;\n            } catch (ParameterObservedException e) {\n                assertThat(e.properties)\n                        .containsEntry(\"message\", \"configured through proxy\")\n                        .containsEntry(\"enabled\", true);\n                return true;\n            }\n        };\n\n        InternalBuildActionAdapter<Boolean> adapter = new InternalBuildActionAdapter<>(\n                action,\n                new File(\".\"),\n                VersionDetails.from(GradleVersion.current()));\n\n        assertThat(adapter.execute(new RecordingBuildController())).isTrue();\n    }\n\n    public interface SampleToolingParameter {\n        String getMessage();\n\n        void setMessage(String message);\n\n        boolean isEnabled();\n\n        void setEnabled(boolean enabled);\n    }\n\n    private static final class RecordingBuildController implements InternalBuildControllerVersion2 {\n        @Override\n        public BuildResult<?> getModel(Object target, ModelIdentifier modelIdentifier, Object parameter) {\n            assertThat(target).isNull();\n            assertThat(modelIdentifier.getName()).isEqualTo(ModelIdentifier.NULL_MODEL);\n\n            Map<String, Object> properties = ToolingParameterProxy.unpackProperties(parameter);\n            throw new ParameterObservedException(properties);\n        }\n    }\n\n    private static final class ParameterObservedException extends RuntimeException {\n        private final Map<String, Object> properties;\n\n        private ParameterObservedException(Map<String, Object> properties) {\n            this.properties = properties;\n        }\n    }\n}\n"}
