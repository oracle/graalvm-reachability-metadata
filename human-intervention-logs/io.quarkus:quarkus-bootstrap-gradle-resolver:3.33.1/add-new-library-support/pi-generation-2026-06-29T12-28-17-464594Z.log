          return false;
      }
  
      public boolean supportsParameterizedToolingModels() {
          return false;
      }
  
      public boolean supportsRunPhasedActions() {
          return false;
      }
  
      public boolean supportsPluginClasspathInjection() {
          return false;
      }
  
