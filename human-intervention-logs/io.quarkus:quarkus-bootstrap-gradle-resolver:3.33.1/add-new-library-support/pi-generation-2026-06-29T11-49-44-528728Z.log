sLoader(\n                new SingleResourceClassLoader(ALLOWED_RESOURCE, resourceUrl), spec);\n\n        URL loadedResource = classLoader.getResource(ALLOWED_RESOURCE);\n        List<URL> loadedResources = Collections.list(classLoader.getResources(ALLOWED_RESOURCE));\n\n        assertThat(loadedResource).isEqualTo(resourceUrl);\n        assertThat(loadedResources).containsExactly(resourceUrl);\n    }\n\n    @Test\n    void delegatesDisallowedResourceLookupToPlatformClassLoader() throws Exception {\n        FilteringClassLoader.Spec spec = new FilteringClassLoader.Spec();\n        FilteringClassLoader classLoader = new FilteringClassLoader(\n                new SingleResourceClassLoader(PLATFORM_RESOURCE, createResource(PLATFORM_RESOURCE)), spec);\n\n        URL loadedResource = classLoader.getResource(PLATFORM_RESOURCE);\n        Enumeration<URL> loadedResources = classLoader.getResources(PLATFORM_RESOURCE);\n\n        assertThat(loadedResource).isNotEqualTo(createResource(PLATFORM_RESOURCE));\n        assertThat(loadedResources).isNotNull();\n    }\n\n    private URL createResource(String resourceName) throws Exception {\n        Path resource = tempDir.resolve(resourceName);\n        Files.createDirectories(resource.getParent());\n        Files.writeString(resource, \"loaded by filtering class loader test\");\n        return resource.toUri().toURL();\n    }\n\n    private static final class SingleResourceClassLoader extends ClassLoader {\n        private final String resourceName;\n        private final URL resourceUrl;\n\n        private SingleResourceClassLoader(String resourceName, URL resourceUrl) {\n            super(OrgGradleInternalClassloaderFilteringClassLoaderTest.class.getClassLoader());\n            this.resourceName = resourceName;\n            this.resourceUrl = resourceUrl;\n        }\n\n        @Override\n        public URL getResource(String name) {\n            if (resourceName.equals(name)) {\n                return resourceUrl;\n            }\