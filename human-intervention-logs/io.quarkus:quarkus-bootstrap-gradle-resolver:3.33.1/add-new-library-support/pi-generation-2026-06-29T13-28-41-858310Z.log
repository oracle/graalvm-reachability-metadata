  package io_quarkus.quarkus_bootstrap_gradle_resolver;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  import org.gradle.internal.reflect.JavaMethod;
  import org.junit.jupiter.api.Test;
  
  public class OrgGradleInternalReflectJavaMethodTest {
      @Test
      void findsAndInvokesPublicInstanceMethod() {
          PublicGreetingService service = new PublicGreetingService("hello");
  
          JavaMethod<PublicGreetingService, String> method = JavaMethod.of(
                  PublicGreetingService.class,
                  String.class,
                  "greet",
                  String.class);
  
          assertThat(method.isStatic()).isFalse();
          assertThat(method.getParameterTypes()).containsExactly(String.class);
          assertThat(method.invoke(service, "Quarkus")).isEqualTo("hello, Quarkus");
      }
  
      @Test
      void fallsBackToDeclaredMethodsForPrivateInstanceMethod() {
          PrivateGreetingService service = new PrivateGreetingService("secret");
  
          JavaMethod<PrivateGreetingService, String> method = JavaMethod.of(
                  PrivateGreetingService.class,
                  String.class,
                  "formatSecretGreeting",
                  String.class);
  
          assertThat(method.isStatic()).isFalse();
          assertThat(method.invoke(service, "Gradle")).isEqualTo("secret, Gradle");
      }
  
      @Test
      void findsAndInvokesPublicStaticMethod() {
          JavaMethod<PublicGreetingService, String> method = JavaMethod.ofStatic(
                  PublicGreetingService.class,
                  String.class,
                  "staticGreeting",
                  String.class);
  
          assertThat(method.isStatic()).isTrue();
          assertThat(method.invokeStatic("Bootstrap")).isEqualTo("static hello, Bootstrap");
      }
  
      public static class PublicGreetingService {
          private final String prefix;
  
          public PublicGreetingService(String prefix) {
              this.prefix = prefix;
          }
  
          public String greet(String name) {
              return prefix + ", " + name;
          }
  
          public static String staticGreeting(String name) {
              return "static hello, " + name;
          }
      }
  
      private static class PrivateGreetingService {
          private final String prefix;
  
          PrivateGreetingService(String prefix) {
              this.prefix = prefix;
          }
  
          private String formatSecretGreeting(String name) {
              return prefix + ", " + name;
          }
      }
  }
