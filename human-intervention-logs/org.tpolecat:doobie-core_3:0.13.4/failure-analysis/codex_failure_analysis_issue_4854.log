tThat(failure).isInstanceOf(classOf[SQLException])\\n      assertThat(failure.getMessage).contains(DoobieCoreFromDriverManagerFailingDriver.failureMessage)\\n    } finally {\\n      DriverManager.deregisterDriver(driver)\\n    }\\n  }\\n}\\n\\nobject DoobieCoreFromDriverManagerFailingDriver {\\n  val url: String = \\\"jdbc:doobie-core-from-driver-manager-test\\\"\\n  val failureMessage: String = \\\"driver was loaded and asked to connect\\\"\\n}\\n\\nclass DoobieCoreFromDriverManagerFailingDriver extends Driver {\\n  override def connect(url: String, info: Properties): Connection = {\\n    if (acceptsURL(url)) {\\n      throw new SQLException(DoobieCoreFromDriverManagerFailingDriver.failureMessage)\\n    }\\n    null\\n  }\\n\\n  override def acceptsURL(url: String): Boolean =\\n    DoobieCoreFromDriverManagerFailingDriver.url == url\\n\\n  override def getPropertyInfo(url: String, info: Properties): Array[DriverPropertyInfo] =\\n    Array.empty[DriverPropertyInfo]\\n\\n  override def getMajorVersion: Int = 1\\n\\n  override def getMinorVersion: Int = 0\\n\\n  override def jdbcCompliant(): Boolean = false\\n\\n  override def getParentLogger: Logger = Logger.getGlobal\\n}\\n\"}]}\n1452:[tool-call] end id=call_RJa17QdwB4JG9mgTAfvf44SW|fc_07804db651c470730169fafaf01cc08193a8975196177b2c65 name=edit args={\"path\": \"tests/src/org.tpolecat/doobie-core_3/0.13.4/src/test/scala/org_tpolecat/doobie_core_3/TransactorInnerTransactorInnerFromDriverManagerTest.scala\", \"edits\": [{\"oldText\": \"import java.sql.SQLException\\nimport scala.concurrent.ExecutionContext\\n\\nclass TransactorInnerTransactorInnerFromDriverManagerTest {\\n  private implicit val contextShift: ContextShift[IO] = IO.contextShift(ExecutionContext.global)\\n  private val blocker: Blocker = Blocker.liftExecutionContext(ExecutionContext.global)\\n\\n  @Test\\n  @Timeout(10)\\n  def fromDriverManagerLoadsDriverClassWhenOpeningConnection(): Unit = {\\n    val xa: Transactor.Aux[IO, Unit] =\\n      Transactor.