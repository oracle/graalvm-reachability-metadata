  --- build.gradle ---
      group = "io.projectreactor.tools"
  
  --- agent/build.gradle ---
          attributes('Automatic-Module-Name': 'reactor.blockhound')
          attributes('Premain-Class': 'reactor.blockhound.BlockHound')
      exclude 'reactor/shaded/META-INF/**'
      // TODO discuss with ByteBuddy folks how to shade it
      prefix = "reactor.blockhound.shaded"
      compileOnly 'com.google.auto.service:auto-service-annotations:1.0.1'
      implementation 'net.bytebuddy:byte-buddy:1.14.4'    
      implementation 'net.bytebuddy:byte-buddy-agent:1.14.4'
      compileOnly 'io.projectreactor:reactor-core:3.2.5.RELEASE'
      compileOnly 'io.reactivex.rxjava2:rxjava:2.2.18'
      jarFileTestImplementation 'org.assertj:assertj-core:3.24.2'
      jarFileTestImplementation 'junit:junit:4.13.2'
  	src "${repositories.mavenCentral().url}io/projectreactor/tools/blockhound/$compatibleVersion/blockhound-${compatibleVersion}.jar"
  			'reactor.blockhound.shaded.*'
  			'reactor.blockhound.AllowancesByteBuddyTransformer$AllowedArgument$Factory',
  			'reactor.blockhound.BlockingCallsByteBuddyTransformer$ModifiersArgument$Factory'
  
  --- example/build.gradle ---
      reactor_3_3_x {
          extendsFrom(testRuntimeOnly, testImplementation)
  task testReactor3_3_x(type: Test) {
      classpath = sourceSets.test.output.classesDirs + configurations.reactor_3_3_x
      include 'com/example/ReactorTest**'
  check.dependsOn(testReactor3_3_x)
      testImplementation project(path: ":agent", configuration: 'shadow')
      testImplementation 'io.projectreactor:reactor-core:3.2.5.RELEASE'
      testImplementation 'io.reactivex.rxjava2:rxjava:2.2.18'
      testImplementation 'junit:junit:4.13.2'
      testImplementation 'org.assertj:assertj-core:3.24.2'
      reactor_3_3_x 'io.projectreactor:reactor-core:3.2.5.RELEASE'
  
  --- gradle.properties ---
