{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,220p' tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/LambdaFactoryTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport java.lang.instrument.ClassFileTransformer;\nimport java.lang.reflect.Method;\nimport java.security.ProtectionDomain;\nimport java.util.ArrayList;\nimport java.util.Collection;\nimport java.util.Collections;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Map;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.parallel.ResourceLock;\n\nimport reactor.blockhound.shaded.net.bytebuddy.agent.builder.LambdaFactory;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LambdaFactoryTest {\n    private static final String BYTE_BUDDY_EXPERIMENTAL_PROPERTY =\n            \"reactor.blockhound.shaded.net.bytebuddy.experimental\";\n    private static final byte[] CLASS_BYTES = new byte[] {1, 2, 3, 4};\n\n    static {\n        System.setProperty(BYTE_BUDDY_EXPERIMENTAL_PROPERTY, \"true\");\n    }\n\n    @Test\n    @ResourceLock(\"lambda-factory-transformers\")\n    void registerAndReleaseTransformerThroughInjectedFactory() {\n        ClassFileTransformer transformer = new NoOpClassFileTransformer();\n        Dispatcher dispatcher = new Dispatcher();\n\n        try {\n            boolean firstRegistration = LambdaFactory.register(transformer, dispatcher);\n            assertThat(firstRegistration).isTrue();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n            return;\n        } catch (RuntimeException exception) {\n            if (!isCausedByUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n            return;\n        }\n\n        try {\n            assertThat(LambdaFactory.release(transformer)).isTrue();\n            assertThat(LambdaFactory.release(transformer)).isFalse();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (RuntimeException exception) {\n            if (!isCausedByUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n        }\n    }\n\n    @Test\n    @ResourceLock(\"lambda-factory-transformers\")\n    void makeDelegatesToRegisteredDispatcher() throws Exception {\n        Map<ClassFileTransformer, LambdaFactory> previousFactories = new LinkedHashMap<>(\n                LambdaFactory.CLASS_FILE_TRANSFORMERS);\n        LambdaFactory.CLASS_FILE_TRANSFORMERS.clear();\n\n        try {\n            ClassFileTransformer transformer = new NoOpClassFileTransformer();\n            Dispatcher dispatcher = new Dispatcher();\n            Method makeMethod = Dispatcher.class.getMethod(\n                    \"make\",\n                    Object.class,\n                    String.class,\n                    Object.class,\n                    Object.class,\n                    Object.class,\n                    Object.class,\n                    boolean.class,\n                    List.class,\n                    List.class,\n                    Collection.class);\n            LambdaFactory.CLASS_FILE_TRANSFORMERS.put(transformer, new LambdaFactory(dispatcher, makeMethod));\n\n            Object caller = new Object();\n            Object invokedType = new Object();\n            Object samMethodType = new Object();\n            Object implMethod = new Object();\n            Object instantiatedMethodType = new Object();\n            List<Class<?>> markerInterfaces = Collections.singletonList(Runnable.class);\n            List<Object> additionalBridges = Collections.singletonList(\"bridge\");\n\n            byte[] generatedBytes = LambdaFactory.make(\n                    caller,\n                    \"run\",\n                    invokedType,\n                    samMethodType,\n                    implMethod,\n                    instantiatedMethodType,\n                    true,\n                    markerInterfaces,\n                    additionalBridges);\n\n            assertThat(generatedBytes).isSameAs(CLASS_BYTES);\n            assertThat(dispatcher.invocations).hasSize(1);\n            Invocation invocation = dispatcher.invocations.get(0);\n            assertThat(invocation.caller).isSameAs(caller);\n            assertThat(invocation.methodName).isEqualTo(\"run\");\n            assertThat(invocation.invokedType).isSameAs(invokedType);\n            assertThat(invocation.samMethodType).isSameAs(samMethodType);\n            assertThat(invocation.implMethod).isSameAs(implMethod);\n            assertThat(invocation.instantiatedMethodType).isSameAs(instantiatedMethodType);\n            assertThat(invocation.serializable).isTrue();\n            assertThat(invocation.markerInterfaces).isSameAs(markerInterfaces);\n            assertThat(invocation.additionalBridges).isSameAs(additionalBridges);\n            assertThat(invocation.classFileTransformers).containsExactly(transformer);\n        } finally {\n            LambdaFactory.CLASS_FILE_TRANSFORMERS.clear();\n            LambdaFactory.CLASS_FILE_TRANSFORMERS.putAll(previousFactories);\n        }\n    }\n\n    private static boolean isCausedByUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable.getCause();\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    public static final class Dispatcher {\n        private final List<Invocation> invocations = new ArrayList<>();\n\n        public byte[] make(Object caller, String methodName, Object invokedType, Object samMethodType,\n                Object implMethod, Object instantiatedMethodType, boolean serializable,\n                List<Class<?>> markerInterfaces, List<?> additionalBridges,\n                Collection<ClassFileTransformer> classFileTransformers) {\n            invocations.add(new Invocation(\n                    caller,\n                    methodName,\n                    invokedType,\n                    samMethodType,\n                    implMethod,\n                    instantiatedMethodType,\n                    serializable,\n                    markerInterfaces,\n                    additionalBridges,\n                    classFileTransformers));\n            return CLASS_BYTES;\n        }\n    }\n\n    private static final class Invocation {\n        private final Object caller;\n        private final String methodName;\n        private final Object invokedType;\n        private final Object samMethodType;\n        private final Object implMethod;\n        private final Object instantiatedMethodType;\n        private final boolean serializable;\n        private final List<Class<?>> markerInterfaces;\n        private final List<?> additionalBridges;\n        private final Collection<ClassFileTransformer> classFileTransformers;\n\n        private Invocation(Object caller, String methodName, Object invokedType, Object samMethodType,\n                Object implMethod, Object instantiatedMethodType, boolean serializable,\n                List<Class<?>> markerInterfaces, List<?> additionalBridges,\n                Collection<ClassFileTransformer> classFileTransformers) {\n            this.caller = caller;\n            this.methodName = methodName;\n            this.invokedType = invokedType;\n            this.samMethodType = samMethodType;\n            this.implMethod = implMethod;\n            this.instantiatedMethodType = instantiatedMethodType;\n            this.serializable = serializable;\n            this.markerInterfaces = markerInterfaces;\n            this.additionalBridges = additionalBridges;\n            this.classFileTransformers = classFileTransformers;\n        }\n    }\n\n    private static final class NoOpClassFileTransformer implements ClassFileTransformer {\n        @Override\n        public byte[] transform(ClassLoader loader, String className, Class<?> classBeingRedefined,\n                ProtectionDomain protectionDomain, byte[] classfileBuffer) {\n            return null;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
