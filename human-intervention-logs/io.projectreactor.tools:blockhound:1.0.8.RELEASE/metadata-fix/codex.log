{"type":"item.completed","item":{"id":"item_159","type":"command_execution","command":"/usr/bin/bash -lc \"sed -n '1,240p' tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/AttacherTest.java\"","aggregated_output":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.parallel.ResourceLock;\n\nimport reactor.blockhound.shaded.net.bytebuddy.agent.Attacher;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@ResourceLock(\"attacher-recording-virtual-machine\")\npublic class AttacherTest {\n    @BeforeEach\n    void resetRecordingVirtualMachine() {\n        RecordingVirtualMachine.reset();\n    }\n\n    @Test\n    void mainAttachesAgentFromJarAndDetachesVirtualMachine() {\n        Attacher.main(new String[] {\n            RecordingVirtualMachine.class.getName(),\n            \"12345\",\n            \"agent.jar\",\n            \"false\",\n            \"=alpha\",\n            \"beta\"\n        });\n\n        assertThat(RecordingVirtualMachine.attachedProcessId).isEqualTo(\"12345\");\n        assertThat(RecordingVirtualMachine.loadedAgent).isEqualTo(\"agent.jar\");\n        assertThat(RecordingVirtualMachine.loadedAgentArgument).isEqualTo(\"alpha beta\");\n        assertThat(RecordingVirtualMachine.loadedAgentPath).isNull();\n        assertThat(RecordingVirtualMachine.detached).isTrue();\n    }\n\n    @Test\n    void mainAttachesAgentFromNativePathAndDetachesVirtualMachine() {\n        Attacher.main(new String[] {\n            RecordingVirtualMachine.class.getName(),\n            \"67890\",\n            \"native-agent\",\n            \"true\",\n            \"\"\n        });\n\n        assertThat(RecordingVirtualMachine.attachedProcessId).isEqualTo(\"67890\");\n        assertThat(RecordingVirtualMachine.loadedAgentPath).isEqualTo(\"native-agent\");\n        assertThat(RecordingVirtualMachine.loadedAgentArgument).isNull();\n        assertThat(RecordingVirtualMachine.loadedAgent).isNull();\n        assertThat(RecordingVirtualMachine.detached).isTrue();\n    }\n\n    public static final class RecordingVirtualMachine {\n        private static String attachedProcessId;\n        private static String loadedAgent;\n        private static String loadedAgentPath;\n        private static String loadedAgentArgument;\n        private static boolean detached;\n\n        private RecordingVirtualMachine() {\n        }\n\n        public static RecordingVirtualMachine attach(String processId) {\n            attachedProcessId = processId;\n            return new RecordingVirtualMachine();\n        }\n\n        public void loadAgent(String agent, String argument) {\n            loadedAgent = agent;\n            loadedAgentArgument = argument;\n        }\n\n        public void loadAgentPath(String agentPath, String argument) {\n            loadedAgentPath = agentPath;\n            loadedAgentArgument = argument;\n        }\n\n        public void detach() {\n            detached = true;\n        }\n\n        private static void reset() {\n            attachedProcessId = null;\n            loadedAgent = null;\n            loadedAgentPath = null;\n            loadedAgentArgument = null;\n            detached = false;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
