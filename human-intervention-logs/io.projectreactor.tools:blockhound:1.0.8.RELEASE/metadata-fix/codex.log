tor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@TestMethodOrder(OrderAnnotation.class)\npublic class NexusAccessorInnerDispatcherInnerCreationActionTest {\n    private static final String MODULE_NAME = \"blockhound.nexus.creationaction\";\n    private static final String NEXUS_CLASS = \"reactor.blockhound.shaded.net.bytebuddy.dynamic.Nexus\";\n    private static final String NEXUS_ACCESSOR_CLASS =\n            \"reactor.blockhound.shaded.net.bytebuddy.dynamic.NexusAccessor\";\n\n    @TempDir\n    Path tempDirectory;\n\n    @Test\n    @Order(1)\n    @SuppressWarnings(\"removal\")\n    void creationActionFallsBackToSystemNexusWhenReflectiveInjectionIsDenied() throws Exception {\n        SecurityManager previousSecurityManager = null;\n        boolean securityManagerChanged = false;\n        Object dispatcher;\n        try {\n            assertThat(ClassInjector.UsingReflection.isAvailable()).isTrue();\n            previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(new DenyingAccessibleObjectSecurityManager());\n            securityManagerChanged = true;\n\n            dispatcher = ExposedNexusAccessor.creationAction().run();\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception).isNotNull();\n            return;\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n            return;\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n\n        assertThat(ExposedNexusAccessor.isDispatcherAlive(dispatcher)).isTrue();\n    }\n\n    @Test\n    @Order(2)\n    void systemAccessorCreationInjectsNexusAndResolvesItsPublicMethods() {\n        try {\n            assertThat(NexusAccessor.isAlive()).isTrue();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @Order(3)\n    void childFirstAccessorWithoutResourcesFallsBackToSystemNexus() throws Exception {\n        try {\n            ClassLoader classLoader = new ByteArrayClassLoader.ChildFirst(\n                    NexusAccessorInnerDispatcherInnerCreationActionTest.class.getClassLoader(),\n                    readClassBytesToNames(NEXUS_CLASS,\n                            NEXUS_ACCESSOR_CLASS,\n                            NEXUS_ACCESSOR_CLASS + \"$Dispatcher\",\n                            NEXUS_ACCESSOR_CLASS + \"$Dispatcher$CreationAction\",\n                            NEXUS_ACCESSOR_CLASS + \"$Dispatcher$Available\",\n                            NEXUS_ACCESSOR_CLASS + \"$Dispatcher$Unavailable\"),\n                    null,\n                    ByteArrayClassLoader.PersistenceHandler.LATENT,\n                    PackageDefinitionStrategy.NoOp.INSTANCE);\n            Class<?> accessor = classLoader.loadClass(NEXUS_ACCESSOR_CLASS);\n\n            Object alive = accessor.getMethod(\"isAlive\").invoke(null);\n\n            assertThat(alive).isEqualTo(Boolean.TRUE);\n        } catch (InvocationTargetException exception) {\n            rethrowInvocationTarget(exception);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @Order(4)\n    void namedModuleAccessorFallsBackToSystemNexusAndAddsReadEdge() throws Exception {\n        try {\n            String targetModule = MODULE_NAME + \".target\";\n            Path targetModules = tempDirectory.resolve(\"target-modules\");\n            Path targetModuleRoot = targetModules.resolve(targetModule);\n            copyLibraryClasses(targetModuleRoot);\n            writeAndCompileModuleDescriptor(targetModule, targetModuleRoot);\n\n            Process process = new ProcessBuilder(javaExecutable().toString(),\n                    \"--add-opens=java.base/java.lang=ALL-UNNAMED\",\n                    \"--module-path\", targetModules.toString(),\n                    \"--add-modules\", targetModule,\n                    \"-cp\", probeClassPath().toString(),\n                    NexusAccessorCreationActionReadEdgeProbe.class.getName(),\n                    locateLibraryJar().toString(),\n                    MODULE_NAME,\n                    targetModule)\n                    .redirectOutput(Redirect.INHERIT)\n                    .redirectError(Redirect.INHERIT)\n                    .start();\n\n            assertThat(waitForProcess(process, \"nexus read edge probe\")).isEqualTo(0);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    private static Map<String, byte[]> readClassBytesToNames(String... classNames) throws IOException {\n        Map<String, byte[]> typeDefinitions = new LinkedHashMap<>();\n        ClassLoader classLoader = NexusAccessorInnerDispatcherInnerCreationActionTest.class.getClassLoader();\n        for (String className : classNames) {\n            String resourceName = className.replace('.', '/') + \".class\";\n            try (InputStream inputStream = classLoader.getResourceAsStream(resourceName)) {\n                if (inputStream == null) {\n                    throw new IllegalStateException(\"Cannot locate class resource \" + resourceName);\n                }\n                typeDefinitions.put(className, inputStream.readAllBytes());\n            }\n        }\n        return typeDefinitions;\n    }\n\n    private static void copyLibraryClasses(Path moduleRoot) throws IOException {\n        try (JarFile jarFile = new JarFile(locateLibraryJar().toFile())) {\n            Enumeration<JarEntry> entries = jarFile.entries();\n            while (entries.hasMoreElements()) {\n                JarEntry entry = entries.nextElement();\n                if (entry.isDirectory() || !entry.getName().endsWith(\".class\")) {\n                    continue;\n                }\n                Path target = moduleRoot.resolve(entry.getName());\n                Files.createDirectories(target.getParent());\n                try (InputStream inputStream = jarFile.getInputStream(entry)) {\n                    Files.copy(inputStream, target);\n                }\n            }\n        }\n    }\n\n    private static void writeAndCompileModuleDescriptor(String moduleName, Path moduleRoot)\n            throws IOException, InterruptedException {\n        Files.writeString(moduleRoot.resolve(\"module-info.java\"), \"\"\"\n                module %s {\n                    requires java.instrument;\n                    exports reactor.blockhound.shaded.net.bytebuddy.dynamic;\n                }\n                \"\"\".formatted(moduleName));\n        Process process = new ProcessBuilder(javacExecutable().toString(),\n                \"-d\", moduleRoot.toString(),\n                moduleRoot.resolve(\"module-info.java\").toString())\n                .redirectOutput(Redirect.INHERIT)\n                .redirectError(Redirect.INHERIT)\n                .start();\n        int exitCode = waitForProcess(process, \"javac\");\n        if (exitCode != 0) {\n            throw new IllegalStateException(\"Could not compile modular BlockHound fixture: javac exited \" + exitCode);\n        }\n    }\n\n    private static int waitForProcess(Process process, String description) throws InterruptedException {\n        if (!process.waitFor(30, TimeUnit.SECONDS)) {\n            process.destroyForcibly();\n            throw new IllegalStateException(description + \" did not complete within 30 seconds\");\n        }\n        return process.exitValue();\n    }\n\n    private static Path javaExecutable() {\n        return javaHomeExecutable(\"java\");\n    }\n\n    private static Path javacExecutable() {\n        return javaHomeExecutable(\"javac\");\n    }\n\n    private static Path javaHomeExecutable(String executableName) {\n        String executable = System.getProperty(\"os.name\", \"\").toLowerCase().contains(\"windows\")\n                ? executableName + \".exe\"\n                : executableName;\n        return Path.of(System.getProperty(\"java.home\"), \"bin\", executable);\n    }\n\n    private static Path probeClassPath() {\n        CodeSource codeSource = NexusAccessorCreationActionReadEdgeProbe.class\n                .getProtectionDomain()\n                .getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLocation().getProtocol())) {\n            throw new IllegalStateException(\"Cannot locate nexus read edge probe classes\");\n        }\n        try {\n","exit_code":0,"status":"completed"}}
