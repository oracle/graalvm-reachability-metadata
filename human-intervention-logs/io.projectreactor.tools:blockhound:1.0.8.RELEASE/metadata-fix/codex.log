l();\n            assertThat(definedPackage.getName()).isEqualTo(PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n\n            Class<?> loaded = dispatcher.defineClass(classLoader, className, generatedTypeBytes(className));\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n            assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loaded);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void directDispatcherInitializesWithSecurityManager() throws Exception {\n        SecurityManager previousSecurityManager = null;\n        boolean securityManagerChanged = false;\n        try {\n            previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(new PermissiveSecurityManager());\n            securityManagerChanged = true;\n\n            DirectHarness.DispatcherHarness dispatcher = DirectHarness.createDispatcher();\n\n            assertThat(dispatcher).isNotNull();\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception).isNotNull();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static byte[] generatedTypeBytes(String className) {\n        DynamicType.Unloaded<Object> generatedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .defineField(\"marker\", String.class, Visibility.PUBLIC)\n                .make();\n        return generatedType.getBytes();\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static class PackageAwareClassLoader extends ClassLoader {\n        PackageAwareClassLoader() {\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.class.getClassLoader());\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            permission.getClass();\n        }\n    }\n}\n\nfinal class DirectHarness extends ClassInjector.UsingReflection {\n    DirectHarness(ClassLoader classLoader) {\n        super(classLoader);\n    }\n\n    static DispatcherHarness createDispatcher() throws Exception {\n        Dispatcher.Initializable initializable = ExposedDirect.makeDispatcher();\n        assertThat(initializable.isAvailable()).isTrue();\n        return new DispatcherHarness(initializable.initialize());\n    }\n\n    static final class DispatcherHarness {\n        private final Dispatcher dispatcher;\n\n        private DispatcherHarness(Dispatcher dispatcher) {\n            this.dispatcher = dispatcher;\n        }\n\n        Class<?> findClass(ClassLoader classLoader, String className) {\n            return dispatcher.findClass(classLoader, className);\n        }\n\n        Class<?> defineClass(ClassLoader classLoader, String className, byte[] binaryRepresentation) {\n            return dispatcher.defineClass(classLoader, className, binaryRepresentation,\n                    getClass().getProtectionDomain());\n        }\n\n        Package getDefinedPackage(ClassLoader classLoader, String packageName) {\n            return dispatcher.getDefinedPackage(classLoader, packageName);\n        }\n\n        Package getPackage(ClassLoader classLoader, String packageName) {\n            return dispatcher.getPackage(classLoader, packageName);\n        }\n\n        Package definePackage(ClassLoader classLoader, String packageName, String specificationTitle,\n                String specificationVersion, String specificationVendor, String implementationTitle,\n                String implementationVersion, String implementationVendor, URL sealBase) {\n            return dispatcher.definePackage(classLoader, packageName, specificationTitle, specificationVersion,\n                    specificationVendor, implementationTitle, implementationVersion, implementationVendor, sealBase);\n        }\n    }\n\n    private abstract static class ExposedDirect extends Dispatcher.Direct {\n        ExposedDirect() {\n            super(null, null, null, null, null);\n        }\n\n        static Dispatcher.Initializable makeDispatcher() throws Exception {\n            return make();\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
