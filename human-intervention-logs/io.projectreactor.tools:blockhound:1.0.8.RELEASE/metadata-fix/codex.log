tRegistration).isTrue();\n            assertThat(classFile).containsExactly(GENERATED_CLASS_FILE);\n            assertThat(classFileFactory.caller).isSameAs(LambdaFactoryTest.class);\n            assertThat(classFileFactory.invokedName).isEqualTo(\"run\");\n            assertThat(classFileFactory.invokedType).isEqualTo(\"factoryType\");\n            assertThat(classFileFactory.samMethodType).isEqualTo(\"samMethodType\");\n            assertThat(classFileFactory.implMethod).isEqualTo(\"implementationHandle\");\n            assertThat(classFileFactory.instantiatedMethodType).isEqualTo(\"instantiatedMethodType\");\n            assertThat(classFileFactory.serializable).isTrue();\n            assertThat(classFileFactory.markerInterfaces).containsExactly(Runnable.class);\n            assertThat(classFileFactory.additionalBridges).hasSize(1);\n            assertThat(classFileFactory.additionalBridges.get(0)).isEqualTo(\"bridge\");\n            assertThat(classFileFactory.classFileTransformers).containsExactly(classFileTransformer);\n            assertThat(LambdaFactory.release(classFileTransformer)).isTrue();\n            registered = false;\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        } finally {\n            if (registered) {\n                LambdaFactory.release(classFileTransformer);\n            }\n        }\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static final class RecordingClassFileFactory {\n        private Object caller;\n        private String invokedName;\n        private Object invokedType;\n        private Object samMethodType;\n        private Object implMethod;\n        private Object instantiatedMethodType;\n        private boolean serializable;\n        private List<Class<?>> markerInterfaces;\n        private List<?> additionalBridges;\n        private Collection<ClassFileTransformer> classFileTransformers;\n\n        public byte[] make(Object caller, String invokedName, Object invokedType, Object samMethodType,\n                Object implMethod, Object instantiatedMethodType, boolean serializable, List<Class<?>> markerInterfaces,\n                List<?> additionalBridges, Collection<ClassFileTransformer> classFileTransformers) {\n            this.caller = caller;\n            this.invokedName = invokedName;\n            this.invokedType = invokedType;\n            this.samMethodType = samMethodType;\n            this.implMethod = implMethod;\n            this.instantiatedMethodType = instantiatedMethodType;\n            this.serializable = serializable;\n            this.markerInterfaces = markerInterfaces;\n            this.additionalBridges = additionalBridges;\n            this.classFileTransformers = classFileTransformers;\n            return GENERATED_CLASS_FILE;\n        }\n    }\n\n    private static final class RecordingClassFileTransformer implements ClassFileTransformer {\n        @Override\n        public byte[] transform(ClassLoader loader, String className, Class<?> classBeingRedefined,\n                ProtectionDomain protectionDomain, byte[] classfileBuffer) {\n            return null;\n        }\n    }\n}\n","exit_code":0,"status":"completed"}}
