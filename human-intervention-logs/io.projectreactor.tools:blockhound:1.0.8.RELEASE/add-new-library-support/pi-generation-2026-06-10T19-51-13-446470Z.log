  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypeDescriptionInnerLazyProxyTest {
      @Test
      void objectConstantLazilyDelegatesToLoadedTypeDescription() {
          try {
              TypeDescription objectType = TypeDescription.OBJECT;
  
              assertThat(objectType.represents(Object.class)).isTrue();
              assertThat(objectType.getTypeName()).isEqualTo(Object.class.getName());
              assertThat(objectType.getInternalName()).isEqualTo("java/lang/Object");
              assertThat(objectType.asGenericType().asErasure().represents(Object.class)).isTrue();
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  }
