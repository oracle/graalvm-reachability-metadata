  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassFileLocatorInnerForModuleTest {
      @Test
      void bootLayerLocatorResolvesClassesFromNamedJdkModules() throws Exception {
          try (ClassFileLocator classFileLocator = ClassFileLocator.ForModule.ofBootLayer()) {
              ClassFileLocator.Resolution stringResolution = classFileLocator.locate("java.lang.String");
              ClassFileLocator.Resolution missingResolution = classFileLocator.locate("java.lang.DoesNotExist");
  
              assertThat(stringResolution.isResolved()).isTrue();
              assertThat(stringResolution.resolve()).isNotEmpty();
              assertThat(missingResolution.isResolved()).isFalse();
          }
      }
  }
