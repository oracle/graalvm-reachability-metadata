[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/GraalImageCodeInnerImageCodeContextActionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.utility.GraalImageCode;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class GraalImageCodeInnerImageCodeContextActionTest {\n    @Test\n    void graalVmHostDetectionReadsRuntimeInputArguments() {\n        String previousVendor = System.getProperty(\"java.vm.vendor\");\n        try {\n            System.setProperty(\"java.vm.vendor\", \"GraalVM Community\");\n\n            GraalImageCode current = GraalImageCode.getCurrent();\n\n            assertThat(current).isNotNull();\n            if (System.getProperty(\"org.graalvm.nativeimage.imagecode\") == null) {\n                assertThat(current).isIn(GraalImageCode.NONE, GraalImageCode.AGENT);\n            }\n        } finally {\n            if (previousVendor == null) {\n                System.clearProperty(\"java.vm.vendor\");\n            } else {\n                System.setProperty(\"java.vm.vendor\", previousVendor);\n            }\n        }\n    }\n}\n"}
