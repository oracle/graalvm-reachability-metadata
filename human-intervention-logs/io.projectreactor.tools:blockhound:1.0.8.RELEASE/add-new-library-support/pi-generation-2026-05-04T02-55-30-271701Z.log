  package io_projectreactor_tools.blockhound;
  
  import java.net.URL;
  import java.security.Permission;
  import java.util.Objects;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.parallel.ResourceLock;
  
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  @SuppressWarnings("removal")
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {
      private static final String BYTE_BUDDY_EXPERIMENTAL_PROPERTY =
              "reactor.blockhound.shaded.net.bytebuddy.experimental";
      private static final String BYTE_BUDDY_SAFE_PROPERTY = "reactor.blockhound.shaded.net.bytebuddy.safe";
      private static final String PACKAGE_PREFIX = "io_projectreactor_tools.blockhound.generated.unsafeoverride";
  
      @Test
      @ResourceLock("system-properties-and-security-manager")
      void unsafeOverrideDispatcherCreatedByByteBuddyInvokesClassLoaderMethods() {
          String previousExperimentalProperty = System.getProperty(BYTE_BUDDY_EXPERIMENTAL_PROPERTY);
          String previousSafeProperty = System.getProperty(BYTE_BUDDY_SAFE_PROPERTY);
          SecurityManager previousSecurityManager = System.getSecurityManager();
          boolean securityManagerInstalled = false;
  
          try {
              System.setProperty(BYTE_BUDDY_EXPERIMENTAL_PROPERTY, "true");
              System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "false");
              securityManagerInstalled = installSecurityManagerIfSupported(new PermissiveSecurityManager());
  
              UnsafeOverrideHarness.exerciseDispatcherCreatedByMake();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } catch (RuntimeException exception) {
              if (!isCausedByUnsupportedFeatureError(exception)) {
                  throw exception;
              }
          } catch (Exception exception) {
              throw new IllegalStateException(exception);
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(previousSecurityManager);
              }
              restoreProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);
              restoreProperty(BYTE_BUDDY_EXPERIMENTAL_PROPERTY, previousExperimentalProperty);
          }
      }
  
      private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {
          try {
              System.setSecurityManager(securityManager);
              return System.getSecurityManager() == securityManager;
          } catch (UnsupportedOperationException | SecurityException exception) {
              return false;
          }
      }
  
      private static boolean isCausedByUnsupportedFeatureError(Throwable throwable) {
          Throwable current = throwable.getCause();
          while (current != null) {
              if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {
                  return true;
              }
              current = current.getCause();
          }
          return false;
      }
  
      private static void restoreProperty(String propertyName, String previousValue) {
          if (previousValue == null) {
              System.clearProperty(propertyName);
          } else {
              System.setProperty(propertyName, previousValue);
          }
      }
  
      private static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
          }
      }
  
      private static final class OverrideDispatcherClassLoader extends ClassLoader {
          private OverrideDispatcherClassLoader(ClassLoader parent) {
              super(parent);
          }
      }
  
      private static final class UnsafeOverrideHarness extends ClassInjector.UsingReflection {
          private UnsafeOverrideHarness(ClassLoader classLoader) {
              super(classLoader);
          }
  
          private static void exerciseDispatcherCreatedByMake() throws Exception {
              Dispatcher.Initializable initializable = ExposedUnsafeOverrideDispatcher.makeDispatcher();
              assertThat(initializable.isAvailable()).isTrue();
              Dispatcher dispatcher = initializable.initialize();
  
              OverrideDispatcherClassLoader classLoader = new OverrideDispatcherClassLoader(
                      ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class
                              .getClassLoader());
              String packageName = PACKAGE_PREFIX + Long.toUnsignedString(java.lang.System.nanoTime());
              String className = packageName + ".Injected";
              byte[] classFile = new ByteBuddy()
                      .subclass(Object.class)
                      .name(className)
                      .make()
                      .getBytes();
  
              Object classLoadingLock = dispatcher.getClassLoadingLock(classLoader, className);
              assertThat(classLoadingLock).isNotNull();
  
              synchronized (classLoadingLock) {
                  assertThat(dispatcher.findClass(classLoader, className)).isNull();
                  assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();
  
                  Package definedPackage = dispatcher.definePackage(
                          classLoader,
                          packageName,
                          "specification-title",
                          "1",
                          "specification-vendor",
                          "implementation-title",
                          "2",
                          "implementation-vendor",
                          (URL) null);
                  assertThat(definedPackage.getName()).isEqualTo(packageName);
                  assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isSameAs(definedPackage);
                  assertThat(dispatcher.getPackage(classLoader, packageName)).isSameAs(definedPackage);
  
                  Class<?> definedClass = dispatcher.defineClass(classLoader, className, classFile, null);
                  assertThat(definedClass.getName()).isEqualTo(className);
                  assertThat(definedClass.getClassLoader()).isSameAs(classLoader);
                  assertThat(dispatcher.findClass(classLoader, className)).isSameAs(definedClass);
                  assertThat(Objects.requireNonNull(definedClass.getPackage()).getName()).isEqualTo(packageName);
              }
          }
  
          private abstract static class ExposedUnsafeOverrideDispatcher extends Dispatcher.UsingUnsafeOverride {
              private ExposedUnsafeOverrideDispatcher() {
                  super(null, null, null, null, null);
              }
  
              private static Dispatcher.Initializable makeDispatcher() throws Exception {
                  return make();
              }
          }
      }
  }
