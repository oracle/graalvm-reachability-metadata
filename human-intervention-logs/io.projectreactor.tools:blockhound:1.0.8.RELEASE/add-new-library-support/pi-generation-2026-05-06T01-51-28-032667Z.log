.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String PACKAGE_NAME = \"io_projectreactor_tools.blockhound.generated\";\n\n    static {\n        System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n    }\n\n    @Test\n    void injectionDefinesClassAndPackageThroughUnsafeReflectionDispatcher() {\n        try {\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\n            String className = PACKAGE_NAME + \".InjectedType\";\n\n            Class<?> loaded = generatedType(className)\n                    .load(classLoader, packageDefiningInjection())\n                    .getLoaded();\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n            assertThat(loaded.getPackage()).isNotNull();\n            assertThat(loaded.getPackage().getName()).isEqualTo(PACKAGE_NAME);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    void rejectedPackageDefinitionExercisesPackageFallback() {\n        try {\n            RejectingPackageClassLoader classLoader = new RejectingPackageClassLoader();\n            String className = PACKAGE_NAME + \".RejectedPackageType\";\n\n            generatedType(className).load(classLoader, packageDefiningInjection());\n            throw new AssertionError(\"Expected package definition to be rejected\");\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(RejectingPackageClassLoader.REJECTION_MESSAGE);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void injectionInitializesUnsafeReflectionDispatcherWithSecurityManager() {\n        SecurityManager previousSecurityManager = null;\n        boolean securityManagerChanged = false;\n        try {\n            previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(new PermissiveSecurityManager());\n            securityManagerChanged = true;\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\n            String className = PACKAGE_NAME + \".SecurityManagedType\";\n\n            Class<?> loaded = generatedType(className)\n                    .load(classLoader, ClassLoadingStrategy.Default.INJECTION)\n                    .getLoaded();\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception).isNotNull();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static DynamicType.Unloaded<Object> generatedType(String className) {\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .defineField(\"marker\", String.class, Visibility.PUBLIC)\n                .make();\n    }\n\n    private static ClassLoadingStrategy.Configurable<ClassLoader> packageDefiningInjection() {\n        return ClassLoadingStrategy.Default.INJECTION.with(definingPackages());\n    }\n\n    private static PackageDefinitionStrategy definingPackages() {\n        return (classLoader, packageName, typeName) -> PackageDefinitionStrategy.Definition.Trivial.INSTANCE;\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static class PackageAwareClassLoader extends ClassLoader {\n        PackageAwareClassLoader() {\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            permission.getClass();\n        }\n    }\n\n    private static final class RejectingPackageClassLoader extends PackageAwareClassLoader {\n        private static final String REJECTION_MESSAGE = \"deliberate package rejection\";\n\n        @Override\n        protected Package definePackage(String name, String specificationTitle, String specificationVersion,\n                String specificationVendor, String implementationTitle, String implementationVersion,\n                String implementationVendor, URL sealBase) {\n            throw new IllegalStateException(REJECTION_MESSAGE);\n        }\n\n        @Override\n        protected Package getPackage(String name) {\n            return null;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778032226920}, {"role": "toolResult", "toolCallId": "call_ie5xr2EQDjjd9VjOc5o6MqOk|fc_0e0402c8787bbe490169fa9e62943881a0b56cc576d3f25133", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {\n    testImplementation \"io.projectreactor.tools:blockhound:$libraryVersion\"\n    test