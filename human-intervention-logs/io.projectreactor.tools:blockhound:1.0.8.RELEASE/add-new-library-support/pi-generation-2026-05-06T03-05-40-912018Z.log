rectTest {\n    private static final String PACKAGE_NAME = \"io_projectreactor_tools.blockhound.direct.generated\";\n\n    @Test\n    void directDispatcherDefinesAndFindsClassesAndPackages() throws Exception {\n        try {\n            DirectHarness.DispatcherHarness dispatcher = DirectHarness.createDispatcher();\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\n            String className = PACKAGE_NAME + \".InjectedType\";\n\n            assertThat(dispatcher.findClass(classLoader, className)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(classLoader, PACKAGE_NAME,\n                    \"specification-title\", \"1\", \"specification-vendor\",\n                    \"implementation-title\", \"1\", \"implementation-vendor\", null);\n            assertThat(definedPackage).isNotNull();\n            assertThat(definedPackage.getName()).isEqualTo(PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n\n            Class<?> loaded = dispatcher.defineClass(classLoader, className, generatedTypeBytes(className));\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n            assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loaded);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void directDispatcherInitializesWithSecurityManager() throws Exception {\n        SecurityManager previousSecurityManager = null;\n        boolean securityManagerChanged = false;\n        try {\n            previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(new PermissiveSecurityManager());\n            securityManagerChanged = true;\n\n            DirectHarness.DispatcherHarness dispatcher = DirectHarness.createDispatcher();\n\n            assertThat(dispatcher).isNotNull();\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception).isNotNull();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static byte[] generatedTypeBytes(String className) {\n        DynamicType.Unloaded<Object> generatedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .defineField(\"marker\", String.class, Visibility.PUBLIC)\n                .make();\n        return generatedType.getBytes();\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static class PackageAwareClassLoader extends ClassLoader {\n        PackageAwareClassLoader() {\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.class.getClassLoader());\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            permission.getClass();\n        }\n    }\n}\n\nfinal class DirectHarness extends ClassInjector.UsingReflection {\n    DirectHarness(ClassLoader classLoader) {\n        super(classLoader);\n    }\n\n    static DispatcherHarness createDispatcher() throws Exception {\n        Dispatcher.Initializable initializable = ExposedDirect.makeDispatcher();\n        assertThat(initializable.isAvailable()).isTrue();\n        return new DispatcherHarness(initializable.initialize());\n    }\n\n    static final class DispatcherHarness {\n        private final Dispatcher dispatcher;\n\n        private DispatcherHarness(Dispatcher dispatcher) {\n            this.dispatcher = dispatcher;\n        }\n\n        Class<?> findClass(ClassLoader classLoader, String className) {\n            return dispatcher.findClass(classLoader, className);\n        }\n\n        Class<?> defineClass(ClassLoader classLoader, String className, byte[] binaryRepresentation) {\n            return dispatcher.defineClass(classLoader, className, binaryRepresentation,\n                    getClass().getProtectionDomain());\n        }\n\n        Package getDefinedPackage(ClassLoader classLoader, String packageName) {\n            return dispatcher.getDefinedPackage(classLoader, packageName);\n        }\n\n        Package getPackage(ClassLoader classLoader, String packageName) {\n            return dispatcher.getPackage(classLoader, packageName);\n        }\n\n        Package definePackage(ClassLoader classLoader, String packageName, String specificationTitle,\n                String specificationVersion, String specificationVendor, String implementationTitle,\n                String implementationVersion, String implementationVendor, URL sealBase) {\n            return dispatcher.definePackage(classLoader, packageName, specificationTitle, specificationVersion,\n                    specificationVendor, implementationTitle, implementationVersion, implementationVendor, sealBase);\n        }\n    }\n\n    private abstract static class ExposedDirect extends Dispatcher.Direct {\n        ExposedDirect() {\n            super(null, null, null, null, null);\n        }\n\n        static Dispatcher.Initializable makeDispatcher() throws Exception {\n            return make();\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_projectreactor_tools.blockhound;\\n\\nimport java.net.URL;\\nimport java.security.Permission;\\n\\nimport org.graalvm.internal.tck.NativeImageSupport;\\nimport org.junit.jupiter.api.Test;\\n\\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\\nimport reactor.blockhound.shaded.net.bytebuddy.description.modifier.Visibility;\\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;\\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest {\\n    private static final String PACKAGE_NAME = \\\"io_projectreactor_tools.blockhound.direct.generated\\\";\\n\\n    @Test\\n    void directDispatcherDefinesAndFindsClassesAndPackages() throws Exception {\\n        try {\\n            DirectHarness.DispatcherHarness dispatcher = DirectHarness.createDispatcher();\\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\\n            String className = PACKAGE_NAME + \\\".InjectedType\\\";\\n\\n            assertThat(dispatcher.findClass(classLoader, className)).isNull();\\n\\n            Package definedPackage = dispatcher.definePackage(classLoader, PACKAGE_NAME,\\n                    \\\"specification-title\\\", \\\"1\\\", \\\"specification-vendor\\\",\\n                    \\\"implementation-title\\\", \\\"1\\\", \\\"implementation-vendor\\\", null);\\n            assertThat(definedPackage).isNotNull();\\n            assertThat(definedPackage.getName()).isEqualTo(PACKAGE_NAME);\\n            assertThat(dispatcher.getDefinedPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\\n            assertThat(dispatcher.getPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\\n\\n            Class<?> loaded = dispatcher.defineClass(classLoader, className, generatedTypeBytes(className));\\n\\n            assertThat(loaded.getName()).isEqualTo(className);\\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\\n            assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loaded);\\n        } catch (Error error) {\\n            verifyNativeImageUnsupportedFeature(error);\\n        }\\n    }\\n\\n    @Test\\n    @SuppressWarnings(\\\"removal\\\")\\n    void directDispatcherInitializesWithSecurityManager() throws Exception {\\n        SecurityManager previousSecurityManager = null;\\n        boolean securityManagerChanged = false;\\n        try {\\n            previousSecurityManager = System.getSecurityManager();\\n            System.setSecurityManager(new PermissiveSecurityManager());\\n            securityManagerChanged = true;\\n\\n            DirectHarness.DispatcherHarness dispatcher = DirectHarness.createDispatcher();\\n\\n            assertThat(dispatcher).isNotNull();\\n        } catch (UnsupportedOperationException exception) {\\n            assertThat(exception).isNotNull();\\n        } catch (Error error) {\\n            verifyNativeImageUnsupportedFeature(error);\\n        } finally {\\n            if (securityManagerChanged) {\\n                System.setSecurityManager(previousSecurityManager);\\n            }\\n        }\\n    }\\n\\n    private static byte[] generatedTypeBytes(String className) {\\n        DynamicType.Unloaded<Object> generatedType = new ByteBuddy()\\n                .subclass(Object.class)\\n                .name(className)\\n                .defineField(\\\"marker\\\", String.class, Visibility.PUBLIC)\\n                .make();\\n        return generatedType.getBytes();\\n    }\\n\\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\\n            throw error;\\n        }\\n    }\\n\\n    private static class PackageAwareClassLoader extends ClassLoader {\\n        PackageAwareClassLoader() {\\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.class.getClassLoader());\\n        }\\n    }\\n\\n    @SuppressWarnings(\\\"removal\\\")\\n    private static final class PermissiveSecurityManager extends SecurityManager {\\n        @Override\\n        public void checkPermission(Permission permission) {\\n            permission.getClass();\\n        }\\n    }\\n}\\n\\nfinal class DirectHarness extends ClassInjector.UsingReflection {\\n    DirectHarness(ClassLoader classLoader) {\\n        super(classLoader);\\n    }\\n\\n    static DispatcherHarness createDispatcher() throws Exception {\\n        Dispatcher.Initializable initializable = ExposedDirect.makeDispatcher();\\n        assertThat(initializable.isAvailable()).isTrue();\\n        return new DispatcherHarness(initializable.initialize());\\n    }\\n\\n    static final class DispatcherHarness {\\n        private final Dispatcher dispatcher;\\n\\n        private DispatcherHarness(Dispatcher dispatcher) {\\n            this.dispatcher = dispatcher;\\n        }\\n\\n        Class<?> findClass(ClassLoader classLoader, String className) {\\n            return dispatcher.findClass(classLoader, className);\\n        }\\n\\n        Class<?> defineClass(ClassLoader classLoader, String className, byte[] binaryRepresentation) {\\n            return dispatcher.defineClass(classLoader, className, binaryRepresentation,\\n                    getClass().getProtectionDomain());\\n        }\\n\\n        Package getDefinedPackage(ClassLoader classLoader, String packageName) {\\n            return dispatcher.getDefinedPackage(classLoader, packageName);\\n        }\\n\\n        Package getPackage(ClassLoader classLoader, String packageName) {\\n            return dispatcher.getPackage(classLoader, packageName);\\n        }\\n\\n        Package definePackage(ClassLoader classLoader, String packageName, String specificationTitle,\\n                String specificationVersion, String specificationVendor, String implementationTitle,\\n                String implementationVersion, String implementationVendor, URL sealBase) {\\n            return dispatcher.definePackage(classLoader, packageName, specificationTitle, specificationVersion,\\n                    specificationVendor, implementationTitle, implementationVersion, implementationVendor, sealBase);\\n        }\\n    }\\n\\n    private abstract static class ExposedDirect extends Dispatcher.Direct {\\n        ExposedDirect() {\\n            super(null, null, null, null, null);\\n        }\\n\\n        static Dispatcher.Initializable makeDispatcher() throws Exception {\\n            return make();\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 690, "output": 2144, "cacheRead": 23040, "cacheWrite": 0, "totalTokens": 25874, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1778036665586, "responseId": "resp_02310933e049a01b0169faafb9fd0881a3b63005fc5d471806"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_nZuA1kI8lpAZx0VQ75ASKDQ2|fc_02310933e049a01b0169faafc448d881a3b7a4ff1f9d7f1889", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6456 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerDirectTest.java"}], "isError": false, "timestamp": 1778036683091}]}
