ertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String PACKAGE_NAME = \"io_projectreactor_tools.blockhound.generated\";\n\n    static {\n        System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n    }\n\n    @Test\n    void injectionDefinesClassAndPackageThroughUnsafeReflectionDispatcher() {\n        try {\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\n            String className = PACKAGE_NAME + \".InjectedType\";\n\n            Class<?> loaded = generatedType(className)\n                    .load(classLoader, packageDefiningInjection())\n                    .getLoaded();\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n            assertThat(loaded.getPackage()).isNotNull();\n            assertThat(loaded.getPackage().getName()).isEqualTo(PACKAGE_NAME);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    void rejectedPackageDefinitionExercisesPackageFallback() {\n        try {\n            RejectingPackageClassLoader classLoader = new RejectingPackageClassLoader();\n            String className = PACKAGE_NAME + \".RejectedPackageType\";\n\n            generatedType(className).load(classLoader, packageDefiningInjection());\n            throw new AssertionError(\"Expected package definition to be rejected\");\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(RejectingPackageClassLoader.REJECTION_MESSAGE);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void injectionInitializesUnsafeReflectionDispatcherWithSecurityManager() {\n        SecurityManager previousSecurityManager = null;\n        boolean securityManagerChanged = false;\n        try {\n            previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(new PermissiveSecurityManager());\n            securityManagerChanged = true;\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\n            String className = PACKAGE_NAME + \".SecurityManagedType\";\n\n            Class<?> loaded = generatedType(className)\n                    .load(classLoader, ClassLoadingStrategy.Default.INJECTION)\n                    .getLoaded();\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception).isNotNull();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static DynamicType.Unloaded<Object> generatedType(String className) {\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .defineField(\"marker\", String.class, Visibility.PUBLIC)\n                .make();\n    }\n\n    private static ClassLoadingStrategy.Configurable<ClassLoader> packageDefiningInjection() {\n        return ClassLoadingStrategy.Default.INJECTION.with(definingPackages());\n    }\n\n    private static PackageDefinitionStrategy definingPackages() {\n        return (classLoader, packageName, typeName) -> PackageDefinitionStrategy.Definition.Trivial.INSTANCE;\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static class PackageAwareClassLoader extends ClassLoader {\n        PackageAwareClassLoader() {\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            permission.getClass();\n        }\n    }\n\n    private static final class RejectingPackageClassLoader extends PackageAwareClassLoader {\n        private static final String REJECTION_MESSAGE = \"deliberate package rejection\";\n\n        @Override\n        protected Package definePackage(String name, String specificationTitle, String specificationVersion,\n                String specificationVendor, String implementationTitle, String implementationVersion,\n                String implementationVendor, URL sealBase) {\n            throw new IllegalStateException(REJECTION_MESSAGE);\n        }\n\n        @Override\n        protected Package getPackage(String name) {\n            return null;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778036626762}, {"role": "toolResult", "toolCallId": "call_wwdHCF56aLUYeWK0uu0ztXaE|fc_02310933e049a01b0169faaf928b9081a3917682891a42a449", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport java.lang.reflect.Method;\nimport java.net.URL;\nimport java.security.Permission;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.description.modifier.Visibility;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\n    private static final String BYTE_BUDDY_SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String BYTE_BUDDY_EXPERIMENTAL_PROPERTY =\n            \"reactor.blockhound.shaded.net.bytebuddy.experimental\";\n    private static final String PACKAGE_NAME = \"io_projectreactor_tools.blockhound.unsafeoverride.generated\";\n\n    static {\n        System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n        System.setProperty(BYTE_BUDDY_EXPERIMENTAL_PROPERTY, \"true\");\n    }\n\n    @Test\n    void unsafeOverrideDispatcherDefinesAndFindsClassesAndPackages() throws Exception {\n        try {\n            UnsafeOverrideHarness.DispatcherHarness dispatcher = UnsafeOverrideHarness.createDispatcher();\n            PackageAwareClassLoader classLoader = new PackageAwareClassLoader();\n            String className = PACKAGE_NAME + \".InjectedType\";\n\n            assertThat(dispatcher.findClass(classLoader, className)).isNull();\n\n            Package definedPackage = dispatcher.definePackage(classLoader, PACKAGE_NAME,\n                    \"specification-title\", \"1\", \"specification-vendor\",\n                    \"implementation-title\", \"1\", \"implementation-vendor\", null);\n            assertThat(definedPackage).isNotNull();\n            assertThat(definedPackage.getName()).isEqualTo(PACKAGE_NAME);\n            assertThat(dispatcher.getDefinedPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n            assertThat(dispatcher.getPackage(classLoader, PACKAGE_NAME)).isSameAs(definedPackage);\n\n            Class<?> loaded = dispatcher.defineClass(classLoader, className, generatedTypeBytes(className));\n\n            assertThat(loaded.getName()).isEqualTo(className);\n            assertThat(loaded.getClassLoader()).isSameAs(classLoader);\n            assertThat(dispatcher.findClass(classLoader, className)).isSameAs(loaded);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @SuppressWarnings(\"removal\")\n    void unsafeOverrideDispatcherInitializesWithSecurityManager() throws Exception {\n        SecurityManager previousSecurityManager = null;\n        boolean securityManagerChanged = false;\n        try {\n            previousSecurityManager = System.getSecurityManager();\n            System.setSecurityManager(new PermissiveSecurityManager());\n            securityManagerChanged = true;\n\n            UnsafeOverrideHarness.DispatcherHarness dispatcher = UnsafeOverrideHarness.createDispatcher();\n\n            assertThat(dispatcher).isNotNull();\n        } catch (UnsupportedOperationException exception) {\n            assertThat(exception).isNotNull();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        } finally {\n            if (securityManagerChanged) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n        }\n    }\n\n    private static byte[] generatedTypeBytes(String className) {\n        DynamicType.Unloaded<Object> generatedType = new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .defineField(\"marker\", String.class, Visibility.PUBLIC)\n                .make();\n        return generatedType.getBytes();\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static class PackageAwareClassLoader extends ClassLoader {\n        PackageAwareClassLoader() {\n            super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class.getClassLoader());\n        }\n    }\n\n    @SuppressWarnings(\"removal\")\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            permission.getClass();\n        }\n    }\n}\n\nfinal class UnsafeOverrideHarness extends ClassInjector.UsingReflection {\n    UnsafeOverrideHarness(ClassLoader classLoader) {\n        super(classLoader);\n    }\n\n    static DispatcherHarness createDispatcher() throws Exception {\n        Dispatcher.Initializable initializable = ExposedUsingUnsafeOverride.makeDispatcher();\n        assertThat(initializable.isAvailable()).isTrue();\n        return new DispatcherHarness(initializable.initialize());\n    }\n\n    static final class DispatcherHarness {\n        private final Dispatcher dispatcher;\n\n        private DispatcherHarness(Dispatcher dispatcher) {\n            this.dispatcher = dispatcher;\n        }\n\n        Class<?> findClass(ClassLoader classLoader, String className) {\n            return dispatcher.findClass(classLoader, className);\n        }\n\n        Class<?> defineClass(ClassLoader classLoader, String className, byte[] binaryRepresentation) {\n            return dispatcher.defineClass(classLoader, className, binaryRepresentation,\n                    getClass().getProtectionDomain());\n        }\n\n        Package getDefinedPackage(ClassLoader classLoader, String packageName) {\n            return dispatcher.getDefinedPackage(classLoader, packageName);\n        }\n\n        Package getPackage(ClassLoader classLoader, String packageName) {\n            return dispatcher.getPackage(classLoader, packageName);\n        }\n\n        Package definePackage(ClassLoader classLoader, String packageName, String specificationTitle,\n                String specificationVersion, String specificationVendor, String implementationTitle,\n                String implementationVersion, String implementationVendor, URL sealBase) {\n            return dispatcher.definePackage(classLoader, packageName, specificationTitle, specificationVersion,\n                    specificationVendor, implementationTitle, implementationVersion, implementationVendor, sealBase);\n        }\n    }\n\n    private abstract static class ExposedUsingUnsafeOverride extends Dispatcher.UsingUnsafeOverride {\n        ExposedUsingUnsafeOverride(Method findLoadedClass, Method defineClass, Method getDefinedPackage,\n                Method getPackage, Method definePackage) {\n            super(findLoadedClass, defineClass, getDefinedPackage, getPackage, definePackage);\n        }\n\n        static Dispatcher.Initializable makeDispatcher() throws Exception {\n            return make();\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1778036626763}]}
