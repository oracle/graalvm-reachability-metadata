              "ByteBuddyAgent$ProcessProvider$ForCurrentVm.class",
              "ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForJava9CapableVm.class",
              "ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForLegacyVm.class",
              "Installer.class");
  
      @Test
      void getInstrumentationAndExternalAttachmentUseByteBuddyAgentInstallerPaths() throws Throwable {
          try {
              exerciseByteBuddyAgentInstallerPaths();
              getInstrumentationFromNamedModuleAddsReadEdgeToSystemInstaller();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void exerciseByteBuddyAgentInstallerPaths() throws Exception {
          String originalAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);
          String originalLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);
          Path marker = Files.createTempFile("blockhound-byte-buddy-agent", ".marker");
          Files.deleteIfExists(marker);
          Path virtualMachineJar = writeVirtualMachineJar();
          Path agentJar = Files.createTempFile("blockhound-byte-buddy-agent", ".jar");
          try {
              System.setProperty(ALLOW_SELF_ATTACH_PROPERTY, Boolean.FALSE.toString());
              System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());
  
              assertThatThrownBy(ByteBuddyAgent::getInstrumentation)
                      .isInstanceOf(IllegalStateException.class)
                      .hasMessageContaining("Byte Buddy agent");
  
              Instrumentation instrumentation = new RecordingInstrumentation();
              Installer.premain(null, instrumentation);
              assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);
              Installer.premain(null, null);
  
              ByteBuddyAgent.attach(agentJar.toFile(),
                      () -> Long.toString(ProcessHandle.current().pid()),
                      marker.toString(),
                      new ExternalAttachmentProvider(virtualMachineJar.toFile()));
  
              assertThat(marker).exists();
              assertThat(Files.readString(marker)).contains(agentJar.toString());
          } finally {
              Installer.premain(null, null);
              restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, originalAllowSelfAttach);
              restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, originalLatentResolve);
              Files.deleteIfExists(agentJar);
              Files.deleteIfExists(marker);
              Files.deleteIfExists(virtualMachineJar);
          }
      }
  
      private static void getInstrumentationFromNamedModuleAddsReadEdgeToSystemInstaller() throws Throwable {
          Path modularJar = writeModularByteBuddyAgentJar();
          Instrumentation instrumentation = new RecordingInstrumentation();
          try {
              Installer.premain(null, instrumentation);
  
              ModuleFinder finder = ModuleFinder.of(modularJar);
              Configuration configuration = ModuleLayer.boot().configuration()
                      .resolve(finder, ModuleFinder.of(), Set.of(BYTE_BUDDY_AGENT_COPY_MODULE));
              ModuleLayer layer = ModuleLayer.boot()
                      .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
              Class<?> agentClass = layer.findLoader(BYTE_BUDDY_AGENT_COPY_MODULE)
                      .loadClass(BYTE_BUDDY_AGENT_PACKAGE + ".ByteBuddyAgent");
              MethodHandle getInstrumentation = MethodHandles.publicLookup()
                      .findStatic(agentClass, "getInstrumentation", MethodType.methodType(Instrumentation.class));
  
              assertThat(getInstrumentation.invoke()).isSameAs(instrumentation);
          } finally {
              Installer.premain(null, null);
              Files.deleteIfExists(modularJar);
          }
      }
  
      private static Path writeModularByteBuddyAgentJar() throws IOException {
          Path jar = Files.createTempFile("blockhound-byte-buddy-agent-module", ".jar");
          try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {
              jarOutputStream.putNextEntry(new JarEntry("module-info.class"));
              jarOutputStream.write(BYTE_BUDDY_AGENT_COPY_MODULE_INFO);
              jarOutputStream.closeEntry();
              for (String classResource : MODULAR_AGENT_CLASS_RESOURCES) {
                  String resourceName = BYTE_BUDDY_AGENT_RESOURCE_PATH + classResource;
                  try (InputStream inputStream = ByteBuddyAgent.class.getClassLoader()
                          .getResourceAsStream(resourceName)) {
                      assertThat(inputStream).isNotNull();
                      jarOutputStream.putNextEntry(new JarEntry(resourceName));
                      copy(inputStream, jarOutputStream);
                      jarOutputStream.closeEntry();
                  }
              }
          }
          return jar;
      }
  
      private static Path writeVirtualMachineJar() throws IOException {
          Path jar = Files.createTempFile("blockhound-byte-buddy-virtual-machine", ".jar");
          String resourceName = RecordingVirtualMachine.class.getName().replace('.', '/') + ".class";
          try (InputStream inputStream = ByteBuddyAgentTest.class.getClassLoader().getResourceAsStream(resourceName)) {
              assertThat(inputStream).isNotNull();
              try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {
                  jarOutputStream.putNextEntry(new JarEntry(resourceName));
                  copy(inputStream, jarOutputStream);
                  jarOutputStream.closeEntry();
              }
          }
          return jar;
      }
  
      private static void copy(InputStream inputStream, OutputStream outputStream) throws IOException {
          byte[] buffer = new byte[8192];
          int length;
          while ((length = inputStream.read(buffer)) != -1) {
              outputStream.write(buffer, 0, length);
          }
      }
  
      private static void restoreProperty(String name, String originalValue) {
          if (originalValue == null) {
              System.clearProperty(name);
          } else {
              System.setProperty(name, originalValue);
          }
      }
  
      private static final class ExternalAttachmentProvider implements AttachmentProvider {
          private final File virtualMachineJar;
  
          private ExternalAttachmentProvider(File virtualMachineJar) {
              this.virtualMachineJar = virtualMachineJar;
          }
  
          @Override
          public Accessor attempt() {
              return new ExternalAttachmentAccessor(virtualMachineJar);
          }
      }
  
      private static final class ExternalAttachmentAccessor implements Accessor {
          private final File virtualMachineJar;
  
          private ExternalAttachmentAccessor(File virtualMachineJar) {
              this.virtualMachineJar = virtualMachineJar;
          }
  
          @Override
          public boolean isAvailable() {
              return true;
          }
  
          @Override
          public boolean isExternalAttachmentRequired() {
              return true;
          }
  
          @Override
          public Class<?> getVirtualMachineType() {
              return RecordingVirtualMachine.class;
          }
  
          @Override
          public ExternalAttachment getExternalAttachment() {
              return new ExternalAttachment(
                      RecordingVirtualMachine.class.getName(),
                      Collections.singletonList(virtualMachineJar));
          }
      }
  
      private static final class RecordingInstrumentation implements Instrumentation {
