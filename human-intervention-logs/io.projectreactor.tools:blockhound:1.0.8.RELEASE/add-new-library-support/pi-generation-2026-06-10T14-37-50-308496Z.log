      public static final class RecordingVirtualMachine {
          private final String processId;
  
          private RecordingVirtualMachine(String processId) {
              this.processId = processId;
          }
  
          public static RecordingVirtualMachine attach(String processId) {
              return new RecordingVirtualMachine(processId);
          }
  
          public void loadAgent(String agent, String argument) throws IOException {
              Files.writeString(Path.of(argument), processId + System.lineSeparator() + agent);
          }
  
          public void loadAgentPath(String agent, String argument) throws IOException {
              Files.writeString(Path.of(argument), processId + System.lineSeparator() + agent);
          }
  
          public void detach() {
          }
