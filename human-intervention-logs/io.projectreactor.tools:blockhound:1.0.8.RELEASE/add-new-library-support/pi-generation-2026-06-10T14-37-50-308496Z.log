  package io_projectreactor_tools.blockhound;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.AttachmentProvider.Accessor;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.AttachmentProvider.ForJ9Vm;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteBuddyAgentInnerAttachmentProviderInnerAccessorInnerSimpleTest {
      @Test
      void j9AccessorAttemptsToResolveIbmAttachVirtualMachine() {
          try {
              Accessor accessor = ForJ9Vm.INSTANCE.attempt();
  
              assertThat(accessor).isNotNull();
              if (accessor.isAvailable()) {
                  assertThat(accessor.getVirtualMachineType().getName())
                          .isEqualTo("com.ibm.tools.attach.VirtualMachine");
              } else {
                  assertThat(accessor.isAvailable()).isFalse();
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  }
