  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.ProcessProvider;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteBuddyAgentInnerProcessProviderInnerForCurrentVmInnerForLegacyVmTest {
      private static final String LEGACY_VM_PROVIDER = "reactor.blockhound.shaded.net.bytebuddy.agent"
              + ".ByteBuddyAgent$ProcessProvider$ForCurrentVm$ForLegacyVm";
  
      @Test
      void resolvesCurrentProcessIdThroughLegacyManagementBeanProvider() throws ClassNotFoundException {
          ProcessProvider processProvider = (ProcessProvider) enumConstant(LEGACY_VM_PROVIDER, "INSTANCE");
  
          String processId = processProvider.resolve();
  
          assertThat(processId)
                  .containsOnlyDigits()
                  .isEqualTo(Long.toString(ProcessHandle.current().pid()));
      }
  
      @SuppressWarnings({"rawtypes", "unchecked"})
      private static Enum<?> enumConstant(String className, String constantName) throws ClassNotFoundException {
          Class<? extends Enum> enumType = Class.forName(className).asSubclass(Enum.class);
          return Enum.valueOf(enumType, constantName);
      }
  }
