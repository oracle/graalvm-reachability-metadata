  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDefinition;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class TypeDescriptionInnerGenericInnerLazyProxyTest {
      @Test
      void genericObjectConstantLazilyDelegatesToLoadedTypeDescription() {
          try {
              TypeDescription.Generic objectType = TypeDescription.Generic.OBJECT;
  
              assertThat(objectType.getSort()).isEqualTo(TypeDefinition.Sort.NON_GENERIC);
              assertThat(objectType.represents(Object.class)).isTrue();
              assertThat(objectType.asErasure().represents(Object.class)).isTrue();
              assertThat(objectType.getTypeName()).isEqualTo(Object.class.getName());
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  }
