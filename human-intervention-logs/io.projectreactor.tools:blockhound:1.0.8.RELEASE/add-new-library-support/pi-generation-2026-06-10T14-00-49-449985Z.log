[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/InstrumentationUtilsTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\nimport java.util.concurrent.CountDownLatch;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.BlockHound;\nimport reactor.blockhound.BlockingMethod;\n\npublic class InstrumentationUtilsTest {\n    @Test\n    void installInjectsBootstrapClassesAndDetectsBlockingCall() throws Exception {\n        CountDownLatch blockingCallDetected = new CountDownLatch(1);\n        AtomicReference<BlockingMethod> blockingMethod = new AtomicReference<>();\n\n        try {\n            BlockHound.builder()\n                    .nonBlockingThreadPredicate(current -> current.or(NonBlockingThread.class::isInstance))\n                    .blockingMethodCallback(method -> {\n                        blockingMethod.set(method);\n                        blockingCallDetected.countDown();\n                    })\n                    .install();\n        } catch (RuntimeException exception) {\n            if (hasUnsupportedFeatureError(exception)) {\n                return;\n            }\n            throw exception;\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n            return;\n        }\n\n        NonBlockingThread thread = new NonBlockingThread();\n        thread.start();\n        thread.join(TimeUnit.SECONDS.toMillis(5));\n        if (thread.isAlive()) {\n            thread.interrupt();\n            thread.join(TimeUnit.SECONDS.toMillis(1));\n        }\n\n        assertThat(thread.isAlive()).isFalse();\n        assertThat(thread.failure).isNull();\n        assertThat(blockingCallDetected.await(1, TimeUnit.SECONDS)).isTrue();\n        assertThat(blockingMethod.get()).isNotNull();\n        assertThat(blockingMethod.get().getClassName()).isEqualTo(Thread.class.getName());\n        assertThat(blockingMethod.get().getName()).isEqualTo(\"sleep\");\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class NonBlockingThread extends Thread {\n        private volatile Throwable failure;\n\n        @Override\n        public void run() {\n            try {\n                Thread.sleep(1);\n            } catch (Throwable throwable) {\n                failure = throwable;\n            }\n        }\n    }\n}\n"}
