it.SECONDS.toMillis(5));\n        if (thread.isAlive()) {\n            thread.interrupt();\n            thread.join(TimeUnit.SECONDS.toMillis(1));\n        }\n\n        assertThat(thread.isAlive()).isFalse();\n        assertThat(thread.failure).isNull();\n        assertThat(blockingCallDetected.await(1, TimeUnit.SECONDS)).isTrue();\n        assertThat(blockingMethod.get()).isNotNull();\n        assertThat(blockingMethod.get().getClassName()).isEqualTo(Thread.class.getName());\n        assertThat(blockingMethod.get().getName()).isEqualTo(\"sleep\");\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable;\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class NonBlockingThread extends Thread {\n        private volatile Throwable failure;\n\n        @Override\n        public void run() {\n            try {\n                Thread.sleep(1);\n            } catch (Throwable throwable) {\n                failure = throwable;\n            }\n        }\n    }\n}\n"}
