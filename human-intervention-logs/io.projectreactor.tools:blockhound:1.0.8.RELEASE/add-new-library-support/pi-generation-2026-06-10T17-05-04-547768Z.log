            TypeDescription annotationType = TypeDescription.ForLoadedType.of(SampleAnnotation.class);\n            AnnotationValue<String, String> value = new AnnotationValue.ForMissingValue<>(annotationType, \"missing\");\n\n            AnnotationValue.Loaded<String> loadedValue = value.load(SampleAnnotation.class.getClassLoader());\n\n            assertThat(value.getState()).isEqualTo(AnnotationValue.State.UNDEFINED);\n            assertThat(loadedValue.getState()).isEqualTo(AnnotationValue.State.UNDEFINED);\n            assertThatThrownBy(loadedValue::resolve)\n                    .isInstanceOfSatisfying(IncompleteAnnotationException.class, exception -> {\n                        assertThat(exception.annotationType()).isEqualTo(SampleAnnotation.class);\n                        assertThat(exception.elementName()).isEqualTo(\"missing\");\n                    });\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    public @interface SampleAnnotation {\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1185, "output": 687, "cacheRead": 23552, "cacheWrite": 0, "totalTokens": 25424, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781111086304, "responseId": "resp_07ddf96fdf05a2dc016a29992ec1b88196a499d20570964aac"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_xpijEJ0v1s7a2NTpRj0wDqxt|fc_07ddf96fdf05a2dc016a299936829481969cf75d7c0bcd5dcc", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1840 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/AnnotationValueInnerForMissingValueTest.java"}], "isError": false, "timestamp": 1781111098826}]}
