  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;
  import reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  
  import java.lang.annotation.AnnotationTypeMismatchException;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  import static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;
  
  public class AnnotationValueInnerForMismatchedTypeTest {
      @Test
      void loadsMismatchedValueForExistingAnnotationProperty() {
          try {
              TypeDescription annotationType = TypeDescription.ForLoadedType.of(SampleAnnotation.class);
              MethodDescription.InDefinedShape property = annotationType
                      .getDeclaredMethods()
                      .filter(named("name"))
                      .getOnly();
              AnnotationValue<String, String> mismatchedValue = new AnnotationValue.ForMismatchedType<>(
                      property,
                      "42");
  
              AnnotationValue.Loaded<String> loadedValue = mismatchedValue.load(
                      SampleAnnotation.class.getClassLoader());
  
              assertThat(loadedValue.toString()).contains("42");
              assertThatThrownBy(loadedValue::resolve)
                      .isInstanceOfSatisfying(AnnotationTypeMismatchException.class, exception -> {
                          assertThat(exception.element().getName()).isEqualTo("name");
                          assertThat(exception.foundType()).isEqualTo("42");
                      });
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      public @interface SampleAnnotation {
          String name();
      }
  }
