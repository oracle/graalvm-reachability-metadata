                  | UnmodifiableClassException
                  | UnsupportedOperationException exception) {
              resolvesCurrentVmVersionThroughIsolatedMajorFallback();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      @Test
      void resolvesCurrentVmVersionThroughIsolatedMajorFallback() throws Exception {
          try {
              ClassLoader parent = getClass().getClassLoader();
              ClassLoader classLoader = new RuntimeVersionMajorFallbackClassLoader(parent);
              Class<?> classFileVersion = classLoader.loadClass(CLASS_FILE_VERSION);
  
