          try (InputStream inputStream = Runtime.Version.class
                  .getResourceAsStream("Runtime$Version.class")) {
              if (inputStream == null) {
                  throw new IOException("Runtime.Version class bytes are not available");
              }
              return readAllBytes(inputStream);
          }
      }
  
      private static byte[] removeFeatureMethod(byte[] classFile) throws IOException {
