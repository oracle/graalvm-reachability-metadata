          int methodsCount = unsignedShort(classFile, methodsCountOffset);
          offset += 2;
          ByteArrayOutputStream methods = new ByteArrayOutputStream();
          int keptMethods = 0;
          int removedMethods = 0;
          for (int index = 0; index < methodsCount; index++) {
              int methodStart = offset;
              int nameIndex = unsignedShort(classFile, methodStart + 2);
              int descriptorIndex = unsignedShort(classFile, methodStart + 4);
              offset = skipMember(classFile, methodStart);
              if (nameIndex == featureIndex && descriptorIndex == intMethodDescriptorIndex) {
                  removedMethods++;
              } else {
                  methods.write(classFile, methodStart, offset - methodStart);
                  keptMethods++;
              }
          }
          if (removedMethods == 0) {
              return classFile;
          }
  
          ByteArrayOutputStream outputStream = new ByteArrayOutputStream(classFile.length);
          outputStream.write(classFile, 0, methodsCountOffset);
          writeUnsignedShort(outputStream, keptMethods);
          methods.writeTo(outputStream);
          outputStream.write(classFile, offset, classFile.length - offset);
          return outputStream.toByteArray();
      }
  
      private static ConstantPool parseConstantPool(byte[] classFile) throws IOException {
          int constantPoolCount = unsignedShort(classFile, 8);
          String[] utf8Values = new String[constantPoolCount];
          int offset = 10;
          for (int index = 1; index < constantPoolCount; index++) {
              int tag = classFile[offset++] & 0xff;
              switch (tag) {
                  case 1:
                      int length = unsignedShort(classFile, offset);
                      offset += 2;
                      utf8Values[index] = new String(
                              classFile,
                              offset,
                              length,
                              StandardCharsets.UTF_8);
                      offset += length;
                      break;
                  case 3:
                  case 4:
                  case 9:
                  case 10:
                  case 11:
                  case 12:
                  case 17:
                  case 18:
                      offset += 4;
                      break;
                  case 5:
                  case 6:
                      offset += 8;
                      index++;
                      break;
                  case 7:
                  case 8:
                  case 16:
