  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassFileVersionInnerVersionLocatorInnerResolverTest {
      private static final String CLASS_FILE_VERSION =
              "reactor.blockhound.shaded.net.bytebuddy.ClassFileVersion";
  
      @Test
      void resolverUsesRuntimeVersionMajorWhenFeatureMethodIsUnavailable() throws Exception {
          try {
              Instrumentation instrumentation = ByteBuddyAgent.install();
              byte[] originalBytes = readRuntimeVersionClassBytes();
              byte[] withoutFeatureMethod = removeFeatureMethod(originalBytes);
              instrumentation.redefineClasses(
                      new ClassDefinition(Runtime.Version.class, withoutFeatureMethod));
              try {
                  VersionLocator versionLocator = Resolver.INSTANCE.run();
  
                  assertThat(versionLocator).isNotNull();
              } finally {
