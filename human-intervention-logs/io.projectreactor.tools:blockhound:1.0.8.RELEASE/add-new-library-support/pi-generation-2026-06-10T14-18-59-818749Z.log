 try {\n            ClassLoader parent = getClass().getClassLoader();\n            ClassLoader classLoader = new RuntimeVersionMajorFallbackClassLoader(parent);\n            Class<?> classFileVersion = classLoader.loadClass(CLASS_FILE_VERSION);\n\n            Object version = classFileVersion.getMethod(\"ofThisVm\").invoke(null);\n            int javaVersion = ((Number) classFileVersion.getMethod(\"getJavaVersion\")\n                    .invoke(version)).intValue();\n\n            assertThat(javaVersion).isEqualTo(Runtime.version().major());\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getCause();\n            if (cause instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return;\n            }\n            throw exception;\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static final class RuntimeVersionMajorFallbackClassLoader extends ClassLoader {\n        private static final String RESOLVER = CLASS_FILE_VERSION + \"$VersionLocator$Resolver\";\n        private static final String FEATURE = \"feature\";\n        private static final String MISSING = \"missing\";\n\n        private RuntimeVersionMajorFallbackClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        @Override\n        protected Class<?> loadClass(String name, boolean resolve) throws ClassNotFoundException {\n            synchronized (getClassLoadingLock(name)) {\n                Class<?> loadedClass = findLoadedClass(name);\n                if (loadedClass == null) {\n                    loadedClass = name.startsWith(CLASS_FILE_VERSION)\n                            ? findClass(name)\n                            : super.loadClass(name, false);\n                }\n                if (resolve) {\n                    resolveClass(loadedClass);\n                }\n                return loadedClass;\n            }\n        }\n\n        @Override\n        protected Class<?> findClass(String name) throws ClassNotFoundException {\n            if (!name.startsWith(CLASS_FILE_VERSION)) {\n                return super.findClass(name);\n            }\n            byte[] bytecode = readClassBytes(name);\n            if (name.equals(RESOLVER)) {\n                replaceUtf8Constant(bytecode, FEATURE, MISSING);\n            }\n            return defineClass(name, bytecode, 0, bytecode.length);\n        }\n\n        private byte[] readClassBytes(String name) throws ClassNotFoundException {\n            String resourceName = name.replace('.', '/') + \".class\";\n            try (InputStream inputStream = getParent().getResourceAsStream(resourceName)) {\n                if (inputStream == null) {\n                    throw new ClassNotFoundException(name);\n                }\n                ByteArrayOutputStream outputStream = new ByteArrayOutputStream();\n                byte[] buffer = new byte[4096];\n                int read;\n                while ((read = inputStream.read(buffer)) != -1) {\n                    outputStream.write(buffer, 0, read);\n                }\n                return outputStream.toByteArray();\n            } catch (IOException exception) {\n                throw new ClassNotFoundException(name, exception);\n            }\n        }\n\n        private void replaceUtf8Constant(byte[] bytecode, String source, String target) {\n            byte[] sourceBytes = source.getBytes(StandardCharsets.UTF_8);\n            byte[] targetBytes = target.getBytes(StandardCharsets.UTF_8);\n            if (sourceBytes.length != targetBytes.length) {\n                throw new IllegalArgumentException(\"Replacement must keep the constant length\");\n            }\n\n            int constantPoolCount = unsignedShort(bytecode, 8);\n            int offset = 10;\n            int replacements = 0;\n            for (int index = 1; index < constantPoolCount; index++) {\n                int tag = bytecode[offset++] & 0xff;\n                switch (tag) {\n                    case 1:\n                        int length = unsignedShort(bytecode, offset);\n                        int valueOffset = offset + 2;\n                        if (length == sourceBytes.length && matches(bytecode, valueOffset, sourceBytes)) {\n                            System.arraycopy(targetBytes, 0, bytecode, valueOffset, targetBytes.length);\n                            replacements++;\n                        }\n                        offset = valueOffset + length;\n                        break;\n                    case 3:\n                    case 4:\n                    case 9:\n                    case 10:\n                    case 11:\n                    case 12:\n                    case 17:\n                    case 18:\n                        offset += 4;\n                        break;\n                    case 5:\n                    case 6:\n                        offset += 8;\n                        index++;\n                        break;\n                    case 7:\n                    case 8:\n                    case 16:\n                    case 19:\n                    case 20:\n                        offset += 2;\n                        break;\n                    case 15:\n                        offset += 3;\n                        break;\n                    default:\n                        throw new IllegalStateException(\"Unexpected constant pool tag: \" + tag);\n                }\n            }\n            if (replacements != 1) {\n                throw new IllegalStateException(\"Expected one feature method-name constant\");\n            }\n        }\n\n        private int unsignedShort(byte[] bytecode, int offset) {\n            return ((bytecode[offset] & 0xff) << 8) | (bytecode[offset + 1] & 0xff);\n        }\n\n        private boolean matches(byte[] bytecode, int offset, byte[] expected) {\n            for (int index = 0; index < expected.length; index++) {\n                if (bytecode[offset + index] != expected[index]) {\n                    return false;\n                }\n            }\n            return true;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1759, "output": 2183, "cacheRead": 48128, "cacheWrite": 0, "totalTokens": 52070, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781101024597, "responseId": "resp_00052007b4fb7ca0016a2971e145ac8197845f0081079578f0"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_nDbtLxpcncq0oDOuIlQCMMp8|fc_00052007b4fb7ca0016a2971f3463c8197ba792a1e177b3204", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 6997 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassFileVersionInnerVersionLocatorInnerResolverTest.java"}], "isError": false, "timestamp": 1781101057590}]}
