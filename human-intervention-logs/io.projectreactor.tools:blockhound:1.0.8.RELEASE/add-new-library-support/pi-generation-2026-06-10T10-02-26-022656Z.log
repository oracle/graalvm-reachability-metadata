                      packageName,
                      UsingUnsafeOverrideExercise.class.getPackage())) {
                  Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);
                  if (!generatedClass.getName().equals(className) || generatedClass.getClassLoader() != classLoader) {
                      throw new IllegalStateException("Generated class was not injected after package fallback");
                  }
              } catch (Exception exception) {
                  throw new IllegalStateException(exception);
              }
          }
  
