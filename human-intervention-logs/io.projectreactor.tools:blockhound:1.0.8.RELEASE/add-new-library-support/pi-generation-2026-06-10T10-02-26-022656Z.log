          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          }
      }
  
      private static void rethrowUnlessUnsupportedFeatureError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      public static final class UsingUnsafeOverrideExercise {
          private static final String SAFE_PROPERTY = ClassInjector.UsingUnsafe.SAFE_PROPERTY;
  
          public String call() {
              String previousSafeProperty = System.getProperty(SAFE_PROPERTY);
              SecurityManager previousSecurityManager = System.getSecurityManager();
              boolean securityManagerChanged = false;
              try {
                  System.setProperty(SAFE_PROPERTY, Boolean.TRUE.toString());
                  if (ClassInjector.UsingUnsafe.isAvailable()) {
                      throw new IllegalStateException("Unsafe injection should be disabled before reflection injection");
