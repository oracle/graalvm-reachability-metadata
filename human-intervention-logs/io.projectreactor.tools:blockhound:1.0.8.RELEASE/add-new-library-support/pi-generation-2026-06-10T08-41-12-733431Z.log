unit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.builder.LambdaFactory;\n\nimport java.lang.instrument.ClassFileTransformer;\nimport java.security.ProtectionDomain;\nimport java.util.Collection;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LambdaFactoryTest {\n    @Test\n    void registersFactoryInvokesItAndReleasesTransformer() {\n        ClassFileTransformer transformer = new NoOpClassFileTransformer();\n        RecordingClassFileFactory factory = new RecordingClassFileFactory();\n        boolean registered = false;\n\n        try {\n            boolean firstRegistration = LambdaFactory.register(transformer, factory);\n            registered = true;\n\n            byte[] generatedBytes = LambdaFactory.make(\n                    new Object(),\n                    \"run\",\n                    new Object(),\n                    new Object(),\n                    new Object(),\n                    new Object(),\n                    false,\n                    List.of(Runnable.class),\n                    List.of());\n\n            assertThat(firstRegistration).isTrue();\n            assertThat(generatedBytes).containsExactly(1, 2, 3);\n            assertThat(factory.invocations).isEqualTo(1);\n            assertThat(factory.lastInvokedName).isEqualTo(\"run\");\n            assertThat(factory.lastClassFileTransformers).containsExactly(transformer);\n\n            assertThat(LambdaFactory.release(transformer)).isTrue();\n            registered = false;\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        } finally {\n            if (registered) {\n                LambdaFactory.release(transformer);\n            }\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class NoOpClassFileTransformer implements ClassFileTransformer {\n        @Override\n        public byte[] transform(\n                Module module,\n                ClassLoader loader,\n                String className,\n                Class<?> classBeingRedefined,\n                ProtectionDomain protectionDomain,\n                byte[] classfileBuffer) {\n            return null;\n        }\n    }\n\n    public static final class RecordingClassFileFactory {\n        private int invocations;\n        private String lastInvokedName;\n        private Collection<ClassFileTransformer> lastClassFileTransformers;\n\n        public byte[] make(\n                Object caller,\n                String invokedName,\n                Object invokedType,\n                Object samMethodType,\n                Object implMethod,\n                Object instantiatedMethodType,\n                boolean serializable,\n                List<Class<?>> markerInterfaces,\n                List<?> additionalBridges,\n                Collection<ClassFileTransformer> classFileTransformers) {\n            invocations++;\n            lastInvokedName = invokedName;\n            lastClassFileTransformers = classFileTransformers;\n            return new byte[] {1, 2, 3};\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 14314, "output": 1365, "cacheRead": 21504, "cacheWrite": 0, "totalTokens": 37183, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781080771516, "responseId": "resp_07103d4a18b3d323016a2922c4024881939aba2827cc47913c"}}
