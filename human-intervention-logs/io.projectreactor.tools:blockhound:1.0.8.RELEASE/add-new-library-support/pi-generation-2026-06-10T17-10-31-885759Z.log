  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.utility.Invoker;
  import reactor.blockhound.shaded.net.bytebuddy.utility.dispatcher.JavaDispatcher;
  
  import java.lang.reflect.Constructor;
  import java.lang.reflect.Method;
  import java.security.Permission;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class JavaDispatcherInnerDirectInvokerTest {
      private static final String CREATE_CLASS_LOADER_PERMISSION = "createClassLoader";
      private static final String SECURITY_MANAGER_PROPERTY = "java.security.manager";
  
      @Test
      void directInvokerDelegatesConstructorAndMethodCalls() throws Exception {
          try {
              Invoker invoker = directInvoker();
              Constructor<StringBuilder> constructor = StringBuilder.class.getConstructor(String.class);
              StringBuilder builder = (StringBuilder) invoker.newInstance(constructor, new Object[]{"block"});
              Method append = StringBuilder.class.getMethod("append", String.class);
              Method toString = StringBuilder.class.getMethod("toString");
  
              assertThat(invoker.invoke(append, builder, new Object[]{"hound"})).isSameAs(builder);
              assertThat(invoker.invoke(toString, builder, new Object[0])).isEqualTo("blockhound");
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      @Test
      @SuppressWarnings("removal")
      void reflectiveFallbackInvokerCallsConstructorsAndMethods() {
          String previousSecurityManagerProperty = System.getProperty(SECURITY_MANAGER_PROPERTY);
          SecurityManager previousSecurityManager = System.getSecurityManager();
          ClassLoaderBlockingSecurityManager securityManager = new ClassLoaderBlockingSecurityManager();
          boolean securityManagerInstalled = installSecurityManager(previousSecurityManager, securityManager);
  
          try {
              StringBuilderDispatcher dispatcher = dispatcher().run();
              StringBuilder builder = dispatcher.newStringBuilder("block");
  
              assertThat(dispatcher.append(builder, "hound")).isSameAs(builder);
              assertThat(dispatcher.toString(builder)).isEqualTo("blockhound");
              if (securityManagerInstalled) {
                  assertThat(securityManager.classLoaderCreationBlocked).isTrue();
              }
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(previousSecurityManager);
              }
              restoreSecurityManagerProperty(previousSecurityManagerProperty);
          }
      }
  
      private static ExposedJavaDispatcher<StringBuilderDispatcher> dispatcher() {
          return new ExposedJavaDispatcher<>(
                  StringBuilderDispatcher.class,
                  JavaDispatcherInnerDirectInvokerTest.class.getClassLoader(),
                  false);
      }
  
      private static Invoker directInvoker() throws Exception {
          Class<?> directInvokerType = Class.forName(
                  "reactor.blockhound.shaded.net.bytebuddy.utility.dispatcher.JavaDispatcher$DirectInvoker");
          Constructor<?> constructor = directInvokerType.getDeclaredConstructor();
          constructor.setAccessible(true);
          return (Invoker) constructor.newInstance();
      }
  
      @SuppressWarnings("removal")
      private static boolean installSecurityManager(
              SecurityManager previousSecurityManager,
              ClassLoaderBlockingSecurityManager securityManager) {
          if (previousSecurityManager != null) {
              return false;
          }
          try {
              if (System.getProperty(SECURITY_MANAGER_PROPERTY) == null) {
                  System.setProperty(SECURITY_MANAGER_PROPERTY, "allow");
              }
              System.setSecurityManager(securityManager);
              return true;
          } catch (UnsupportedOperationException unsupportedOperationException) {
              return false;
          }
      }
  
      private static void restoreSecurityManagerProperty(String previousSecurityManagerProperty) {
          if (previousSecurityManagerProperty == null) {
              System.clearProperty(SECURITY_MANAGER_PROPERTY);
          } else {
              System.setProperty(SECURITY_MANAGER_PROPERTY, previousSecurityManagerProperty);
          }
      }
  
      private static final class ExposedJavaDispatcher<T> extends JavaDispatcher<T> {
          private ExposedJavaDispatcher(Class<T> proxy, ClassLoader classLoader, boolean generate) {
              super(proxy, classLoader, generate);
          }
      }
  
      @JavaDispatcher.Proxied("java.lang.StringBuilder")
      public interface StringBuilderDispatcher {
          @JavaDispatcher.IsConstructor
          StringBuilder newStringBuilder(String value);
  
          StringBuilder append(StringBuilder builder, String value);
  
          String toString(StringBuilder builder);
