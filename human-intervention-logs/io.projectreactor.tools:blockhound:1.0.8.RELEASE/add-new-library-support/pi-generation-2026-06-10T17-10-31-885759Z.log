[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/TypeDescriptionInnerGenericInnerLazyProxyTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDefinition;\nimport reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class TypeDescriptionInnerGenericInnerLazyProxyTest {\n    @Test\n    void genericObjectConstantLazilyDelegatesToLoadedTypeDescription() {\n        TypeDescription.Generic objectType = TypeDescription.Generic.OBJECT;\n\n        assertThat(objectType.getSort()).isEqualTo(TypeDefinition.Sort.NON_GENERIC);\n        assertThat(objectType.represents(Object.class)).isTrue();\n        assertThat(objectType.asErasure().represents(Object.class)).isTrue();\n        assertThat(objectType.getTypeName()).isEqualTo(Object.class.getName());\n    }\n}\n"}
