.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\n\n            assertThatThrownBy(ByteBuddyAgent::getInstrumentation)\n                    .isInstanceOf(IllegalStateException.class)\n                    .hasMessageContaining(\"Byte Buddy agent\");\n\n            Instrumentation instrumentation = new RecordingInstrumentation();\n            Installer.premain(null, instrumentation);\n            assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n            Installer.premain(null, null);\n\n            ByteBuddyAgent.attach(agentJar.toFile(),\n                    () -> Long.toString(ProcessHandle.current().pid()),\n                    marker.toString(),\n                    new ExternalAttachmentProvider(virtualMachineJar.toFile()));\n\n            assertThat(marker).exists();\n            assertThat(Files.readString(marker)).contains(agentJar.toString());\n        } finally {\n            Installer.premain(null, null);\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, originalAllowSelfAttach);\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, originalLatentResolve);\n            Files.deleteIfExists(agentJar);\n            Files.deleteIfExists(marker);\n            Files.deleteIfExists(virtualMachineJar);\n        }\n    }\n\n    private static void getInstrumentationFromNamedModuleAddsReadEdgeToSystemInstaller() throws Throwable {\n        Path modularJar = writeModularByteBuddyAgentJar();\n        Instrumentation instrumentation = new RecordingInstrumentation();\n        try {\n            Installer.premain(null, instrumentation);\n\n            ModuleFinder finder = ModuleFinder.of(modularJar);\n            Configuration configuration = ModuleLayer.boot().configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(BYTE_BUDDY_AGENT_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            Class<?> agentClass = layer.findLoader(BYTE_BUDDY_AGENT_COPY_MODULE)\n                    .loadClass(BYTE_BUDDY_AGENT_PACKAGE + \".ByteBuddyAgent\");\n            MethodHandle getInstrumentation = MethodHandles.publicLookup()\n                    .findStatic(agentClass, \"getInstrumentation\", MethodType.methodType(Instrumentation.class));\n\n            assertThat(getInstrumentation.invoke()).isSameAs(instrumentation);\n        } finally {\n            Installer.premain(null, null);\n            Files.deleteIfExists(modularJar);\n        }\n    }\n\n    private static Path writeModularByteBuddyAgentJar() throws IOException {\n        Path jar = Files.createTempFile(\"blockhound-byte-buddy-agent-module\", \".jar\");\n        try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n            jarOutputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            jarOutputStream.write(BYTE_BUDDY_AGENT_COPY_MODULE_INFO);\n            jarOutputStream.closeEntry();\n            for (String classResource : MODULAR_AGENT_CLASS_RESOURCES) {\n                String resourceName = BYTE_BUDDY_AGENT_RESOURCE_PATH + classResource;\n                try (InputStream inputStream = ByteBuddyAgent.class.getClassLoader()\n                        .getResourceAsStream(resourceName)) {\n                    assertThat(inputStream).isNotNull();\n                    jarOutputStream.putNextEntry(new JarEntry(resourceName));\n                    copy(inputStream, jarOutputStream);\n                    jarOutputStream.closeEntry();\n                }\n            }\n        }\n        return jar;\n    }\n\n    private static Path writeVirtualMachineJar() throws IOException {\n        Path jar = Files.createTempFile(\"blockhound-byte-buddy-virtual-machine\", \".jar\");\n        String resourceName = RecordingVirtualMachine.class.getName().replace('.', '/') + \".class\";\n        try (InputStream inputStream = ByteBuddyAgentTest.class.getClassLoader().getResourceAsStream(resourceName)) {\n            assertThat(inputStream).isNotNull();\n            try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n                jarOutputStream.putNextEntry(new JarEntry(resourceName));\n                copy(inputStream, jarOutputStream);\n                jarOutputStream.closeEntry();\n            }\n        }\n        return jar;\n    }\n\n    private static void copy(InputStream inputStream, OutputStream outputStream) throws IOException {\n        byte[] buffer = new byte[8192];\n        int length;\n        while ((length = inputStream.read(buffer)) != -1) {\n            outputStream.write(buffer, 0, length);\n        }\n    }\n\n    private static void restoreProperty(String name, String originalValue) {\n        if (originalValue == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, originalValue);\n        }\n    }\n\n    private static final class ExternalAttachmentProvider implements AttachmentProvider {\n        private final File virtualMachineJar;\n\n        private ExternalAttachmentProvider(File virtualMachineJar) {\n            this.virtualMachineJar = virtualMachineJar;\n        }\n\n        @Override\n        public Accessor attempt() {\n            return new ExternalAttachmentAccessor(virtualMachineJar);\n        }\n    }\n\n    private static final class ExternalAttachmentAccessor implements Accessor {\n        private final File virtualMachineJar;\n\n        private ExternalAttachmentAccessor(File virtualMachineJar) {\n            this.virtualMachineJar = virtualMachineJar;\n        }\n\n        @Override\n        public boolean isAvailable() {\n            return true;\n        }\n\n        @Override\n        public boolean isExternalAttachmentRequired() {\n            return true;\n        }\n\n        @Override\n        public Class<?> getVirtualMachineType() {\n            return Re