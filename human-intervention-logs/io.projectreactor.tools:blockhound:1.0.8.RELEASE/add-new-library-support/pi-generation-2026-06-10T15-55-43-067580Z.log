      @Test
      void installOnByteBuddyAgentAddsReadEdgeFromNamedAgentBuilderModule() throws Throwable {
          try {
              installAgentBuilderFromNamedModule();
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static void installAgentBuilderFromNamedModule() throws Throwable {
          Path agentBuilderJar = writeModularAgentBuilderJar();
          Path agentJar = writeModularAgentJar();
          RecordingInstrumentation instrumentation = new RecordingInstrumentation();
          MethodHandle installerPremain = null;
          try {
              defineAgentModuleOnSystemClassLoader(agentJar);
              Class<?> installerType = ClassLoader.getSystemClassLoader().loadClass(INSTALLER_TYPE);
              installerPremain = MethodHandles.publicLookup()
                      .findStatic(installerType, "premain", MethodType.methodType(void.class, String.class,
                              Instrumentation.class));
              installerPremain.invoke(null, instrumentation);
  
              ModuleFinder finder = ModuleFinder.of(agentBuilderJar);
              Configuration configuration = ModuleLayer.boot().configuration()
                      .resolve(finder, ModuleFinder.of(), Set.of(AGENT_BUILDER_COPY_MODULE));
              ModuleLayer layer = ModuleLayer.boot()
                      .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
              ClassLoader loader = layer.findLoader(AGENT_BUILDER_COPY_MODULE);
              Class<?> defaultType = loader.loadClass(AGENT_BUILDER_DEFAULT_TYPE);
              Class<?> transformerType = loader.loadClass(
                      "reactor.blockhound.shaded.net.bytebuddy.agent.builder.ResettableClassFileTransformer");
              MethodHandle constructor = MethodHandles.publicLookup()
                      .findConstructor(defaultType, MethodType.methodType(void.class));
              MethodHandle installOnByteBuddyAgent = MethodHandles.publicLookup()
                      .findVirtual(defaultType, "installOnByteBuddyAgent", MethodType.methodType(transformerType));
  
              assertThat(defaultType.getModule().canRead(installerType.getModule())).isFalse();
              Object transformer = installOnByteBuddyAgent.invoke(constructor.invoke());
  
              assertThat(defaultType.getModule().canRead(installerType.getModule())).isTrue();
              assertThat(transformer).isNotNull();
              assertThat(instrumentation.addedTransformers).hasSize(1);
          } finally {
              if (installerPremain != null) {
                  installerPremain.invoke(null, null);
              }
              Files.deleteIfExists(agentBuilderJar);
              Files.deleteIfExists(agentJar);
          }
      }
  
      private static void defineAgentModuleOnSystemClassLoader(Path agentJar) {
          ModuleFinder finder = ModuleFinder.of(agentJar);
          Configuration configuration = ModuleLayer.boot().configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(AGENT_COPY_MODULE));
          ModuleLayer.defineModules(configuration, List.of(ModuleLayer.boot()),
                  moduleName -> ClassLoader.getSystemClassLoader());
      }
  
      private static Path writeModularAgentBuilderJar() throws IOException {
          Path sourcePath = codeSourcePath(AgentBuilder.class);
          Path jar = Files.createTempFile("blockhound-agent-builder-module", ".jar");
          Set<String> copiedEntries = new HashSet<>();
          try (JarOutputStream outputStream = new JarOutputStream(Files.newOutputStream(jar))) {
              outputStream.putNextEntry(new JarEntry("module-info.class"));
              outputStream.write(AGENT_BUILDER_COPY_MODULE_INFO);
              outputStream.closeEntry();
              if (Files.isDirectory(sourcePath)) {
                  copyByteBuddyClassesFromDirectory(sourcePath, outputStream, copiedEntries, true);
              } else {
                  copyByteBuddyClassesFromJar(sourcePath, outputStream, copiedEntries, true);
              }
          }
          return jar;
      }
  
      private static Path writeModularAgentJar() throws IOException {
          Path sourcePath = codeSourcePath(AgentBuilder.class);
          Path jar = Files.createTempFile("blockhound-agent-module", ".jar");
          Set<String> copiedEntries = new HashSet<>();
          try (JarOutputStream outputStream = new JarOutputStream(Files.newOutputStream(jar))) {
              outputStream.putNextEntry(new JarEntry("module-info.class"));
              outputStream.write(AGENT_COPY_MODULE_INFO);
              outputStream.closeEntry();
              if (Files.isDirectory(sourcePath)) {
                  copyByteBuddyClassesFromDirectory(sourcePath, outputStream, copiedEntries, false);
              } else {
                  copyByteBuddyClassesFromJar(sourcePath, outputStream, copiedEntries, false);
              }
          }
          return jar;
      }
  
      private static Path codeSourcePath(Class<?> type) {
          CodeSource codeSource = type.getProtectionDomain().getCodeSource();
          assertThat(codeSource).isNotNull();
          URI location = URI.create(codeSource.getLocation().toString());
          return Path.of(location);
      }
  
      private static void copyByteBuddyClassesFromJar(
              Path sourceJar,
              JarOutputStream outputStream,
              Set<String> copiedEntries,
              boolean agentBuilderModule) throws IOException {
          try (JarFile jarFile = new JarFile(sourceJar.toFile())) {
              for (JarEntry entry : Collections.list(jarFile.entries())) {
                  if (isByteBuddyClass(entry.getName(), agentBuilderModule)) {
                      copyEntry(entry.getName(), jarFile.getInputStream(entry), outputStream, copiedEntries);
                  }
              }
          }
      }
  
      private static void copyByteBuddyClassesFromDirectory(
              Path sourceDirectory,
              JarOutputStream outputStream,
              Set<String> copiedEntries,
              boolean agentBuilderModule) throws IOException {
          try (Stream<Path> paths = Files.walk(sourceDirectory)) {
              for (Path file : paths.filter(Files::isRegularFile).toList()) {
                  String entryName = sourceDirectory.relativize(file).toString().replace(File.separatorChar, '/');
                  if (isByteBuddyClass(entryName, agentBuilderModule)) {
                      copyEntry(entryName, Files.newInputStream(file), outputStream, copiedEntries);
                  }
              }
          }
      }
  
      private static boolean isByteBuddyClass(String entryName, boolean agentBuilderModule) {
          if (!entryName.startsWith(BYTE_BUDDY_RESOURCE_ROOT) || !entryName.endsWith(".class")) {
              return false;
          }
          if (agentBuilderModule) {
              return !entryName.startsWith(BYTE_BUDDY_AGENT_RESOURCE_ROOT)
                      || entryName.startsWith(BYTE_BUDDY_AGENT_BUILDER_RESOURCE_ROOT);
          }
          return entryName.equals(BYTE_BUDDY_AGENT_RESOURCE_ROOT + "Installer.class")
                  || entryName.startsWith(BYTE_BUDDY_AGENT_RESOURCE_ROOT + "utility/nullability/");
      }
  
      private static void copyEntry(
              String entryName,
              InputStream inputStream,
              JarOutputStream outputStream,
              Set<String> copiedEntries) throws IOException {
          if (!copiedEntries.add(entryName)) {
              return;
          }
          try (InputStream source = inputStream) {
              outputStream.putNextEntry(new JarEntry(entryName));
              copy(source, outputStream);
              outputStream.closeEntry();
          }
      }
  
      private static void copy(InputStream inputStream, OutputStream outputStream) throws IOException {
          byte[] buffer = new byte[8192];
          int length;
          while ((length = inputStream.read(buffer)) != -1) {
              outputStream.write(buffer, 0, length);
          }
      }
  
