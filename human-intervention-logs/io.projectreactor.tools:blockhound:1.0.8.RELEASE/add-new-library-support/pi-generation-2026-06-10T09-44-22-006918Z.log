 file format.\n    37\t */\n    38\tpublic interface LoadedTypeInitializer {\n    39\t\n    40\t    /**\n    41\t     * Callback that is invoked on the creation of an instrumented type. If the loaded type initializer is alive, this\n    42\t     * method should be implemented empty instead of throwing an exception.\n    43\t     *\n    44\t     * @param type The manifestation of the instrumented type.\n    45\t     */\n    46\t    void onLoad(Class<?> type);\n    47\t\n    48\t    /**\n    49\t     * Indicates if this initializer is alive and needs to be invoked. This is only meant as a mark. A loaded type\n    50\t     * initializer that is not alive might still be called and must therefore not throw an exception but rather\n    51\t     * provide an empty implementation.\n    52\t     *\n    53\t     * @return {@code true} if this initializer is alive.\n    54\t     */\n    55\t    boolean isAlive();\n    56\t\n    57\t    /**\n    58\t     * A loaded type initializer that does not do anything.\n    59\t     */\n    60\t    enum NoOp implements LoadedTypeInitializer {\n    61\t\n    62\t        /**\n    63\t         * The singleton instance.\n    64\t         */\n    65\t        INSTANCE;\n    66\t\n    67\t        /**\n    68\t         * {@inheritDoc}\n    69\t         */\n    70\t        public void onLoad(Class<?> type) {\n    71\t            /* do nothing */\n    72\t        }\n    73\t\n    74\t        /**\n    75\t         * {@inheritDoc}\n    76\t         */\n    77\t        public boolean isAlive() {\n    78\t            return false;\n    79\t        }\n    80\t    }\n    81\t\n    82\t    /**\n    83\t     * A type initializer for setting a value for a static field.\n    84\t     */\n    85\t    @HashCodeAndEqualsPlugin.Enhance\n    86\t    class ForStaticField implements LoadedTypeInitializer, Serializable {\n    87\t\n    88\t        /**\n    89\t         * This class's serial version UID.\n    90\t         */\n"}], "isError": false, "timestamp": 1781084501308}}
