are always garbage\n   110\t     * collected. However, the initialization data stored by Byte Buddy does not become eligible which is why it needs to be cleaned explicitly.\n   111\t     *\n   112\t     * @param reference The reference to remove. References are collected via a reference queue that is supplied to the {@link NexusAccessor}.\n   113\t     */\n   114\t    public static void clean(Reference<? extends ClassLoader> reference) {\n   115\t        DISPATCHER.clean(reference);\n   116\t    }\n   117\t\n   118\t    /**\n   119\t     * Registers a loaded type initializer in Byte Buddy's {@link Nexus} which is injected into the system class loader.\n   120\t     *\n   121\t     * @param name                  The binary name of the class.\n   122\t     * @param classLoader           The class's class loader.\n   123\t     * @param identification        The id used for identifying the loaded type initializer that was added to the {@link Nexus}.\n   124\t     * @param loadedTypeInitializer The loaded type initializer to make available via the {@link Nexus}.\n   125\t     */\n   126\t    public void register(String name, @MaybeNull ClassLoader classLoader, int identification, LoadedTypeInitializer loadedTypeInitializer) {\n   127\t        if (loadedTypeInitializer.isAlive()) {\n   128\t            DISPATCHER.register(name, classLoader, referenceQueue, identification, loadedTypeInitializer);\n   129\t        }\n   130\t    }\n   131\t\n   132\t    /**\n   133\t     * An initialization appender that looks up a loaded type initializer from Byte Buddy's {@link Nexus}.\n   134\t     */\n   135\t    @HashCodeAndEqualsPlugin.Enhance\n   136\t    public static class InitializationAppender implements ByteCodeAppender {\n   137\t\n   138\t        /**\n   139\t         * The id used for identifying the loaded type initializer that was added to the {@link Nexus}.\n   140\t         */\n   141\t        private final int identification;\n   142\t\n   143\t        /**\n   144\t         * Creates a new initialization appender.\n   145\t         *\n   146\t         * @param identification The id used for identifying the loaded type initializer that was added to the {@link Nexus}.\n   147\t         */\n   148\t        public InitializationAppender(int identification) {\n   149\t            this.identification = identification;\n   150\t        }\n   151\t\n   152\t        /**\n   153\t         * {@inheritDoc}\n   154\t         */\n   155\t        public Size apply(MethodVisitor methodVisitor, Implementation.Context implementationContext, MethodDescription instrumentedMethod) {\n   156\t            try {\n   157\t                return new ByteCodeAppender.Simple(new StackManipulation.Compound(\n   158\t                        MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(ClassLoader.class.getMethod(\"getSystemClassLoader\"))),\n   159\t                        new TextConstant(Nexus.class.getName()),\n   160\t                        MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(ClassLoader.class.getMethod(\"loadClass\", String.class))),\n   161\t                        new TextConstant(\"initialize\"),\n   162\t                        ArrayFactory.forType(TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(Class.class))\n   163\t                                .withValues(Arrays.asList(\n   164\t                                        ClassConstant.of(TypeDescription.ForLoadedType.of(Class.class)),\n   165\t                                        ClassConstant.of(TypeDescription.ForLoadedType.of(int.class)))),\n   166\t                        MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(Class.class.getMethod(\"getMethod\", String.class, Class[].class))),\n   167\t                        NullConstant.INSTANCE,\n   168\t                        ArrayFactory.forType(TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(Object.class))\n   169\t                                .withValues(Arrays.asList(\n   170\t                                        ClassConstant.of(instrumentedMethod.getDeclaringType().asErasure()),\n   171\t                                        new StackManipulation.Compound(\n   172\t                                                IntegerConstant.forValue(identification),\n   173\t                                                MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(Integer.class.getMethod(\"valueOf\", int.class)))))),\n   174\t                        MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(Method.class.getMethod(\"invoke\", Object.class, Object[].class))),\n   175\t                        Removal.SINGLE\n   176\t                )).apply(methodVisitor, implementationContext, instrumentedMethod);\n   177\t            } catch (NoSuchMethodException exception) {\n   178\t                throw new IllegalStateException(\"Cannot locate method\", exception);\n   179\t            }\n   180\t        }\n   181\t    }\n   182\t\n   183\t    /**\n   184\t     * A dispatcher for registering type initializers in the {@link Nexus}.\n   185\t     */\n   186\t    protected interface Dispatcher {\n   187\t\n   188\t        /**\n   189\t         * Returns {@code true} if this dispatcher is alive.\n   190\t         *\n   191\t         * @return {@code true} if this dispatcher is alive.\n   192\t         */\n   193\t        boolean isAlive();\n   194\t\n   195\t        /**\n   196\t         * Cleans any dead entries of the system class loader's {@link Nexus}.\n   197\t         *\n   198\t         * @param reference The reference to remove.\n   199\t         */\n"}], "isError": false, "timestamp": 1781084357305}}
