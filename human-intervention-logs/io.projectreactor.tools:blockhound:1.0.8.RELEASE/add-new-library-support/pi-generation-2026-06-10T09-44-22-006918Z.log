  package io_projectreactor_tools.blockhound;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  
  import java.net.URL;
  import java.net.URLClassLoader;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {
      private static final Class<?> TEST_CLASS =
              ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class;
  
      private static final String PARENT_PACKAGE_NAME = TEST_CLASS.getPackageName();
  
      @Test
      void injectsGeneratedClassIntoCustomClassLoaderAndDefinesPackage() throws Exception {
          ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION
                  .with(PackageDefinitionStrategy.Trivial.INSTANCE);
          String className = "io_projectreactor_tools.blockhound.generated.Injected"
                  + System.nanoTime();
  
          try (URLClassLoader classLoader =
                       new URLClassLoader(new URL[0], TEST_CLASS.getClassLoader())) {
              Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);
  
              assertThat(generatedClass.getName()).isEqualTo(className);
              assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          }
      }
  
      @Test
      void fallsBackToParentPackageWhenCustomClassLoaderRejectsPackageDefinition() throws Exception {
          ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION
                  .with(PackageDefinitionStrategy.Trivial.INSTANCE);
          String className = PARENT_PACKAGE_NAME + ".InjectedIntoParentPackage" + System.nanoTime();
  
          try (RejectingPackageClassLoader classLoader =
                       new RejectingPackageClassLoader(TEST_CLASS.getClassLoader())) {
              Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);
  
              assertThat(generatedClass.getName()).isEqualTo(className);
              assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);
          } catch (Error error) {
              rethrowUnlessUnsupportedFeatureError(error);
          }
      }
  
      private static Class<?> injectGeneratedClass(
              ClassLoader classLoader,
              String className,
              ClassLoadingStrategy<ClassLoader> strategy) {
          return new ByteBuddy()
                  .subclass(Object.class)
                  .name(className)
                  .make()
                  .load(classLoader, strategy)
                  .getLoaded();
      }
  
      private static void rethrowUnlessUnsupportedFeatureError(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static final class RejectingPackageClassLoader extends URLClassLoader {
          private RejectingPackageClassLoader(ClassLoader parent) {
              super(new URL[0], parent);
          }
  
          @Override
          protected Package definePackage(
                  String name,
                  String specificationTitle,
                  String specificationVersion,
                  String specificationVendor,
                  String implementationTitle,
                  String implementationVersion,
                  String implementationVendor,
                  URL sealBase) {
              if (PARENT_PACKAGE_NAME.equals(name)) {
                  throw new IllegalStateException("Use parent package definition");
              }
              return super.definePackage(
                      name,
                      specificationTitle,
                      specificationVersion,
                      specificationVendor,
                      implementationTitle,
                      implementationVersion,
                      implementationVendor,
                      sealBase);
          }
      }
