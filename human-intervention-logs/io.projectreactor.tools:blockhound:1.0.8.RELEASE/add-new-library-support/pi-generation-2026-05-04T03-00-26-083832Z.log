  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.BeforeEach;
  import org.junit.jupiter.api.Test;
  
  import reactor.blockhound.shaded.net.bytebuddy.agent.Attacher;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AttacherTest {
      @BeforeEach
      void resetRecordingVirtualMachine() {
          RecordingVirtualMachine.reset();
      }
  
      @Test
      void mainAttachesAgentFromJarAndDetachesVirtualMachine() {
          Attacher.main(new String[] {
              RecordingVirtualMachine.class.getName(),
              "12345",
              "agent.jar",
              "false",
              "=alpha",
              "beta"
          });
  
          assertThat(RecordingVirtualMachine.attachedProcessId).isEqualTo("12345");
          assertThat(RecordingVirtualMachine.loadedAgent).isEqualTo("agent.jar");
          assertThat(RecordingVirtualMachine.loadedAgentArgument).isEqualTo("alpha beta");
          assertThat(RecordingVirtualMachine.loadedAgentPath).isNull();
          assertThat(RecordingVirtualMachine.detached).isTrue();
      }
  
      @Test
      void mainAttachesAgentFromNativePathAndDetachesVirtualMachine() {
          Attacher.main(new String[] {
              RecordingVirtualMachine.class.getName(),
              "67890",
              "native-agent",
              "true",
              ""
          });
  
          assertThat(RecordingVirtualMachine.attachedProcessId).isEqualTo("67890");
          assertThat(RecordingVirtualMachine.loadedAgentPath).isEqualTo("native-agent");
          assertThat(RecordingVirtualMachine.loadedAgentArgument).isNull();
          assertThat(RecordingVirtualMachine.loadedAgent).isNull();
          assertThat(RecordingVirtualMachine.detached).isTrue();
      }
  
      public static final class RecordingVirtualMachine {
          private static String attachedProcessId;
          private static String loadedAgent;
          private static String loadedAgentPath;
          private static String loadedAgentArgument;
          private static boolean detached;
  
          private RecordingVirtualMachine() {
          }
  
          public static RecordingVirtualMachine attach(String processId) {
              attachedProcessId = processId;
              return new RecordingVirtualMachine();
          }
  
          public void loadAgent(String agent, String argument) {
              loadedAgent = agent;
              loadedAgentArgument = argument;
          }
  
          public void loadAgentPath(String agentPath, String argument) {
              loadedAgentPath = agentPath;
              loadedAgentArgument = argument;
          }
  
          public void detach() {
              detached = true;
          }
  
          private static void reset() {
              attachedProcessId = null;
              loadedAgent = null;
              loadedAgentPath = null;
              loadedAgentArgument = null;
              detached = false;
          }
      }
  }
