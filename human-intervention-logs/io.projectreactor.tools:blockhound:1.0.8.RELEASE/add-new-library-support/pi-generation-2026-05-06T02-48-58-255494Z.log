  class ModuleReadEdgeProbe {
      private static final String AGENT_CLASS =
              "reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent";
      private static final String INSTALLER_CLASS =
              "reactor.blockhound.shaded.net.bytebuddy.agent.Installer";
  
      public static void main(String[] args) throws Exception {
          Path agentModules = Path.of(args[0]);
          String agentModuleName = args[1];
          String installerModuleName = args[2];
  
          Class<?> installer = Class.forName(INSTALLER_CLASS, true, ClassLoader.getSystemClassLoader());
          Object instrumentation = Proxy.newProxyInstance(ModuleReadEdgeProbe.class.getClassLoader(),
                  new Class<?>[] { Instrumentation.class },
                  (proxy, method, methodArguments) -> defaultValue(method.getReturnType()));
          installer.getMethod("agentmain", String.class, Instrumentation.class)
                  .invoke(null, "probe", instrumentation);
  
          ModuleFinder finder = ModuleFinder.of(agentModules);
          Configuration configuration = ModuleLayer.boot()
                  .configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(agentModuleName));
          ModuleLayer layer = ModuleLayer.boot()
                  .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
          Class<?> agent = layer.findLoader(agentModuleName).loadClass(AGENT_CLASS);
          Module agentModule = agent.getModule();
          Module installerModule = ModuleLayer.boot()
                  .findModule(installerModuleName)
                  .orElseThrow(() -> new IllegalStateException("Installer module was not resolved"));
          if (agentModule.canRead(installerModule)) {
              throw new IllegalStateException("Agent module unexpectedly reads installer module before lookup");
          }
          Method getInstrumentation = agent.getMethod("getInstrumentation");
          try {
              Object result = getInstrumentation.invoke(null);
              if (result != instrumentation) {
                  throw new IllegalStateException("Unexpected instrumentation instance");
              }
              if (!agentModule.canRead(installerModule)) {
                  throw new IllegalStateException("Agent module did not gain a read edge to installer module");
              }
          } catch (InvocationTargetException exception) {
              Throwable cause = exception.getTargetException();
              if (cause instanceof Exception nestedException) {
                  throw nestedException;
              }
              if (cause instanceof Error nestedError) {
                  throw nestedError;
              }
              throw new IllegalStateException(cause);
          } finally {
              installer.getMethod("agentmain", String.class, Instrumentation.class)
                      .invoke(null, "clear", null);
          }
      }
  
      private static Object defaultValue(Class<?> returnType) {
          if (!returnType.isPrimitive()) {
              return null;
          }
          if (returnType == boolean.class) {
              return false;
          }
          if (returnType == long.class) {
              return 0L;
          }
          if (returnType == float.class) {
              return 0F;
          }
          if (returnType == double.class) {
              return 0D;
          }
          if (returnType == void.class) {
              return null;
          }
          return 0;
