  package io_projectreactor_tools.blockhound;
  
  import java.net.URL;
  import java.security.Permission;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.description.modifier.Visibility;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {
      private static final String BYTE_BUDDY_SAFE_PROPERTY = "reactor.blockhound.shaded.net.bytebuddy.safe";
      private static final String PACKAGE_NAME = "io_projectreactor_tools.blockhound.generated";
  
      static {
          System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, "false");
      }
  
      @Test
      void injectionDefinesClassAndPackageThroughUnsafeReflectionDispatcher() {
          try {
              PackageAwareClassLoader classLoader = new PackageAwareClassLoader();
              String className = PACKAGE_NAME + ".InjectedType";
  
              Class<?> loaded = generatedType(className)
                      .load(classLoader, packageDefiningInjection())
                      .getLoaded();
  
              assertThat(loaded.getName()).isEqualTo(className);
              assertThat(loaded.getClassLoader()).isSameAs(classLoader);
              assertThat(loaded.getPackage()).isNotNull();
              assertThat(loaded.getPackage().getName()).isEqualTo(PACKAGE_NAME);
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          }
      }
  
      @Test
      void rejectedPackageDefinitionExercisesPackageFallback() {
          try {
              RejectingPackageClassLoader classLoader = new RejectingPackageClassLoader();
              String className = PACKAGE_NAME + ".RejectedPackageType";
  
              generatedType(className).load(classLoader, packageDefiningInjection());
              throw new AssertionError("Expected package definition to be rejected");
          } catch (IllegalStateException exception) {
              assertThat(exception).hasMessageContaining(RejectingPackageClassLoader.REJECTION_MESSAGE);
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          }
      }
  
      @Test
      @SuppressWarnings("removal")
      void injectionInitializesUnsafeReflectionDispatcherWithSecurityManager() {
          SecurityManager previousSecurityManager = null;
          boolean securityManagerChanged = false;
          try {
              previousSecurityManager = System.getSecurityManager();
              System.setSecurityManager(new PermissiveSecurityManager());
              securityManagerChanged = true;
              PackageAwareClassLoader classLoader = new PackageAwareClassLoader();
              String className = PACKAGE_NAME + ".SecurityManagedType";
  
              Class<?> loaded = generatedType(className)
                      .load(classLoader, ClassLoadingStrategy.Default.INJECTION)
                      .getLoaded();
  
              assertThat(loaded.getName()).isEqualTo(className);
              assertThat(loaded.getClassLoader()).isSameAs(classLoader);
          } catch (UnsupportedOperationException exception) {
              assertThat(exception).isNotNull();
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          } finally {
              if (securityManagerChanged) {
                  System.setSecurityManager(previousSecurityManager);
              }
          }
      }
  
      private static DynamicType.Unloaded<Object> generatedType(String className) {
          return new ByteBuddy()
                  .subclass(Object.class)
                  .name(className)
                  .defineField("marker", String.class, Visibility.PUBLIC)
                  .make();
      }
  
      private static ClassLoadingStrategy.Configurable<ClassLoader> packageDefiningInjection() {
          return ClassLoadingStrategy.Default.INJECTION.with(definingPackages());
      }
  
      private static PackageDefinitionStrategy definingPackages() {
          return (classLoader, packageName, typeName) -> PackageDefinitionStrategy.Definition.Trivial.INSTANCE;
      }
  
      private static void verifyNativeImageUnsupportedFeature(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      private static class PackageAwareClassLoader extends ClassLoader {
          PackageAwareClassLoader() {
              super(ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());
          }
      }
  
      @SuppressWarnings("removal")
      private static final class PermissiveSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              permission.getClass();
          }
      }
  
      private static final class RejectingPackageClassLoader extends PackageAwareClassLoader {
          private static final String REJECTION_MESSAGE = "deliberate package rejection";
  
          @Override
          protected Package definePackage(String name, String specificationTitle, String specificationVersion,
                  String specificationVendor, String implementationTitle, String implementationVersion,
                  String implementationVendor, URL sealBase) {
              throw new IllegalStateException(REJECTION_MESSAGE);
          }
  
          @Override
          protected Package getPackage(String name) {
              return null;
          }
      }
  }
