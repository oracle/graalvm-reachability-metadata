  package io_projectreactor_tools.blockhound;
  
  import java.io.IOException;
  import java.io.InputStream;
  import java.net.URL;
  import java.util.Enumeration;
  import java.util.LinkedHashMap;
  import java.util.Map;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.description.modifier.Visibility;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ByteArrayClassLoader;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteArrayClassLoaderInnerChildFirstTest {
      private static final String PACKAGE_NAME = "io_projectreactor_tools.blockhound.childfirst.generated";
  
      @Test
      void staticLoadDefinesClassWithChildFirstLookupAndShadowsLatentClassResource() {
          try {
              DynamicType.Unloaded<Object> generatedType = generatedType(PACKAGE_NAME + ".StaticLoadedType");
              Map<TypeDescription, byte[]> types = new LinkedHashMap<>();
              types.put(generatedType.getTypeDescription(), generatedType.getBytes());
  
              Map<TypeDescription, Class<?>> loadedTypes = ByteArrayClassLoader.ChildFirst.load(
                      parentClassLoader(), types);
              Class<?> loaded = loadedTypes.get(generatedType.getTypeDescription());
  
              assertThat(loaded).isNotNull();
              assertThat(loaded.getName()).isEqualTo(generatedType.getTypeDescription().getName());
              assertThat(loaded.getClassLoader()).isInstanceOf(ByteArrayClassLoader.ChildFirst.class);
              assertThat(loaded.getClassLoader().getResource(resourceName(loaded.getName()))).isNull();
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          }
      }
  
      @Test
      void getResourceAndGetResourcesFallBackToParentWhenResourceIsNotShadowed() throws IOException {
          ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(
                  parentClassLoader(), Map.of());
          String testClassResourceName = resourceName(ByteArrayClassLoaderInnerChildFirstTest.class.getName());
  
          URL resource = classLoader.getResource(testClassResourceName);
          Enumeration<URL> resources = classLoader.getResources(testClassResourceName);
  
          assertThat(resource).isNotNull();
          assertThat(resources.hasMoreElements()).isTrue();
          assertThat(resources.nextElement()).isEqualTo(resource);
      }
  
      @Test
      void getResourcesPrependsManifestChildResourceBeforeParentResources() throws IOException {
          try {
              DynamicType.Unloaded<Object> generatedType = generatedType(PACKAGE_NAME + ".ManifestResourceType");
              String className = generatedType.getTypeDescription().getName();
              ByteArrayClassLoader.ChildFirst classLoader = new ByteArrayClassLoader.ChildFirst(
                      parentClassLoader(),
                      Map.of(className, generatedType.getBytes()),
                      ByteArrayClassLoader.PersistenceHandler.MANIFEST);
  
              Enumeration<URL> resources = classLoader.getResources(resourceName(className));
  
              assertThat(resources.hasMoreElements()).isTrue();
              try (InputStream inputStream = resources.nextElement().openStream()) {
                  assertThat(inputStream.read()).isEqualTo(0xCA);
              }
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          }
      }
  
      private static DynamicType.Unloaded<Object> generatedType(String className) {
          return new ByteBuddy()
                  .subclass(Object.class)
                  .name(className)
                  .defineField("marker", String.class, Visibility.PUBLIC)
                  .make();
      }
  
      private static String resourceName(String className) {
          return className.replace('.', '/') + ".class";
      }
  
      private static ClassLoader parentClassLoader() {
          return ByteArrayClassLoaderInnerChildFirstTest.class.getClassLoader();
      }
  
      private static void verifyNativeImageUnsupportedFeature(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  }
