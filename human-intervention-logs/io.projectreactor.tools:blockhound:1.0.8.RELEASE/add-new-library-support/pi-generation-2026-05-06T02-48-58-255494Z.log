[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/NexusAccessorInnerDispatcherInnerCreationActionTest.java","edits":[{"oldText":"    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n","newText":"    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n\nclass NexusAccessorCreationActionReadEdgeProbe {\n    private static final String NEXUS_CLASS = \"reactor.blockhound.shaded.net.bytebuddy.dynamic.Nexus\";\n    private static final String NEXUS_ACCESSOR_CLASS =\n            \"reactor.blockhound.shaded.net.bytebuddy.dynamic.NexusAccessor\";\n\n    public static void main(String[] args) throws Exception {\n        Path libraryJar = Path.of(args[0]);\n        String sourceModuleName = args[1];\n        String targetModuleName = args[2];\n\n        Class<?> systemNexus = ClassLoader.getSystemClassLoader().loadClass(NEXUS_CLASS);\n        if (!targetModuleName.equals(systemNexus.getModule().getName())) {\n            throw new IllegalStateException(\"System Nexus was not loaded from the target module\");\n        }\n\n        ModuleFinder finder = new InMemoryBlockHoundModuleFinder(sourceModuleName, libraryJar);\n        Configuration configuration = ModuleLayer.boot()\n                .configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(sourceModuleName));\n        ModuleLayer layer = ModuleLayer.boot()\n                .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n        Class<?> accessor = layer.findLoader(sourceModuleName).loadClass(NEXUS_ACCESSOR_CLASS);\n        if (accessor.getModule().canRead(systemNexus.getModule())) {\n            throw new IllegalStateException(\"Source module unexpectedly reads target module before Nexus lookup\");\n        }\n\n        Object alive;\n        try {\n            alive = accessor.getMethod(\"isAlive\").invoke(null);\n        } catch (InvocationTargetException exception) {\n            Throwable cause = exception.getTargetException();\n            if (cause instanceof Exception nestedException) {\n                throw nestedException;\n            }\n            if (cause instanceof Error nestedError) {\n                throw nestedError;\n            }\n            throw new IllegalStateException(cause);\n        }\n        if (!Boolean.TRUE.equals(alive)) {\n            throw new IllegalStateException(\"Named module NexusAccessor was not alive\");\n        }\n        if (!accessor.getModule().canRead(systemNexus.getModule())) {\n            throw new IllegalStateException(\"NexusAccessor did not add a read edge to the target Nexus module\");\n        }\n    }\n\n    private static final class InMemoryBlockHoundModuleFinder implements ModuleFinder {\n        private final ModuleReference reference;\n\n        InMemoryBlockHoundModuleFinder(String moduleName, Path libraryJar) throws IOException {\n            Map<String, byte[]> entries = new LinkedHashMap<>();\n            Set<String> packages = new TreeSet<>();\n            try (JarFile jarFile = new JarFile(libraryJar.toFile())) {\n                Enumeration<JarEntry> jarEntries = jarFile.entries();\n                while (jarEntries.hasMoreElements()) {\n                    JarEntry entry = jarEntries.nextElement();\n                    if (entry.isDirectory()\n                            || !entry.getName().endsWith(\".class\")\n                            || \"module-info.class\".equals(entry.getName())) {\n                        continue;\n                    }\n                    try (InputStream inputStream = jarFile.getInputStream(entry)) {\n                        entries.put(entry.getName(), inputStream.readAllBytes());\n                    }\n                    int separator = entry.getName().lastIndexOf('/');\n                    if (separator > 0) {\n                        packages.add(entry.getName().substring(0, separator).replace('/', '.'));\n                    }\n                }\n            }\n            ModuleDescriptor descriptor = ModuleDescriptor.newModule(moduleName)\n                    .requires(\"java.instrument\")\n                    .exports(\"reactor.blockhound.shaded.net.bytebuddy.dynamic\")\n                    .packages(packages)\n                    .build();\n            reference = new InMemoryModuleReference(descriptor, entries);\n        }\n\n        @Override\n        public Optional<ModuleReference> find(String name) {\n            return reference.descriptor().name().equals(name)\n                    ? Optional.of(reference)\n                    : Optional.empty();\n        }\n\n        @Override\n        public Set<ModuleReference> findAll() {\n            return Collections.singleton(reference);\n        }\n    }\n\n    private static final class InMemoryModuleReference extends ModuleReference {\n        private final Map<String, byte[]> entries;\n\n        InMemoryModuleReference(ModuleDescriptor descriptor, Map<String, byte[]> entries) {\n            super(descriptor, URI.create(\"memory:///\" + descriptor.name()));\n            this.entries = entries;\n        }\n\n        @Override\n        public ModuleReader open() {\n            return new InMemoryModuleReader(entries);\n        }\n    }\n\n    private static final class InMemoryModuleReader implements ModuleReader {\n        private final Map<String, byte[]> entries;\n\n        InMemoryModuleReader(Map<String, byte[]> entries) {\n            this.entries = entries;\n        }\n\n        @Override\n        public Optional<URI> find(String name) {\n            return Optional.empty();\n        }\n\n        @Override\n        public Optional<InputStream> open(String name) {\n            return Optional.empty();\n        }\n\n        @Override\n        public Optional<ByteBuffer> read(String name) {\n            byte[] bytes = entries.get(name);\n            return bytes == null\n                    ? Optional.empty()\n                    : Optional.of(ByteBuffer.wrap(bytes));\n        }\n\n        @Override\n        public void release(ByteBuffer byteBuffer) {\n            byteBuffer.position(0);\n        }\n\n        @Override\n        public Stream<String> list() {\n            return entries.keySet().stream();\n        }\n\n        @Override\n        public void close() {\n        }\n    }\n}\n"}]}
