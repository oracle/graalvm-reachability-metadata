. It seems I should keep the primary as it is. I need to figure out how to implement module copying with `javac` while keeping it within the same JVM. Then there's the dynamic class loading of module classes, which feels open-ended. But since Native Image might not support this, I’ll need to catch errors and verify along the way.\"},{\"type\":\"summary_text\",\"text\":\"**Considering code structure**\\n\\nI'm thinking about class or file names, and it's alright to have strings. I need to reflect directly in the test, and I plan to use reflection to invoke public methods from classes loaded in the generated module. It seems public API is required here. I wonder if I should add a comment — but maybe not. I also need to check imports and ensure I'm adhering to Checkstyle line length limits, keeping existing lines around 120. Alright, I'll implement it!\"}]}"}, {"type": "toolCall", "id": "call_mMpIrYYJY0Gku6vZqO102CzR|fc_07066c0709a9ed1a0169faabcffc408190b6d1dff879b2749b", "name": "write", "arguments": {"path": "tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/NexusAccessorInnerDispatcherInnerCreationActionTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.lang.reflect.InvocationTargetException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.security.CodeSource;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.Set;\nimport java.util.concurrent.TimeUnit;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarFile;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Order;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.TestMethodOrder;\nimport org.junit.jupiter.api.MethodOrderer.OrderAnnotation;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.NexusAccessor;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@TestMethodOrder(OrderAnnotation.class)\npublic class NexusAccessorInnerDispatcherInnerCreationActionTest {\n    private static final String MODULE_NAME = \"blockhound.nexus.creationaction\";\n    private static final String NEXUS_CLASS = \"reactor.blockhound.shaded.net.bytebuddy.dynamic.Nexus\";\n    private static final String NEXUS_ACCESSOR_CLASS =\n            \"reactor.blockhound.shaded.net.bytebuddy.dynamic.NexusAccessor\";\n\n    @TempDir\n    Path tempDirectory;\n\n    @Test\n    @Order(1)\n    void systemAccessorCreationInjectsNexusAndResolvesItsPublicMethods() {\n        try {\n            assertThat(NexusAccessor.isAlive()).isTrue();\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    @Test\n    @Order(2)\n    void namedModuleAccessorFallsBackToSystemNexusAndAddsReadEdge() throws Exception {\n        try {\n            Class<?> systemNexus = ClassLoader.getSystemClassLoader().loadClass(NEXUS_CLASS);\n            ModuleLayer layer = defineNamedBlockHoundModule();\n            Class<?> accessor = layer.findLoader(MODULE_NAME).loadClass(NEXUS_ACCESSOR_CLASS);\n            assertThat(accessor.getModule().canRead(systemNexus.getModule())).isFalse();\n\n            Object alive = accessor.getMethod(\"isAlive\").invoke(null);\n\n            assertThat(alive).isEqualTo(Boolean.TRUE);\n        } catch (InvocationTargetException exception) {\n            rethrowInvocationTarget(exception);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    private ModuleLayer defineNamedBlockHoundModule() throws IOException, InterruptedException {\n        Path modulesDirectory = tempDirectory.resolve(\"modules\");\n        Path moduleRoot = modulesDirectory.resolve(MODULE_NAME);\n        copyLibraryClasses(moduleRoot);\n        writeAndCompileModuleDescriptor(moduleRoot);\n\n        ModuleFinder finder = ModuleFinder.of(modulesDirectory);\n        Configuration configuration = ModuleLayer.boot()\n                .configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(MODULE_NAME));\n        return ModuleLayer.boot().defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n    }\n\n    private static void copyLibraryClasses(Path moduleRoot) throws IOException {\n        try (JarFile jarFile = new JarFile(locateLibraryJar().toFile())) {\n            Enumeration<JarEntry> entries = jarFile.entries();\n            while (entries.hasMoreElements()) {\n                JarEntry entry = entries.nextElement();\n                if (entry.isDirectory() || !entry.getName().endsWith(\".class\")) {\n                    continue;\n                }\n                Path target = moduleRoot.resolve(entry.getName());\n                Files.createDirectories(target.getParent());\n                try (InputStream inputStream = jarFile.getInputStream(entry)) {\n                    Files.copy(inputStream, target);\n                }\n            }\n        }\n    }\n\n    private static void writeAndCompileModuleDescriptor(Path moduleRoot) throws IOException, InterruptedException {\n        Files.writeString(moduleRoot.resolve(\"module-info.java\"), \"\"\"\n                module %s {\n                    requires java.instrument;\n                    exports reactor.blockhound.shaded.net.bytebuddy.dynamic;\n                }\n                \"\"\".formatted(MODULE_NAME));\n        Process process = new ProcessBuilder(javacExecutable().toString(),\n                \"-d\", moduleRoot.toString(),\n                moduleRoot.resolve(\"module-info.java\").toString())\n                .redirectOutput(ProcessBuilder.Redirect.INHERIT)\n                .redirectError(ProcessBuilder.Redirect.INHERIT)\n                .start();\n        int exitCode = waitForProcess(process, \"javac\");\n        if (exitCode != 0) {\n            throw new IllegalStateException(\"Could not compile modular BlockHound fixture: javac exited \" + exitCode);\n        }\n    }\n\n    private static int waitForProcess(Process process, String description) throws InterruptedException {\n        if (!process.waitFor(30, TimeUnit.SECONDS)) {\n            process.destroyForcibly();\n            throw new IllegalStateException(description + \" did not complete within 30 seconds\");\n        }\n        return process.exitValue();\n    }\n\n    private static Path javacExecutable() {\n        String executable = System.getProperty(\"os.name\", \"\").toLowerCase().contains(\"windows\")\n                ? \"javac.exe\"\n                : \"javac\";\n        return Path.of(System.getProperty(\"java.home\"), \"bin\", executable);\n    }\n\n    private static Path locateLibraryJar() {\n        CodeSource codeSource = NexusAccessor.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLocation().getProtocol())) {\n            throw new IllegalStateException(\"Cannot locate BlockHound library jar\");\n        }\n        try {\n            return Path.of(codeSource.getLocation().toURI());\n        } catch (Exception exception) {\n            return Path.of(codeSource.getLocation().getPath());\n        }\n    }\n\n    private static void rethrowInvocationTarget(InvocationTargetException exception) throws Exception {\n        Throwable cause = exception.getTargetException();\n        if (cause instanceof Exception nestedException) {\n            throw nestedException;\n        }\n        if (cause instanceof Error nestedError) {\n            throw nestedError;\n        }\n        throw new IllegalStateException(ca