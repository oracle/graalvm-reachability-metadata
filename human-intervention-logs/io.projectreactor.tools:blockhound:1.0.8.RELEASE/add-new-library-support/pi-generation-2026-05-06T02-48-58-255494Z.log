  package io_projectreactor_tools.blockhound;
  
  import java.io.File;
  import java.io.IOException;
  import java.io.InputStream;
  import java.lang.ProcessBuilder.Redirect;
  import java.lang.instrument.ClassDefinition;
  import java.lang.instrument.ClassFileTransformer;
  import java.lang.instrument.Instrumentation;
  import java.lang.instrument.UnmodifiableClassException;
  import java.lang.module.Configuration;
  import java.lang.module.ModuleFinder;
  import java.lang.reflect.InvocationTargetException;
  import java.lang.reflect.Method;
  import java.lang.reflect.Proxy;
  import java.net.URISyntaxException;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.security.CodeSource;
  import java.util.Collections;
  import java.util.List;
  import java.util.Map;
  import java.util.Set;
  import java.util.concurrent.TimeUnit;
  import java.util.jar.JarEntry;
  import java.util.jar.JarFile;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.AttachmentProvider;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.AttachmentProvider.Accessor;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.AttachmentProvider.Accessor.ExternalAttachment;
  import reactor.blockhound.shaded.net.bytebuddy.agent.Installer;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteBuddyAgentTest {
      private static final String ALLOW_SELF_ATTACH_PROPERTY = "jdk.attach.allowAttachSelf";
  
      @TempDir
      File tempDirectory;
  
      @Test
      void getInstrumentationPerformsInstallerLookup() {
          try {
              assertThat(ByteBuddyAgent.getInstrumentation()).isNotNull();
          } catch (IllegalStateException exception) {
              assertThat(exception).hasMessageContaining("Byte Buddy agent is not initialized");
          }
      }
  
      @Test
      void getInstrumentationReturnsInstalledInstrumentation() {
          TestInstrumentation instrumentation = new TestInstrumentation();
          try {
              Installer.agentmain("test", instrumentation);
  
              assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);
          } finally {
              Installer.agentmain("clear", null);
          }
      }
  
      @Test
      void namedModuleCopyAddsReadEdgeBeforeInstallerLookup() throws Exception {
          TestInstrumentation instrumentation = new TestInstrumentation();
          try {
              Installer.agentmain("test", instrumentation);
  
              assertThat(runModuleReadEdgeProbe()).isEqualTo(0);
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          } finally {
              Installer.agentmain("clear", null);
          }
      }
  
      @Test
      void externalAttachmentCreatesTemporaryAttacherJarWhenSelfResolutionIsDisabled() {
          String previousLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);
          String previousAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);
          System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());
          System.clearProperty(ALLOW_SELF_ATTACH_PROPERTY);
          try {
              try {
                  ByteBuddyAgent.attach(new File(tempDirectory, "agent.jar"),
                          () -> Long.toString(ProcessHandle.current().pid()),
                          "coverage",
                          new ExternalOnlyAttachmentProvider());
              } catch (IllegalStateException exception) {
                  assertThat(exception.getMessage()).containsAnyOf(
                          "Could not self-attach to current VM using external process",
                          "Error during attachment using");
              }
          } finally {
              restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, previousLatentResolve);
              restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttach);
          }
      }
  
      private int runModuleReadEdgeProbe() throws IOException, InterruptedException {
          Path moduleFixtures = tempDirectory.toPath().resolve("module-fixtures");
          Path installerModules = moduleFixtures.resolve("installer-modules");
          Path agentModules = moduleFixtures.resolve("agent-modules");
          String installerModule = "reactor.blockhound.installer.copy";
          String agentModule = "reactor.blockhound.agent.copy";
          Path installerModuleRoot = installerModules.resolve(installerModule);
          Path agentModuleRoot = agentModules.resolve(agentModule);
          copyLibraryClasses(installerModuleRoot, "reactor/blockhound/shaded/net/bytebuddy/agent/Installer.class");
          copyLibraryClasses(agentModuleRoot, "reactor/blockhound/shaded/net/bytebuddy/agent/ByteBuddyAgent");
          copyLibraryClasses(agentModuleRoot, "reactor/blockhound/shaded/net/bytebuddy/agent/Installer.class");
          compileModuleDescriptor(installerModule, installerModuleRoot);
          compileModuleDescriptor(agentModule, agentModuleRoot);
  
          Process process = new ProcessBuilder(javaExecutable().toString(),
                  "--module-path", installerModules.toString(),
                  "--add-modules", installerModule,
                  "-cp", probeClassPath().toString(),
                  ModuleReadEdgeProbe.class.getName(),
                  agentModules.toString(),
                  agentModule,
                  installerModule)
                  .redirectOutput(Redirect.INHERIT)
                  .redirectError(Redirect.INHERIT)
                  .start();
          return waitForProcess(process, "module read edge probe");
      }
  
      private static void copyLibraryClasses(Path moduleRoot, String includedEntryPrefix) throws IOException {
          try (JarFile jarFile = new JarFile(locateLibraryJar().toFile())) {
              for (JarEntry entry : Collections.list(jarFile.entries())) {
                  if (entry.isDirectory()
                          || !entry.getName().startsWith(includedEntryPrefix)
                          || !entry.getName().endsWith(".class")) {
                      continue;
                  }
                  Path target = moduleRoot.resolve(entry.getName());
                  Files.createDirectories(target.getParent());
                  try (InputStream inputStream = jarFile.getInputStream(entry)) {
                      Files.copy(inputStream, target);
                  }
              }
          }
      }
  
      private static void compileModuleDescriptor(String moduleName, Path moduleRoot)
              throws IOException, InterruptedException {
          Path descriptor = moduleRoot.resolve("module-info.java");
          Files.writeString(descriptor, """
                  module %s {
                      requires java.instrument;
                      exports reactor.blockhound.shaded.net.bytebuddy.agent;
                  }
                  """.formatted(moduleName));
          Process process = new ProcessBuilder(javacExecutable().toString(),
                  "--patch-module", moduleName + "=" + moduleRoot,
                  "-d", moduleRoot.toString(),
                  descriptor.toString())
                  .redirectOutput(Redirect.INHERIT)
                  .redirectError(Redirect.INHERIT)
                  .start();
          int exitCode = waitForProcess(process, "javac");
          if (exitCode != 0) {
              throw new IllegalStateException(
                      "Could not compile modular BlockHound fixture: javac exited " + exitCode);
          }
      }
  
      private static int waitForProcess(Process process, String description) throws InterruptedException {
          if (!process.waitFor(30, TimeUnit.SECONDS)) {
              process.destroyForcibly();
              throw new IllegalStateException(description + " did not complete within 30 seconds");
          }
          return process.exitValue();
      }
  
      private static Path javaExecutable() {
          String executable = System.getProperty("os.name", "").toLowerCase().contains("windows")
                  ? "java.exe"
                  : "java";
          return Path.of(System.getProperty("java.home"), "bin", executable);
      }
  
      private static Path javacExecutable() {
          String executable = System.getProperty("os.name", "").toLowerCase().contains("windows")
                  ? "javac.exe"
                  : "javac";
          return Path.of(System.getProperty("java.home"), "bin", executable);
      }
  
      private static Path probeClassPath() {
          CodeSource codeSource = ModuleReadEdgeProbe.class.getProtectionDomain().getCodeSource();
          if (codeSource == null || !"file".equals(codeSource.getLocation().getProtocol())) {
              throw new IllegalStateException("Cannot locate module read edge probe classes");
          }
          try {
              return Path.of(codeSource.getLocation().toURI());
          } catch (URISyntaxException exception) {
              return Path.of(codeSource.getLocation().getPath());
          }
      }
  
      private static Path locateLibraryJar() {
          CodeSource codeSource = ByteBuddyAgent.class.getProtectionDomain().getCodeSource();
          if (codeSource == null || !"file".equals(codeSource.getLocation().getProtocol())) {
              throw new IllegalStateException("Cannot locate BlockHound library jar");
          }
          try {
              return Path.of(codeSource.getLocation().toURI());
          } catch (URISyntaxException exception) {
              return Path.of(codeSource.getLocation().getPath());
          }
      }
  
      private static void restoreProperty(String name, String value) {
          if (value == null) {
              System.clearProperty(name);
          } else {
              System.setProperty(name, value);
          }
      }
  
      private static List<File> recordingVirtualMachineClassPath() {
          CodeSource codeSource = RecordingVirtualMachine.class.getProtectionDomain().getCodeSource();
          if (codeSource == null || !"file".equals(codeSource.getLocation().getProtocol())) {
              return Collections.emptyList();
          }
          try {
              return Collections.singletonList(new File(codeSource.getLocation().toURI()));
          } catch (URISyntaxException exception) {
              return Collections.singletonList(new File(codeSource.getLocation().getPath()));
          }
      }
  
      private static final class ExternalOnlyAttachmentProvider implements AttachmentProvider {
          @Override
          public Accessor attempt() {
              return new ExternalOnlyAccessor();
          }
      }
  
      private static final class ExternalOnlyAccessor implements Accessor {
          @Override
          public boolean isAvailable() {
              return true;
          }
  
          @Override
          public boolean isExternalAttachmentRequired() {
  
