"));\n    }\n\n    static void rethrowIfNotExpectedNativeImageFailure(Throwable throwable) {\n        if (isExpectedNativeImageFailure(throwable)) {\n            return;\n        }\n        if (throwable instanceof RuntimeException runtimeException) {\n            throw runtimeException;\n        }\n        if (throwable instanceof Error error) {\n            throw error;\n        }\n        throw new AssertionError(throwable);\n    }\n\n    static boolean isExpectedNativeImageFailure(Throwable throwable) {\n        return hasUnsupportedFeatureError(throwable)\n                || hasShadedByteBuddyInitializationFailure(throwable)\n                || hasByteBuddyAttachmentFailure(throwable)\n                || hasNativeImageCodeSourceJarFailure(throwable);\n    }\n\n    private static boolean hasUnsupportedFeatureError(Throwable throwable) {\n        for (Throwable current = throwable; current != null; current = current.getCause()) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n        }\n        return false;\n    }\n\n    private static boolean hasShadedByteBuddyInitializationFailure(Throwable throwable) {\n        if (!isNativeImageRuntime()) {\n            return false;\n        }\n        for (Throwable current = throwable; current != null; current = current.getCause()) {\n            if (current instanceof ClassNotFoundException || current instanceof NoClassDefFoundError) {\n                String message = current.getMessage();\n                if (message != null && (message.contains(SHADED_BYTE_BUDDY_PREFIX)\n                        || message.contains(\"JavaDispatcherTest$ExposedJavaDispatcher\"))) {\n                    return true;\n                }\n            }\n        }\n        return false;\n    }\n\n    private static boolean hasByteBuddyAttachmentFailure(Throwable throwable) {\n        if (!isNativeImageRuntime()) {\n            return false;\n        }\n        for (Throwable current = throwable; current != null; current = current.getCause()) {\n            if (current instanceof IllegalStateException) {\n                String message = current.getMessage();\n                if (message != null && (message.startsWith(\"Error during attachment using:\")\n                        || \"No compatible attachment provider is available\".equals(message))) {\n                    return true;\n                }\n            }\n        }\n        return false;\n    }\n\n    private static boolean hasNativeImageCodeSourceJarFailure(Throwable throwable) {\n        if (!isNativeImageRuntime()) {\n            return false;\n        }\n        for (Throwable current = throwable; current != null; current = current.getCause()) {\n            if (current instanceof ZipException\n                    && \"zip END header not found\".equals(current.getMessage())) {\n                return true;\n            }\n        }\n        return false;\n    }\n}\n"}], "isError": false, "timestamp": 1781117064550}, {"role": "toolResult", "toolCallId": "call_iX8RuHsujE5GsVKzseg37H6B|fc_05a29ba766014dae016a29b0883eac8194ac4dbc4f2a26af6d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\n\nimport java.lang.instrument.Instrumentation;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.util.Collections;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingUnsafeInnerFactoryTest {\n    private static final String ALLOW_SELF_ATTACH_PROPERTY = \"jdk.attach.allowAttachSelf\";\n    private static final String SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String EXPERIMENTAL_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.experimental\";\n\n    @Test\n    void resolveCreatesUnsafeFallbackFactoryThroughGeneratedAccessResolver() throws Exception {\n        String previousAllowSelfAttachProperty = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        String previousSafeProperty = System.getProperty(SAFE_PROPERTY);\n        String previousExperimentalProperty = System.getProperty(EXPERIMENTAL_PROPERTY);\n        try {\n            System.setProperty(ALLOW_SELF_ATTACH_PROPERTY, Boolean.TRUE.toString());\n            System.setProperty(SAFE_PROPERTY, Boolean.TRUE.toString());\n            System.setProperty(EXPERIMENTAL_PROPERTY, Boolean.TRUE.toString());\n\n            Instrumentation instrumentation = ByteBuddyAgent.install();\n            ClassInjector.UsingUnsafe.Factory factory = ClassInjector.UsingUnsafe.Factory.resolve(\n                    instrumentation,\n                    false);\n            assertThat(factory.isAvailable()).isTrue();\n\n            try (URLClassLoader classLoader = new URLClassLoader(\n                    new URL[0],\n                    ClassInjectorInnerUsingUnsafeInnerFactoryTest.class.getClassLoader())) {\n                String className = \"io_projectreactor_tools.blockhound.generated.unsafefactory.Injected\"\n                        + System.nanoTime();\n                DynamicType.Unloaded<?> dynamicType = new ByteBuddy()\n                        .subclass(Object.class)\n                        .name(className)\n                        .make();\n\n                Map<String, Class<?>> injectedTypes = factory.make(classLoader)\n                        .injectRaw(Collections.singletonMap(className, dynamicType.getBytes()));\n\n                Class<?> injectedType = injectedTypes.get(className);\n                assertThat(injectedType).isNotNull();\n                assertThat(injectedType.getName()).isEqualTo(className);\n                assertThat(injectedType.getClassLoader()).isSameAs(classLoader);\n            }\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        } finally {\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttachProperty);\n            restoreProperty(SAFE_PROPERTY, previousSafeProperty);\n            restoreProperty(EXPERIMENTAL_PROPERTY, previousExperimentalProperty);\n        }\n    }\n\n    private static void restoreProperty(String propertyName, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(propertyName);\n        } else {\n            System.setProperty(propertyName, previousValue);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781117064550}, {"role": "toolResult", "toolCallId": "call_wnuzr8Bl7JVBItn6hezSi6Q0|fc_05a29ba766014dae016a29b0883eb881948e6b5e942ae4cdba", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\n\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.util.Collections;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest {\n    private static final String SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String EXPERIMENTAL_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.experimental\";\n\n    @Test\n    void createsUnsafeDispatcherAndInjectsGeneratedClass() throws Exception {\n        String previousSafeProperty = System.getProperty(SAFE_PROPERTY);\n        String previousExperimentalProperty = System.getProperty(EXPERIMENTAL_PROPERTY);\n        try {\n            System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\n            System.setProperty(EXPERIMENTAL_PROPERTY, Boolean.TRUE.toString());\n            boolean unsafeAvailable = ClassInjector.UsingUnsafe.isAvailable();\n\n            try (URLClassLoader classLoader = new URLClassLoader(\n                    new URL[0],\n                    ClassInjectorInnerUsingUnsafeInnerDispatcherInnerCreationActionTest.class.getClassLoader())) {\n                ClassInjector.UsingUnsafe classInjector = new ClassInjector.UsingUnsafe(classLoader);\n                assertThat(classInjector.isAlive()).isEqualTo(unsafeAvailable);\n\n                if (unsafeAvailable) {\n                    String className = \"io_projectreactor_tools.blockhound.generated.unsafecreation.Injected\"\n                            + System.nanoTime();\n                    DynamicType.Unloaded<?> dynamicType = new ByteBuddy()\n                            .subclass(Object.class)\n                            .name(className)\n                            .make();\n\n                    Map<String, Class<?>> injectedTypes = classInjector\n                            .injectRaw(Collections.singletonMap(className, dynamicType.getBytes()));\n\n                    Class<?> injectedType = injectedTypes.get(className);\n                    assertThat(injectedType).isNotNull();\n                    assertThat(injectedType.getName()).isEqualTo(className);\n                    assertThat(injectedType.getClassLoader()).isSameAs(classLoader);\n                }\n            }\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        } finally {\n            restoreProperty(SAFE_PROPERTY, previousSafeProperty);\n            restoreProperty(EXPERIMENTAL_PROPERTY, previousExperimentalProperty);\n        }\n    }\n\n    private static void restoreProperty(String propertyName, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(propertyName);\n        } else {\n            System.setProperty(propertyName, previousValue);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781117064551}]}
