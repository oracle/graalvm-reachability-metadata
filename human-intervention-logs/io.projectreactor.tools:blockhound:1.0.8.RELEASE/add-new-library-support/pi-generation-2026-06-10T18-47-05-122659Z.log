  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  
  import java.lang.instrument.Instrumentation;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.util.Collections;
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingUnsafeInnerFactoryTest {
      private static final String ALLOW_SELF_ATTACH_PROPERTY = "jdk.attach.allowAttachSelf";
      private static final String SAFE_PROPERTY = "reactor.blockhound.shaded.net.bytebuddy.safe";
      private static final String EXPERIMENTAL_PROPERTY = "reactor.blockhound.shaded.net.bytebuddy.experimental";
  
      @Test
      void resolveCreatesUnsafeFallbackFactoryThroughGeneratedAccessResolver() throws Exception {
          String previousAllowSelfAttachProperty = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);
          String previousSafeProperty = System.getProperty(SAFE_PROPERTY);
          String previousExperimentalProperty = System.getProperty(EXPERIMENTAL_PROPERTY);
          try {
              System.setProperty(ALLOW_SELF_ATTACH_PROPERTY, Boolean.TRUE.toString());
              System.setProperty(SAFE_PROPERTY, Boolean.TRUE.toString());
              System.setProperty(EXPERIMENTAL_PROPERTY, Boolean.TRUE.toString());
  
              Instrumentation instrumentation = ByteBuddyAgent.install();
              ClassInjector.UsingUnsafe.Factory factory = ClassInjector.UsingUnsafe.Factory.resolve(
                      instrumentation,
                      false);
              assertThat(factory.isAvailable()).isTrue();
  
              try (URLClassLoader classLoader = new URLClassLoader(
                      new URL[0],
                      ClassInjectorInnerUsingUnsafeInnerFactoryTest.class.getClassLoader())) {
                  String className = "io_projectreactor_tools.blockhound.generated.unsafefactory.Injected"
                          + System.nanoTime();
                  DynamicType.Unloaded<?> dynamicType = new ByteBuddy()
                          .subclass(Object.class)
                          .name(className)
                          .make();
  
                  Map<String, Class<?>> injectedTypes = factory.make(classLoader)
                          .injectRaw(Collections.singletonMap(className, dynamicType.getBytes()));
  
                  Class<?> injectedType = injectedTypes.get(className);
                  assertThat(injectedType).isNotNull();
                  assertThat(injectedType.getName()).isEqualTo(className);
                  assertThat(injectedType.getClassLoader()).isSameAs(classLoader);
              }
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          } finally {
              restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttachProperty);
              restoreProperty(SAFE_PROPERTY, previousSafeProperty);
              restoreProperty(EXPERIMENTAL_PROPERTY, previousExperimentalProperty);
          }
      }
  
      private static void restoreProperty(String propertyName, String previousValue) {
          if (previousValue == null) {
              System.clearProperty(propertyName);
          } else {
              System.setProperty(propertyName, previousValue);
          }
      }
  }
