   void reflectionInjectorUsesUnsafeAccessorForClassAndPackageOperations() {\n        String previousSafeProperty = System.getProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        SecurityManager previousSecurityManager = System.getSecurityManager();\n        boolean securityManagerInstalled = false;\n\n        try {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, \"false\");\n            securityManagerInstalled = installSecurityManagerIfSupported(new PermissiveSecurityManager());\n\n            injectClassThroughReflectionDispatcher();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (RuntimeException exception) {\n            if (!isCausedByUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n            restoreSafeProperty(previousSafeProperty);\n        }\n    }\n\n    private static void injectClassThroughReflectionDispatcher() {\n        boolean unsafeInjectionAvailable = ClassInjector.UsingUnsafe.isAvailable();\n        boolean reflectionInjectionAvailable = ClassInjector.UsingReflection.isAvailable();\n\n        String packageName = PACKAGE_PREFIX + Long.toUnsignedString(System.nanoTime());\n        String className = packageName + \".Injected\";\n        byte[] classFile = new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .getBytes();\n\n        PackagePredefiningClassLoader classLoader = new PackagePredefiningClassLoader(\n                ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class.getClassLoader());\n        PackageDefinitionStrategy packageDefinitionStrategy = new PredefiningPackageDefinitionStrategy(classLoader);\n        ClassInjec