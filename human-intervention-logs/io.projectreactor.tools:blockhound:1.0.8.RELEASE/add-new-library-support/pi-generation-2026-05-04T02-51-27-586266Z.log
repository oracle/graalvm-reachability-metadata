dByMake();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } catch (RuntimeException exception) {\n            if (!isCausedByUnsupportedFeatureError(exception)) {\n                throw exception;\n            }\n        } catch (Exception exception) {\n            throw new IllegalStateException(exception);\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(previousSecurityManager);\n            }\n            restoreSafeProperty(previousSafeProperty);\n        }\n    }\n\n    private static boolean installSecurityManagerIfSupported(SecurityManager securityManager) {\n        try {\n            System.setSecurityManager(securityManager);\n            return System.getSecurityManager() == securityManager;\n        } catch (UnsupportedOperationException | SecurityException exception) {\n            return false;\n        }\n    }\n\n    private static boolean isCausedByUnsupportedFeatureError(Throwable throwable) {\n        Throwable current = throwable.getCause();\n        while (current != null) {\n            if (current instanceof Error error && NativeImageSupport.isUnsupportedFeatureError(error)) {\n                return true;\n            }\n            current = current.getCause();\n        }\n        return false;\n    }\n\n    private static void restoreSafeProperty(String previousSafeProperty) {\n        if (previousSafeProperty == null) {\n            System.clearProperty(BYTE_BUDDY_SAFE_PROPERTY);\n        } else {\n            System.setProperty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n        }\n    }\n\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n        }\n    }\n\n    private static final class OverrideDispatcherClassLoader extends ClassLoader {\n        private OverrideDispatcherClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n    }\n\n    private static final class UnsafeOverrideHarness extends ClassInjector.UsingReflection {\n        private UnsafeOverrideHarness(ClassLoader classLoader) {\n            super(classLoader);\n        }\n\n        private static void exerciseDispatcherCreatedByMake() throws Exception {\n            Dispatcher dispatcher = Dispatcher.UsingUnsafeOverride.make().initialize();\n            assertThat(dispatcher.isAvailable()).isTrue();\n\n            OverrideDispatcherClassLoader classLoader = new OverrideDispatcherClassLoader(\n                    ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest.class\n                            .getClassLoader());\n            String packageName = PACKAGE_PREFIX + Long.toUnsignedString(System.nanoTime());\n            String className = packageName + \".Injected\";\n            byte[] classFile = new ByteBuddy()\n                    .subclass(Object.class)\n                    .name(className)\n                    .make()\n                    .getBytes();\n\n            Object classLoadingLock = dispatcher.getClassLoadingLock(classLoader, className);\n            assertThat(classLoadingLock).isNotNull();\n\n            synchronized (classLoadingLock) {\n                assertThat(dispatcher.findClass(classLoader, className)).isNull();\n                assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isNull();\n\n                Package definedPackage = dispatcher.definePackage(\n                        classLoader,\n                        packageName,\n                        \"specification-title\",\n                        \"1\",\n                        \"specification-vendor\",\n                        \"implementation-title\",\n                        \"2\",\n                        \"implementation-vendor\",\n                        (URL) null);\n                assertThat(definedPackage.getName()).isEqualTo(packageName);\n                assertThat(dispatcher.getDefinedPackage(classLoader, packageName)).isSameAs(definedPackage);\n                assertThat(dispatcher.getPackage(classLoader, packageName)).isSameAs(definedPackage);\n\n                Class<?> definedClass = dispatcher.defineClass(classLoader, className, classFile, null);\n                assertThat(definedClass.getName()).isEqualTo(className);\n                assertThat(definedClass.getClassLoader()).isSameAs(classLoader);\n                assertThat(dispatcher.findClass(classLoader, className)).isSameAs(definedClass);\n                assertThat(Objects.requireNonNull(definedClass.getPackage()).getName()).isEqualTo(packageName);\n            }\n        }\n    }\n}\n"}
