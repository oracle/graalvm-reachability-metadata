ty(BYTE_BUDDY_SAFE_PROPERTY, previousSafeProperty);\n        }\n    }\n\n    private static final class PackagePredefiningClassLoader extends ClassLoader {\n        private PackagePredefiningClassLoader(ClassLoader parent) {\n            super(parent);\n        }\n\n        private void definePackageIfAbsent(String packageName) {\n            if (getDefinedPackage(packageName) == null) {\n                definePackage(packageName, null, null, null, null, null, null, null);\n            }\n        }\n\n        private Package getDefinedPackageForTest(String packageName) {\n            return getDefinedPackage(packageName);\n        }\n    }\n\n    private static final class PredefiningPackageDefinitionStrategy implements PackageDefinitionStrategy {\n        private final PackagePredefiningClassLoader classLoader;\n\n        private PredefiningPackageDefinitionStrategy(PackagePredefiningClassLoader classLoader) {\n            this.classLoader = classLoader;\n        }\n\n        @Override\n        public Definition define(ClassLoader classLoader, String packageName, String typeName) {\n            assertThat(classLoader).isSameAs(this.classLoader);\n            assertThat(typeName).startsWith(packageName + \".\");\n            return new PredefiningDefinition(this.classLoader, packageName);\n        }\n    }\n\n    private static final class PredefiningDefinition implements PackageDefinitionStrategy.Definition {\n        private final PackagePredefiningClassLoader classLoader;\n        private final String packageName;\n\n        private PredefiningDefinition(PackagePredefiningClassLoader classLoader, String packageName) {\n            this.classLoader = classLoader;\n            this.packageName = packageName;\n        }\n\n        @Override\n        public boolean isDefined() {\n            return true;\n        }\n\n        @Override\n        public String getSpecificationTitle() {\n            classLoader.definePackageIfAbsent(packageName);\n            return null;\n        }\n\n        @Override\n        public String getSpecificationVersion() {\n            return null;\n        }\n\n        @Override\n        public String getSpecificationVendor() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationTitle() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationVersion() {\n            return null;\n        }\n\n        @Override\n        public String getImplementationVendor() {\n            return null;\n        }\n\n        @Override\n        public URL getSealBase() {\n            return null;\n        }\n\n        @Override\n        public boolean isCompatibleTo(Package definedPackage) {\n            return definedPackage != null && packageName.equals(definedPackage.getName());\n        }\n    }\n\n    public static final class Accessor {\n        public Object getClassLoadingLock(ClassLoader classLoader, String name) {\n            return classLoader;\n        }\n\n        public Class<?> findLoadedClass(ClassLoader classLoader, String name) {\n            try {\n                return Class.forName(name, false, classLoader);\n            } catch (ClassNotFoundException exception) {\n                return null;\n            }\n        }\n\n        public Class<?> defineClass(ClassLoader classLoader, String name, byte[] binaryRepresentation,\n                int offset, int length, ProtectionDomain protectionDomain) {\n            return ((DispatcherClassLoader) classLoader)\n                    .defineClassForTest(name, binaryRepresentation, offset, length, protectionDomain);\n        }\n\n        public Package getDefinedPackage(ClassLoader classLoader, String name) {\n            return ((DispatcherClassLoader) classLoader).getDefinedPackageForTest(name);\n        }\n\n        public Package getPackage(ClassLoader classLoader, String name) {\n            return ((DispatcherClassLoader) classLoader).getPackageForTest(name);\n        }\n\n        public Package definePackage(ClassLoader classLoader, String name, String specificationTitle,\n                String specificationVersion, String specificationVendor, String implementationTitle,\n                String implementationVersion, String implementationVendor, URL sealBase) {\n            return ((DispatcherClassLoader) classLoader).definePackageForTest(\n                    name,\n                    specificationTitle,\n                    specificationVersion,\n                    specificationVendor,\n                    implementationTitle,\n                    implementationVersion,\n                    implementationVendor,\n                    sealBase);\n        }\n    }\n\n    private static final class PermissiveSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n        }\n    }\n}\n\nfinal class UnsafeInjectionHarness extends ClassInjector.UsingReflection {\n    private static final String PACKAGE_PREFIX = \"io_projectreactor_tools.blockhound.generated.unsafeinjection\";\n\n    private UnsafeInjectionHarness(ClassLoader classLoader) {\n        super(classLoader);\n    }\n\n    static void exerciseDispatcherMethods() throws Exception {\n        ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.Accessor accessor =\n                new ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.Accessor();\n        Dispatcher dispatcher = new HarnessDispatcher(\n                accessor,\n                accessorMethod(\"findLoadedClass\", ClassLoader.class, String.class),\n                accessorMethod(\"defineClass\", ClassLoader.class, String.class, byte[].class,\n                        int.class, int.class, ProtectionDomain.class),\n                accessorMethod(\"getDefinedPackage\", ClassLoader.class, String.class),\n                accessorMethod(\"getPackage\", ClassLoader.class, String.class),\