  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationDescription;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnnotationValueInnerForDescriptionArrayTest {
      @Test
      void loadsAnnotationDescriptionArrayWithRuntimeComponentType() {
          try {
              TypeDescription componentType = TypeDescription.ForLoadedType.of(Element.class);
              AnnotationDescription first = AnnotationDescription.Builder.ofType(Element.class)
                      .define("name", "alpha")
                      .define("priority", 3)
                      .build();
              AnnotationDescription second = AnnotationDescription.Builder.ofType(Element.class)
                      .define("name", "bravo")
                      .define("priority", 5)
                      .build();
              AnnotationValue<AnnotationDescription[], Element[]> arrayValue = AnnotationValue.ForDescriptionArray.of(
                      componentType,
                      new AnnotationDescription[] { first, second });
  
              AnnotationValue.Loaded<Element[]> loadedValue = arrayValue.load(Element.class.getClassLoader());
              Element[] resolved = loadedValue.resolve();
  
              assertThat(resolved).hasSize(2);
              assertThat(resolved[0].name()).isEqualTo("alpha");
              assertThat(resolved[0].priority()).isEqualTo(3);
              assertThat(resolved[1].name()).isEqualTo("bravo");
              assertThat(resolved[1].priority()).isEqualTo(5);
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface Element {
          String name();
  
          int priority();
      }
  }
