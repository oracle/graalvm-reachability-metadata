  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;
  import reactor.blockhound.shaded.net.bytebuddy.description.enumeration.EnumerationDescription;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnnotationValueInnerForEnumerationDescriptionTest {
      @Test
      void loadsEnumerationDescriptionWithProvidedClassLoader() {
          try {
              EnumerationDescription enumerationDescription = new EnumerationDescription.ForLoadedEnumeration(SampleChoice.SECOND);
              AnnotationValue<EnumerationDescription, SampleChoice> value =
                      AnnotationValue.ForEnumerationDescription.of(enumerationDescription);
  
              AnnotationValue.Loaded<SampleChoice> loadedValue = value.load(SampleChoice.class.getClassLoader());
              SampleChoice resolved = loadedValue.resolve();
  
              assertThat(loadedValue.getState()).isEqualTo(AnnotationValue.State.RESOLVED);
              assertThat(resolved).isSameAs(SampleChoice.SECOND);
              assertThat(loadedValue.represents(SampleChoice.SECOND)).isTrue();
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      enum SampleChoice {
          FIRST,
          SECOND
      }
  }
