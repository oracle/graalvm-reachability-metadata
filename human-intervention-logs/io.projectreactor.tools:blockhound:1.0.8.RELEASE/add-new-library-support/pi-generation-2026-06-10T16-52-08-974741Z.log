ons.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\n\npublic class AnnotationValueInnerForEnumerationDescriptionInnerWithUnknownConstantTest {\n    @Test\n    void loadsUnknownEnumerationConstantWithProvidedClassLoader() {\n        try {\n            TypeDescription typeDescription = TypeDescription.ForLoadedType.of(SampleChoice.class);\n            AnnotationValue<EnumerationDescription, SampleChoice> value =\n                    new AnnotationValue.ForEnumerationDescription.WithUnknownConstant<>(typeDescription, \"MISSING\");\n\n            AnnotationValue.Loaded<SampleChoice> loadedValue = value.load(SampleChoice.class.getClassLoader());\n\n            assertThat(value.getState()).isEqualTo(AnnotationValue.State.UNRESOLVED);\n            assertThat(loadedValue.getState()).isEqualTo(AnnotationValue.State.UNRESOLVED);\n            assertThat(loadedValue.toString()).contains(\"MISSING\");\n            assertThatThrownBy(loadedValue::resolve)\n                    .isInstanceOf(EnumConstantNotPresentException.class)\n                    .hasMessageContaining(SampleChoice.class.getName())\n                    .hasMessageContaining(\"MISSING\");\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    enum SampleChoice {\n        FIRST,\n        SECOND\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 983, "output": 912, "cacheRead": 25600, "cacheWrite": 0, "totalTokens": 27495, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781110285112, "responseId": "resp_04ffe36fb48f4627016a29960d9f9c8194930f8621c543550e"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_qO0iUqqq70bt8s7HZuPxZRvn|fc_04ffe36fb48f4627016a29961921f481948fbe7e50bb95b212", "toolName": "write", "content": [{"type": "text", "text": "Succe