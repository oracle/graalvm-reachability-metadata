  package io_projectreactor_tools.blockhound;
  
  import java.lang.instrument.ClassFileTransformer;
  import java.security.ProtectionDomain;
  import java.util.Collection;
  import java.util.Collections;
  import java.util.List;
  
  import org.graalvm.internal.tck.NativeImageSupport;
  import org.junit.jupiter.api.Test;
  
  import reactor.blockhound.shaded.net.bytebuddy.agent.builder.LambdaFactory;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LambdaFactoryTest {
      private static final byte[] GENERATED_CLASS_FILE = new byte[] {1, 2, 3};
  
      @Test
      void registeredLambdaFactoryDispatchesMakeAndReleasesTransformer() {
          RecordingClassFileFactory classFileFactory = new RecordingClassFileFactory();
          RecordingClassFileTransformer classFileTransformer = new RecordingClassFileTransformer();
          boolean registered = false;
          try {
              boolean firstRegistration = LambdaFactory.register(classFileTransformer, classFileFactory);
              registered = true;
  
              byte[] classFile = LambdaFactory.make(
                      LambdaFactoryTest.class,
                      "run",
                      "factoryType",
                      "samMethodType",
                      "implementationHandle",
                      "instantiatedMethodType",
                      true,
                      Collections.singletonList(Runnable.class),
                      Collections.singletonList("bridge"));
  
              assertThat(firstRegistration).isTrue();
              assertThat(classFile).containsExactly(GENERATED_CLASS_FILE);
              assertThat(classFileFactory.caller).isSameAs(LambdaFactoryTest.class);
              assertThat(classFileFactory.invokedName).isEqualTo("run");
              assertThat(classFileFactory.invokedType).isEqualTo("factoryType");
              assertThat(classFileFactory.samMethodType).isEqualTo("samMethodType");
              assertThat(classFileFactory.implMethod).isEqualTo("implementationHandle");
              assertThat(classFileFactory.instantiatedMethodType).isEqualTo("instantiatedMethodType");
              assertThat(classFileFactory.serializable).isTrue();
              assertThat(classFileFactory.markerInterfaces).containsExactly(Runnable.class);
              assertThat(classFileFactory.additionalBridges).hasSize(1);
              assertThat(classFileFactory.additionalBridges.get(0)).isEqualTo("bridge");
              assertThat(classFileFactory.classFileTransformers).containsExactly(classFileTransformer);
              assertThat(LambdaFactory.release(classFileTransformer)).isTrue();
              registered = false;
          } catch (Error error) {
              verifyNativeImageUnsupportedFeature(error);
          } finally {
              if (registered) {
                  LambdaFactory.release(classFileTransformer);
              }
          }
      }
  
      private static void verifyNativeImageUnsupportedFeature(Error error) {
          if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
              throw error;
          }
      }
  
      public static final class RecordingClassFileFactory {
          private Object caller;
          private String invokedName;
          private Object invokedType;
          private Object samMethodType;
          private Object implMethod;
          private Object instantiatedMethodType;
          private boolean serializable;
          private List<Class<?>> markerInterfaces;
          private List<?> additionalBridges;
          private Collection<ClassFileTransformer> classFileTransformers;
  
          public byte[] make(Object caller, String invokedName, Object invokedType, Object samMethodType,
                  Object implMethod, Object instantiatedMethodType, boolean serializable, List<Class<?>> markerInterfaces,
                  List<?> additionalBridges, Collection<ClassFileTransformer> classFileTransformers) {
              this.caller = caller;
              this.invokedName = invokedName;
              this.invokedType = invokedType;
              this.samMethodType = samMethodType;
              this.implMethod = implMethod;
              this.instantiatedMethodType = instantiatedMethodType;
              this.serializable = serializable;
              this.markerInterfaces = markerInterfaces;
              this.additionalBridges = additionalBridges;
              this.classFileTransformers = classFileTransformers;
              return GENERATED_CLASS_FILE;
          }
      }
  
      private static final class RecordingClassFileTransformer implements ClassFileTransformer {
          @Override
          public byte[] transform(ClassLoader loader, String className, Class<?> classBeingRedefined,
                  ProtectionDomain protectionDomain, byte[] classfileBuffer) {
              return null;
          }
      }
  }
