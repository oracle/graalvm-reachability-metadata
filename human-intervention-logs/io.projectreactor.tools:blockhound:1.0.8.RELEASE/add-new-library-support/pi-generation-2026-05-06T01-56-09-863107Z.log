[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/AttacherTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.Test;\n\nimport reactor.blockhound.shaded.net.bytebuddy.agent.Attacher;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AttacherTest {\n    private static final String PROCESS_ID = \"12345\";\n    private static final String AGENT = \"/tmp/blockhound-agent.jar\";\n\n    @BeforeEach\n    void resetVirtualMachine() {\n        RecordingVirtualMachine.reset();\n    }\n\n    @Test\n    void mainAttachesAndLoadsJavaAgent() {\n        Attacher.main(new String[] {\n                RecordingVirtualMachine.class.getName(),\n                PROCESS_ID,\n                AGENT,\n                \"false\",\n                \"=alpha\",\n                \"beta\"\n        });\n\n        RecordingVirtualMachine virtualMachine = RecordingVirtualMachine.lastInstance;\n        assertThat(virtualMachine).isNotNull();\n        assertThat(virtualMachine.processId).isEqualTo(PROCESS_ID);\n        assertThat(virtualMachine.loadedAgent).isEqualTo(AGENT);\n        assertThat(virtualMachine.loadedAgentArgument).isEqualTo(\"alpha beta\");\n        assertThat(virtualMachine.loadedAgentPath).isNull();\n        assertThat(virtualMachine.detached).isTrue();\n    }\n\n    @Test\n    void mainAttachesAndLoadsNativeAgentPath() {\n        Attacher.main(new String[] {\n                RecordingVirtualMachine.class.getName(),\n                PROCESS_ID,\n                AGENT,\n                \"true\"\n        });\n\n        RecordingVirtualMachine virtualMachine = RecordingVirtualMachine.lastInstance;\n        assertThat(virtualMachine).isNotNull();\n        assertThat(virtualMachine.processId).isEqualTo(PROCESS_ID);\n        assertThat(virtualMachine.loadedAgentPath).isEqualTo(AGENT);\n        assertThat(virtualMachine.loadedAgentPathArgument).isNull();\n        assertThat(virtualMachine.loadedAgent).isNull();\n        assertThat(virtualMachine.detached).isTrue();\n    }\n\n    public static final class RecordingVirtualMachine {\n        private static RecordingVirtualMachine lastInstance;\n\n        private final String processId;\n        private String loadedAgent;\n        private String loadedAgentArgument;\n        private String loadedAgentPath;\n        private String loadedAgentPathArgument;\n        private boolean detached;\n\n        private RecordingVirtualMachine(String processId) {\n            this.processId = processId;\n        }\n\n        public static RecordingVirtualMachine attach(String processId) {\n            lastInstance = new RecordingVirtualMachine(processId);\n            return lastInstance;\n        }\n\n        public void loadAgent(String agent, String argument) {\n            loadedAgent = agent;\n            loadedAgentArgument = argument;\n        }\n\n        public void loadAgentPath(String agentPath, String argument) {\n            loadedAgentPath = agentPath;\n            loadedAgentPathArgument = argument;\n        }\n\n        public void detach() {\n            detached = true;\n        }\n\n        private static void reset() {\n            lastInstance = null;\n        }\n    }\n}\n"}
