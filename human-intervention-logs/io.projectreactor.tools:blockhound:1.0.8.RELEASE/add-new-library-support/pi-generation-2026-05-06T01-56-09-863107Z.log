   \"true\"\n        });\n\n        RecordingVirtualMachine virtualMachine = RecordingVirtualMachine.lastInstance;\n        assertThat(virtualMachine).isNotNull();\n        assertThat(virtualMachine.processId).isEqualTo(PROCESS_ID);\n        assertThat(virtualMachine.loadedAgentPath).isEqualTo(AGENT);\n        assertThat(virtualMachine.loadedAgentPathArgument).isNull();\n        assertThat(virtualMachine.loadedAgent).isNull();\n        assertThat(virtualMachine.detached).isTrue();\n    }\n\n    public static final class RecordingVirtualMachine {\n        private static RecordingVirtualMachine lastInstance;\n\n        private final String processId;\n        private String loadedAgent;\n        private String loadedAgentArgument;\n        private String loadedAgentPath;\n        private String loadedAgentPathArgument;\n        private boolean detached;\n\n        private RecordingVirtualMachine(String processId) {\n            this.processId = processId;\n        }\n\n        public static RecordingVirtualMachine attach(String processId) {\n            lastInstance = new RecordingVirtualMachine(processId);\n            return lastInstance;\n        }\n\n        public void loadAgent(String agent, String argument) {\n            loadedAgent = agent;\n            loadedAgentArgument = argument;\n        }\n\n        public void loadAgentPath(String agentPath, String argument) {\n            loadedAgentPath = agentPath;\n            loadedAgentPathArgument = argument;\n        }\n\n        public void detach() {\n            detached = true;\n        }\n\n        private static void reset() {\n            lastInstance = null;\n        }\n    }\n}\n"}
