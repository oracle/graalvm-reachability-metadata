|fc_074e60da5ae787a1016a2925da813881968d964e8b58c68202", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.builder.LambdaFactory;\n\nimport java.lang.instrument.ClassFileTransformer;\nimport java.security.ProtectionDomain;\nimport java.util.Collection;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class LambdaFactoryTest {\n    @Test\n    void registersFactoryInvokesItAndReleasesTransformer() {\n        ClassFileTransformer transformer = new NoOpClassFileTransformer();\n        RecordingClassFileFactory factory = new RecordingClassFileFactory();\n        boolean registered = false;\n\n        try {\n            boolean firstRegistration = LambdaFactory.register(transformer, factory);\n            registered = true;\n\n            byte[] generatedBytes = LambdaFactory.make(\n                    new Object(),\n                    \"run\",\n                    new Object(),\n                    new Object(),\n                    new Object(),\n                    new Object(),\n                    false,\n                    List.of(Runnable.class),\n                    List.of());\n\n            assertThat(firstRegistration).isTrue();\n            assertThat(generatedBytes).containsExactly(1, 2, 3);\n            assertThat(factory.invocations).isEqualTo(1);\n            assertThat(factory.lastInvokedName).isEqualTo(\"run\");\n            assertThat(factory.lastClassFileTransformers).containsExactly(transformer);\n\n            assertThat(LambdaFactory.release(transformer)).isTrue();\n            registered = false;\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        } finally {\n            if (registered) {\n                LambdaFactory.release(transformer);\n            }\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class NoOpClassFileTransformer implements ClassFileTransformer {\n        @Override\n        public byte[] transform(\n                Module module,\n                ClassLoader loader,\n                String className,\n                Class<?> classBeingRedefined,\n                ProtectionDomain protectionDomain,\n                byte[] classfileBuffer) {\n            return null;\n        }\n    }\n\n    public static final class RecordingClassFileFactory {\n        private int invocations;\n        private String lastInvokedName;\n        private Collection<ClassFileTransformer> lastClassFileTransformers;\n\n        public byte[] make(\n                Object caller,\n                String invokedName,\n                Object invokedType,\n                Object samMethodType,\n                Object implMethod,\n                Object instantiatedMethodType,\n                boolean serializable,\n                List<Class<?>> markerInterfaces,\n                List<?> additionalBridges,\n                Collection<ClassFileTransformer> classFileTransformers) {\n            invocations++;\n            lastInvokedName = invokedName;\n            lastClassFileTransformers = classFileTransformers;\n            return new byte[] {1, 2, 3};\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781081562807}, {"role": "toolResult", "toolCallId": "call_sDBcPTLhuHjKx0cqEcBhduKR|fc_074e60da5ae787a1016a2925da81508196bbc1b1771c8f8bf1", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport java.net.URL;\nimport java.net.URLClassLoader;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest {\n    private static final Class<?> TEST_CLASS =\n            ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeInjectionTest.class;\n\n    private static final String PARENT_PACKAGE_NAME = TEST_CLASS.getPackageName();\n\n    @Test\n    void injectsGeneratedClassIntoCustomClassLoaderAndDefinesPackage() throws Exception {\n        ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION\n                .with(PackageDefinitionStrategy.Trivial.INSTANCE);\n        String className = \"io_projectreactor_tools.blockhound.generated.Injected\"\n                + System.nanoTime();\n\n        try (URLClassLoader classLoader =\n                     new URLClassLoader(new URL[0], TEST_CLASS.getClassLoader())) {\n            Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    @Test\n    void fallsBackToParentPackageWhenCustomClassLoaderRejectsPackageDefinition() throws Exception {\n        ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION\n                .with(PackageDefinitionStrategy.Trivial.INSTANCE);\n        String className = PARENT_PACKAGE_NAME + \".InjectedIntoParentPackage\" + System.nanoTime();\n\n        try (RejectingPackageClassLoader classLoader =\n                     new RejectingPackageClassLoader(TEST_CLASS.getClassLoader())) {\n            Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n\n            assertThat(generatedClass.getName()).isEqualTo(className);\n            assertThat(generatedClass.getClassLoader()).isSameAs(classLoader);\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static Class<?> injectGeneratedClass(\n            ClassLoader classLoader,\n            String className,\n            ClassLoadingStrategy<ClassLoader> strategy) {\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(classLoader, strategy)\n                .getLoaded();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class RejectingPackageClassLoader extends URLClassLoader {\n        private RejectingPackageClassLoader(ClassLoader parent) {\n            super(new URL[0], parent);\n        }\n\n        @Override\n        protected Package definePackage(\n                String name,\n                String specificationTitle,\n                String specificationVersion,\n                String specificationVendor,\n                String implementationTitle,\n                String implementationVersion,\n                String implementationVendor,\n                URL sealBase) {\n            if (PARENT_PACKAGE_NAME.equals(name)) {\n                throw new IllegalStateException(\"Use parent package definition\");\n            }\n            return super.definePackage(\n                    name,\n                    specificationTitle,\n                    specificationVersion,\n                    specificationVendor,\n                    implementationTitle,\n                    implementationVersion,\n                    implementationVendor,\n                    sealBase);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781081562808}, {"role": "toolResult", "toolCallId": "call_pvqLdiioLcwfYlgUM6W0NKu9|fc_074e60da5ae787a1016a2925da815881968f3876c04d0022b0", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.security.Permission;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\n@SuppressWarnings({\"deprecation\", \"removal\"})\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerUsingUnsafeOverrideTest {\n    @Test\n    void injectsClassesThroughUnsafeOverrideDispatcher() {\n        try {\n            assertThat(new UsingUnsafeOverrideExercise().call()).isEqualTo(\"ok\");\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    public static final class UsingUnsafeOverrideExercise {\n        private static final String SAFE_PROPERTY = ClassInjector.UsingUnsafe.SAFE_PROPERTY;\n\n        public String call() {\n            String previousSafeProperty = System.getProperty(SAFE_PROPERTY);\n            SecurityManager previousSecurityManager = System.getSecurityManager();\n            boolean securityManagerChanged = false;\n            try {\n                System.setProperty(SAFE_PROPERTY, Boolean.TRUE.toString());\n                if (ClassInjector.UsingUnsafe.isAvailable()) {\n                    throw new IllegalStateException(\"Unsafe injection should be disabled before reflection injection\");\n                }\n                System.setProperty(SAFE_PROPERTY, Boolean.FALSE.toString());\n\n                securityManagerChanged = installPermissiveSecurityManager();\n\n                ClassLoadingStrategy<ClassLoader> strategy = ClassLoadingStrategy.Default.INJECTION\n                        .with(PackageDefinitionStrategy.Trivial.INSTANCE);\n                injectIntoNewPackage(strategy);\n                injectWithPackageFallback(strategy);\n                return \"ok\";\n            } finally {\n                if (securityManagerChanged) {\n                    System.setSecurityManager(previousSecurityManager);\n                }\n                restoreSafeProperty(previousSafeProperty);\n            }\n        }\n\n        private static void injectIntoNewPackage(ClassLoadingStrategy<ClassLoader> strategy) {\n            String className = \"io_projectreactor_tools.blockhound.generated.unsafeoverride.Injected\"\n                    + System.nanoTime();\n            try (URLClassLoader classLoader = new URLClassLoader(new URL[0],\n                    UsingUnsafeOverrideExercise.class.getClassLoader())) {\n                Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n                if (!generatedClass.getName().equals(className) || generatedClass.getClassLoader() != classLoader) {\n                    throw new IllegalStateException(\"Generated class was not injected into the requested loader\");\n                }\n            } catch (Exception exception) {\n                throw new IllegalStateException(exception);\n            }\n        }\n\n        private static void injectWithPackageFallback(ClassLoadingStrategy<ClassLoader> strategy) {\n            String packageName = \"io_projectreactor_tools.blockhound.generated.unsafeoverridefallback\";\n            String className = packageName + \".Injected\" + System.nanoTime();\n            try (RejectingPackageClassLoader classLoader = new RejectingPackageClassLoader(\n                    UsingUnsafeOverrideExercise.class.getClassLoader(),\n                    packageName,\n                    UsingUnsafeOverrideExercise.class.getPackage())) {\n                Class<?> generatedClass = injectGeneratedClass(classLoader, className, strategy);\n                if (!generatedClass.getName().equals(className) || generatedClass.getClassLoader() != classLoader) {\n                    throw new IllegalStateException(\"Generated class was not injected after package fallback\");\n                }\n            } catch (Exception exception) {\n                throw new IllegalStateException(exception);\n            }\n        }\n\n        private static Class<?> injectGeneratedClass(\n                ClassLoader classLoader,\n                String className,\n                ClassLoadingStrategy<ClassLoader> strategy) {\n            return new ByteBuddy()\n                    .subclass(Object.class)\n                    .name(className)\n                    .make()\n                    .load(classLoader, strategy)\n                    .getLoaded();\n        }\n\n        private static boolean installPermissiveSecurityManag