[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/AnnotationValueInnerForMismatchedTypeTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;\nimport reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;\n\nimport java.lang.annotation.AnnotationTypeMismatchException;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\nimport static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;\n\npublic class AnnotationValueInnerForMismatchedTypeTest {\n    @Test\n    void loadsMismatchedValueForExistingAnnotationProperty() {\n        MethodDescription.InDefinedShape property = TypeDescription.ForLoadedType.of(SampleAnnotation.class)\n                .getDeclaredMethods()\n                .filter(named(\"name\"))\n                .getOnly();\n        AnnotationValue<String, String> mismatchedValue = new AnnotationValue.ForMismatchedType<>(property, \"42\");\n\n        AnnotationValue.Loaded<String> loadedValue = mismatchedValue.load(SampleAnnotation.class.getClassLoader());\n\n        assertThat(loadedValue.toString()).contains(\"42\");\n        assertThatThrownBy(loadedValue::resolve)\n                .isInstanceOfSatisfying(AnnotationTypeMismatchException.class, exception -> {\n                    assertThat(exception.element().getName()).isEqualTo(\"name\");\n                    assertThat(exception.foundType()).isEqualTo(\"42\");\n                });\n    }\n\n    public @interface SampleAnnotation {\n        String name();\n    }\n}\n"}
