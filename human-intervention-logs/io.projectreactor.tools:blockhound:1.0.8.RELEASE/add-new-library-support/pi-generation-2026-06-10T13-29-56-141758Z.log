  .getOnly();\n        MethodDescription packagePrivateConstructor = subjectType.getDeclaredMethods()\n                .filter(isConstructor().and(takesArguments(String.class)))\n                .getOnly();\n\n        assertThat(lookupAction(publicMethod)).isSameAs(PrivilegedMemberLookupAction.FOR_PUBLIC_METHOD);\n        assertThat(lookupAction(packagePrivateMethod)).isSameAs(PrivilegedMemberLookupAction.FOR_DECLARED_METHOD);\n        assertThat(lookupAction(publicConstructor)).isSameAs(PrivilegedMemberLookupAction.FOR_PUBLIC_CONSTRUCTOR);\n        assertThat(lookupAction(packagePrivateConstructor)).isSameAs(PrivilegedMemberLookupAction.FOR_DECLARED_CONSTRUCTOR);\n    }\n\n    private static PrivilegedMemberLookupAction lookupAction(MethodDescription methodDescription) {\n        AuxiliaryType auxiliaryType = PrivilegedMemberLookupAction.of(methodDescription);\n\n        assertThat(auxiliaryType.getSuffix()).isNotEmpty();\n        return (PrivilegedMemberLookupAction) auxiliaryType;\n    }\n\n    public static class MemberLookupSubject {\n        public MemberLookupSubject() {\n        }\n\n        MemberLookupSubject(String ignored) {\n        }\n\n        public void publicMethod() {\n        }\n\n        void packagePrivateMethod() {\n        }\n    }\n}\n"}
