g with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.implementation.auxiliary.AuxiliaryType;\nimport reactor.blockhound.shaded.net.bytebuddy.implementation.auxiliary.PrivilegedMemberLookupAction;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.isConstructor;\nimport static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;\nimport static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.takesArguments;\n\npublic class PrivilegedMemberLookupActionTest {\n    @Test\n    void selectsLookupActionForLoadedMethodsAndConstructors() {\n        TypeDescription.ForLoadedType subjectType = TypeDescription.ForLoadedType.of(MemberLookupSubject.class);\n        MethodDescription publicMethod = subjectType.getDeclaredMethods()\n                .filter(named(\"publicMethod\"))\n                .getOnly();\n        MethodDescription packagePrivateMethod = subjectType.getDeclaredMethods()\n                .filter(named(\"packagePrivateMethod\"))\n                .getOnly();\n        MethodDescription publicConstructor = subjectType.getDeclaredMethods()\n                .filter(isConstructor().and(takesArguments(0)))\n                .getOnly();\n        MethodDescription packagePrivateConstructor = subjectType.getDeclaredMethods()\n                .filter(isConstructor().and(takesArguments(String.class)))\n                .getOnly();\n\n        assertThat(lookupAction(publicMethod)).isSameAs(PrivilegedMemberLookupAction.FOR_PUBLIC_METHOD);\n        assertThat(lookupAction(packagePrivateMethod)).isSameAs(PrivilegedMemberLookupAction.FOR_DECLARED_METHOD);\n        assertThat(lookupAction(publicConstructor)).isSameAs(PrivilegedMemberLookupAction.FOR_PUBLIC_CONSTRUCTOR);\n        assertThat(lookupAction(packagePrivateConstructor)).isSameAs(PrivilegedMemberLookupAction.FOR_DECLARED_CONSTRUCTOR);\n    }\n\n    private static PrivilegedMemberLookupAction lookupAction(MethodDescription methodDescription) {\n        AuxiliaryType auxiliaryType = PrivilegedMemberLookupAction.of(methodDescription);\n\n        assertThat(auxiliaryType.getSuffix()).isNotEmpty();\n        return (PrivilegedMemberLookupAction) auxiliaryType;\n    }\n\n    public static class MemberLookupSubject {\n        public MemberLookupSubject() {\n        }\n\n        MemberLookupSubject(String ignored) {\n        }\n\n        public void publicMethod() {\n        }\n\n        void packagePrivateMethod() {\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 2045, "output": 1540, "cacheRead": 22528, "cacheWrite": 0, "totalTokens": 26113, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781098138532, "responseId": "resp_0083fdae8e894da7016a29669c9a4481969e4f0b88b3e1b378"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_C8dQbFehqi8mOgjo2CqCl0hD|fc_0083fdae8e894da7016a2966b13e5c8196b227677719df427d", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2924 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/PrivilegedMemberLookupActionTest.java"}], "isError": false, "timestamp": 1781098168097}]}
