elated rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.nio.charset.StandardCharsets;\nimport java.util.jar.JarFile;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PackageDefinitionStrategyInnerManifestReadingTest {\n    private static final String PACKAGE_NAME = \"io_projectreactor_tools.blockhound.generated.manifest\";\n    private static final String TYPE_NAME = PACKAGE_NAME + \".Sample\";\n\n    @Test\n    void defineReadsPackageMetadataFromClassLoaderManifest() {\n        PackageDefinitionStrategy strategy = new PackageDefinitionStrategy.ManifestReading(\n                PackageDefinitionStrategy.ManifestReading.SealBaseLocator.NonSealing.INSTANCE);\n\n        PackageDefinitionStrategy.Definition definition = strategy.define(\n                new ManifestClassLoader(),\n                PACKAGE_NAME,\n                TYPE_NAME);\n\n        assertThat(definition.isDefined()).isTrue();\n        assertThat(definition.getSpecificationTitle()).isEqualTo(\"Main specification\");\n        assertThat(definition.getSpecificationVersion()).isEqualTo(\"1.0\");\n        assertThat(definition.getSpecificationVendor()).isEqualTo(\"Main vendor\");\n        assertThat(definition.getImplementationTitle()).isEqualTo(\"Package implementation\");\n        assertThat(definition.getImplementationVersion()).isEqualTo(\"2.0\");\n        assertThat(definition.getImplementationVendor()).isEqualTo(\"Package vendor\");\n        assertThat(definition.getSealBase()).isNull();\n    }\n\n    private static final class ManifestClassLoader extends ClassLoader {\n        private static fi