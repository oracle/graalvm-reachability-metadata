[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/PackageDefinitionStrategyInnerManifestReadingInnerSealBaseLocatorInnerForTypeResourceUrlTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.PackageDefinitionStrategy;\n\nimport java.io.ByteArrayInputStream;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.nio.charset.StandardCharsets;\nimport java.util.jar.JarFile;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class PackageDefinitionStrategyInnerManifestReadingInnerSealBaseLocatorInnerForTypeResourceUrlTest {\n    private static final String PACKAGE_NAME = \"io_projectreactor_tools.blockhound.generated.sealed\";\n    private static final String TYPE_NAME = PACKAGE_NAME + \".Sample\";\n    private static final String TYPE_RESOURCE = \"io_projectreactor_tools/blockhound/generated/sealed/Sample.class\";\n\n    @Test\n    void sealedPackageUsesTypeResourceUrlAsSealBase() throws Exception {\n        URL typeResourceUrl = new URL(\"file:/tmp/blockhound-sample/Sample.class\");\n        PackageDefinitionStrategy strategy = new PackageDefinitionStrategy.ManifestReading(\n                new PackageDefinitionStrategy.ManifestReading.SealBaseLocator.ForTypeResourceUrl());\n\n        PackageDefinitionStrategy.Definition definition = strategy.define(\n                new SealedManifestClassLoader(typeResourceUrl),\n                PACKAGE_NAME,\n                TYPE_NAME);\n\n        assertThat(definition.isDefined()).isTrue();\n        assertThat(definition.getImplementationTitle()).isEqualTo(\"Sealed package implementation\");\n        