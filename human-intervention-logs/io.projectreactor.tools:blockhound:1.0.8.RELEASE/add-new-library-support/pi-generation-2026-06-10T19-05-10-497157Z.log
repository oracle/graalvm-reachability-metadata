ojectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerInitializableInnerUnavailableTest.java", "content": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingReflectionInnerDispatcherInnerInitializableInnerUnavailableTest {\n    @Test\n    void unavailableDispatcherFindsClassesVisibleToTheTargetClassLoader() {\n        try {\n            UnavailableDispatcherAccessor accessor = new UnavailableDispatcherAccessor(getClass().getClassLoader());\n\n            Class<?> loadedClass = accessor.findVisibleClass(String.class.getName());\n\n            assertThat(loadedClass).isSameAs(String.class);\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n}\n\nfinal class UnavailableDispatcherAccessor extends ClassInjector.UsingReflection {\n    private final ClassLoader targetClassLoader;\n\n    UnavailableDispatcherAccessor(ClassLoader targetClassLoader) {\n        super(targetClassLoader);\n        this.targetClassLoader = targetClassLoader;\n    }\n\n    Class<?> findVisibleClass(String className) {\n        Dispatcher dispatcher = new InitializableUnavailableDispatcher(\"reflection injection unavailable\").initialize();\n        return dispatcher.findClass(targetClassLoader, className);\n    }\n\n    private static final class InitializableUnavailableDispatcher extends Dispatcher.Initializable.Unavailable {\n        private InitializableUnavailableDispatcher(String message) {\n            super(message);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 844, "output": 1480, "cacheRead": 40448, "cacheWrite": 0, "totalTokens": 42772, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781118255462, "responseId": "resp_06b6a471fc6c2d70016a29b5303624819384c7bd8640e98f9f"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_FnwUCvRVi5emgzOk9UvHJr3K|fc_06b6a471fc6c2d70016a29b54be7f881938ef56de8e2fc6fc3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 1804 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingReflectionInnerDispatcherInnerInitializableInnerUnavailableTest.java"}], "isError": false, "timestamp": 1781118286159}]}
