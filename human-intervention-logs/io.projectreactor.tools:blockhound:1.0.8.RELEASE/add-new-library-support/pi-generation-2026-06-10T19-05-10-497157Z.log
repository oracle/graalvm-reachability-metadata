  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import org.junit.jupiter.api.io.TempDir;
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;
  
  import java.lang.instrument.Instrumentation;
  import java.nio.file.Path;
  import java.util.Map;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassInjectorInnerUsingInstrumentationTest {
      @TempDir
      Path temporaryFolder;
  
      @Test
      void injectsGeneratedClassIntoSystemClassLoaderWithInstrumentation() {
          try {
              Instrumentation instrumentation = ByteBuddyAgent.install();
              String className = "io_projectreactor_tools.blockhound.generated.instrumentation.Injected"
                      + System.nanoTime();
              DynamicType.Unloaded<?> dynamicType = new ByteBuddy()
                      .subclass(Object.class)
                      .name(className)
                      .make();
  
              ClassInjector injector = ClassInjector.UsingInstrumentation.of(
                      temporaryFolder.toFile(),
                      ClassInjector.UsingInstrumentation.Target.SYSTEM,
                      instrumentation);
              Map<String, Class<?>> injectedTypes = injector.injectRaw(Map.of(className, dynamicType.getBytes()));
  
              Class<?> injectedClass = injectedTypes.get(className);
              assertThat(injectedClass).isNotNull();
              assertThat(injectedClass.getName()).isEqualTo(className);
              assertThat(injectedClass.getClassLoader()).isSameAs(ClassLoader.getSystemClassLoader());
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  }
