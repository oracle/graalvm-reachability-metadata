  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;
  import reactor.blockhound.shaded.net.bytebuddy.description.enumeration.EnumerationDescription;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static org.assertj.core.api.Assertions.assertThatThrownBy;
  
  public class AnnotationValueInnerForEnumerationDescriptionInnerWithUnknownConstantTest {
      @Test
      void loadsUnknownEnumerationConstantWithProvidedClassLoader() {
          try {
              TypeDescription typeDescription = TypeDescription.ForLoadedType.of(SampleChoice.class);
              AnnotationValue<EnumerationDescription, SampleChoice> value =
                      new AnnotationValue.ForEnumerationDescription.WithUnknownConstant<>(typeDescription, "MISSING");
  
              AnnotationValue.Loaded<SampleChoice> loadedValue = value.load(SampleChoice.class.getClassLoader());
  
              assertThat(value.getState()).isEqualTo(AnnotationValue.State.UNRESOLVED);
              assertThat(loadedValue.getState()).isEqualTo(AnnotationValue.State.UNRESOLVED);
              assertThat(loadedValue.toString()).contains("MISSING");
              assertThatThrownBy(loadedValue::resolve)
                      .isInstanceOf(EnumConstantNotPresentException.class)
                      .hasMessageContaining(SampleChoice.class.getName())
                      .hasMessageContaining("MISSING");
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      enum SampleChoice {
          FIRST,
          SECOND
      }
  }
