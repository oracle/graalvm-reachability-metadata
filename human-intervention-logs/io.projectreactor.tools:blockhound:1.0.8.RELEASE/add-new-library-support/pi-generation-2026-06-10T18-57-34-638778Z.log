  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ByteArrayClassLoader;
  
  import java.lang.reflect.Method;
  import java.util.Collections;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteArrayClassLoaderInnerSynchronizationStrategyInnerForJava7CapableVmTest {
      @Test
      void java7SynchronizationStrategyUsesClassLoaderLockLookup() throws Exception {
          try {
              Java7CapableByteArrayClassLoader classLoader = new Java7CapableByteArrayClassLoader(
                      getClass().getClassLoader());
  
              Object firstLock = classLoader.getLockFor("io_projectreactor_tools.blockhound.generated.LockedType");
              Object secondLock = classLoader.getLockFor("io_projectreactor_tools.blockhound.generated.LockedType");
  
              assertThat(firstLock).isNotNull();
              assertThat(secondLock).isSameAs(firstLock);
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  }
  
  final class Java7CapableByteArrayClassLoader extends ByteArrayClassLoader {
      Java7CapableByteArrayClassLoader(ClassLoader parent) {
          super(parent, false, Collections.emptyMap());
      }
  
      Object getLockFor(String name) throws Exception {
          Method getClassLoadingLock = ClassLoader.class.getDeclaredMethod("getClassLoadingLock", String.class);
          SynchronizationStrategy strategy = new Java7SynchronizationStrategy(getClassLoadingLock).initialize();
          return strategy.getClassLoadingLock(this, name);
      }
  
      private final class Java7SynchronizationStrategy extends SynchronizationStrategy.ForJava7CapableVm {
          private Java7SynchronizationStrategy(Method method) {
              super(method);
          }
      }
  }
