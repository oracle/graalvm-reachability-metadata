  public class ByteBuddyAgentTest {
      private static final String ALLOW_SELF_ATTACH_PROPERTY = "jdk.attach.allowAttachSelf";
      private static final String BYTE_BUDDY_AGENT_COPY_MODULE = "blockhound.bytebuddy.agent.copy";
      private static final String BYTE_BUDDY_AGENT_PACKAGE = "reactor.blockhound.shaded.net.bytebuddy.agent";
      private static final String BYTE_BUDDY_AGENT_RESOURCE_PATH = "reactor/blockhound/shaded/net/bytebuddy/agent/";
      private static final byte[] BYTE_BUDDY_AGENT_COPY_MODULE_INFO = Base64.getDecoder().decode(
              "yv66vgAAADUADwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB"
                      + "AAZNb2R1bGUTAAcBAB9ibG9ja2hvdW5kLmJ5dGVidWRkeS5hZ2VudC5jb3B5EwAJAQAJamF2YS5iYXNl"
                      + "AQABORMADAEAD2phdmEuaW5zdHJ1bWVudBQADgEALXJlYWN0b3IvYmxvY2tob3VuZC9zaGFkZWQvbmV0"
                      + "L2J5dGVidWRkeS9hZ2VudIAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAACIABgAAAAAAAgAIgAAACgAL"
                      + "AAAACgABAA0AAAAAAAAAAAAA");
      private static final List<String> MODULAR_AGENT_CLASS_RESOURCES = List.of(
              "ByteBuddyAgent.class",
              "ByteBuddyAgent$AgentProvider.class",
              "ByteBuddyAgent$AgentProvider$ForByteBuddyAgent.class",
              "ByteBuddyAgent$AgentProvider$ForExistingAgent.class",
              "ByteBuddyAgent$AttachmentProvider.class",
              "ByteBuddyAgent$AttachmentProvider$Accessor.class",
              "ByteBuddyAgent$AttachmentProvider$Accessor$ExternalAttachment.class",
              "ByteBuddyAgent$AttachmentProvider$Accessor$Simple.class",
              "ByteBuddyAgent$AttachmentProvider$Accessor$Simple$WithDirectAttachment.class",
              "ByteBuddyAgent$AttachmentProvider$Accessor$Simple$WithExternalAttachment.class",
              "ByteBuddyAgent$AttachmentProvider$Accessor$Unavailable.class",
              "ByteBuddyAgent$AttachmentProvider$Compound.class",
              "ByteBuddyAgent$AttachmentProvider$ForEmulatedAttachment.class",
              "ByteBuddyAgent$AttachmentProvider$ForJ9Vm.class",
              "ByteBuddyAgent$AttachmentProvider$ForModularizedVm.class",
              "ByteBuddyAgent$AttachmentProvider$ForStandardToolsJarVm.class",
