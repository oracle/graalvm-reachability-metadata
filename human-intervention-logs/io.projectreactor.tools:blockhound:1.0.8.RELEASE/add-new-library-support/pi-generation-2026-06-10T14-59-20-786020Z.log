[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/build.gradle","edits":[{"oldText":"String libraryVersion = tck.testedLibraryVersion.get()\n\ndependencies {","newText":"String libraryVersion = tck.testedLibraryVersion.get()\nint currentJavaMajorVersion = JavaVersion.current().majorVersion as int\nint testJavaMajorVersion = currentJavaMajorVersion > 23 ? 21 : currentJavaMajorVersion\n\nif (currentJavaMajorVersion > 23) {\n    tasks.withType(JavaCompile).configureEach {\n        options.release = 21\n    }\n}\n\ndependencies {"},{"oldText":"tasks.named(\"test\") {\n    forkEvery = 1\n    jvmArgs += [\"--add-opens=java.base/java.lang=ALL-UNNAMED\", \"-Djdk.attach.allowAttachSelf=true\"]\n    if ((JavaVersion.current().majorVersion as int) >= 13) {\n        jvmArgs += [\"-XX:+AllowRedefinitionToAddDeleteMethods\"]\n    }\n    if ((JavaVersion.current().majorVersion as int) < 24) {\n        jvmArgs += [\"-Djava.security.manager=allow\"]\n    }\n}","newText":"tasks.named(\"test\") {\n    forkEvery = 1\n    if (currentJavaMajorVersion > 23) {\n        javaLauncher = javaToolchains.launcherFor {\n            languageVersion = JavaLanguageVersion.of(21)\n        }\n    }\n    jvmArgs += [\"--add-opens=java.base/java.lang=ALL-UNNAMED\", \"-Djdk.attach.allowAttachSelf=true\"]\n    if (testJavaMajorVersion >= 13) {\n        jvmArgs += [\"-XX:+AllowRedefinitionToAddDeleteMethods\"]\n    }\n    if (testJavaMajorVersion < 24) {\n        jvmArgs += [\"-Djava.security.manager=allow\"]\n    }\n}"}]}
