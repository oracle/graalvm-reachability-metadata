  plugins {
      id "org.graalvm.internal.tck"
  }
  
  String libraryVersion = tck.testedLibraryVersion.get()
  
  dependencies {
      testImplementation "io.projectreactor.tools:blockhound:$libraryVersion"
      testImplementation 'io.projectreactor:reactor-core:3.2.5.RELEASE'
      testImplementation 'org.ow2.asm:asm:5.2'
      testImplementation 'org.assertj:assertj-core:3.22.0'
  }
  
  tasks.named("test") {
      forkEvery = 1
      jvmArgs += ["--add-opens=java.base/java.lang=ALL-UNNAMED", "-Djdk.attach.allowAttachSelf=true"]
      if ((JavaVersion.current().majorVersion as int) >= 13) {
          jvmArgs += ["-XX:+AllowRedefinitionToAddDeleteMethods"]
      }
      if ((JavaVersion.current().majorVersion as int) < 24) {
          jvmArgs += ["-Djava.security.manager=allow"]
      }
  }
  
  graalvmNative {
      agent {
          defaultMode = "conditional"
          modes {
              conditional {
                  userCodeFilterPath = "user-code-filter.json"
              }
          }
      }
  }
