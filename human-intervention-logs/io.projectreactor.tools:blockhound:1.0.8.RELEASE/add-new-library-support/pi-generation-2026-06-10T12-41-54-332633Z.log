a.lang.instrument.UnmodifiableClassException;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.net.URI;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.security.CodeSource;\nimport java.util.Base64;\nimport java.util.Collections;\nimport java.util.HashSet;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarFile;\nimport java.util.jar.JarOutputStream;\nimport java.util.stream.Stream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AgentBuilderInnerDefaultTest {\n    private static final String AGENT_BUILDER_COPY_MODULE = \"blockhound.bytebuddy.agentbuilder.copy\";\n    private static final String AGENT_COPY_MODULE = \"blockhound.bytebuddy.agent.copy\";\n    private static final String AGENT_BUILDER_DEFAULT_TYPE =\n            \"reactor.blockhound.shaded.net.bytebuddy.agent.builder.AgentBuilder$Default\";\n    private static final String INSTALLER_TYPE = \"reactor.blockhound.shaded.net.bytebuddy.agent.Installer\";\n    private static final String BYTE_BUDDY_RESOURCE_ROOT = \"reactor/blockhound/shaded/net/bytebuddy/\";\n    private static final String BYTE_BUDDY_AGENT_BUILDER_RESOURCE_ROOT =\n            \"reactor/blockhound/shaded/net/bytebuddy/agent/builder/\";\n    private static final String BYTE_BUDDY_AGENT_RESOURCE_ROOT =\n            \"reactor/blockhound/shaded/net/bytebuddy/agent/\";\n    private static final byte[] AGENT_BUILDER_COPY_MODULE_INFO = Base64.getDecoder().decode(\n            \"yv66vgAAADUAHQcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB\"\n                    + \"AAZNb2R1bGUTAAcBACZibG9ja2hvdW5kLmJ5dGVidWRkeS5hZ2VudGJ1aWxkZXIuY29weRMACQEA\"\n                    + \"CWphdmEuYmFzZQEAATkTAAwBAAxqYXZhLmRlc2t0b3ATAA4BAA9qYXZhLmluc3RydW1lbnQTABAB\"\n                    + \"AAxqYXZhLmxvZ2dpbmcTABIBAA9qYXZhLm1hbmFnZW1lbnQTABQBAAtqYXZhLm5hbWluZxMAFgEA\"\n                    + \"CGphdmEuc3FsEwAYAQAIamF2YS54bWwTABoBAA9qZGsudW5zdXBwb3J0ZWQUABwBADVyZWFjdG9y\"\n                    + \"L2Jsb2NraG91bmQvc2hhZGVkL25ldC9ieXRlYnVkZHkvYWdlbnQvYnVpbGRlcoAAAAEAAAAAAAAA\"\n                    + \"AAACAAMAAAACAAQABQAAAEwABgAAAAAACQAIgAAACgALAAAACgANAAAACgAPAAAACgARAAAACgAT\"\n                    + \"AAAACgAVAAAACgAXAAAACgAZAAAACgABABsAAAAAAAAAAAAA\");\n    private static final byte[] AGENT_COPY_MODULE_INFO = Base64.getDecoder().decode(\n            \"yv66vgAAADUADwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB\"\n                    + \"AAZNb2R1bGUTAAcBAB9ibG9ja2hvdW5kLmJ5dGVidWRkeS5hZ2VudC5jb3B5EwAJAQAJamF2YS5i\"\n                    + \"YXNlAQABORMADAEAD2phdmEuaW5zdHJ1bWVudBQADgEALXJlYWN0b3IvYmxvY2tob3VuZC9zaGFk\"\n                    + \"ZWQvbmV0L2J5dGVidWRkeS9hZ2VudIAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAACIABgAAAAAA\"\n                    + \"AgAIgAAACgALAAAACgABAA0AAAAAAAAAAAAA\");\n\n    @Test\n    void installOnByteBuddyAgentAddsReadEdgeFromNamedAgentBuilderModule() throws Throwable {\n        try {\n            installAgentBuilderFromNamedModule();\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        }\n    }\n\n    private static void installAgentBuilderFromNamedModule() throws Throwable {\n        Path agentBuilderJar = writeModularAgentBuilderJar();\n        Path agentJar = writeModularAgentJar();\n        RecordingInstrumentation instrumentation = new RecordingInstrumentation();\n        MethodHandle installerPremain = null;\n        try {\n            defineAgentModuleOnSystemClassLoader(agentJar);\n            Class<?> installerType = ClassLoader.getSystemClassLoader().loadClass(INSTALLER_TYPE);\n            installerPremain = MethodHandles.publicLookup()\n                    .findStatic(installerType, \"premain\", MethodType.methodType(void.class, String.class,\n                            Instrumentation.class));\n            installerPremain.invoke(null, instrumentation);\n\n            ModuleFinder finder = ModuleFinder.of(agentBuilderJar);\n            Configuration configuration = ModuleLayer.boot().configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(AGENT_BUILDER_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            ClassLoader loader = layer.findLoader(AGENT_BUILDER_COPY_MODULE);\n            Class<?> defaultType = loader.loadClass(AGENT_BUILDER_DEFAULT_TYPE);\n            Class<?> transformerType = loader.loadClass(\n                    \"reactor.blockhound.shaded.net.bytebuddy.agent.builder.ResettableClassFileTransformer\");\n            MethodHandle constructor = MethodHandles.publicLookup()\n                    .findConstructor(defaultType, MethodType.methodType(void.class));\n            MethodHandle installOnByteBuddyAgent = MethodHandles.publicLookup()\n                    .findVirtual(defaultType, \"installOnByteBuddyAgent\", MethodType.methodType(transformerType));\n\n            assertThat(defaultType.getModule().canRead(installerType.getModule())).isFalse();\n            Object transformer = installOnByteBuddyAgent.invoke(constructor.invoke());\n\n            assertThat(defaultType.getModule().canRead(installerType.getModule())).isTrue();\n            assertThat(transformer).isNotNull();\n            assertThat(instrumentation.addedTransformers).hasSize(1);\n        } finally {\n            if (installerPremain != null) {\n                installerPremain.invoke(null, null);\n            }\n            Files.deleteIfExists(agentBuilderJar);\n            Files.deleteIfExists(agentJar);\n        }\n    }\n\n    private static void defineAgentModuleOnSystemClassLoader(Path agentJar) {\n        ModuleFinder finder = ModuleFinder.of(agentJar);\n        Configuration configuration = ModuleLayer.boot().configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(AGENT_COPY_MODULE));\n        ModuleLayer.defineModules(configuration, List.of(ModuleLayer.boot()),\n                moduleName -> ClassLoader.getSystemClassLoader());\n    }\n\n    private static Path writeModularAgentBuilderJar() throws IOException {\n        Path sourcePath = codeSourcePath(AgentBuilder.class);\n        Path jar = Files.createTempFile(\"blockhound-agent-builder-module\", \".jar\");\n        Set<String> copiedEntries = new HashSet<>();\n        try (JarOutputStream outputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n            outputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            outputStream.write(AGENT_BUILDER_COPY_MODULE_INFO);\n            outputStream.closeEntry();\n            if (Files.isDirectory(sourcePath)) {\n                copyByteBuddyClassesFromDirectory(sourcePath, outputStream, copiedEntries, true);\n            } else {\n                copyByteBuddyClassesFromJar(sourcePath, outputStream, copiedEntries, true);\n            }\n        }\n        return jar;\n    }\n\n    private static Path writeModularAgentJar() throws IOException {\n        Path sourcePath = codeSourcePath(AgentBuilder.class);\n        Path jar = Files.createTempFile(\"blockhound-agent-module\", \".jar\");\n        Set<String> copiedEntries = new HashSet<>();\n        try (JarOutputStream outputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n            outputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            outputStream.write(AGENT_COPY_MODULE_INFO);\n            outputStream.closeEntry();\n            if (Files.isDirectory(sourcePath)) {\n                copyByteBuddyClassesFromDirectory(sourcePath, outputStream, copiedEntries, false);\n            } else {\n                copyByteBuddyClassesFromJar(sourcePath, outputStream, copiedEntries, false);\n            }\n        }\n        return jar;\n    }\n\n    private static Path codeSourcePath(Class<?> type) {\n        CodeSource codeSource = type.getProtectionDomain().getCodeSource();\n        assertThat(codeSource).isNotNull();\n        URI location = URI.create(codeSource.getLocation().toString());\n        return Path.of(location);\n    }\n\n    private static void copyByteBuddyClassesFromJar(\n            Path sourceJar,\n            JarOutputStream outputStream,\n            Set<String> copiedEntries,\n            boolean agentBuilderModule) throws IOException {\n        try (JarFile jarFile = new JarFile(sourceJar.toFile())) {\n            for (JarEntry entry : Collections.list(jarFile.entries())) {\n                if (isByteBuddyClass(entry.getName(), agentBuilderModule)) {\n                    copyEntry(entry.getName(), jarFile.getInputStream(entry), outputStream, copiedEntries);\n                }\n            }\n        }\n    }\n\n    private static void copyByteBuddyClassesFromDirectory(\n            Path sourceDirectory,\n            JarOutputStream outputStream,\n            Set<String> copiedEntries,\n            boolean agentBuilderModule) throws IOException {\n        try (Stream<Path> paths = Files.walk(sourceDirectory)) {\n            for (Path file : paths.filter(Files::isRegularFile).toList()) {\n                String entryName = sourceDirectory.relativize(file).toString().replace(File.separatorChar, '/');\n                if (isByteBuddyClass(entryName, agentBuilderModule)) {\n                    copyEntry(entryName, Files.newInputStream(file), outputStream, copiedEntries);\n                }\n            }\n        }\n    }\n\n    private static boolean isByteBuddyClass(String entryName, boolean agentBuilderModule) {\n        if (!entryName.startsWith(BYTE_BUDDY_RESOURCE_ROOT) || !entryName.endsWith(\".class\")) {\n            return false;\n        }\n        if (agentBuilderModule) {\n 