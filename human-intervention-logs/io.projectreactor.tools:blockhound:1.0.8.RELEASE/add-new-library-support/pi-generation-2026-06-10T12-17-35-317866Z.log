[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassInjectorInnerUsingUnsafeInnerFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassInjector;\n\nimport java.lang.instrument.Instrumentation;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.util.Collections;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassInjectorInnerUsingUnsafeInnerFactoryTest {\n    private static final String ALLOW_SELF_ATTACH_PROPERTY = \"jdk.attach.allowAttachSelf\";\n    private static final String SAFE_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.safe\";\n    private static final String EXPERIMENTAL_PROPERTY = \"reactor.blockhound.shaded.net.bytebuddy.experimental\";\n\n    @Test\n    void resolveCreatesUnsafeFallbackFactoryThroughGeneratedAccessResolver() throws Exception {\n        String previousAllowSelfAttachProperty = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        String previousSafeProperty = System.getProperty(SAFE_PROPERTY);\n        String previousExperimentalProperty = System.getProperty(EXPERIMENTAL_PROPERTY);\n        try {\n            System.setProperty(ALLOW_SELF_ATTACH_PROPERTY, Boolean.TRUE.toString());\n            System.setProperty(SAFE_PROPERTY, Boolean.TRUE.toString());\n            System.setProperty(EXPERIMENTAL_PROPERTY, Boolean.TRUE.toString());\n\n            Instrumentation instrumentation = ByteBuddyAgent.install();\n            ClassInjector.UsingUnsafe.Factory factory = ClassInjector.UsingUnsafe.Factory.resolve(\n                    instrumentation,\n                    false);\n            assertThat(factory.isAvailable()).isTrue();\n\n            try (URLClassLoader classLoader = new URLClassLoader(\n                    new URL[0],\n                    ClassInjectorInnerUsingUnsafeInnerFactoryTest.class.getClassLoader())) {\n                String className = \"io_projectreactor_tools.blockhound.generated.unsafefactory.Injected\"\n                        + System.nanoTime();\n                DynamicType.Unloaded<?> dynamicType = new ByteBuddy()\n                        .subclass(Object.class)\n                        .name(className)\n                        .make();\n\n                Map<String, Class<?>> injectedTypes = factory.make(classLoader)\n                        .injectRaw(Collections.singletonMap(className, dynamicType.getBytes()));\n\n                Class<?> injectedType = injectedTypes.get(className);\n                assertThat(injectedType).isNotNull();\n                assertThat(injectedType.getName()).isEqualTo(className);\n                assertThat(injectedType.getClassLoader()).isSameAs(classLoader);\n            }\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        } finally {\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttachProperty);\n            restoreProperty(SAFE_PROPERTY, previousSafeProperty);\n            restoreProperty(EXPERIMENTAL_PROPERTY, previousExperimentalProperty);\n        }\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static void restoreProperty(String propertyName, String previousValue) {\n        if (previousValue == null) {\n            System.clearProperty(propertyName);\n        } else {\n            System.setProperty(propertyName, previousValue);\n        }\n    }\n}\n"}
