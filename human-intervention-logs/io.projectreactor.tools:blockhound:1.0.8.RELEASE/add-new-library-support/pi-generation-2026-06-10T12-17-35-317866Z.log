, ModuleFinder.of(), Set.of(BYTE_BUDDY_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            Class<?> classReloadingStrategy = layer.findLoader(BYTE_BUDDY_COPY_MODULE)\n                    .loadClass(CLASS_RELOADING_STRATEGY_NAME);\n            MethodType methodType = MethodType.methodType(classReloadingStrategy);\n            MethodHandle fromInstalledAgent = MethodHandles.publicLookup()\n                    .findStatic(classReloadingStrategy, \"fromInstalledAgent\", methodType);\n            return fromInstalledAgent.invoke();\n        } finally {\n            Files.deleteIfExists(modularJar);\n        }\n    }\n\n    private static Path writeModularByteBuddyJar() throws IOException, URISyntaxException {\n        Path jar = Files.createTempFile(\"blockhound-byte-buddy-loading-module\", \".jar\");\n        Set<String> addedEntries = new HashSet<>();\n        try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n            writeEntry(jarOutputStream, addedEntries, \"module-info.class\", BYTE_BUDDY_COPY_MODULE_INFO);\n            Path codeSource = Path.of(ClassReloadingStrategy.class.getProtectionDomain()\n                    .getCodeSource()\n                    .getLocation()\n                    .toURI());\n            if (Files.isDirectory(codeSource)) {\n                copyByteBuddyClassesFromDirectory(codeSource, jarOutputStream, addedEntries);\n            } else {\n                copyByteBuddyClassesFromJar(codeSource, jarOutputStream, addedEntries);\n            }\n        }\n        return jar;\n    }\n\n    private static void copyByteBuddyClassesFromDirectory(\n            Path root,\n            JarOutputStream jarOutputStream,\n            Set<String> addedEntries) throws IOException {\n        try (Stream<Path> paths = Files.walk(root.resolve(BYTE_BUDDY_PACKAGE_ROOT))) {\n            paths.filter(Files::isRegularFile)\n                    .filter(path -> path.getFileName().toString().endsWith(\".class\"))\n                    .forEach(path -> copyDirectoryClass(root, path, jarOutputStream, addedEntries));\n        }\n    }\n\n    private static void copyDirectoryClass(\n            Path root,\n            Path path,\n            JarOutputStream jarOutputStream,\n            Set<String> addedEntries) {\n        String entryName = root.relativize(path).toString().replace('\\\\', '/');\n        try {\n            writeEntry(jarOutputStream, addedEntries, entryName, Files.readAllBytes(path));\n        } catch (IOException exception) {\n            throw new IllegalStateException(\"Could not copy Byte Buddy class \" + entryName, exception);\n        }\n    }\n\n    private static void copyByteBuddyClassesFromJar(\n            Path sourceJar,\n            JarOutputStream jarOutputStream,\n            Set<String> addedEntries) throws IOException {\n        try (JarFile jarFile = new JarFile(sourceJar.toFile())) {\n            Enumeration<JarEntry> entries = jarFile.entries();\n            while (entries.hasMoreElements()) {\n                JarEntry entry = entries.nextElement();\n                if (!entry.isDirectory()\n                        && entry.getName().startsWith(BYTE_BUDDY_PACKAGE_ROOT)\n                        && entry.getName().endsWith(\".class\")) {\n                    try (InputStream inputStream = jarFile.getInputStream(entry)) {\n                        writeEntry(jarOutputStream, addedEntries, entry.getName(), inputStream.readAllBytes());\n                    }\n                }\n            }\n        }\n    }\n\n    private static void writeEntry(\n            JarOutputStream jarOutputStream,\n            Set<String> addedEntries,\n            String name,\n            byte[] bytes) throws IOException {\n        if (addedEntries.add(name)) {\n            jarOutputStream.putNextEntry(new JarEntry(name));\n            jarOutputStream.write(bytes);\n            jarOutputStream.closeEntry();\n        }\n\n[89 more lines in file. Use offset=161 to continue.]"}], "isError": false, "timestamp": 1781093723621}]}
