  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassReloadingStrategyTest {
      private static final String BYTE_BUDDY_COPY_MODULE = "blockhound.bytebuddy.loading.copy";
      private static final String BYTE_BUDDY_PACKAGE_ROOT = "reactor/blockhound/shaded/net/bytebuddy/";
      private static final String CLASS_RELOADING_STRATEGY_NAME =
              "reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassReloadingStrategy";
      private static final byte[] BYTE_BUDDY_COPY_MODULE_INFO = Base64.getDecoder().decode(
              "yv66vgAAADUADwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB"
                      + "AAZNb2R1bGUTAAcBACFibG9ja2hvdW5kLmJ5dGVidWRkeS5sb2FkaW5nLmNvcHkTAAkBAAlqYXZhLmJh"
                      + "c2UBAAE5EwAMAQAPamF2YS5pbnN0cnVtZW50FAAOAQA3cmVhY3Rvci9ibG9ja2hvdW5kL3NoYWRlZC9u"
                      + "ZXQvYnl0ZWJ1ZGR5L2R5bmFtaWMvbG9hZGluZ4AAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAACIABgAA"
                      + "AAAAAgAIgAAACgALAAAACgABAA0AAAAAAAAAAAAA");
  
      @Test
      void fromInstalledAgentResolvesInstrumentationFromSystemInstaller() throws Throwable {
          try {
              Instrumentation instrumentation = new RetransformCapableInstrumentation();
              Installer.premain(null, instrumentation);
              try {
                  assertThat(ClassReloadingStrategy.fromInstalledAgent()).isNotNull();
                  assertThat(fromNamedModule()).isNotNull();
              } finally {
                  Installer.premain(null, null);
              }
          } catch (Error error) {
              if (!NativeImageSupport.isUnsupportedFeatureError(error)) {
                  throw error;
              }
          }
      }
  
      private static Object fromNamedModule() throws Throwable {
          Path modularJar = writeModularByteBuddyJar();
          try {
              ModuleFinder finder = ModuleFinder.of(modularJar);
              Configuration configuration = ModuleLayer.boot().configuration()
                      .resolve(finder, ModuleFinder.of(), Set.of(BYTE_BUDDY_COPY_MODULE));
              ModuleLayer layer = ModuleLayer.boot()
                      .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
              Class<?> classReloadingStrategy = layer.findLoader(BYTE_BUDDY_COPY_MODULE)
                      .loadClass(CLASS_RELOADING_STRATEGY_NAME);
              MethodType methodType = MethodType.methodType(classReloadingStrategy);
              MethodHandle fromInstalledAgent = MethodHandles.publicLookup()
                      .findStatic(classReloadingStrategy, "fromInstalledAgent", methodType);
              return fromInstalledAgent.invoke();
          } finally {
              Files.deleteIfExists(modularJar);
