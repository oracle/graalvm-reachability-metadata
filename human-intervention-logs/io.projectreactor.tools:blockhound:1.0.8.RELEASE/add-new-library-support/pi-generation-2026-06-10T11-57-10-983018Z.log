 @Retention(RetentionPolicy.RUNTIME)\n    public @interface SampleAnnotation {\n        String value();\n\n        int count() default 7;\n\n        Class<?> type() default Void.class;\n    }\n\n    @SampleAnnotation(value = \"alpha\", count = 42, type = String.class)\n    static class AnnotatedSample {\n    }\n}\n"}
