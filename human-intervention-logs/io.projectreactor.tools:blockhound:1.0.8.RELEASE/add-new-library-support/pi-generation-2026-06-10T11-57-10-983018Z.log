  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationDescription;
  
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class AnnotationDescriptionInnerAnnotationInvocationHandlerTest {
      @Test
      void loadsAnnotationDescriptionAsAnnotationProxyAndComparesItWithRuntimeAnnotation() {
          AnnotationDescription annotationDescription = AnnotationDescription.Builder.ofType(SampleAnnotation.class)
                  .define("value", "alpha")
                  .define("count", 42)
                  .define("type", String.class)
                  .build();
  
          SampleAnnotation generated = annotationDescription.prepare(SampleAnnotation.class).load();
          SampleAnnotation runtimeAnnotation = AnnotatedSample.class.getAnnotation(SampleAnnotation.class);
  
          assertThat(generated.annotationType()).isEqualTo(SampleAnnotation.class);
          assertThat(generated.value()).isEqualTo("alpha");
          assertThat(generated.count()).isEqualTo(42);
          assertThat(generated.type()).isEqualTo(String.class);
          assertThat(generated).isEqualTo(runtimeAnnotation);
          assertThat(generated.hashCode()).isEqualTo(runtimeAnnotation.hashCode());
          assertThat(generated.toString()).contains("alpha");
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface SampleAnnotation {
          String value();
  
          int count() default 7;
  
          Class<?> type() default Void.class;
      }
  
      @SampleAnnotation(value = "alpha", count = 42, type = String.class)
      static class AnnotatedSample {
      }
  }
