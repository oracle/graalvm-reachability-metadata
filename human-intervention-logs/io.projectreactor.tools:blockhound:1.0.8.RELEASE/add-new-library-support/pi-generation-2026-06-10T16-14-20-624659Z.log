[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/AnnotationValueInnerForAnnotationDescriptionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;\nimport reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;\n\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;\n\npublic class AnnotationValueInnerForAnnotationDescriptionTest {\n    @Test\n    void loadsAnnotationDescriptionValueWithAnnotationTypeClassLoader() {\n        ContainerAnnotation loadedAnnotation = AnnotatedSample.class.getAnnotation(ContainerAnnotation.class);\n        AnnotationDescription containerDescription = AnnotationDescription.ForLoadedAnnotation.of(loadedAnnotation);\n        MethodDescription.InDefinedShape nestedMethod = TypeDescription.ForLoadedType.of(ContainerAnnotation.class)\n                .getDeclaredMethods()\n                .filter(named(\"nested\"))\n                .getOnly();\n        AnnotationDescription nestedDescription = (AnnotationDescription) containerDescription.getValue(nestedMethod).resolve();\n        AnnotationValue<AnnotationDescription, NestedAnnotation> nestedValue =\n                new AnnotationValue.ForAnnotationDescription<>(nestedDescription);\n\n        AnnotationValue.Loaded<NestedAnnotation> loadedValue = nestedValue.load(NestedAnnotation.class.getClassLoader());\n        NestedAnnotation resolvedAnnotation = loadedValue.resolve();\n\n        assertThat(resolvedAnnotation.annotationType()).isEqualTo(NestedAnnotation.class);\n        assertThat(resolvedAnnotation.name()).isEqualTo(\"charlie\");\n        assertThat(resolvedAnnotation.count()).isEqualTo(11);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface ContainerAnnotation {\n        NestedAnnotation nested();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface NestedAnnotation {\n        String name();\n\n        int count();\n    }\n\n    @ContainerAnnotation(nested = @NestedAnnotation(name = \"charlie\", count = 11))\n    static class AnnotatedSample {\n    }\n}\n"}
