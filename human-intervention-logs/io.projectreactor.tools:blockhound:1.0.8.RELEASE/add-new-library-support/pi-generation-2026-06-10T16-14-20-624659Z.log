lvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nint currentJavaMajorVersion = JavaVersion.current().majorVersion as int\nint testJavaMajorVersion = currentJavaMajorVersion > 23 ? 21 : currentJavaMajorVersion\n\nif (currentJavaMajorVersion > 23) {\n    tasks.withType(JavaCompile).configureEach {\n        options.release = 21\n    }\n}\n\ndependencies {\n    testImplementation \"io.projectreactor.tools:blockhound:$libraryVersion\"\n    testImplementation 'io.projectreactor:reactor-core:3.2.5.RELEASE'\n    testImplementation 'org.ow2.asm:asm:5.2'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.named(\"test\") {\n    forkEvery = 1\n    if (currentJavaMajorVersion > 23) {\n        javaLauncher = javaToolchains.launcherFor {\n            languageVersion = JavaLanguageVersion.of(21)\n        }\n    }\n    jvmArgs += [\"--add-opens=java.base/java.lang=ALL-UNNAMED\", \"-Djdk.attach.allowAttachSelf=true\"]\n    if (testJavaMajorVersion >= 13) {\n        jvmArgs += [\"-XX:+AllowRedefinitionToAddDeleteMethods\"]\n    }\n    if (testJavaMajorVersion < 24) {\n        jvmArgs += [\"-Djava.security.manager=allow\"]\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781107691498}, {"role": "toolResult", "toolCallId": "call_i3qlrTQPuDGrAfhmTZG50pcH|fc_0b2178cde8f919d9016a298be818188196a238ff53aeaafa33", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;\n\nimport java.lang.annotation.Retention;\nimport java.lang.annotation.RetentionPolicy;\nimport java.lang.reflect.Modifier;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;\n\npublic class AnnotationDescriptionInnerForLoadedAnnotationTest {\n    @Test\n    void readsNestedValuesFromLoadedPackagePrivateAnnotation() {\n        OuterAnnotation loadedAnnotation = AnnotatedSample.class.getAnnotation(OuterAnnotation.class);\n        AnnotationDescription loadedDescription = AnnotationDescription.ForLoadedAnnotation.of(loadedAnnotation);\n        MethodDescription.InDefinedShape nestedMethod = new MethodDescription.Latent(\n                TypeDescription.ForLoadedType.of(OuterAnnotation.class),\n                new MethodDescription.Token(\n                        \"nested\",\n                        Modifier.PUBLIC | Modifier.ABSTRACT,\n                        TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(NestedAnnotation.class)));\n        MethodDescription.InDefinedShape nameMethod = TypeDescription.ForLoadedType.of(NestedAnnotation.class)\n                .getDeclaredMethods()\n                .filter(named(\"name\"))\n                .getOnly();\n        MethodDescription.InDefinedShape countMethod = TypeDescription.ForLoadedType.of(NestedAnnotation.class)\n                .getDeclaredMethods()\n                .filter(named(\"count\"))\n                .getOnly();\n\n        AnnotationDescription nestedDescription = (AnnotationDescription) loadedDescription.getValue(nestedMethod).resolve();\n\n        assertThat(nestedDescription.getAnnotationType().represents(NestedAnnotation.class)).isTrue();\n        assertThat(nestedDescription.getValue(nameMethod).resolve()).isEqualTo(\"bravo\");\n        assertThat(nestedDescription.getValue(countMethod).resolve()).isEqualTo(7);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface OuterAnnotation {\n        NestedAnnotation nested();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface NestedAnnotation {\n        String name();\n\n        int count();\n    }\n\n    @OuterAnnotation(nested = @NestedAnnotation(name = \"bravo\", count = 7))\n    static class AnnotatedSample {\n    }\n}\n"}], "isError": false, "timestamp": 1781107691499}, {"role": "toolResult", "toolCallId": "call_v3QQH8QZdM2lnSJVZEOFY1DL|fc_0b2178cde8f919d9016a298be818208196b977b6be7c3bef1d", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;\nimport reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;\nimport reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;\n\nimport java.lang.annotation.AnnotationTypeMismatchException;\n\nimport static org.assertj.core.api.Assertions.assertThat;\nimport static org.assertj.core.api.Assertions.assertThatThrownBy;\nimport static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;\n\npublic class AnnotationValueInnerForMismatchedTypeTest {\n    @Test\n    void loadsMismatchedValueForExistingAnnotationProperty() {\n        TypeDescription annotationType = TypeDescription.ForLoadedType.of(SampleAnnotation.class);\n        MethodDescription.InDefinedShape property = annotationType\n                .getDeclaredMethods()\n                .filter(named(\"name\"))\n                .getOnly();\n        AnnotationValue<String, String> mismatchedValue = new AnnotationValue.ForMismatchedType<>(\n                property,\n                \"42\");\n\n        AnnotationValue.Loaded<String> loadedValue = mismatchedValue.load(\n                SampleAnnotation.class.getClassLoader());\n\n        assertThat(loadedValue.toString()).contains(\"42\");\n        assertThatThrownBy(loadedValue::resolve)\n                .isInstanceOfSatisfying(AnnotationTypeMismatchException.class, exception -> {\n                    assertThat(exception.element().getName()).isEqualTo(\"name\");\n                    assertThat(exception.foundType()).isEqualTo(\"42\");\n                });\n    }\n\n    public @interface SampleAnnotation {\n        String name();\n    }\n}\n"}], "isError": false, "timestamp": 1781107691499}]}
