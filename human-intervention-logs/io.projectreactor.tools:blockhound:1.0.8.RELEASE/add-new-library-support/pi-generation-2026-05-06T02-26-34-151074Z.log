h.allowAttachSelf\";\n\n    @TempDir\n    File tempDirectory;\n\n    @Test\n    void getInstrumentationPerformsInstallerLookup() {\n        try {\n            assertThat(ByteBuddyAgent.getInstrumentation()).isNotNull();\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(\"Byte Buddy agent is not initialized\");\n        }\n    }\n\n    @Test\n    void getInstrumentationReturnsInstalledInstrumentation() {\n        TestInstrumentation instrumentation = new TestInstrumentation();\n        try {\n            Installer.agentmain(\"test\", instrumentation);\n\n            assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n        } finally {\n            Installer.agentmain(\"clear\", null);\n        }\n    }\n\n    @Test\n    void namedModuleCopyAddsReadEdgeBeforeInstallerLookup() throws Exception {\n        TestInstrumentation instrumentation = new TestInstrumentation();\n        try {\n            Installer.agentmain(\"test\", instrumentation);\n\n            assertThat(loadNamedModuleCopyAndGetInstrumentation()).isSameAs(instrumentation);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Installer.agentmain(\"clear\", null);\n        }\n    }\n\n    @Test\n    void externalAttachmentCreatesTemporaryAttacherJarWhenSelfResolutionIsDisabled() {\n        String previousLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);\n        String previousAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\n        System.clearProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        try {\n            try {\n                ByteBuddyAgent.attach(new File(tempDirectory, \"agent.jar\"),\n                        () -> Long.toString(ProcessHandle.current().pid()),\n                        \"coverage\",\n                        new ExternalOnlyAttachmentProvider());\n            } catch (IllegalStateException exception) {\n                assertThat(exception.getMessage()).containsAnyOf(\n                        \"Could not self-attach to current VM using external process\",\n                        \"Error during attachment using\");\n            }\n        } finally {\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, previousLatentResolve);\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttach);\n        }\n    }\n\n    private static Object loadNamedModuleCopyAndGetInstrumentation() throws Exception {\n        Path libraryJar = locateLibraryJar();\n        ModuleFinder finder = ModuleFinder.of(libraryJar);\n        Configuration configuration = ModuleLayer.boot()\n                .configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(\"reactor.blockhound\"));\n        ModuleLayer layer = ModuleLayer.boot()\n                .defineModulesWithOneLoader(configuration, ClassLoader.getSystemClassLoader());\n        Class<?> namedByteBuddyAgent = layer.findLoader(\"reactor.blockhound\")\n                .loadClass(ByteBuddyAgent.class.getName());\n        Method getInstrumentation = namedByteBuddyAgent.getMethod(\"getInstrumentation\");\n        try {\n            return getInstrumentation.invoke(null);\n        } catch (InvocationTargetException exception) {\n            throw new IllegalStateException(\"Named ByteBuddyAgent copy did not return instrumentation\",\n                    exception.getTargetException());\n        }\n    }\n\n    private static Path locateLibraryJar() {\n        CodeSource codeSource = ByteBuddyAgent.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLocation().getProtocol())) {\n            throw new IllegalStateException(\"Cannot locate BlockHound library jar\");\n        }\n        try {\n            return Path.of(codeSource.getLocation().toURI());\n        } catch (URISyntaxException exception) {\n            return Path.of(codeSource.getLocation().getPath());\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    private static List<File> recordingVirtualMachineClassPath() {\n        CodeSource codeSource = RecordingVirtualMachine.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLocation().getProtocol())) {\n            return Collections.emptyList();\n        }\n        try {\n            return Collections.singletonList(new File(codeSource.getLocation().toURI()));\n        } catch (URISyntaxException exception) {\n            return Collections.singletonList(new File(codeSource.getLocation().getPath()));\n        }\n    }\n\n    private static final class ExternalOnlyAttachmentProvider implements AttachmentProvider {\n        @Override\n        public Accessor attempt() {\n            return new ExternalOnlyAccessor();\n        }\n    }\n\n    private static final class ExternalOnlyAccessor implements Accessor {\n        @Override\n        public boolean isAvailable() {\n            return true;\n        }\n\n        @Override\n        public boolean isExternalAttachmentRequired() {\n            return true;\n        }\n\n        @Override\n        public Class<?> getVirtualMachineType() {\n            return RecordingVirtualMachine.class;\n        }\n\n        @Override\n        public ExternalAttachment getExternalAttachment() {\n            return new ExternalAttachment(RecordingVirtualMachine.class.getName(), recordingVirtualMachineClassPath());\n        }\n    }\n\n    private static final class TestInstrumentation implements Instrumentation {\n        @Override\n        public void addTransformer(ClassFileTransformer transformer, boolean canRetransform) {\n            throw unsupportedOperation();\n        }\n\n        @Override\n        public void addTransformer(ClassFileTransformer transformer) {\n            throw unsupportedOperation();\n        }\n\n        @Override\n        public boolean removeTransformer(ClassFileTransformer transformer) {\n            throw unsupportedOperation();\n        }\n\n        @Override\n        public boolean isRetransformClassesSupported() {\n            return false;\n        }\n\n        @Override\n        public void retransformClasses(Class<?>... classes) throws UnmodifiableClassException {\n            throw unsupportedOperation();\n        }\n\n        @Override\n        public boolean isRedefineClassesSupported() {\n            return false;\n        }\n\n        @Override\n        public void redefineClasses(ClassDefinition... definitions)\n                throws ClassNotFoundException, UnmodifiableClassException {\n            throw unsupportedOperation();\n        }\n\n        @Override\n        public boolean isModifiableClass(Class<?> theClass) {\n            return false;\n        }\n\n        @Override\n        public Class<?>[] getAllLoadedClasses() {\n            return new Class<?>[0];\n        }\n\n        @Override\n        public Class<?>[] getInitiatedClasses(ClassLoader loader) {\n            return new Class<?>[0];\n        }\n\n        @Override\n        public long getObjectSize(Object objectToSize) {\n            return 0L;\n        }\n\n        @Override\n        public void appendToBootstrapClassLoaderSearch(JarFile jarfile) {\n            throw unsupportedOperation();\n        }\n\n        @Override\n        public void appendToSystemClassLoaderSearch(JarFile jarfile) {\n            throw unsupportedOperation();\n        }\n\n        @Override\n        public boolean isNativeMethodPrefixSupported() {\n            return false;\n        }\n\n        @Override\n        public void setNativeMethodPrefix(ClassFileTransformer transformer, String prefix) {\n            throw unsupportedOperation();\n        }\n\n[50 more lines in file. Use offset=261 to continue.]"}], "isError": false, "timestamp": 1778034653185}]}
