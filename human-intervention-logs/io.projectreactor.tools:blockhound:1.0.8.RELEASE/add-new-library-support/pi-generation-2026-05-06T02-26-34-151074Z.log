nimport reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.AttachmentProvider.Accessor;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent.AttachmentProvider.Accessor.ExternalAttachment;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.Installer;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteBuddyAgentTest {\n    private static final String ALLOW_SELF_ATTACH_PROPERTY = \"jdk.attach.allowAttachSelf\";\n\n    @TempDir\n    File tempDirectory;\n\n    @Test\n    void getInstrumentationPerformsInstallerLookup() {\n        try {\n            assertThat(ByteBuddyAgent.getInstrumentation()).isNotNull();\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(\"Byte Buddy agent is not initialized\");\n        }\n    }\n\n    @Test\n    void getInstrumentationReturnsInstalledInstrumentation() {\n        TestInstrumentation instrumentation = new TestInstrumentation();\n        try {\n            Installer.agentmain(\"test\", instrumentation);\n\n            assertThat(ByteBuddyAgent.getInstrumentation()).isSameAs(instrumentation);\n        } finally {\n            Installer.agentmain(\"clear\", null);\n        }\n    }\n\n    @Test\n    void namedModuleCopyAddsReadEdgeBeforeInstallerLookup() throws Exception {\n        TestInstrumentation instrumentation = new TestInstrumentation();\n        try {\n            Installer.agentmain(\"test\", instrumentation);\n\n            assertThat(loadExplicitModuleCopyAndGetInstrumentation()).isSameAs(instrumentation);\n        } catch (Error error) {\n            if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n                throw error;\n            }\n        } finally {\n            Installer.agentmain(\"clear\", null);\n        }\n    }\n\n    @Test\n    void externalAttachmentCreatesTemporaryAttacherJarWhenSelfResolutionIsDisabled() {\n        String previousLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);\n        String previousAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\n        System.clearProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        try {\n            try {\n                ByteBuddyAgent.attach(new File(tempDirectory, \"agent.jar\"),\n                        () -> Long.toString(ProcessHandle.current().pid()),\n                        \"coverage\",\n                        new ExternalOnlyAttachmentProvider());\n            } catch (IllegalStateException exception) {\n                assertThat(exception.getMessage()).containsAnyOf(\n                        \"Could not self-attach to current VM using external process\",\n                        \"Error during attachment using\");\n            }\n        } finally {\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, previousLatentResolve);\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttach);\n        }\n    }\n\n    private Object loadExplicitModuleCopyAndGetInstrumentation() throws Exception {\n        String moduleName = \"reactor.blockhound.copy\";\n        Path moduleRoot = tempDirectory.toPath().resolve(moduleName);\n        copyLibraryClasses(moduleRoot);\n        compileModuleDescriptor(moduleName, moduleRoot);\n\n        ModuleFinder finder = ModuleFinder.of(moduleRoot.getParent());\n        Configuration configuration = ModuleLayer.boot()\n                .configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(moduleName));\n        ModuleLayer layer = ModuleLayer.boot()\n                .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n        Class<?> namedByteBuddyAgent = layer.findLoader(moduleName)\n                .loadClass(ByteBuddyAgent.class.getName());\n        Method getInstrumentation = namedByteBuddyAgent.getMethod(\"getInstrumentation\");\n        try {\n            return getInstrumentation.invoke(null);\n        } catch (InvocationTargetException exception) {\n            throw new IllegalStateException(\"Named ByteBuddyAgent copy did not return instrumentation\",\n                    exception.getTargetException());\n        }\n    }\n\n    private static void copyLibraryClasses(Path moduleRoot) throws IOException {\n        try (JarFile jarFile = new JarFile(locateLibraryJar().toFile())) {\n            for (JarEntry entry : Collections.list(jarFile.entries())) {\n                if (entry.isDirectory() || !entry.getName().endsWith(\".class\") || entry.getName().equals(\"module-info.class\")) {\n                    continue;\n                }\n                Path target = moduleRoot.resolve(entry.getName());\n                Files.createDirectories(target.getParent());\n                Files.copy(jarFile.getInputStream(entry), target);\n            }\n        }\n    }\n\n    private static void compileModuleDescriptor(String moduleName, Path moduleRoot) throws IOException {\n        Path descriptor = moduleRoot.resolve(\"module-info.java\");\n        Files.writeString(descriptor, \"\"\"\n                module reactor.blockhound.copy {\n                    requires java.instrument;\n                    exports reactor.blockhound.shaded.net.bytebuddy.agent;\n                }\n                \"\"\");\n        JavaCompiler compiler = ToolProvider.getSystemJavaCompiler();\n        if (compiler == null) {\n            throw new IllegalStateException(\"System Java compiler is required to build a modular BlockHound fixture\");\n        }\n        int exitCode = compiler.run(null, null, null,\n                \"--patch-module\", moduleName + \"=\" + moduleRoot,\n                \"-d\", moduleRoot.toString(),\n                descriptor.toString());\n        if (exitCode != 0) {\n            throw new IllegalStateException(\"Could not compile modular BlockHound fixture: javac exited \" + exitCode);\n        }\n    }\n\n    private static Path locateLibraryJar() {\n        CodeSource codeSource = ByteBuddyAgent.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLocation().getProtocol())) {\n            throw new IllegalStateException(\"Cannot locate BlockHound library jar\");\n        }\n        try {\n            return Path.of(codeSource.getLocation().toURI());\n        } catch (URISyntaxException exception) {\n            return Path.of(codeSource.getLocation().getPath());\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    private static List<File> recordingVirtualMachineClassPath() {\n        CodeSource codeSource = RecordingVirtualMachine.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLocation().getProtocol())) {\n\n[165 more lines in file. Use offset=191 to continue.]"}], "isError": false, "timestamp": 1778034746932}]}
