ntry)) {\n                    Files.copy(inputStream, target);\n                }\n            }\n        }\n    }\n\n    private static void compileModuleDescriptor(String moduleName, Path moduleRoot)\n            throws IOException, InterruptedException {\n        Path descriptor = moduleRoot.resolve(\"module-info.java\");\n        Files.writeString(descriptor, \"\"\"\n                module %s {\n                    requires java.instrument;\n                    exports reactor.blockhound.shaded.net.bytebuddy.agent;\n                }\n                \"\"\".formatted(moduleName));\n        Process process = new ProcessBuilder(javacExecutable().toString(),\n                \"--patch-module\", moduleName + \"=\" + moduleRoot,\n                \"-d\", moduleRoot.toString(),\n                descriptor.toString())\n                .redirectOutput(Redirect.INHERIT)\n                .redirectError(Redirect.INHERIT)\n                .start();\n        int exitCode = process.waitFor();\n        if (exitCode != 0) {\n            throw new IllegalStateException(\n                    \"Could not compile modular BlockHound fixture: javac exited \" + exitCode);\n        }\n    }\n\n    private static Path javaExecutable() {\n        String executable = System.getProperty(\"os.name\", \"\").toLowerCase().contains(\"windows\")\n                ? \"java.exe\"\n                : \"java\";\n        return Path.of(System.getProperty(\"java.home\"), \"bin\", executable);\n    }\n\n    private static Path javacExecutable() {\n        String executable = System.getProperty(\"os.name\", \"\").toLowerCase().contains(\"windows\")\n                ? \"javac.exe\"\n                : \"javac\";\n        return Path.of(System.getProperty(\"java.home\"), \"bin\", executable);\n    }\n\n    private static Path probeClassPath() {\n        CodeSource codeSource = ModuleReadEdgeProbe.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLo