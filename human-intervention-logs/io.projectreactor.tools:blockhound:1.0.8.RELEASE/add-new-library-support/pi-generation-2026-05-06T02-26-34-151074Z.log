      private Object loadExplicitModuleCopyAndGetInstrumentation() throws Exception {
          String moduleName = "reactor.blockhound.copy";
          Path moduleRoot = tempDirectory.toPath().resolve(moduleName);
          copyLibraryClasses(moduleRoot);
          compileModuleDescriptor(moduleName, moduleRoot);
  
          ModuleFinder finder = ModuleFinder.of(moduleRoot.getParent());
          Configuration configuration = ModuleLayer.boot()
                  .configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(moduleName));
          ModuleLayer layer = ModuleLayer.boot()
                  .defineModulesWithOneLoader(configuration, ClassLoader.getSystemClassLoader());
          Class<?> namedByteBuddyAgent = layer.findLoader(moduleName)
                  .loadClass(ByteBuddyAgent.class.getName());
          Module namedAgentModule = namedByteBuddyAgent.getModule();
          Module systemInstallerModule = Installer.class.getModule();
          assertThat(namedAgentModule.canRead(systemInstallerModule)).isFalse();
          Method getInstrumentation = namedByteBuddyAgent.getMethod("getInstrumentation");
          try {
              Object instrumentation = getInstrumentation.invoke(null);
              assertThat(namedAgentModule.canRead(systemInstallerModule)).isTrue();
              return instrumentation;
          } catch (InvocationTargetException exception) {
              throw new IllegalStateException("Named ByteBuddyAgent copy did not return instrumentation",
                      exception.getTargetException());
          }
      }
  
      private static void copyLibraryClasses(Path moduleRoot) throws IOException {
          try (JarFile jarFile = new JarFile(locateLibraryJar().toFile())) {
              for (JarEntry entry : Collections.list(jarFile.entries())) {
                  if (entry.isDirectory()
                          || !entry.getName().startsWith(
                                  "reactor/blockhound/shaded/net/bytebuddy/agent/ByteBuddyAgent")
                          || !entry.getName().endsWith(".class")) {
                      continue;
