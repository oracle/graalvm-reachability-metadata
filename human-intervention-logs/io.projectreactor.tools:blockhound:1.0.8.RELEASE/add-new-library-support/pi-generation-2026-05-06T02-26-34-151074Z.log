age io_projectreactor_tools.blockhound;\n\nimport java.io.File;\nimport java.net.URISyntaxException;\nimport java.security.CodeSource;\nimport java.util.Collections;\nimport java.util.List;\n\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\n\nimport reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteBuddyAgentTest {\n    private static final String ALLOW_SELF_ATTACH_PROPERTY = \"jdk.attach.allowAttachSelf\";\n\n    @TempDir\n    File tempDirectory;\n\n    @Test\n    void getInstrumentationPerformsInstallerLookup() {\n        try {\n            assertThat(ByteBuddyAgent.getInstrumentation()).isNotNull();\n        } catch (IllegalStateException exception) {\n            assertThat(exception).hasMessageContaining(\"Byte Buddy agent is not initialized\");\n        }\n    }\n\n    @Test\n    void externalAttachmentCreatesTemporaryAttacherJarWhenSelfResolutionIsDisabled() {\n        String previousLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);\n        String previousAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\n        System.clearProperty(ALLOW_SELF_ATTACH_PROPERTY);\n        try {\n            try {\n                ByteBuddyAgent.attach(new File(tempDirectory, \"agent.jar\"),\n                        () -> Long.toString(ProcessHandle.current().pid()),\n                        \"coverage\",\n                        new ExternalOnlyAttachmentProvider());\n            } catch (IllegalStateException exception) {\n                assertThat(exception.getMessage()).containsAnyOf(\n                        \"Cannot locate class file for Byte Buddy installation process\",\n                        \"Could not self-attach to current VM using external process\",\n                        \"Error during attachment using\");\n            }\n        } finally {\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, previousLatentResolve);\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttach);\n        }\n    }\n\n    private static void restoreProperty(String name, String value) {\n        if (value == null) {\n            System.clearProperty(name);\n        } else {\n            System.setProperty(name, value);\n        }\n    }\n\n    private static List<File> recordingVirtualMachineClassPath() {\n        CodeSource codeSource = RecordingVirtualMachine.class.getProtectionDomain().getCodeSource();\n        if (codeSource == null || !\"file\".equals(codeSource.getLocation().getProtocol())) {\n            return Collections.emptyList();\n        }\n        try {\n            return Collections.singletonList(new File(codeSource.getLocation().toURI()));\n        } catch (URISyntaxException exception) {\n            return Collections.singletonList(new File(codeSource.getLocation().getPath()));\n        }\n    }\n\n    private static final class ExternalOnlyAttachmentProvider implements ByteBuddyAgent.AttachmentProvider {\n        @Override\n        public Accessor attempt() {\n            return new ExternalOnlyAccessor();\n        }\n    }\n\n    private static final class ExternalOnlyAccessor implements ByteBuddyAgent.AttachmentProvider.Accessor {\n        @Override\n        public boolean isAvailable() {\n            return true;\n        }\n\n        @Override\n        public boolean isExternalAttachmentRequired() {\n            return true;\n        }\n\n        @Override\n        public Class<?> getVirtualMachineType() {\n            return RecordingVirtualMachine.class;\n        }\n\n        @Override\n        public ExternalAttachment getExternalAttachment() {\n            return new ExternalAttachment(RecordingVirtualMachine.class.getName(), recordingVirtualMachineClassPath());\n        }\n    }\n\n    public static final class RecordingVirtualMachine {\n        private RecordingVirtualMachine() {\n        }\n\n        public static RecordingVirtualMachine attach(String processId) {\n            assertThat(processId).isNotBlank();\n            return new RecordingVirtualMachine();\n        }\n\n        public void loadAgent(String agent, String argument) {\n            assertThat(agent).endsWith(\"agent.jar\");\n            assertThat(argument).isEqualTo(\"coverage\");\n        }\n\n        public void loadAgentPath(String agent, String argument) {\n            throw new AssertionError(\"Native agent loading is not expected in this test\");\n        }\n\n        public void detach() {\n        }\n    }\n}\n"}, "partialJson": "{\"path\":\"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ByteBuddyAgentTest.java\",\"content\":\"/*\\n * Copyright and related rights waived via CC0\\n *\\n * You should have received a copy of the CC0 legalcode along with this\\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\\n */\\npackage io_projectreactor_tools.blockhound;\\n\\nimport java.io.File;\\nimport java.net.URISyntaxException;\\nimport java.security.CodeSource;\\nimport java.util.Collections;\\nimport java.util.List;\\n\\nimport org.junit.jupiter.api.Test;\\nimport org.junit.jupiter.api.io.TempDir;\\n\\nimport reactor.blockhound.shaded.net.bytebuddy.agent.ByteBuddyAgent;\\n\\nimport static org.assertj.core.api.Assertions.assertThat;\\n\\npublic class ByteBuddyAgentTest {\\n    private static final String ALLOW_SELF_ATTACH_PROPERTY = \\\"jdk.attach.allowAttachSelf\\\";\\n\\n    @TempDir\\n    File tempDirectory;\\n\\n    @Test\\n    void getInstrumentationPerformsInstallerLookup() {\\n        try {\\n            assertThat(ByteBuddyAgent.getInstrumentation()).isNotNull();\\n        } catch (IllegalStateException exception) {\\n            assertThat(exception).hasMessageContaining(\\\"Byte Buddy agent is not initialized\\\");\\n        }\\n    }\\n\\n    @Test\\n    void externalAttachmentCreatesTemporaryAttacherJarWhenSelfResolutionIsDisabled() {\\n        String previousLatentResolve = System.getProperty(ByteBuddyAgent.LATENT_RESOLVE);\\n        String previousAllowSelfAttach = System.getProperty(ALLOW_SELF_ATTACH_PROPERTY);\\n        System.setProperty(ByteBuddyAgent.LATENT_RESOLVE, Boolean.TRUE.toString());\\n        System.clearProperty(ALLOW_SELF_ATTACH_PROPERTY);\\n        try {\\n            try {\\n                ByteBuddyAgent.attach(new File(tempDirectory, \\\"agent.jar\\\"),\\n                        () -> Long.toString(ProcessHandle.current().pid()),\\n                        \\\"coverage\\\",\\n                        new ExternalOnlyAttachmentProvider());\\n            } catch (IllegalStateException exception) {\\n                assertThat(exception.getMessage()).containsAnyOf(\\n                        \\\"Cannot locate class file for Byte Buddy installation process\\\",\\n                        \\\"Could not self-attach to current VM using external process\\\",\\n                        \\\"Error during attachment using\\\");\\n            }\\n        } finally {\\n            restoreProperty(ByteBuddyAgent.LATENT_RESOLVE, previousLatentResolve);\\n            restoreProperty(ALLOW_SELF_ATTACH_PROPERTY, previousAllowSelfAttach);\\n        }\\n    }\\n\\n    private static void restoreProperty(String name, String value) {\\n        if (value == null) {\\n            System.clearProperty(name);\\n        } else {\\n            System.setProperty(name, value);\\n        }\\n    }\\n\\n    private static List<File> recordingVirtualMachineClassPath() {\\n        CodeSource codeSource = RecordingVirtualMachine.class.getProtectionDomain().getCodeSource();\\n        if (codeSource == null || !\\\"file\\\".equals(codeSource.getLocation().getProtocol())) {\\n            return Collections.emptyList();\\n        }\\n        try {\\n            return Collections.singletonList(new File(codeSource.getLocation().toURI()));\\n        } catch (URISyntaxException exception) {\\n            return Collections.singletonList(new File(codeSource.getLocation().getPath()));\\n        }\\n    }\\n\\n    private static final class ExternalOnlyAttachmentProvider implements ByteBuddyAgent.AttachmentProvider {\\n        @Override\\n        public Accessor attempt() {\\n            return new ExternalOnlyAccessor();\\n        }\\n    }\\n\\n    private static final class ExternalOnlyAccessor implements ByteBuddyAgent.AttachmentProvider.Accessor {\\n        @Override\\n        public boolean isAvailable() {\\n            return true;\\n        }\\n\\n        @Override\\n        public boolean isExternalAttachmentRequired() {\\n            return true;\\n        }\\n\\n        @Override\\n        public Class<?> getVirtualMachineType() {\\n            return RecordingVirtualMachine.class;\\n        }\\n\\n        @Override\\n        public ExternalAttachment getExternalAttachment() {\\n            return new ExternalAttachment(RecordingVirtualMachine.class.getName(), recordingVirtualMachineClassPath());\\n        }\\n    }\\n\\n    public static final class RecordingVirtualMachine {\\n        private RecordingVirtualMachine() {\\n        }\\n\\n        public static RecordingVirtualMachine attach(String processId) {\\n            assertThat(processId).isNotBlank();\\n            return new RecordingVirtualMachine();\\n        }\\n\\n        public void loadAgent(String agent, String argument) {\\n            assertThat(agent).endsWith(\\\"agent.jar\\\");\\n            assertThat(argument).isEqualTo(\\\"coverage\\\");\\n        }\\n\\n        public void loadAgentPath(String agent, String argument) {\\n            throw new AssertionError(\\\"Native agent loading is not expected in this test\\\");\\n        }\\n\\n        public void detach() {\\n        }\\n    }\\n}\\n\"}"}], "api": "openai-responses", "provider": "OCA", "model": "gpt-5.5", "usage": {"input": 2090, "output": 2285, "