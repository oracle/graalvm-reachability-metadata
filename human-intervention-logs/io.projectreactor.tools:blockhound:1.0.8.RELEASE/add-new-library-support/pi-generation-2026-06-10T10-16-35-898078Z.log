16a2938bff3308193a79580926857d51a", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Enumeration;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteArrayClassLoaderInnerChildFirstTest {\n    private static final Class<?> TEST_CLASS = ByteArrayClassLoaderInnerChildFirstTest.class;\n\n    @Test\n    void childFirstLoaderLoadsGeneratedTypesAndDelegatesResources() throws IOException, ClassNotFoundException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Latent\", ClassLoadingStrategy.Default.CHILD_FIRST);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            assertThat(classLoader.loadClass(generatedClass.getName())).isSameAs(generatedClass);\n            assertThat(classLoader.getResource(generatedResourceName)).isNull();\n\n            String parentResourceName = \"org/junit/jupiter/api/Test.class\";\n            URL parentResource = classLoader.getResource(parentResourceName);\n            Enumeration<URL> parentResources = classLoader.getResources(parentResourceName);\n\n            assertThat(parentResource).isNotNull();\n            assertThat(parentResources.hasMoreElements()).isTrue();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    @Test\n    void persistentChildFirstLoaderExposesGeneratedClassResources() throws IOException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Persistent\", ClassLoadingStrategy.Default.CHILD_FIRST_PERSISTENT);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            URL generatedResource = classLoader.getResource(generatedResourceName);\n            Enumeration<URL> generatedResources = classLoader.getResources(generatedResourceName);\n\n            assertThat(generatedResource).isNotNull();\n            assertThat(generatedResources).isNotNull();\n        } catch (Error error) {\n            rethrowUnlessUnsupportedFeatureError(error);\n        }\n    }\n\n    private static Class<?> loadGeneratedClass(\n            String nameSuffix,\n            ClassLoadingStrategy<ClassLoader> classLoadingStrategy) {\n        String className = \"io_projectreactor_tools.blockhound.generated.childfirst.Generated\"\n                + nameSuffix\n                + System.nanoTime();\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(TEST_CLASS.getClassLoader(), classLoadingStrategy)\n                .getLoaded();\n    }\n\n    private static void rethrowUnlessUnsupportedFeatureError(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781086400272}, {"role": "toolResult", "toolCallId": "call_08q0H3hFmyrN0xFL77lI6IQT|fc_05458f53c1a30096016a2938bff3388193a66b2f7696310102", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1