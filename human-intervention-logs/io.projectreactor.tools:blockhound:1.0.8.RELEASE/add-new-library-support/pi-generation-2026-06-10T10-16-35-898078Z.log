piter.api.Test;\nimport org.junit.jupiter.api.io.TempDir;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.MultipleParentClassLoader;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.net.URL;\nimport java.net.URLClassLoader;\nimport java.nio.charset.StandardCharsets;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.ArrayList;\nimport java.util.Collections;\nimport java.util.Enumeration;\nimport java.util.List;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class MultipleParentClassLoaderTest {\n    @Test\n    void loadsClassFromRegisteredParent() throws ClassNotFoundException {\n        ClassLoader parent = MultipleParentClassLoaderTest.class.getClassLoader();\n        ClassLoader classLoader = new MultipleParentClassLoader(Collections.singletonList(parent));\n\n        Class<?> loadedClass = classLoader.loadClass(MultipleParentClassLoaderTest.class.getName());\n\n        assertThat(loadedClass).isSameAs(MultipleParentClassLoaderTest.class);\n    }\n\n    @Test\n    void resolvesResourcesFromRegisteredParentsAndExplicitParent(@TempDir Path tempDirectory) throws IOException {\n        String resourceName = \"multiple-parent-class-loader-resource.txt\";\n        Path registeredParentDirectory = Files.createDirectory(tempDirectory.resolve(\"registered-parent\"));\n        Path explicitParentDirectory = Files.createDirectory(tempDirectory.resolve(\"explicit-parent\"));\n        Path emptyParentDirectory = Files.createDirectory(tempDirectory.resolve(\"empty-parent\"));\n        writeResource(registeredParentDirectory, resourceName, \"registered-parent\");\n        writeResource(explicitParentDirectory, resourceName, \"explicit-parent\");\n\n        try (URLClassLoader registeredParent = directoryLoader(registeredParentDirectory);\n                URLClassLoader explicitParent = directoryLoader(explicitParentDirectory);\n                URLClassLoader emptyParent = directoryLoader(emptyParentDirectory)) {\n            ClassLoader parentFirstLoader = new MultipleParentClassLoader(\n                    explicitParent,\n                    Collections.singletonList(registeredParent));\n            ClassLoader fallbackLoader = new MultipleParentClassLoader(\n                    explicitParent,\n                    Collections.singletonList(emptyParent));\n\n            URL parentResource = parentFirstLoader.getResource(resourceName);\n            URL fallbackResource = fallbackLoader.getResource(resourceName);\n            Enumeration<URL> resources = parentFirstLoader.getResources(resourceName);\n\n            assertThat(readResource(parentResource)).isEqualTo(\"registered-parent\");\n            assertThat(readResource(fallbackResource)).isEqualTo(\"explicit-parent\");\n            assertThat(readResources(resources)).containsExactly(\"registered-parent\", \"explicit-parent\");\n        }\n    }\n\n    private static URLClassLoader directoryLoader(Path directory) throws IOException {\n        return new URLClassLoader(new URL[] {directory.toUri().toURL()}, null);\n    }\n\n    private static void writeResource(Path directory, String name, String contents) throws IOException {\n        Files.write(directory.resolve(name), contents.getBytes(StandardCharsets.UTF_8));\n    }\n\n    private static List<String> readResources(Enumeration<URL> urls) throws IOException {\n        List<String> resources = new ArrayList<String>();\n        while (urls.hasMoreElements()) {\n            resources.add(readResource(urls.nextElement()));\n        }\n        return resources;\n    }\n\n    private static String readResource(URL url) throws IOException {\n        assertThat(url).isNotNull();\n        try (InputStream inputStream = url.openStream()) {\n            return new String(inputStream.readAllBytes(), StandardCharsets.UTF_8);\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1811, "output": 3578, "cacheRead": 27648, "cacheWrite": 0, "totalTokens": 33037, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781086484786, "responseId": "resp_05458f53c1a30096016a2939155f508193a6c1131dec823829"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_bIv7zvIuEBZ3I9EQ2FuYKQcV|fc_05458f53c1a30096016a29395844f88193a8deadb8267688f3", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 4054 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/MultipleParentClassLoaderTest.java"}], "isError": false, "timestamp": 1781086561575}]}
