[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/ClassVisitorFactoryInnerCreateClassVisitorFactoryTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport io_projectreactor_tools.blockhound.classvisitorfactory.ClassVisitor;\nimport org.graalvm.internal.tck.NativeImageSupport;\nimport org.junit.jupiter.api.Test;\n\nimport reactor.blockhound.shaded.net.bytebuddy.asm.ClassVisitorFactory;\nimport reactor.blockhound.shaded.net.bytebuddy.utility.OpenedClassReader;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassVisitorFactoryInnerCreateClassVisitorFactoryTest {\n    @Test\n    void createsFactoryForVisitorFacadeInAnotherAsmNamespace() {\n        try {\n            ClassVisitorFactory<ClassVisitor> factory = ClassVisitorFactory.of(ClassVisitor.class);\n            reactor.blockhound.shaded.net.bytebuddy.jar.asm.ClassVisitor shadedVisitor = new NoOpShadedClassVisitor();\n\n            ClassVisitor wrapped = factory.wrap(shadedVisitor);\n            reactor.blockhound.shaded.net.bytebuddy.jar.asm.ClassVisitor unwrapped = factory.unwrap(wrapped);\n\n            assertThat(factory.getType()).isSameAs(ClassVisitor.class);\n            assertThat(wrapped).isInstanceOf(ClassVisitor.class);\n            assertThat(wrapped.getApi()).isEqualTo(OpenedClassReader.ASM_API);\n            assertThat(unwrapped).isInstanceOf(reactor.blockhound.shaded.net.bytebuddy.jar.asm.ClassVisitor.class);\n        } catch (Error error) {\n            verifyNativeImageUnsupportedFeature(error);\n        }\n    }\n\n    private static void verifyNativeImageUnsupportedFeature(Error error) {\n        if (!NativeImageSupport.isUnsupportedFeatureError(error)) {\n            throw error;\n        }\n    }\n\n    private static final class NoOpShadedClassVisitor extends reactor.blockhound.shaded.net.bytebuddy.jar.asm.ClassVisitor {\n        private NoOpShadedClassVisitor() {\n            super(OpenedClassReader.ASM_API);\n        }\n    }\n}\n"}
