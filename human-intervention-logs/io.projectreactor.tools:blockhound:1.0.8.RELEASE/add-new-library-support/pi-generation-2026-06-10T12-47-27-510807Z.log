e\n        public boolean matches(TypeDescription target) {\n            return false;\n        }\n\n        @Override\n        public DynamicType.Builder<?> apply(\n                DynamicType.Builder<?> builder,\n                TypeDescription typeDescription,\n                ClassFileLocator classFileLocator) {\n            return builder;\n        }\n\n        @Override\n        public void close() {\n        }\n    }\n}\n"}
