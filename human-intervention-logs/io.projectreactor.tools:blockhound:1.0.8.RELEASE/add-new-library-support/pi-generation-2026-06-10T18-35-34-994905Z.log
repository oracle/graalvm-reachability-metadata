  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  
  import java.io.IOException;
  import java.net.URL;
  import java.util.Enumeration;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ByteArrayClassLoaderInnerChildFirstTest {
      private static final Class<?> TEST_CLASS = ByteArrayClassLoaderInnerChildFirstTest.class;
  
      @Test
      void childFirstLoaderLoadsGeneratedTypesAndDelegatesResources() throws IOException, ClassNotFoundException {
          try {
              Class<?> generatedClass = loadGeneratedClass("Latent", ClassLoadingStrategy.Default.CHILD_FIRST);
              ClassLoader classLoader = generatedClass.getClassLoader();
              String generatedResourceName = generatedClass.getName().replace('.', '/') + ".class";
  
              assertThat(classLoader.loadClass(generatedClass.getName())).isSameAs(generatedClass);
              assertThat(classLoader.getResource(generatedResourceName)).isNull();
  
              String parentResourceName = "org/junit/jupiter/api/Test.class";
              URL parentResource = classLoader.getResource(parentResourceName);
              Enumeration<URL> parentResources = classLoader.getResources(parentResourceName);
  
              assertThat(parentResource).isNotNull();
              assertThat(parentResources.hasMoreElements()).isTrue();
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      @Test
      void persistentChildFirstLoaderExposesGeneratedClassResources() throws IOException {
          try {
              Class<?> generatedClass = loadGeneratedClass("Persistent", ClassLoadingStrategy.Default.CHILD_FIRST_PERSISTENT);
              ClassLoader classLoader = generatedClass.getClassLoader();
              String generatedResourceName = generatedClass.getName().replace('.', '/') + ".class";
  
              URL generatedResource = classLoader.getResource(generatedResourceName);
              Enumeration<URL> generatedResources = classLoader.getResources(generatedResourceName);
  
              assertThat(generatedResource).isNotNull();
              assertThat(generatedResources).isNotNull();
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      private static Class<?> loadGeneratedClass(
              String nameSuffix,
              ClassLoadingStrategy<ClassLoader> classLoadingStrategy) {
          String className = "io_projectreactor_tools.blockhound.generated.childfirst.Generated"
                  + nameSuffix
                  + System.nanoTime();
          return new ByteBuddy()
                  .subclass(Object.class)
                  .name(className)
                  .make()
                  .load(TEST_CLASS.getClassLoader(), classLoadingStrategy)
                  .getLoaded();
      }
  
  }
