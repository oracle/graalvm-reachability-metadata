 * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\nplugins {\n    id \"org.graalvm.internal.tck\"\n}\n\nString libraryVersion = tck.testedLibraryVersion.get()\nint currentJavaMajorVersion = JavaVersion.current().majorVersion as int\nint testJavaMajorVersion = currentJavaMajorVersion > 23 ? 21 : currentJavaMajorVersion\n\nif (currentJavaMajorVersion > 23) {\n    tasks.withType(JavaCompile).configureEach {\n        options.release = 21\n    }\n}\n\ndependencies {\n    testImplementation \"io.projectreactor.tools:blockhound:$libraryVersion\"\n    testImplementation 'io.projectreactor:reactor-core:3.2.5.RELEASE'\n    testImplementation 'org.ow2.asm:asm:5.2'\n    testImplementation 'org.assertj:assertj-core:3.22.0'\n}\n\ntasks.named(\"test\") {\n    forkEvery = 1\n    if (currentJavaMajorVersion > 23) {\n        javaLauncher = javaToolchains.launcherFor {\n            languageVersion = JavaLanguageVersion.of(21)\n        }\n    }\n    jvmArgs += [\"--add-opens=java.base/java.lang=ALL-UNNAMED\", \"-Djdk.attach.allowAttachSelf=true\"]\n    if (testJavaMajorVersion >= 13) {\n        jvmArgs += [\"-XX:+AllowRedefinitionToAddDeleteMethods\"]\n    }\n    if (testJavaMajorVersion < 24) {\n        jvmArgs += [\"-Djava.security.manager=allow\"]\n    }\n}\n\ngraalvmNative {\n    agent {\n        defaultMode = \"conditional\"\n        modes {\n            conditional {\n                userCodeFilterPath = \"user-code-filter.json\"\n            }\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781116379499}, {"role": "toolResult", "toolCallId": "call_UUd4AGDqKc4EQE8dtTQVE8GB|fc_06683b30337ae7a1016a29addb47b88193a53f9b5f9c930c9b", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.DynamicType;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ByteArrayClassLoader;\n\nimport java.util.Collections;\nimport java.util.Map;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteArrayClassLoaderTest {\n    private static final ClassLoader PARENT_CLASS_LOADER = ByteArrayClassLoaderTest.class.getClassLoader();\n\n    @Test\n    void defineClassesInjectsGeneratedTypesIntoUnsealedByteArrayClassLoader() throws Exception {\n        try {\n            String className = \"io_projectreactor_tools.blockhound.generated.bytearray.Injected\" + System.nanoTime();\n            DynamicType.Unloaded<?> dynamicType = new ByteBuddy()\n                    .subclass(Object.class)\n                    .name(className)\n                    .make();\n            ByteArrayClassLoader classLoader = new ByteArrayClassLoader(\n                    PARENT_CLASS_LOADER,\n                    false,\n                    Collections.emptyMap());\n\n            Map<String, Class<?>> loadedTypes = classLoader.defineClasses(\n                    Collections.singletonMap(className, dynamicType.getBytes()));\n\n            Class<?> loadedType = loadedTypes.get(className);\n            assertThat(loadedType).isNotNull();\n            assertThat(loadedType.getName()).isEqualTo(className);\n            assertThat(loadedType.getClassLoader()).isSameAs(classLoader);\n            assertThat(classLoader.loadClass(className)).isSameAs(loadedType);\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781116379500}, {"role": "toolResult", "toolCallId": "call_xsuIzOaxNg8Dvo3x2XdGgz8T|fc_06683b30337ae7a1016a29addb48048193ad86b101c652a623", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\n\nimport java.io.IOException;\nimport java.net.URL;\nimport java.util.Enumeration;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ByteArrayClassLoaderInnerChildFirstTest {\n    private static final Class<?> TEST_CLASS = ByteArrayClassLoaderInnerChildFirstTest.class;\n\n    @Test\n    void childFirstLoaderLoadsGeneratedTypesAndDelegatesResources() throws IOException, ClassNotFoundException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Latent\", ClassLoadingStrategy.Default.CHILD_FIRST);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            assertThat(classLoader.loadClass(generatedClass.getName())).isSameAs(generatedClass);\n            assertThat(classLoader.getResource(generatedResourceName)).isNull();\n\n            String parentResourceName = \"org/junit/jupiter/api/Test.class\";\n            URL parentResource = classLoader.getResource(parentResourceName);\n            Enumeration<URL> parentResources = classLoader.getResources(parentResourceName);\n\n            assertThat(parentResource).isNotNull();\n            assertThat(parentResources.hasMoreElements()).isTrue();\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    @Test\n    void persistentChildFirstLoaderExposesGeneratedClassResources() throws IOException {\n        try {\n            Class<?> generatedClass = loadGeneratedClass(\"Persistent\", ClassLoadingStrategy.Default.CHILD_FIRST_PERSISTENT);\n            ClassLoader classLoader = generatedClass.getClassLoader();\n            String generatedResourceName = generatedClass.getName().replace('.', '/') + \".class\";\n\n            URL generatedResource = classLoader.getResource(generatedResourceName);\n            Enumeration<URL> generatedResources = classLoader.getResources(generatedResourceName);\n\n            assertThat(generatedResource).isNotNull();\n            assertThat(generatedResources).isNotNull();\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    private static Class<?> loadGeneratedClass(\n            String nameSuffix,\n            ClassLoadingStrategy<ClassLoader> classLoadingStrategy) {\n        String className = \"io_projectreactor_tools.blockhound.generated.childfirst.Generated\"\n                + nameSuffix\n                + System.nanoTime();\n        return new ByteBuddy()\n                .subclass(Object.class)\n                .name(className)\n                .make()\n                .load(TEST_CLASS.getClassLoader(), classLoadingStrategy)\n                .getLoaded();\n    }\n\n}\n"}], "isError": false, "timestamp": 1781116379503}, {"role": "toolResult", "toolCallId": "call_Wl4nRDzUoQEtY98bsYlRbaTg|fc_06683b30337ae7a1016a29addb480c81939906423adc907e72", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\n\npublic class BlockhoundTest {\n    @Test\n    void test() thr