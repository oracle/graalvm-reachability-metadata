  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassFileLocatorInnerForInstrumentationTest {
      private static final String EXPLICIT_BYTE_BUDDY_MODULE = "blockhound.bytebuddy.classfilelocator.explicit";
      private static final String CLASS_FILE_LOCATOR =
              "reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator";
      private static final String CLASS_FILE_LOCATOR_FOR_INSTRUMENTATION =
              "reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator$ForInstrumentation";
  
      @Test
      void fromInstalledAgentResolvesInstrumentationThroughSystemInstaller() throws Throwable {
          Instrumentation instrumentation = new RetransformCapableInstrumentation();
          try {
              Installer.premain(null, instrumentation);
              try {
                  ClassFileLocator classFileLocator = ClassFileLocator.ForInstrumentation.fromInstalledAgent(
                          ClassLoader.getSystemClassLoader());
                  classFileLocator.close();
  
                  invokeClassFileLocatorFromExplicitModule();
              } catch (Throwable throwable) {
                  BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
              }
          } finally {
              Installer.premain(null, null);
          }
      }
  
      private static void invokeClassFileLocatorFromExplicitModule() throws Throwable {
          Path blockHoundJar = Path.of(ClassFileLocator.class.getProtectionDomain()
                  .getCodeSource()
                  .getLocation()
                  .toURI());
          ModuleFinder finder = new ExplicitBlockHoundModuleFinder(blockHoundJar);
          Configuration configuration = ModuleLayer.boot().configuration()
                  .resolve(finder, ModuleFinder.of(), Set.of(EXPLICIT_BYTE_BUDDY_MODULE));
          ModuleLayer layer = ModuleLayer.boot()
                  .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
          ClassLoader moduleClassLoader = layer.findLoader(EXPLICIT_BYTE_BUDDY_MODULE);
          Class<?> locatorType = moduleClassLoader.loadClass(CLASS_FILE_LOCATOR);
          Class<?> locatorFactory = moduleClassLoader.loadClass(CLASS_FILE_LOCATOR_FOR_INSTRUMENTATION);
          MethodHandle fromInstalledAgent = MethodHandles.publicLookup().findStatic(locatorFactory,
                  "fromInstalledAgent", MethodType.methodType(locatorType, ClassLoader.class));
          MethodHandle close = MethodHandles.publicLookup()
                  .findVirtual(locatorType, "close", MethodType.methodType(void.class));
  
          Object classFileLocator = fromInstalledAgent.invoke(ClassLoader.getSystemClassLoader());
          assertThat(classFileLocator).isNotNull();
          close.invoke(classFileLocator);
      }
  
      private static final class ExplicitBlockHoundModuleFinder implements ModuleFinder {
          private final ModuleReference moduleReference;
  
          private ExplicitBlockHoundModuleFinder(Path jar) throws IOException {
              this.moduleReference = new JarModuleReference(createDescriptor(jar), jar);
          }
  
          @Override
          public Optional<ModuleReference> find(String name) {
              if (EXPLICIT_BYTE_BUDDY_MODULE.equals(name)) {
                  return Optional.of(moduleReference);
              }
              return Optional.empty();
          }
  
          @Override
          public Set<ModuleReference> findAll() {
              return Set.of(moduleReference);
          }
  
          private static ModuleDescriptor createDescriptor(Path jar) throws IOException {
              Set<String> packages;
              try (JarFile jarFile = new JarFile(jar.toFile())) {
                  packages = jarFile.stream()
                          .map(JarEntry::getName)
                          .filter(name -> name.endsWith(".class"))
                          .filter(name -> !"module-info.class".equals(name))
                          .filter(name -> name.contains("/"))
                          .map(name -> name.substring(0, name.lastIndexOf('/')).replace('/', '.'))
                          .collect(Collectors.toSet());
              }
              return ModuleDescriptor.newModule(EXPLICIT_BYTE_BUDDY_MODULE)
                      .requires("java.instrument")
                      .exports("reactor.blockhound.shaded.net.bytebuddy.dynamic")
                      .packages(packages)
                      .build();
          }
      }
  
      private static final class JarModuleReference extends ModuleReference {
          private final Path jar;
  
          private JarModuleReference(ModuleDescriptor descriptor, Path jar) {
              super(descriptor, jar.toUri());
              this.jar = jar;
          }
  
          @Override
          public ModuleReader open() throws IOException {
              return new JarModuleReader(jar);
          }
      }
  
      private static final class JarModuleReader implements ModuleReader {
          private final Path jar;
          private final JarFile jarFile;
  
          private JarModuleReader(Path jar) throws IOException {
              this.jar = jar;
              this.jarFile = new JarFile(jar.toFile());
          }
  
          @Override
          public Optional<URI> find(String name) {
              if (jarFile.getJarEntry(name) == null) {
                  return Optional.empty();
              }
              return Optional.of(URI.create("jar:" + jar.toUri() + "!/" + name));
          }
  
          @Override
  
