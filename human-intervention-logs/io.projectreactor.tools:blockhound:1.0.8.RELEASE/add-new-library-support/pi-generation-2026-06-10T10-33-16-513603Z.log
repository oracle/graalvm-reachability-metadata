ertThat(instrumentation.addedTransformers).hasSize(1);\n        } finally {\n            Installer.premain(null, null);\n        }\n    }\n\n    @Test\n    void installOnByteBuddyAgentAddsReadEdgeFromNamedAgentBuilderModule() throws Throwable {\n","newText":"    private static final byte[] AGENT_COPY_MODULE_INFO = Base64.getDecoder().decode(\n            \"yv66vgAAADUADwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB\"\n                    + \"AAZNb2R1bGUTAAcBAB9ibG9ja2hvdW5kLmJ5dGVidWRkeS5hZ2VudC5jb3B5EwAJAQAJamF2YS5i\"\n                    + \"YXNlAQABORMADAEAD2phdmEuaW5zdHJ1bWVudBQADgEALXJlYWN0b3IvYmxvY2tob3VuZC9zaGFk\"\n                    + \"ZWQvbmV0L2J5dGVidWRkeS9hZ2VudIAAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAACIABgAAAAAA\"\n                    + \"AgAIgAAACgALAAAACgABAA0AAAAAAAAAAAAA\");\n\n    @Test\n    void installOnByteBuddyAgentAddsReadEdgeFromNamedAgentBuilderModule() throws Throwable {\n"},{"oldText":"    private static void installAgentBuilderFromNamedModule() throws Throwable {\n        Path modularJar = writeModularByteBuddyJar();\n        RecordingInstrumentation instrumentation = new RecordingInstrumentation();\n        try {\n            Installer.premain(null, instrumentation);\n\n            ModuleFinder finder = ModuleFinder.of(modularJar);\n            Configuration configuration = ModuleLayer.boot().configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(AGENT_BUILDER_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            ClassLoader loader = layer.findLoader(AGENT_BUILDER_COPY_MODULE);\n            Class<?> defaultType = loader.loadClass(AGENT_BUILDER_DEFAULT_TYPE);\n            Class<?> transformerType = loader.loadClass(\n                    \"reactor.blockhound.shaded.net.bytebuddy.agent.builder.ResettableClassFileTransformer\");\n            MethodHandle constructor = MethodHandles.publicLookup()\n                    .findConstructor(defaultType, MethodType.methodType(void.class));\n            MethodHandle installOnByteBuddyAgent = MethodHandles.publicLookup()\n                    .findVirtual(defaultType, \"installOnByteBuddyAgent\", MethodType.methodType(transformerType));\n\n            Object transformer = installOnByteBuddyAgent.invoke(constructor.invoke());\n\n            assertThat(transformer).isNotNull();\n            assertThat(instrumentation.addedTransformers).hasSize(1);\n        } finally {\n            Installer.premain(null, null);\n            Files.deleteIfExists(modularJar);\n        }\n    }\n\n    private static Path writeModularByteBuddyJar() throws IOException {\n","newText":"    private static void installAgentBuilderFromNamedModule() throws Throwable {\n        Path agentBuilderJar = writeModularAgentBuilderJar();\n        Path agentJar = writeModularAgentJar();\n        RecordingInstrumentation instrumentation = new RecordingInstrumentation();\n        MethodHandle installerPremain = null;\n        try {\n            defineAgentModuleOnSystemClassLoader(agentJar);\n            Class<?> installerType = ClassLoader.getSystemClassLoader().loadClass(INSTALLER_TYPE);\n            installerPremain = MethodHandles.publicLookup()\n                    .findStatic(installerType, \"premain\", MethodType.methodType(void.class, String.class,\n                            Instrumentation.class));\n            installerPremain.invoke(null, instrumentation);\n\n            ModuleFinder finder = ModuleFinder.of(agentBuilderJar);\n            Configuration configuration = ModuleLayer.boot().configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(AGENT_BUILDER_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            ClassLoader loader = layer.findLoader(AGENT_BUILDER_COPY_MODULE);\n            Class<?> defaultType = loader.loadClass(AGENT_BUILDER_DEFAULT_TYPE);\n            Class<?> transformerType = loader.loadClass(\n                    \"reactor.blockhound.shaded.net.bytebuddy.agent.builder.ResettableClassFileTransformer\");\n            MethodHandle constructor = MethodHandles.publicLookup()\n                    .findConstructor(defaultType, MethodType.methodType(void.class));\n            MethodHandle installOnByteBuddyAgent = MethodHandles.publicLookup()\n                    .findVirtual(defaultType, \"installOnByteBuddyAgent\", MethodType.methodType(transformerType));\n\n            Object transformer = installOnByteBuddyAgent.invoke(constructor.invoke());\n\n            assertThat(transformer).isNotNull();\n            assertThat(instrumentation.addedTransformers).hasSize(1);\n        } finally {\n            if (installerPremain != null) {\n                installerPremain.invoke(null, null);\n            }\n            Files.deleteIfExists(agentBuilderJar);\n            Files.deleteIfExists(agentJar);\n        }\n    }\n\n    private static void defineAgentModuleOnSystemClassLoader(Path agentJar) {\n        ModuleFinder finder = ModuleFinder.of(agentJar);\n        Configuration configuration = ModuleLayer.boot().configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(AGENT_COPY_MODULE));\n        ModuleLayer.defineModules(configuration, List.of(ModuleLayer.boot()),\n                moduleName -> ClassLoader.getSystemClassLoader());\n    }\n\n    private static Path writeModularAgentBuilderJar() throws IOException {\n"},{"oldText":"            outputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            outputStream.write(AGENT_BUILDER_COPY_MODULE_INFO);\n            outputStream.closeEntry();\n            if (Files.isDirectory(sourcePath)) {\n                copyByteBuddyClassesFromDirectory(sourcePath, outputStream, copiedEntries);\n            } else {\n                copyByteBuddyClassesFromJar(sourcePath, outputStream, copiedEntries);\n            }\n        }\n        return jar;\n    }\n\n    private static Path codeSourcePath(Class<?> type) {\n","newText":"            outputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            outputStream.write(AGENT_BUILDER_COPY_MODULE_INFO);\n            outputStream.closeEntry();\n            if (Files.isDirectory(sourcePath)) {\n                copyByteBuddyClassesFromDirectory(sourcePath, outputStream, copiedEntries, true);\n            } else {\n                copyByteBuddyClassesFromJar(sourcePath, outputStream, copiedEntries, true);\n            }\n        }\n        return jar;\n    }\n\n    private static Path writeModularAgentJar() throws IOException {\n        Path sourcePath = codeSourcePath(AgentBuilder.class);\n        Path jar = Files.createTempFile(\"blockhound-agent-module\", \".jar\");\n        Set<String> copiedEntries = new HashSet<>();\n        try (JarOutputStream outputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n            outputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            outputStream.write(AGENT_COPY_MODULE_INFO);\n            outputStream.closeEntry();\n            if (Files.isDirectory(sourcePath)) {\n                copyByteBuddyClassesFromDirectory(sourcePath, outputStream, copiedEntries, false);\n            } else {\n                copyByteBuddyClassesFromJar(sourcePath, outputStream, copiedEntries, false);\n            }\n        }\n        return jar;\n    }\n\n    private static Path codeSourcePath(Class<?> type) {\n"},{"oldText":"    private static void copyByteBuddyClassesFromJar(\n            Path sourceJar,\n            JarOutputStream outputStream,\n            Set<String> copiedEntries) throws IOException {\n        try (JarFile jarFile = new JarFile(sourceJar.toFile())) {\n            for (JarEntry entry : Collections.list(jarFile.entries())) {\n                if (isByteBuddyClass(entry.getName())) {\n                    copyEntry(entry.getName(), jarFile.getInputStream(entry), outputStream, copiedEntries);\n                }\n            }\n        }\n    }\n\n    private static void copyByteBuddyClassesFromDirectory(\n            Path sourceDirectory,\n            JarOutputStream outputStream,\n            Set<String> copiedEntries) throws IOException {\n        try (Stream<Path> paths = Files.walk(sourceDirectory)) {\n            for (Path file : paths.filter(Files::isRegularFile).toList()) {\n                String entryName = sourceDirectory.relativize(file).toString().replace(File.separatorChar, '/');\n                if (isByteBuddyClass(entryName)) {\n                    copyEntry(entryName, Files.newInputStream(file), outputStream, copiedEntries);\n                }\n            }\n        }\n    }\n\n    private static boolean isByteBuddyClass(String entryName) {\n        return entryName.startsWith(BYTE_BUDDY_RESOURCE_ROOT) && entryName.endsWith(\".class\");\n    }\n","newText":"    private static void copyByteBuddyClassesFromJar(\n            Path sourceJar,\n            JarOutputStream outputStream,\n            Set<String> copiedEntries,\n            boolean agentBuilderModule) throws IOException {\n        try (JarFile jarFile = new JarFile(sourceJar.toFile())) {\n            for (JarEntry entry : Collections.list(jarFile.entries())) {\n                if (isByteBuddyClass(entry.getName(), agentBuilderModule)) {\n                    copyEntry(entry.getName(), jarFile.getInputStream(entry), outputStream, copiedEntries);\n                }\n            }\n        }\n    }\n\n    private static void copyByteBuddyClassesFromDirectory(\n            Path sourceDirectory,\n            JarOutputStream outputStream,\n            Set<String> copiedEntries,\n            boolean agentBuilderModule) throws IOException {\n        try (Stream<Path> paths = Files.walk(sourceDirectory)) {\n            for (Path file : paths.filter(Files::isRegularFile).toList()) {\n                String entryName = sourceDirectory.relativize(file).toString().replace(File.separatorChar, '/');\n                if (isByteBuddyClass(entryName, agentBuilderModule)) {\n                    copyEntry(entryName, Files.newInputStream(file), outputStream, copiedEntries);\n                }\n            }\n        }\n    }\n\n    private static boolean isByteBuddyClass(String entryName, boolean agentBuilderModule) {\n        if (!entryName.startsWith(BYTE_BUDDY_RESOURCE_ROOT) || !entryName.endsWith(\".class\")) {\n            return false;\n        }\n        if (agentBuilderModule) {\n            return !entryName.startsWith(BYTE_BUDDY_AGENT_RESOURCE_ROOT)\n                    || entryName.startsWith(BYTE_BUDDY_AGENT_BUILDER_RESOURCE_ROOT);\n        }\n        return entryName.equals(BYTE_BUDDY_AGENT_RESOURCE_ROOT + \"Installer.class\")\n                || entryName.startsWith(BYTE_BUDDY_AGENT_RESOURCE_ROOT + \"utility/nullability/\");\n    }\n"}]}
