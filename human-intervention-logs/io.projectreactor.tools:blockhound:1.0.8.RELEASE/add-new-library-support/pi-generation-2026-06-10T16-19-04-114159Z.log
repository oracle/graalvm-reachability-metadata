new AnnotationDescription[] { first, second });\n\n        AnnotationValue.Loaded<Element[]> loadedValue = arrayValue.load(Element.class.getClassLoader());\n        Element[] resolved = loadedValue.resolve();\n\n        assertThat(resolved).hasSize(2);\n        assertThat(resolved[0].name()).isEqualTo(\"alpha\");\n        assertThat(resolved[0].priority()).isEqualTo(3);\n        assertThat(resolved[1].name()).isEqualTo(\"bravo\");\n        assertThat(resolved[1].priority()).isEqualTo(5);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface Element {\n        String name();\n\n        int priority();\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 3255, "output": 1167, "cacheRead": 33280, "cacheWrite": 0, "totalTokens": 37702, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781108288158, "responseId": "resp_0cf08d5a66014875016a298e4097c88195937a0ccca5b73aec"}, "toolResults": [{"role": "toolResult", "toolCallId": "call_ZjqTpC2U33BqZfP3pyLMVHrW|fc_0cf08d5a66014875016a298e52e8f48195beea3925905276e9", "toolName": "write", "content": [{"type": "text", "text": "Successfully wrote 2084 bytes to tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/AnnotationValueInnerForDescriptionArrayTest.java"}], "isError": false, "timestamp": 1781108313074}]}
