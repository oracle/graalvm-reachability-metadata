  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationDescription;
  import reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  import java.lang.reflect.Modifier;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;
  
  public class AnnotationDescriptionInnerForLoadedAnnotationTest {
      @Test
      void readsNestedValuesFromLoadedPackagePrivateAnnotation() {
          OuterAnnotation loadedAnnotation = AnnotatedSample.class.getAnnotation(OuterAnnotation.class);
          AnnotationDescription loadedDescription = AnnotationDescription.ForLoadedAnnotation.of(loadedAnnotation);
          MethodDescription.InDefinedShape nestedMethod = new MethodDescription.Latent(
                  TypeDescription.ForLoadedType.of(OuterAnnotation.class),
                  new MethodDescription.Token(
                          "nested",
                          Modifier.PUBLIC | Modifier.ABSTRACT,
                          TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(NestedAnnotation.class)));
          MethodDescription.InDefinedShape nameMethod = TypeDescription.ForLoadedType.of(NestedAnnotation.class)
                  .getDeclaredMethods()
                  .filter(named("name"))
                  .getOnly();
          MethodDescription.InDefinedShape countMethod = TypeDescription.ForLoadedType.of(NestedAnnotation.class)
                  .getDeclaredMethods()
                  .filter(named("count"))
                  .getOnly();
  
          AnnotationDescription nestedDescription = (AnnotationDescription) loadedDescription.getValue(nestedMethod).resolve();
  
          assertThat(nestedDescription.getAnnotationType().represents(NestedAnnotation.class)).isTrue();
          assertThat(nestedDescription.getValue(nameMethod).resolve()).isEqualTo("bravo");
          assertThat(nestedDescription.getValue(countMethod).resolve()).isEqualTo(7);
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface OuterAnnotation {
          NestedAnnotation nested();
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface NestedAnnotation {
          String name();
  
          int count();
      }
  
      @OuterAnnotation(nested = @NestedAnnotation(name = "bravo", count = 7))
      static class AnnotatedSample {
      }
  }
