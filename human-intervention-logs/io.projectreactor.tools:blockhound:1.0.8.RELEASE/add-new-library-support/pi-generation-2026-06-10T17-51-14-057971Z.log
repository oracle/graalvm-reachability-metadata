[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/NexusTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.Nexus;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.NexusAccessor;\nimport reactor.blockhound.shaded.net.bytebuddy.implementation.LoadedTypeInitializer;\n\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class NexusTest {\n    @Test\n    void initializeInvokesRegisteredLoadedTypeInitializerOnce() throws Exception {\n        try {\n            int identification = (int) System.nanoTime();\n            RecordingLoadedTypeInitializer initializer = new RecordingLoadedTypeInitializer();\n\n            new NexusAccessor().register(Target.class.getName(), Target.class.getClassLoader(), identification, initializer);\n\n            Nexus.initialize(Target.class, identification);\n            Nexus.initialize(Target.class, identification);\n\n            assertThat(initializer.initializedType).hasValue(Target.class);\n            assertThat(initializer.invocations).hasValue(1);\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    public static class Target {\n    }\n\n    private static final class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {\n        private final AtomicReference<Class<?>> initializedType = new AtomicReference<>();\n        private final AtomicInteger invocations = new AtomicInteger();\n\n        @Override\n        public void onLoad(Class<?> type) {\n            initializedType.set(type);\n            invocations.incrementAndGet();\n        }\n\n        @Override\n        public boolean isAlive() {\n            return true;\n        }\n    }\n}\n"}
