rollerPlugin;\n20: import net.bytebuddy.build.HashCodeAndEqualsPlugin;\n21: import net.bytebuddy.description.method.MethodDescription;\n22: import net.bytebuddy.description.type.TypeDescription;\n23: import net.bytebuddy.dynamic.loading.ClassInjector;\n24: import net.bytebuddy.dynamic.loading.ClassLoadingStrategy;\n25: import net.bytebuddy.implementation.Implementation;\n26: import net.bytebuddy.implementation.LoadedTypeInitializer;\n27: import net.bytebuddy.implementation.bytecode.ByteCodeAppender;\n28: import net.bytebuddy.implementation.bytecode.Removal;\n29: import net.bytebuddy.implementation.bytecode.StackManipulation;\n30: import net.bytebuddy.implementation.bytecode.collection.ArrayFactory;\n31: import net.bytebuddy.implementation.bytecode.constant.ClassConstant;\n32: import net.bytebuddy.implementation.bytecode.constant.IntegerConstant;\n33: import net.bytebuddy.implementation.bytecode.constant.NullConstant;\n34: import net.bytebuddy.implementation.bytecode.constant.TextConstant;\n35: import net.bytebuddy.implementation.bytecode.member.MethodInvocation;\n36: import net.bytebuddy.utility.JavaModule;\n37: import net.bytebuddy.utility.nullability.MaybeNull;\n38: import org.objectweb.asm.MethodVisitor;\n39: \n40: import java.lang.ref.Reference;\n41: import java.lang.ref.ReferenceQueue;\n42: import java.lang.reflect.InvocationTargetException;\n43: import java.lang.reflect.Method;\n44: import java.security.PrivilegedAction;\n45: import java.util.Arrays;\n46: import java.util.Collections;\n47: \n48: /**\n49:  * The Nexus accessor is creating a VM-global singleton {@link Nexus} such that it can be seen by all class loaders of\n50:  * a virtual machine. Furthermore, it provides an API to access this global instance.\n51:  */\n52: @HashCodeAndEqualsPlugin.Enhance\n53: public class NexusAccessor {\n54: \n55:     /**\n56:      * The dispatcher to use.\n57:      */\n58:     private static final Dispatcher DISPATCHER = doPrivileged(Dispatcher.CreationAction.INSTANCE);\n59: \n60:     /**\n61:      * The reference queue that is notified upon a GC eligible {@link Nexus} entry or {@code null} if no such queue should be notified.\n62:      */\n63:     @MaybeNull\n64:     @HashCodeAndEqualsPlugin.ValueHandling(HashCodeAndEqualsPlugin.ValueHandling.Sort.REVERSE_NULLABILITY)\n65:     private final ReferenceQueue<? super ClassLoader> referenceQueue;\n66: \n67:     /**\n68:      * Creates a new accessor for the {@link Nexus} without any active management of stale references within a nexus.\n69:      */\n70:     public NexusAccessor() {\n71:         this(null);\n72:     }\n73: \n74:     /**\n75:      * Creates a new accessor for a {@link Nexus} where any GC eligible are enqueued to the supplied reference queue. Any such enqueued\n76:      * reference can be explicitly removed from the nexus via the {@link NexusAccessor#clean(Reference)} method. Nexus entries can\n77:      * become stale if a class loader is garbage collected after a class was loaded but before a class was initialized.\n78:      *\n79:      * @param referenceQueue The reference queue onto which stale references should be enqueued or {@code null} if no reference queue\n80:      *                       should be notified.\n81:      */\n82:     public NexusAccessor(@MaybeNull ReferenceQueue<? super ClassLoader> referenceQueue) {\n83:         this.referenceQueue = referenceQueue;\n84:     }\n85: \n86:     /**\n87:      * A proxy for {@code java.security.AccessController#doPrivileged} that is activated if available.\n88:      *\n89:      * @param action The action to execute from a privileged context.\n90:      * @param <T>    The type of the action's resolved value.\n91:      * @return The action's resolved value.\n92:      */\n93:     @AccessControllerPlugin.Enhance\n94:     private static <T> T doPrivileged(PrivilegedAction<T> action) {\n95:         return action.run();\n96:     }\n97: \n98:     /**\n99:      * Checks if this {@link NexusAccessor} is capable of registering loaded type initializers.\n100:      *\n101:      * @return {@code true} if this accessor is alive.\n102:      */\n103:     public static boolean isAlive() {\n104:         return DISPATCHER.isAlive();\n105:     }\n106: \n107:     /**\n108:      * Removes a stale entries that are registered in the {@link Nexus}. Entries can become stale if a class is loaded but never initialized\n109:      * prior to its garbage collection. As all class loaders within a nexus are only referenced weakly, such class loaders are always garbage\n110:      * collected. However, the initialization data stored by Byte Buddy does not become eligible which is why it needs to be cleaned explicitly.\n111:      *\n112:      * @param reference The reference to remove. References are collected via a reference queue that is supplied to the {@link NexusAccessor}.\n113:      */\n114:     public static void clean(Reference<? extends ClassLoader> reference) {\n115:         DISPATCHER.clean(reference);\n116:     }\n117: \n118:     /**\n119:      * Registers a loaded type initializer in Byte Buddy's {@link Nexus} which is injected into the system class loader.\n120:      *\n121:      * @param name                  The binary name of the class.\n122:      * @param classLoader           The class's class loader.\n123:      * @param identification        The id used for identifying the loaded type initializer that was added to the {@link Nexus}.\n124:      * @param loadedTypeInitializer The loaded type initializer to make available via the {@link Nexus}.\n125:      */\n126:     public void register(String name, @MaybeNull ClassLoader classLoader, int identification, LoadedTypeInitializer loadedTypeInitializer) {\n127:         if (loadedTypeInitializer.isAlive()) {\n128:             DISPATCHER.register(name, classLoader, referenceQueue, identification, loadedTypeInitializer);\n129:         }\n130:     }\n131: \n132:     /**\n133:      * An initialization appender that looks up a loaded type initializer from Byte Buddy's {@link Nexus}.\n134:      */\n135:     @HashCodeAndEqualsPlugin.Enhance\n136:     public static class InitializationAppender implements ByteCodeAppender {\n137: \n138:         /**\n139:          * The id used for identifying the loaded type initializer that was added to the {@link Nexus}.\n140:          */\n141:         private final int identification;\n142: \n143:         /**\n144:          * Creates a new initialization appender.\n145:          *\n146:          * @param identification The id used for identifying the loaded type initializer that was added to the {@link Nexus}.\n147:          */\n148:         public InitializationAppender(int identification) {\n149:             this.identification = identification;\n150:         }\n151: \n152:         /**\n153:          * {@inheritDoc}\n154:          */\n155:         public Size apply(MethodVisitor methodVisitor, Implementation.Context implementationContext, MethodDescription instrumentedMethod) {\n156:             try {\n157:                 return new ByteCodeAppender.Simple(new StackManipulation.Compound(\n158:                         MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(ClassLoader.class.getMethod(\"getSystemClassLoader\"))),\n159:                         new TextConstant(Nexus.class.getName()),\n160:                         MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(ClassLoader.class.getMethod(\"loadClass\", String.class))),\n161:                         new TextConstant(\"initialize\"),\n162:                         ArrayFactory.forType(TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(Class.class))\n163:                                 .withValues(Arrays.asList(\n164:                                         ClassConstant.of(TypeDescription.ForLoadedType.of(Class.class)),\n165:                                         ClassConstant.of(TypeDescription.ForLoadedType.of(int.class)))),\n166:                         MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(Class.class.getMethod(\"getMethod\", String.class, Class[].class))),\n167:                         NullConstant.INSTANCE,\n168:                         ArrayFactory.forType(TypeDescription.Generic.OfNonGenericType.ForLoadedType.of(Object.class))\n169:                                 .withValues(Arrays.asList(\n170:                                         ClassConstant.of(instrumentedMethod.getDeclaringType().asErasure()),\n171:                                         new StackManipulation.Compound(\n172:                                                 IntegerConstant.forValue(identification),\n173:                                                 MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(Integer.class.getMethod(\"valueOf\", int.class)))))),\n174:                         MethodInvocation.invoke(new MethodDescription.ForLoadedMethod(Method.class.getMethod(\"invoke\", Object.class, Object[].class))),\n175:                         Removal.SINGLE\n176:                 )).apply(methodVisitor, implementationContext, instrumentedMethod);\n177:             } catch (NoSuchMethodException exception) {\n178:                 throw new IllegalStateException(\"Cannot locate method\", exception);\n179:             }\n281:             /**\n282:              * Creates a new dispatcher.\n283:              *\n284:              * @param register The {@link Nexus#register(String, ClassLoader, ReferenceQueue, int, Object)} method.\n285:              * @param clean    The {@link Nexus#clean(Reference)} method.\n286:              */\n287:             protected Available(Method register, Method clean) {\n288:                 this.register = register;\n289:                 this.clean = clean;\n290:             }\n291: \n292:             /**\n293:              * {@inheritDoc}\n294:              */\n295:             public boolean isAlive() {\n296:                 return true;\n297:             }\n298: \n299:             /**\n300:              * {@inheri