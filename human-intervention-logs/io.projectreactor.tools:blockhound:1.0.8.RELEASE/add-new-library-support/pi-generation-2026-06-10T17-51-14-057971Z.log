et.class.getName(), Target.class.getClassLoader(), identification, initializer);\n\n            Nexus.initialize(Target.class, identification);\n            Nexus.initialize(Target.class, identification);\n\n            assertThat(initializer.initializedType).hasValue(Target.class);\n            assertThat(initializer.invocations).hasValue(1);\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    public static class Target {\n    }\n\n    private static final class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {\n        private final AtomicReference<Class<?>> initializedType = new AtomicReference<>();\n        private final AtomicInteger invocations = new AtomicInteger();\n\n        @Override\n        public void onLoad(Class<?> type) {\n            initializedType.set(type);\n            invocations.incrementAndGet();\n        }\n\n        @Override\n        public boolean isAlive() {\n            return true;\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 13197, "output": 1063, "cacheRead": 31232, "cacheWrite": 0, "totalTokens": 45492, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781113833003, "responseId": "resp_03f78e43eab255a8016a29a3e9806c8196a974bf1af893d70a"}}
