  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.ByteBuddy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.NexusAccessor;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.TypeResolutionStrategy;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassLoadingStrategy;
  import reactor.blockhound.shaded.net.bytebuddy.implementation.LoadedTypeInitializer;
  
  import java.io.InputStream;
  import java.io.OutputStream;
  import java.lang.invoke.MethodHandle;
  import java.lang.invoke.MethodHandles;
  import java.lang.invoke.MethodType;
  import java.lang.module.Configuration;
  import java.lang.module.ModuleFinder;
  import java.net.URL;
  import java.net.URLClassLoader;
  import java.nio.file.Files;
  import java.nio.file.Path;
  import java.security.Permission;
  import java.util.Base64;
  import java.util.Enumeration;
  import java.util.Set;
  import java.util.concurrent.atomic.AtomicReference;
  import java.util.jar.JarEntry;
  import java.util.jar.JarFile;
  import java.util.jar.JarOutputStream;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class NexusAccessorInnerDispatcherInnerCreationActionTest {
      private static final Class<?> TEST_CLASS = NexusAccessorInnerDispatcherInnerCreationActionTest.class;
      private static final String BLOCKHOUND_COPY_MODULE = "blockhound.bytebuddy.copy";
      private static final byte[] BLOCKHOUND_COPY_MODULE_INFO = Base64.getDecoder().decode(
              "yv66vgAAADUADQcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB"
                      + "AAZNb2R1bGUTAAcBABlibG9ja2hvdW5kLmJ5dGVidWRkeS5jb3B5EwAJAQAJamF2YS5iYXNlAQAB"
                      + "ORQADAEAL3JlYWN0b3IvYmxvY2tob3VuZC9zaGFkZWQvbmV0L2J5dGVidWRkeS9keW5hbWljgAAA"
                      + "AQAAAAAAAAAAAAIAAwAAAAIABAAFAAAAHAAGAAAAAAABAAiAAAAKAAEACwAAAAAAAAAAAAA=");
  
      @Test
      void activeTypeResolutionRegistersInitializerThroughSystemNexus() throws Throwable {
          try {
              createNamedModuleAccessorWithNexusDefinitionDenied();
              registerInitializerThroughSystemNexus();
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      private static void registerInitializerThroughSystemNexus() throws Exception {
          try (URLClassLoader classLoader = new URLClassLoader(new URL[0], TEST_CLASS.getClassLoader())) {
              AtomicReference<Class<?>> initializedType = new AtomicReference<>();
              String className = "io_projectreactor_tools.blockhound.generated.NexusInitialized" + System.nanoTime();
  
              Class<?> generatedType = new ByteBuddy()
                      .subclass(Object.class)
                      .name(className)
                      .initializer(new RecordingLoadedTypeInitializer(initializedType))
                      .make(new TypeResolutionStrategy.Active())
                      .load(classLoader, ClassLoadingStrategy.Default.WRAPPER)
                      .getLoaded();
  
              Class.forName(generatedType.getName(), true, generatedType.getClassLoader());
  
              assertThat(initializedType).hasValue(generatedType);
          }
      }
  
      private static void createNamedModuleAccessorWithNexusDefinitionDenied() throws Throwable {
          Path modularBlockhoundJar = writeModularBlockhoundJar();
          SecurityManager originalSecurityManager = System.getSecurityManager();
          boolean securityManagerInstalled = false;
          try {
              ModuleFinder finder = ModuleFinder.of(modularBlockhoundJar);
              Configuration configuration = ModuleLayer.boot().configuration()
                      .resolve(finder, ModuleFinder.of(), Set.of(BLOCKHOUND_COPY_MODULE));
              ModuleLayer layer = ModuleLayer.boot()
                      .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());
              try {
                  System.setSecurityManager(new DenyByteBuddyNexusDefinitionSecurityManager());
                  securityManagerInstalled = true;
              } catch (UnsupportedOperationException exception) {
                  assertThat(NexusAccessor.isAlive()).isTrue();
                  return;
              }
              Class<?> accessorType = layer.findLoader(BLOCKHOUND_COPY_MODULE).loadClass(NexusAccessor.class.getName());
              MethodHandle isAlive = MethodHandles.publicLookup()
                      .findStatic(accessorType, "isAlive", MethodType.methodType(boolean.class));
  
              assertThat((boolean) isAlive.invoke()).isTrue();
          } finally {
              if (securityManagerInstalled) {
                  System.setSecurityManager(originalSecurityManager);
              }
              Files.deleteIfExists(modularBlockhoundJar);
          }
      }
  
      private static Path writeModularBlockhoundJar() throws Exception {
          Path blockhoundJar = Path.of(NexusAccessor.class.getProtectionDomain().getCodeSource().getLocation().toURI());
          Path modularJar = Files.createTempFile("blockhound-byte-buddy-module", ".jar");
          try (JarFile sourceJar = new JarFile(blockhoundJar.toFile());
               JarOutputStream outputStream = new JarOutputStream(Files.newOutputStream(modularJar))) {
              outputStream.putNextEntry(new JarEntry("module-info.class"));
              outputStream.write(BLOCKHOUND_COPY_MODULE_INFO);
              outputStream.closeEntry();
              Enumeration<JarEntry> entries = sourceJar.entries();
              while (entries.hasMoreElements()) {
                  JarEntry sourceEntry = entries.nextElement();
                  if (!"module-info.class".equals(sourceEntry.getName())) {
                      copyJarEntry(sourceJar, sourceEntry, outputStream);
                  }
              }
          }
          return modularJar;
      }
  
      private static void copyJarEntry(
              JarFile sourceJar,
              JarEntry sourceEntry,
              JarOutputStream outputStream) throws Exception {
          outputStream.putNextEntry(new JarEntry(sourceEntry.getName()));
          if (!sourceEntry.isDirectory()) {
              try (InputStream inputStream = sourceJar.getInputStream(sourceEntry)) {
                  copy(inputStream, outputStream);
              }
          }
          outputStream.closeEntry();
      }
  
      private static void copy(InputStream inputStream, OutputStream outputStream) throws Exception {
          byte[] buffer = new byte[8192];
          int length;
          while ((length = inputStream.read(buffer)) != -1) {
              outputStream.write(buffer, 0, length);
          }
      }
  
      private static final class DenyByteBuddyNexusDefinitionSecurityManager extends SecurityManager {
          @Override
          public void checkPermission(Permission permission) {
              if (permission instanceof RuntimePermission
                      && permission.getName().equals("defineClassInPackage."
                      + "reactor.blockhound.shaded.net.bytebuddy.dynamic")
                      && isByteBuddyClassInjectionOnStack()) {
                  throw new SecurityException("Use the system class loader's existing Nexus class");
              }
          }
  
          private static boolean isByteBuddyClassInjectionOnStack() {
              for (StackTraceElement element : Thread.currentThread().getStackTrace()) {
                  if (element.getClassName().contains(".dynamic.loading.ClassInjector")) {
                      return true;
                  }
              }
              return false;
          }
      }
  
      private static final class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {
          private final AtomicReference<Class<?>> initializedType;
  
          private RecordingLoadedTypeInitializer(AtomicReference<Class<?>> initializedType) {
              this.initializedType = initializedType;
          }
  
          @Override
          public void onLoad(Class<?> type) {
              initializedType.set(type);
          }
  
          @Override
          public boolean isAlive() {
              return true;
          }
      }
  }
