  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.AfterEach;
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.implementation.LoadedTypeInitializer.ForStaticField;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class LoadedTypeInitializerInnerForStaticFieldTest {
      @AfterEach
      void resetTargetField() {
          Target.value = null;
      }
  
      @Test
      void onLoadAssignsConfiguredValueToDeclaredStaticField() {
          try {
              String expectedValue = "initialized-by-byte-buddy";
              ForStaticField initializer = new ForStaticField("value", expectedValue);
  
              initializer.onLoad(Target.class);
  
              assertThat(Target.value).isEqualTo(expectedValue);
              assertThat(initializer.isAlive()).isTrue();
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      public static class Target {
          public static Object value;
      }
  }
