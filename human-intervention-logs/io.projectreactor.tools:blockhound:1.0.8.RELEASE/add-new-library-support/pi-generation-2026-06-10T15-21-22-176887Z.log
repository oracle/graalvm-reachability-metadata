ter(named(\"name\"))\n                .getOnly();\n        MethodDescription.InDefinedShape countMethod = TypeDescription.ForLoadedType.of(NestedAnnotation.class)\n                .getDeclaredMethods()\n                .filter(named(\"count\"))\n                .getOnly();\n\n        AnnotationDescription nestedDescription = (AnnotationDescription) loadedDescription.getValue(nestedMethod).resolve();\n\n        assertThat(nestedDescription.getAnnotationType().represents(NestedAnnotation.class)).isTrue();\n        assertThat(nestedDescription.getValue(nameMethod).resolve()).isEqualTo(\"bravo\");\n        assertThat(nestedDescription.getValue(countMethod).resolve()).isEqualTo(7);\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface OuterAnnotation {\n        NestedAnnotation nested();\n    }\n\n    @Retention(RetentionPolicy.RUNTIME)\n    public @interface NestedAnnotation {\n        String name();\n\n        int count();\n    }\n\n    @OuterAnnotation(nested = @NestedAnnotation(name = \"bravo\", count = 7))\n    static class AnnotatedSample {\n    }\n}\n"}], "isError": false, "timestamp": 1781104731823}}
