classFileLocator = ClassFileLocator.ForInstrumentation.fromInstalledAgent(\n                        ClassLoader.getSystemClassLoader());\n                classFileLocator.close();\n\n                invokeClassFileLocatorFromExplicitModule();\n            } catch (Throwable throwable) {\n                BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n            }\n        } finally {\n            Installer.premain(null, null);\n        }\n    }\n\n    private static void invokeClassFileLocatorFromExplicitModule() throws Throwable {\n        Path blockHoundJar = Path.of(ClassFileLocator.class.getProtectionDomain()\n                .getCodeSource()\n                .getLocation()\n                .toURI());\n        ModuleFinder finder = new ExplicitBlockHoundModuleFinder(blockHoundJar);\n        Configuration configuration = ModuleLayer.boot().configuration()\n                .resolve(finder, ModuleFinder.of(), Set.of(EXPLICIT_BYTE_BUDDY_MODULE));\n        ModuleLayer layer = ModuleLayer.boot()\n                .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n        ClassLoader moduleClassLoader = layer.findLoader(EXPLICIT_BYTE_BUDDY_MODULE);\n        Class<?> locatorType = moduleClassLoader.loadClass(CLASS_FILE_LOCATOR);\n        Class<?> locatorFactory = moduleClassLoader.loadClass(CLASS_FILE_LOCATOR_FOR_INSTRUMENTATION);\n        MethodHandle fromInstalledAgent = MethodHandles.publicLookup().findStatic(locatorFactory,\n                \"fromInstalledAgent\", MethodType.methodType(locatorType, ClassLoader.class));\n        MethodHandle close = MethodHandles.publicLookup()\n                .findVirtual(locatorType, \"close\", MethodType.methodType(void.class));\n\n        Object classFileLocator = fromInstalledAgent.invoke(ClassLoader.getSystemClassLoader());\n        assertThat(classFileLocator).isNotNull();\n        close.invoke(classFileLocator);\n    }\n\n    private static final class ExplicitBlockHoundModuleFinder implements ModuleFinder {\n        private final ModuleReference moduleReference;\n\n        private ExplicitBlockHoundModuleFinder(Path jar) throws IOException {\n            this.moduleReference = new JarModuleReference(createDescriptor(jar), jar);\n        }\n\n        @Override\n        public Optional<ModuleReference> find(String name) {\n            if (EXPLICIT_BYTE_BUDDY_MODULE.equals(name)) {\n                return Optional.of(moduleReference);\n            }\n            return Optional.empty();\n        }\n\n        @Override\n        public Set<ModuleReference> findAll() {\n            return Set.of(moduleReference);\n        }\n\n        private static ModuleDescriptor createDescriptor(Path jar) throws IOException {\n            Set<String> packages;\n            try (JarFile jarFile = new JarFile(jar.toFile())) {\n                packages = jarFile.stream()\n                        .map(JarEntry::getName)\n                        .filter(name -> name.endsWith(\".class\"))\n                        .filter(name -> !\"module-info.class\".equals(name))\n                        .filter(name -> name.contains(\"/\"))\n                        .map(name -> name.substring(0, name.lastIndexOf('/')).replace('/', '.'))\n                        .collect(Collectors.toSet());\n            }\n            return ModuleDescriptor.newModule(EXPLICIT_BYTE_BUDDY_MODULE)\n                    .requires(\"java.instrument\")\n                    .exports(\"reactor.blockhound.shaded.net.bytebuddy.dynamic\")\n                    .packages(packages)\n                    .build();\n        }\n    }\n\n    private static final class JarModuleReference extends ModuleReference {\n        private final Path jar;\n\n        private JarModuleReference(ModuleDescriptor descriptor, Path jar) {\n            super(descriptor, jar.toUri());\n            this.jar = jar;\n        }\n\n        @Override\n        public ModuleReader open() throws IOException {\n            return new JarModuleReader(jar);\n        }\n    }\n\n    private static final class JarModuleReader implements ModuleReader {\n        private final Path jar;\n        private final JarFile jarFile;\n\n        private JarModuleReader(Path jar) throws IOException {\n            this.jar = jar;\n            this.jarFile = new JarFile(jar.toFile());\n        }\n\n        @Override\n        public Optional<URI> find(String name) {\n            if (jarFile.getJarEntry(name) == null) {\n                return Optional.empty();\n            }\n            return Optional.of(URI.create(\"jar:\" + jar.toUri() + \"!/\" + name));\n        }\n\n        @Override\n        public Optional<InputStream> open(String name) throws IOException {\n            JarEntry entry = jarFile.getJarEntry(name);\n            if (entry == null) {\n                return Optional.empty();\n            }\n            return Optional.of(jarFile.getInputStream(entry));\n        }\n\n        @Override\n        public Optional<ByteBuffer> read(String name) throws IOException {\n            Optional<InputStream> inputStream = open(name);\n            if (inputStream.isEmpty()) {\n                return Optional.empty();\n            }\n            try (InputStream stream = inputStream.get()) {\n                return Optional.of(ByteBuffer.wrap(stream.readAllBytes()));\n            }\n        }\n\n        @Override\n        public void release(ByteBuffer byteBuffer) {\n        }\n\n        @Override\n        public Stream<String> list() {\n            return jarFile.stream().map(JarEntry::getName);\n        }\n\n        @Override\n        public void close() throws IOException {\n            jarFile.close();\n        }\n    }\n\n    private static final class RetransformCapableInstrumentation implements Instrumentation {\n        @Override\n        public void addTransformer(ClassFileTransformer transformer, boolean canRetransform) {\n        }\n\n        @Override\n        public void addTransformer(ClassFileTransformer transformer) {\n        }\n\n        @Override\n        public boolean removeTransformer(ClassFileTransformer transformer) {\n            return true;\n        }\n\n        @Override\n        public boolean isRetransformClassesSupported() {\n            return true;\n        }\n\n        @Override\n        public void retransformClasses(Class<?>... classes) throws UnmodifiableClassException {\n            throw new UnmodifiableClassException();\n        }\n\n        @Override\n        public boolean isRedefineClassesSupported() {\n            return false;\n        }\n\n        @Override\n        public void redefineClasses(ClassDefinition... definitions)\n                throws ClassNotFoundException, UnmodifiableClassException {\n            throw new UnmodifiableClassException();\n        }\n\n        @Override\n        public boolean isModifiableClass(Class<?> theClass) {\n            return false;\n        }\n\n        @Override\n        public Class[] getAllLoadedClasses() {\n            return new Class[0];\n        }\n\n        @Override\n        public Class[] getInitiatedClasses(ClassLoader loader) {\n            return new Class[0];\n        }\n\n        @Override\n        public long getObjectSize(Object objectToSize) {\n            return 0L;\n        }\n\n        @Override\n        public void appendToBootstrapClassLoaderSearch(JarFile jarfile) {\n        }\n\n        @Override\n        public void appendToSystemClassLoaderSearch(JarFile jarfile) {\n        }\n\n        @Override\n        public boolean isNativeMethodPrefixSupported() {\n            return false;\n        }\n\n        @Override\n        public void setNativeMethodPrefix(ClassFileTransformer transformer, String prefix) {\n        }\n\n        @Override\n        public void redefineModule(\n                Module module,\n                Set<Module> extraReads,\n                Map<String, Set<Module>> extraExports,\n                Map<String, Set<Module>> extraOpens