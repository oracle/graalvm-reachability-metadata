ommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.lang.instrument.ClassDefinition;\nimport java.lang.instrument.ClassFileTransformer;\nimport java.lang.instrument.Instrumentation;\nimport java.lang.instrument.UnmodifiableClassException;\nimport java.security.ProtectionDomain;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.jar.JarFile;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassFileLocatorInnerForInstrumentationInnerClassLoadingDelegateInnerDefaultTest {\n\n    @Test\n    void locateLoadsClassThroughDefaultClassLoadingDelegate() throws IOException {\n        ClassLoader targetClassLoader = LoadTarget.class.getClassLoader();\n        Instrumentation instrumentation = new ClassBytesSupplyingInstrumentation();\n        ClassFileLocator classFileLocator = new ClassFileLocator.ForInstrumentation(instrumentation, targetClassLoader);\n\n        try {\n            ClassFileLocator.Resolution resolution = classFileLocator.locate(LoadTarget.class.getName());\n\n            assertThat(resolution.isResolved()).isTrue();\n            assertThat(resolution.resolve()).isEqualTo(readClassBytes(LoadTarget.class));\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        } finally {\n            classFileLocator.close();\n        }\n    }\n\n    private static byte[] readClassBytes(Class<?> type) throws IOException {\n        String resourceName = type.getName().replace('.', '/') + \".class\";\n        try (InputStream inputStream = type.getClassLoader().getResourceAsStream(resourceName)) {\n            assertThat(inputStream).isNotNull();\n            return inputStream.readAllBytes();\n        }\n    }\n\n    private static final class LoadTarget {\n    }\n\n    private static final class ClassBytesSupplyingInstrumentation implements Instrumentation {\n        private ClassFileTransformer transformer;\n\n        @Override\n        public void addTransformer(ClassFileTransformer transformer, boolean canRetransform) {\n            assertThat(canRetransform).isTrue();\n            this.transformer = transformer;\n        }\n\n        @Override\n        public void addTransformer(ClassFileTransformer transformer) {\n            this.transformer = transformer;\n        }\n\n        @Override\n        public boolean removeTransformer(ClassFileTransformer transformer) {\n            assertThat(transformer).isSameAs(this.transformer);\n            this.transformer = null;\n            return true;\n        }\n\n        @Override\n        public boolean isRetransformClassesSupported() {\n            return true;\n        }\n\n        @Override\n        public void retransformClasses(Class<?>... classes) throws UnmodifiableClassException {\n            assertThat(classes).containsExactly(LoadTarget.class);\n            assertThat(transformer).isNotNull();\n            try {\n                Class<?> type = classes[0];\n                ProtectionDomain protectionDomain = type.getProtectionDomain();\n                byte[] classBytes = readClassBytes(type);\n                transformer.transform(type.getModule(), type.getClassLoader(), internalName(type), type,\n                        protectionDomain, classBytes);\n            } catch (IOException exception) {\n                throw new AssertionError(exception);\n            }\n        }\n\n        @Override\n        public boolean isRedefineClassesSupported() {\n            return false;\n        }\n\n        @Override\n        public void redefineClasses(ClassDefinition... definitions)\n                throws ClassNotFoundException, UnmodifiableClassException {\n            throw new UnmodifiableClassException();\n        }\n\n        @Override\n        public boolean isModifiableClass(Class<?> theClass) {\n            return true;\n        }\n\n        @Override\n        public Class[] getAllLoadedClasses() {\n            return new Class[] {LoadTarget.class};\n        }\n\n        @Override\n        public Class[] getInitiatedClasses(ClassLoader loader) {\n            return new Class[] {LoadTarget.class};\n        }\n\n        @Override\n        public long getObjectSize(Object objectToSize) {\n            return 0L;\n        }\n\n        @Override\n        public void appendToBootstrapClassLoaderSearch(JarFile jarfile) {\n        }\n\n        @Override\n        public void appendToSystemClassLoaderSearch(JarFile jarfile) {\n        }\n\n        @Override\n        public boolean isNativeMethodPrefixSupported() {\n            return false;\n        }\n\n        @Override\n        public void setNativeMethodPrefix(ClassFileTransformer transformer, String prefix) {\n        }\n\n        @Override\n        public void redefineModule(\n                Module module,\n                Set<Module> extraReads,\n                Map<String, Set<Module>> extraExports,\n                Map<String, Set<Module>> extraOpens,\n                Set<Class<?>> extraUses,\n                Map<Class<?>, List<Class<?>>> extraProvides) {\n        }\n\n        @Override\n        public boolean isModifiableModule(Module module) {\n            return true;\n        }\n\n        private static String internalName(Class<?> type) {\n            return type.getName().replace('.', '/');\n        }\n    }\n}\n"}}], "api": "openai-responses", "provider": "OCA", "model": "oca/gpt-5.5", "usage": {"input": 1376, "output": 2501, "cacheRead": 29696, "cacheWrite": 0, "totalTokens": 33573, "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0, "total": 0}}, "stopReason": "toolUse", "timestamp": 1781113110885, "responseId": "resp_0e650248b49e0fb6016a29a117623c81908d3dcff011fe3237"}, "toolResults": [{"role": "