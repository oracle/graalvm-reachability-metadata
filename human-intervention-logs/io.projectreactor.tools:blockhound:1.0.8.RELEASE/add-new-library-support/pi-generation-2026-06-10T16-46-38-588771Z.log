[tool-call] delta {"path":"tests/src/io.projectreactor.tools/blockhound/1.0.8.RELEASE/src/test/java/io_projectreactor_tools/blockhound/AnnotationValueInnerForEnumerationDescriptionTest.java","content":"/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;\nimport reactor.blockhound.shaded.net.bytebuddy.description.enumeration.EnumerationDescription;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class AnnotationValueInnerForEnumerationDescriptionTest {\n    @Test\n    void loadsEnumerationDescriptionWithProvidedClassLoader() {\n        try {\n            EnumerationDescription enumerationDescription = new EnumerationDescription.ForLoadedEnumeration(SampleChoice.SECOND);\n            AnnotationValue<EnumerationDescription, SampleChoice> value =\n                    AnnotationValue.ForEnumerationDescription.of(enumerationDescription);\n\n            AnnotationValue.Loaded<SampleChoice> loadedValue = value.load(SampleChoice.class.getClassLoader());\n            SampleChoice resolved = loadedValue.resolve();\n\n            assertThat(loadedValue.getState()).isEqualTo(AnnotationValue.State.RESOLVED);\n            assertThat(resolved).isSameAs(SampleChoice.SECOND);\n            assertThat(loadedValue.represents(SampleChoice.SECOND)).isTrue();\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    enum SampleChoice {\n        FIRST,\n        SECOND\n    }\n}\n"}
