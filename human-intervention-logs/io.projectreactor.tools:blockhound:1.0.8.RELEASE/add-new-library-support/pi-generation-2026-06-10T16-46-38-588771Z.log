  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationDescription;
  import reactor.blockhound.shaded.net.bytebuddy.description.annotation.AnnotationValue;
  import reactor.blockhound.shaded.net.bytebuddy.description.method.MethodDescription;
  import reactor.blockhound.shaded.net.bytebuddy.description.type.TypeDescription;
  
  import java.lang.annotation.Retention;
  import java.lang.annotation.RetentionPolicy;
  
  import static org.assertj.core.api.Assertions.assertThat;
  import static reactor.blockhound.shaded.net.bytebuddy.matcher.ElementMatchers.named;
  
  public class AnnotationValueInnerForAnnotationDescriptionTest {
      @Test
      void loadsAnnotationDescriptionValueWithAnnotationTypeClassLoader() {
          try {
              ContainerAnnotation loadedAnnotation = AnnotatedSample.class.getAnnotation(ContainerAnnotation.class);
              AnnotationDescription containerDescription = AnnotationDescription.ForLoadedAnnotation.of(loadedAnnotation);
              MethodDescription.InDefinedShape nestedMethod = TypeDescription.ForLoadedType.of(ContainerAnnotation.class)
                      .getDeclaredMethods()
                      .filter(named("nested"))
                      .getOnly();
              AnnotationDescription nestedDescription = (AnnotationDescription) containerDescription
                      .getValue(nestedMethod)
                      .resolve();
              AnnotationValue<AnnotationDescription, NestedAnnotation> nestedValue =
                      new AnnotationValue.ForAnnotationDescription<>(nestedDescription);
  
              AnnotationValue.Loaded<NestedAnnotation> loadedValue = nestedValue.load(
                      NestedAnnotation.class.getClassLoader());
              NestedAnnotation resolvedAnnotation = loadedValue.resolve();
  
              assertThat(resolvedAnnotation.annotationType()).isEqualTo(NestedAnnotation.class);
              assertThat(resolvedAnnotation.name()).isEqualTo("charlie");
              assertThat(resolvedAnnotation.count()).isEqualTo(11);
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface ContainerAnnotation {
          NestedAnnotation nested();
      }
  
      @Retention(RetentionPolicy.RUNTIME)
      public @interface NestedAnnotation {
          String name();
  
          int count();
      }
  
      @ContainerAnnotation(nested = @NestedAnnotation(name = "charlie", count = 11))
      static class AnnotatedSample {
      }
  }
