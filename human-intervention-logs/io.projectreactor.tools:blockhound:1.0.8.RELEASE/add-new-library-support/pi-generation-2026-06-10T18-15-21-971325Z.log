BlibG9ja2hvdW5kLmJ5dGVidWRkeS5jb3B5EwAJAQAJamF2YS5iYXNlAQAB\"\n                    + \"ORQADAEAL3JlYWN0b3IvYmxvY2tob3VuZC9zaGFkZWQvbmV0L2J5dGVidWRkeS9keW5hbWljgAAA\"\n                    + \"AQAAAAAAAAAAAAIAAwAAAAIABAAFAAAAHAAGAAAAAAABAAiAAAAKAAEACwAAAAAAAAAAAAA=\");\n\n    @Test\n    void activeTypeResolutionRegistersInitializerThroughSystemNexus() throws Throwable {\n        try {\n            createNamedModuleAccessorWithNexusDefinitionDenied();\n            registerInitializerThroughSystemNexus();\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    private static void registerInitializerThroughSystemNexus() throws Exception {\n        try (URLClassLoader classLoader = new URLClassLoader(new URL[0], TEST_CLASS.getClassLoader())) {\n            AtomicReference<Class<?>> initializedType = new AtomicReference<>();\n            String className = \"io_projectreactor_tools.blockhound.generated.NexusInitialized\" + System.nanoTime();\n\n            Class<?> generatedType = new ByteBuddy()\n                    .subclass(Object.class)\n                    .name(className)\n                    .initializer(new RecordingLoadedTypeInitializer(initializedType))\n                    .make(new TypeResolutionStrategy.Active())\n                    .load(classLoader, ClassLoadingStrategy.Default.WRAPPER)\n                    .getLoaded();\n\n            Class.forName(generatedType.getName(), true, generatedType.getClassLoader());\n\n            assertThat(initializedType).hasValue(generatedType);\n        }\n    }\n\n    private static void createNamedModuleAccessorWithNexusDefinitionDenied() throws Throwable {\n        Path modularBlockhoundJar = writeModularBlockhoundJar();\n        SecurityManager originalSecurityManager = System.getSecurityManager();\n        boolean securityManagerInstalled = false;\n        try {\n            ModuleFinder finder = ModuleFinder.of(modularBlockhoundJar);\n            Configuration configuration = ModuleLayer.boot().configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(BLOCKHOUND_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            try {\n                System.setSecurityManager(new DenyByteBuddyNexusDefinitionSecurityManager());\n                securityManagerInstalled = true;\n            } catch (UnsupportedOperationException exception) {\n                assertThat(NexusAccessor.isAlive()).isTrue();\n                return;\n            }\n            Class<?> accessorType = layer.findLoader(BLOCKHOUND_COPY_MODULE).loadClass(NexusAccessor.class.getName());\n            MethodHandle isAlive = MethodHandles.publicLookup()\n                    .findStatic(accessorType, \"isAlive\", MethodType.methodType(boolean.class));\n\n            assertThat((boolean) isAlive.invoke()).isTrue();\n        } finally {\n            if (securityManagerInstalled) {\n                System.setSecurityManager(originalSecurityManager);\n            }\n            Files.deleteIfExists(modularBlockhoundJar);\n        }\n    }\n\n    private static Path writeModularBlockhoundJar() throws Exception {\n        Path blockhoundJar = Path.of(NexusAccessor.class.getProtectionDomain().getCodeSource().getLocation().toURI());\n        Path modularJar = Files.createTempFile(\"blockhound-byte-buddy-module\", \".jar\");\n        try (JarFile sourceJar = new JarFile(blockhoundJar.toFile());\n             JarOutputStream outputStream = new JarOutputStream(Files.newOutputStream(modularJar))) {\n            outputStream.putNextEntry(new JarEntry(\"module-info.class\"));\n            outputStream.write(BLOCKHOUND_COPY_MODULE_INFO);\n            outputStream.closeEntry();\n            Enumeration<JarEntry> entries = sourceJar.entries();\n            while (entries.hasMoreElements()) {\n                JarEntry sourceEntry = entries.nextElement();\n                if (!\"module-info.class\".equals(sourceEntry.getName())) {\n                    copyJarEntry(sourceJar, sourceEntry, outputStream);\n                }\n            }\n        }\n        return modularJar;\n    }\n\n    private static void copyJarEntry(\n            JarFile sourceJar,\n            JarEntry sourceEntry,\n            JarOutputStream outputStream) throws Exception {\n        outputStream.putNextEntry(new JarEntry(sourceEntry.getName()));\n        if (!sourceEntry.isDirectory()) {\n            try (InputStream inputStream = sourceJar.getInputStream(sourceEntry)) {\n                copy(inputStream, outputStream);\n            }\n        }\n        outputStream.closeEntry();\n    }\n\n    private static void copy(InputStream inputStream, OutputStream outputStream) throws Exception {\n        byte[] buffer = new byte[8192];\n        int length;\n        while ((length = inputStream.read(buffer)) != -1) {\n            outputStream.write(buffer, 0, length);\n        }\n    }\n\n    private static final class DenyByteBuddyNexusDefinitionSecurityManager extends SecurityManager {\n        @Override\n        public void checkPermission(Permission permission) {\n            if (permission instanceof RuntimePermission\n                    && permission.getName().equals(\"defineClassInPackage.\"\n                    + \"reactor.blockhound.shaded.net.bytebuddy.dynamic\")\n                    && isByteBuddyClassInjectionOnStack()) {\n                throw new SecurityException(\"Use the system class loader's existing Nexus class\");\n            }\n        }\n\n        private static boolean isByteBuddyClassInjectionOnStack() {\n            for (StackTraceElement element : Thread.currentThread().getStackTrace()) {\n                if (element.getClassName().contains(\".dynamic.loading.ClassInjector\")) {\n                    return true;\n                }\n            }\n            return false;\n        }\n    }\n\n    private static final class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {\n        private final AtomicReference<Class<?>> initializedType;\n\n        private RecordingLoadedTypeInitializer(AtomicReference<Class<?>> initializedType) {\n            this.initializedType = initializedType;\n        }\n\n        @Override\n        public void onLoad(Class<?> type) {\n            initializedType.set(type);\n        }\n\n        @Override\n        public boolean isAlive() {\n            return true;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781115174083}, {"role": "toolResult", "toolCallId": "call_6CscLybPcokioxa8nJx50Bef|fc_04c68fc177858740016a29a925d8848197847591281c9fa097", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.Nexus;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.NexusAccessor;\nimport reactor.blockhound.shaded.net.bytebuddy.implementation.LoadedTypeInitializer;\n\nimport java.util.concurrent.atomic.AtomicInteger;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class NexusTest {\n    @Test\n    void initializeInvokesRegisteredLoadedTypeInitializerOnce() throws Exception {\n        try {\n            int identification = (int) System.nanoTime();\n            RecordingLoadedTypeInitializer initializer = new RecordingLoadedTypeInitializer();\n\n            new NexusAccessor().register(\n                    Target.class.getName(),\n                    Target.class.getClassLoader(),\n                    identification,\n                    initializer);\n\n            Nexus.initialize(Target.class, identification);\n            Nexus.initialize(Target.class, identification);\n\n            assertThat(initializer.initializedType).hasValue(Target.class);\n            assertThat(initializer.invocations).hasValue(1);\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    public static class Target {\n    }\n\n    private static final class RecordingLoadedTypeInitializer implements LoadedTypeInitializer {\n        private final AtomicReference<Class<?>> initializedType = new AtomicReference<>();\n        private final AtomicInteger invocations = new AtomicInteger();\n\n        @Override\n        public void onLoad(Class<?> type) {\n            initializedType.set(type);\n            invocations.incrementAndGet();\n        }\n\n        @Override\n        public boolean isAlive() {\n            return true;\n        }\n    }\n}\n"}], "isError": false, "timestamp": 1781115174086}, {"role": "toolResult", "toolCallId": "call_bv69u94FB8eTA8elIgY7FeLF|fc_04c68fc177858740016a29a925d88c8197a0852eb8b861e03f", "toolName": "read", "content": [{"type": "text", "text": "/*\n * Copyright and related rights waived via CC0\n *\n * You should have received a copy of the CC0 legalcode along with this\n * work. If not, see <http://creativecommons.org/publicdomain/zero/1.0/>.\n */\npackage io_projectreactor_tools.blockhound;\n\nimport org.junit.jupiter.api.Test;\nimport reactor.blockhound.shaded.net.bytebuddy.agent.Installer;\nimport reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassReloadingStrategy;\n\nimport java.io.IOException;\nimport java.io.InputStream;\nimport java.lang.instrument.ClassDefinition;\nimport java.lang.instrument.ClassFileTransformer;\nimport java.lang.instrument.Instrumentation;\nimport java.lang.instrument.UnmodifiableClassException;\nimport java.lang.invoke.MethodHandle;\nimport java.lang.invoke.MethodHandles;\nimport java.lang.invoke.MethodType;\nimport java.lang.module.Configuration;\nimport java.lang.module.ModuleFinder;\nimport java.net.URISyntaxException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.util.Base64;\nimport java.util.Enumeration;\nimport java.util.HashSet;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.Set;\nimport java.util.jar.JarEntry;\nimport java.util.jar.JarFile;\nimport java.util.jar.JarOutputStream;\nimport java.util.stream.Stream;\n\nimport static org.assertj.core.api.Assertions.assertThat;\n\npublic class ClassReloadingStrategyTest {\n    private static final String BYTE_BUDDY_COPY_MODULE = \"blockhound.bytebuddy.loading.copy\";\n    private static final String BYTE_BUDDY_PACKAGE_ROOT = \"reactor/blockhound/shaded/net/bytebuddy/\";\n    private static final String CLASS_RELOADING_STRATEGY_NAME =\n            \"reactor.blockhound.shaded.net.bytebuddy.dynamic.loading.ClassReloadingStrategy\";\n    private static final byte[] BYTE_BUDDY_COPY_MODULE_INFO = Base64.getDecoder().decode(\n            \"yv66vgAAADUADwcAAgEAC21vZHVsZS1pbmZvAQAKU291cmNlRmlsZQEAEG1vZHVsZS1pbmZvLmphdmEB\"\n                    + \"AAZNb2R1bGUTAAcBACFibG9ja2hvdW5kLmJ5dGVidWRkeS5sb2FkaW5nLmNvcHkTAAkBAAlqYXZhLmJh\"\n                    + \"c2UBAAE5EwAMAQAPamF2YS5pbnN0cnVtZW50FAAOAQA3cmVhY3Rvci9ibG9ja2hvdW5kL3NoYWRlZC9u\"\n                    + \"ZXQvYnl0ZWJ1ZGR5L2R5bmFtaWMvbG9hZGluZ4AAAAEAAAAAAAAAAAACAAMAAAACAAQABQAAACIABgAA\"\n                    + \"AAAAAgAIgAAACgALAAAACgABAA0AAAAAAAAAAAAA\");\n\n    @Test\n    void fromInstalledAgentResolvesInstrumentationFromSystemInstaller() throws Throwable {\n        try {\n            Instrumentation instrumentation = new RetransformCapableInstrumentation();\n            Installer.premain(null, instrumentation);\n            try {\n                assertThat(ClassReloadingStrategy.fromInstalledAgent()).isNotNull();\n                assertThat(fromNamedModule()).isNotNull();\n            } finally {\n                Installer.premain(null, null);\n            }\n        } catch (Throwable throwable) {\n            BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);\n        }\n    }\n\n    private static Object fromNamedModule() throws Throwable {\n        Path modularJar = writeModularByteBuddyJar();\n        try {\n            ModuleFinder finder = ModuleFinder.of(modularJar);\n            Configuration configuration = ModuleLayer.boot().configuration()\n                    .resolve(finder, ModuleFinder.of(), Set.of(BYTE_BUDDY_COPY_MODULE));\n            ModuleLayer layer = ModuleLayer.boot()\n                    .defineModulesWithOneLoader(configuration, ClassLoader.getPlatformClassLoader());\n            Class<?> classReloadingStrategy = layer.findLoader(BYTE_BUDDY_COPY_MODULE)\n                    .loadClass(CLASS_RELOADING_STRATEGY_NAME);\n            MethodType methodType = MethodType.methodType(classReloadingStrategy);\n            MethodHandle fromInstalledAgent = MethodHandles.publicLookup()\n                    .findStatic(classReloadingStrategy, \"fromInstalledAgent\", methodType);\n            return fromInstalledAgent.invoke();\n        } finally {\n            Files.deleteIfExists(modularJar);\n        }\n    }\n\n    private static Path writeModularByteBuddyJar() throws IOException, URISyntaxException {\n        Path jar = Files.createTempFile(\"blockhound-byte-buddy-loading-module\", \".jar\");\n        Set<String> addedEntries = new HashSet<>();\n        try (JarOutputStream jarOutputStream = new JarOutputStream(Files.newOutputStream(jar))) {\n            writeEntry(jarOutputStream, addedEntries, \"module-info.class\", BYTE_BUDDY_COPY_MODULE_INFO);\n            Path codeSource = Path.of(ClassReloadingStrategy.class.getProtectionDomain()\n                    .getCodeSource()\n                    .getLocation()\n                    .toURI());\n            if (Files.isDirectory(codeSource)) {\n                copyByteBuddyClassesFromDirectory(codeSource, jarOutputStream, addedEntries);\n            } else {\n                copyByteBuddyClassesFromJar(codeSource, jarOutputStream, addedEntries);\n            }\n        }\n        return jar;\n    }\n\n    private static void copyByteBuddyClassesFromDirectory(\n            Path root,\n            JarOutputStream jarOutputStream,\n            Set<String> addedEntries) throws IOException {\n        try (Stream<Path> paths = Files.walk(root.resolve(BYTE_BUDDY_PACKAGE_ROOT))) {\n            paths.filter(Files::isRegularFile)\n                    .filter(path -> path.getFileName().toString().endsWith(\".class\"))\n                    .forEach(path -> copyDirectoryClass(root, path, jarOutputStream, addedEntries));\n        }\n    }\n\n    private static void copyDirectoryClass(\n            Path root,\n            Path path,\n            JarOutputStream jarOutputStream,\n            Set<String> addedEntries) {\n        String entryName = root.relativize(path).toString().replace('\\\\', '/');\n        try {\n            writeEntry(jarOutputStream, addedEntries, entryName, Files.readAllBytes(path));\n        } catch (IOException exception) {\n            throw new IllegalStateException(\"Could not copy Byte Buddy class \" + entryName, exception);\n        }\n    }\n\n    private static void copyByteBuddyClassesFromJar(\n            Path sourceJar,\n            JarOutputStream jarOutputStream,\n            Set<String> addedEntries) throws IOException {\n        try (JarFile jarFile = new JarFile(sourceJar.toFile())) {\n            Enumeration<JarEntry> entries = jarFile.entries();\n            while (entries.hasMoreElements()) {\n                JarEntry entry = entries.nextElement();\n                if (!entry.isDirectory()\n                        && entry.getName().startsWith(BYTE_BUDDY_PACKAGE_ROOT)\n                        && entry.getName().endsWith(\".class\")) {\n                    try (InputStream inputStream = jarFile.g