  1269:         /**
  1270:          * Returns an agent-based class file locator for the given class loader and an already installed
  1271:          * Byte Buddy-agent.
  1272:          *
  1273:          * @param classLoader The class loader that is expected to load the looked-up a class.
  1274:          * @return A class file locator for the given class loader based on a Byte Buddy agent.
  1275:          */
  1276:         public static ClassFileLocator fromInstalledAgent(@MaybeNull ClassLoader classLoader) {
  1277:             return new ForInstrumentation(resolveByteBuddyAgentInstrumentation(), classLoader);
  1278:         }
