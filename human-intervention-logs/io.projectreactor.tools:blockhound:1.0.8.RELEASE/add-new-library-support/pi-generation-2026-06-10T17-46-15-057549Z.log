  1280:         /**
  1281:          * Returns a class file locator that is capable of locating a class file for the given type using the given instrumentation instance.
  1282:          *
  1283:          * @param instrumentation The instrumentation instance to query for a retransformation.
  1284:          * @param type            The locatable type which class loader is used as a fallback.
  1285:          * @return A class file locator for locating the class file of the given type.
  1286:          */
  1287:         public static ClassFileLocator of(Instrumentation instrumentation, Class<?> type) {
  1288:             return new ForInstrumentation(instrumentation, ClassLoadingDelegate.Explicit.of(type));
  1289:         }
