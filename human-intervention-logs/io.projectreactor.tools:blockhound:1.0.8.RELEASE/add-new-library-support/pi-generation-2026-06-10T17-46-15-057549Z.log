  package io_projectreactor_tools.blockhound;
  
  import org.junit.jupiter.api.Test;
  import reactor.blockhound.shaded.net.bytebuddy.dynamic.ClassFileLocator;
  
  import java.lang.reflect.Field;
  import java.util.Vector;
  
  import static org.assertj.core.api.Assertions.assertThat;
  
  public class ClassFileLocatorInnerForInstrumentationInnerClassLoadingDelegateInnerForDelegatingClassLoaderInnerDispatcherInnerResolvedTest {
      @Test
      void resolvedDispatcherExtractsLoadedClassesFromClassLoaderField() throws Exception {
          VectorBackedClassLoader classLoader = new VectorBackedClassLoader(getClass().getClassLoader(), LoadedType.class);
          Field classesField = VectorBackedClassLoader.class.getDeclaredField("classes");
          ResolvedDispatcherAccessor accessor = new ResolvedDispatcherAccessor(classLoader);
  
          try {
              Vector<Class<?>> loadedClasses = accessor.extract(classesField, classLoader);
  
              assertThat(loadedClasses).containsExactly(LoadedType.class);
          } catch (Throwable throwable) {
              BlockHoundNativeImageSupport.rethrowIfNotExpectedNativeImageFailure(throwable);
          }
      }
  
      private static final class LoadedType {
      }
  
      private static final class VectorBackedClassLoader extends ClassLoader {
          private final Vector<Class<?>> classes = new Vector<>();
  
          private VectorBackedClassLoader(ClassLoader parent, Class<?> loadedType) {
              super(parent);
              classes.add(loadedType);
          }
      }
  
      private static final class ResolvedDispatcherAccessor
              extends ClassFileLocator.ForInstrumentation.ClassLoadingDelegate.ForDelegatingClassLoader {
          private ResolvedDispatcherAccessor(ClassLoader classLoader) {
              super(classLoader);
          }
  
          private Vector<Class<?>> extract(Field classesField, ClassLoader classLoader) {
              Dispatcher dispatcher = new Dispatcher.Resolved(classesField).initialize();
              return dispatcher.extract(classLoader);
          }
      }
  }
