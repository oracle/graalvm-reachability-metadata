inedClass.getName()).isEqualTo(className);\n        assertThat(definedClass.getClassLoader()).isSameAs(classLoader);\n        assertThat(dispatcher.findClass(classLoader, className)).isSameAs(definedClass);\n    }\n\n    private static Method accessorMethod(String name, Class<?>... parameterTypes) throws NoSuchMethodException {\n        return Accessor.class.getMethod(name, parameterTypes);\n    }\n\n    private static final class HarnessDispatcher extends Dispatcher.UsingUnsafeInjection {\n        private HarnessDispatcher(Object accessor, Method findLoadedClass, Method defineClass,\n                Method getDefinedPackage, Method getPackage, Method definePackage,\n                Method getClassLoadingLock) {\n            super(accessor, findLoadedClass, defineClass, getDefinedPackage, getPackage,\n                    definePackage, getClassLoadingLock);\n        }\n    }\n}\n\nfinal class Accessor {\n    public Object getClassLoadingLock(ClassLoader classLoader, String name) {\n        return classLoader;\n    }\n\n    public Class<?> findLoadedClass(ClassLoader classLoader, String name) {\n        try {\n            return Class.forName(name, false, classLoader);\n        } catch (ClassNotFoundException exception) {\n            return null;\n        }\n    }\n\n    public Class<?> defineClass(ClassLoader classLoader, String name, byte[] binaryRepresentation,\n            int offset, int length, ProtectionDomain protectionDomain) {\n        return ((DispatcherClassLoader) classLoader)\n                .defineClassForTest(name, binaryRepresentation, offset, length, protectionDomain);\n    }\n\n    public Package getDefinedPackage(ClassLoader classLoader, String name) {\n        return ((DispatcherClassLoader) classLoader).getDefinedPackageForTest(name);\n    }\n\n    public Package getPackage(ClassLoader classLoader, String name) {\n        return ((DispatcherClassLoader) classLoader).getPackageForTest(name);\n    }\n\n    public Package definePackage(ClassLoader classLoader, String name, String specificationTitle,\n            String specificationVersion, String specificationVendor, String implementationTitle,\n            String implementationVersion, String implementationVendor, URL sealBase) {\n        return ((DispatcherClassLoader) classLoader).definePackageForTest(\n                name,\n                specificationTitle,\n                specificationVersion,\n                specificationVendor,\n                implementationTitle,\n                implementationVersion,\n                implementationVendor,\n                sealBase);\n    }\n}\n\nfinal class DispatcherClassLoader extends ClassLoader {\n    private DispatcherClassLoader(ClassLoader parent) {\n        super(parent);\n    }\n\n    Class<?> defineClassForTest(String name, byte[] binaryRepresentation, int offset,\n            int length, ProtectionDomain protectionDomain) {\n        return defineClass(name, binaryRepresentation, offset, length, protectionDomain);\n    }\n\n    Package definePackageForTest(String name, String specificationTitle,\n            String specificationVersion, String specificationVendor, String implementationTitle,\n            String implementationVersion, String implementationVendor, URL sealBase) {\n        return definePackage(name, specificationTitle, specificationVersion, specificationVendor,\n                implementationTitle, implementationVersion, implementationVendor, sealBase);\n    }\n\n    Package getDefinedPackageForTest(String name) {\n        return getDefinedPackage(name);\n    }\n\n    Package getPackageForTest(String name) {\n        return getPackage(name);\n    }\n}\n"}]}
